{
    "name": "@repo/db",
    "version": "0.1.0",
    "description": "Database layer using Drizzle ORM and PostgreSQL",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./client": {
            "types": "./src/client.ts",
            "import": "./src/client.ts"
        },
        "./schemas": {
            "types": "./src/schemas/index.ts",
            "import": "./src/schemas/index.ts"
        },
        "./schemas/billing": {
            "types": "./src/schemas/billing/index.ts",
            "import": "./src/schemas/billing/index.ts"
        }
    },
    "files": ["dist"],
    "scripts": {
        "drizzle-kit": "tsx node_modules/drizzle-kit/bin.cjs",
        "build": "tsup",
        "dev": "echo 'Dev mode uses tsconfig paths (no build)'",
        "lint": "biome check .",
        "format": "biome format --write .",
        "check": "biome check --write .",
        "clean": "rm -rf node_modules dist",
        "typecheck": "tsc --noEmit --project ./tsconfig.json",
        "db:migrate": "pnpm run drizzle-kit push --config drizzle.config.ts",
        "db:generate": "pnpm run drizzle-kit generate --config drizzle.config.ts",
        "db:studio": "pnpm run drizzle-kit studio --config drizzle.config.ts",
        "db:regenerate": "pnpm run db:generate -- --force && pnpm run db:migrate",
        "db:enum-migration": "tsx ./scripts/generate-enum-migrations.ts && tsx ./scripts/apply-latest-enum-migration.ts",
        "db:reset": "pnpm run db:drop && pnpm run db:push",
        "db:drop": "pnpm run drizzle-kit drop --config drizzle.config.ts",
        "db:push": "pnpm run drizzle-kit push --config drizzle.config.ts",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:file": "vitest run --passWithNoTests",
        "test:coverage": "vitest run --coverage",
        "test:integration": "vitest run --config vitest.config.integration.ts --passWithNoTests"
    },
    "dependencies": {
        "@qazuor/qzpay-core": "^1.2.0",
        "@qazuor/qzpay-drizzle": "^1.3.0",
        "@repo/billing": "workspace:*",
        "@repo/config": "workspace:*",
        "@repo/logger": "workspace:*",
        "@repo/schemas": "workspace:*",
        "@repo/utils": "workspace:*",
        "bcryptjs": "^3.0.2",
        "drizzle-orm": "^0.44.7"
    },
    "devDependencies": {
        "@repo/typescript-config": "workspace:*",
        "@types/bcrypt": "^5.0.2",
        "@types/node": "^22.15.3",
        "@types/pg": "^8.15.1",
        "@vitest/coverage-v8": "^3.1.3",
        "@vitest/ui": "^3.1.4",
        "c8": "^10.1.3",
        "dotenv": "^16.4.5",
        "drizzle-kit": "^0.31.5",
        "pg": "^8.11.1",
        "tsup": "^8.4.0",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.1.3"
    },
    "peerDependencies": {
        "pg": "^8.11.1"
    }
}
