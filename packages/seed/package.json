{
    "name": "@repo/seed",
    "version": "0.1.0",
    "description": "Database seeding package",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "require": "./src/index.ts"
        }
    },
    "files": ["dist"],
    "scripts": {
        "lint": "biome check .",
        "format": "biome format --write .",
        "check": "biome check --write .",
        "clean": "rm -rf node_modules dist",
        "seed": "tsx --tsconfig ./tsconfig.json ./src/cli.ts",
        "seed:required": "tsx --tsconfig ./tsconfig.json ./src/seeds/required.seed.ts",
        "seed:example": "tsx --tsconfig ./tsconfig.json ./src/seeds/example.seed.ts",
        "seed:test-users": "tsx --tsconfig ./tsconfig.json ./src/cli.ts --test-users",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest --passWithNoTests",
        "test:coverage": "vitest run --coverage --passWithNoTests",
        "migrate:accommodation-prices": "tsx --tsconfig ./tsconfig.json ./scripts/migrate-accommodation-prices.ts",
        "validate:accommodations": "tsx --tsconfig ./tsconfig.json ./scripts/validate-fix-accommodations.ts",
        "lint:image-pool": "tsx --tsconfig ./tsconfig.json ./scripts/check-image-pool-coverage.ts",
        "seed:ready-user": "tsx --tsconfig ./tsconfig.json ./scripts/mark-user-ready.ts"
    },
    "dependencies": {
        "@repo/ai-core": "workspace:*",
        "@repo/billing": "workspace:*",
        "@repo/config": "workspace:*",
        "@repo/db": "workspace:*",
        "@repo/logger": "workspace:*",
        "@repo/media": "workspace:*",
        "@repo/schemas": "workspace:*",
        "@repo/service-core": "workspace:*",
        "@repo/utils": "workspace:*",
        "bcryptjs": "^3.0.2",
        "dotenv": "^17.2.1",
        "drizzle-orm": "^0.45.2",
        "pg": "^8.11.1",
        "zod": "^4.0.8"
    },
    "devDependencies": {
        "@repo/typescript-config": "workspace:*",
        "@types/bcryptjs": "^3.0.0",
        "@types/node": "^25.9.3",
        "@types/pg": "^8.15.1",
        "@vitest/coverage-v8": "^3.1.3",
        "tsup": "^8.5.1",
        "tsx": "^4.22.4",
        "typescript": "^5.9.3",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.1.3"
    }
}
