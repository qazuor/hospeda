{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "eventLocation.schema.json",
    "title": "EventLocation Seed Schema",
    "description": "JSON schema for EventLocation entity seeds (post SPEC-095). Geographic context (city/state/country) lives on the related destination, not on the event location row.",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string"
        },
        "id": {
            "type": "string",
            "description": "EventLocation ID (UUID)"
        },
        "slug": {
            "type": "string",
            "description": "URL-friendly slug for the location"
        },
        "destinationId": {
            "type": "string",
            "description": "FK to a destination of type CITY (resolved at seed time)"
        },
        "coordinates": {
            "type": "object",
            "properties": {
                "lat": {
                    "type": "string",
                    "description": "Latitude"
                },
                "long": {
                    "type": "string",
                    "description": "Longitude"
                }
            },
            "required": ["lat", "long"],
            "additionalProperties": false
        },
        "street": {
            "type": "string",
            "description": "Street address"
        },
        "number": {
            "type": "string",
            "description": "Street number"
        },
        "floor": {
            "type": "string",
            "description": "Floor number"
        },
        "apartment": {
            "type": "string",
            "description": "Apartment number"
        },
        "placeName": {
            "type": "string",
            "description": "Place name"
        },
        "lifecycleState": {
            "type": "string",
            "enum": ["DRAFT", "ACTIVE", "ARCHIVED"],
            "description": "Lifecycle state of the event location"
        }
    },
    "required": ["id", "destinationId", "lifecycleState"],
    "additionalProperties": false
}
