{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "amenity.schema.json",
    "title": "Amenity Seed Schema",
    "description": "JSON schema for Amenity entity seeds",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string"
        },
        "id": {
            "type": "string",
            "description": "Amenity ID (UUID)"
        },
        "slug": {
            "type": "string",
            "description": "Amenity slug"
        },
        "description": {
            "type": "object",
            "description": "Amenity description (i18n text object)"
        },
        "applicableVerticals": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": ["accommodation", "gastronomy", "experience"]
            },
            "minItems": 1,
            "description": "Verticals this amenity applies to (SPEC-266)"
        },
        "type": {
            "type": "string",
            "enum": [
                "CLIMATE_CONTROL",
                "CONNECTIVITY",
                "ENTERTAINMENT",
                "KITCHEN",
                "BED_AND_BATH",
                "OUTDOORS",
                "ACCESSIBILITY",
                "SERVICES",
                "SAFETY",
                "FAMILY_FRIENDLY",
                "WORK_FRIENDLY",
                "GENERAL_APPLIANCES"
            ],
            "description": "Amenity type"
        },
        "icon": {
            "type": "string",
            "description": "Amenity icon identifier"
        },
        "isBuiltin": {
            "type": "boolean",
            "description": "Whether this amenity is built-in (system default)"
        },
        "isFeatured": {
            "type": "boolean",
            "description": "Whether this amenity is featured (highlighted in UI)"
        },
        "displayWeight": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "Display weight for ordering"
        },
        "adminInfo": {
            "$ref": "common.schema.json#/definitions/adminInfo"
        }
    },
    "required": ["id", "slug", "type", "isBuiltin", "isFeatured", "applicableVerticals"],
    "additionalProperties": false
}
