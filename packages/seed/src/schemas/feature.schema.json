{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "feature.schema.json",
    "title": "Feature Seed Schema",
    "description": "JSON schema for Feature entity seeds",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string"
        },
        "id": {
            "type": "string",
            "description": "Feature ID (UUID)"
        },
        "slug": {
            "type": "string",
            "description": "Feature slug"
        },
        "description": {
            "type": "object",
            "description": "Feature description (i18n text object)"
        },
        "applicableVerticals": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": ["accommodation", "gastronomy", "experience"]
            },
            "minItems": 1,
            "description": "Verticals this feature applies to (SPEC-266)"
        },
        "icon": {
            "type": "string",
            "description": "Feature icon identifier"
        },
        "isBuiltin": {
            "type": "boolean",
            "description": "Whether this feature is built-in (system default)"
        },
        "isFeatured": {
            "type": "boolean",
            "description": "Whether this feature is highlighted (featured) in the UI"
        },
        "displayWeight": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "description": "Display weight for ordering"
        },
        "lifecycleState": {
            "type": "string",
            "enum": ["DRAFT", "ACTIVE", "ARCHIVED"],
            "description": "Lifecycle state of the feature"
        }
    },
    "required": ["id", "slug", "isBuiltin", "isFeatured", "lifecycleState", "applicableVerticals"],
    "additionalProperties": false
}
