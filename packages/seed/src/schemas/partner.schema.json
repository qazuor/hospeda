{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "partner.schema.json",
    "title": "Partner Seed Schema",
    "description": "JSON schema for Partner entity seeds (brand/business directory, SPEC-271)",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string"
        },
        "id": {
            "type": "string",
            "description": "Fixture seed id (used for idMapper, not the DB id)"
        },
        "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "URL-safe unique slug"
        },
        "name": {
            "type": "string",
            "description": "Partner display name"
        },
        "type": {
            "type": "string",
            "enum": ["commerce", "ngo", "institution"],
            "description": "Partner type (PartnerTypeEnum)"
        },
        "tier": {
            "type": "string",
            "enum": ["bronze", "silver", "gold"],
            "description": "Partner tier (PartnerTierEnum)"
        },
        "logoUrl": {
            "type": "string",
            "format": "uri",
            "description": "Logo image URL"
        },
        "websiteUrl": {
            "type": "string",
            "format": "uri",
            "description": "Partner website URL"
        },
        "description": {
            "type": "string",
            "description": "Short description of the partner"
        },
        "subscriptionStatus": {
            "type": "string",
            "enum": ["pending", "active", "past_due", "cancelled"],
            "description": "Partner billing subscription status (PartnerSubscriptionStatusEnum)"
        },
        "lifecycleState": {
            "type": "string",
            "enum": ["ACTIVE", "INACTIVE", "ARCHIVED", "SUSPENDED"],
            "description": "Lifecycle state (LifecycleStatusEnum)"
        },
        "startsAt": {
            "type": "string",
            "format": "date-time",
            "description": "Date the partnership started"
        },
        "endsAt": {
            "type": "string",
            "format": "date-time",
            "description": "Date the partnership ends (omit for ongoing)"
        }
    },
    "required": [
        "id",
        "slug",
        "name",
        "type",
        "tier",
        "subscriptionStatus",
        "lifecycleState",
        "startsAt"
    ],
    "additionalProperties": false
}
