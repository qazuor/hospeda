/* Admin dark theme — combined selector requires both flags. */
[data-app="admin"][data-theme="dark"] {
    --color-primary: oklch(0.702 0.171 259);
    --color-primary-hover: oklch(0.774 0.152 259);
    --color-primary-pressed: oklch(0.63 0.19 259);
    --color-accent: oklch(0.7 0.18 55);
