    --color-fg-primary: oklch(0.95 0 0);
    --color-fg-secondary: oklch(0.7 0 0);
    --color-fg-muted: oklch(0.55 0 0);
    --color-border: oklch(0.3 0 0);
    --color-success: oklch(0.58 0.15 150);
    --color-warning: oklch(0.75 0.18 85);
    --color-danger: oklch(0.577 0.245 27.325);
    --color-info: oklch(0.63 0.19 259);
    --brand-primary: oklch(0.68 0.17 259);
    --brand-accent: oklch(0.72 0.19 55);
    --brand-secondary: oklch(0.25 0.05 255);
    --muted: oklch(0.22 0.02 220);
    --info: oklch(0.68 0.17 259);
    --warning: oklch(0.78 0.18 85);
    --warning-foreground: oklch(0.1 0.02 85);
    --core-foreground: oklch(0.92 0.01 210);
}
"
