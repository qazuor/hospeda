    --color-bg-app: oklch(0.97 0.006 259);
    --color-bg-elevated: oklch(1 0 0);
    --color-fg-primary: oklch(0.1 0 0);
    --color-fg-secondary: oklch(0.3 0 0);
    --color-fg-muted: oklch(0.55 0 0);
    --color-border: oklch(0.9 0 0);
    --color-success: oklch(0.46 0.131 150);
    --color-warning: oklch(0.588 0.158 85);
    --color-danger: oklch(0.458 0.214 27.325);
    --color-info: oklch(0.498 0.166 259);
    --font-body: "Roboto", sans-serif;
    --font-heading: "Geologica", sans-serif;
    --radius: 0.75rem;
    --brand-primary: oklch(0.63 0.19 259);
    --brand-accent: oklch(0.7 0.18 55);
    --brand-secondary: oklch(0.96 0.02 236);
    --hospeda-river: oklch(0.63 0.19 259);
    --hospeda-sky: oklch(0.8 0.08 259);
    --hospeda-forest: oklch(0.5 0.14 155);
    --hospeda-sand: oklch(0.7 0.12 75);
    --muted: oklch(0.95 0.01 210);
    --info: oklch(0.63 0.19 259);
    --warning: oklch(0.75 0.18 85);
    --warning-foreground: oklch(0.2 0.02 85);
    --core-foreground: oklch(0.2 0.02 220);
    --accommodation-type-hotel: var(--palette-accent-500);
    --accommodation-type-apartment: var(--palette-river-500);
    --accommodation-type-house: var(--palette-forest-500);
    --accommodation-type-country-house: var(--palette-teal-500);
    --accommodation-type-cabin: var(--palette-terracotta-500);
    --accommodation-type-camping: var(--palette-sand-500);
    --accommodation-type-hostel: var(--palette-cyan-500);
    --accommodation-type-room: var(--palette-rose-500);
    --accommodation-type-motel: var(--palette-danger-500);
    --accommodation-type-resort: var(--palette-purple-500);
}

/* Admin dark theme — combined selector requires both flags. */
[data-app="admin"][data-theme="dark"] {
    --color-primary: oklch(0.702 0.171 259);
    --color-primary-hover: oklch(0.774 0.152 259);
    --color-primary-pressed: oklch(0.63 0.19 259);
    --color-accent: oklch(0.7 0.18 55);
    --color-bg-app: oklch(0.1 0 0);
    --color-bg-elevated: oklch(0.18 0 0);
    --color-fg-primary: oklch(0.95 0 0);
    --color-fg-secondary: oklch(0.7 0 0);
    --color-fg-muted: oklch(0.55 0 0);
    --color-border: oklch(0.3 0 0);
    --color-success: oklch(0.58 0.15 150);
    --color-warning: oklch(0.75 0.18 85);
    --color-danger: oklch(0.577 0.245 27.325);
    --color-info: oklch(0.63 0.19 259);
    --brand-primary: oklch(0.68 0.17 259);
    --brand-accent: oklch(0.72 0.19 55);
    --brand-secondary: oklch(0.25 0.05 255);
    --muted: oklch(0.22 0.02 220);
    --info: oklch(0.68 0.17 259);
    --warning: oklch(0.78 0.18 85);
    --warning-foreground: oklch(0.1 0.02 85);
    --core-foreground: oklch(0.92 0.01 210);
}
"
`;
