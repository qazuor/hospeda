/* Viewport-conditional overrides from layoutMediaOverrides. */
@media (min-width: 1600px) {
    :root {
        --container-max: 1500px;
    }
}

/* Web dark theme — opt-in, scoped to NOT apply when admin is mounted. */
[data-theme="dark"]:not([data-app="admin"]) {
    --core-background: oklch(0.14 0.02 220);
    --core-foreground: oklch(0.92 0.01 210);
    --core-card: oklch(0.19 0.02 220);
    --card-foreground: oklch(0.92 0.01 210);
    --popover: oklch(0.19 0.02 220);
    --popover-foreground: oklch(0.92 0.01 210);
    --brand-primary: oklch(0.68 0.17 259);
    --primary-foreground: oklch(0.1 0.02 259);
    --brand-secondary: oklch(0.25 0.05 255);
    --brand-secondary-foreground: oklch(0.8 0.08 255);
    --brand-tertiary: oklch(0.28 0.05 155);
    --muted: oklch(0.22 0.02 220);
    --core-muted-foreground: oklch(0.6 0.03 261);
    --brand-accent: oklch(0.72 0.19 55);
    --rating-star: oklch(0.85 0.19 95);
    --accent-foreground: oklch(0.1 0.01 55);
    --destructive: oklch(0.6 0.22 27);
    --destructive-foreground: oklch(0.98 0 0);
    --overlay: oklch(0.05 0.01 220 / 0.7);
    --border: oklch(0.28 0.02 220);
    --input: oklch(0.28 0.02 220);
    --ring: oklch(0.68 0.17 259);
    --chart-1: oklch(0.68 0.17 259);
    --chart-2: oklch(0.68 0.15 155);
    --chart-3: oklch(0.72 0.19 55);
    --chart-4: oklch(0.78 0.11 190);
    --chart-5: oklch(0.62 0.1 240);
    --primary-hover: oklch(from var(--brand-primary) calc(l + 0.07) c h);
    --accent-hover: oklch(from var(--brand-accent) calc(l + 0.07) c h);
    --brand-primary-dark: oklch(from var(--brand-primary) calc(l - 0.08) c h);
    --success: oklch(0.65 0.16 150);
    --success-foreground: oklch(0.1 0.02 150);
    --warning: oklch(0.78 0.18 85);
    --warning-foreground: oklch(0.1 0.02 85);
    --info: oklch(0.68 0.17 259);
    --info-foreground: oklch(0.1 0.02 259);
    --surface-warm: oklch(0.2 0.03 50);
    --surface-dark: oklch(0.1 0.02 160);
    --surface-elevated: oklch(0.24 0.025 220);
    --footer-bg: oklch(0.12 0.02 220);
    --footer-fg: oklch(0.85 0.01 210);
    --footer-fg-muted: oklch(0.6 0.02 240);
    --footer-newsletter-bg: oklch(0.18 0.025 220);
    --footer-newsletter-fg: oklch(0.8 0.01 210);
    --footer-newsletter-border: oklch(0.3 0.02 220);
    --footer-link: oklch(0.65 0.01 210);
    --footer-link-hover: oklch(0.9 0.01 210);
    --footer-border: oklch(from var(--brand-accent) l c h / 0.2);
    --avatar-1-from: oklch(0.3 0.1 255);
    --avatar-1-to: oklch(0.42 0.14 255);
    --avatar-2-from: oklch(0.68 0.16 75);
    --avatar-2-to: oklch(0.8 0.18 80);
    --avatar-3-from: oklch(0.52 0.11 195);
    --avatar-3-to: oklch(0.68 0.14 195);
    --avatar-4-from: oklch(0.45 0.13 155);
    --avatar-4-to: oklch(0.65 0.17 155);
}

/* Admin light theme — applies whenever \`data-app="admin"\` is set on <html>. */
[data-app="admin"] {
    --color-primary: oklch(0.63 0.19 259);
    --color-primary-hover: oklch(0.702 0.171 259);
    --color-primary-pressed: oklch(0.498 0.166 259);
    --color-accent: oklch(0.55 0.158 55);
    --color-bg-app: oklch(0.97 0.006 259);
    --color-bg-elevated: oklch(1 0 0);
    --color-fg-primary: oklch(0.1 0 0);
    --color-fg-secondary: oklch(0.3 0 0);
    --color-fg-muted: oklch(0.55 0 0);
    --color-border: oklch(0.9 0 0);
    --color-success: oklch(0.46 0.131 150);
    --color-warning: oklch(0.588 0.158 85);
    --color-danger: oklch(0.458 0.214 27.325);
    --color-info: oklch(0.498 0.166 259);
    --font-body: "Roboto", sans-serif;
    --font-heading: "Geologica", sans-serif;
    --radius: 0.75rem;
    --brand-primary: oklch(0.63 0.19 259);
    --brand-accent: oklch(0.7 0.18 55);
    --brand-secondary: oklch(0.96 0.02 236);
    --hospeda-river: oklch(0.63 0.19 259);
    --hospeda-sky: oklch(0.8 0.08 259);
    --hospeda-forest: oklch(0.5 0.14 155);
