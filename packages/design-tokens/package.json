{
    "name": "@repo/design-tokens",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "license": "MIT",
    "description": "Shared design tokens (palette, typography, spacing, radius, shadows, motion) consumed by both apps/web and apps/admin. SPEC-153.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./tokens.css": "./dist/tokens.css",
        "./seed/web-baseline.json": "./seed/web-baseline.json"
    },
    "files": ["dist", "seed"],
    "scripts": {
        "build": "tsup && tsx src/generators/generate-css.ts && tsx src/generators/validate.ts",
        "build:ts": "tsup",
        "build:css": "tsx src/generators/generate-css.ts",
        "validate": "tsx src/generators/validate.ts",
        "extract:web": "tsx ../../scripts/extract-web-tokens.ts",
        "dev": "echo 'Dev mode uses tsconfig paths (no build)'",
        "typecheck": "tsc --noEmit --project ./tsconfig.json",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "lint": "biome check .",
        "format": "biome format --write .",
        "check": "biome check --write .",
        "clean": "rm -rf node_modules dist"
    },
    "devDependencies": {
        "@repo/typescript-config": "workspace:*",
        "@types/node": "^22.15.3",
        "@vitest/coverage-v8": "^3.1.3",
        "culori": "^4.0.2",
        "tsup": "^8.4.0",
        "tsx": "^4.20.4",
        "typescript": "^5.8.3",
        "vitest": "^3.1.3"
    }
}
