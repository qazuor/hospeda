{
    "name": "@repo/i18n",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "Shared internationalization package for Hospeda monorepo",
    "sideEffects": false,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./web": {
            "types": "./src/web.ts",
            "import": "./src/web.ts"
        },
        "./locales/*": "./src/locales/*"
    },
    "scripts": {
        "build": "tsx scripts/generate-types.ts",
        "generate-types": "tsx scripts/generate-types.ts",
        "check-locales": "tsx scripts/check-locales.ts",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage --passWithNoTests",
        "lint": "biome check .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit --project ./tsconfig.json",
        "clean": "rm -rf node_modules dist"
    },
    "dependencies": {
        "zod": "^4.0.8"
    },
    "peerDependencies": {
        "react": ">=18.2.0 || ^19"
    },
    "devDependencies": {
        "@repo/schemas": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@types/node": "^26.1.1",
        "@types/react": "^19.1.1",
        "@vitest/coverage-v8": "^4.1.10",
        "tsx": "^4.23.0",
        "typescript": "7.0.2",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.10"
    }
}
