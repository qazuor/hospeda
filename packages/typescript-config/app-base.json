{
    "extends": "./base.json",
    "compilerOptions": {
        "lib": ["es2022", "DOM", "DOM.Iterable"],
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "paths": {
            "@/*": ["./src/*"],
            "@repo/config": ["../../packages/config/src/index.ts"],
            "@repo/config/*": ["../../packages/config/src/*"],
            "@repo/db": ["../../packages/db/src/index.ts"],
            "@repo/db/*": ["../../packages/db/src/*"],
            "@repo/logger": ["../../packages/logger/src/index.ts"],
            "@repo/logger/*": ["../../packages/logger/src/*"],
            "@repo/schemas": ["../../packages/schemas/src/index.ts"],
            "@repo/schemas/*": ["../../packages/schemas/src/*"],
            "@repo/ui": ["../../packages/ui/src/index.ts"],
            "@repo/ui/*": ["../../packages/ui/src/*"],
            "@repo/utils": ["../../packages/utils/src/index.ts"],
            "@repo/utils/*": ["../../packages/utils/src/*"],
            "@repo/service-core": ["../../packages/service-core/src/index.ts"],
            "@repo/service-core/*": ["../../packages/service-core/src/*"],
            "@repo/seed": ["../../packages/seed/src/index.ts"],
            "@repo/seed/*": ["../../packages/seed/src/*"],
            "@repo/notifications": ["../../packages/notifications/src/index.ts"],
            "@repo/notifications/*": ["../../packages/notifications/src/*"],
            "@repo/i18n": ["../../packages/i18n/src/index.ts"],
            "@repo/i18n/*": ["../../packages/i18n/src/*"],
            "@repo/media": ["../../packages/media/src/index.ts"],
            "@repo/media/server": ["../../packages/media/src/server/index.ts"],
            "@repo/media/test-utils": ["../../packages/media/src/test-utils/index.ts"],
            "@repo/media/*": ["../../packages/media/src/*"],
            "@repo/email": ["../../packages/email/src/index.ts"],
            "@repo/email/*": ["../../packages/email/src/*"],
            "@repo/ai-core": ["../../packages/ai-core/src/index.ts"],
            "@repo/ai-core/*": ["../../packages/ai-core/src/*"],
            "@repo/feedback": ["../../packages/feedback/src/index.ts"],
            "@repo/feedback/*": ["../../packages/feedback/src/*"],
            "@repo/content-moderation": ["../../packages/content-moderation/src/index.ts"],
            "@repo/content-moderation/*": ["../../packages/content-moderation/src/*"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["dist", "node_modules"]
}
