{
    "root": false,
    "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "defaultBranch": "main",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**",
            "!**/node_modules",
            "!**/.turbo",
            "!**/dist",
            "!**/build",
            "!**/coverage",
            "!**/.output",
            "!**/.vinxi",
            "!**/tsup.config.bundled_*.mjs",
            "!**/routeTree.gen.ts",
            "!**/*.astro",
            "!**/docs/examples",
            "!**/mappings/id-mappings.json",
            "!**/.remember",
            "!**/test/**/fixtures",
            "!**/*.svg"
        ]
    },
    "css": {
        "parser": {
            "cssModules": true,
            "tailwindDirectives": true
        }
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "correctness": {
                "noUnusedVariables": "error",
                "noUnusedImports": "error"
            },
            "style": {
                "useConst": "error",
                "useTemplate": "error",
                "noNegationElse": "error",
                "noUselessElse": "error"
            },
            "suspicious": {
                "noExplicitAny": "error",
                "noVar": "error",
                "noConsole": {
                    "level": "error",
                    "options": {
                        "allow": [
                            "assert",
                            "clear",
                            "count",
                            "countReset",
                            "debug",
                            "dir",
                            "dirxml",
                            "error",
                            "group",
                            "groupCollapsed",
                            "groupEnd",
                            "info",
                            "table",
                            "time",
                            "timeEnd",
                            "timeLog",
                            "trace",
                            "warn"
                        ]
                    }
                }
            },
            "nursery": {
                "useSortedClasses": {
                    "level": "error",
                    "fix": "safe",
                    "options": {}
                }
            }
        }
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "lineWidth": 100,
        "formatWithErrors": true,
        "attributePosition": "multiline",
        "indentWidth": 4,
        "lineEnding": "lf",
        "useEditorconfig": true
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "trailingCommas": "none",
            "semicolons": "always"
        }
    },
    "overrides": [
        {
            "includes": ["**/tests/**", "**/__tests__/**", "**/test/**"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noExplicitAny": "off"
                    },
                    "style": {
                        "noNonNullAssertion": "off"
                    },
                    "a11y": {
                        "useButtonType": "off"
                    }
                }
            }
        },
        {
            "includes": ["packages/db/src/seeds/**"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off"
                    }
                }
            }
        },
        {
            "includes": ["**/github-workflow/**"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noAssignInExpressions": "off"
                    }
                }
            }
        },
        {
            "includes": [
                "**/scripts/**/*.ts",
                "**/scripts/**/*.mjs",
                "**/scripts/**/*.js",
                "**/scripts/**/*.cjs"
            ],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off"
                    }
                }
            }
        },
        {
            "includes": ["**/components/account/CollectionPickers.tsx"],
            "linter": {
                "rules": {
                    "a11y": {
                        "useSemanticElements": "off"
                    }
                }
            }
        },
        {
            "includes": [
                "packages/logger/**",
                "**/logger.ts",
                "**/lib/logger.ts",
                "**/utils/logger.ts"
            ],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off"
                    }
                }
            }
        }
    ]
}
