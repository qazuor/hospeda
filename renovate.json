{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:base"],
    "schedule": ["every weekend"],
    "rangeStrategy": "bump",
    "semanticCommits": "enabled",
    "packageRules": [
        {
            "matchUpdateTypes": ["minor", "patch"],
            "automerge": false,
            "description": "Disable automerge for minor/patch updates - require manual review"
        },
        {
            "matchUpdateTypes": ["patch"],
            "matchCategories": ["security"],
            "schedule": ["at any time"],
            "automerge": false,
            "description": "Security patches should not wait for weekend schedule"
        },
        {
            "matchPackageNames": ["cloudinary"],
            "matchUpdateTypes": ["minor", "patch"],
            "automerge": false,
            "description": "SPEC-078-GAPS GAP-078-226: pin cloudinary to minor/patch updates only — major bumps require manual review (breaking changes in upload contract)"
        },
        {
            "matchPackageNames": ["cloudinary"],
            "matchUpdateTypes": ["major"],
            "enabled": false,
            "description": "SPEC-078-GAPS GAP-078-226: block automatic major bumps for cloudinary; open an issue and upgrade by hand"
        }
    ],
    "prConcurrentLimit": 5,
    "prHourlyLimit": 0,
    "labels": ["dependencies"],
    "assignees": ["@qazuor"],
    "reviewers": ["@qazuor"]
}
