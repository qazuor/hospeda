# /etc/hospeda-backup.env
# Configuration for postgres-to-r2.sh and restore-from-r2.sh.
#
# Deploy by copying this file to /etc/hospeda-backup.env on the VPS and
# replacing each placeholder with the real value. Then chmod 600 so only root
# (or whoever owns the cron job) can read the credentials.
#
# Required:

# Cloudflare account ID. Found in Cloudflare dashboard top-right or in the URL
# of any R2 object endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=""

# R2 API token credentials. Create a token scoped to the hospeda-backups bucket
# with "Object Read & Write" permission in Cloudflare R2 → Manage R2 API
# Tokens. Save both values to your password manager.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Bucket where backups are stored. Pre-created.
R2_BUCKET="hospeda-backups"

# Postgres connection. Resolved against the Coolify-managed Postgres container.
POSTGRES_CONTAINER="yhhqnorqbtw2aslbxy64kjzd"
POSTGRES_USER="postgres"
POSTGRES_DB="postgres"

# Optional overrides. Uncomment to change defaults.
# BACKUP_DIR="/var/tmp/hospeda-backups"
# MIN_BACKUP_SIZE="100000"  # bytes
