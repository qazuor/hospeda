# Hospeda server-tools — local environment template.
#
# Copy this file to `.env.local` (same directory) and fill in the real
# values. `.env.local` is gitignored and must NEVER be committed.
#
# `hops` reads this file at startup. Required vs optional is documented
# below; missing required values cause the matching commands to fail
# with a clear error.

# ---------------------------------------------------------------------------
# Target environment (prod vs staging)
# ---------------------------------------------------------------------------

# Default target environment for container lookup. Every `hops` command
# resolves api/web/admin/postgres/redis containers based on this value.
# Override per invocation with `hops --target=staging <cmd>`.
#
# Note: this is NOT the same as `HOPS_TARGET` (which is read only by
# install.sh as the binary install path — that one is one-shot).
#
# Valid values: prod | staging
HOPS_DEFAULT_TARGET=prod

# Database service UUIDs from Coolify (`coolify.resourceName` label of
# the Postgres / Redis container is `<kind>-database-<UUID>`). Find the
# UUID either in the container name (it's the prefix) or by reading the
# resourceName label:
#   docker inspect <container> --format '{{index .Config.Labels "coolify.resourceName"}}'
#
# Required by: any command that resolves a postgres or redis container
# (psql, db-counts, db-backup-now, db-restore, exec on db).
HOPS_PROD_POSTGRES_UUID=
HOPS_PROD_REDIS_UUID=
HOPS_STAGING_POSTGRES_UUID=
HOPS_STAGING_REDIS_UUID=

# ---------------------------------------------------------------------------
# Coolify API
# ---------------------------------------------------------------------------

# Personal access token generated from
#   https://coolify.hospeda.com.ar → Profile → API Keys → Create token.
# Required by: redeploy, env-list, env-set, env-pull.
COOLIFY_API_URL=https://coolify.hospeda.com.ar
COOLIFY_API_TOKEN=

# ---------------------------------------------------------------------------
# Cloudflare R2 (Postgres backups) — per target environment
# ---------------------------------------------------------------------------

# R2 buckets are split per target so a leaked staging key cannot read or
# overwrite prod backups. The unprefixed R2_* variables hold the prod
# credentials (kept unprefixed for backwards-compat with the pre-split
# toolkit); the R2_STAGING_* set holds the staging ones.
#
# Required by: db-backup-now and db-restore, BOTH targets. Missing values
# fail loud with the offending env var name in the error.

# --- prod ---
# Account-scoped S3-compatible credentials for s3://hospeda-backups/.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=hospeda-backups
R2_REGION=auto

# --- staging ---
# Account-scoped S3-compatible credentials for s3://hospeda-staging-backups/.
# Typically mirror /etc/hospeda-backup-staging.env on the VPS (the same
# values used by the staging daily cron).
R2_STAGING_ACCOUNT_ID=
R2_STAGING_ACCESS_KEY_ID=
R2_STAGING_SECRET_ACCESS_KEY=
R2_STAGING_BUCKET=hospeda-staging-backups

# ---------------------------------------------------------------------------
# Backup encryption
# ---------------------------------------------------------------------------

# Passphrase used by the existing backup script when encrypting dumps
# (gpg symmetric AES256). `db-restore` needs it to decrypt before
# restoring. Required by: db-restore.
BACKUP_PASSPHRASE=

# ---------------------------------------------------------------------------
# Postgres (overrides for the Coolify-managed DB container)
# ---------------------------------------------------------------------------

# Defaults match the Coolify-managed Postgres service. Override if
# someone changed the user/db at the platform level.
PG_USER=postgres
PG_DB=postgres

# ---------------------------------------------------------------------------
# db-seed
# ---------------------------------------------------------------------------

# Path to the hospeda checkout used by `db-seed` (git pull + cwd for
# `pnpm --filter @repo/seed`). Defaults to ~/hospeda. Override only if
# the repo lives elsewhere on the VPS.
#
# The Postgres connection URL is NOT configured here — `db-seed` derives
# it at runtime from the postgres container (POSTGRES_PASSWORD + the
# published 5432 port). The container's 5432 port MUST be published to
# the host for this to work; if it isn't, expose it via Coolify before
# running db-seed.
# HOPS_REPO_ROOT=

# Cloudinary credentials for the seed's `--clean-images` step (default
# ON when running db-seed). When all three are set, the seed deletes
# every asset under the `hospeda/<env>/seed/` prefix before reseeding,
# so demo content does not leave orphan images in storage. When any of
# them is missing, the seed logs "Cloudinary env vars not configured —
# skipping remote deletion" and continues without aborting.
#
# Pass `hops db-seed --no-clean-images` to skip this step entirely
# without touching the vars here.
HOSPEDA_CLOUDINARY_CLOUD_NAME=
HOSPEDA_CLOUDINARY_API_KEY=
HOSPEDA_CLOUDINARY_API_SECRET=

# ---------------------------------------------------------------------------
# Hospeda API (used by health / cron-list / cron-trigger)
# ---------------------------------------------------------------------------

# Public URL the API serves on. Used by `health` to hit smoke endpoints
# and by `cron-list` / `cron-trigger` to call the admin cron endpoints.
HOSPEDA_API_URL=https://api.hospeda.com.ar

# Full Cookie-header value for an admin session. Required by:
# `cron-list`, `cron-trigger`. The admin endpoints (`/api/v1/admin/*`)
# only accept Better Auth session cookies — there is no bearer-token
# auth today (planned in SPEC-102).
#
# How to populate:
#   1. Open https://admin.hospeda.com.ar in a browser logged in as a
#      SUPER_ADMIN (or any user with SYSTEM_MAINTENANCE_MODE).
#   2. Open DevTools → Application → Cookies → https://admin.hospeda.com.ar.
#   3. Find the cookie named `__Secure-better-auth.session_token` (or
#      `better-auth.session_token` in dev) and copy its full value.
#   4. Paste below in the form `<cookie_name>=<cookie_value>`. If you
#      need multiple cookies, separate them with `; ` (semicolon-space).
#
# The cookie typically expires in 7-30 days. When hops returns 401, just
# refresh this value from DevTools again.
HOPS_ADMIN_COOKIE=
