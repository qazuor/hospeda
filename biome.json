{
    "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
    "extends": ["./packages/biome-config/biome.json"],
    "overrides": [
        {
            "includes": [
                "**/apps/web/src/components/sections/SearchBar.client.tsx",
                "**/apps/web/src/components/sections/DestinationsIsland.client.tsx",
                "**/apps/web/src/components/shared/MobileMenu.client.tsx"
            ],
            "linter": {
                "rules": {
                    "a11y": {
                        "useSemanticElements": "off",
                        "useFocusableInteractive": "off",
                        "noNoninteractiveTabindex": "off"
                    }
                }
            }
        },
        {
            "includes": ["**/apps/web/src/components/sections/DestinationsIsland.client.tsx"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noArrayIndexKey": "off"
                    }
                }
            }
        }
    ]
}
