{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
    "buildCommand": "cd ../.. && pnpm turbo run build --filter=hospeda-api; mkdir -p apps/api/_static && echo '' > apps/api/_static/.keep",
    "outputDirectory": "_static",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/v1/cron/trial-expiry",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/v1/cron/addon-expiry",
            "schedule": "0 5 * * *"
        },
        {
            "path": "/api/v1/cron/notification-schedule",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/v1/cron/webhook-retry",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/v1/cron/exchange-rate-fetch",
            "schedule": "0 4 * * *"
        },
        {
            "path": "/api/v1/cron/dunning",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/v1/cron/page-revalidation",
            "schedule": "0 * * * *"
        }
    ],
    "functions": {
        "api/index.js": {
            "maxDuration": 30,
            "memory": 512
        }
    }
}
