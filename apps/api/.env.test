# =============================================================================
# apps/api — Test Environment Variables
# =============================================================================
#
# Loaded automatically by Vitest when NODE_ENV=test.
# Never commit real secrets here — all values are safe test-only placeholders.
# =============================================================================

NODE_ENV=test

# Server binding
API_PORT=3001
API_HOST=localhost

# Core URLs
HOSPEDA_API_URL=http://localhost:3001
HOSPEDA_SITE_URL=http://localhost:4321
HOSPEDA_ADMIN_URL=http://localhost:3000

# Database — uses a dedicated test database.
# Single source of truth: HOSPEDA_DATABASE_URL (SPEC-035 canonical, SPEC-143 T-143-01).
# Port 5436 = host port of the hospeda-postgres docker container (per docker-compose,
# the internal 5432 is mapped to host 5436 to avoid clashing with system postgres on 5432).
# Owned by hospeda_user, matches the docker postgres POSTGRES_USER config.
HOSPEDA_DATABASE_URL=postgresql://hospeda_user:hospeda_pass@localhost:5436/hospeda_test

# Authentication
HOSPEDA_BETTER_AUTH_SECRET=test-secret-key-minimum-32-characters-long-for-testing
HOSPEDA_BETTER_AUTH_URL=http://localhost:3001/api/auth

# Location obfuscation salt (fixed for deterministic test snapshots)
HOSPEDA_LOCATION_SALT=test-location-salt-fixed-for-deterministic-tests-32+chars

# View-tracking visitor hash secret (fixed for deterministic test hashes, SPEC-159)
HOSPEDA_VIEWS_HASH_SECRET=test-views-hash-secret-fixed-for-deterministic-tests-32ch

# Geocoding User-Agent (test value)
HOSPEDA_GEOCODING_USER_AGENT=Hospeda-Test/1.0 (test@hospeda.com.ar)

# Testing flags — disable security controls that interfere with unit tests
HOSPEDA_DISABLE_AUTH=true
HOSPEDA_ALLOW_MOCK_ACTOR=true
HOSPEDA_TESTING_RATE_LIMIT=false
HOSPEDA_TESTING_ORIGIN_VERIFICATION=false

# Cron
HOSPEDA_CRON_SECRET=test-cron-secret-minimum-32-characters-long-for-testing
HOSPEDA_CRON_ADAPTER=manual

# MercadoPago access token (SPEC-143 T-143-09).
# Required by isBillingConfigured() in apps/api/src/middlewares/billing.ts so the
# QZPay billing middleware initializes the singleton. Tests replace the real
# adapter via vi.mock of @repo/billing.createMercadoPagoAdapter, so this token
# is never sent to MercadoPago — but the env presence check must pass.
# Format requirement: APP_USR- prefix (the real adapter validates this even
# though our mock bypasses it; keeping the format aligned avoids surprises if
# anyone disables the mock).
HOSPEDA_MERCADO_PAGO_ACCESS_TOKEN=APP_USR-test-stub-token-spec-143-do-not-send-to-mp

# MercadoPago webhook secret (SPEC-143 T-143-06).
# Tests sign webhook payloads with this value via signWebhookPayload() in
# apps/api/test/e2e/helpers/billing-fixtures.ts. The real webhookSignatureMiddleware
# uses the same env var to verify signatures, so the signing path exercised by tests
# is identical to production. Must be non-empty: when empty the middleware skips
# verification entirely (legacy dev fallback) and signature-validation tests cannot
# exercise the rejection branches.
HOSPEDA_MERCADO_PAGO_WEBHOOK_SECRET=test-webhook-secret-hospeda-spec-143

# Disable the MercadoPago subscription polling fallback in tests.
# start-paid schedules a background poll (schedulePollingForSubscription in
# subscription-checkout.service.ts) that later activates the subscription. With
# polling ON, that timer fires AFTER the test's afterEach testDb.clean(), leaving
# a stray ACTIVE subscription row that bleeds into a later test in the same
# singleFork worker (flaky "expected 1 subscription row, got 2"). The service
# code explicitly expects this flag OFF in test environments. e2e activation is
# exercised directly via webhook POSTs, not the polling fallback.
HOSPEDA_BILLING_POLLING_ENABLED=false
