# =============================================================================
# MercadoPago Sandbox E2E Test Configuration
# =============================================================================
# This file is a template for configuring sandbox E2E tests.
# Copy this file to .env.sandbox and fill in your actual test credentials.
#
# ⚠️  IMPORTANT: .env.sandbox is in .gitignore - never commit real credentials!
#
# To get sandbox credentials:
# 1. Go to https://www.mercadopago.com.ar/developers
# 2. Create a test application
# 3. Get your TEST credentials (token starts with TEST-)
# 4. Generate a webhook secret for IPN verification
#
# =============================================================================

# =============================================================================
# 💳 MercadoPago Sandbox Credentials
# =============================================================================
# 🔴 REQUIRED - Test access token (must start with TEST-)
MERCADO_PAGO_ACCESS_TOKEN=TEST-1234567890-abcdef-your-test-token-here

# 🟡 OPTIONAL - Webhook secret for signature verification testing
# Highly recommended to test webhook security
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret-here

# 🟡 OPTIONAL - Sandbox mode (should always be true for these tests)
MERCADO_PAGO_SANDBOX=true

# 🟡 OPTIONAL - Request timeout in milliseconds
# Increase if experiencing network timeouts
MERCADO_PAGO_TIMEOUT=10000

# =============================================================================
# 💾 Database Configuration (Test Database)
# =============================================================================
# 🔴 REQUIRED - Use a separate test database, not your development database
# The tests will create and modify billing records
HOSPEDA_DATABASE_URL=postgresql://user:password@localhost:5432/hospeda_test

# Alternative: Use a dedicated test database URL
# HOSPEDA_TEST_DATABASE_URL=postgresql://user:password@localhost:5432/hospeda_sandbox_test

# =============================================================================
# 🌐 API Configuration
# =============================================================================
# 🟡 OPTIONAL - API configuration for tests
API_PORT=3001
HOSPEDA_API_URL=http://localhost:3001
HOSPEDA_SITE_URL=http://localhost:4321

# =============================================================================
# 🔐 Authentication (Clerk) - For Full Integration Tests
# =============================================================================
# 🟡 OPTIONAL - Only needed if tests require authentication
# HOSPEDA_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_TEST_PUBLISHABLE_HERE
# HOSPEDA_CLERK_SECRET_KEY=YOUR_TEST_SECRET_HERE

# =============================================================================
# 🧪 Test Configuration
# =============================================================================
# 🟡 OPTIONAL - Test-specific settings
NODE_ENV=test

# Disable rate limiting in tests for faster execution
TESTING_RATE_LIMIT=false

# Enable debug logging if needed
DEBUG_TESTS=false

# =============================================================================
# Usage Instructions
# =============================================================================
# 1. Copy this file:
#    cp .env.sandbox.example .env.sandbox
#
# 2. Fill in your MercadoPago TEST credentials
#
# 3. Verify configuration:
#    pnpm test:sandbox
#
# 4. Tests will skip if credentials are not configured (safe default)
#
# 5. For CI/CD, use GitHub Secrets instead of .env file:
#    - MERCADO_PAGO_TEST_TOKEN
#    - MERCADO_PAGO_WEBHOOK_SECRET
#    - TEST_DATABASE_URL
#
# =============================================================================
# Security Notes
# =============================================================================
# ✅ DO:
#   - Use TEST- credentials only (never production)
#   - Keep .env.sandbox in .gitignore
#   - Use separate test database
#   - Rotate credentials periodically
#   - Use GitHub Secrets for CI/CD
#
# ❌ DON'T:
#   - Commit real credentials to git
#   - Use production credentials in tests
#   - Share credentials in public channels
#   - Use development database for tests
#   - Skip webhook secret (security risk)
#
# =============================================================================
