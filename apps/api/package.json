{
    "name": "hospeda-api",
    "description": "Complete API for the Hospeda tourism accommodation platform",
    "version": "0.0.1",
    "type": "module",
    "private": true,
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsup",
        "start": "node dist/index.js",
        "clean": "rm -rf node_modules dist",
        "lint": "biome check .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit --project ./tsconfig.json",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:file": "vitest run --passWithNoTests",
        "test:coverage": "vitest run --coverage",
        "test:cache": "node test-cache.js",
        "test:e2e": "pnpm run build:deps && vitest run --config vitest.config.e2e.ts",
        "test:e2e:watch": "vitest --config vitest.config.e2e.ts",
        "test:e2e:ci": "mkdir -p test-results && pnpm run build:deps && VITEST_E2E_JSON_OUTPUT=./test-results/e2e-results.json vitest run --config vitest.config.e2e.ts; CODE=$?; node scripts/check-e2e-budget.mjs ./test-results/e2e-results.json || exit 1; exit $CODE",
        "test:e2e:single": "NODE_OPTIONS=--max-old-space-size=8192 vitest run --config vitest.config.e2e.ts",
        "test:sandbox": "vitest run --config test/e2e/sandbox/vitest.config.sandbox.ts",
        "test:sandbox:watch": "vitest --config test/e2e/sandbox/vitest.config.sandbox.ts",
        "build:deps": "turbo run build --filter=@repo/db --filter=@repo/service-core --filter=@repo/schemas --filter=@repo/logger --filter=@repo/config --filter=@repo/billing --filter=@repo/notifications --filter=@repo/utils --filter=@repo/email --filter=@repo/ai-core --filter=@repo/feedback --filter=@repo/content-moderation"
    },
    "dependencies": {
        "@ai-sdk/gateway": "3.0.127",
        "@hono/node-server": "^1.19.10",
        "@hono/swagger-ui": "^0.6.1",
        "@hono/zod-openapi": "^1.4.0",
        "@linear/sdk": "^75.0.0",
        "@qazuor/qzpay-core": "^1.12.0",
        "@qazuor/qzpay-hono": "^1.6.1",
        "@qazuor/qzpay-mercadopago": "^2.2.0",
        "@react-email/components": "^0.0.30",
        "@react-email/render": "^2.0.8",
        "@repo/ai-core": "workspace:*",
        "@repo/billing": "workspace:*",
        "@repo/config": "workspace:*",
        "@repo/db": "workspace:*",
        "@repo/email": "workspace:*",
        "@repo/feedback": "workspace:*",
        "@repo/i18n": "workspace:*",
        "@repo/logger": "workspace:*",
        "@repo/media": "workspace:*",
        "@repo/notifications": "workspace:*",
        "@repo/schemas": "workspace:*",
        "@repo/service-core": "workspace:*",
        "@repo/utils": "workspace:*",
        "@scalar/hono-api-reference": "^0.11.2",
        "@sentry/node": "^10.57.0",
        "@sentry/profiling-node": "^10.57.0",
        "@vercel/oidc": "3.6.1",
        "bcryptjs": "^3.0.3",
        "better-auth": "^1.6.16",
        "bullmq": "^5.78.0",
        "cloudinary": "^2.10.0",
        "cron-parser": "^5.5.0",
        "cronstrue": "^3.14.0",
        "dotenv": "^16.5.0",
        "drizzle-orm": "^0.45.2",
        "file-type": "^19.6.0",
        "hono": "^4.12.21",
        "hono-rate-limiter": "^0.5.3",
        "image-size": "^2.0.0",
        "ioredis": "^5.11.1",
        "jose": "^6.2.3",
        "lru-cache": "^11.5.1",
        "pg": "^8.21.0",
        "posthog-node": "^5.36.9",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "resend": "^4",
        "sanitize-html": "^2.17.4",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@repo/typescript-config": "workspace:*",
        "@sentry/esbuild-plugin": "^5.1.1",
        "@types/bcryptjs": "^3.0.0",
        "@types/lru-cache": "^7.10.10",
        "@types/node": "^22.15.3",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.20.0",
        "@types/sanitize-html": "^2.16.1",
        "@vitest/coverage-v8": "^3.2.4",
        "tsup": "^8.4.0",
        "tsx": "^4.7.1",
        "typescript": "^5.8.3",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.1.3"
    },
    "optionalDependencies": {
        "node-cron": "^3.0.3"
    }
}
