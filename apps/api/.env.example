# ===========================================
# Hospeda API - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set before starting.
# Optional variables are commented out with their defaults shown.

# --- Server ---
NODE_ENV=development
API_PORT=3001
API_HOST=localhost

# --- Database [REQUIRED] ---
HOSPEDA_DATABASE_URL=postgresql://user:password@localhost:5432/hospeda

# --- Authentication (Better Auth) [REQUIRED] ---
HOSPEDA_BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars

# --- Trusted Origins ---
HOSPEDA_API_URL=http://localhost:3001
HOSPEDA_SITE_URL=http://localhost:4321
HOSPEDA_ADMIN_URL=http://localhost:3000

# --- Social OAuth (optional) ---
# HOSPEDA_GOOGLE_CLIENT_ID=
# HOSPEDA_GOOGLE_CLIENT_SECRET=
# HOSPEDA_FACEBOOK_CLIENT_ID=
# HOSPEDA_FACEBOOK_CLIENT_SECRET=

# --- CORS ---
API_CORS_ORIGINS=http://localhost:3000,http://localhost:4321
API_CORS_ALLOW_CREDENTIALS=true
API_CORS_MAX_AGE=86400
API_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
API_CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With
API_CORS_EXPOSE_HEADERS=Content-Length,X-Request-ID

# --- Rate Limiting (global) ---
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_KEY_GENERATOR=ip
API_RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
API_RATE_LIMIT_SKIP_FAILED_REQUESTS=false
API_RATE_LIMIT_STANDARD_HEADERS=true
API_RATE_LIMIT_LEGACY_HEADERS=false
API_RATE_LIMIT_MESSAGE=Too many requests, please try again later.
# Set to true when behind a reverse proxy (Vercel, Cloudflare, nginx).
# Reads client IP from x-forwarded-for instead of socket address. MUST be true in production.
API_RATE_LIMIT_TRUST_PROXY=false
# API_RATE_LIMIT_TRUSTED_PROXIES=

# --- Rate Limiting (auth endpoints) ---
API_RATE_LIMIT_AUTH_ENABLED=true
API_RATE_LIMIT_AUTH_WINDOW_MS=300000
API_RATE_LIMIT_AUTH_MAX_REQUESTS=50
API_RATE_LIMIT_AUTH_MESSAGE=Too many authentication requests, please try again later.

# --- Rate Limiting (public endpoints) ---
API_RATE_LIMIT_PUBLIC_ENABLED=true
API_RATE_LIMIT_PUBLIC_WINDOW_MS=3600000
API_RATE_LIMIT_PUBLIC_MAX_REQUESTS=1000
API_RATE_LIMIT_PUBLIC_MESSAGE=Too many API requests, please try again later.

# --- Rate Limiting (admin endpoints) ---
API_RATE_LIMIT_ADMIN_ENABLED=true
API_RATE_LIMIT_ADMIN_WINDOW_MS=600000
API_RATE_LIMIT_ADMIN_MAX_REQUESTS=200
API_RATE_LIMIT_ADMIN_MESSAGE=Too many admin requests, please try again later.

# --- Security ---
API_SECURITY_ENABLED=true
API_SECURITY_CSRF_ENABLED=true
API_SECURITY_CSRF_ORIGINS=http://localhost:3000,http://localhost:5173
# API_SECURITY_CSRF_ORIGIN=
API_SECURITY_HEADERS_ENABLED=true
API_SECURITY_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';
API_SECURITY_STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains
API_SECURITY_X_FRAME_OPTIONS=SAMEORIGIN
API_SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
API_SECURITY_X_XSS_PROTECTION=1; mode=block
API_SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
API_SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()

# --- Cache ---
API_CACHE_ENABLED=true
API_CACHE_DEFAULT_MAX_AGE=300
API_CACHE_DEFAULT_STALE_WHILE_REVALIDATE=60
API_CACHE_DEFAULT_STALE_IF_ERROR=86400
API_CACHE_PUBLIC_ENDPOINTS=/api/v1/public/accommodations,/health
API_CACHE_PRIVATE_ENDPOINTS=/api/v1/public/users
API_CACHE_NO_CACHE_ENDPOINTS=/health/db,/docs
API_CACHE_ETAG_ENABLED=true
API_CACHE_LAST_MODIFIED_ENABLED=true

# --- Compression ---
API_COMPRESSION_ENABLED=true
API_COMPRESSION_LEVEL=6
API_COMPRESSION_THRESHOLD=1024
API_COMPRESSION_CHUNK_SIZE=16384
API_COMPRESSION_FILTER=text/*,application/json,application/xml,application/javascript
API_COMPRESSION_EXCLUDE_ENDPOINTS=/health/db,/docs
API_COMPRESSION_ALGORITHMS=gzip,deflate

# --- Validation ---
API_VALIDATION_MAX_BODY_SIZE=10485760
API_VALIDATION_MAX_REQUEST_TIME=30000
API_VALIDATION_ALLOWED_CONTENT_TYPES=application/json,multipart/form-data
API_VALIDATION_REQUIRED_HEADERS=user-agent
API_VALIDATION_AUTH_ENABLED=true
API_VALIDATION_AUTH_HEADERS=authorization
API_VALIDATION_SANITIZE_ENABLED=true
API_VALIDATION_SANITIZE_MAX_STRING_LENGTH=1000
API_VALIDATION_SANITIZE_REMOVE_HTML_TAGS=true
API_VALIDATION_SANITIZE_ALLOWED_CHARS=[\w\s\-.,!?@#$%&*()+=]

# --- Response Format ---
API_RESPONSE_FORMAT_ENABLED=true
API_RESPONSE_INCLUDE_TIMESTAMP=true
API_RESPONSE_INCLUDE_VERSION=true
API_RESPONSE_API_VERSION=1.0.0
API_RESPONSE_INCLUDE_REQUEST_ID=true
API_RESPONSE_INCLUDE_METADATA=true
API_RESPONSE_SUCCESS_MESSAGE=Success
API_RESPONSE_ERROR_MESSAGE=An error occurred

# --- Logging ---
API_LOG_LEVEL=info
API_ENABLE_REQUEST_LOGGING=true
API_LOG_INCLUDE_TIMESTAMPS=true
API_LOG_INCLUDE_LEVEL=true
API_LOG_USE_COLORS=true
API_LOG_SAVE=false
API_LOG_EXPAND_OBJECTS=false
API_LOG_TRUNCATE_TEXT=true
API_LOG_TRUNCATE_AT=1000
API_LOG_STRINGIFY=false

# --- Metrics ---
API_METRICS_ENABLED=true
API_METRICS_SLOW_REQUEST_THRESHOLD_MS=1000
API_METRICS_SLOW_AUTH_THRESHOLD_MS=2000

# --- Database Pool ---
DB_POOL_MAX_CONNECTIONS=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=2000

# --- Redis (REQUIRED in production for rate limiting, caching, and notification idempotency) ---
HOSPEDA_REDIS_URL=redis://localhost:6379

# --- Cron Jobs [REQUIRED for cron endpoints] ---
CRON_SECRET=your-cron-secret-key
# CRON_ADAPTER: "node-cron" (default, local dev) or "vercel" (production on Vercel)
# CRON_ADAPTER=node-cron

# --- Sentry Error Tracking (optional) ---
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# --- Linear Integration (optional, for bug reports) ---
# HOSPEDA_LINEAR_API_KEY=
# HOSPEDA_LINEAR_TEAM_ID=

# --- Exchange Rate API (optional) ---
# HOSPEDA_EXCHANGE_RATE_API_KEY=

# --- Seed Configuration (optional) ---
# If not set, a cryptographically random password is generated and printed to stdout
# SEED_SUPER_ADMIN_PASSWORD=your-secure-password

# --- Test / Debug ---
# Show detailed 5xx error messages in production (for debugging, disable after)
API_DEBUG_ERRORS=false
DISABLE_AUTH=false
ALLOW_MOCK_ACTOR=false
TESTING_RATE_LIMIT=false
DEBUG_TESTS=false
COMMIT_SHA=unknown

# --- MercadoPago (required for billing) ---
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxx
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret
# MERCADO_PAGO_SANDBOX=true
# MERCADO_PAGO_TIMEOUT=5000
# MERCADO_PAGO_PLATFORM_ID=
# MERCADO_PAGO_INTEGRATOR_ID=

# --- Email Notifications (Resend) ---
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@hospeda.com.ar
# RESEND_FROM_NAME=Hospeda

# --- Admin Notifications ---
# ADMIN_NOTIFICATION_EMAILS=admin@hospeda.com.ar

# --- Sentry (add missing vars) ---
# SENTRY_PROJECT=hospeda
# SENTRY_RELEASE=
