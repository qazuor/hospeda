# Hospeda Mobile App — Environment Variables
#
# Copy this file to .env.local for local development.
# For EAS builds, these are set via EAS Secrets (T-012).
#
# Expo public variables are inlined at build time and exposed to the JS bundle.
# They MUST be prefixed with EXPO_PUBLIC_ to be accessible via expo-constants.
# Never put secrets in EXPO_PUBLIC_ variables.

# Base URL of the Hospeda API (Hono backend)
# Local: http://localhost:3001
# Staging: https://staging-api.hospeda.com.ar
# Production: https://api.hospeda.com.ar
EXPO_PUBLIC_API_URL=http://localhost:3001

# App environment — controls logging verbosity and feature flags
# Values: development | staging | production
EXPO_PUBLIC_APP_ENV=development
