{
    "cli": {
        "version": ">=12.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development",
            "env": {
                "EXPO_PUBLIC_APP_ENV": "development"
            }
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "env": {
                "EXPO_PUBLIC_APP_ENV": "staging",
                "EXPO_PUBLIC_API_URL": "https://staging-api.hospeda.com.ar"
            }
        },
        "production": {
            "autoIncrement": true,
            "channel": "production",
            "env": {
                "EXPO_PUBLIC_APP_ENV": "production",
                "EXPO_PUBLIC_API_URL": "https://api.hospeda.com.ar"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
