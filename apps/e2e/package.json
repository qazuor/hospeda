{
    "name": "hospeda-e2e",
    "description": "End-to-end test suite for Hospeda platform — Playwright-driven cross-app validation (SPEC-092)",
    "version": "0.0.1",
    "type": "module",
    "private": true,
    "scripts": {
        "e2e:up": "docker compose -f docker-compose.e2e.yml up -d --wait",
        "e2e:down": "docker compose -f docker-compose.e2e.yml down -v",
        "e2e:seed": "tsx seeds/e2e-seed.ts",
        "e2e:test": "playwright test",
        "e2e:test:p0": "playwright test --grep @p0",
        "e2e:test:p1": "playwright test --grep @p1",
        "e2e:test:resilience": "playwright test --grep @resilience",
        "e2e:report": "playwright show-report",
        "e2e:install": "playwright install chromium --with-deps",
        "lint": "biome check .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit --project ./tsconfig.json",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest --passWithNoTests",
        "clean": "rm -rf node_modules test-results playwright-report"
    },
    "dependencies": {
        "@repo/config": "workspace:*",
        "@repo/db": "workspace:*",
        "@repo/logger": "workspace:*",
        "@repo/schemas": "workspace:*",
        "@repo/seed": "workspace:*",
        "@repo/service-core": "workspace:*",
        "@repo/utils": "workspace:*",
        "drizzle-orm": "^0.45.2",
        "pg": "^8.16.3",
        "zod": "^4.0.8"
    },
    "devDependencies": {
        "@playwright/test": "^1.56.0",
        "@repo/typescript-config": "workspace:*",
        "@types/node": "^22.15.3",
        "@types/pg": "^8.15.1",
        "@vitest/coverage-v8": "^3.2.4",
        "tsx": "^4.7.1",
        "typescript": "^5.8.3",
        "vitest": "^3.1.3"
    }
}
