---
/**
 * @file 500.astro
 * @description Custom 500 error page with friendly design, retry/report actions,
 * and expandable dev details when running in development mode.
 */

export const prerender = false;

import ErrorLayout from '@/layouts/ErrorLayout.astro';
import { RefreshIcon, ChatIcon } from '@repo/icons';
import { isDevelopment } from '@/lib/env';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = (Astro.locals?.locale ?? 'es') as SupportedLocale;
const { t } = createTranslations(locale);
const homeUrl = buildUrl({ locale, path: '/' });
const feedbackUrl = buildUrl({ locale, path: 'feedback' });

const feedbackParams = new URLSearchParams({
	type: 'bug-js',
	source: 'error-500',
	url: Astro.url.href,
	title: 'Error 500 en la página',
	description: `Página: ${Astro.url.pathname}\nError: Se produjo un error interno del servidor.`,
});
const feedbackWithParams = `${feedbackUrl}?${feedbackParams.toString()}`;

const showDevDetails = isDevelopment();
---

<ErrorLayout locale={locale} title={t('error.500.title')} description={t('error.500.description')} noindex={true}>
	<!-- Illustrated icon -->
	<div class="err500-illustration" aria-hidden="true">
		<svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
			<circle cx="60" cy="60" r="54" stroke="var(--destructive, #ef4444)" stroke-width="1.5" opacity="0.12" />
			<circle cx="60" cy="60" r="40" stroke="var(--destructive, #ef4444)" stroke-width="1.5" opacity="0.08" />
			<circle cx="60" cy="60" r="20" stroke="var(--destructive, #ef4444)" stroke-width="2" fill="oklch(from var(--destructive, #ef4444) l c h / 0.06)" />
			<circle cx="60" cy="60" r="8" stroke="var(--destructive, #ef4444)" stroke-width="2" fill="none" />
			<line x1="60" y1="50" x2="60" y2="58" stroke="var(--destructive, #ef4444)" stroke-width="2.5" stroke-linecap="round" />
			<circle cx="60" cy="64" r="1.5" fill="var(--destructive, #ef4444)" />
			<circle cx="60" cy="30" r="3" fill="var(--destructive, #ef4444)" opacity="0.15" />
			<circle cx="60" cy="90" r="3" fill="var(--destructive, #ef4444)" opacity="0.15" />
			<circle cx="30" cy="60" r="3" fill="var(--destructive, #ef4444)" opacity="0.15" />
			<circle cx="90" cy="60" r="3" fill="var(--destructive, #ef4444)" opacity="0.15" />
		</svg>
	</div>

	<div class="err500-code" aria-hidden="true">500</div>

	<h1 class="err500-title">{t('error.500.heading')}</h1>
	<p class="err500-message">{t('error.500.message')}</p>

	<div class="err500-actions">
		<button type="button" class="err500-btn err500-btn--primary" id="retry-btn">
			<RefreshIcon size={18} />
			{t('error.500.retry')}
		</button>
		<a href={feedbackWithParams} class="err500-btn err500-btn--secondary">
			<ChatIcon size={18} />
			Reportar problema
		</a>
	</div>

	<a href={homeUrl} class="err500-home-link">
		{t('error.500.goHome')}
	</a>

	{showDevDetails && (
		<details class="err500-dev">
			<summary class="err500-dev__summary">Detalles del error (dev)</summary>
			<div class="err500-dev__content">
				<p><strong>URL:</strong> {Astro.url.href}</p>
				<p><strong>Method:</strong> {Astro.request.method}</p>
				<p><strong>Timestamp:</strong> {new Date().toISOString()}</p>
				<p class="err500-dev__hint">Revisá la terminal del dev server para el stack trace completo.</p>
			</div>
		</details>
	)}
</ErrorLayout>

<script>
	document.getElementById('retry-btn')?.addEventListener('click', () => {
		window.location.reload();
	});
</script>

