---
/**
 * 500 Internal Server Error page.
 * Server-rendered to detect locale from URL path or Accept-Language header.
 * Falls back to Spanish (default locale).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/seo/SEOHead.astro';
import { isValidLocale, parseAcceptLanguage, t } from '../lib/i18n';
import type { SupportedLocale } from '../lib/i18n';

/**
 * Detect locale from URL path first segment, then Accept-Language header.
 */
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const firstSegment = pathSegments[0] ?? '';
let locale: SupportedLocale = 'es';

if (isValidLocale(firstSegment)) {
	locale = firstSegment;
} else {
	locale = parseAcceptLanguage(Astro.request.headers.get('accept-language'));
}

const tError = (key: string) => t({ locale, namespace: 'error', key });

const title = tError('500.title');
const description = tError('500.description');
const heading = tError('500.heading');
const message = tError('500.message');
const retryLabel = tError('500.retry');
const goHomeLabel = tError('500.goHome');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout title={title} description={description} noindex={true} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		noindex={true}
		locale={locale}
		type="website"
	/>

	<div class="flex min-h-screen items-center justify-center bg-gradient-to-b from-bg to-bg-alt px-4 py-16">
		<div class="w-full max-w-2xl text-center">
			<!-- Decorative 500 text -->
			<div class="mb-8">
				<span class="text-9xl font-bold text-error opacity-20" aria-hidden="true">500</span>
			</div>

			<!-- SVG illustration (server/technical error themed) -->
			<div class="mb-8 flex justify-center" aria-hidden="true">
				<svg
					width="200"
					height="120"
					viewBox="0 0 200 120"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					class="text-error opacity-30"
				>
					<!-- Simple server/error illustration -->
					<rect
						x="60"
						y="30"
						width="80"
						height="60"
						rx="4"
						stroke="currentColor"
						stroke-width="3"
						fill="none"
					/>
					<circle cx="75" cy="45" r="4" fill="currentColor" />
					<circle cx="90" cy="45" r="4" fill="currentColor" />
					<circle cx="105" cy="45" r="4" fill="currentColor" />
					<circle cx="120" cy="45" r="4" fill="currentColor" />

					<circle cx="75" cy="60" r="4" fill="currentColor" />
					<circle cx="90" cy="60" r="4" fill="currentColor" />
					<circle cx="105" cy="60" r="4" fill="currentColor" />
					<circle cx="120" cy="60" r="4" fill="currentColor" />

					<circle cx="75" cy="75" r="4" fill="currentColor" />
					<circle cx="90" cy="75" r="4" fill="currentColor" />
					<circle cx="105" cy="75" r="4" fill="currentColor" />
					<circle cx="120" cy="75" r="4" fill="currentColor" />

					<!-- Error symbol (X) -->
					<line x1="155" y1="35" x2="175" y2="55" stroke="currentColor" stroke-width="4" />
					<line x1="175" y1="35" x2="155" y2="55" stroke="currentColor" stroke-width="4" />
				</svg>
			</div>

			<!-- Heading -->
			<h1 class="mb-4 text-4xl font-bold text-text">{heading}</h1>

			<!-- Message -->
			<p class="mx-auto mb-8 max-w-md text-lg text-text-secondary">
				{message}
			</p>

			<!-- Action buttons -->
			<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
				<!-- Retry button -->
				<button
					type="button"
					onclick="window.location.reload()"
					class="inline-flex items-center justify-center rounded-lg border-2 border-border bg-surface px-6 py-3 text-base font-semibold text-text transition-colors hover:bg-surface-alt focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
				>
					{retryLabel}
				</button>

				<!-- Home link -->
				<a
					href={`/${locale}/`}
					class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
				>
					{goHomeLabel}
				</a>
			</div>
		</div>
	</div>
</BaseLayout>
