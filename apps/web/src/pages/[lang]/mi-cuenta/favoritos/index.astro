---
/**
 * @file mi-cuenta/favoritos/index.astro
 * @description Account favorites page.
 * @route /{lang}/mi-cuenta/favoritos/
 * @rendering SSR
 */

import AccountLayout from '@/layouts/AccountLayout.astro';
import { UserFavoritesList } from '@/components/account/UserFavoritesList.client';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const user = Astro.locals.user;

if (!user) {
	return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const { t } = createTranslations(locale);
const title = t('account.pages.favorites.title', 'Favoritos');
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001';
---

<AccountLayout locale={locale} title={title} activeSection="favoritos">
	<h2 class="account-section__title">{title}</h2>

	<UserFavoritesList client:load locale={locale} apiUrl={apiUrl} />
</AccountLayout>

<style>
	.account-section__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.5rem, 3vw, 2rem);
		color: var(--foreground);
		margin: 0 0 var(--space-6);
	}
</style>
