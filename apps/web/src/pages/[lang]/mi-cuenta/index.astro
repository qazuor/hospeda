---
/**
 * @file mi-cuenta/index.astro
 * @description Account dashboard — shows user info and navigation to sub-sections.
 *
 * Auth protection: both the middleware AND this page check for a valid user.
 * Middleware redirects before the page renders; the in-page guard is a safety net
 * for any SSR edge case where middleware did not run.
 *
 * Quick stats (bookmarks, reviews, subscription) are fetched client-side so that
 * we avoid SSR cookie-forwarding complexity and the page can show a skeleton first.
 *
 * @route    /[lang]/mi-cuenta/
 * @rendering SSR (prerender = false — requires authenticated user)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import AccountLayout from '@/layouts/AccountLayout.astro';
import AccountStatsGrid from '@/components/account/AccountStatsGrid.astro';
import AccountSectionCards from '@/components/account/AccountSectionCards.astro';
import {
    UserIcon,
    SettingsIcon,
    ChatIcon,
    NewsletterIcon
} from '@repo/icons';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

// Auth guard: middleware should have redirected already, but this is the safety net.
const user = Astro.locals.user;
if (!user) {
    return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const t = createT(locale);

const title = t('account.pages.dashboard.title', 'Mi Cuenta');
const description = t(
    'account.pages.dashboard.description',
    'Gestiona tu perfil, favoritos, resenas y suscripcion'
);
const greeting = t('account.pages.dashboard.greeting', 'Hola');
const dashboardLabel = t('account.pages.dashboard.dashboardLabel', 'Panel de control');

// Generate user initials (up to 2 characters) for the avatar placeholder.
const initials = user.name
    .split(' ')
    .map((word: string) => word[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();

// Sections grid. We intentionally exclude Favoritos, Reseñas and
// Suscripción from this list — they already have dedicated stat
// cards directly above with the same link. Listing them in both
// places duplicated the navigation entry and made the dashboard feel
// cluttered. Keep this grid for items the stats row does NOT cover.
const navItems = [
    {
        label: t('account.pages.dashboard.nav.editProfile', 'Editar perfil'),
        href: buildUrl({ locale, path: 'mi-cuenta/editar' }),
        description: t(
            'account.pages.dashboard.nav.editProfileDesc',
            'Actualizá tu información personal y foto de perfil'
        ),
        Icon: UserIcon
    },
    {
        label: t('account.pages.dashboard.nav.myMessages', 'Mis consultas'),
        href: buildUrl({ locale, path: 'mi-cuenta/messages' }),
        description: t(
            'account.pages.dashboard.nav.myMessagesDesc',
            'Conversaciones con anfitriones'
        ),
        Icon: ChatIcon
    },
    {
        label: t('account.pages.dashboard.nav.preferences', 'Preferencias'),
        href: buildUrl({ locale, path: 'mi-cuenta/preferencias' }),
        description: t(
            'account.pages.dashboard.nav.preferencesDesc',
            'Configurá notificaciones, idioma y privacidad'
        ),
        Icon: SettingsIcon
    },
    {
        label: t('account.pages.dashboard.nav.newsletter', 'Newsletter'),
        href: buildUrl({ locale, path: 'mi-cuenta/newsletter' }),
        description: t(
            'account.pages.dashboard.nav.newsletterDesc',
            'Gestioná tu suscripción al boletín'
        ),
        Icon: NewsletterIcon
    }
] as const;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<AccountLayout locale={locale} title={title} description={description} activeSection="mi-cuenta">
    <!-- ── User header card ── -->
    <article id="user-header" class="account__header-card">
        <!-- Decorative warm gradient frame on the right edge -->
        <span class="account__header-glow" aria-hidden="true" />
        <span class="account__header-pattern" aria-hidden="true" />

        <div class="account__header-inner">
            <!-- Avatar with initials fallback -->
            <div class="account__avatar" aria-hidden="true">
                <span class="account__avatar-ring" aria-hidden="true" />
                <span class="account__avatar-initials">{initials}</span>
            </div>

            <!-- Name + email + small detail row -->
            <div class="account__user-info">
                <p class="account__user-eyebrow">{greeting}</p>
                <h1 class="account__user-name">{user.name}</h1>
                <p class="account__user-email">{user.email}</p>
            </div>

            <!-- CTA: edit profile -->
            <div class="account__header-actions">
                <a
                    href={buildUrl({ locale, path: 'mi-cuenta/editar' })}
                    class="account__header-cta"
                >
                    <UserIcon size={18} weight="regular" aria-hidden="true" />
                    {t('account.pages.dashboard.nav.editProfile', 'Editar perfil')}
                </a>
            </div>
        </div>
    </article>

    <!-- Main content: quick stats -->
    <div id="account-stats" class="account__main">
        <h2 class="account__section-title">{dashboardLabel}</h2>

        <!-- Stat cards row -->
        <AccountStatsGrid locale={locale} />

        <!-- Navigation cards grid (secondary) -->
        <AccountSectionCards locale={locale} navItems={navItems} />
    </div>
</AccountLayout>

<style>
    /* ── Page container ── */
    .account {
        max-width: var(--container-max, 1350px);
        margin-inline: auto;
        padding: var(--space-8, 2rem) var(--space-4, 1rem);
    }

    /* ── User header card ── */
    .account__header-card {
        position: relative;
        margin-bottom: var(--space-8, 2rem);
        border-radius: var(--radius-card);
        border: 1px solid oklch(from var(--core-foreground) l c h / 0.08);
        background-color: var(--core-card);
        background-image: linear-gradient(
            135deg,
            oklch(from var(--brand-primary) l c h / 0.06) 0%,
            oklch(from var(--brand-accent) l c h / 0.04) 100%
        );
        box-shadow: var(--shadow-card);
        overflow: hidden;
        isolation: isolate;
    }

    /* Soft brand glow on the right shoulder. */
    .account__header-glow {
        position: absolute;
        top: -40%;
        right: -10%;
        width: 22rem;
        height: 22rem;
        border-radius: var(--radius-pill);
        background: radial-gradient(
            closest-side,
            oklch(from var(--brand-primary) l c h / 0.18),
            transparent 70%
        );
        pointer-events: none;
        z-index: -1;
    }

    /* Faint dotted pattern at the bottom-left of the card. */
    .account__header-pattern {
        position: absolute;
        bottom: -1rem;
        left: -1rem;
        width: 10rem;
        height: 10rem;
        background-image: radial-gradient(
            circle,
            oklch(from var(--brand-accent) l c h / 0.18) 1px,
            transparent 1.5px
        );
        background-size: 12px 12px;
        opacity: 0.55;
        pointer-events: none;
        z-index: -1;
    }

    .account__header-inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-6, 1.5rem);
        padding: var(--space-8, 2rem);
        text-align: center;
    }

    @media (min-width: 640px) {
        .account__header-inner {
            flex-direction: row;
            text-align: left;
            align-items: center;
        }
    }

    .account__avatar {
        position: relative;
        flex-shrink: 0;
        display: flex;
        width: 6.5rem;
        height: 6.5rem;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-pill);
        background: linear-gradient(
            135deg,
            var(--brand-primary),
            oklch(from var(--brand-primary) calc(l - 0.12) c h)
        );
        color: var(--core-card);
        font-size: 2rem;
        font-weight: 700;
        font-family: var(--font-heading);
        box-shadow: 0 12px 24px oklch(from var(--brand-primary) l c h / 0.25);
    }

    /* Outer ring around the avatar to lift it visually off the surface. */
    .account__avatar-ring {
        position: absolute;
        inset: -6px;
        border-radius: var(--radius-pill);
        border: 2px solid oklch(from var(--brand-primary) l c h / 0.2);
        pointer-events: none;
    }

    .account__avatar-initials {
        position: relative;
        z-index: 1;
    }

    .account__user-info {
        flex: 1;
        min-width: 0;
    }

    .account__user-eyebrow {
        margin: 0 0 var(--space-1);
        font-family: var(--font-sans);
        font-size: 0.8125rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--brand-primary);
    }

    .account__user-name {
        margin: 0 0 var(--space-2);
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-family: var(--font-heading);
        font-weight: 700;
        color: var(--core-foreground);
        line-height: 1.15;
        word-break: break-word;
    }

    .account__user-email {
        margin: 0;
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
        word-break: break-all;
    }

    .account__header-actions {
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }

    .account__header-cta {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-3) var(--space-5);
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        font-weight: 600;
        color: var(--brand-primary);
        background-color: var(--core-card);
        border: 1px solid oklch(from var(--brand-primary) l c h / 0.3);
        border-radius: var(--radius-button);
        text-decoration: none;
        transition:
            background-color var(--duration-fast) ease,
            color var(--duration-fast) ease,
            transform var(--duration-fast) ease,
            box-shadow var(--duration-fast) ease;
    }

    .account__header-cta:hover {
        background-color: var(--brand-primary);
        color: var(--core-card);
        transform: translateY(-1px);
        box-shadow: 0 8px 16px oklch(from var(--brand-primary) l c h / 0.25);
    }

    .account__header-cta:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    /* ── Two-column layout ── */
    .account__body {
        display: grid;
        gap: var(--space-8, 2rem);
    }

    @media (min-width: 1024px) {
        .account__body {
            grid-template-columns: 17.5rem 1fr;
        }
    }

    /* ── Sidebar navigation ── */
    .account__sidebar {
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
        background-color: var(--core-card);
        padding: var(--space-6, 1.5rem);
    }

    .account__nav-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .account__nav-link {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        border-radius: var(--radius-button);
        padding: 0.75rem 1rem;
        color: var(--core-foreground);
        text-decoration: none;
        transition: background-color var(--duration-fast) ease, color var(--duration-fast) ease;
    }

    .account__nav-link:hover {
        background-color: var(--surface-warm);
    }

    .account__nav-link:hover .account__nav-label {
        color: var(--brand-primary);
    }

    .account__nav-link:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    .account__nav-icon {
        margin-top: 0.125rem;
        flex-shrink: 0;
        color: var(--core-muted-foreground);
        transition: color var(--duration-fast) ease;
    }

    .account__nav-link:hover .account__nav-icon {
        color: var(--brand-primary);
    }

    .account__nav-label {
        font-weight: 600;
        font-size: var(--text-body-sm);
        color: var(--core-foreground);
        transition: color var(--duration-fast) ease;
    }

    .account__nav-desc {
        font-size: var(--text-caption);
        color: var(--core-muted-foreground);
        margin-top: 0.125rem;
    }

    /* ── Main content ── */
    .account__main {
        display: flex;
        flex-direction: column;
        gap: var(--space-6, 1.5rem);
    }

    .account__section-title {
        margin: 0;
        font-size: var(--text-h3, 1.5rem);
        font-family: var(--font-heading);
        font-weight: 700;
        color: var(--core-foreground);
    }

</style>

<script>
    import { getApiUrl } from '@/lib/env';

    /**
     * Fetch user stats from the protected API and update the dashboard counters.
     * Runs client-side to avoid SSR cookie-forwarding complexity.
     * Falls back gracefully — default zeros are already rendered server-side.
     */
    async function loadStats(): Promise<void> {
        const base = `${getApiUrl()}/api/v1/protected`;

        try {
            const [statsRes, reviewsRes] = await Promise.all([
                fetch(`${base}/users/me/stats`, { credentials: 'include' }),
                fetch(`${base}/users/me/reviews?pageSize=1`, { credentials: 'include' })
            ]);

            if (statsRes.ok) {
                const statsData = (await statsRes.json()) as {
                    data?: {
                        bookmarkCount?: number;
                        plan?: { name?: string; status?: string };
                    };
                };

                const favEl = document.getElementById('stat-favorites');
                if (favEl && statsData.data?.bookmarkCount !== undefined) {
                    favEl.textContent = String(statsData.data.bookmarkCount);
                    favEl.classList.remove('stat-value--loading');
                }

                const subEl = document.getElementById('stat-subscription');
                if (subEl && statsData.data?.plan?.name) {
                    subEl.textContent = statsData.data.plan.name;
                    subEl.classList.remove('stat-value--loading');
                }

                const statusEl = document.getElementById('stat-subscription-status');
                if (statusEl) {
                    const plan = statsData.data?.plan;
                    if (plan?.status) {
                        const label = statusEl.getAttribute(`data-label-${plan.status}`);
                        if (label) statusEl.textContent = label;
                    } else {
                        const freeLabel = statusEl.getAttribute('data-label-free');
                        if (freeLabel) statusEl.textContent = freeLabel;
                    }
                }
            }

            if (reviewsRes.ok) {
                const reviewsData = (await reviewsRes.json()) as {
                    data?: { totals?: { total?: number } };
                };
                const revEl = document.getElementById('stat-reviews');
                if (revEl && reviewsData.data?.totals?.total !== undefined) {
                    revEl.textContent = String(reviewsData.data.totals.total);
                    revEl.classList.remove('stat-value--loading');
                }
            }
        } catch (error) {
            console.error('[account] Failed to load stats:', error);
            // Remove shimmer on error so stats don't stay in loading state forever
            for (const id of ['stat-favorites', 'stat-reviews', 'stat-subscription']) {
                document.getElementById(id)?.classList.remove('stat-value--loading');
            }
        }
    }

    void loadStats();
</script>
