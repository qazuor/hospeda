---
/**
 * User Account Dashboard - authenticated SSR page.
 * Shows user information, quick stats, and navigation to account sections.
 * This page is protected by middleware - user is redirected to signin if not authenticated.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Container from '../../../components/ui/Container.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Section from '../../../components/ui/Section.astro';
import { isValidLocale, type SupportedLocale } from '../../../lib/i18n';
import { FavoriteIcon, StarIcon, CheckCircleIcon } from '@repo/icons';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * User is guaranteed to exist due to middleware auth protection
 */
const user = Astro.locals.user;
if (!user) {
	return Astro.redirect(`/${locale}/auth/signin`);
}

/**
 * Generate user initials from name for avatar
 */
const initials = user.name
	.split(' ')
	.map((word) => word[0])
	.slice(0, 2)
	.join('')
	.toUpperCase();

/**
 * Localized page titles
 */
const titles: Record<SupportedLocale, string> = {
	es: 'Mi Cuenta',
	en: 'My Account',
	pt: 'Minha Conta',
};

/**
 * Localized meta descriptions
 */
const descriptions: Record<SupportedLocale, string> = {
	es: 'Administra tu cuenta, favoritos, reseñas y preferencias.',
	en: 'Manage your account, favorites, reviews and preferences.',
	pt: 'Gerencie sua conta, favoritos, avaliações e preferências.',
};

/**
 * Localized home breadcrumb labels
 */
const homeLabels: Record<SupportedLocale, string> = {
	es: 'Inicio',
	en: 'Home',
	pt: 'Início',
};

/**
 * Localized greeting
 */
const greetings: Record<SupportedLocale, string> = {
	es: 'Bienvenido',
	en: 'Welcome',
	pt: 'Bem-vindo',
};

/**
 * Localized navigation items
 */
const navItems: Record<
	SupportedLocale,
	Array<{ label: string; href: string; description: string }>
> = {
	es: [
		{
			label: 'Editar Perfil',
			href: `/${locale}/mi-cuenta/editar/`,
			description: 'Actualiza tu información personal',
		},
		{
			label: 'Mis Favoritos',
			href: `/${locale}/mi-cuenta/favoritos/`,
			description: 'Alojamientos que has guardado',
		},
		{
			label: 'Mis Reseñas',
			href: `/${locale}/mi-cuenta/resenas/`,
			description: 'Reseñas que has escrito',
		},
		{
			label: 'Preferencias',
			href: `/${locale}/mi-cuenta/preferencias/`,
			description: 'Configuración de notificaciones y privacidad',
		},
		{
			label: 'Mi Suscripción',
			href: `/${locale}/mi-cuenta/suscripcion/`,
			description: 'Plan actual y facturación',
		},
	],
	en: [
		{
			label: 'Edit Profile',
			href: `/${locale}/mi-cuenta/editar/`,
			description: 'Update your personal information',
		},
		{
			label: 'My Favorites',
			href: `/${locale}/mi-cuenta/favoritos/`,
			description: 'Accommodations you have saved',
		},
		{
			label: 'My Reviews',
			href: `/${locale}/mi-cuenta/resenas/`,
			description: 'Reviews you have written',
		},
		{
			label: 'Preferences',
			href: `/${locale}/mi-cuenta/preferencias/`,
			description: 'Notification and privacy settings',
		},
		{
			label: 'My Subscription',
			href: `/${locale}/mi-cuenta/suscripcion/`,
			description: 'Current plan and billing',
		},
	],
	pt: [
		{
			label: 'Editar Perfil',
			href: `/${locale}/mi-cuenta/editar/`,
			description: 'Atualize suas informações pessoais',
		},
		{
			label: 'Meus Favoritos',
			href: `/${locale}/mi-cuenta/favoritos/`,
			description: 'Acomodações que você salvou',
		},
		{
			label: 'Minhas Avaliações',
			href: `/${locale}/mi-cuenta/resenas/`,
			description: 'Avaliações que você escreveu',
		},
		{
			label: 'Preferências',
			href: `/${locale}/mi-cuenta/preferencias/`,
			description: 'Configurações de notificações e privacidade',
		},
		{
			label: 'Minha Assinatura',
			href: `/${locale}/mi-cuenta/suscripcion/`,
			description: 'Plano atual e faturamento',
		},
	],
};

/**
 * Localized quick stats section
 */
const statsLabels: Record<
	SupportedLocale,
	{ favorites: string; reviews: string; subscription: string }
> = {
	es: {
		favorites: 'Mis Favoritos',
		reviews: 'Mis Reseñas',
		subscription: 'Mi Suscripción',
	},
	en: {
		favorites: 'My Favorites',
		reviews: 'My Reviews',
		subscription: 'My Subscription',
	},
	pt: {
		favorites: 'Meus Favoritos',
		reviews: 'Minhas Avaliações',
		subscription: 'Minha Assinatura',
	},
};

const statsDescriptions: Record<
	SupportedLocale,
	{
		favorites: string;
		reviews: string;
		subscription: string;
		subscriptionStatus: string;
		activeStatus: string;
		trialStatus: string;
		freeStatus: string;
	}
> = {
	es: {
		favorites: 'Alojamientos guardados',
		reviews: 'Reseñas publicadas',
		subscription: 'Plan Gratuito',
		subscriptionStatus: 'Plan Gratuito',
		activeStatus: 'Activo',
		trialStatus: 'Periodo de prueba',
		freeStatus: 'Plan Gratuito',
	},
	en: {
		favorites: 'Saved accommodations',
		reviews: 'Published reviews',
		subscription: 'Free Plan',
		subscriptionStatus: 'Free Plan',
		activeStatus: 'Active',
		trialStatus: 'Trial period',
		freeStatus: 'Free Plan',
	},
	pt: {
		favorites: 'Acomodações salvas',
		reviews: 'Avaliações publicadas',
		subscription: 'Plano Gratuito',
		subscriptionStatus: 'Plano Gratuito',
		activeStatus: 'Ativo',
		trialStatus: 'Periodo de avaliacao',
		freeStatus: 'Plano Gratuito',
	},
};

const viewLabels: Record<SupportedLocale, string> = {
	es: 'Ver',
	en: 'View',
	pt: 'Ver',
};

const dashboardLabels: Record<SupportedLocale, string> = {
	es: 'Dashboard',
	en: 'Dashboard',
	pt: 'Painel',
};

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: homeLabels[locale], href: `/${locale}/` },
	{ label: titles[locale], href: `/${locale}/mi-cuenta/` },
];

/**
 * Stats are fetched client-side via API calls to avoid SSR cookie forwarding issues.
 * Default values are shown during loading.
 */
const stats = {
	favorites: 0,
	reviews: 0,
	subscription: 'free',
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout title={titles[locale]} description={descriptions[locale]} locale={locale}>
	<SEOHead
		slot="head"
		title={titles[locale]}
		description={descriptions[locale]}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- User Header Card -->
				<article
					id="user-header"
					class="mb-8 overflow-hidden rounded-lg border border-border bg-surface shadow-sm"
				>
					<div class="flex flex-col items-center gap-6 p-8 sm:flex-row">
						<!-- User Avatar with Initials -->
						<div
							class="flex h-24 w-24 flex-shrink-0 items-center justify-center rounded-full bg-primary text-3xl font-bold text-white"
							aria-hidden="true"
						>
							{initials}
						</div>

						<!-- User Info -->
						<div class="flex-1 text-center sm:text-left">
							<h1 class="mb-2 text-3xl font-bold text-text-primary">
								{greetings[locale]}, {user.name}
							</h1>
							<p class="text-lg text-text-secondary">{user.email}</p>
						</div>
					</div>
				</article>

				<div class="grid gap-8 lg:grid-cols-[300px_1fr]">
					<!-- Navigation Sidebar -->
					<aside
						id="account-nav"
						class="rounded-lg border border-border bg-surface p-6"
						aria-label="Account navigation"
					>
						<nav>
							<ul class="space-y-2" role="list">
								{
									navItems[locale].map((item) => (
										<li>
											<a
												href={item.href}
												class="group block rounded-md px-4 py-3 text-text-primary transition-colors hover:bg-bg focus-visible:bg-bg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
											>
												<div class="font-semibold group-hover:text-primary">
													{item.label}
												</div>
												<div class="text-sm text-text-tertiary">{item.description}</div>
											</a>
										</li>
									))
								}
							</ul>
						</nav>
					</aside>

					<!-- Main Content - Quick Stats -->
					<div id="account-stats" class="space-y-6">
						<h2 class="text-2xl font-bold text-text-primary">{dashboardLabels[locale]}</h2>

						<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
							<!-- Favorites Card -->
							<article
								class="rounded-lg border border-border bg-surface p-6 shadow-sm transition-shadow hover:shadow-md"
							>
								<div class="mb-3 flex items-center justify-between">
									<h3 class="text-lg font-semibold text-text-primary">
										{statsLabels[locale].favorites}
									</h3>
									<FavoriteIcon size={24} className="text-primary" weight="fill" aria-hidden="true" />
								</div>
								<p id="stat-favorites" class="mb-2 text-3xl font-bold text-text-primary">{stats.favorites}</p>
								<p class="text-sm text-text-secondary">{statsDescriptions[locale].favorites}</p>
								<a
									href={`/${locale}/mi-cuenta/favoritos/`}
									class="mt-4 inline-flex items-center text-sm font-medium text-primary hover:underline"
								>
									{viewLabels[locale]} {statsLabels[locale].favorites.toLowerCase()} →
								</a>
							</article>

							<!-- Reviews Card -->
							<article
								class="rounded-lg border border-border bg-surface p-6 shadow-sm transition-shadow hover:shadow-md"
							>
								<div class="mb-3 flex items-center justify-between">
									<h3 class="text-lg font-semibold text-text-primary">
										{statsLabels[locale].reviews}
									</h3>
									<StarIcon size={24} className="text-primary" weight="fill" aria-hidden="true" />
								</div>
								<p id="stat-reviews" class="mb-2 text-3xl font-bold text-text-primary">{stats.reviews}</p>
								<p class="text-sm text-text-secondary">{statsDescriptions[locale].reviews}</p>
								<a
									href={`/${locale}/mi-cuenta/resenas/`}
									class="mt-4 inline-flex items-center text-sm font-medium text-primary hover:underline"
								>
									{viewLabels[locale]} {statsLabels[locale].reviews.toLowerCase()} →
								</a>
							</article>

							<!-- Subscription Card -->
							<article
								class="rounded-lg border border-border bg-surface p-6 shadow-sm transition-shadow hover:shadow-md"
							>
								<div class="mb-3 flex items-center justify-between">
									<h3 class="text-lg font-semibold text-text-primary">
										{statsLabels[locale].subscription}
									</h3>
									<CheckCircleIcon size={24} className="text-primary" aria-hidden="true" />
								</div>
								<p id="stat-subscription" class="mb-2 text-3xl font-bold text-text-primary">
									{statsDescriptions[locale].subscription}
								</p>
								<p
									id="stat-subscription-status"
									class="text-sm text-text-secondary"
									data-label-active={statsDescriptions[locale].activeStatus}
									data-label-trial={statsDescriptions[locale].trialStatus}
									data-label-free={statsDescriptions[locale].freeStatus}
								>
									{statsDescriptions[locale].subscriptionStatus}
								</p>
								<a
									href={`/${locale}/mi-cuenta/suscripcion/`}
									class="mt-4 inline-flex items-center text-sm font-medium text-primary hover:underline"
								>
									{viewLabels[locale]} {statsLabels[locale].subscription.toLowerCase()} →
								</a>
							</article>
						</div>
					</div>
				</div>
			</div>
		</Section>
	</Container>
</BaseLayout>

<script>
	/**
	 * Fetch user stats from API and update dashboard numbers.
	 * Falls back gracefully to default values on error.
	 */
	async function loadStats() {
		const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001';
		const base = `${apiUrl}/api/v1/protected`;

		try {
			const [statsRes, reviewsRes] = await Promise.all([
				fetch(`${base}/users/me/stats`, { credentials: 'include' }),
				fetch(`${base}/users/me/reviews?pageSize=1`, { credentials: 'include' }),
			]);

			if (statsRes.ok) {
				const statsData = await statsRes.json();
				const favEl = document.getElementById('stat-favorites');
				if (favEl && statsData.data?.bookmarkCount !== undefined) {
					favEl.textContent = String(statsData.data.bookmarkCount);
				}
				const subEl = document.getElementById('stat-subscription');
				if (subEl && statsData.data?.plan?.name) {
					subEl.textContent = statsData.data.plan.name;
				}
				const statusEl = document.getElementById('stat-subscription-status');
				if (statusEl) {
					const plan = statsData.data?.plan;
					if (plan && plan.status) {
						const labelKey = `data-label-${plan.status}`;
						const label = statusEl.getAttribute(labelKey);
						if (label) {
							statusEl.textContent = label;
						}
					} else {
						// No plan = free user, use free label
						const freeLabel = statusEl.getAttribute('data-label-free');
						if (freeLabel) {
							statusEl.textContent = freeLabel;
						}
					}
				}
			}

			if (reviewsRes.ok) {
				const reviewsData = await reviewsRes.json();
				const revEl = document.getElementById('stat-reviews');
				if (revEl && reviewsData.data?.totals?.total !== undefined) {
					revEl.textContent = String(reviewsData.data.totals.total);
				}
			}
		} catch {
			// Silently fail - default values are already displayed
		}
	}

	loadStats();
</script>
