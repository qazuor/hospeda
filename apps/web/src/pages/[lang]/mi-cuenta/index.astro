---
/**
 * @file mi-cuenta/index.astro
 * @description Account dashboard — shows user info and navigation to sub-sections.
 *
 * Auth protection: both the middleware AND this page check for a valid user.
 * Middleware redirects before the page renders; the in-page guard is a safety net
 * for any SSR edge case where middleware did not run.
 *
 * Quick stats (bookmarks, reviews, subscription) are fetched client-side so that
 * we avoid SSR cookie-forwarding complexity and the page can show a skeleton first.
 *
 * @route    /[lang]/mi-cuenta/
 * @rendering SSR (prerender = false — requires authenticated user)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { isHostRole } from '@/lib/account-roles';
import AccountLayout from '@/layouts/AccountLayout.astro';
import AccountStatsGrid from '@/components/account/AccountStatsGrid.astro';
import AccountSectionCards from '@/components/account/AccountSectionCards.astro';
import {
    UserIcon,
    SettingsIcon,
    ChatIcon,
    NewsletterIcon,
    BuildingIcon,
    DashboardIcon,
} from '@repo/icons';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

// Auth guard: middleware should have redirected already, but this is the safety net.
const user = Astro.locals.user;
if (!user) {
    return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const t = createT(locale);

const title = t('account.pages.dashboard.title', 'Mi Cuenta');
const description = t(
    'account.pages.dashboard.description',
    'Gestiona tu perfil, favoritos, resenas y suscripcion'
);
const greeting = t('account.pages.dashboard.greeting', 'Hola');
const dashboardLabel = t('account.pages.dashboard.dashboardLabel', 'Panel de control');

// Determine host role for conditional sections.
const isHost = isHostRole(user.role ?? null);

// Generate user initials (up to 2 characters) for the avatar placeholder.
const initials = user.name
    .split(' ')
    .map((word: string) => word[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();

// Sections grid. We intentionally exclude Favoritos, Reseñas and
// Suscripción from this list — they already have dedicated stat
// cards directly above with the same link. Listing them in both
// places duplicated the navigation entry and made the dashboard feel
// cluttered. Keep this grid for items the stats row does NOT cover.
// Host roles get two extra cards prepended (properties + host dashboard).
const navItems = [
    ...(isHost
        ? [
              {
                  label: t('account.pages.dashboard.nav.myProperties', 'Mis propiedades'),
                  href: buildUrl({ locale, path: 'mi-cuenta/propiedades' }),
                  description: t(
                      'account.pages.dashboard.nav.myPropertiesDesc',
                      'Gestioná tus alojamientos publicados'
                  ),
                  Icon: BuildingIcon,
              },
              {
                  label: t('account.pages.dashboard.nav.hostDashboard', 'Panel del anfitrión'),
                  href: buildUrl({ locale, path: 'mi-cuenta/host-dashboard' }),
                  description: t(
                      'account.pages.dashboard.nav.hostDashboardDesc',
                      'Resumen de tu actividad como anfitrión'
                  ),
                  Icon: DashboardIcon,
              },
          ]
        : []),
    {
        label: t('account.pages.dashboard.nav.editProfile', 'Editar perfil'),
        href: buildUrl({ locale, path: 'mi-cuenta/editar' }),
        description: t(
            'account.pages.dashboard.nav.editProfileDesc',
            'Actualizá tu información personal y foto de perfil'
        ),
        Icon: UserIcon,
    },
    {
        label: t('account.pages.dashboard.nav.myMessages', 'Mis consultas'),
        href: buildUrl({ locale, path: 'mi-cuenta/consultas' }),
        description: t(
            'account.pages.dashboard.nav.myMessagesDesc',
            'Conversaciones con anfitriones'
        ),
        Icon: ChatIcon,
    },
    {
        label: t('account.pages.dashboard.nav.preferences', 'Preferencias'),
        href: buildUrl({ locale, path: 'mi-cuenta/preferencias' }),
        description: t(
            'account.pages.dashboard.nav.preferencesDesc',
            'Configurá notificaciones, idioma y privacidad'
        ),
        Icon: SettingsIcon,
    },
    {
        label: t('account.pages.dashboard.nav.newsletter', 'Boletín de novedades'),
        href: buildUrl({ locale, path: 'mi-cuenta/newsletter' }),
        description: t(
            'account.pages.dashboard.nav.newsletterDesc',
            'Gestioná tu suscripción al boletín'
        ),
        Icon: NewsletterIcon,
    },
];

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<AccountLayout locale={locale} title={title} description={description} activeSection="mi-cuenta">
    <!-- ── User header card ── -->
    <article id="user-header" class="account__header-card">
        <!-- Decorative warm gradient frame on the right edge -->
        <span class="account__header-glow" aria-hidden="true" />
        <span class="account__header-pattern" aria-hidden="true" />

        <div class="account__header-inner">
            <!-- Avatar: photo when available, initials fallback otherwise (BETA-32) -->
            <div class="account__avatar" aria-hidden="true">
                <span class="account__avatar-ring" aria-hidden="true" />
                {user.image ? (
                    <img src={user.image} alt={user.name} class="account__avatar-img" />
                ) : (
                    <span class="account__avatar-initials">{initials}</span>
                )}
            </div>

            <!-- Name + email + small detail row -->
            <div class="account__user-info">
                <p class="account__user-eyebrow">{greeting}</p>
                <h1 class="account__user-name">{user.name}</h1>
                <p class="account__user-email">{user.email}</p>
            </div>

            <!-- CTA: edit profile -->
            <div class="account__header-actions">
                <a
                    href={buildUrl({ locale, path: 'mi-cuenta/editar' })}
                    class="account__header-cta"
                >
                    <UserIcon size={18} weight="regular" aria-hidden="true" />
                    {t('account.pages.dashboard.nav.editProfile', 'Editar perfil')}
                </a>
            </div>
        </div>
    </article>

    <!-- Main content: quick stats -->
    <div id="account-stats" class="account__main">
        <h2 class="account__section-title">{dashboardLabel}</h2>

        <!-- Stat cards row -->
        <AccountStatsGrid locale={locale} isHost={isHost} />

        <!-- Navigation cards grid (secondary) -->
        <AccountSectionCards locale={locale} navItems={navItems} />
    </div>
</AccountLayout>

<style>
    /* ── Page container ── */
    .account {
        max-width: var(--container-max, 1350px);
        margin-inline: auto;
        padding: var(--space-8, 2rem) var(--space-4, 1rem);
    }

    /* ── User header card ── */
    .account__header-card {
        position: relative;
        margin-bottom: var(--space-8, 2rem);
        border-radius: var(--radius-card);
        border: 1px solid var(--core-foreground-a08);
        background-color: var(--core-card);
        background-image: linear-gradient(
            135deg,
            var(--brand-primary-a05) 0%,
            var(--brand-accent-a05) 100%
        );
        box-shadow: var(--shadow-card);
        overflow: hidden;
        isolation: isolate;
    }

    /* Soft brand glow on the right shoulder. */
    .account__header-glow {
        position: absolute;
        top: -40%;
        right: -10%;
        width: 22rem;
        height: 22rem;
        border-radius: var(--radius-pill);
        background: radial-gradient(
            closest-side,
            var(--brand-primary-a20),
            transparent 70%
        );
        pointer-events: none;
        z-index: -1;
    }

    /* Faint dotted pattern at the bottom-left of the card. */
    .account__header-pattern {
        position: absolute;
        bottom: -1rem;
        left: -1rem;
        width: 10rem;
        height: 10rem;
        background-image: radial-gradient(
            circle,
            var(--brand-accent-a20) 1px,
            transparent 1.5px
        );
        background-size: 12px 12px;
        opacity: 0.55;
        pointer-events: none;
        z-index: -1;
    }

    .account__header-inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-6, 1.5rem);
        padding: var(--space-8, 2rem);
        text-align: center;
    }

    @media (min-width: 640px) {
        .account__header-inner {
            flex-direction: row;
            text-align: left;
            align-items: center;
        }
    }

    .account__avatar {
        position: relative;
        flex-shrink: 0;
        display: flex;
        width: 6.5rem;
        height: 6.5rem;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-pill);
        background: linear-gradient(
            135deg,
            var(--brand-primary),
            var(--brand-primary-lm12)
        );
        color: var(--core-card);
        font-size: 2rem;
        font-weight: 700;
        font-family: var(--font-heading);
        box-shadow: 0 12px 24px var(--brand-primary-a25);
    }

    /* Outer ring around the avatar to lift it visually off the surface. */
    .account__avatar-ring {
        position: absolute;
        inset: -6px;
        border-radius: var(--radius-pill);
        border: 2px solid var(--brand-primary-a20);
        pointer-events: none;
    }

    .account__avatar-initials {
        position: relative;
        z-index: 1;
    }

    /* Avatar photo fills the circle, covering the gradient placeholder. */
    .account__avatar-img {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: var(--radius-pill);
    }

    .account__user-info {
        flex: 1;
        min-width: 0;
    }

    .account__user-eyebrow {
        margin: 0 0 var(--space-1);
        font-family: var(--font-sans);
        font-size: 0.8125rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--brand-primary);
    }

    .account__user-name {
        margin: 0 0 var(--space-2);
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-family: var(--font-heading);
        font-weight: 700;
        color: var(--core-foreground);
        line-height: 1.15;
        word-break: break-word;
    }

    .account__user-email {
        margin: 0;
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
        word-break: break-all;
    }

    .account__header-actions {
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }

    .account__header-cta {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-3) var(--space-5);
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        font-weight: 600;
        color: var(--brand-primary);
        background-color: var(--core-card);
        border: 1px solid var(--brand-primary-a30);
        border-radius: var(--radius-button);
        text-decoration: none;
        transition:
            background-color var(--duration-fast) ease,
            color var(--duration-fast) ease,
            transform var(--duration-fast) ease,
            box-shadow var(--duration-fast) ease;
    }

    .account__header-cta:hover {
        background-color: var(--brand-primary);
        color: var(--core-card);
        transform: translateY(-1px);
        box-shadow: 0 8px 16px var(--brand-primary-a25);
    }

    .account__header-cta:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    /* ── Two-column layout ── */
    .account__body {
        display: grid;
        gap: var(--space-8, 2rem);
    }

    @media (min-width: 1024px) {
        .account__body {
            grid-template-columns: 17.5rem 1fr;
        }
    }

    /* ── Sidebar navigation ── */
    .account__sidebar {
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
        background-color: var(--core-card);
        padding: var(--space-6, 1.5rem);
    }

    .account__nav-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .account__nav-link {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        border-radius: var(--radius-button);
        padding: 0.75rem 1rem;
        color: var(--core-foreground);
        text-decoration: none;
        transition: background-color var(--duration-fast) ease, color var(--duration-fast) ease;
    }

    .account__nav-link:hover {
        background-color: var(--surface-warm);
    }

    .account__nav-link:hover .account__nav-label {
        color: var(--brand-primary);
    }

    .account__nav-link:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    .account__nav-icon {
        margin-top: 0.125rem;
        flex-shrink: 0;
        color: var(--core-muted-foreground);
        transition: color var(--duration-fast) ease;
    }

    .account__nav-link:hover .account__nav-icon {
        color: var(--brand-primary);
    }

    .account__nav-label {
        font-weight: 600;
        font-size: var(--text-body-sm);
        color: var(--core-foreground);
        transition: color var(--duration-fast) ease;
    }

    .account__nav-desc {
        font-size: var(--text-caption);
        color: var(--core-muted-foreground);
        margin-top: 0.125rem;
    }

    /* ── Main content ── */
    .account__main {
        display: flex;
        flex-direction: column;
        gap: var(--space-6, 1.5rem);
    }

    .account__section-title {
        margin: 0;
        font-size: var(--text-h3, 1.5rem);
        font-family: var(--font-heading);
        font-weight: 700;
        color: var(--core-foreground);
    }

</style>

<script>
    import { getApiUrl } from '@/lib/env';

    /**
     * Fetch user stats from the protected API and update the dashboard counters.
     * Runs client-side to avoid SSR cookie-forwarding complexity.
     * Falls back gracefully — default zeros are already rendered server-side.
     */
    /**
     * Clears the `stat-value--loading` shimmer from a list of element IDs.
     * Mirrors the defensive cleanup used throughout this script.
     */
    function clearLoadingState(ids: readonly string[]): void {
        for (const id of ids) {
            document.getElementById(id)?.classList.remove('stat-value--loading');
        }
    }

    async function loadStats(): Promise<void> {
        const base = `${getApiUrl()}/api/v1/protected`;

        // Detect view mode from the DOM: host view renders stat-properties;
        // tourist view renders stat-favorites/stat-reviews.
        const isHostView = document.getElementById('stat-properties') !== null;

        try {
            // /users/me/stats feeds the subscription widget for BOTH roles.
            // Reviews are only fetched when the tourist view is active (the
            // stat-reviews element exists), avoiding a needless request for hosts.
            const fetchPromises: Array<Promise<Response>> = [
                fetch(`${base}/users/me/stats`, { credentials: 'include' }),
            ];
            if (!isHostView) {
                fetchPromises.push(
                    fetch(`${base}/users/me/reviews?pageSize=1`, { credentials: 'include' })
                );
            }

            const [statsRes, reviewsRes] = await Promise.all(fetchPromises);

            // ── Subscription widget (common to both views) ──────────────────
            if (statsRes.ok) {
                const statsData = (await statsRes.json()) as {
                    data?: {
                        bookmarkCount?: number;
                        plan?: { name?: string; status?: string };
                    };
                };

                // Tourist-only: favorites counter.
                const favEl = document.getElementById('stat-favorites');
                if (favEl && statsData.data?.bookmarkCount !== undefined) {
                    favEl.textContent = String(statsData.data.bookmarkCount);
                    favEl.classList.remove('stat-value--loading');
                }

                const subEl = document.getElementById('stat-subscription');
                const statusEl = document.getElementById('stat-subscription-status');
                const planName = statsData.data?.plan?.name;
                const planStatus = statsData.data?.plan?.status;

                if (subEl) {
                    // BETA-32: free-tier users have `plan: null`. The old guard
                    // (`if plan?.name`) never cleared the shimmer for them, so the
                    // widget span loaded forever. Always clear on a successful
                    // fetch — show the plan name, or the "free" label otherwise.
                    if (planName) {
                        subEl.textContent = planName;
                    } else {
                        subEl.textContent = subEl.getAttribute('data-label-free') ?? 'Gratuito';
                    }
                    subEl.classList.remove('stat-value--loading');
                }

                if (statusEl) {
                    if (planStatus) {
                        const label = statusEl.getAttribute(`data-label-${planStatus}`);
                        if (label) statusEl.textContent = label;
                    } else {
                        // Free tier: the value line already reads "Plan Gratuito".
                        // Hide the status line instead of repeating the same label
                        // on both rows (was duplicated as "Plan Gratuito" twice).
                        statusEl.textContent = '';
                        statusEl.hidden = true;
                    }
                }
            }

            // ── Tourist view: reviews counter ────────────────────────────────
            if (!isHostView && reviewsRes?.ok) {
                const reviewsData = (await reviewsRes.json()) as {
                    data?: { totals?: { total?: number } };
                };
                const revEl = document.getElementById('stat-reviews');
                if (revEl && reviewsData.data?.totals?.total !== undefined) {
                    revEl.textContent = String(reviewsData.data.totals.total);
                    revEl.classList.remove('stat-value--loading');
                }
            }

            // Defensive: a non-2xx response (e.g. 401/500) runs neither the
            // ok-branches above nor the catch below, which used to leave the
            // widgets shimmering forever. Clear any remaining loading state so
            // no stat stays stuck (BETA-32).
            clearLoadingState(['stat-favorites', 'stat-reviews', 'stat-subscription']);
        } catch (error) {
            console.error('[account] Failed to load stats:', error);
            clearLoadingState(['stat-favorites', 'stat-reviews', 'stat-subscription']);
        }

        // ── Host view: properties + messages counters ────────────────────────
        // Runs independently of the tourist stats so a failure in one does not
        // affect the other. Only executes when the host DOM elements exist.
        if (!isHostView) {
            return;
        }

        try {
            const hostRes = await fetch(`${getApiUrl()}/api/v1/protected/host/dashboard`, {
                credentials: 'include',
            });

            if (hostRes.ok) {
                const hostData = (await hostRes.json()) as {
                    data?: {
                        properties?: { total?: number };
                        unreadConversations?: number;
                    };
                };

                const propEl = document.getElementById('stat-properties');
                if (propEl) {
                    propEl.textContent = String(hostData.data?.properties?.total ?? 0);
                    propEl.classList.remove('stat-value--loading');
                }

                const msgEl = document.getElementById('stat-messages');
                if (msgEl) {
                    msgEl.textContent = String(hostData.data?.unreadConversations ?? 0);
                    msgEl.classList.remove('stat-value--loading');
                }
            } else {
                // Non-2xx: clear shimmer so widgets don't stay stuck.
                clearLoadingState(['stat-properties', 'stat-messages']);
            }
        } catch (error) {
            console.error('[account] Failed to load host dashboard stats:', error);
            clearLoadingState(['stat-properties', 'stat-messages']);
        }
    }

    void loadStats();
</script>
