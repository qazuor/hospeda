---
/**
 * User Account Dashboard page.
 * Shows user information, quick stats, and navigation to account sub-sections.
 *
 * Rendering: SSR (prerender = false) - requires authenticated user.
 * Auth protection: This page checks Astro.locals.user and redirects to signin
 * if not authenticated. The middleware layer also enforces auth for /mi-cuenta/*.
 *
 * Route: /[lang]/mi-cuenta/
 */

import type { SupportedLocale } from '../../../lib/i18n';
import { createT } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import {
  UserIcon,
  FavoriteIcon,
  StarIcon,
  CreditCardIcon,
  SettingsIcon,
} from '@repo/icons';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Auth guard: redirect to signin if the user is not authenticated.
 * Astro.locals.user is populated by the auth middleware for protected routes.
 */
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const t = createT(locale as SupportedLocale);

const title = t('account.pages.dashboard.title', 'Mi Cuenta');
const description = t(
  'account.pages.dashboard.description',
  'Gestioná tu perfil, favoritos, reseñas y suscripción'
);
const greeting = t('account.pages.dashboard.greeting', 'Hola');
const dashboardLabel = t('account.pages.dashboard.dashboardLabel', 'Panel de control');
const viewLabel = t('account.pages.dashboard.viewLabel', 'Ver');

/**
 * Generate user initials from name for the avatar placeholder.
 */
const initials = user.name
  .split(' ')
  .map((word: string) => word[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();

/**
 * Navigation cards linking to each account sub-section.
 * Labels and descriptions are localized via createT(); hrefs use buildUrl() for consistency.
 */
const navItems = [
  {
    label: t('account.pages.dashboard.nav.editProfile', 'Editar perfil'),
    href: buildUrl({ locale, path: 'mi-cuenta/editar' }),
    description: t(
      'account.pages.dashboard.nav.editProfileDesc',
      'Actualizá tu información personal y foto de perfil'
    ),
    Icon: UserIcon,
  },
  {
    label: t('account.pages.dashboard.nav.myFavorites', 'Mis favoritos'),
    href: buildUrl({ locale, path: 'mi-cuenta/favoritos' }),
    description: t(
      'account.pages.dashboard.nav.myFavoritesDesc',
      'Alojamientos que guardaste para consultar más tarde'
    ),
    Icon: FavoriteIcon,
  },
  {
    label: t('account.pages.dashboard.nav.myReviews', 'Mis reseñas'),
    href: buildUrl({ locale, path: 'mi-cuenta/resenas' }),
    description: t(
      'account.pages.dashboard.nav.myReviewsDesc',
      'Reseñas que escribiste sobre alojamientos visitados'
    ),
    Icon: StarIcon,
  },
  {
    label: t('account.pages.dashboard.nav.mySubscription', 'Mi suscripción'),
    href: buildUrl({ locale, path: 'mi-cuenta/suscripcion' }),
    description: t(
      'account.pages.dashboard.nav.mySubscriptionDesc',
      'Administrá tu plan y método de pago'
    ),
    Icon: CreditCardIcon,
  },
  {
    label: t('account.pages.dashboard.nav.preferences', 'Preferencias'),
    href: buildUrl({ locale, path: 'mi-cuenta/preferencias' }),
    description: t(
      'account.pages.dashboard.nav.preferencesDesc',
      'Configurá notificaciones, idioma y privacidad'
    ),
    Icon: SettingsIcon,
  },
] as const;

/** Stat card translation keys */
const statFavoritesLabel = t('account.pages.dashboard.stats.favorites', 'Favoritos');
const statReviewsLabel = t('account.pages.dashboard.stats.reviews', 'Reseñas');
const statSubscriptionLabel = t('account.pages.dashboard.stats.subscription', 'Suscripción');
const statFavoritesDesc = t(
  'account.pages.dashboard.stats.favoritesDesc',
  'Alojamientos guardados'
);
const statReviewsDesc = t('account.pages.dashboard.stats.reviewsDesc', 'Reseñas escritas');
const statSubscriptionDesc = t(
  'account.pages.dashboard.stats.subscriptionDesc',
  'Plan actual'
);
const statSubscriptionStatus = t(
  'account.pages.dashboard.stats.subscriptionStatus',
  'Estado de la suscripción'
);
const statActiveStatus = t('account.pages.dashboard.stats.activeStatus', 'Activa');
const statTrialStatus = t('account.pages.dashboard.stats.trialStatus', 'En prueba');
const statFreeStatus = t('account.pages.dashboard.stats.freeStatus', 'Gratuito');

/**
 * Breadcrumb navigation items for this page.
 */
const breadcrumbItems = [
  { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
  { label: title, href: buildUrl({ locale, path: 'mi-cuenta' }) },
];

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout title={title} description={description} locale={locale}>
  <SEOHead
    slot="head"
    title={title}
    description={description}
    canonical={canonicalUrl}
    locale={locale}
    type="website"
    noindex={true}
  />

  <div class="container mx-auto max-w-6xl px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <!-- User Header Card -->
    <article
      id="user-header"
      class="mb-8 overflow-hidden rounded-xl border border-border bg-card shadow-sm"
    >
      <div class="flex flex-col items-center gap-6 p-8 sm:flex-row">
        <!-- User Avatar with Initials -->
        <div
          class="flex h-24 w-24 shrink-0 items-center justify-center rounded-full bg-primary text-3xl font-bold text-primary-foreground"
          aria-hidden="true"
        >
          {initials}
        </div>

        <!-- User Info -->
        <div class="flex-1 text-center sm:text-left">
          <h1 class="mb-1 text-3xl font-bold text-foreground">
            {greeting}, {user.name}
          </h1>
          <p class="text-lg text-muted-foreground">{user.email}</p>
        </div>
      </div>
    </article>

    <div class="grid gap-8 lg:grid-cols-[280px_1fr]">
      <!-- Navigation Sidebar -->
      <aside
        id="account-nav"
        class="rounded-xl border border-border bg-card p-6"
        aria-label="Navegación de cuenta"
      >
        <nav>
          <ul class="space-y-1" role="list">
            {navItems.map(({ label, href, description: desc, Icon }) => (
              <li>
                <a
                  href={href}
                  class="group flex items-start gap-3 rounded-lg px-4 py-3 text-foreground transition-colors hover:bg-muted focus-visible:bg-muted focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                >
                  <Icon
                    size={20}
                    weight="regular"
                    className="mt-0.5 shrink-0 text-muted-foreground group-hover:text-primary"
                    aria-hidden="true"
                  />
                  <div>
                    <div class="font-semibold group-hover:text-primary">{label}</div>
                    <div class="text-sm text-muted-foreground">{desc}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <!-- Main Content: Quick Stats -->
      <div id="account-stats" class="space-y-6">
        <h2 class="text-2xl font-bold text-foreground">{dashboardLabel}</h2>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <!-- Favorites Stat Card -->
          <article
            class="rounded-xl border border-border bg-card p-6 shadow-sm transition-shadow hover:shadow-md"
          >
            <div class="mb-3 flex items-center justify-between">
              <h3 class="text-lg font-semibold text-foreground">
                {statFavoritesLabel}
              </h3>
              <FavoriteIcon
                size={24}
                weight="fill"
                className="text-primary"
                aria-hidden="true"
              />
            </div>
            <p
              id="stat-favorites"
              class="mb-2 text-3xl font-bold text-foreground"
              aria-live="polite"
            >
              0
            </p>
            <p class="text-sm text-muted-foreground">{statFavoritesDesc}</p>
            <a
              href={buildUrl({ locale, path: 'mi-cuenta/favoritos' })}
              class="mt-4 inline-flex items-center text-sm font-medium text-primary hover:underline"
            >
              {viewLabel} {statFavoritesLabel.toLowerCase()} →
            </a>
          </article>

          <!-- Reviews Stat Card -->
          <article
            class="rounded-xl border border-border bg-card p-6 shadow-sm transition-shadow hover:shadow-md"
          >
            <div class="mb-3 flex items-center justify-between">
              <h3 class="text-lg font-semibold text-foreground">
                {statReviewsLabel}
              </h3>
              <StarIcon
                size={24}
                weight="fill"
                className="text-primary"
                aria-hidden="true"
              />
            </div>
            <p
              id="stat-reviews"
              class="mb-2 text-3xl font-bold text-foreground"
              aria-live="polite"
            >
              0
            </p>
            <p class="text-sm text-muted-foreground">{statReviewsDesc}</p>
            <a
              href={buildUrl({ locale, path: 'mi-cuenta/resenas' })}
              class="mt-4 inline-flex items-center text-sm font-medium text-primary hover:underline"
            >
              {viewLabel} {statReviewsLabel.toLowerCase()} →
            </a>
          </article>

          <!-- Subscription Stat Card -->
          <article
            class="rounded-xl border border-border bg-card p-6 shadow-sm transition-shadow hover:shadow-md"
          >
            <div class="mb-3 flex items-center justify-between">
              <h3 class="text-lg font-semibold text-foreground">
                {statSubscriptionLabel}
              </h3>
              <CreditCardIcon
                size={24}
                weight="regular"
                className="text-primary"
                aria-hidden="true"
              />
            </div>
            <p
              id="stat-subscription"
              class="mb-2 text-3xl font-bold text-foreground"
              aria-live="polite"
            >
              {statSubscriptionDesc}
            </p>
            <p
              id="stat-subscription-status"
              class="text-sm text-muted-foreground"
              data-label-active={statActiveStatus}
              data-label-trial={statTrialStatus}
              data-label-free={statFreeStatus}
              aria-live="polite"
            >
              {statSubscriptionStatus}
            </p>
            <a
              href={buildUrl({ locale, path: 'mi-cuenta/suscripcion' })}
              class="mt-4 inline-flex items-center text-sm font-medium text-primary hover:underline"
            >
              {viewLabel} {statSubscriptionLabel.toLowerCase()} →
            </a>
          </article>
        </div>

        <!-- Navigation Cards Grid -->
        <section aria-label="Secciones de cuenta">
          <h2 class="mb-4 text-xl font-semibold text-foreground">
            {t('account.pages.dashboard.sectionsLabel', 'Secciones')}
          </h2>
          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            {navItems.map(({ label, href, description: desc, Icon }) => (
              <a
                href={href}
                class="group flex flex-col gap-3 rounded-xl border border-border bg-card p-5 shadow-sm transition-all hover:border-primary/40 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
              >
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors">
                    <Icon size={20} weight="regular" aria-hidden="true" />
                  </div>
                  <span class="font-semibold text-foreground group-hover:text-primary transition-colors">
                    {label}
                  </span>
                </div>
                <p class="text-sm text-muted-foreground">{desc}</p>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { getApiUrl } from '../../../lib/env';

  /**
   * Fetch user stats from the protected API and update dashboard counters.
   * Runs client-side to avoid SSR cookie forwarding issues.
   * Falls back gracefully to default values on any error.
   */
  async function loadStats(): Promise<void> {
    const base = `${getApiUrl()}/api/v1/protected`;

    try {
      const [statsRes, reviewsRes] = await Promise.all([
        fetch(`${base}/users/me/stats`, { credentials: 'include' }),
        fetch(`${base}/users/me/reviews?pageSize=1`, { credentials: 'include' }),
      ]);

      if (statsRes.ok) {
        const statsData = (await statsRes.json()) as {
          data?: {
            bookmarkCount?: number;
            plan?: { name?: string; status?: string };
          };
        };

        const favEl = document.getElementById('stat-favorites');
        if (favEl && statsData.data?.bookmarkCount !== undefined) {
          favEl.textContent = String(statsData.data.bookmarkCount);
        }

        const subEl = document.getElementById('stat-subscription');
        if (subEl && statsData.data?.plan?.name) {
          subEl.textContent = statsData.data.plan.name;
        }

        const statusEl = document.getElementById('stat-subscription-status');
        if (statusEl) {
          const plan = statsData.data?.plan;
          if (plan?.status) {
            const label = statusEl.getAttribute(`data-label-${plan.status}`);
            if (label) {
              statusEl.textContent = label;
            }
          } else {
            const freeLabel = statusEl.getAttribute('data-label-free');
            if (freeLabel) {
              statusEl.textContent = freeLabel;
            }
          }
        }
      }

      if (reviewsRes.ok) {
        const reviewsData = (await reviewsRes.json()) as {
          data?: { totals?: { total?: number } };
        };
        const revEl = document.getElementById('stat-reviews');
        if (revEl && reviewsData.data?.totals?.total !== undefined) {
          revEl.textContent = String(reviewsData.data.totals.total);
        }
      }
    } catch {
      // Silently fail - default values are already displayed
    }
  }

  loadStats();
</script>
