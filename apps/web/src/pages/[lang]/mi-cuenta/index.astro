---
/**
 * User Account Dashboard - authenticated SSR page.
 * Shows user information, quick stats, and navigation to account sections.
 * This page is protected by middleware - user is redirected to signin if not authenticated.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Container from '../../../components/ui/Container.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Section from '../../../components/ui/Section.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { t } from '../../../lib/i18n';
import { FavoriteIcon, StarIcon, CheckCircleIcon } from '@repo/icons';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * User is guaranteed to exist due to middleware auth protection
 */
const user = Astro.locals.user;
if (!user) {
	return Astro.redirect(`/${locale}/auth/signin`);
}

/**
 * Generate user initials from name for avatar
 */
const initials = user.name
	.split(' ')
	.map((word) => word[0])
	.slice(0, 2)
	.join('')
	.toUpperCase();

const title = t({ locale, namespace: 'account', key: 'pages.dashboard.title' });
const description = t({ locale, namespace: 'account', key: 'pages.dashboard.description' });
const greeting = t({ locale, namespace: 'account', key: 'pages.dashboard.greeting' });
const dashboardLabel = t({ locale, namespace: 'account', key: 'pages.dashboard.dashboardLabel' });
const viewLabel = t({ locale, namespace: 'account', key: 'pages.dashboard.viewLabel' });

/**
 * Navigation items for the account sidebar.
 * Labels and descriptions are localized via t(); hrefs use locale dynamically.
 */
const navItems = [
	{
		label: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.editProfile' }),
		href: `/${locale}/mi-cuenta/editar/`,
		description: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.editProfileDesc' }),
	},
	{
		label: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.myFavorites' }),
		href: `/${locale}/mi-cuenta/favoritos/`,
		description: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.myFavoritesDesc' }),
	},
	{
		label: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.myReviews' }),
		href: `/${locale}/mi-cuenta/resenas/`,
		description: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.myReviewsDesc' }),
	},
	{
		label: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.preferences' }),
		href: `/${locale}/mi-cuenta/preferencias/`,
		description: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.preferencesDesc' }),
	},
	{
		label: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.mySubscription' }),
		href: `/${locale}/mi-cuenta/suscripcion/`,
		description: t({ locale, namespace: 'account', key: 'pages.dashboard.nav.mySubscriptionDesc' }),
	},
];

const statFavoritesLabel = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.favorites' });
const statReviewsLabel = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.reviews' });
const statSubscriptionLabel = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.subscription' });
const statFavoritesDesc = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.favoritesDesc' });
const statReviewsDesc = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.reviewsDesc' });
const statSubscriptionDesc = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.subscriptionDesc' });
const statSubscriptionStatus = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.subscriptionStatus' });
const statActiveStatus = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.activeStatus' });
const statTrialStatus = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.trialStatus' });
const statFreeStatus = t({ locale, namespace: 'account', key: 'pages.dashboard.stats.freeStatus' });

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: title, href: `/${locale}/mi-cuenta/` },
];

/**
 * Stats are fetched client-side via API calls to avoid SSR cookie forwarding issues.
 * Default values are shown during loading.
 */
const stats = {
	favorites: 0,
	reviews: 0,
	subscription: 'free',
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout title={title} description={description} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- User Header Card -->
				<article
					id="user-header"
					class="mb-8 overflow-hidden rounded-lg border border-border bg-surface shadow-sm"
				>
					<div class="flex flex-col items-center gap-6 p-8 sm:flex-row">
						<!-- User Avatar with Initials -->
						<div
							class="flex h-24 w-24 flex-shrink-0 items-center justify-center rounded-full bg-primary text-3xl font-bold text-white"
							aria-hidden="true"
						>
							{initials}
						</div>

						<!-- User Info -->
						<div class="flex-1 text-center sm:text-left">
							<h1 class="mb-2 text-3xl font-bold text-text-primary">
								{greeting}, {user.name}
							</h1>
							<p class="text-lg text-text-secondary">{user.email}</p>
						</div>
					</div>
				</article>

				<div class="grid gap-8 lg:grid-cols-[300px_1fr]">
					<!-- Navigation Sidebar -->
					<aside
						id="account-nav"
						class="rounded-lg border border-border bg-surface p-6"
						aria-label="Account navigation"
					>
						<nav>
							<ul class="space-y-2" role="list">
								{
									navItems.map((item) => (
										<li>
											<a
												href={item.href}
												class="group block rounded-md px-4 py-3 text-text-primary transition-colors hover:bg-bg focus-visible:bg-bg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
											>
												<div class="font-semibold group-hover:text-primary">
													{item.label}
												</div>
												<div class="text-sm text-text-tertiary">{item.description}</div>
											</a>
										</li>
									))
								}
							</ul>
						</nav>
					</aside>

					<!-- Main Content - Quick Stats -->
					<div id="account-stats" class="space-y-6">
						<h2 class="text-2xl font-bold text-text-primary">{dashboardLabel}</h2>

						<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
							<!-- Favorites Card -->
							<article
								class="rounded-lg border border-border bg-surface p-6 shadow-sm transition-shadow hover:shadow-md"
							>
								<div class="mb-3 flex items-center justify-between">
									<h3 class="text-lg font-semibold text-text-primary">
										{statFavoritesLabel}
									</h3>
									<FavoriteIcon size={24} className="text-primary" weight="fill" aria-hidden="true" />
								</div>
								<p id="stat-favorites" class="mb-2 text-3xl font-bold text-text-primary">{stats.favorites}</p>
								<p class="text-sm text-text-secondary">{statFavoritesDesc}</p>
								<a
									href={`/${locale}/mi-cuenta/favoritos/`}
									class="mt-4 inline-flex items-center text-sm font-medium text-primary hover:underline"
								>
									{viewLabel} {statFavoritesLabel.toLowerCase()} →
								</a>
							</article>

							<!-- Reviews Card -->
							<article
								class="rounded-lg border border-border bg-surface p-6 shadow-sm transition-shadow hover:shadow-md"
							>
								<div class="mb-3 flex items-center justify-between">
									<h3 class="text-lg font-semibold text-text-primary">
										{statReviewsLabel}
									</h3>
									<StarIcon size={24} className="text-primary" weight="fill" aria-hidden="true" />
								</div>
								<p id="stat-reviews" class="mb-2 text-3xl font-bold text-text-primary">{stats.reviews}</p>
								<p class="text-sm text-text-secondary">{statReviewsDesc}</p>
								<a
									href={`/${locale}/mi-cuenta/resenas/`}
									class="mt-4 inline-flex items-center text-sm font-medium text-primary hover:underline"
								>
									{viewLabel} {statReviewsLabel.toLowerCase()} →
								</a>
							</article>

							<!-- Subscription Card -->
							<article
								class="rounded-lg border border-border bg-surface p-6 shadow-sm transition-shadow hover:shadow-md"
							>
								<div class="mb-3 flex items-center justify-between">
									<h3 class="text-lg font-semibold text-text-primary">
										{statSubscriptionLabel}
									</h3>
									<CheckCircleIcon size={24} className="text-primary" aria-hidden="true" />
								</div>
								<p id="stat-subscription" class="mb-2 text-3xl font-bold text-text-primary">
									{statSubscriptionDesc}
								</p>
								<p
									id="stat-subscription-status"
									class="text-sm text-text-secondary"
									data-label-active={statActiveStatus}
									data-label-trial={statTrialStatus}
									data-label-free={statFreeStatus}
								>
									{statSubscriptionStatus}
								</p>
								<a
									href={`/${locale}/mi-cuenta/suscripcion/`}
									class="mt-4 inline-flex items-center text-sm font-medium text-primary hover:underline"
								>
									{viewLabel} {statSubscriptionLabel.toLowerCase()} →
								</a>
							</article>
						</div>
					</div>
				</div>
			</div>
		</Section>
	</Container>
</BaseLayout>

<script>
	import { getApiUrl } from '../../../lib/env';

	/**
	 * Fetch user stats from API and update dashboard numbers.
	 * Falls back gracefully to default values on error.
	 */
	async function loadStats() {
		const base = `${getApiUrl()}/api/v1/protected`;

		try {
			const [statsRes, reviewsRes] = await Promise.all([
				fetch(`${base}/users/me/stats`, { credentials: 'include' }),
				fetch(`${base}/users/me/reviews?pageSize=1`, { credentials: 'include' }),
			]);

			if (statsRes.ok) {
				const statsData = await statsRes.json();
				const favEl = document.getElementById('stat-favorites');
				if (favEl && statsData.data?.bookmarkCount !== undefined) {
					favEl.textContent = String(statsData.data.bookmarkCount);
				}
				const subEl = document.getElementById('stat-subscription');
				if (subEl && statsData.data?.plan?.name) {
					subEl.textContent = statsData.data.plan.name;
				}
				const statusEl = document.getElementById('stat-subscription-status');
				if (statusEl) {
					const plan = statsData.data?.plan;
					if (plan && plan.status) {
						const labelKey = `data-label-${plan.status}`;
						const label = statusEl.getAttribute(labelKey);
						if (label) {
							statusEl.textContent = label;
						}
					} else {
						// No plan = free user, use free label
						const freeLabel = statusEl.getAttribute('data-label-free');
						if (freeLabel) {
							statusEl.textContent = freeLabel;
						}
					}
				}
			}

			if (reviewsRes.ok) {
				const reviewsData = await reviewsRes.json();
				const revEl = document.getElementById('stat-reviews');
				if (revEl && reviewsData.data?.totals?.total !== undefined) {
					revEl.textContent = String(reviewsData.data.totals.total);
				}
			}
		} catch {
			// Silently fail - default values are already displayed
		}
	}

	loadStats();
</script>
