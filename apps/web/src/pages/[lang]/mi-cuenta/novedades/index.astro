---
/**
 * @file novedades/index.astro
 * @description What's New panel page — shows all platform updates for hosts/commerce.
 *
 * SSR (not prerendered) — requires an authenticated user.
 *
 * @route /[lang]/mi-cuenta/novedades/
 */

import AccountLayout from '@/layouts/AccountLayout.astro';
import { WhatsNewPageList } from '@/components/account/WhatsNewPageList.client';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';

const locale = (Astro.locals.locale ?? (Astro.params.lang as SupportedLocale | undefined) ?? 'es') as SupportedLocale;
const user = Astro.locals.user;

if (!user) {
    return Astro.redirect(`/${locale}/auth/signin`);
}

const { t } = createTranslations(locale);

const title = t('account.pages.whatsNew.title', 'Novedades');
const description = t('account.pages.whatsNew.desc', 'Novedades y actualizaciones de la plataforma');
---

<AccountLayout locale={locale} title={title} description={description} activeSection="novedades">
    <article class="whats-new-page">
        <header class="whats-new-page__header">
            <h1 class="whats-new-page__title">{title}</h1>
            <p class="whats-new-page__desc">{description}</p>
        </header>

        <WhatsNewPageList locale={locale} client:idle />
    </article>
</AccountLayout>

<style>
    :global(.whats-new-page) {
        max-width: 720px;
    }

    :global(.whats-new-page__header) {
        margin-bottom: var(--space-6);
    }

    :global(.whats-new-page__title) {
        margin: 0 0 var(--space-2);
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--core-foreground);
    }

    :global(.whats-new-page__desc) {
        margin: 0;
        color: var(--core-muted-foreground);
        font-size: 0.9375rem;
    }

    :global(.whats-new-page__empty) {
        padding: var(--space-8) 0;
        text-align: center;
        color: var(--core-muted-foreground);
    }

    :global(.whats-new-page__error) {
        padding: var(--space-8) 0;
        text-align: center;
        color: var(--brand-accent);
    }

    :global(.whats-new-card) {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
        padding: var(--space-5);
        margin-bottom: var(--space-4);
        border-radius: var(--radius-card);
        border: 1px solid var(--core-foreground-a08);
        background-color: var(--core-card);
    }

    :global(.whats-new-card--seen) {
        opacity: 0.7;
    }

    :global(.whats-new-card__img) {
        width: 100%;
        height: 200px;
        object-fit: cover;
        border-radius: var(--radius-md);
    }

    :global(.whats-new-card__body) {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    :global(.whats-new-card__meta) {
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }

    :global(.whats-new-card__badge) {
        display: inline-flex;
        border-radius: var(--radius-pill);
        background-color: var(--brand-primary-a12);
        padding: 0.125rem 0.5rem;
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--brand-primary);
    }

    :global(.whats-new-card__date) {
        font-size: 0.8125rem;
        color: var(--core-muted-foreground);
    }

    :global(.whats-new-card__title) {
        margin: 0;
        font-family: var(--font-heading);
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--core-foreground);
    }

    :global(.whats-new-card__content) {
        font-size: 0.9375rem;
        line-height: 1.6;
        color: var(--core-foreground);
    }

    :global(.whats-new-card__content a) {
        color: var(--brand-primary);
        text-decoration: underline;
    }
</style>
