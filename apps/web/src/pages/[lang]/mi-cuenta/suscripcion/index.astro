---
/**
 * @file mi-cuenta/suscripcion/index.astro
 * @description Account subscription page — renders the SubscriptionDashboard island.
 * @route /{lang}/mi-cuenta/suscripcion/
 * @rendering SSR
 */

import AccountLayout from '@/layouts/AccountLayout.astro';
import { SubscriptionDashboard } from '@/components/account/SubscriptionDashboard.client';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { fetchPublicPlans, filterPlansByCategory } from '@/lib/billing/fetch-plans';

const locale = Astro.locals.locale as SupportedLocale;
const user = Astro.locals.user;

if (!user) {
	return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const { t } = createTranslations(locale);
const title = t('account.pages.subscription.title', 'Suscripción');

/** Minimal user shape forwarded to the island (no sensitive fields) */
const islandUser = {
	id: user.id,
	role: (user as { role?: string }).role ?? 'USER',
};

/**
 * Fetch owner plans server-side so the PlanChangeFlow island has the full plan
 * catalog without an extra client-side request. Degrades gracefully on error
 * (island falls back to the plain pricing-page link).
 */
const plansResult = await fetchPublicPlans();
const ownerPlans = plansResult.ok ? filterPlansByCategory(plansResult.plans, 'owner') : [];
---

<AccountLayout locale={locale} title={title} activeSection="suscripcion">
	<h2 class="account-section__title">{title}</h2>

	<SubscriptionDashboard
		locale={locale}
		user={islandUser}
		plans={ownerPlans}
		client:load
	/>
</AccountLayout>

<style>
	.account-section__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.5rem, 3vw, 2rem);
		color: var(--core-foreground);
		margin: 0 0 var(--space-6);
	}
</style>
