---
/**
 * Subscription page - displays current plan and billing information.
 * Protected page under /mi-cuenta/ requiring authentication.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { t } from '../../../lib/i18n';
import { SubscriptionCard } from '../../../components/account/SubscriptionCard.client';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/** Auth guard: redirect unauthenticated users to sign in */
const user = Astro.locals.user;
if (!user) {
	return Astro.redirect(`/${locale}/auth/signin`);
}

const title = t({ locale, namespace: 'account', key: 'pages.subscription.title' });
const description = t({ locale, namespace: 'account', key: 'pages.subscription.description' });
const accountLabel = t({ locale, namespace: 'account', key: 'pages.accountLabel' });
const headingText = t({ locale, namespace: 'account', key: 'pages.subscription.heading' });
const headingDesc = t({ locale, namespace: 'account', key: 'pages.subscription.headingDesc' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: accountLabel, href: `/${locale}/mi-cuenta/` },
	{ label: title, href: `/${locale}/mi-cuenta/suscripcion/` },
];

/**
 * Subscription data will be enhanced client-side via API when billing is available.
 * For now, shows "Free Plan" as the default.
 */
---

<BaseLayout title={title} description={description} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<div class="mx-auto max-w-3xl py-8">
			<div class="mb-8">
				<h1 class="mb-2 text-3xl font-bold text-text-primary">
					{headingText}
				</h1>
				<p class="text-text-secondary">
					{headingDesc}
				</p>
			</div>

			<SubscriptionCard
				client:load
				locale={locale}
				upgradeHref={`/${locale}/precios/turistas/`}
			/>
		</div>
	</Container>
</BaseLayout>
