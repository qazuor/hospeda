---
/**
 * Edit Profile page.
 * Wraps ProfileEditForm React island for interactive profile updates.
 *
 * Rendering: SSR (on-demand). Auth-protected via middleware; also guards
 * directly in frontmatter and redirects to signin if user is absent.
 *
 * Route: /[lang]/mi-cuenta/editar
 */

import type { SupportedLocale } from '../../../lib/i18n';
import { createT } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import { ProfileEditForm } from '../../../components/account/ProfileEditForm.client';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Auth guard: middleware protects /mi-cuenta/* but we also check here
 * to ensure a clean redirect with the correct locale.
 */
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const t = createT(locale as SupportedLocale);

const title = t('account.pages.editProfile.title', 'Editar perfil');
const description = t(
  'account.pages.editProfile.description',
  'Actualizá tu información personal y foto de perfil'
);
const accountLabel = t('account.pages.accountLabel', 'Mi Cuenta');

/**
 * Extract bio from user profile if present, with a safe fallback.
 */
const userRecord = user as Record<string, unknown>;
const profile = userRecord.profile as Record<string, unknown> | undefined;
const initialBio = (profile?.bio as string) ?? '';

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const breadcrumbItems = [
  { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
  { label: accountLabel, href: buildUrl({ locale, path: 'mi-cuenta' }) },
  { label: title, href: buildUrl({ locale, path: 'mi-cuenta/editar' }) },
];
---

<BaseLayout title={title} description={description} locale={locale}>
  <SEOHead
    slot="head"
    title={title}
    description={description}
    canonical={canonicalUrl}
    locale={locale}
    type="website"
    noindex={true}
  />

  <div class="container mx-auto max-w-3xl px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <header class="mb-8">
      <h1 class="mb-2 text-3xl font-bold text-foreground">{title}</h1>
      <p class="text-lg text-muted-foreground">{description}</p>
    </header>

    <div class="rounded-xl border border-border bg-card p-6 shadow-sm sm:p-8">
      <ProfileEditForm
        client:load
        userId={user.id}
        initialName={user.name}
        initialBio={initialBio}
        email={user.email}
        locale={locale}
      />
    </div>
  </div>
</BaseLayout>
