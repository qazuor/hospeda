---
/**
 * Edit Profile Page - authenticated SSR page.
 * Uses ProfileEditForm React island for interactive form submission.
 * This page is protected by middleware - user is redirected to signin if not authenticated.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Container from '../../../components/ui/Container.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Section from '../../../components/ui/Section.astro';
import { ProfileEditForm } from '../../../components/account/ProfileEditForm.client';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { t } from '../../../lib/i18n';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * User is guaranteed to exist due to middleware auth protection
 */
const user = Astro.locals.user;
if (!user) {
	return Astro.redirect(`/${locale}/auth/signin`);
}

const title = t({ locale, namespace: 'account', key: 'pages.editProfile.title' });
const description = t({ locale, namespace: 'account', key: 'pages.editProfile.description' });
const accountLabel = t({ locale, namespace: 'account', key: 'pages.accountLabel' });

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: accountLabel, href: `/${locale}/mi-cuenta/` },
	{ label: title, href: `/${locale}/mi-cuenta/editar/` },
];

/**
 * Extract user bio from profile if available
 */
const userBio = (user as Record<string, unknown>).profile
	? ((user as Record<string, unknown>).profile as Record<string, unknown>)?.bio as string ?? ''
	: '';

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout title={title} description={description} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-3xl">
				<!-- Page Header -->
				<header id="page-header" class="mb-8">
					<h1 class="mb-2 text-3xl font-bold text-text-primary">{title}</h1>
					<p class="text-lg text-text-secondary">{description}</p>
				</header>

				<!-- Profile Edit Form (React Island) -->
				<article
					id="profile-form"
					class="rounded-lg border border-border bg-surface p-6 shadow-sm sm:p-8"
				>
					<ProfileEditForm
						client:visible
						userId={user.id}
						initialName={user.name}
						initialBio={userBio}
						email={user.email}
						locale={locale}
					/>
				</article>
			</div>
		</Section>
	</Container>
</BaseLayout>
