---
/**
 * Edit Profile Page - authenticated SSR page.
 * Uses ProfileEditForm React island for interactive form submission.
 * This page is protected by middleware - user is redirected to signin if not authenticated.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Container from '../../../components/ui/Container.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Section from '../../../components/ui/Section.astro';
import { ProfileEditForm } from '../../../components/account/ProfileEditForm.client';
import { isValidLocale, type SupportedLocale } from '../../../lib/i18n';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * User is guaranteed to exist due to middleware auth protection
 */
const user = Astro.locals.user;
if (!user) {
	return Astro.redirect(`/${locale}/auth/signin`);
}

/**
 * Localized page titles
 */
const titles: Record<SupportedLocale, string> = {
	es: 'Editar Perfil',
	en: 'Edit Profile',
	pt: 'Editar Perfil',
};

/**
 * Localized meta descriptions
 */
const descriptions: Record<SupportedLocale, string> = {
	es: 'Actualiza tu información personal y preferencias de cuenta.',
	en: 'Update your personal information and account preferences.',
	pt: 'Atualize suas informações pessoais e preferências de conta.',
};

/**
 * Localized home breadcrumb labels
 */
const homeLabels: Record<SupportedLocale, string> = {
	es: 'Inicio',
	en: 'Home',
	pt: 'Início',
};

/**
 * Localized account breadcrumb labels
 */
const accountLabels: Record<SupportedLocale, string> = {
	es: 'Mi Cuenta',
	en: 'My Account',
	pt: 'Minha Conta',
};

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: homeLabels[locale], href: `/${locale}/` },
	{ label: accountLabels[locale], href: `/${locale}/mi-cuenta/` },
	{ label: titles[locale], href: `/${locale}/mi-cuenta/editar/` },
];

/**
 * Extract user bio from profile if available
 */
const userBio = (user as Record<string, unknown>).profile
	? ((user as Record<string, unknown>).profile as Record<string, unknown>)?.bio as string ?? ''
	: '';

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout title={titles[locale]} description={descriptions[locale]} locale={locale}>
	<SEOHead
		slot="head"
		title={titles[locale]}
		description={descriptions[locale]}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-3xl">
				<!-- Page Header -->
				<header id="page-header" class="mb-8">
					<h1 class="mb-2 text-3xl font-bold text-text-primary">{titles[locale]}</h1>
					<p class="text-lg text-text-secondary">{descriptions[locale]}</p>
				</header>

				<!-- Profile Edit Form (React Island) -->
				<article
					id="profile-form"
					class="rounded-lg border border-border bg-surface p-6 shadow-sm sm:p-8"
				>
					<ProfileEditForm
						client:visible
						userId={user.id}
						initialName={user.name}
						initialBio={userBio}
						email={user.email}
						locale={locale}
					/>
				</article>
			</div>
		</Section>
	</Container>
</BaseLayout>
