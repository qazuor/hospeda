---
/**
 * @file mi-cuenta/promociones/[id]/editar.astro
 * @description Edit owner promotion page — mounts the PromotionForm island in edit
 * mode. The island fetches the promotion record client-side via
 * `ownerPromotionApi.getById({ id: promotionId })` on mount and shows a loading
 * skeleton until data arrives.
 *
 * Approach: client-load (b). The `PromotionForm` already imports `ownerPromotionApi`
 * and handles loading/error states. Fetching server-side would require forwarding
 * cookies and a full SSR fetch cycle just to pass data the island can fetch itself —
 * unlike `AccommodationEditor`, the promotion form has no additional catalogs
 * (amenities, destinations) that would justify the SSR fetch overhead.
 *
 * Auth protection: middleware redirects unauthenticated users. This page
 * is only reachable by users with an active session.
 *
 * @route    /[lang]/mi-cuenta/promociones/[id]/editar
 * @rendering SSR (prerender = false — requires authenticated user)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import AccountLayout from '@/layouts/AccountLayout.astro';
import { PromotionForm } from '@/components/host/PromotionForm.client';

export const prerender = false;

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);

const title = t('host.promotions.actions.edit', 'Editar promoción');
const description = t('host.promotions.pageDescription', 'Gestioná tus promociones y descuentos');

// Auth guard: middleware protects /mi-cuenta/* automatically, safety net.
const user = Astro.locals.user;
if (!user) {
    return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

// Extract promotion ID from route params.
const promotionId = Astro.params.id;
if (!promotionId) {
    return Astro.redirect(buildUrl({ locale, path: 'mi-cuenta/promociones' }));
}
---

<AccountLayout locale={locale} title={title} description={description} activeSection="promociones">
    <div class="edit-promo-page__header">
        <h2 class="edit-promo-page__title">{title}</h2>
        <p class="edit-promo-page__subtitle">{description}</p>
    </div>

    <PromotionForm client:load locale={locale} mode="edit" promotionId={promotionId} />
</AccountLayout>

<style>
    .edit-promo-page__header {
        margin-bottom: var(--space-6);
    }

    .edit-promo-page__title {
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: clamp(1.5rem, 3vw, 2rem);
        color: var(--core-foreground);
        margin: 0 0 0.25rem;
    }

    .edit-promo-page__subtitle {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm, 0.9375rem);
        color: var(--core-muted-foreground);
        margin: 0;
    }
</style>
