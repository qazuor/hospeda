---
/**
 * @file mi-cuenta/host-dashboard.astro
 * @description Host dashboard page — aggregated view of property counts, plan info,
 * unread messages, and quick actions for the authenticated host user.
 *
 * Data is fetched client-side by the HostDashboard React island.
 * The island renders a loading skeleton, then hydrates with live data.
 *
 * Auth protection: middleware redirects unauthenticated users. This page
 * is only reachable by users with an active session.
 *
 * @route    /[lang]/mi-cuenta/host-dashboard/
 * @rendering SSR (prerender = false — requires authenticated user)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import AccountLayout from '@/layouts/AccountLayout.astro';
import AccountPageHeader from '@/components/account/AccountPageHeader.astro';
import { HostDashboard } from '@/components/host/HostDashboard.client';

export const prerender = false;

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);

const title = t('host.dashboard.pageTitle', 'Panel del anfitrión');
const description = t('host.dashboard.pageDescription', 'Resumen de tus propiedades y suscripción');

// Auth guard: middleware protects /mi-cuenta/* automatically, safety net.
const user = Astro.locals.user;
if (!user) {
    return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}
---

<AccountLayout locale={locale} title={title} description={description} activeSection="host-dashboard">
    <AccountPageHeader title={title} description={description} />

    <HostDashboard client:load locale={locale} />
</AccountLayout>
