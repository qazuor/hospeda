---
/**
 * @file mi-cuenta/comercio/index.astro
 * @description Commerce owner self-service listing index (SPEC-249 Part A,
 * extended in HOS-166 PR-C with the create CTA and the per-listing state
 * machine — badge, completeness checklist, and publish+pay CTA).
 * Lists the authenticated COMMERCE_OWNER's own listings across both verticals
 * (gastronomy + experiences) and deep-links each to its operational editor.
 *
 * Auth: middleware protects /mi-cuenta/* (session required). This page adds a
 * role gate so only commerce owners (and staff) reach it.
 *
 * @route     /[lang]/mi-cuenta/comercio/
 * @rendering SSR (prerender = false — authenticated, owner-scoped data)
 */
import AccountLayout from '@/layouts/AccountLayout.astro';
import AccountPageHeader from '@/components/account/AccountPageHeader.astro';
import AccountSectionCard from '@/components/account/AccountSectionCard.astro';
import { CommerceListingActions } from '@/components/commerce/CommerceListingActions.client';
import { isCommerceOwnerRole } from '@/lib/account-roles';
import { fetchOwnerCommerceListingsWithState } from '@/lib/commerce/owner-listings';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

export const prerender = false;

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);

const user = Astro.locals.user;
if (!user) {
    return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

// Role gate: only commerce owners (and staff) may manage commerce listings.
if (!isCommerceOwnerRole(user.role)) {
    return Astro.redirect(buildUrl({ locale, path: 'mi-cuenta' }));
}

const title = t('commerce.owner.list.title', 'Mi comercio');
const subtitle = t('commerce.owner.list.subtitle', '');

const cookieHeader = Astro.request.headers.get('cookie') ?? undefined;
const listings = await fetchOwnerCommerceListingsWithState({ cookieHeader });

const createUrl = buildUrl({ locale, path: 'mi-cuenta/comercio/nuevo' });
---

<AccountLayout locale={locale} title={title} description={subtitle} activeSection="comercio">
    <div class="mc-header">
        <AccountPageHeader title={title} description={subtitle || undefined} />
        <a
            class="mc-create-cta"
            href={createUrl}
        >
            {t('commerce.owner.list.createCta', '+ Nuevo comercio')}
        </a>
    </div>

    <AccountSectionCard>
        {
            listings.length === 0 ? (
                <div class="mc-empty">
                    <p class="mc-empty__text">
                        {t(
                            'commerce.owner.list.empty',
                            'Todavía no tenés comercios. Creá tu primera ficha para empezar.'
                        )}
                    </p>
                    <a
                        class="mc-empty__cta"
                        href={createUrl}
                    >
                        {t('commerce.owner.list.emptyCta', 'Crear mi primer comercio')}
                    </a>
                </div>
            ) : (
                <ul class="mc-list">
                    {listings.map((listing) => (
                        <li class="mc-list__item">
                            <div class="mc-list__main">
                                <span class="mc-list__name">{listing.name}</span>
                                <span class="mc-badge">
                                    {t(`commerce.owner.list.badge.${listing.vertical}`, listing.vertical)}
                                </span>
                            </div>

                            <CommerceListingActions
                                client:visible
                                listing={listing}
                                locale={locale}
                            />

                            <a
                                class="mc-list__edit"
                                href={buildUrl({
                                    locale,
                                    path: `mi-cuenta/comercio/${listing.vertical}/${listing.id}/editar`
                                })}
                            >
                                {t('commerce.owner.list.edit', 'Editar')}
                            </a>
                        </li>
                    ))}
                </ul>
            )
        }
    </AccountSectionCard>
</AccountLayout>

<style>
    .mc-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--space-4);
        flex-wrap: wrap;
    }

    .mc-create-cta {
        flex-shrink: 0;
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-button, 0.5rem);
        background: var(--brand-accent);
        color: var(--accent-foreground);
        font-weight: 600;
        font-size: var(--text-body-sm, 0.9375rem);
        text-decoration: none;
        transition: opacity 150ms ease;
    }

    .mc-create-cta:hover {
        opacity: 0.85;
    }

    .mc-empty {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-4);
    }

    .mc-empty__text {
        margin: 0;
        color: var(--core-muted-foreground);
        font-size: var(--text-body-sm, 0.9375rem);
    }

    .mc-empty__cta {
        padding: var(--space-3) var(--space-8);
        border-radius: var(--radius-button, 0.5rem);
        background: var(--brand-accent);
        color: var(--accent-foreground);
        font-weight: 600;
        text-decoration: none;
        transition: opacity 150ms ease;
    }

    .mc-empty__cta:hover {
        opacity: 0.85;
    }

    .mc-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .mc-list__item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        flex-wrap: wrap;
        padding: var(--space-4);
        border: 1px solid var(--border);
        border-radius: var(--radius-md, 0.5rem);
        background: var(--core-card, var(--core-background));
    }

    .mc-list__main {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        flex-wrap: wrap;
        min-width: 0;
    }

    .mc-list__name {
        font-weight: 600;
        color: var(--core-foreground);
    }

    .mc-badge {
        font-size: var(--text-caption, 0.75rem);
        padding: 0.125rem 0.5rem;
        border-radius: var(--radius-pill, 999px);
        background: var(--surface-warm, rgba(0, 0, 0, 0.06));
        color: var(--core-muted-foreground);
    }

    .mc-list__edit {
        flex-shrink: 0;
        font-weight: 600;
        color: var(--brand-primary, var(--core-foreground));
        text-decoration: none;
    }

    .mc-list__edit:hover {
        text-decoration: underline;
    }
</style>
