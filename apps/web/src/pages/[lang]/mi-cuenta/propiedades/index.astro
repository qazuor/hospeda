---
/**
 * @file mi-cuenta/propiedades/index.astro
 * @description Host property listing page — shows all accommodations owned by the
 * authenticated user, with empty state fallback and optional lifecycle filter.
 *
 * Auth protection: both middleware AND this page check for a valid user session.
 * Middleware redirects before the page renders; the in-page guard is a safety net.
 *
 * Data: fetched server-side by forwarding the session cookie to the protected API
 * endpoint `GET /api/v1/protected/accommodations` (owner-scoped, see T-014).
 * On fetch error the page renders the empty state with an error log so the user
 * still has a functional page and can navigate to publish a new property.
 *
 * @route    /[lang]/mi-cuenta/propiedades/
 * @rendering SSR (prerender = false — requires authenticated user)
 */

import { LifecycleStatusEnum } from '@repo/schemas';
import type { Accommodation } from '@repo/schemas';
import { CreditCardIcon } from '@repo/icons';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { buildLoginRedirect } from '@/lib/middleware-helpers';
import { isHostRole } from '@/lib/account-roles';
import { getApiUrl } from '@/lib/env';
import { webLogger as logger } from '@/lib/logger';
import { MAX_ACCOMMODATIONS_LIMIT_KEY, parseUsageResponse } from '@/lib/host/usage-badge';
import AccountLayout from '@/layouts/AccountLayout.astro';
import AccountPageHeader from '@/components/account/AccountPageHeader.astro';
import accountSectionStyles from '@/components/account/AccountSection.module.css';
import PropertyCard from '@/components/host/PropertyCard.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import { BuildingIcon } from '@repo/icons';
import btn from '@/components/account/AccountButton.module.css';

export const prerender = false;

// ---------------------------------------------------------------------------
// Locale — injected by middleware, always a valid SupportedLocale.
// ---------------------------------------------------------------------------

const locale = Astro.locals.locale as SupportedLocale;

// ---------------------------------------------------------------------------
// Auth guard: middleware protects /mi-cuenta/* automatically, but this is the
// safety net for any SSR edge case where middleware did not run.
// ---------------------------------------------------------------------------

const user = Astro.locals.user;
if (!user) {
    return Astro.redirect(buildLoginRedirect({ locale, currentUrl: Astro.url.pathname }));
}

// Role gate: only host-level roles may manage properties. A plain tourist
// reaching this URL directly is redirected back to the account home.
if (!isHostRole(user.role)) {
    return Astro.redirect(buildUrl({ locale, path: 'mi-cuenta' }));
}

// ---------------------------------------------------------------------------
// Server-side fetch: list owner's accommodations.
// The protected endpoint filters by actor.id server-side (T-014 / Option A).
// Session cookie is forwarded to authenticate the request.
// ---------------------------------------------------------------------------

let properties: readonly Accommodation[] = [];
let fetchError = false;

// ── Usage/limit data for plan-awareness badge ──
let usageData: { currentUsage: number; maxAllowed: number; threshold: string } | null = null;

// ── HOS-217: does the owner have a REAL owner/complex plan? ──
// Fail-open (`true`) on any fetch error — this only gates a proactive nag
// banner, never actual publish capability (the `/publish` endpoint is the
// enforcement point via `checkEligibility`), so a transient API failure
// must not falsely nag a paying host.
let hasOwnerPlan = true;

try {
    const apiUrl = getApiUrl();
    const cookieHeader = Astro.request.headers.get('cookie');

    if (cookieHeader) {
        const headers = {
            cookie: cookieHeader,
            Accept: 'application/json'
        };

        // Parallel fetch: accommodations + usage limit + entitlements/plan
        const [accomResponse, usageResponse, entitlementsResponse] = await Promise.all([
            fetch(
                `${apiUrl}/api/v1/protected/accommodations?pageSize=50&sortBy=createdAt&sortOrder=desc`,
                { headers }
            ),
            fetch(
                `${apiUrl}/api/v1/protected/billing/usage/${MAX_ACCOMMODATIONS_LIMIT_KEY}`,
                { headers }
            ),
            fetch(`${apiUrl}/api/v1/protected/users/me/entitlements`, { headers })
        ]);

        if (accomResponse.ok) {
            const body = (await accomResponse.json()) as {
                data?: { items?: readonly Accommodation[] };
            };
            properties = body.data?.items ?? [];
        } else {
            fetchError = true;
            logger.error('[propiedades] API responded with status', accomResponse.status);
        }

        if (usageResponse.ok) {
            usageData = parseUsageResponse({ json: await usageResponse.json() });
        }
        // Usage fetch failure is non-critical — badge simply won't render

        if (entitlementsResponse.ok) {
            // `plan` is null when the owner has no real owner/complex-category
            // subscription — including the HOS-217 bug case (a HOST whose only
            // live subscription is a tourist plan, or a HOST with no
            // subscription at all resolving owner-basico draft defaults).
            const entJson = (await entitlementsResponse.json()) as {
                data?: { plan?: unknown };
            };
            hasOwnerPlan = entJson.data?.plan != null;
        } else {
            logger.warn('[propiedades] entitlements fetch returned non-ok', {
                status: entitlementsResponse.status
            });
        }
        // Entitlements fetch failure is non-fatal — hasOwnerPlan stays true (fail-open)
    }
} catch (err) {
    fetchError = true;
    logger.error('[propiedades] Failed to fetch properties', err instanceof Error ? err.message : String(err));
}

// ---------------------------------------------------------------------------
// i18n
// ---------------------------------------------------------------------------

const { t } = createTranslations(locale);

const title = t('host.properties.list.title', 'Mis propiedades');
const subtitle = t('host.properties.list.subtitle', 'Gestioná tus publicaciones');
const emptyMessage = t('host.properties.empty.title', 'Aún no publicaste ninguna propiedad');
const emptyCta = t('host.properties.empty.cta', 'Publicar ahora');

const publishNewUrl = buildUrl({ locale, path: 'publicar/nueva' });
const subscriptionUrl = buildUrl({ locale, path: 'mi-cuenta/suscripcion' });

const isEmpty = properties.length === 0;

// HOS-217: proactive "pick a host plan" banner — an owner with at least one
// DRAFT property but no real owner/complex subscription would otherwise only
// discover they can't publish by clicking "Publicar" on the card and hitting
// the `subscription_required` error. Surfacing it here (list level) instead
// of only reactively (card level) matches the requested onboarding journey.
const hasDraftProperty = properties.some(
    (property) => property.lifecycleState === LifecycleStatusEnum.DRAFT
);
const showNeedsPlanBanner = !isEmpty && !fetchError && hasDraftProperty && !hasOwnerPlan;

const needsPlanTitle = t('host.properties.list.needsPlanBanner.title', 'Elegí tu plan para publicar');
const needsPlanDescription = t(
    'host.properties.list.needsPlanBanner.description',
    'Tenés propiedades en borrador. Para publicarlas necesitás un plan de anfitrión activo.'
);
const needsPlanCta = t('host.properties.list.needsPlanBanner.cta', 'Ver planes de anfitrión');
---

<AccountLayout locale={locale} title={title} description={subtitle} activeSection="propiedades">
    <!-- Page header. The header CTA is hidden in the empty state to avoid
         showing two stacked "Publicar ahora" buttons — the empty-state
         illustration already owns the primary call to action. -->
    <div class="props-page__header">
        <div class="props-page__heading">
            <AccountPageHeader title={title} description={subtitle} />
        </div>
        {!isEmpty && !fetchError && (
            <a href={publishNewUrl} class:list={['props-page__cta-btn', btn.primary]}>
                {t('host.properties.list.publishAnother', 'Publicar otra')}
            </a>
        )}
    </div>

    {/* ── HOS-217: proactive "pick a host plan" banner ── */}
    {showNeedsPlanBanner && (
        <aside class="props-page__needs-plan" role="note">
            <div class="props-page__needs-plan-icon" aria-hidden="true">
                <CreditCardIcon size={20} weight="fill" />
            </div>
            <div class="props-page__needs-plan-body">
                <p class="props-page__needs-plan-title">{needsPlanTitle}</p>
                <p class="props-page__needs-plan-text">{needsPlanDescription}</p>
            </div>
            <a href={subscriptionUrl} class:list={['props-page__needs-plan-cta', btn.primary]}>
                {needsPlanCta}
            </a>
        </aside>
    )}

    {/* ── Plan/limit awareness badge ── */}
    {usageData && usageData.maxAllowed > 0 && (
        <div class={`props-page__usage props-page__usage--${usageData.threshold}`} role="status">
            <span class="props-page__usage-label">
                {t('host.properties.usage.label', '{{current}} de {{max}} propiedades', {
                    current: String(usageData.currentUsage),
                    max: String(usageData.maxAllowed)
                })}
            </span>
            {usageData.threshold !== 'ok' && (
                <a href={buildUrl({ locale, path: 'suscriptores/planes' })} class="props-page__usage-upgrade">
                    {t('host.properties.usage.upgrade', 'Mejorar plan')}
                </a>
            )}
        </div>
    )}

    {fetchError ? (
        /* Error state (e.g. API down or permission denied). Already a
             standalone full-page card (bg/border/radius below); branded on
             its own since it is no longer nested in AccountSectionCard. */
        <div class:list={['props-page__error', accountSectionStyles.branded]} role="alert">
            <p class="props-page__error-title">
                {t('host.properties.empty.fetchError', 'No se pudo cargar la lista. Intentá recargar la página.')}
            </p>
            <a
                href={Astro.url.pathname}
                class:list={['props-page__cta-btn', 'props-page__cta-btn--centered', btn.primary]}
            >
                {t('host.properties.error.retry', 'Reintentar')}
            </a>
        </div>
    ) : !isEmpty ? (
        /* Properties grid — each PropertyCard carries its own branded accent
             bar (no outer wrapper). */
        <div class="props-page__grid" role="list" aria-label={title}>
            {properties.map((property) => (
                <div class="props-page__item" role="listitem" data-reveal="up">
                    <PropertyCard property={property} locale={locale} />
                </div>
            ))}
        </div>
    ) : (
        /* Empty state: uses the shared EmptyState component with a @repo/icons icon
             for visual consistency with the rest of the web app. */
        <EmptyState
            locale={locale}
            variant="empty"
            message={emptyMessage}
            actionUrl={publishNewUrl}
            actionLabel={emptyCta}
            tone="warm"
        >
            <BuildingIcon size={56} weight="duotone" />
        </EmptyState>
    )}
</AccountLayout>

<style>
    /* ── Usage/limit awareness badge ── */
    .props-page__usage {
        display: inline-flex;
        align-items: center;
        gap: var(--space-3, 0.75rem);
        padding: 0.5rem 1rem;
        margin-bottom: var(--space-6, 1.5rem);
        border-radius: var(--radius-pill, 9999px);
        font-family: var(--font-sans);
        font-size: 0.875rem;
        font-weight: 500;
        background-color: var(--surface-warm, oklch(0.96 0.02 60));
        color: var(--core-foreground);
        border: 1px solid var(--border);
    }

    .props-page__usage--ok {
        background-color: oklch(0.95 0.04 145);
        color: oklch(0.35 0.12 145);
        border-color: oklch(0.85 0.08 145);
    }

    .props-page__usage--warning {
        background-color: oklch(0.95 0.05 65);
        color: oklch(0.40 0.12 65);
        border-color: oklch(0.85 0.10 65);
    }

    .props-page__usage--critical,
    .props-page__usage--exceeded {
        background-color: oklch(0.95 0.04 25);
        color: oklch(0.45 0.15 25);
        border-color: oklch(0.85 0.10 25);
    }

    .props-page__usage-label {
        white-space: nowrap;
    }

    .props-page__usage-upgrade {
        display: inline-flex;
        align-items: center;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-pill, 9999px);
        background-color: var(--brand-primary);
        color: var(--primary-foreground, #ffffff);
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 0.75rem;
        text-decoration: none;
        white-space: nowrap;
        transition: opacity 150ms ease-out;
    }

    .props-page__usage-upgrade:hover {
        opacity: 0.88;
    }

    /* ── HOS-217: proactive "pick a host plan" banner ──
       Layout mirrors SearchContextBanner.astro's info-banner pattern (icon +
       body + accent left-border), plus a CTA button since this one is
       actionable (link to the subscription page), not purely informational. */
    .props-page__needs-plan {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-3, 0.75rem);
        padding: 16px 20px;
        margin-bottom: var(--space-6, 1.5rem);
        background-color: var(--surface-warm);
        border: 1px solid var(--border);
        border-left: 4px solid var(--brand-accent);
        border-radius: var(--radius-md, 12px);
    }

    @media (min-width: 640px) {
        .props-page__needs-plan {
            flex-direction: row;
            align-items: center;
        }
    }

    .props-page__needs-plan-icon {
        color: var(--brand-accent);
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }

    .props-page__needs-plan-body {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
        flex: 1;
    }

    .props-page__needs-plan-title {
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 15px;
        line-height: 1.3;
        color: var(--core-foreground);
        margin: 0;
    }

    .props-page__needs-plan-text {
        font-family: var(--font-sans);
        font-size: 14px;
        line-height: 1.5;
        color: var(--core-foreground);
        margin: 0;
    }

    .props-page__needs-plan-cta {
        flex-shrink: 0;
        text-decoration: none;
        white-space: nowrap;
    }

    /* ── Page header ── */
    .props-page__header {
        display: flex;
        flex-direction: column;
        gap: var(--space-4, 1rem);
        margin-bottom: var(--space-8, 2rem);
    }

    @media (min-width: 640px) {
        .props-page__header {
            flex-direction: row;
            align-items: flex-start;
            justify-content: space-between;
        }
    }

    .props-page__heading {
        display: flex;
        flex-direction: column;
    }

    /* ── CTA button ──
       Colors/radius/padding/font come from the shared AccountButton
       `.primary` variant (BETA-143e, see the `btn` import above). This local
       class only supplies layout (self-alignment) and the anchor-specific
       underline reset. */
    .props-page__cta-btn {
        align-self: flex-start;
        text-decoration: none;
    }

    .props-page__cta-btn--centered {
        margin-top: var(--space-4, 1rem);
    }

    /* ── Properties grid: 1 col → 2 col → 3 col ── */
    .props-page__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-card-gap, 1.875rem);
    }

    @media (min-width: 640px) {
        .props-page__grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .props-page__grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .props-page__item {
        display: contents;
    }

    /* ── Error state (fetch failed) ── */
    .props-page__error {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-4, 1rem);
        padding: var(--space-12, 3rem) var(--space-8, 2rem);
        background-color: var(--core-card);
        border: 1px solid oklch(0.85 0.05 25 / 0.4);
        border-radius: var(--radius-card, 24px);
        text-align: center;
    }

    .props-page__error-title {
        font-family: var(--font-sans);
        font-size: var(--text-body, 1rem);
        color: oklch(0.55 0.22 25);
        margin: 0;
    }
</style>
