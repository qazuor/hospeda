---
/**
 * @file mi-cuenta/propiedades/[id]/editar.astro
 * @description Server-side redirect to the admin panel edit page.
 *
 * The full property editor lives in the admin app (Tailwind, TanStack-based
 * UI). This page exists only to keep the legacy `/mi-cuenta/propiedades/:id/editar`
 * URL alive and bounce the user to `/{ADMIN_URL}/accommodations/:id/edit`.
 *
 * Auth: /mi-cuenta/* is auto-protected by middleware. The redirect below
 * happens after the user is known to be authenticated.
 *
 * @route    /[lang]/mi-cuenta/propiedades/[id]/editar/
 * @rendering SSR (prerender = false — requires authenticated user)
 */

import { getAdminUrlOrThrow } from '@/lib/env';

export const prerender = false;

const { id } = Astro.params;

if (!id) {
    return Astro.redirect('/404');
}

const adminUrl = getAdminUrlOrThrow();
return Astro.redirect(`${adminUrl}/accommodations/${id}/edit`);
---
