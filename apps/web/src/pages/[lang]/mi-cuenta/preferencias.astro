---
/**
 * Preferences page - user settings and preferences configuration.
 * Uses PreferenceToggles React island for interactive notification and language settings.
 * Protected page under /mi-cuenta/ requiring authentication.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import { PreferenceToggles } from '../../../components/account/PreferenceToggles.client';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { t } from '../../../lib/i18n';
import { InfoIcon } from '@repo/icons';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/** Auth guard: redirect unauthenticated users to sign in */
const user = Astro.locals.user;
if (!user) {
	return Astro.redirect(`/${locale}/auth/signin`);
}

const title = t({ locale, namespace: 'account', key: 'pages.preferences.title' });
const description = t({ locale, namespace: 'account', key: 'pages.preferences.description' });
const accountLabel = t({ locale, namespace: 'account', key: 'pages.accountLabel' });
const headingText = t({ locale, namespace: 'account', key: 'pages.preferences.heading' });
const headingDesc = t({ locale, namespace: 'account', key: 'pages.preferences.headingDesc' });
const tzSection = t({ locale, namespace: 'account', key: 'pages.preferences.timezone.section' });
const tzDescription = t({ locale, namespace: 'account', key: 'pages.preferences.timezone.description' });
const tzCurrent = t({ locale, namespace: 'account', key: 'pages.preferences.timezone.current' });
const tzValue = t({ locale, namespace: 'account', key: 'pages.preferences.timezone.value' });
const tzNote = t({ locale, namespace: 'account', key: 'pages.preferences.timezone.note' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: accountLabel, href: `/${locale}/mi-cuenta/` },
	{ label: title, href: `/${locale}/mi-cuenta/preferencias/` },
];

/**
 * Extract user settings from session, with safe defaults
 */
const userRecord = user as Record<string, unknown>;
const rawSettings = userRecord.settings as Record<string, unknown> | undefined;
const rawNotifications = rawSettings?.notifications as Record<string, unknown> | undefined;

const initialSettings = {
	darkMode: (rawSettings?.darkMode as boolean) ?? false,
	language: (rawSettings?.language as string) ?? locale,
	notifications: {
		enabled: (rawNotifications?.enabled as boolean) ?? true,
		allowEmails: (rawNotifications?.allowEmails as boolean) ?? true,
		allowSms: (rawNotifications?.allowSms as boolean) ?? false,
		allowPush: (rawNotifications?.allowPush as boolean) ?? false,
	},
};

---

<BaseLayout title={title} description={description} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<div class="mx-auto max-w-3xl py-8">
			<div class="mb-8">
				<h1 class="mb-2 text-3xl font-bold text-text-primary">
					{headingText}
				</h1>
				<p class="text-text-secondary">
					{headingDesc}
				</p>
			</div>

			<div class="space-y-8">
				<!-- PreferenceToggles React Island handles notifications and language -->
				<PreferenceToggles
					client:visible
					userId={user.id}
					initialSettings={initialSettings}
					locale={locale}
				/>

				<!-- Timezone section (read-only, no React needed) -->
				<section
					class="rounded-lg border border-border bg-bg p-6"
					aria-labelledby="timezone-heading"
				>
					<h2 id="timezone-heading" class="mb-2 text-lg font-semibold text-text-primary">
						{tzSection}
					</h2>
					<p class="mb-6 text-sm text-text-secondary">
						{tzDescription}
					</p>

					<div class="rounded-lg bg-bg-secondary p-4">
						<div class="mb-3 flex items-center justify-between">
							<span class="text-sm font-medium text-text-primary">
								{tzCurrent}
							</span>
							<span
								class="inline-flex items-center rounded-full bg-secondary/10 px-3 py-1 text-sm font-semibold text-secondary"
								role="status"
								aria-label={`${tzCurrent}: ${tzValue}`}
							>
								{tzValue}
							</span>
						</div>
						<p class="text-sm text-text-tertiary">
							{tzNote}
						</p>
					</div>
				</section>
			</div>
		</div>
	</Container>
</BaseLayout>
