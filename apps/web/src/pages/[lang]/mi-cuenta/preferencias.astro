---
/**
 * Preferences page.
 * Wraps PreferenceToggles React island for notification and language settings.
 *
 * Rendering: SSR (on-demand). Auth-protected via middleware; also guards
 * directly in frontmatter and redirects to signin if user is absent.
 *
 * Route: /[lang]/mi-cuenta/preferencias
 */

import type { SupportedLocale } from '../../../lib/i18n';
import { createT } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import { PreferenceToggles } from '../../../components/account/PreferenceToggles.client';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Auth guard: middleware protects /mi-cuenta/* but we also check here
 * to ensure a clean redirect with the correct locale.
 */
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const t = createT(locale as SupportedLocale);

const title = t('account.pages.preferences.title', 'Preferencias');
const description = t(
  'account.pages.preferences.description',
  'Configurá notificaciones, idioma y privacidad'
);
const accountLabel = t('account.pages.accountLabel', 'Mi Cuenta');

/**
 * Extract user settings from session with safe defaults.
 */
const userRecord = user as Record<string, unknown>;
const rawSettings = userRecord.settings as Record<string, unknown> | undefined;
const rawNotifications = rawSettings?.notifications as Record<string, unknown> | undefined;

const initialSettings = {
  darkMode: (rawSettings?.darkMode as boolean) ?? false,
  language: (rawSettings?.language as string) ?? locale,
  notifications: {
    enabled: (rawNotifications?.enabled as boolean) ?? true,
    allowEmails: (rawNotifications?.allowEmails as boolean) ?? true,
    allowSms: (rawNotifications?.allowSms as boolean) ?? false,
    allowPush: (rawNotifications?.allowPush as boolean) ?? false,
  },
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const breadcrumbItems = [
  { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
  { label: accountLabel, href: buildUrl({ locale, path: 'mi-cuenta' }) },
  { label: title, href: buildUrl({ locale, path: 'mi-cuenta/preferencias' }) },
];
---

<BaseLayout title={title} description={description} locale={locale}>
  <SEOHead
    slot="head"
    title={title}
    description={description}
    canonical={canonicalUrl}
    locale={locale}
    type="website"
    noindex={true}
  />

  <div class="container mx-auto max-w-3xl px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <header class="mb-8">
      <h1 class="mb-2 text-3xl font-bold text-foreground">{title}</h1>
      <p class="text-muted-foreground">{description}</p>
    </header>

    <!-- PreferenceToggles handles notification and language settings -->
    <PreferenceToggles
      client:load
      userId={user.id}
      initialSettings={initialSettings}
      locale={locale}
    />
  </div>
</BaseLayout>
