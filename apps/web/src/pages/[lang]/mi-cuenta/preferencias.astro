---
/**
 * Preferences page - user settings and preferences configuration.
 * Uses PreferenceToggles React island for interactive notification and language settings.
 * Protected page under /mi-cuenta/ requiring authentication.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import { PreferenceToggles } from '../../../components/account/PreferenceToggles.client';
import { isValidLocale, type SupportedLocale } from '../../../lib/i18n';
import { InfoIcon } from '@repo/icons';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/** Auth guard: redirect unauthenticated users to sign in */
const user = Astro.locals.user;
if (!user) {
	return Astro.redirect(`/${locale}/auth/signin`);
}

/**
 * Localized page titles
 */
const titles: Record<SupportedLocale, string> = {
	es: 'Preferencias',
	en: 'Preferences',
	pt: 'Preferencias',
};

/**
 * Localized meta descriptions
 */
const descriptions: Record<SupportedLocale, string> = {
	es: 'Configura tus preferencias de cuenta en Hospeda',
	en: 'Configure your account preferences on Hospeda',
	pt: 'Configure suas preferencias de conta no Hospeda',
};

/**
 * Localized home breadcrumb labels
 */
const homeLabels: Record<SupportedLocale, string> = {
	es: 'Inicio',
	en: 'Home',
	pt: 'Inicio',
};

/**
 * Localized account breadcrumb labels
 */
const accountLabels: Record<SupportedLocale, string> = {
	es: 'Mi Cuenta',
	en: 'My Account',
	pt: 'Minha Conta',
};

/**
 * Localized heading and description
 */
const headings: Record<SupportedLocale, { heading: string; description: string }> = {
	es: {
		heading: 'Preferencias',
		description: 'Personaliza tu experiencia en Hospeda',
	},
	en: {
		heading: 'Preferences',
		description: 'Customize your Hospeda experience',
	},
	pt: {
		heading: 'Preferencias',
		description: 'Personalize sua experiencia no Hospeda',
	},
};

/**
 * Localized timezone labels
 */
const timezoneLabels: Record<SupportedLocale, {
	section: string;
	description: string;
	current: string;
	value: string;
	note: string;
}> = {
	es: {
		section: 'Zona horaria',
		description: 'Zona horaria utilizada para mostrar fechas y horarios',
		current: 'Zona horaria actual',
		value: 'America/Argentina/Buenos_Aires',
		note: 'La zona horaria se ajusta automaticamente segun tu ubicacion',
	},
	en: {
		section: 'Timezone',
		description: 'Timezone used to display dates and times',
		current: 'Current timezone',
		value: 'America/Argentina/Buenos_Aires',
		note: 'The timezone is automatically adjusted based on your location',
	},
	pt: {
		section: 'Fuso horario',
		description: 'Fuso horario usado para exibir datas e horarios',
		current: 'Fuso horario atual',
		value: 'America/Argentina/Buenos_Aires',
		note: 'O fuso horario e ajustado automaticamente com base em sua localizacao',
	},
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: homeLabels[locale], href: `/${locale}/` },
	{ label: accountLabels[locale], href: `/${locale}/mi-cuenta/` },
	{ label: titles[locale], href: `/${locale}/mi-cuenta/preferencias/` },
];

/**
 * Extract user settings from session, with safe defaults
 */
const userRecord = user as Record<string, unknown>;
const rawSettings = userRecord.settings as Record<string, unknown> | undefined;
const rawNotifications = rawSettings?.notifications as Record<string, unknown> | undefined;

const initialSettings = {
	darkMode: (rawSettings?.darkMode as boolean) ?? false,
	language: (rawSettings?.language as string) ?? locale,
	notifications: {
		enabled: (rawNotifications?.enabled as boolean) ?? true,
		allowEmails: (rawNotifications?.allowEmails as boolean) ?? true,
		allowSms: (rawNotifications?.allowSms as boolean) ?? false,
		allowPush: (rawNotifications?.allowPush as boolean) ?? false,
	},
};

const tz = timezoneLabels[locale];
---

<BaseLayout title={titles[locale]} description={descriptions[locale]} locale={locale}>
	<SEOHead
		slot="head"
		title={titles[locale]}
		description={descriptions[locale]}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<div class="mx-auto max-w-3xl py-8">
			<div class="mb-8">
				<h1 class="mb-2 text-3xl font-bold text-text-primary">
					{headings[locale].heading}
				</h1>
				<p class="text-text-secondary">
					{headings[locale].description}
				</p>
			</div>

			<div class="space-y-8">
				<!-- PreferenceToggles React Island handles notifications and language -->
				<PreferenceToggles
					client:visible
					userId={user.id}
					initialSettings={initialSettings}
					locale={locale}
				/>

				<!-- Timezone section (read-only, no React needed) -->
				<section
					class="rounded-lg border border-border bg-bg p-6"
					aria-labelledby="timezone-heading"
				>
					<h2 id="timezone-heading" class="mb-2 text-lg font-semibold text-text-primary">
						{tz.section}
					</h2>
					<p class="mb-6 text-sm text-text-secondary">
						{tz.description}
					</p>

					<div class="rounded-lg bg-bg-secondary p-4">
						<div class="mb-3 flex items-center justify-between">
							<span class="text-sm font-medium text-text-primary">
								{tz.current}
							</span>
							<span
								class="inline-flex items-center rounded-full bg-secondary/10 px-3 py-1 text-sm font-semibold text-secondary"
								role="status"
								aria-label={`${tz.current}: ${tz.value}`}
							>
								{tz.value}
							</span>
						</div>
						<p class="text-sm text-text-tertiary">
							{tz.note}
						</p>
					</div>
				</section>
			</div>
		</div>
	</Container>
</BaseLayout>
