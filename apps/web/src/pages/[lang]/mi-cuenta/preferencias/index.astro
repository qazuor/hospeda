---
/**
 * @file mi-cuenta/preferencias/index.astro
 * @description Account preferences page.
 * @route /{lang}/mi-cuenta/preferencias/
 * @rendering SSR
 */

import { getApiUrl } from '@/lib/env';
import AccountLayout from '@/layouts/AccountLayout.astro';
import AccountPageHeader from '@/components/account/AccountPageHeader.astro';
import AccountSectionCard from '@/components/account/AccountSectionCard.astro';
import { PreferenceToggles } from '@/components/account/PreferenceToggles.client';
import { RestartTour } from '@/components/account/RestartTour.client';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const user = Astro.locals.user;

if (!user) {
	return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const { t } = createTranslations(locale);
const title = t('account.pages.preferences.title', 'Preferencias');
const apiUrl = getApiUrl();
---

<AccountLayout locale={locale} title={title} activeSection="preferencias">
	<AccountPageHeader title={title} />

	<PreferenceToggles
		client:load
		userId={user.id}
		locale={locale}
		apiUrl={apiUrl}
	/>

	<div class="preferencias-tour-gap">
		<AccountSectionCard>
			<RestartTour client:idle locale={locale} userRole={user.role} />
		</AccountSectionCard>
	</div>
</AccountLayout>

<style>
	/* Stacked-card spacing: PreferenceToggles renders its own card (no outer
	   margin, same as every other AccountSection.module.css consumer), so this
	   page needs an explicit gap before the RestartTour card below it. */
	.preferencias-tour-gap {
		margin-top: var(--space-6);
	}

	:global(.restart-tour) {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	/*
	 * Same dot-bullet + divider treatment as AccountSection.module.css's
	 * `.cardTitle` (BETA-143c nitpick), so this heading matches every other
	 * section card title. `margin` stays 0 (unlike `.cardTitle`'s
	 * `margin: 0 0 var(--space-5)`) because `.restart-tour` already provides
	 * vertical rhythm via its own flex `gap`.
	 */
	:global(.restart-tour__title) {
		position: relative;
		margin: 0;
		padding-bottom: var(--space-3);
		border-bottom: 1px solid var(--core-foreground-a05);
		font-family: var(--font-heading);
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--core-foreground);
		display: flex;
		align-items: center;
		gap: var(--space-2);
	}

	:global(.restart-tour__title)::before {
		content: "";
		display: inline-block;
		width: 8px;
		height: 8px;
		border-radius: var(--radius-pill);
		background: linear-gradient(135deg, var(--brand-primary), var(--brand-accent));
		flex-shrink: 0;
		box-shadow: 0 0 0 3px var(--brand-primary-a12);
	}

	:global(.restart-tour__desc) {
		margin: 0;
		font-size: 0.9375rem;
		color: var(--core-muted-foreground);
	}

	:global(.restart-tour__button) {
		align-self: flex-start;
		padding: var(--space-3) var(--space-4);
		border: 1px solid var(--brand-primary-a30);
		border-radius: var(--radius-button);
		background-color: var(--core-card);
		color: var(--brand-primary);
		font-weight: 600;
		cursor: pointer;
		transition: background-color var(--duration-fast) ease, color var(--duration-fast) ease;
	}

	:global(.restart-tour__button:hover:enabled) {
		background-color: var(--brand-primary);
		color: var(--primary-foreground);
	}

	:global(.restart-tour__button:disabled) {
		opacity: 0.6;
		cursor: default;
	}
</style>
