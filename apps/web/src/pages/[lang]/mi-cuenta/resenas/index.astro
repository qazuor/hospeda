---
/**
 * @file mi-cuenta/resenas/index.astro
 * @description Account reviews page.
 * @route /{lang}/mi-cuenta/resenas/
 * @rendering SSR
 */

import { getApiUrl } from '@/lib/env';
import AccountLayout from '@/layouts/AccountLayout.astro';
import { UserReviewsList } from '@/components/account/UserReviewsList.client';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const user = Astro.locals.user;

if (!user) {
	return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const { t } = createTranslations(locale);
const title = t('account.pages.reviews.title', 'Mis reseñas');
const apiUrl = getApiUrl();
---

<AccountLayout locale={locale} title={title} activeSection="resenas">
	<h2 class="account-section__title">{title}</h2>

	<UserReviewsList client:load locale={locale} apiUrl={apiUrl} />
</AccountLayout>

<style>
	.account-section__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.5rem, 3vw, 2rem);
		color: var(--core-foreground);
		margin: 0 0 var(--space-6);
	}
</style>
