---
/**
 * My Reviews page - user written reviews for accommodations and destinations.
 * Uses UserReviewsList React island for interactive data fetching and pagination.
 * Auth-protected (middleware handles authentication check).
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import { UserReviewsList } from '../../../components/account/UserReviewsList.client';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { t } from '../../../lib/i18n';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/** Auth guard: redirect unauthenticated users to sign in */
const user = Astro.locals.user;
if (!user) {
	return Astro.redirect(`/${locale}/auth/signin`);
}

const title = t({ locale, namespace: 'account', key: 'pages.reviews.title' });
const description = t({ locale, namespace: 'account', key: 'pages.reviews.description' });
const accountLabel = t({ locale, namespace: 'account', key: 'pages.accountLabel' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: accountLabel, href: `/${locale}/mi-cuenta/` },
	{ label: title, href: `/${locale}/mi-cuenta/resenas/` },
];
---

<BaseLayout title={title} description={description} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-7xl">
				<h1 class="mb-8 text-4xl font-bold text-text-primary">
					{title}
				</h1>

				<!-- UserReviewsList React Island handles tabs, data fetching, and pagination -->
				<UserReviewsList client:visible locale={locale} />
			</div>
		</Section>
	</Container>
</BaseLayout>
