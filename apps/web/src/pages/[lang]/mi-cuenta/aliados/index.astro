---
/**
 * @file mi-cuenta/aliados/index.astro
 * @description "Sumate como aliado" discovery-door hub page (HOS-131 §6.2,
 * expanded HOS-134 §5.3). Lists the four B2B alliance roles: sponsor, partner
 * (home-ad), and service provider are not-yet-implemented verticals (NG-2)
 * that render "Próximamente" + a "Contactanos" CTA; `editor` has a real entry
 * form (`/colaborar/editores`) and resolves `acquired` once the user holds
 * `POST_CREATE`, linking the admin panel to manage it.
 *
 * @route     /[lang]/mi-cuenta/aliados/
 * @rendering SSR (prerender = false — requires authenticated user)
 */

import { ACCOUNT_DISCOVERY_DOORS } from '@/config/discovery-doors';
import DiscoveryDoorHub from '@/components/account/DiscoveryDoorHub.astro';
import AccountLayout from '@/layouts/AccountLayout.astro';
import AccountPageHeader from '@/components/account/AccountPageHeader.astro';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { getAdminUrl } from '@/lib/env';
import { isVisibleByRole, resolveDoorLabelKey } from '@/lib/nav-gating';

export const prerender = false;

const locale = Astro.locals.locale as SupportedLocale;

// Auth guard: middleware protects /mi-cuenta/* automatically, safety net.
const user = Astro.locals.user;
if (!user) {
    return Astro.redirect(buildUrl({ locale, path: 'auth/signin' }));
}

const door = ACCOUNT_DISCOVERY_DOORS.find((candidate) => candidate.id === 'partner');
if (!door) {
    return Astro.redirect(buildUrl({ locale, path: 'mi-cuenta' }));
}

const { t } = createTranslations(locale);
const labelKey = resolveDoorLabelKey({
    door,
    visibility: (node) => isVisibleByRole(node, user.role)
});
const title = t(labelKey);
const description = t(door.subtitleI18nKey);
---

<AccountLayout locale={locale} title={title} description={description} activeSection="aliados">
    <AccountPageHeader title={title} />
    <DiscoveryDoorHub locale={locale} door={door} role={user.role} adminUrl={getAdminUrl()} />
</AccountLayout>
