---
export const prerender = true;

export function getStaticPaths() {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

/**
 * Contact page - form and contact information.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import { ContactForm } from '../../components/forms/ContactForm.client';
import { isValidLocale, type SupportedLocale } from '../../lib/i18n';
import { EmailIcon, LocationIcon, ClockIcon, InstagramIcon, FacebookIcon, TwitterIcon } from '@repo/icons';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * Localized page titles
 */
const titles: Record<SupportedLocale, string> = {
	es: 'Contacto',
	en: 'Contact',
	pt: 'Contato',
};

/**
 * Localized meta descriptions
 */
const descriptions: Record<SupportedLocale, string> = {
	es: 'Contacta con Hospeda. Estamos aquí para ayudarte con tus consultas sobre alojamiento en Concepción del Uruguay',
	en: 'Contact Hospeda. We are here to help you with your accommodation inquiries in Concepción del Uruguay',
	pt: 'Entre em contato com Hospeda. Estamos aqui para ajudá-lo com suas dúvidas sobre acomodação em Concepción del Uruguay',
};

/**
 * Localized home breadcrumb labels
 */
const homeLabels: Record<SupportedLocale, string> = {
	es: 'Inicio',
	en: 'Home',
	pt: 'Início',
};

/**
 * Localized contact info labels (form handling moved to ContactForm.client.tsx)
 */
const formLabels = {
	es: {
		contactInfo: 'Información de contacto',
		officeHours: 'Horario de atención',
		officeHoursValue: 'Lunes a Viernes, 9:00 - 18:00',
	},
	en: {
		contactInfo: 'Contact information',
		officeHours: 'Office hours',
		officeHoursValue: 'Monday to Friday, 9:00 AM - 6:00 PM',
	},
	pt: {
		contactInfo: 'Informações de contato',
		officeHours: 'Horário de atendimento',
		officeHoursValue: 'Segunda a Sexta, 9:00 - 18:00',
	},
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: homeLabels[locale], href: `/${locale}/` },
	{ label: titles[locale], href: `/${locale}/contacto/` },
];

const labels = formLabels[locale];
---

<BaseLayout title={titles[locale]} description={descriptions[locale]} locale={locale}>
	<SEOHead
		slot="head"
		title={titles[locale]}
		description={descriptions[locale]}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-7xl">
				<h1 class="mb-8 text-4xl font-bold text-text-primary">
					{titles[locale]}
				</h1>

				<div class="grid gap-12 lg:grid-cols-2">
					<!-- Left column: Contact form (React island) -->
					<div class="order-2 lg:order-1">
						<ContactForm client:visible locale={locale === 'pt' ? 'es' : locale} />
					</div>

					<!-- Right column: Contact information -->
					<div class="order-1 lg:order-2">
						<div class="rounded-lg border border-border bg-bg-secondary p-8">
							<h2 class="mb-6 text-2xl font-semibold text-text-primary">
								{labels.contactInfo}
							</h2>

							<div class="space-y-6">
								<!-- Email -->
								<div class="flex items-start gap-4">
									<div
										class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary bg-opacity-10"
									>
										<EmailIcon size={20} className="text-primary" aria-hidden="true" />
									</div>
									<div>
										<p class="font-medium text-text-primary">Email</p>
										<a
											href="mailto:info@hospeda.com.ar"
											class="text-text-secondary transition-colors hover:text-primary"
										>
											info@hospeda.com.ar
										</a>
									</div>
								</div>

								<!-- Location -->
								<div class="flex items-start gap-4">
									<div
										class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary bg-opacity-10"
									>
										<LocationIcon size={20} className="text-primary" aria-hidden="true" />
									</div>
									<div>
										<p class="font-medium text-text-primary">Location</p>
										<p class="text-text-secondary">
											Concepción del Uruguay, Entre Ríos, Argentina
										</p>
									</div>
								</div>

								<!-- Office hours -->
								<div class="flex items-start gap-4">
									<div
										class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary bg-opacity-10"
									>
										<ClockIcon size={20} className="text-primary" aria-hidden="true" />
									</div>
									<div>
										<p class="font-medium text-text-primary">{labels.officeHours}</p>
										<p class="text-text-secondary">
											{labels.officeHoursValue}
										</p>
									</div>
								</div>

								<!-- Social media -->
								<div class="border-t border-border pt-6">
									<p class="mb-4 font-medium text-text-primary">
										{locale === 'es' ? 'Síguenos' : locale === 'en' ? 'Follow us' : 'Siga-nos'}
									</p>
									<div class="flex gap-4">
										<a
											href="https://instagram.com/hospeda"
											target="_blank"
											rel="noopener noreferrer"
											class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary bg-opacity-10 text-primary transition-colors hover:bg-primary hover:text-white"
											aria-label="Instagram"
										>
											<InstagramIcon size={20} weight="fill" aria-hidden="true" />
										</a>

										<a
											href="https://facebook.com/hospeda"
											target="_blank"
											rel="noopener noreferrer"
											class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary bg-opacity-10 text-primary transition-colors hover:bg-primary hover:text-white"
											aria-label="Facebook"
										>
											<FacebookIcon size={20} weight="fill" aria-hidden="true" />
										</a>

										<a
											href="https://twitter.com/hospeda"
											target="_blank"
											rel="noopener noreferrer"
											class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary bg-opacity-10 text-primary transition-colors hover:bg-primary hover:text-white"
											aria-label="Twitter"
										>
											<TwitterIcon size={20} weight="fill" aria-hidden="true" />
										</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</Section>
	</Container>
</BaseLayout>
