---
export const prerender = true;

export function getStaticPaths() {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

/**
 * Contact page - form and contact information.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import { isValidLocale, type SupportedLocale } from '../../lib/i18n';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * Localized page titles
 */
const titles: Record<SupportedLocale, string> = {
	es: 'Contacto',
	en: 'Contact',
	pt: 'Contato',
};

/**
 * Localized meta descriptions
 */
const descriptions: Record<SupportedLocale, string> = {
	es: 'Contacta con Hospeda. Estamos aquí para ayudarte con tus consultas sobre alojamiento en Concepción del Uruguay',
	en: 'Contact Hospeda. We are here to help you with your accommodation inquiries in Concepción del Uruguay',
	pt: 'Entre em contato com Hospeda. Estamos aqui para ajudá-lo com suas dúvidas sobre acomodação em Concepción del Uruguay',
};

/**
 * Localized home breadcrumb labels
 */
const homeLabels: Record<SupportedLocale, string> = {
	es: 'Inicio',
	en: 'Home',
	pt: 'Início',
};

/**
 * Localized form labels
 */
const formLabels = {
	es: {
		name: 'Nombre',
		namePlaceholder: 'Tu nombre completo',
		email: 'Correo electrónico',
		emailPlaceholder: 'tu@email.com',
		subject: 'Asunto',
		subjectPlaceholder: 'Motivo de tu consulta',
		message: 'Mensaje',
		messagePlaceholder: 'Escribe tu mensaje aquí...',
		submit: 'Enviar mensaje',
		contactInfo: 'Información de contacto',
		officeHours: 'Horario de atención',
		officeHoursValue: 'Lunes a Viernes, 9:00 - 18:00',
	},
	en: {
		name: 'Name',
		namePlaceholder: 'Your full name',
		email: 'Email',
		emailPlaceholder: 'your@email.com',
		subject: 'Subject',
		subjectPlaceholder: 'Reason for your inquiry',
		message: 'Message',
		messagePlaceholder: 'Write your message here...',
		submit: 'Send message',
		contactInfo: 'Contact information',
		officeHours: 'Office hours',
		officeHoursValue: 'Monday to Friday, 9:00 AM - 6:00 PM',
	},
	pt: {
		name: 'Nome',
		namePlaceholder: 'Seu nome completo',
		email: 'E-mail',
		emailPlaceholder: 'seu@email.com',
		subject: 'Assunto',
		subjectPlaceholder: 'Motivo de sua consulta',
		message: 'Mensagem',
		messagePlaceholder: 'Escreva sua mensagem aqui...',
		submit: 'Enviar mensagem',
		contactInfo: 'Informações de contato',
		officeHours: 'Horário de atendimento',
		officeHoursValue: 'Segunda a Sexta, 9:00 - 18:00',
	},
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: homeLabels[locale], href: `/${locale}/` },
	{ label: titles[locale], href: `/${locale}/contacto/` },
];

const labels = formLabels[locale];
---

<BaseLayout title={titles[locale]} description={descriptions[locale]} locale={locale}>
	<SEOHead
		slot="head"
		title={titles[locale]}
		description={descriptions[locale]}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-7xl">
				<h1 class="mb-8 text-4xl font-bold text-text-primary">
					{titles[locale]}
				</h1>

				<div class="grid gap-12 lg:grid-cols-2">
					<!-- Left column: Contact form -->
					<div class="order-2 lg:order-1">
						<form class="space-y-6" id="contact-form">
							<!-- Name field -->
							<div>
								<label
									for="name"
									class="mb-2 block text-sm font-medium text-text-primary"
								>
									{labels.name}
								</label>
								<input
									type="text"
									id="name"
									name="name"
									required
									placeholder={labels.namePlaceholder}
									class="w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text-primary placeholder-text-tertiary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-opacity-20"
								/>
							</div>

							<!-- Email field -->
							<div>
								<label
									for="email"
									class="mb-2 block text-sm font-medium text-text-primary"
								>
									{labels.email}
								</label>
								<input
									type="email"
									id="email"
									name="email"
									required
									placeholder={labels.emailPlaceholder}
									class="w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text-primary placeholder-text-tertiary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-opacity-20"
								/>
							</div>

							<!-- Subject field -->
							<div>
								<label
									for="subject"
									class="mb-2 block text-sm font-medium text-text-primary"
								>
									{labels.subject}
								</label>
								<input
									type="text"
									id="subject"
									name="subject"
									required
									placeholder={labels.subjectPlaceholder}
									class="w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text-primary placeholder-text-tertiary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-opacity-20"
								/>
							</div>

							<!-- Message field -->
							<div>
								<label
									for="message"
									class="mb-2 block text-sm font-medium text-text-primary"
								>
									{labels.message}
								</label>
								<textarea
									id="message"
									name="message"
									required
									rows={6}
									placeholder={labels.messagePlaceholder}
									class="w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text-primary placeholder-text-tertiary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-opacity-20"
								></textarea>
							</div>

							<!-- Submit button -->
							<button
								type="submit"
								class="w-full rounded-lg bg-primary px-6 py-3 font-semibold text-white transition-colors hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:cursor-not-allowed disabled:bg-gray-300"
							>
								{labels.submit}
							</button>
						</form>
					</div>

					<!-- Right column: Contact information -->
					<div class="order-1 lg:order-2">
						<div class="rounded-lg border border-border bg-bg-secondary p-8">
							<h2 class="mb-6 text-2xl font-semibold text-text-primary">
								{labels.contactInfo}
							</h2>

							<div class="space-y-6">
								<!-- Email -->
								<div class="flex items-start gap-4">
									<div
										class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary bg-opacity-10"
									>
										<svg
											class="h-5 w-5 text-primary"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
											aria-hidden="true"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
											></path>
										</svg>
									</div>
									<div>
										<p class="font-medium text-text-primary">Email</p>
										<a
											href="mailto:info@hospeda.com.ar"
											class="text-text-secondary transition-colors hover:text-primary"
										>
											info@hospeda.com.ar
										</a>
									</div>
								</div>

								<!-- Location -->
								<div class="flex items-start gap-4">
									<div
										class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary bg-opacity-10"
									>
										<svg
											class="h-5 w-5 text-primary"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
											aria-hidden="true"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
											></path>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
										</svg>
									</div>
									<div>
										<p class="font-medium text-text-primary">Location</p>
										<p class="text-text-secondary">
											Concepción del Uruguay, Entre Ríos, Argentina
										</p>
									</div>
								</div>

								<!-- Office hours -->
								<div class="flex items-start gap-4">
									<div
										class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary bg-opacity-10"
									>
										<svg
											class="h-5 w-5 text-primary"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
											aria-hidden="true"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
										</svg>
									</div>
									<div>
										<p class="font-medium text-text-primary">{labels.officeHours}</p>
										<p class="text-text-secondary">
											{labels.officeHoursValue}
										</p>
									</div>
								</div>

								<!-- Social media -->
								<div class="border-t border-border pt-6">
									<p class="mb-4 font-medium text-text-primary">
										{locale === 'es' ? 'Síguenos' : locale === 'en' ? 'Follow us' : 'Siga-nos'}
									</p>
									<div class="flex gap-4">
										<a
											href="https://instagram.com/hospeda"
											target="_blank"
											rel="noopener noreferrer"
											class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary bg-opacity-10 text-primary transition-colors hover:bg-primary hover:text-white"
											aria-label="Instagram"
										>
											<svg
												class="h-5 w-5"
												fill="currentColor"
												viewBox="0 0 24 24"
												aria-hidden="true"
											>
												<path
													d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
												></path>
											</svg>
										</a>

										<a
											href="https://facebook.com/hospeda"
											target="_blank"
											rel="noopener noreferrer"
											class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary bg-opacity-10 text-primary transition-colors hover:bg-primary hover:text-white"
											aria-label="Facebook"
										>
											<svg
												class="h-5 w-5"
												fill="currentColor"
												viewBox="0 0 24 24"
												aria-hidden="true"
											>
												<path
													d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
												></path>
											</svg>
										</a>

										<a
											href="https://twitter.com/hospeda"
											target="_blank"
											rel="noopener noreferrer"
											class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary bg-opacity-10 text-primary transition-colors hover:bg-primary hover:text-white"
											aria-label="Twitter"
										>
											<svg
												class="h-5 w-5"
												fill="currentColor"
												viewBox="0 0 24 24"
												aria-hidden="true"
											>
												<path
													d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"
												></path>
											</svg>
										</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</Section>
	</Container>
</BaseLayout>
