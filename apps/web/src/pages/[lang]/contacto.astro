---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../lib/page-helpers';

/**
 * Contact page - form and contact information.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import { ContactForm } from '../../components/content/ContactForm.client';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../lib/page-helpers';
import { t } from '../../lib/i18n';
import { EmailIcon, LocationIcon, ClockIcon, InstagramIcon, FacebookIcon, TwitterIcon } from '@repo/icons';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const title = t({ locale, namespace: 'contact', key: 'page.title' });
const description = t({ locale, namespace: 'contact', key: 'page.description' });
const contactInfo = t({ locale, namespace: 'contact', key: 'page.contactInfo' });
const officeHours = t({ locale, namespace: 'contact', key: 'page.officeHours' });
const officeHoursValue = t({ locale, namespace: 'contact', key: 'page.officeHoursValue' });
const followUs = t({ locale, namespace: 'contact', key: 'page.followUs' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: title, href: `/${locale}/contacto/` },
];
---

<BaseLayout title={title} description={description} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-7xl">
				<h1 class="mb-8 text-4xl font-bold text-text-primary">
					{title}
				</h1>

				<div class="grid gap-12 lg:grid-cols-2">
					<!-- Left column: Contact form (React island) -->
					<div class="order-2 lg:order-1">
						<ContactForm client:visible locale={locale} />
					</div>

					<!-- Right column: Contact information -->
					<div class="order-1 lg:order-2">
						<div class="rounded-lg border border-border bg-bg-secondary p-8">
							<h2 class="mb-6 text-2xl font-semibold text-text-primary">
								{contactInfo}
							</h2>

							<div class="space-y-6">
								<!-- Email -->
								<div class="flex items-start gap-4">
									<div
										class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary bg-opacity-10"
									>
										<EmailIcon size={20} className="text-primary" aria-hidden="true" />
									</div>
									<div>
										<p class="font-medium text-text-primary">Email</p>
										<a
											href="mailto:info@hospeda.com.ar"
											class="text-text-secondary transition-colors hover:text-primary"
										>
											info@hospeda.com.ar
										</a>
									</div>
								</div>

								<!-- Location -->
								<div class="flex items-start gap-4">
									<div
										class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary bg-opacity-10"
									>
										<LocationIcon size={20} className="text-primary" aria-hidden="true" />
									</div>
									<div>
										<p class="font-medium text-text-primary">Location</p>
										<p class="text-text-secondary">
											Concepción del Uruguay, Entre Ríos, Argentina
										</p>
									</div>
								</div>

								<!-- Office hours -->
								<div class="flex items-start gap-4">
									<div
										class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary bg-opacity-10"
									>
										<ClockIcon size={20} className="text-primary" aria-hidden="true" />
									</div>
									<div>
										<p class="font-medium text-text-primary">{officeHours}</p>
										<p class="text-text-secondary">
											{officeHoursValue}
										</p>
									</div>
								</div>

								<!-- Social media -->
								<div class="border-t border-border pt-6">
									<p class="mb-4 font-medium text-text-primary">
										{followUs}
									</p>
									<div class="flex gap-4">
										<a
											href="https://instagram.com/hospeda"
											target="_blank"
											rel="noopener noreferrer"
											class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary bg-opacity-10 text-primary transition-colors hover:bg-primary hover:text-white"
											aria-label="Instagram"
										>
											<InstagramIcon size={20} weight="fill" aria-hidden="true" />
										</a>

										<a
											href="https://facebook.com/hospeda"
											target="_blank"
											rel="noopener noreferrer"
											class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary bg-opacity-10 text-primary transition-colors hover:bg-primary hover:text-white"
											aria-label="Facebook"
										>
											<FacebookIcon size={20} weight="fill" aria-hidden="true" />
										</a>

										<a
											href="https://twitter.com/hospeda"
											target="_blank"
											rel="noopener noreferrer"
											class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary bg-opacity-10 text-primary transition-colors hover:bg-primary hover:text-white"
											aria-label="Twitter"
										>
											<TwitterIcon size={20} weight="fill" aria-hidden="true" />
										</a>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</Section>
	</Container>
</BaseLayout>
