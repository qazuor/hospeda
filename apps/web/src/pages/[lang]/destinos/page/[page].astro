---
/**
 * @file [page].astro
 * @description Legacy pagination route. The destinations listing no longer
 * paginates (the catalog is small enough to render in a single grid), so any
 * `/destinos/page/N/` URL — page 1 or otherwise — is permanently redirected
 * to the canonical listing. Kept around to preserve link equity from
 * previously indexed paginated URLs.
 */

const { page: pageParam, lang } = Astro.params;
const page = Number(pageParam);

// Reject obviously malformed values with a 404 instead of redirecting,
// so we don't trade a broken URL for a slightly less broken one.
if (!Number.isInteger(page) || page < 1) {
	return new Response(null, { status: 404 });
}

return Astro.redirect(`/${lang}/destinos/`, 301);
---
