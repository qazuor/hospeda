---
/**
 * @file destinos/index.astro
 * @description Destinations listing page with card grid (no pagination).
 * Uses DefaultLayout (no filter sidebar - hierarchy serves as filter).
 *
 * Renders all destinations in a single grid: the catalog is small enough
 * that pagination only adds friction. Default order is "featured first, then
 * alphabetical A-Z" — applied via a stable client-side sort over the API
 * response (which already comes ordered by name asc).
 *
 * Attraction filter (multi-select AND): a row of attraction badges above the
 * grid lets users narrow the list to destinations that have ALL of the
 * selected attractions. The selection is persisted in `?attractions=a,b`
 * so URLs are shareable and survive refresh. The available badge set is
 * derived from the union of all attractions across the loaded destinations.
 * Note: with AND semantics each extra badge restricts the list further, so
 * the result can become empty quickly — the empty-filter banner below
 * handles that case explicitly.
 *
 * @route /{lang}/destinos/
 * @rendering SSR + ISR 24h
 */

import DefaultLayout from '@/layouts/DefaultLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import DestinationCard from '@/components/shared/cards/DestinationCard.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import { destinationsApi } from '@/lib/api/endpoints';
import { toDestinationCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const isAuthenticated = Boolean(Astro.locals.user);

const url = Astro.url;

// The public destinations endpoint caps `pageSize` at 100 (Zod validator on
// the API). The catalog is curated and tiny (~tens of CITY destinations), so
// a single page of 100 covers everything today. If `total` ever approaches
// 100, revisit this and either add real pagination back or fan out a second
// request server-side.
const PAGE_SIZE_ALL = 100;

// Default order is fixed: "featured first, then alphabetical A-Z". The API
// applies that ordering when no explicit sortBy is provided (see
// DestinationModel.findAll override), so this endpoint relies on the API
// default instead of re-sorting client-side.
const result = await destinationsApi.list({
    page: 1,
    pageSize: PAGE_SIZE_ALL,
    destinationType: 'CITY'
});

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.total : 0;
const rawCards = items.map((item) =>
    toDestinationCardProps({ item: item as unknown as Record<string, unknown> })
);

// API already returns featured-first then alphabetical (see
// DestinationModel.findAll default ordering), so no client-side sort is needed.
const sortedCards = rawCards;

// --- Attraction filter state ----------------------------------------------
// Parse the active attraction ids from the query string. Empty/missing means
// no filter is active. We store an ordered array (for canonical URL building)
// AND a Set (for O(1) membership lookups during filtering and badge rendering).
const rawAttractionsParam = url.searchParams.get('attractions') ?? '';
const requestedIds = rawAttractionsParam
    .split(',')
    .map((s) => s.trim())
    .filter((s) => s.length > 0);

// Build the union of attractions across all loaded destinations, deduplicated
// by id. Sorted by displayWeight desc, then name asc, so the most relevant
// attractions show up first. This guarantees every badge has ≥1 matching
// destination (we derive from the same dataset we're filtering).
type AttractionBadge = {
    readonly id: string;
    readonly name: string;
    readonly displayWeight: number;
};
const attractionMap = new Map<string, AttractionBadge>();
for (const card of rawCards) {
    if (!card.attractions) continue;
    for (const a of card.attractions) {
        if (!attractionMap.has(a.id)) {
            attractionMap.set(a.id, {
                id: a.id,
                name: a.name,
                displayWeight: a.displayWeight ?? 0
            });
        }
    }
}
const availableAttractions: ReadonlyArray<AttractionBadge> = [...attractionMap.values()].sort(
    (a, b) => {
        if (b.displayWeight !== a.displayWeight) return b.displayWeight - a.displayWeight;
        return a.name.localeCompare(b.name);
    }
);

// Drop any requested id that doesn't exist in the available set (stale link,
// stripped attraction, etc.). This keeps the URL canonical and prevents the
// filter from "pretending" to be active with no visible badge.
const activeIds = new Set(requestedIds.filter((id) => attractionMap.has(id)));
const isFilterActive = activeIds.size > 0;

// AND semantics: a card passes only if it has every active attraction.
// Implemented as `Array.prototype.every` over the active id set against the
// card's own attractions, which keeps the comparison branch-free and works
// with the readonly array shape returned by the transform.
const filteredCards = isFilterActive
    ? sortedCards.filter((c) => {
          const cardAttractionIds = new Set(c.attractions?.map((a) => a.id) ?? []);
          for (const requiredId of activeIds) {
              if (!cardAttractionIds.has(requiredId)) return false;
          }
          return true;
      })
    : sortedCards;

// Anchor appended to every filter href. With Astro's `<ClientRouter />`
// preserving scroll across navigations, clicking a badge while scrolled
// down can leave the user staring at whitespace if the filtered grid is
// shorter than the previous one. The anchor brings them back to the
// filters + grid region without any JS.
const FILTER_ANCHOR = '#dest-filter-top';

// Build the canonical href for a badge. Toggle the badge id in the active set:
// click an inactive badge → adds it; click an active one → removes it. When
// the resulting set is empty, drop the `attractions` query param entirely so
// `/destinos/` stays clean.
function buildBadgeHref(badgeId: string): string {
    const next = new Set(activeIds);
    if (next.has(badgeId)) next.delete(badgeId);
    else next.add(badgeId);
    const target = new URL(url.toString());
    if (next.size === 0) target.searchParams.delete('attractions');
    else target.searchParams.set('attractions', [...next].join(','));
    return `${target.pathname}${target.search}${FILTER_ANCHOR}`;
}

function buildClearHref(): string {
    const target = new URL(url.toString());
    target.searchParams.delete('attractions');
    const base = `${target.pathname}${target.search}` || target.pathname;
    return `${base}${FILTER_ANCHOR}`;
}

const mapHref = buildUrl({ locale, path: 'destinos/mapa' });
---

<DefaultLayout
	locale={locale}
	title={t('destinations.title', 'Destinos')}
	description={t('destinations.description', 'Explorá los destinos turísticos del Litoral Entrerriano.')}
>
	<div class="dest-listing">
		<div class="dest-listing__header section section--warm">
			<div class="dest-listing__header-container">
				<Breadcrumbs locale={locale} items={[{ label: t('destinations.title', 'Destinos') }]} />
				<ListingPageHeader
					locale={locale}
					tagline={t('destinations.tagline', 'Explorá la región')}
					title={t('destinations.title', 'Destinos')}
					totalCount={total}
				/>
			</div>
		</div>

		<!-- Wave separator -->
		<div class="dest-listing__wave" aria-hidden="true">
			<svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
				<path d="M0,64 C288,120 576,0 864,64 C1152,128 1440,32 1440,32 L1440,0 L0,0 Z" fill="var(--surface-warm)" />
			</svg>
		</div>

		<div class="dest-listing__body">
			<div class="dest-listing__container">
				{hasError && !result.ok && <ErrorBanner locale={locale} error={result.error} entityName="destinos" />}

				{!hasError && sortedCards.length === 0 && (
					<EmptyState locale={locale} variant="empty" />
				)}

				{!hasError && sortedCards.length > 0 && availableAttractions.length > 0 && (
					<nav
						id="dest-filter-top"
						class="dest-attractions-filter"
						aria-label={t('destinations.filter.attractionsAriaLabel', 'Filtrar por atracciones')}
					>
						<ul class="dest-attractions-filter__list">
							{availableAttractions.map((attr) => {
								const active = activeIds.has(attr.id);
								return (
									<li>
										<a
											href={buildBadgeHref(attr.id)}
											class:list={[
												'dest-attractions-filter__badge',
												{ 'dest-attractions-filter__badge--active': active }
											]}
											aria-pressed={active ? 'true' : 'false'}
											rel="nofollow"
										>
											{attr.name}
										</a>
									</li>
								);
							})}
							{isFilterActive && (
								<li>
									<a
										href={buildClearHref()}
										class="dest-attractions-filter__clear"
										rel="nofollow"
									>
										{t('destinations.filter.clear', 'Limpiar filtros')}
									</a>
								</li>
							)}
						</ul>
					</nav>
				)}

				{!hasError && sortedCards.length > 0 && (
					<div class="dest-listing__controls">
						<nav class="view-toggle" aria-label={t('accommodations.viewToggle.ariaLabel', 'Vista')}>
							<span
								class="view-toggle__btn view-toggle__btn--active"
								aria-current="page"
							>
								{t('accommodations.viewToggle.list', 'Lista')}
							</span>
							<a
								href={mapHref}
								class="view-toggle__btn"
							>
								{t('accommodations.viewToggle.map', 'Mapa')}
							</a>
						</nav>
					</div>
				)}

				{!hasError && filteredCards.length > 0 && (
					<div class="dest-grid">
						{filteredCards.map((card) => (
							<DestinationCard
								destination={card}
								locale={locale}
								variant="grid"
								isAuthenticated={isAuthenticated}
							/>
						))}
					</div>
				)}

				{!hasError && sortedCards.length > 0 && filteredCards.length === 0 && (
					<div class="dest-listing__empty-filter">
						<p class="dest-listing__empty-filter-msg">
							{t(
								'destinations.filter.empty',
								'No hay destinos que coincidan con los filtros seleccionados.'
							)}
						</p>
						<a href={buildClearHref()} class="dest-listing__empty-filter-clear">
							{t('destinations.filter.clear', 'Limpiar filtros')}
						</a>
					</div>
				)}
			</div>
		</div>
	</div>
</DefaultLayout>

<style>
	.dest-listing__header-container,
	.dest-listing__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.dest-listing__header {
		padding: 3rem 0 1.5rem;
	}

	.dest-listing__wave { margin-top: -1px; line-height: 0; }
	.dest-listing__wave svg { width: 100%; height: 80px; display: block; }

	.dest-listing__body { padding: var(--space-section-sm) 0; }

	.dest-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-card-gap);
	}

	@media (max-width: 1024px) { .dest-grid { grid-template-columns: repeat(3, 1fr); } }
	@media (max-width: 768px) { .dest-grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 480px) { .dest-grid { grid-template-columns: 1fr; } }

	/* Attraction filter row.
	 * Wrapping pill list. Each pill is a plain anchor — no JS — that flips the
	 * id in the `?attractions=` query param. Active state uses brand-accent for
	 * affordance; the rest uses surface-warm to stay calm against the grid. */
	.dest-attractions-filter {
		margin: 0 0 1.25rem;
		/* Used as the anchor target after each badge click. Without scroll
		 * margin the nav lands flush against the (potentially sticky) site
		 * header. The value is intentionally a bit generous so the user can
		 * see the filter row + the first row of cards in one viewport. */
		scroll-margin-top: 6rem;
	}

	.dest-attractions-filter__list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.dest-attractions-filter__badge,
	.dest-attractions-filter__clear {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-sans);
		font-size: 0.875rem;
		padding: 0.5rem 0.875rem;
		border-radius: var(--radius-pill);
		text-decoration: none;
		transition:
			background-color var(--duration-normal) ease,
			color var(--duration-normal) ease,
			border-color var(--duration-normal) ease;
	}

	.dest-attractions-filter__badge {
		background-color: var(--surface-warm);
		color: var(--core-foreground);
		border: 1px solid transparent;
	}

	.dest-attractions-filter__badge:hover {
		background-color: oklch(from var(--brand-accent) l c h / 0.12);
		color: var(--brand-accent);
	}

	.dest-attractions-filter__badge--active,
	.dest-attractions-filter__badge--active:hover {
		background-color: var(--brand-accent);
		color: var(--accent-foreground);
		font-weight: 500;
	}

	.dest-attractions-filter__clear {
		background-color: transparent;
		color: var(--core-muted-foreground);
		border: 1px dashed var(--core-muted-foreground);
	}

	.dest-attractions-filter__clear:hover {
		color: var(--core-foreground);
		border-color: var(--core-foreground);
	}

	/* View toggle (Lista | Mapa) */
	.view-toggle {
		display: inline-flex;
		gap: 0.5rem;
		padding: 4px;
		margin: 0;
		background-color: var(--surface-warm);
		border-radius: var(--radius-pill);
	}
	.view-toggle__btn {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-pill);
		color: var(--core-muted-foreground);
		text-decoration: none;
		transition: background-color var(--duration-normal) ease, color var(--duration-normal) ease;
		cursor: pointer;
	}
	.view-toggle__btn:hover { color: var(--core-foreground); }
	.view-toggle__btn--active {
		background-color: var(--brand-accent);
		color: var(--accent-foreground);
		font-weight: 500;
		cursor: default;
	}

	.dest-listing__controls {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-start;
		gap: 0.75rem;
		margin: 0 0 1rem;
	}

	/* Empty state shown when filters narrow the list to zero.
	 * Distinct from EmptyState (which fires when the catalog itself is empty)
	 * because we want to hint at the action: clear the filters. */
	.dest-listing__empty-filter {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.875rem;
		padding: var(--space-12) var(--space-6);
		text-align: center;
	}

	.dest-listing__empty-filter-msg {
		margin: 0;
		font-family: var(--font-sans);
		font-size: var(--text-body-lg, 1rem);
		color: var(--core-muted-foreground);
		max-width: 40ch;
		line-height: 1.6;
	}

	.dest-listing__empty-filter-clear {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-sans);
		font-size: 0.875rem;
		padding: 0.625rem 1.25rem;
		border-radius: var(--radius-button);
		color: var(--brand-accent);
		border: 1px solid var(--brand-accent);
		text-decoration: none;
		transition: background-color var(--duration-normal) ease, color var(--duration-normal) ease;
	}

	.dest-listing__empty-filter-clear:hover {
		background-color: var(--brand-accent);
		color: var(--accent-foreground);
	}
</style>
