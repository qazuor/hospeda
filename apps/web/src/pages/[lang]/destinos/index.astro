---
/**
 * @file destinos/index.astro
 * @description Destinations listing page with card grid (no pagination).
 * Uses DefaultLayout (no filter sidebar - hierarchy serves as filter).
 *
 * Renders all destinations in a single grid: the catalog is small enough
 * that pagination only adds friction. Default order is "featured first, then
 * alphabetical A-Z" — applied via a stable client-side sort over the API
 * response (which already comes ordered by name asc).
 *
 * Attraction filter (multi-select AND): a row of attraction badges above the
 * grid lets users narrow the list to destinations that have ALL of the
 * selected attractions. The selection is persisted in `?attractions=a,b`
 * so URLs are shareable and survive refresh. The available badge set is
 * derived from the union of all attractions across the loaded destinations.
 * Note: with AND semantics each extra badge restricts the list further, so
 * the result can become empty quickly — the empty-filter banner below
 * handles that case explicitly.
 *
 * @route /{lang}/destinos/
 * @rendering SSR + ISR 24h
 */

import DefaultLayout from '@/layouts/DefaultLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import ContributionBanner from '@/components/contributions/ContributionBanner.astro';
import DestinationCard from '@/components/shared/cards/DestinationCard.astro';
import ItemListJsonLd from '@/components/seo/ItemListJsonLd.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import { destinationsApi } from '@/lib/api/endpoints';
import { toDestinationCardProps } from '@/lib/api/transforms';
import { getAttractionIcon } from '@repo/icons';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { CloseIcon } from '@repo/icons';

/**
 * How many attraction chips render in the first row before the "Ver más"
 * disclosure kicks in. Tuned so the row fits in one line on typical desktop
 * widths and stays calm on mobile.
 */
const VISIBLE_ATTRACTION_LIMIT = 12;

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const isAuthenticated = Boolean(Astro.locals.user);

const url = Astro.url;

// The public destinations endpoint caps `pageSize` at 100 (Zod validator on
// the API). The catalog is curated and tiny (~tens of CITY destinations), so
// a single page of 100 covers everything today. If `total` ever approaches
// 100, revisit this and either add real pagination back or fan out a second
// request server-side.
const PAGE_SIZE_ALL = 100;

// Default order is fixed: "featured first, then alphabetical A-Z". The API
// applies that ordering when no explicit sortBy is provided (see
// DestinationModel.findAll override), so this endpoint relies on the API
// default instead of re-sorting client-side.
const result = await destinationsApi.list({
    page: 1,
    pageSize: PAGE_SIZE_ALL,
    destinationType: 'CITY'
});

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.pagination.total : 0;
const rawCards = items.map((item) =>
    toDestinationCardProps({ item: item as unknown as Record<string, unknown> })
);

// API already returns featured-first then alphabetical (see
// DestinationModel.findAll default ordering), so no client-side sort is needed.
const sortedCards = rawCards;

// --- Attraction filter state ----------------------------------------------
// Parse the active attraction ids from the query string. Empty/missing means
// no filter is active. We store an ordered array (for canonical URL building)
// AND a Set (for O(1) membership lookups during filtering and badge rendering).
const rawAttractionsParam = url.searchParams.get('attractions') ?? '';
const requestedIds = rawAttractionsParam
    .split(',')
    .map((s) => s.trim())
    .filter((s) => s.length > 0);

// Build the union of attractions across all loaded destinations, deduplicated
// by id. Sorted by displayWeight desc, then name asc, so the most relevant
// attractions show up first. This guarantees every badge has ≥1 matching
// destination (we derive from the same dataset we're filtering).
type AttractionBadge = {
    readonly id: string;
    readonly name: string;
    readonly icon?: string;
    readonly displayWeight: number;
};
const attractionMap = new Map<string, AttractionBadge>();
for (const card of rawCards) {
    if (!card.attractions) continue;
    for (const a of card.attractions) {
        if (!attractionMap.has(a.id)) {
            attractionMap.set(a.id, {
                id: a.id,
                name: a.name,
                icon: a.icon,
                displayWeight: a.displayWeight ?? 0
            });
        }
    }
}
const availableAttractions: ReadonlyArray<AttractionBadge> = [...attractionMap.values()].sort(
    (a, b) => {
        if (b.displayWeight !== a.displayWeight) return b.displayWeight - a.displayWeight;
        return a.name.localeCompare(b.name);
    }
);

// Drop any requested id that doesn't exist in the available set (stale link,
// stripped attraction, etc.). This keeps the URL canonical and prevents the
// filter from "pretending" to be active with no visible badge.
const activeIds = new Set(requestedIds.filter((id) => attractionMap.has(id)));
const isFilterActive = activeIds.size > 0;

// The chip list renders ALL attractions in a single flex-wrap <ul>, and a
// sibling <details> toggles whether the overflow (chips past the first
// `VISIBLE_ATTRACTION_LIMIT`) are hidden via CSS `:has(details:not([open]))`.
// Keeping every chip in the same flex container makes the expanded set
// continue the wrap from wherever the visible row ended, instead of
// starting a fresh row from the left.
//
// When a selected filter lives in the overflow, the disclosure opens by
// default so the user can see (and unselect) it without hunting for the
// "Ver más" toggle.
const hasOverflowAttractions = availableAttractions.length > VISIBLE_ATTRACTION_LIMIT;
const overflowCount = Math.max(0, availableAttractions.length - VISIBLE_ATTRACTION_LIMIT);
const anyOverflowActive = availableAttractions
    .slice(VISIBLE_ATTRACTION_LIMIT)
    .some((a) => activeIds.has(a.id));

// AND semantics: a card matches only if it has every active attraction.
// SSR uses this to decide which cards are hidden on first paint, so users
// landing on a deep-linked URL (or browsing with JS disabled) see the
// filtered set immediately without waiting for any script to run. The same
// predicate is mirrored in the inline script below, which keeps it in sync
// across client-driven toggles.
function cardMatchesFilter(card: (typeof sortedCards)[number]): boolean {
    if (!isFilterActive) return true;
    const cardAttractionIds = new Set(card.attractions?.map((a) => a.id) ?? []);
    for (const requiredId of activeIds) {
        if (!cardAttractionIds.has(requiredId)) return false;
    }
    return true;
}

const visibleCardCount = sortedCards.reduce(
    (acc, c) => acc + (cardMatchesFilter(c) ? 1 : 0),
    0
);
const showEmptyBanner = isFilterActive && visibleCardCount === 0;

// Anchor appended to every filter href so that no-JS navigations land users
// back at the filter row + grid instead of the page header.
const FILTER_ANCHOR = '#dest-filter-top';

// Build the canonical href for a badge. Toggle the badge id in the active set:
// click an inactive badge → adds it; click an active one → removes it. When
// the resulting set is empty, drop the `attractions` query param entirely so
// `/destinos/` stays clean. The inline script below intercepts the click and
// drives the same transition through the History API; the href is the
// no-JS fallback (and what `target=_blank` / copy-link / right-click use).
function buildBadgeHref(badgeId: string): string {
    const next = new Set(activeIds);
    if (next.has(badgeId)) next.delete(badgeId);
    else next.add(badgeId);
    const target = new URL(url.toString());
    if (next.size === 0) target.searchParams.delete('attractions');
    else target.searchParams.set('attractions', [...next].join(','));
    return `${target.pathname}${target.search}${FILTER_ANCHOR}`;
}

function buildClearHref(): string {
    const target = new URL(url.toString());
    target.searchParams.delete('attractions');
    const base = `${target.pathname}${target.search}` || target.pathname;
    return `${base}${FILTER_ANCHOR}`;
}

const mapHref = buildUrl({ locale, path: 'destinos/mapa' });

// ItemList JSON-LD entries — the full (single-page) destinations catalog,
// routed through the reusable ItemListJsonLd component (SPEC-157 D-1 canonical
// JSON-LD path). Destinos has no pagination, so startPosition stays at the
// default 1 and numberOfItems mirrors the rendered set.
const itemListEntries = sortedCards.map((card) => ({
	url: new URL(buildUrl({ locale, path: `destinos/${card.slug}` }), Astro.site ?? Astro.url.origin).href,
	name: card.name,
}));

const cspNonce = Astro.locals.cspNonce ?? '';
---

<DefaultLayout
	locale={locale}
	title={t('destinations.title', 'Destinos')}
	description={t('destinations.description', 'Explorá los destinos turísticos del Litoral Entrerriano.')}
>
	<ItemListJsonLd
		slot="head-extra"
		name={t('destinations.title', 'Destinos')}
		items={itemListEntries}
		numberOfItems={total}
	/>

	<div class="dest-listing">
		<div class="dest-listing__header section section--warm">
			<div class="dest-listing__header-container">
				<Breadcrumbs locale={locale} items={[{ label: t('destinations.title', 'Destinos') }]} />
				<ListingPageHeader
					locale={locale}
					tagline={t('destinations.tagline', 'Explorá la región')}
					title={t('destinations.title', 'Destinos')}
					totalCount={total}
				/>
			</div>
		</div>

		<!-- Wave separator -->
		<div class="dest-listing__wave" aria-hidden="true">
			<svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
				<path d="M0,64 C288,120 576,0 864,64 C1152,128 1440,32 1440,32 L1440,0 L0,0 Z" fill="var(--surface-warm)" />
			</svg>
		</div>

		<div class="dest-listing__body">
			<div class="dest-listing__container">
				{hasError && !result.ok && <ErrorBanner locale={locale} error={result.error} entityName="destinos" />}

				{!hasError && sortedCards.length === 0 && (
					<EmptyState locale={locale} variant="empty" />
				)}

				{!hasError && sortedCards.length > 0 && availableAttractions.length > 0 && (
					<nav
						id="dest-filter-top"
						class="dest-attractions-filter"
						aria-label={t('destinations.filter.attractionsAriaLabel', 'Filtrar por atracciones')}
					>
						<ul class="dest-attractions-filter__list">
							{availableAttractions.map((attr) => {
								const active = activeIds.has(attr.id);
								const Icon = getAttractionIcon({ icon: attr.icon });
								return (
									<li>
										<a
											href={buildBadgeHref(attr.id)}
											class:list={[
												'dest-attractions-filter__badge',
												{ 'dest-attractions-filter__badge--active': active }
											]}
											aria-pressed={active ? 'true' : 'false'}
											rel="nofollow"
											data-attraction-id={attr.id}
										>
											<span class="dest-attractions-filter__badge-icon" aria-hidden="true">
												<Icon size={14} weight="regular" />
											</span>
											<span>{attr.name}</span>
											<span class="dest-attractions-filter__badge-remove" aria-hidden="true">
												<CloseIcon size={11} weight="bold" />
											</span>
										</a>
									</li>
								);
							})}
						</ul>

						{hasOverflowAttractions && (
							<details class="dest-attractions-filter__more" open={anyOverflowActive}>
								<summary class="dest-attractions-filter__more-toggle">
									<span class="dest-attractions-filter__more-label-closed">
										{t('destinations.filter.showMore', 'Ver más')}
									</span>
									<span class="dest-attractions-filter__more-label-open">
										{t('destinations.filter.showLess', 'Ver menos')}
									</span>
									<span class="dest-attractions-filter__more-count">
										{overflowCount}
									</span>
								</summary>
							</details>
						)}

					</nav>
				)}

				{!hasError && sortedCards.length > 0 && (
					<div class="dest-listing__controls">
						<nav class="view-toggle" aria-label={t('accommodations.viewToggle.ariaLabel', 'Vista')}>
							<span
								class="view-toggle__btn view-toggle__btn--active"
								aria-current="page"
							>
								{t('accommodations.viewToggle.list', 'Lista')}
							</span>
							<a
								href={mapHref}
								class="view-toggle__btn"
							>
								{t('accommodations.viewToggle.map', 'Mapa')}
							</a>
						</nav>
					</div>
				)}

				{!hasError && sortedCards.length > 0 && (
					<div class="dest-grid">
						{sortedCards.map((card) => {
							const matches = cardMatchesFilter(card);
							const attractionIdsAttr = (card.attractions ?? [])
								.map((a) => a.id)
								.join(',');
							return (
								<div
									class:list={[
										'dest-card-wrap',
										{ 'dest-card-wrap--hidden': !matches }
									]}
									data-attraction-ids={attractionIdsAttr}
								>
									<DestinationCard
										destination={card}
										locale={locale}
										variant="grid"
										isAuthenticated={isAuthenticated}
									/>
								</div>
							);
						})}
					</div>
				)}

				{!hasError && sortedCards.length > 0 && (
					<div class="dest-listing__empty-filter" hidden={!showEmptyBanner}>
						<p class="dest-listing__empty-filter-msg">
							{t(
								'destinations.filter.empty',
								'No hay destinos que coincidan con los filtros seleccionados.'
							)}
						</p>
						<a href={buildClearHref()} class="dest-listing__empty-filter-clear">
							{t('destinations.filter.clear', 'Limpiar filtros')}
						</a>
					</div>
				)}

				<!-- Photo-contribution banner (SPEC-191 FR-8): after the grid.
				     page/[page].astro is a 301 redirect — this single mount
				     covers the whole listing. -->
				<ContributionBanner
					title={t('contributions.banner.photosListing.title', '¿Tenés fotos de estos destinos?')}
					description={t(
						'contributions.banner.photosListing.description',
						'Sumá tus fotos y ayudá a mostrar el Litoral como se merece.'
					)}
					ctaLabel={t('contributions.banner.photos.cta', 'Aportar fotos')}
					ctaHref={buildUrl({ locale, path: 'colaborar/fotos' })}
					source="destination_listing"
					variant="photos"
				/>
			</div>
		</div>
	</div>
</DefaultLayout>

<style>
	.dest-listing__header-container,
	.dest-listing__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.dest-listing__header {
		padding: 3rem 0 1.5rem;
	}

	.dest-listing__wave { margin-top: -1px; line-height: 0; }
	.dest-listing__wave svg { width: 100%; height: 80px; display: block; }

	.dest-listing__body { padding: var(--space-section-sm) 0; }

	.dest-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-card-gap);
	}

	@media (max-width: 1024px) { .dest-grid { grid-template-columns: repeat(3, 1fr); } }
	@media (max-width: 768px) { .dest-grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 480px) { .dest-grid { grid-template-columns: 1fr; } }

	/* Card wrapper that participates in the grid AND carries the
	 * data-attraction-ids attribute the inline filter script reads. Hidden
	 * via display:none (rather than visibility) so it stops occupying a grid
	 * cell — otherwise the grid would leave holes between visible cards. */
	.dest-card-wrap--hidden {
		display: none;
	}

	/* During chip-toggle View Transitions, fold the per-image transition
	 * names (Astro emits them for list ↔ detail page morphs) back into the
	 * root snapshot. Otherwise the named images snapshot independently and
	 * escape their parent's rounded `overflow: hidden` mask while the
	 * crossfade runs, briefly looking like the photo pops out of the card.
	 * Astro applies the name via inline style, so we need `!important` to
	 * win the cascade. Scoped to `:global` so it pierces Astro's scoped
	 * styling and reaches the cards rendered by DestinationCard.astro. */
	:global(html.is-attractions-transition .dest-card__img) {
		view-transition-name: none !important;
	}

	/* Attraction filter block.
	 * Vertical stack: head row of chips → "Ver más" toggle. Each chip is an
	 * <a> with an href that doubles as a no-JS fallback; the inline script
	 * below intercepts click and drives the toggle through the History API
	 * so the page never navigates. */
	.dest-attractions-filter {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.5rem;
		margin: 0 0 1.25rem;
		/* Used as the anchor target after each badge click. Without scroll
		 * margin the nav lands flush against the (potentially sticky) site
		 * header. The value is intentionally a bit generous so the user can
		 * see the filter row + the first row of cards in one viewport. */
		scroll-margin-top: 6rem;
	}

	.dest-attractions-filter__list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	/* When the "Ver más" disclosure is closed, hide every chip past the
	 * first VISIBLE_ATTRACTION_LIMIT (currently 12 — keep `nth-child(n+13)`
	 * in sync if you tweak the constant). Keeping all chips in the same
	 * <ul> lets the expanded set continue the flex-wrap from wherever the
	 * head row left off, instead of starting a fresh row from the left. */
	.dest-attractions-filter:has(details:not([open]))
		.dest-attractions-filter__list
		> li:nth-child(n + 13) {
		display: none;
	}

	.dest-attractions-filter__badge,
	.dest-attractions-filter__more-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-family: var(--font-sans);
		font-size: 0.75rem;
		line-height: 1;
		padding: 0.3125rem 0.625rem;
		border-radius: var(--radius-pill);
		text-decoration: none;
		transition:
			background-color var(--duration-normal) ease,
			color var(--duration-normal) ease,
			border-color var(--duration-normal) ease;
	}

	.dest-attractions-filter__badge {
		background-color: var(--surface-warm);
		color: var(--core-foreground);
		border: 1px solid transparent;
	}

	.dest-attractions-filter__badge:hover {
		background-color: var(--brand-accent-a12);
		color: var(--brand-accent);
	}

	.dest-attractions-filter__badge--active,
	.dest-attractions-filter__badge--active:hover {
		background-color: var(--brand-accent);
		color: var(--accent-foreground);
		font-weight: 500;
	}

	.dest-attractions-filter__badge-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		opacity: 0.85;
	}

	.dest-attractions-filter__badge--active .dest-attractions-filter__badge-icon {
		opacity: 1;
	}

	/* The close (×) glyph is pre-rendered inside every chip so the inline
	 * filter script can flip it on/off through a single class change instead
	 * of injecting SVG markup at runtime. Hidden by default; revealed only
	 * when the chip is active. */
	.dest-attractions-filter__badge-remove {
		display: none;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		margin-left: 0.125rem;
		opacity: 0.7;
	}

	.dest-attractions-filter__badge--active .dest-attractions-filter__badge-remove {
		display: inline-flex;
	}

	/* Native <details> disclosure used purely as a stateful toggle — the
	 * actual chip list lives in the sibling <ul> and is hidden/shown via the
	 * `:has(details:not([open]))` rule above. align-self keeps the summary
	 * compact (it would otherwise stretch to the nav's full width). */
	.dest-attractions-filter__more {
		align-self: flex-start;
	}

	.dest-attractions-filter__more-toggle {
		background-color: transparent;
		color: var(--core-muted-foreground);
		border: 1px dashed var(--core-muted-foreground);
		cursor: pointer;
		list-style: none;
		user-select: none;
	}

	.dest-attractions-filter__more-toggle::-webkit-details-marker {
		display: none;
	}

	.dest-attractions-filter__more-toggle:hover {
		color: var(--core-foreground);
		border-color: var(--core-foreground);
	}

	.dest-attractions-filter__more[open] .dest-attractions-filter__more-toggle {
		color: var(--core-foreground);
		border-color: var(--core-foreground);
	}

	/* Two-state label inside the summary: closed = "Ver más", open =
	 * "Ver menos". Both strings ship through i18n so translators do not have
	 * to deal with CSS ::after content swaps. */
	.dest-attractions-filter__more:not([open]) .dest-attractions-filter__more-label-open {
		display: none;
	}

	.dest-attractions-filter__more[open] .dest-attractions-filter__more-label-closed {
		display: none;
	}

	/* The count is meaningful only while the tail is hidden ("Ver más (45)").
	 * Once expanded, the chips themselves convey that info and the count
	 * becomes redundant noise next to "Ver menos". */
	.dest-attractions-filter__more[open] .dest-attractions-filter__more-count {
		display: none;
	}

	.dest-attractions-filter__more-count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.25rem;
		height: 1.125rem;
		padding: 0 0.3125rem;
		border-radius: var(--radius-pill);
		background-color: var(--brand-primary-a12);
		color: var(--brand-primary);
		font-size: 0.6875rem;
		font-weight: 600;
	}

	/* View toggle (Lista | Mapa) */
	.view-toggle {
		display: inline-flex;
		gap: 0.5rem;
		padding: 4px;
		margin: 0;
		background-color: var(--surface-warm);
		border-radius: var(--radius-pill);
	}
	.view-toggle__btn {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-pill);
		color: var(--core-muted-foreground);
		text-decoration: none;
		transition: background-color var(--duration-normal) ease, color var(--duration-normal) ease;
		cursor: pointer;
	}
	.view-toggle__btn:hover { color: var(--core-foreground); }
	.view-toggle__btn--active {
		background-color: var(--brand-accent);
		color: var(--accent-foreground);
		font-weight: 500;
		cursor: default;
	}

	.dest-listing__controls {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-start;
		gap: 0.75rem;
		margin: 0 0 1rem;
	}

	/* Empty state shown when filters narrow the list to zero.
	 * Distinct from EmptyState (which fires when the catalog itself is empty)
	 * because we want to hint at the action: clear the filters. */
	.dest-listing__empty-filter {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.875rem;
		padding: var(--space-12) var(--space-6);
		text-align: center;
	}

	.dest-listing__empty-filter-msg {
		margin: 0;
		font-family: var(--font-sans);
		font-size: var(--text-body-lg, 1rem);
		color: var(--core-muted-foreground);
		max-width: 40ch;
		line-height: 1.6;
	}

	.dest-listing__empty-filter-clear {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-sans);
		font-size: 0.875rem;
		padding: 0.625rem 1.25rem;
		border-radius: var(--radius-button);
		color: var(--brand-accent);
		border: 1px solid var(--brand-accent);
		text-decoration: none;
		transition: background-color var(--duration-normal) ease, color var(--duration-normal) ease;
	}

	.dest-listing__empty-filter-clear:hover {
		background-color: var(--brand-accent);
		color: var(--accent-foreground);
	}
</style>

<script is:inline nonce={cspNonce}>
	/**
	 * Client-side attractions filter for /destinos.
	 *
	 * The page is SSR-rendered with every card present and the right cards
	 * pre-hidden based on `?attractions=` in the URL, so no-JS visitors and
	 * the first paint always reflect the canonical state. This script
	 * progressively enhances that baseline: chip clicks no longer navigate,
	 * the URL is updated via History API, and the card grid + empty banner +
	 * chip styling are reconciled in place. No scroll reset, no view-
	 * transition flash, no network round-trip.
	 *
	 * Init runs on `astro:page-load` so it re-attaches after every
	 * `<ClientRouter />` soft swap — relying on a one-shot IIFE would leave
	 * stale closures pointing at detached DOM after the user navigates away
	 * and back.
	 */
	(function () {
		var FILTER_ROOT_ID = 'dest-filter-top';
		var BADGE_SEL = '.dest-attractions-filter__badge';
		var BADGE_ACTIVE_CLASS = 'dest-attractions-filter__badge--active';
		var CARD_WRAP_SEL = '.dest-card-wrap';
		var CARD_HIDDEN_CLASS = 'dest-card-wrap--hidden';
		var BANNER_SEL = '.dest-listing__empty-filter';
		var CLEAR_LINK_SEL = '.dest-listing__empty-filter-clear';
		var DETAILS_SEL = '.dest-attractions-filter__more';
		var VISIBLE_LIMIT = 12;

		function init() {
			var filterRoot = document.getElementById(FILTER_ROOT_ID);
			if (!filterRoot) return;

			var cards = Array.prototype.slice.call(document.querySelectorAll(CARD_WRAP_SEL));
			var badges = Array.prototype.slice.call(filterRoot.querySelectorAll(BADGE_SEL));
			var banner = document.querySelector(BANNER_SEL);
			var clearLink = document.querySelector(CLEAR_LINK_SEL);
			var details = filterRoot.querySelector(DETAILS_SEL);

			// Pre-compute each card's attraction id set once — the dataset
			// never changes within a session, so re-parsing the string on
			// every reconcile pass would be wasted work.
			var cardIds = cards.map(function (card) {
				var raw = card.getAttribute('data-attraction-ids') || '';
				return raw.split(',').filter(Boolean);
			});

			function readActiveFromUrl() {
				var raw = new URLSearchParams(window.location.search).get('attractions') || '';
				return new Set(
					raw
						.split(',')
						.map(function (s) { return s.trim(); })
						.filter(Boolean)
				);
			}

			function buildHref(active) {
				var url = new URL(window.location.href);
				if (active.size === 0) url.searchParams.delete('attractions');
				else url.searchParams.set('attractions', Array.from(active).join(','));
				return url.pathname + url.search + '#' + FILTER_ROOT_ID;
			}

			function buildHrefToggling(badgeId, active) {
				var next = new Set(active);
				if (next.has(badgeId)) next.delete(badgeId);
				else next.add(badgeId);
				return buildHref(next);
			}

			function reconcile(active) {
				// Cards: AND semantics — a card stays visible only when it
				// carries every active id. When no filter is active, every
				// card shows.
				var visibleCount = 0;
				for (var i = 0; i < cards.length; i++) {
					var ids = cardIds[i];
					var matches = true;
					active.forEach(function (required) {
						if (ids.indexOf(required) === -1) matches = false;
					});
					cards[i].classList.toggle(CARD_HIDDEN_CLASS, !matches);
					if (matches) visibleCount++;
				}

				// Chips: active class + aria-pressed + refreshed href so
				// modifier-clicks (new tab / copy link) keep producing a URL
				// that round-trips to the current state.
				var overflowActive = false;
				for (var j = 0; j < badges.length; j++) {
					var badge = badges[j];
					var id = badge.getAttribute('data-attraction-id');
					if (!id) continue;
					var isActive = active.has(id);
					badge.classList.toggle(BADGE_ACTIVE_CLASS, isActive);
					badge.setAttribute('aria-pressed', isActive ? 'true' : 'false');
					badge.setAttribute('href', buildHrefToggling(id, active));
					if (isActive && j >= VISIBLE_LIMIT) overflowActive = true;
				}

				// Empty banner: surface only when filters narrow to zero.
				if (banner) {
					var show = active.size > 0 && visibleCount === 0;
					if (show) banner.removeAttribute('hidden');
					else banner.setAttribute('hidden', '');
				}

				// "Limpiar filtros" link in the empty banner: target the
				// cleared URL so the no-JS fallback still works.
				if (clearLink) clearLink.setAttribute('href', buildHref(new Set()));

				// If a freshly-active filter lives in the collapsed overflow,
				// open the disclosure so the user can see (and remove) it. We
				// never auto-close — that's the user's choice once they've
				// expanded it.
				if (details && overflowActive && !details.open) details.open = true;
			}

			// Wrap DOM mutations in the View Transitions API so the browser
			// crossfades cards as they appear/disappear and morphs the grid
			// reflow. This is the same animation `<ClientRouter />` gave us
			// for free when chip clicks still triggered a full navigation.
			//
			// `is-attractions-transition` on <html> suppresses the per-card
			// `view-transition-name` Astro emits for list ↔ detail morphs
			// (see DestinationCard.astro). Without that suppression the
			// named images get their own snapshot and escape the parent's
			// rounded `overflow: hidden` mask while crossfading — they
			// briefly render with no clip, looking like the image "pops
			// out" of the card. Stripping the names for the duration of
			// our transition folds them back into the root snapshot.
			//
			// Browsers without VT (Firefox < 129 at time of writing) get
			// the unanimated reconcile, which still works fine.
			function applyTransition(update) {
				if (typeof document.startViewTransition !== 'function') {
					update();
					return;
				}
				var root = document.documentElement;
				root.classList.add('is-attractions-transition');
				var transition = document.startViewTransition(update);
				transition.finished.finally(function () {
					root.classList.remove('is-attractions-transition');
				});
			}

			function onClick(e) {
				// Honor modifier-clicks and middle-click so users keep the
				// "open in new tab" / "copy link address" affordances they
				// would expect from a normal anchor.
				if (e.defaultPrevented) return;
				if (e.button !== undefined && e.button !== 0) return;
				if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

				var badge = e.target.closest(BADGE_SEL);
				var clear = e.target.closest(CLEAR_LINK_SEL);
				var nextActive = null;
				if (badge && filterRoot.contains(badge)) {
					var id = badge.getAttribute('data-attraction-id');
					if (!id) return;
					var current = readActiveFromUrl();
					nextActive = new Set(current);
					if (nextActive.has(id)) nextActive.delete(id);
					else nextActive.add(id);
				} else if (clear) {
					nextActive = new Set();
				} else {
					return;
				}

				e.preventDefault();
				window.history.pushState({}, '', buildHref(nextActive));
				applyTransition(function () { reconcile(nextActive); });
			}

			function onPopState() {
				// The popstate listener lives on `window` and survives soft
				// swaps, so guard against firing after the user navigated to
				// a different page: filterRoot is detached once /destinos is
				// gone from the DOM.
				if (!document.contains(filterRoot)) return;
				var next = readActiveFromUrl();
				applyTransition(function () { reconcile(next); });
			}

			// Scope click handling to the page DOM (dies with the swap) and
			// keep popstate on window (the guard above neutralises stale
			// instances).
			filterRoot.addEventListener('click', onClick);
			if (banner) banner.addEventListener('click', onClick);
			window.addEventListener('popstate', onPopState);
		}

		document.addEventListener('astro:page-load', init);
	})();
</script>
