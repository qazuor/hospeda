---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../../lib/page-helpers';

/**
 * Destination list page - displays all destinations in the Litoral region.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import DestinationCard from '../../../components/destination/DestinationCard.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import DestinationErrorState from '../../../components/error/DestinationErrorState.astro';
import SectionTitle from '../../../components/ui/SectionTitle.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { destinationsApi } from '../../../lib/api/endpoints';
import Pagination from '../../../components/ui/Pagination.astro';
import { LocationIcon } from '@repo/icons';
import { DestinationFilters } from '../../../components/destination/DestinationFilters.client.tsx';
import { toDestinationCardProps } from '../../../lib/api/transforms';
import { t } from '../../../lib/i18n';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Pagination parameters
 */
const page = Number.parseInt(Astro.url.searchParams.get('page') || '1', 10);
const pageSize = 12;

/**
 * Fetch destinations from API
 */
const result = await destinationsApi.list({ page, pageSize, destinationType: 'CITY' });
const apiError = !result.ok;
const destinations = result.ok ? (result.data.items as Array<Record<string, unknown>>) : [];
const pagination = result.ok ? result.data.pagination : null;

/**
 * Parse URL query parameters for client-side filter pre-population.
 * Since prerender = true, these are only used to pass initial values to the React island.
 */
const initialQuery = Astro.url.searchParams.get('q') || '';
const initialType = Astro.url.searchParams.get('type') || '';
const initialParentId = Astro.url.searchParams.get('parentId') || '';

const pageTitle = t({ locale, namespace: 'destination', key: 'listing.title' });
const pageDescription = t({ locale, namespace: 'destination', key: 'listing.description' });
const heroHeading = t({ locale, namespace: 'destination', key: 'listing.hero.heading' });
const heroDescription = t({ locale, namespace: 'destination', key: 'listing.hero.description' });
const featuredTitle = t({ locale, namespace: 'destination', key: 'listing.featured.title' });
const emptyStateTitle = t({ locale, namespace: 'destination', key: 'listing.emptyState.title' });
const emptyStateMessage = t({ locale, namespace: 'destination', key: 'listing.emptyState.message' });
const regionalTitle = t({ locale, namespace: 'destination', key: 'listing.regional.title' });
const regionalText = t({ locale, namespace: 'destination', key: 'listing.regional.text' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: pageTitle, href: `/${locale}/destinos/` },
];
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={pageDescription}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- Hero Section -->
				<article id="hero" class="mb-12 text-center">
					<SectionTitle as="h1" class="mb-6">
						{heroHeading}
					</SectionTitle>
					<p class="mx-auto max-w-3xl text-xl leading-relaxed text-text-secondary">
						{heroDescription}
					</p>
				</article>

				<!-- Search and Filters (client-side React island) -->
				<article id="search-bar" class="mb-12">
					<DestinationFilters
						client:visible
						initialQuery={initialQuery}
						initialType={initialType}
						initialParentId={initialParentId}
						locale={locale}
					/>
				</article>

				<!-- Featured Destinations Section -->
				<article id="featured-destinations" class="mb-16">
					<SectionTitle as="h2" weight="semibold" class="mb-8 text-center">
						{featuredTitle}
					</SectionTitle>

					<!-- Grid Area for Destination Cards -->
					<div
						id="destination-grid"
						class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
						role="region"
						aria-label={featuredTitle}
					>
						{destinations.length > 0 ? (
							destinations.map((dest) => (
								<DestinationCard
									destination={toDestinationCardProps({ item: dest as Record<string, unknown> })}
									locale={locale}
								/>
							))
						) : apiError ? (
							<div class="col-span-full">
								<DestinationErrorState locale={locale} />
							</div>
						) : (
							<div class="col-span-full">
								<EmptyState
									title={emptyStateTitle}
									message={emptyStateMessage}
								/>
							</div>
						)}
					</div>
				</article>

				<!-- Pagination -->
				{
					pagination && pagination.totalPages > 1 && (
						<article id="pagination" class="mb-12">
							<Pagination
								currentPage={pagination.page as number}
								totalPages={pagination.totalPages as number}
								baseUrl={`/${locale}/destinos`}
								locale={locale}
							/>
						</article>
					)
				}

				<!-- Regional Highlight Section -->
				<article id="regional-highlight" class="mb-12">
					<div class="rounded-lg bg-bg p-8 shadow-sm">
						<SectionTitle as="h2" weight="semibold" class="mb-4 text-center">
							{regionalTitle}
						</SectionTitle>
						<p class="mx-auto max-w-4xl text-lg leading-relaxed text-text-secondary">
							{regionalText}
						</p>
					</div>
				</article>

				<!-- Provinces Highlight -->
				<article id="provinces" class="mb-16">
					<div class="grid gap-8 md:grid-cols-3">
						<!-- Entre Ríos -->
						<div class="text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 mx-auto"
							>
								<LocationIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Entre Ríos</h3>
							<p class="text-text-secondary">
								Termas naturales, playas del río Uruguay y rica historia colonial.
							</p>
						</div>

						<!-- Corrientes -->
						<div class="text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 mx-auto"
							>
								<LocationIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Corrientes</h3>
							<p class="text-text-secondary">
								Esteros del Iberá, carnaval y tradiciones guaraníes.
							</p>
						</div>

						<!-- Santa Fe -->
						<div class="text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 mx-auto"
							>
								<LocationIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Santa Fe</h3>
							<p class="text-text-secondary">
								Cuna de la Constitución, ciudades coloniales y pesca deportiva.
							</p>
						</div>
					</div>
				</article>
			</div>
		</Section>
	</Container>
</BaseLayout>
