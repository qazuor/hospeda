---
export const prerender = true;

export function getStaticPaths() {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

/**
 * Destination list page - displays all destinations in the Litoral region.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import DestinationCard from '../../../components/destination/DestinationCard.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import { isValidLocale, type SupportedLocale } from '../../../lib/i18n';
import { destinationsApi } from '../../../lib/api/endpoints';
import { SearchIcon, LocationIcon } from '@repo/icons';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * Fetch destinations from API
 */
const result = await destinationsApi.list({ pageSize: 100 });
const destinations = result.ok ? (result.data.items as Array<Record<string, unknown>>) : [];

/**
 * Localized page titles
 */
const titles: Record<SupportedLocale, string> = {
	es: 'Destinos',
	en: 'Destinations',
	pt: 'Destinos',
};

/**
 * Localized meta descriptions
 */
const descriptions: Record<SupportedLocale, string> = {
	es: 'Descubre los destinos turísticos más fascinantes del Litoral argentino. Entre Ríos, Corrientes y Santa Fe te esperan.',
	en: 'Discover the most fascinating tourist destinations in the Argentine Litoral region. Entre Ríos, Corrientes and Santa Fe await you.',
	pt: 'Descubra os destinos turísticos mais fascinantes do Litoral argentino. Entre Ríos, Corrientes e Santa Fe esperam por você.',
};

/**
 * Localized home breadcrumb labels
 */
const homeLabels: Record<SupportedLocale, string> = {
	es: 'Inicio',
	en: 'Home',
	pt: 'Início',
};

/**
 * Localized hero heading
 */
const heroHeadings: Record<SupportedLocale, string> = {
	es: 'Explora los Destinos del Litoral',
	en: 'Explore Litoral Destinations',
	pt: 'Explore os Destinos do Litoral',
};

/**
 * Localized hero description
 */
const heroDescriptions: Record<SupportedLocale, string> = {
	es: 'Descubre ciudades históricas, paisajes naturales y experiencias únicas en la región del Litoral argentino. Desde las termas de Entre Ríos hasta los esteros de Corrientes.',
	en: 'Discover historic cities, natural landscapes and unique experiences in the Argentine Litoral region. From the hot springs of Entre Ríos to the wetlands of Corrientes.',
	pt: 'Descubra cidades históricas, paisagens naturais e experiências únicas na região do Litoral argentino. Das termas de Entre Ríos aos pântanos de Corrientes.',
};

/**
 * Localized search placeholder
 */
const searchPlaceholders: Record<SupportedLocale, string> = {
	es: 'Buscar destinos...',
	en: 'Search destinations...',
	pt: 'Pesquisar destinos...',
};

/**
 * Localized featured destinations section title
 */
const featuredTitles: Record<SupportedLocale, string> = {
	es: 'Destinos Destacados',
	en: 'Featured Destinations',
	pt: 'Destinos em Destaque',
};

/**
 * Localized empty state text
 */
const emptyStateTitles: Record<SupportedLocale, string> = {
	es: 'No hay destinos disponibles',
	en: 'No destinations available',
	pt: 'Nenhum destino disponível',
};

const emptyStateMessages: Record<SupportedLocale, string> = {
	es: 'Próximamente agregaremos destinos turísticos en esta sección.',
	en: 'We will soon add tourist destinations in this section.',
	pt: 'Em breve adicionaremos destinos turísticos nesta seção.',
};

/**
 * Localized regional highlight title
 */
const regionalTitles: Record<SupportedLocale, string> = {
	es: 'La Región del Litoral',
	en: 'The Litoral Region',
	pt: 'A Região do Litoral',
};

/**
 * Localized regional highlight text
 */
const regionalTexts: Record<SupportedLocale, string> = {
	es: 'El Litoral argentino comprende las provincias de Entre Ríos, Corrientes y Santa Fe. Esta región se caracteriza por su riqueza natural, con el río Paraná como eje vertebrador, sus termas naturales, su historia colonial y la calidez de su gente. Concepción del Uruguay, en Entre Ríos, es una de las ciudades históricas más importantes de la región.',
	en: 'The Argentine Litoral comprises the provinces of Entre Ríos, Corrientes and Santa Fe. This region is characterized by its natural richness, with the Paraná River as its backbone, its natural hot springs, its colonial history and the warmth of its people. Concepción del Uruguay, in Entre Ríos, is one of the most important historic cities in the region.',
	pt: 'O Litoral argentino compreende as províncias de Entre Ríos, Corrientes e Santa Fe. Esta região é caracterizada por sua riqueza natural, com o rio Paraná como eixo vertebral, suas termas naturais, sua história colonial e o calor de sua gente. Concepción del Uruguay, em Entre Ríos, é uma das cidades históricas mais importantes da região.',
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: homeLabels[locale], href: `/${locale}/` },
	{ label: titles[locale], href: `/${locale}/destinos/` },
];
---

<BaseLayout title={titles[locale]} description={descriptions[locale]} locale={locale}>
	<SEOHead
		slot="head"
		title={titles[locale]}
		description={descriptions[locale]}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- Hero Section -->
				<article id="hero" class="mb-12 text-center">
					<h1 class="mb-6 text-4xl font-bold text-text-primary md:text-5xl">
						{heroHeadings[locale]}
					</h1>
					<p class="mx-auto max-w-3xl text-xl leading-relaxed text-text-secondary">
						{heroDescriptions[locale]}
					</p>
				</article>

				<!-- Search/Filter Bar Placeholder -->
				<article id="search-bar" class="mb-12">
					<div class="mx-auto max-w-2xl">
						<div class="relative">
							<div class="absolute left-4 top-1/2 -translate-y-1/2">
								<SearchIcon size={20} className="text-text-tertiary" aria-hidden="true" />
							</div>
							<input
								type="search"
								placeholder={searchPlaceholders[locale]}
								class="w-full rounded-lg border border-border bg-bg py-3 pl-12 pr-4 text-text-primary placeholder-text-tertiary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
								aria-label={searchPlaceholders[locale]}
							/>
						</div>
					</div>
				</article>

				<!-- Featured Destinations Section -->
				<article id="featured-destinations" class="mb-16">
					<h2 class="mb-8 text-center text-3xl font-semibold text-text-primary">
						{featuredTitles[locale]}
					</h2>

					<!-- Grid Area for Destination Cards -->
					<div
						id="destination-grid"
						class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
						role="region"
						aria-label={featuredTitles[locale]}
					>
						{destinations.length > 0 ? (
							destinations.map((dest) => (
								<DestinationCard
									destination={{
										slug: String(dest.slug || ''),
										name: String(dest.name || 'Sin nombre'),
										summary: String(dest.summary || dest.description || ''),
										featuredImage: String(dest.featuredImage || dest.heroImage || '/images/placeholder-destination.svg'),
										accommodationsCount: Number(dest.accommodationsCount || 0),
										isFeatured: Boolean(dest.isFeatured),
										path: String(dest.path || dest.slug || ''),
									}}
									locale={locale}
								/>
							))
						) : (
							<div class="col-span-full">
								<EmptyState
									title={emptyStateTitles[locale]}
									message={emptyStateMessages[locale]}
								/>
							</div>
						)}
					</div>
				</article>

				<!-- Regional Highlight Section -->
				<article id="regional-highlight" class="mb-12">
					<div class="rounded-lg bg-bg p-8 shadow-sm">
						<h2 class="mb-4 text-center text-3xl font-semibold text-text-primary">
							{regionalTitles[locale]}
						</h2>
						<p class="mx-auto max-w-4xl text-lg leading-relaxed text-text-secondary">
							{regionalTexts[locale]}
						</p>
					</div>
				</article>

				<!-- Provinces Highlight -->
				<article id="provinces" class="mb-16">
					<div class="grid gap-8 md:grid-cols-3">
						<!-- Entre Ríos -->
						<div class="text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 mx-auto"
							>
								<LocationIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Entre Ríos</h3>
							<p class="text-text-secondary">
								Termas naturales, playas del río Uruguay y rica historia colonial.
							</p>
						</div>

						<!-- Corrientes -->
						<div class="text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 mx-auto"
							>
								<LocationIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Corrientes</h3>
							<p class="text-text-secondary">
								Esteros del Iberá, carnaval y tradiciones guaraníes.
							</p>
						</div>

						<!-- Santa Fe -->
						<div class="text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 mx-auto"
							>
								<LocationIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Santa Fe</h3>
							<p class="text-text-secondary">
								Cuna de la Constitución, ciudades coloniales y pesca deportiva.
							</p>
						</div>
					</div>
				</article>
			</div>
		</Section>
	</Container>
</BaseLayout>
