---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../../lib/page-helpers';

/**
 * Destination list page for the Hospeda web application.
 * Displays all destinations in the Litoral region with pagination.
 *
 * Rendering: SSG (pre-rendered at build time for all supported locales)
 * Route: /[lang]/destinos/
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import BackgroundPattern from '../../../components/shared/BackgroundPattern.astro';
import DecorativeElement from '../../../components/shared/DecorativeElement.astro';
import DestinationCard from '../../../components/shared/DestinationCard.astro';
import EmptyState from '../../../components/shared/EmptyState.astro';
import Pagination from '../../../components/shared/Pagination.astro';
import { LocationIcon } from '@repo/icons';
import { createT, type SupportedLocale } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { destinationsApi } from '../../../lib/api/endpoints';
import { toDestinationCardProps } from '../../../lib/api/transforms';
import type { DestinationCardData } from '../../../lib/api/transforms';

const locale = getLocaleFromParams(Astro.params) as SupportedLocale;
if (!locale) return Astro.redirect('/es/');

const t = createT(locale);

/** Pagination parameters (SSG pages always render page 1 at build time) */
const page = 1;
const pageSize = 12;

/** Fetch destinations from the public API */
const result = await destinationsApi.list({ page, pageSize });
const apiError = !result.ok;
const rawItems = result.ok ? result.data.items : [];
const pagination = result.ok ? result.data.pagination : null;

const destinations: readonly DestinationCardData[] = rawItems.map((item) =>
    toDestinationCardProps({ item: item as Record<string, unknown> })
);

/** Translations */
const pageTitle = t('destination.listing.title', 'Destinos turisticos en el Litoral argentino');
const pageDescription = t(
    'destination.listing.description',
    'Explora los destinos mas hermosos del Litoral argentino: Entre Rios, Corrientes y Santa Fe.'
);
const heroHeading = t('destination.listing.hero.heading', 'Descubri el Litoral argentino');
const heroDescription = t(
    'destination.listing.hero.description',
    'Playas de rio, termas naturales, historia colonial y el carnaval mas vibrante del pais.'
);
const featuredTitle = t('destination.listing.featured.title', 'Destinos destacados');
const emptyStateTitle = t('destination.listing.emptyState.title', 'No se encontraron destinos');
const emptyStateMessage = t(
    'destination.listing.emptyState.message',
    'Por el momento no hay destinos disponibles. Vuelve a intentarlo mas tarde.'
);
const regionalTitle = t('destination.listing.regional.title', 'El Litoral argentino te espera');
const regionalText = t(
    'destination.listing.regional.text',
    'Una region unica donde los rios, la naturaleza y la cultura se fusionan para crear experiencias inolvidables. Desde las playas del Uruguay hasta los esteros del Ibera, cada rincon guarda una historia por descubrir.'
);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/** Breadcrumb navigation items */
const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale, path: '' }) },
    { label: pageTitle, href: buildUrl({ locale, path: 'destinos' }) },
] as const;
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale}
        type="website"
    />

    <div class="container mx-auto max-w-6xl px-4 py-6">
        <Breadcrumb items={breadcrumbItems} />

        <!-- Hero Section -->
        <section aria-labelledby="destinations-hero-heading" class="relative mb-12 mt-4 overflow-hidden rounded-xl py-8 text-center">
            <BackgroundPattern pattern="/images/patterns/pattern-topo.svg" size="80px 80px" opacity="opacity-40" />
            <DecorativeElement src="/images/decoratives/deco-pin-location.svg" position="top-2 left-4 md:left-10" size="w-12 md:w-16" opacity="opacity-50" />
            <DecorativeElement src="/images/decoratives/deco-rio-uruguay.svg" position="top-0 right-0" size="w-24 md:w-36" opacity="opacity-30" hidden="" />
            <DecorativeElement src="/images/decoratives/deco-multi-pins.svg" position="bottom-2 right-4 md:right-10" size="w-16 md:w-20" opacity="opacity-40" />
            <div class="relative">
                <h1
                    id="destinations-hero-heading"
                    class="font-serif text-4xl font-bold text-foreground md:text-5xl lg:text-6xl"
                >
                    {heroHeading}
                </h1>
                <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-muted-foreground md:text-xl">
                    {heroDescription}
                </p>
            </div>
        </section>

        <!-- Destination Grid -->
        <section aria-labelledby="destinations-grid-heading" class="scroll-reveal mb-16">
            <h2
                id="destinations-grid-heading"
                class="mb-8 text-center text-2xl font-semibold text-foreground"
            >
                {featuredTitle}
            </h2>

            {destinations.length > 0 ? (
                <div
                    class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
                    role="list"
                    aria-label={featuredTitle}
                >
                    {destinations.map((card, index) => (
                        <div role="listitem">
                            <DestinationCard card={card} index={index} locale={locale} />
                        </div>
                    ))}
                </div>
            ) : apiError ? (
                <EmptyState
                    title={t('destination.error.title', 'Error al cargar destinos')}
                    message={t(
                        'destination.error.message',
                        'No pudimos cargar los destinos en este momento. Por favor, intenta de nuevo.'
                    )}
                    cta={{
                        label: t('destination.error.retry', 'Volver al inicio'),
                        href: buildUrl({ locale, path: '' }),
                    }}
                />
            ) : (
                <EmptyState title={emptyStateTitle} message={emptyStateMessage} />
            )}
        </section>

        <!-- Pagination -->
        {pagination && pagination.totalPages > 1 && (
            <div class="mb-12">
                <Pagination
                    currentPage={pagination.page}
                    totalPages={pagination.totalPages}
                    baseUrl={buildUrl({ locale, path: 'destinos' }).replace(/\/$/, '')}
                    locale={locale}
                />
            </div>
        )}

        <!-- Regional Highlight -->
        <section aria-labelledby="regional-heading" class="scroll-reveal mb-12">
            <div class="rounded-2xl bg-card p-8 shadow-sm border border-border">
                <h2
                    id="regional-heading"
                    class="mb-4 text-center text-2xl font-semibold text-foreground"
                >
                    {regionalTitle}
                </h2>
                <p class="mx-auto max-w-4xl text-center text-base leading-relaxed text-muted-foreground md:text-lg">
                    {regionalText}
                </p>
            </div>
        </section>

        <!-- Province Highlights -->
        <section
            aria-label={t('destination.listing.provinces.label', 'Provincias del Litoral')}
            class="scroll-reveal mb-16"
        >
            <div class="grid gap-8 md:grid-cols-3">
                <!-- Entre Rios -->
                <div class="text-center">
                    <div
                        class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
                    >
                        <LocationIcon size={32} className="text-primary" aria-hidden="true" />
                    </div>
                    <h3 class="mb-2 text-xl font-semibold text-foreground">Entre Rios</h3>
                    <p class="text-muted-foreground">
                        {t(
                            'destination.listing.provinces.entreRios',
                            'Termas naturales, playas del rio Uruguay y rica historia colonial.'
                        )}
                    </p>
                </div>

                <!-- Corrientes -->
                <div class="text-center">
                    <div
                        class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
                    >
                        <LocationIcon size={32} className="text-primary" aria-hidden="true" />
                    </div>
                    <h3 class="mb-2 text-xl font-semibold text-foreground">Corrientes</h3>
                    <p class="text-muted-foreground">
                        {t(
                            'destination.listing.provinces.corrientes',
                            'Esteros del Ibera, carnaval y tradiciones guaranies.'
                        )}
                    </p>
                </div>

                <!-- Santa Fe -->
                <div class="text-center">
                    <div
                        class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
                    >
                        <LocationIcon size={32} className="text-primary" aria-hidden="true" />
                    </div>
                    <h3 class="mb-2 text-xl font-semibold text-foreground">Santa Fe</h3>
                    <p class="text-muted-foreground">
                        {t(
                            'destination.listing.provinces.santaFe',
                            'Cuna de la Constitucion, ciudades coloniales y pesca deportiva.'
                        )}
                    </p>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>
