---
/**
 * @file destinos/[...path].astro
 * @description Destination detail page with hierarchical catch-all routing.
 * Handles paths like /destinos/entre-rios/ and /destinos/entre-rios/colon/.
 * @route /{lang}/destinos/{...path}/
 * @rendering SSR + ISR 24h
 */

import DetailLayout from '@/layouts/DetailLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import AccommodationCard from '@/components/shared/cards/AccommodationCard.astro';
import EventCardHorizontal from '@/components/shared/cards/EventCardHorizontal.astro';
import PlaceJsonLd from '@/components/seo/PlaceJsonLd.astro';
import BreadcrumbJsonLd from '@/components/seo/BreadcrumbJsonLd.astro';
import FAQPageJsonLd from '@/components/seo/FAQPageJsonLd.astro';
import { LocationMap } from '@/components/maps/LocationMap.client';
import DestinationDetailHeader from '@/components/destination/DestinationDetailHeader.astro';
import DestinationGallery from '@/components/destination/DestinationGallery.astro';
import DestinationMiniMap from '@/components/destination/DestinationMiniMap.astro';
import DestinationSidebarCtas from '@/components/destination/DestinationSidebarCtas.astro';
import DestinationStatsCard from '@/components/destination/DestinationStatsCard.astro';
import DestinationFaqAccordion from '@/components/destination/DestinationFaqAccordion.astro';
import DestinationClimateCard from '@/components/destination/DestinationClimateCard.astro';
import DestinationReviewsSection from '@/components/destination/DestinationReviewsSection.astro';
import DestinationRelatedPosts from '@/components/destination/DestinationRelatedPosts.astro';
import DestinationNearbySection from '@/components/destination/DestinationNearbySection.astro';
import {
	destinationsApi,
	accommodationsApi,
	eventsApi,
	postsApi,
	userBookmarksPublicApi
} from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { DestinationReviewSidebarCard } from '@/components/destination/DestinationReviewSidebarCard.client';
import DestinationReviewSignInCta from '@/components/destination/DestinationReviewSignInCta.astro';
import { getApiUrl } from '@/lib/env';
import {
	toAccommodationCardProps,
	toDestinationFaqs,
	toEventCardProps
} from '@/lib/api/transforms';
import ContributionBanner from '@/components/contributions/ContributionBanner.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { AlertTriangleIcon } from '@repo/icons';
import { renderContent } from '@/lib/render-content';
import { getDestinationSameAs } from '@/lib/destination-sameas';
import { Image } from 'astro:assets';

const locale = Astro.locals.locale as SupportedLocale;
const { t, tPlural } = createTranslations(locale);
const { path } = Astro.params;

if (!path) return new Response(null, { status: 404 });

// Single segment = slug lookup, multi-segment = hierarchical path lookup
const segments = path.split('/').filter(Boolean);
const result = segments.length === 1
	? await destinationsApi.getBySlug({ slug: segments[0] })
	: await destinationsApi.getByPath({ path: `/${path}` });

if (!result.ok) return new Response(null, { status: 404 });

const dest = result.data as Record<string, unknown>;
const name = String(dest.name || '');
const summary = String(dest.summary || '');
const description = String(dest.description || summary);
const slug = String(dest.slug || '');
const destId = String(dest.id || '');

type ClimateInputForPage = {
	readonly bestSeason?: string;
	readonly bestMonths?: string;
	readonly seasons?: Record<string, { avgTempMinC?: number; avgTempMaxC?: number; rainfallMm?: number } | undefined>;
	readonly note?: Record<string, string>;
};
const climate = (dest.climate ?? null) as ClimateInputForPage | null;

// --- Media (featuredImage + gallery) ----------------------------------------
// The API returns media as an object { featuredImage: { url, caption }, gallery: [...] }.
// We tolerate either shape (legacy string or new object) so the page never blows up.
interface MediaImage { readonly url: string; readonly caption?: string; readonly description?: string }
const mediaRaw = dest.media as
	| { featuredImage?: MediaImage; gallery?: ReadonlyArray<MediaImage> }
	| undefined;
const PLACEHOLDER = '/assets/images/placeholder-destination.svg';
const featuredImageObj: MediaImage =
	mediaRaw?.featuredImage && typeof mediaRaw.featuredImage === 'object'
		? mediaRaw.featuredImage
		: typeof dest.featuredImage === 'string' && dest.featuredImage
		  ? { url: dest.featuredImage, caption: name }
		  : { url: PLACEHOLDER, caption: name };
const galleryImages: ReadonlyArray<MediaImage> = mediaRaw?.gallery ?? [];

// --- Domain data passed to the new section components -----------------------
const attractions = (dest.attractions as ReadonlyArray<{
	readonly id: string;
	readonly name: string;
	readonly slug?: string;
	readonly description?: string;
	readonly icon?: string;
	readonly isFeatured?: boolean;
	readonly displayWeight?: number;
}>) ?? [];

const ratingBreakdown = dest.rating as Record<string, number | undefined> | null | undefined;

// --- FAQs (SPEC-158): normalize + build FAQPage JSON-LD sections -----------
const faqs = toDestinationFaqs(dest.faqs);
const faqSections = faqs.map((faq) => ({ heading: faq.question, body: faq.answer }));

// --- Previews (accommodations, events, posts) and counts --------------------
let accCards: ReturnType<typeof toAccommodationCardProps>[] = [];
let eventCards: ReturnType<typeof toEventCardProps>[] = [];
let relatedPosts: ReadonlyArray<unknown> = [];
let nearbyDestinations: ReadonlyArray<unknown> = [];
let accCount = 0;
let eventsCount = 0;
let stats: {
	accommodationsCount: number;
	reviewsCount: number;
	averageRating: number;
	attractionsCount: number;
	eventsCount: number;
} = {
	accommodationsCount: 0,
	reviewsCount: 0,
	averageRating: 0,
	attractionsCount: 0,
	eventsCount: 0
};

const parentDestinationId =
	typeof dest.parentDestinationId === 'string' && dest.parentDestinationId
		? dest.parentDestinationId
		: null;

/**
 * Defensive extraction for paginated / wrapped API results.
 *
 * The public API isn't fully consistent on its list-response shape: some
 * endpoints return `{ items: [...] }`, some `{ data: [...] }`, the
 * accommodations-by-destination endpoint returns `{ accommodations: [...] }`
 * (AccommodationListWrapperSchema), and getChildren returns `{ children: [...] }`.
 * Some routes return a bare array. We probe the well-known wrapper keys
 * before giving up — keeps the page resilient to future schema renames.
 */
function extractItems(settled: PromiseSettledResult<unknown>): Record<string, unknown>[] {
	if (settled.status === 'rejected') return [];
	const val = settled.value as { ok?: boolean; data?: unknown };
	if (!val?.ok) return [];
	const d = val.data;
	if (Array.isArray(d)) return d as Record<string, unknown>[];
	if (d && typeof d === 'object') {
		const obj = d as Record<string, unknown>;
		const wrapperKeys = ['items', 'data', 'accommodations', 'children', 'posts', 'events'];
		for (const key of wrapperKeys) {
			if (Array.isArray(obj[key])) return obj[key] as Record<string, unknown>[];
		}
	}
	return [];
}

/**
 * Extract a "total count" from a settled list result.
 *
 * Some endpoints (events) ship pagination.total. Others wrap their array
 * under a custom key (accommodations) without pagination metadata. We prefer
 * pagination.total, then fall back to the length of whichever known wrapper
 * array we can find — better an honest local count than a silent zero.
 */
function extractTotal(settled: PromiseSettledResult<unknown>): number {
	if (settled.status === 'rejected') return 0;
	const val = settled.value as { ok?: boolean; data?: unknown };
	if (!val?.ok) return 0;
	const d = val.data as Record<string, unknown> | undefined;
	const total = (d?.pagination as { total?: number } | undefined)?.total;
	if (typeof total === 'number') return total;
	if (!d) return 0;
	for (const key of ['items', 'data', 'accommodations', 'children', 'posts', 'events']) {
		const arr = d[key];
		if (Array.isArray(arr)) return arr.length;
	}
	return 0;
}

try {
	const [
		accResult,
		eventsResult,
		eventsCountResult,
		statsResult,
		postsResult,
		siblingsResult
	] = await Promise.allSettled([
		// NOTE: getByDestination returns ALL accommodations for the destination in a
		// single non-paginated payload — pageSize is not accepted. One call serves both
		// the preview cards (sliced below) and the total count (array length).
		accommodationsApi.getByDestination({ destinationId: destId }),
		eventsApi.list({ pageSize: 3, destinationId: destId }),
		eventsApi.list({ pageSize: 1, destinationId: destId }),
		destinationsApi.getStats({ id: destId }),
		postsApi.getByRelatedDestination({ destinationId: destId }),
		parentDestinationId
			? destinationsApi.getChildren({ id: parentDestinationId })
			: Promise.resolve({ ok: false } as const)
	]);

	accCards = extractItems(accResult)
		.slice(0, 3)
		.map((item) => toAccommodationCardProps({ item, locale }));
	accCount = extractTotal(accResult);

	eventCards = extractItems(eventsResult)
		.slice(0, 3)
		.map((item) => toEventCardProps({ item, locale }));
	eventsCount = extractTotal(eventsCountResult);

	if (statsResult.status === 'fulfilled' && statsResult.value.ok) {
		stats = {
			accommodationsCount: statsResult.value.data.accommodationsCount,
			reviewsCount: statsResult.value.data.reviewsCount,
			averageRating: statsResult.value.data.averageRating,
			attractionsCount: statsResult.value.data.attractionsCount,
			eventsCount: statsResult.value.data.eventsCount
		};
	} else {
		// Fall back to the locally derived counts so the sidebar still has something useful
		stats = {
			accommodationsCount: accCount,
			reviewsCount: 0,
			averageRating: 0,
			attractionsCount: attractions.length,
			eventsCount
		};
	}

	// Ensure stats always reflect what we actually loaded — when the dedicated
	// stats endpoint returns 0 but our preview lists found items locally, prefer
	// the local count over the missing aggregate. This keeps the sidebar honest.
	stats = {
		...stats,
		accommodationsCount: Math.max(stats.accommodationsCount, accCount, accCards.length),
		eventsCount: Math.max(stats.eventsCount, eventsCount, eventCards.length),
		attractionsCount: Math.max(stats.attractionsCount, attractions.length)
	};

	relatedPosts = extractItems(postsResult).slice(0, 4);

	if (siblingsResult.status === 'fulfilled' && siblingsResult.value.ok) {
		const siblings = (siblingsResult.value.data.children ?? []) as ReadonlyArray<{
			id?: string;
		}>;
		// Drop the current destination from the siblings list and cap at 8 so
		// the carousel stays focused. The component will further cap visible cards.
		nearbyDestinations = siblings.filter((d) => d.id !== destId).slice(0, 8);
	}
} catch (err) {
	console.error('[destinos/detail] Error fetching previews:', err);
}

// --- Auth -------------------------------------------------------------------
const userId = Astro.locals.user?.id ?? null;
const isAuthenticated = userId !== null;

// --- Bookmark count + favorite status (graceful degradation) ----------------
let bookmarkCount: number | undefined;
let initialIsFavorited: boolean | undefined;
let initialBookmarkId: string | null = null;

try {
	const countResult = await userBookmarksPublicApi.count({
		entityType: 'DESTINATION',
		entityId: destId
	});
	if (countResult.ok) {
		bookmarkCount = countResult.data.count;
	}
} catch {
	// Graceful degradation: counter not shown if fetch fails
}

if (isAuthenticated) {
	try {
		const statusResult = await userBookmarksApi.checkStatus({
			entityId: destId,
			entityType: 'DESTINATION'
		});
		if (statusResult.ok) {
			initialIsFavorited = statusResult.data.isFavorited;
			initialBookmarkId = statusResult.data.bookmarkId;
		}
	} catch {
		// Graceful degradation: FavoriteButton hydrates itself on mount
	}
}

// --- Breadcrumbs ------------------------------------------------------------
const pathSegments = path.split('/').filter(Boolean);
const breadcrumbItems = [
	{ label: t('destinations.title', 'Destinos'), path: 'destinos' },
	...pathSegments.map((segment, i) => ({
		label: segment.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
		...(i < pathSegments.length - 1
			? { path: `destinos/${pathSegments.slice(0, i + 1).join('/')}` }
			: {})
	}))
];

// --- TouristDestination JSON-LD --------------------------------------------
const destLocation = dest.location as
	| { coordinates?: { lat?: string; long?: string } }
	| undefined;
const destCoords = destLocation?.coordinates;
const destLat = destCoords?.lat ? Number.parseFloat(destCoords.lat) : null;
const destLng = destCoords?.long ? Number.parseFloat(destCoords.long) : null;
const hasDestCoords = Number.isFinite(destLat) && Number.isFinite(destLng);

const placeGeo =
	hasDestCoords && destLat !== null && destLng !== null
		? { latitude: destLat, longitude: destLng }
		: undefined;

const placeUrl = `${Astro.site ?? Astro.url.origin}${Astro.url.pathname}`;
const placeImage =
	featuredImageObj.url && !featuredImageObj.url.includes('placeholder')
		? featuredImageObj.url
		: undefined;

// Entity disambiguation (schema.org sameAs): interim curated slug→Wikipedia
// map. Resolves only for the main Entre Ríos destinations; undefined otherwise.
const placeSameAs = getDestinationSameAs({ slug });

// --- Breadcrumb JSON-LD (REQ-096-37 / T-068) -------------------------------
const siteOriginDest = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const breadcrumbJsonLdItems = [
	{ name: t('nav.home', 'Inicio'), url: `${siteOriginDest}/${locale}/` },
	{ name: t('destinations.title', 'Destinos'), url: `${siteOriginDest}/${locale}/destinos/` },
	...pathSegments.map((segment, i) => ({
		name: segment.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
		url: `${siteOriginDest}/${locale}/destinos/${pathSegments.slice(0, i + 1).join('/')}/`
	}))
];

// Description rendering — `dest.contentHtml` (TipTap-rendered HTML, when
// present) takes precedence; otherwise `description` may be markdown or plain
// text. `renderContent` normalizes all three into safe HTML for `set:html`.
// (Previously the `contentHtml` branch piped raw HTML directly into `set:html`
// without sanitization — pre-existing XSS hole, fixed here.)
const rawDescription = typeof dest.contentHtml === 'string' && dest.contentHtml.length > 0
	? dest.contentHtml
	: description;
const safeDescriptionHtml = renderContent({
	raw: rawDescription,
	siteOrigin: Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin
});
---

<DetailLayout
	locale={locale}
	title={name}
	description={summary || description}
	ogImage={placeImage}
	ogType="Destino"
	ogSubtitle={t('destinations.region', 'Entre Ríos, Argentina')}
	ogRating={stats.averageRating > 0 ? stats.averageRating.toFixed(1) : undefined}
	showBreadcrumbs={true}
	showSidebar={true}
>
	<PlaceJsonLd
		slot="head-extra"
		name={name}
		description={summary || description}
		url={placeUrl}
		image={placeImage}
		geo={placeGeo}
		sameAs={placeSameAs}
	/>
	<BreadcrumbJsonLd slot="head-extra" items={breadcrumbJsonLdItems} />
	{faqSections.length > 0 && (
		<FAQPageJsonLd slot="head-extra" sections={faqSections} inLanguage={locale} />
	)}

	<Breadcrumbs slot="breadcrumbs" locale={locale} items={breadcrumbItems} />

	<Fragment slot="page-header">
		<DestinationDetailHeader
			destinationId={destId}
			name={name}
			locale={locale}
			isAuthenticated={isAuthenticated}
			initialIsFavorited={initialIsFavorited}
			initialBookmarkId={initialBookmarkId}
			bookmarkCount={bookmarkCount}
			attractions={attractions}
		/>
	</Fragment>

	<div class="dest-detail">
		<!-- Hero -->
		<div class="dest-detail__hero">
			{featuredImageObj.url && !featuredImageObj.url.includes('placeholder') ? (
				<Image
					src={featuredImageObj.url}
					alt={featuredImageObj.caption ?? name}
					width={1200}
					height={675}
					format="webp"
					loading="eager"
					class="dest-detail__hero-img"
				/>
			) : (
				<img
					src={featuredImageObj.url}
					alt={featuredImageObj.caption ?? name}
					loading="eager"
					class="dest-detail__hero-img"
					width="1200"
					height="675"
				/>
			)}
		</div>

		<!-- Description (markdown / HTML / plain text → sanitized HTML) -->
		{safeDescriptionHtml && (
			<div class="dest-detail__section dest-detail__description">
				<div set:html={safeDescriptionHtml} />
			</div>
		)}

		<!-- Report incorrect info (SPEC-191 FR-7): inline link after the
		     description, deep-linking the report form with this destination. -->
		<p class="dest-detail__report-link">
			<AlertTriangleIcon size={16} weight="fill" aria-hidden="true" />
			<a href={`${buildUrl({ locale, path: 'colaborar/reportar' })}?destino=${encodeURIComponent(slug)}`}>
				{t('contributions.reportLink.inline', '¿Viste información incorrecta o desactualizada? Reportala')}
			</a>
		</p>

		<!-- Photo gallery (extras beyond the hero) -->
		{galleryImages.length > 0 && (
			<div class="dest-detail__section">
				<DestinationGallery
					featuredImage={featuredImageObj}
					gallery={galleryImages}
					destinationName={name}
					locale={locale}
				/>
			</div>
		)}

		<!-- Photo-contribution banner (SPEC-191 FR-8): after the gallery —
		     the visitor just saw this destination's photos (or their absence). -->
		<div class="dest-detail__section">
			<ContributionBanner
				title={t('contributions.banner.photos.title', '¿Tenés fotos de este destino?')}
				description={t(
					'contributions.banner.photos.description',
					'Compartilas con la comunidad y ayudá a mostrarlo como se merece.'
				)}
				ctaLabel={t('contributions.banner.photos.cta', 'Aportar fotos')}
				ctaHref={buildUrl({ locale, path: 'colaborar/fotos' })}
				source="destination_detail"
				variant="photos"
			/>
		</div>

		<!-- Reviews + per-dimension rating (combined) -->
		<div class="dest-detail__section">
			<DestinationReviewsSection
				destinationId={destId}
				averageRating={stats.averageRating}
				reviewsCount={stats.reviewsCount}
				ratingBreakdown={ratingBreakdown}
				locale={locale}
			>
				<Fragment slot="actions">
					{isAuthenticated ? (
						<DestinationReviewSidebarCard
							client:idle
							variant="inline"
							destinationId={destId}
							destinationName={name}
							locale={locale}
							apiUrl={getApiUrl()}
						/>
					) : (
						<DestinationReviewSignInCta
							variant="inline"
							locale={locale}
							returnPath={`destinos/${path}`}
						/>
					)}
				</Fragment>
			</DestinationReviewsSection>
		</div>

		<!-- FAQs (SPEC-158): rendered only when the destination has FAQs -->
		{faqs.length > 0 && (
			<div class="dest-detail__section">
				<DestinationFaqAccordion faqs={faqs} lang={locale} />
			</div>
		)}

		<!-- Accommodation preview -->
		<section class="dest-detail__section">
			<div class="dest-detail__section-header">
				<h2 class="dest-detail__section-title">
					{t('destination.detailPage.accommodationsIn', 'Alojamientos en')} {name}
				</h2>
				{accCards.length > 0 && (
					<a
						href={buildUrl({ locale, path: `destinos/${slug}/alojamientos` })}
						class="dest-detail__view-all"
					>
						{t('destination.detailPage.viewAll', 'Ver todos')} →
					</a>
				)}
			</div>
			{accCards.length > 0 ? (
				<div class="dest-detail__preview-grid">
					{accCards.map((card, i) => (
						<div data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
							<AccommodationCard data={card} locale={locale} />
						</div>
					))}
				</div>
			) : (
				<div class="dest-detail__empty-state">
					<p class="dest-detail__empty-title">
						{t('destination.detailPage.noAccommodations', 'No hay alojamientos disponibles')}
					</p>
					<p class="dest-detail__empty-message">
						{t(
							'destination.detailPage.noAccommodationsMessage',
							'Próximamente agregaremos alojamientos en este destino.'
						)}
					</p>
				</div>
			)}
		</section>

		<!-- Events preview -->
		<section class="dest-detail__section">
			<div class="dest-detail__section-header">
				<h2 class="dest-detail__section-title">
					{t('destination.detailPage.eventsIn', 'Eventos en')} {name}
				</h2>
				{eventCards.length > 0 && (
					<a
						href={buildUrl({ locale, path: `destinos/${slug}/eventos` })}
						class="dest-detail__view-all"
					>
						{t('destination.detailPage.viewAll', 'Ver todos')} →
					</a>
				)}
			</div>
			{eventCards.length > 0 ? (
				<div class="dest-detail__preview-grid">
					{eventCards.map((card, i) => (
						<div data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
							<EventCardHorizontal data={card} locale={locale} isAuthenticated={isAuthenticated} />
						</div>
					))}
				</div>
			) : (
				<div class="dest-detail__empty-state">
					<p class="dest-detail__empty-title">
						{t('destination.detailPage.noEvents', 'No hay eventos próximos')}
					</p>
					<p class="dest-detail__empty-message">
						{t(
							'destination.detailPage.noEventsMessage',
							'No hay eventos programados para este destino en este momento.'
						)}
					</p>
				</div>
			)}
		</section>

		<!-- Related posts (filtered by destinationId on the server) -->
		<section class="dest-detail__section">
			{relatedPosts.length > 0 ? (
				<DestinationRelatedPosts
					posts={relatedPosts}
					destinationName={name}
					locale={locale}
				/>
			) : (
				<>
					<h2 class="dest-detail__section-title">
						{t('destination.detail.relatedPosts.title', 'Sobre {{name}}', { name })}
					</h2>
					<div class="dest-detail__empty-state">
						<p class="dest-detail__empty-title">
							{t('destination.detail.relatedPosts.empty', 'Todavía no hay notas sobre este destino')}
						</p>
						<p class="dest-detail__empty-message">
							{t(
								'destination.detail.relatedPosts.emptyMessage',
								'Estamos preparando contenido para que conozcas más sobre este destino.'
							)}
						</p>
					</div>
				</>
			)}
		</section>

		<!-- Other destinations in the area (siblings of the same parent) -->
		{nearbyDestinations.length > 0 && (
			<section class="dest-detail__section">
				<DestinationNearbySection
					destinations={nearbyDestinations}
					locale={locale}
					isAuthenticated={isAuthenticated}
				/>
			</section>
		)}
	</div>

	<!-- Sidebar: stats + mini-map + climate + quick CTAs.
	     The DetailLayout already makes the <aside> sticky on desktop. -->
	<div slot="sidebar" class="dest-sidebar">
		<DestinationStatsCard stats={stats} locale={locale} />

		{hasDestCoords && (
			<DestinationMiniMap
				lat={destLat as number}
				lng={destLng as number}
				name={name}
				locale={locale}
			/>
		)}

		<DestinationClimateCard locale={locale} destinationId={destId} apiUrl={getApiUrl()} climate={climate} />

		<DestinationSidebarCtas
			slug={slug}
			accommodationsCount={stats.accommodationsCount}
			eventsCount={stats.eventsCount}
			locale={locale}
		/>

		{isAuthenticated ? (
			/* client:idle (NOT client:visible): the sticky sidebar is taller than
			   the viewport, so this last card only intersects at full page scroll —
			   with client:visible the CTA renders as a dead SSR button until then. */
			<DestinationReviewSidebarCard
				client:idle
				destinationId={destId}
				destinationName={name}
				locale={locale}
				apiUrl={getApiUrl()}
			/>
		) : (
			<DestinationReviewSignInCta
				locale={locale}
				returnPath={`destinos/${path}`}
			/>
		)}
	</div>
</DetailLayout>

