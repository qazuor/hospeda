---
export const prerender = true;

/**
 * Destination Detail Page
 *
 * Displays comprehensive information about a destination including:
 * - Hero image with destination name and province
 * - Description, climate information, how to get there
 * - Image gallery with lightbox
 * - List of attractions and things to do
 * - Accommodations in this destination
 * - Events happening in this destination
 * - Location map
 * - Share and favorite buttons
 *
 * Rendering: SSG + ISR (24h revalidation)
 * Route: /[lang]/destinos/[...path]
 *
 * Uses catch-all path parameter to support hierarchical paths like:
 * - /es/destinos/entre-rios/colon/
 * - /es/destinos/concepcion-del-uruguay/
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import Badge from '../../../components/ui/Badge.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import AccommodationCard from '../../../components/accommodation/AccommodationCard.astro';
import EventCard from '../../../components/event/EventCard.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import { ImageGallery } from '../../../components/ui/ImageGallery.client.tsx';
import { ShareButtons } from '../../../components/ui/ShareButtons.client.tsx';
import { FavoriteButton } from '../../../components/ui/FavoriteButton.client.tsx';
import { MapView } from '../../../components/map/MapView.client.tsx';
import { isValidLocale, type SupportedLocale } from '../../../lib/i18n';
import { renderTiptapContent } from '../../../lib/tiptap-renderer';
import { destinationsApi, accommodationsApi, eventsApi } from '../../../lib/api/endpoints';
import { fetchAllPages } from '../../../lib/api/client';
import { extractFeaturedImageUrl, extractGalleryUrls } from '../../../lib/media';

/**
 * Generate static paths for all destinations in all locales
 */
export async function getStaticPaths() {
	const locales = ['es', 'en', 'pt'];
	const destinations = await fetchAllPages<Record<string, unknown>>({
		fetcher: (p) => destinationsApi.list(p),
	});

	return locales.flatMap((lang) =>
		destinations
			.filter((d) => d.path || d.slug)
			.map((d) => ({
				params: { lang, path: String(d.path || d.slug).replace(/^\//, '') },
				props: { destinationData: d },
			}))
	);
}

const { lang, path } = Astro.params;
const { destinationData } = Astro.props;

// Validate locale and redirect to default if invalid
if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * Fetch destination data from API
 * Using the path parameter or fallback to destinationData from getStaticPaths
 */
let destination: Record<string, unknown> = destinationData || {};

// If we have a path param, fetch fresh data (for ISR)
if (path) {
	const pathStr = Array.isArray(path) ? path.join('/') : String(path);
	const destResult = await destinationsApi.getByPath({ path: pathStr });

	if (!destResult.ok) {
		// Fallback to destinationData or redirect to destinations list
		if (!destinationData) {
			return Astro.redirect(`/${locale}/destinos/`);
		}
	} else {
		destination = destResult.data as Record<string, unknown>;
	}
}

/**
 * Extract destination name early - needed for event city filtering below
 */
const destinationName = String(destination.name || 'Sin nombre');

/**
 * Fetch related data: accommodations and events
 */
const destinationId = String(destination.id || '');
let accommodations: Array<Record<string, unknown>> = [];
let events: Array<Record<string, unknown>> = [];

if (destinationId) {
	// Fetch accommodations for this destination
	const accResult = await destinationsApi.getAccommodations({
		id: destinationId,
		pageSize: 6,
	});
	if (accResult.ok) {
		const accData = accResult.data as unknown as Record<string, unknown>;
		const rawAccommodations = (accData.accommodations ?? accData.items ?? []) as Array<Record<string, unknown>>;
		accommodations = rawAccommodations.map((a) => ({
			...a,
			slug: String(a.slug || ''),
			name: String(a.name || ''),
			summary: String(a.summary || a.description || ''),
			type: String(a.type || a.accommodationType || ''),
			featuredImage: extractFeaturedImageUrl(a, '/images/placeholder-accommodation.svg'),
			averageRating: Number(a.averageRating || 0),
			reviewsCount: Number(a.reviewsCount || 0),
			location: (a.location as { city: string; state: string }) || { city: '', state: '' },
			isFeatured: Boolean(a.isFeatured),
		}));
	}

	// Fetch events filtered by destination city name.
	// The events API does not support destinationId filtering, so we fetch a larger
	// batch and filter client-side by matching the event location city.
	const evtResult = await eventsApi.list({ pageSize: 100 });
	if (evtResult.ok) {
		const allMapped = evtResult.data.items.map((e) => {
			const evt = e as Record<string, unknown>;
			const evtDate = evt.date as { start?: string; end?: string } | undefined;
			const evtLocation = evt.location as Record<string, unknown> | undefined;
			return {
				...evt,
				slug: String(evt.slug || ''),
				name: String(evt.name || ''),
				summary: String(evt.summary || evt.description || ''),
				featuredImage: extractFeaturedImageUrl(evt, '/images/placeholder-event.svg'),
				category: String(evt.category || ''),
				date: {
					start: String(evtDate?.start || evt.startDate || ''),
					end: evtDate?.end ? String(evtDate.end) : (evt.endDate ? String(evt.endDate) : undefined),
				},
				isFeatured: Boolean(evt.isFeatured),
				location: evtLocation ? { name: String(evtLocation.placeName || evtLocation.name || ''), city: String(evtLocation.city || '') } : undefined,
			};
		});
		// Filter events whose location city matches the destination name
		events = allMapped.filter((e) => {
			const evtCity = (e.location as { city?: string } | undefined)?.city;
			return evtCity && evtCity.toLowerCase() === destinationName.toLowerCase();
		});
	}
}

// Fetch breadcrumb hierarchy
let hierarchyBreadcrumb: readonly {
	id: string;
	slug: string;
	name: string;
	level: number;
	destinationType: string;
	path: string;
}[] = [];
if (destinationId) {
	const bcResult = await destinationsApi.getBreadcrumb({ id: destinationId });
	if (bcResult.ok && bcResult.data.breadcrumb) {
		hierarchyBreadcrumb = [...bcResult.data.breadcrumb];
	}
}

/**
 * Render TipTap content to HTML
 */
const descriptionContent = destination.description || destination.summary || { type: 'doc', content: [] };
const howToGetThereContent = destination.howToGetThere || { type: 'doc', content: [] };

const renderedDescription = renderTiptapContent({ content: descriptionContent });
const renderedHowToGetThere = renderTiptapContent({ content: howToGetThereContent });

const texts = {
  es: { home: 'Inicio', destinations: 'Destinos', description: 'Descripción', gallery: 'Galería', climate: 'Clima', howToGetThere: 'Cómo llegar', attractions: 'Qué hacer', accommodationsTitle: 'Alojamientos', eventsTitle: 'Eventos', viewAll: 'Ver todos', map: 'Mapa', summer: 'Verano', winter: 'Invierno', bestSeason: 'Mejor época', rainfall: 'Lluvias', noAccommodations: 'No hay alojamientos disponibles', noAccommodationsMessage: 'Próximamente agregaremos alojamientos en este destino.', noEvents: 'No hay eventos próximos', noEventsMessage: 'No hay eventos programados para este destino en este momento.', accommodationsIn: 'Alojamientos en', eventsIn: 'Eventos en' },
  en: { home: 'Home', destinations: 'Destinations', description: 'Description', gallery: 'Gallery', climate: 'Climate', howToGetThere: 'How to get there', attractions: 'Things to do', accommodationsTitle: 'Accommodations', eventsTitle: 'Events', viewAll: 'View all', map: 'Map', summer: 'Summer', winter: 'Winter', bestSeason: 'Best season', rainfall: 'Rainfall', noAccommodations: 'No accommodations available', noAccommodationsMessage: 'We will soon add accommodations in this destination.', noEvents: 'No upcoming events', noEventsMessage: 'There are no events scheduled for this destination at this time.', accommodationsIn: 'Accommodations in', eventsIn: 'Events in' },
  pt: { home: 'Início', destinations: 'Destinos', description: 'Descrição', gallery: 'Galeria', climate: 'Clima', howToGetThere: 'Como chegar', attractions: 'O que fazer', accommodationsTitle: 'Acomodações', eventsTitle: 'Eventos', viewAll: 'Ver todos', map: 'Mapa', summer: 'Verão', winter: 'Inverno', bestSeason: 'Melhor época', rainfall: 'Chuvas', noAccommodations: 'Nenhuma acomodação disponível', noAccommodationsMessage: 'Em breve adicionaremos acomodações neste destino.', noEvents: 'Nenhum evento próximo', noEventsMessage: 'Não há eventos programados para este destino no momento.', accommodationsIn: 'Acomodações em', eventsIn: 'Eventos em' },
} as const;

const t = texts[locale];

/**
 * Extract data from destination with fallbacks
 */
const destinationSlug = String(destination.slug || destination.path || '');
const destinationHeroImage = extractFeaturedImageUrl(destination, '/images/placeholder-destination.svg');
const destinationProvince = String(destination.province || destination.state || '');
const destinationCountry = String(destination.country || 'Argentina');
const destinationLocation = (destination.location as { lat?: number; lng?: number }) || {};
const destinationClimate = (destination.climate as Record<string, string>) || {};
const destinationAttractions = (destination.attractions as Array<{ name: string; description: string }>) || [];
const galleryUrls = extractGalleryUrls(destination);
const destinationImages = galleryUrls.length > 0
	? galleryUrls.map((url) => ({ src: url, alt: destinationName }))
	: [{ src: destinationHeroImage, alt: destinationName }];
// Use DB totals for sidebar counts; fetched arrays are just the preview subset
const accommodationCount = Number(destination.accommodationsCount || destination.accommodationCount || accommodations.length);
const eventCount = events.length;
// Limit preview cards shown on page; full list available via "View all" link
const PREVIEW_LIMIT = 3;
const previewAccommodations = accommodations.slice(0, PREVIEW_LIMIT);
const previewEvents = events.slice(0, PREVIEW_LIMIT);
const accommodationsListUrl = `/${locale}/alojamientos/?city=${encodeURIComponent(destinationName)}`;
const eventsListUrl = `/${locale}/eventos/?city=${encodeURIComponent(destinationName)}`;

// Breadcrumb navigation items (includes full hierarchy: Home > Destinations > Parent... > Current)
const breadcrumbItems = [
	{ label: t.home, href: `/${locale}/` },
	{ label: t.destinations, href: `/${locale}/destinos/` },
	...hierarchyBreadcrumb
		.filter((item) => item.id !== destinationId)
		.map((item) => ({
			label: item.name,
			href: `/${locale}/destinos/${item.path}/`,
		})),
	{ label: destinationName },
];

// Authentication state for interactive components
const isAuthenticated = !!Astro.locals.user;

// Page URL for sharing and canonical
const pageUrl = `/${locale}/destinos/${destinationSlug}/`;

// Map markers for destination location
const mapMarkers = destinationLocation.lat && destinationLocation.lng
	? [
			{
				id: destinationId,
				lat: destinationLocation.lat,
				lng: destinationLocation.lng,
				title: destinationName,
				popup: `${destinationName}, ${destinationProvince}`
			}
	  ]
	: [];
---

<BaseLayout
  title={destinationName}
  description={`${destinationName} - ${destinationProvince}, ${destinationCountry}`}
  locale={locale}
  image={destinationHeroImage}
>
  <SEOHead
    slot="head"
    title={destinationName}
    description={`Descubre ${destinationName} en ${destinationProvince}. Guía completa con alojamientos, eventos, atracciones y cómo llegar.`}
    image={destinationHeroImage}
    locale={locale}
  />

  <Container>
    <Breadcrumb items={breadcrumbItems} class="py-4" />

    <!-- Hero section -->
    <div class="relative mb-8 overflow-hidden rounded-lg aspect-[21/9]">
      <img
        src={destinationHeroImage}
        alt={destinationName}
        class="h-full w-full object-cover"
        transition:name={`entity-${destinationSlug}`}
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
        <Badge variant="primary" label={destinationProvince} class="mb-3" />
        <h1 class="text-3xl md:text-5xl font-bold text-white">{destinationName}</h1>
      </div>
    </div>

    <!-- Action buttons -->
    <div class="flex items-center justify-end gap-2 mb-8">
      <FavoriteButton
        client:visible
        entityId={destinationId}
        entityType="destination"
        isAuthenticated={isAuthenticated}
      />
      <ShareButtons
        client:visible
        url={pageUrl}
        title={destinationName}
      />
    </div>

    <!-- Main content grid -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      <!-- Left column (2/3) -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Description -->
        <section>
          <h2 class="mb-4 text-2xl font-bold">{t.description}</h2>
          <div class="prose max-w-none text-text-secondary" set:html={renderedDescription} />
        </section>

        <!-- Image Gallery -->
        {destinationImages.length > 0 && (
          <section>
            <h2 class="mb-4 text-2xl font-bold">{t.gallery}</h2>
            <ImageGallery client:visible images={destinationImages} />
          </section>
        )}

        <!-- Climate -->
        {(destinationClimate.summer || destinationClimate.winter || destinationClimate.bestSeason || destinationClimate.rainfall) && (
          <section>
            <h2 class="mb-4 text-2xl font-bold">{t.climate}</h2>
            <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
              {destinationClimate.summer && (
                <div class="rounded-lg border border-border bg-surface p-4">
                  <div class="text-sm text-text-tertiary">{t.summer}</div>
                  <div class="mt-1 font-semibold text-text">{destinationClimate.summer}</div>
                </div>
              )}
              {destinationClimate.winter && (
                <div class="rounded-lg border border-border bg-surface p-4">
                  <div class="text-sm text-text-tertiary">{t.winter}</div>
                  <div class="mt-1 font-semibold text-text">{destinationClimate.winter}</div>
                </div>
              )}
              {destinationClimate.bestSeason && (
                <div class="rounded-lg border border-border bg-surface p-4">
                  <div class="text-sm text-text-tertiary">{t.bestSeason}</div>
                  <div class="mt-1 font-semibold text-text">{destinationClimate.bestSeason}</div>
                </div>
              )}
              {destinationClimate.rainfall && (
                <div class="rounded-lg border border-border bg-surface p-4">
                  <div class="text-sm text-text-tertiary">{t.rainfall}</div>
                  <div class="mt-1 font-semibold text-text">{destinationClimate.rainfall}</div>
                </div>
              )}
            </div>
          </section>
        )}

        <!-- How to get there -->
        {renderedHowToGetThere && renderedHowToGetThere.trim() !== '' && (
          <section>
            <h2 class="mb-4 text-2xl font-bold">{t.howToGetThere}</h2>
            <div class="prose max-w-none text-text-secondary" set:html={renderedHowToGetThere} />
          </section>
        )}

        <!-- Attractions -->
        {destinationAttractions.length > 0 && (
          <section>
            <h2 class="mb-4 text-2xl font-bold">{t.attractions}</h2>
            <ul class="space-y-3">
              {destinationAttractions.map((attraction) => (
                <li class="rounded-lg border border-border bg-surface p-4">
                  <h3 class="font-semibold text-text">{attraction.name}</h3>
                  <p class="mt-1 text-sm text-text-secondary">{attraction.description}</p>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- Map -->
        {mapMarkers.length > 0 && destinationLocation.lat && destinationLocation.lng && (
          <section>
            <h2 class="mb-4 text-2xl font-bold">{t.map}</h2>
            <MapView
              client:visible
              markers={mapMarkers}
              center={[destinationLocation.lat, destinationLocation.lng]}
              zoom={13}
              height="400px"
            />
          </section>
        )}
      </div>

      <!-- Right sidebar (1/3) -->
      <aside class="lg:sticky lg:top-4 lg:self-start space-y-6">
        <!-- Accommodations count card -->
        <div class="rounded-lg border border-border bg-surface p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-text">{t.accommodationsTitle}</h3>
          <p class="mt-2 text-3xl font-bold text-primary">{accommodationCount}</p>
          <p class="mt-1 text-sm text-text-tertiary">
            {accommodationCount === 1 ? 'alojamiento disponible' : 'alojamientos disponibles'}
          </p>
          <a
            href={accommodationsListUrl}
            class="mt-4 block text-center rounded-md bg-primary px-4 py-2 font-semibold text-white transition-colors hover:bg-primary-dark"
          >
            {t.viewAll}
          </a>
        </div>

        <!-- Events count card -->
        <div class="rounded-lg border border-border bg-surface p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-text">{t.eventsTitle}</h3>
          <p class="mt-2 text-3xl font-bold text-primary">{eventCount}</p>
          <p class="mt-1 text-sm text-text-tertiary">
            {eventCount === 1 ? 'evento próximo' : 'eventos próximos'}
          </p>
          <a
            href={eventsListUrl}
            class="mt-4 block text-center rounded-md bg-primary px-4 py-2 font-semibold text-white transition-colors hover:bg-primary-dark"
          >
            {t.viewAll}
          </a>
        </div>
      </aside>
    </div>

    <!-- Accommodations section -->
    <Section title={`${t.accommodationsIn} ${destinationName}`} class="mt-12">
      {previewAccommodations.length > 0 ? (
        <>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {previewAccommodations.map((accommodation) => (
              <AccommodationCard accommodation={accommodation} locale={locale} />
            ))}
          </div>
          {accommodations.length > PREVIEW_LIMIT && (
            <div class="mt-6 text-center">
              <a
                href={accommodationsListUrl}
                class="inline-block rounded-md border-2 border-primary px-6 py-2 font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
              >
                {t.viewAll} ({accommodationCount})
              </a>
            </div>
          )}
        </>
      ) : (
        <EmptyState
          title={t.noAccommodations}
          message={t.noAccommodationsMessage}
        />
      )}
    </Section>

    <!-- Events section -->
    <Section title={`${t.eventsIn} ${destinationName}`} class="mt-12">
      {previewEvents.length > 0 ? (
        <>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {previewEvents.map((event) => (
              <EventCard event={event} locale={locale} />
            ))}
          </div>
          {events.length > PREVIEW_LIMIT && (
            <div class="mt-6 text-center">
              <a
                href={eventsListUrl}
                class="inline-block rounded-md border-2 border-primary px-6 py-2 font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
              >
                {t.viewAll} ({eventCount})
              </a>
            </div>
          )}
        </>
      ) : (
        <EmptyState
          title={t.noEvents}
          message={t.noEventsMessage}
        />
      )}
    </Section>
  </Container>
</BaseLayout>
