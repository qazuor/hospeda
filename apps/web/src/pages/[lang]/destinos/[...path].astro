---
export const prerender = true;

/**
 * Destination Detail Page
 *
 * Catch-all route supporting any destination hierarchy depth.
 * Displays hero, description, gallery, climate, attractions, map,
 * accommodations preview, and events for a single destination.
 *
 * Route: /[lang]/destinos/[...path]
 * Rendering: SSG (pre-rendered at build time)
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import PlaceJsonLd from '../../../components/seo/PlaceJsonLd.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import AccommodationCard from '../../../components/shared/AccommodationCard.astro';
import EventCard from '../../../components/shared/EventCard.astro';
import EmptyState from '../../../components/shared/EmptyState.astro';
import FavoriteButtonIsland from '../../../components/shared/FavoriteButtonIsland.astro';
import { ImageGallery } from '../../../components/shared/ImageGallery.client';
import { ShareButtons } from '../../../components/shared/ShareButtons.client';
import { MapView } from '../../../components/shared/MapView.client';
import { createTranslations, SUPPORTED_LOCALES, type SupportedLocale } from '../../../lib/i18n';
import { buildUrl, buildUrlWithParams } from '../../../lib/urls';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { destinationsApi, eventsApi } from '../../../lib/api/endpoints';
import { fetchAllPages } from '../../../lib/api/client';
import {
    toAccommodationCardProps,
    toEventCardProps,
    type AccommodationCardData,
    type EventCardData,
} from '../../../lib/api/transforms';
import { extractFeaturedImageUrl, extractGalleryUrls } from '../../../lib/media';
import { renderTiptapContent } from '../../../lib/tiptap-renderer';
import { sanitizeHtml } from '../../../lib/sanitize-html';

/**
 * Generates static paths for every destination in every supported locale.
 * The catch-all `path` parameter handles any hierarchy depth.
 */
export async function getStaticPaths() {
    const all = await fetchAllPages<Record<string, unknown>>({
        fetcher: (p) => destinationsApi.list(p),
    });
    return SUPPORTED_LOCALES.flatMap((lang) =>
        all
            .filter((d) => d.path || d.slug)
            .map((d) => ({
                params: { lang, path: String(d.path || d.slug).replace(/^\//, '') },
                props: { destinationData: d },
            }))
    );
}

// ─── Locale & route params ────────────────────────────────────────────────────

const { path } = Astro.params;
const { destinationData } = Astro.props as { destinationData: Record<string, unknown> };

const locale = getLocaleFromParams(Astro.params) as SupportedLocale;
if (!locale) return Astro.redirect('/es/');

const { t, tPlural } = createTranslations(locale);

// ─── Destination data (refresh on SSR, fallback to getStaticPaths props) ─────

let destination: Record<string, unknown> = destinationData ?? {};

if (path) {
    const pathStr = Array.isArray(path) ? path.join('/') : String(path);
    const result = await destinationsApi.getByPath({ path: pathStr });
    if (result.ok) {
        destination = result.data as unknown as Record<string, unknown>;
    } else if (!destinationData) {
        return Astro.redirect(buildUrl({ locale, path: 'destinos' }));
    }
}

const destinationId       = String(destination.id ?? '');
const destinationName     = String(destination.name ?? '');
const destinationSlug     = String(destination.slug ?? destination.path ?? '');
const destinationProvince = String(destination.province ?? destination.state ?? '');
const destinationCountry  = String(destination.country ?? 'Argentina');
const heroImage           = extractFeaturedImageUrl(destination, '/images/placeholder-destination.svg');
const locationCoords      = (destination.location as { lat?: number; lng?: number }) ?? {};
const climate             = (destination.climate as Record<string, string>) ?? {};
const attractions         = Array.isArray(destination.attractions) ? (destination.attractions as ReadonlyArray<{ name: string; description: string }>) : [];

// ─── Gallery ──────────────────────────────────────────────────────────────────

const galleryUrls    = extractGalleryUrls(destination);
const galleryImages  = (galleryUrls.length > 0 ? galleryUrls : [heroImage]).map((src) => ({
    src,
    alt: destinationName,
}));

// ─── Rich-text HTML ───────────────────────────────────────────────────────────

/** Casts an unknown API value to the TiptapDocument shape expected by renderTiptapContent. */
function toTiptapDoc(raw: unknown) {
    if (raw && typeof raw === 'object' && 'type' in (raw as Record<string, unknown>)) {
        return raw as Parameters<typeof renderTiptapContent>[0]['content'];
    }
    return null;
}

const descriptionHtml   = sanitizeHtml({ html: renderTiptapContent({ content: toTiptapDoc(destination.description ?? destination.summary) }) });
const howToGetThereHtml = sanitizeHtml({ html: renderTiptapContent({ content: toTiptapDoc(destination.howToGetThere) }) });

// ─── Related content (accommodations & events) ────────────────────────────────

let accommodations: readonly AccommodationCardData[] = [];
let events: readonly EventCardData[] = [];

if (destinationId) {
    const [accResult, evtResult] = await Promise.all([
        destinationsApi.getAccommodations({ id: destinationId, pageSize: 6 }),
        // pageSize: 12 provides buffer for city-name filtering while avoiding over-fetching.
        // Only 3 event preview cards are displayed, but we fetch more so the city filter
        // has enough candidates to find matches without loading the full catalog.
        eventsApi.list({ pageSize: 12 }),
    ]);
    if (accResult.ok && Array.isArray(accResult.data?.items)) {
        accommodations = accResult.data.items.map((item) =>
            toAccommodationCardProps({ item: item as Record<string, unknown> })
        );
    }
    if (evtResult.ok && Array.isArray(evtResult.data?.items)) {
        events = evtResult.data.items
            .map((item) => toEventCardProps({ item: item as Record<string, unknown> }))
            .filter((e) => e.location?.city?.toLowerCase() === destinationName.toLowerCase());
    }
}

// ─── Breadcrumb hierarchy ─────────────────────────────────────────────────────

type BreadcrumbEntry = { id: string; name: string; path: string };
let hierarchy: readonly BreadcrumbEntry[] = [];
if (destinationId) {
    const bcResult = await destinationsApi.getBreadcrumb({ id: destinationId });
    if (bcResult.ok && Array.isArray(bcResult.data?.breadcrumb)) {
        hierarchy = [...bcResult.data.breadcrumb];
    }
}

// ─── Derived values ───────────────────────────────────────────────────────────

const PREVIEW_LIMIT      = 3 as const;
const previewAccs        = accommodations.slice(0, PREVIEW_LIMIT);
const previewEvts        = events.slice(0, PREVIEW_LIMIT);
const accommodationCount = Number(destination.accommodationsCount ?? accommodations.length);
const eventCount         = events.length;

const pageUrl       = buildUrl({ locale, path: `destinos/${destinationSlug}` });
const canonicalUrl  = new URL(pageUrl, Astro.site).href;
const accsUrl       = buildUrlWithParams({ locale, path: 'alojamientos', params: { city: destinationName } });
const eventsUrl     = buildUrlWithParams({ locale, path: 'eventos', params: { city: destinationName } });

const mapMarkers = locationCoords.lat && locationCoords.lng
    ? [{ id: destinationId, lat: locationCoords.lat, lng: locationCoords.lng, title: destinationName, popup: `${destinationName}, ${destinationProvince}` }]
    : [];

const pageDescription = t('destination.detail.seoDescription', `${destinationName} - ${destinationProvince}, ${destinationCountry}`);

const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale, path: '' }) },
    { label: t('destination.listing.title', 'Destinos'), href: buildUrl({ locale, path: 'destinos' }) },
    ...hierarchy
        .filter((item) => item.id !== destinationId)
        .map((item) => ({ label: item.name, href: buildUrl({ locale, path: `destinos/${item.path}` }) })),
    { label: destinationName, href: pageUrl },
];

/** Climate fields with i18n keys for the climate grid. */
const climateFields = [
    { key: 'summer',     label: t('destination.detail.summer', 'Verano'),            value: climate.summer },
    { key: 'winter',     label: t('destination.detail.winter', 'Invierno'),           value: climate.winter },
    { key: 'bestSeason', label: t('destination.detail.bestSeason', 'Mejor epoca'),   value: climate.bestSeason },
    { key: 'rainfall',   label: t('destination.detail.rainfall', 'Precipitaciones'), value: climate.rainfall },
].filter((f) => Boolean(f.value));
---

<BaseLayout title={destinationName} description={pageDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={destinationName}
        description={pageDescription}
        canonical={canonicalUrl}
        image={heroImage}
        locale={locale}
        type="website"
    />
    <PlaceJsonLd
        slot="head"
        name={destinationName}
        description={pageDescription}
        url={canonicalUrl}
        image={heroImage}
        address={{ addressLocality: destinationName, addressRegion: destinationProvince || undefined, addressCountry: 'AR' }}
    />

    <div class="container mx-auto max-w-6xl px-4 py-6">
        <Breadcrumb items={breadcrumbItems} />

        <!-- Hero -->
        <div class="relative mb-8 aspect-[21/9] overflow-hidden rounded-2xl">
            <img src={heroImage} alt={destinationName} class="h-full w-full object-cover" transition:name={`entity-${destinationSlug}`} loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-foreground/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
                {destinationProvince && (
                    <span class="mb-3 inline-block rounded-full bg-primary/80 px-3 py-1 text-sm font-semibold text-primary-foreground backdrop-blur-sm">{destinationProvince}</span>
                )}
                <h1 class="text-3xl font-bold text-hero-text md:text-5xl">{destinationName}</h1>
            </div>
        </div>

        <!-- Action row -->
        <div class="mb-8 flex items-center justify-end gap-2">
            <FavoriteButtonIsland server:defer entityId={destinationId} entityType="destination" entityName={destinationName} locale={locale}>
                <div slot="fallback" class="h-10 w-10 animate-pulse rounded-full bg-muted"></div>
            </FavoriteButtonIsland>
            <ShareButtons client:visible url={canonicalUrl} title={destinationName} locale={locale} />
        </div>

        <!-- Two-column layout -->
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
            <!-- Main content (2/3) -->
            <div class="space-y-10 lg:col-span-2">
                {descriptionHtml && (
                    <section aria-labelledby="dest-desc-h">
                        <h2 id="dest-desc-h" class="mb-4 text-2xl font-bold text-foreground">{t('destination.detail.description', 'Descripcion')}</h2>
                        <div class="prose max-w-none text-muted-foreground" set:html={descriptionHtml} />
                    </section>
                )}

                {galleryImages.length > 0 && (
                    <section aria-labelledby="dest-gallery-h">
                        <h2 id="dest-gallery-h" class="mb-4 text-2xl font-bold text-foreground">{t('destination.detail.gallery', 'Galeria de fotos')}</h2>
                        <ImageGallery client:visible images={galleryImages} locale={locale} />
                    </section>
                )}

                {climateFields.length > 0 && (
                    <section aria-labelledby="dest-climate-h" class="scroll-reveal">
                        <h2 id="dest-climate-h" class="mb-4 text-2xl font-bold text-foreground">{t('destination.detail.climate', 'Clima')}</h2>
                        <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
                            {climateFields.map(({ key, label, value }) => (
                                <div class="rounded-xl border border-border bg-card p-4" key={key}>
                                    <div class="text-xs font-medium uppercase tracking-wide text-muted-foreground">{label}</div>
                                    <div class="mt-1 font-semibold text-foreground">{value}</div>
                                </div>
                            ))}
                        </div>
                    </section>
                )}

                {howToGetThereHtml && howToGetThereHtml.trim() !== '' && (
                    <section aria-labelledby="dest-how-h">
                        <h2 id="dest-how-h" class="mb-4 text-2xl font-bold text-foreground">{t('destination.detail.howToGetThere', 'Como llegar')}</h2>
                        <div class="prose max-w-none text-muted-foreground" set:html={howToGetThereHtml} />
                    </section>
                )}

                {attractions.length > 0 && (
                    <section aria-labelledby="dest-attr-h">
                        <h2 id="dest-attr-h" class="mb-4 text-2xl font-bold text-foreground">{t('destination.detail.attractions', 'Atracciones')}</h2>
                        <ul class="space-y-3">
                            {attractions.map((a) => (
                                <li class="rounded-xl border border-border bg-card p-4">
                                    <h3 class="font-semibold text-foreground">{a.name}</h3>
                                    <p class="mt-1 text-sm text-muted-foreground">{a.description}</p>
                                </li>
                            ))}
                        </ul>
                    </section>
                )}

                {mapMarkers.length > 0 && (
                    <section aria-labelledby="dest-map-h">
                        <h2 id="dest-map-h" class="mb-4 text-2xl font-bold text-foreground">{t('destination.detail.map', 'Ubicacion')}</h2>
                        <MapView client:visible markers={mapMarkers} center={[locationCoords.lat!, locationCoords.lng!]} zoom={13} height="400px" locale={locale} />
                    </section>
                )}
            </div>

            <!-- Sidebar (1/3) -->
            <aside class="space-y-6 lg:sticky lg:top-4 lg:self-start">
                <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
                    <h3 class="font-semibold text-foreground">{t('destination.detail.accommodationsTitle', 'Alojamientos')}</h3>
                    <p class="mt-2 text-3xl font-bold text-primary">{accommodationCount}</p>
                    <p class="mt-1 text-sm text-muted-foreground">{tPlural('destination.detail.accommodationCount', accommodationCount, { count: accommodationCount })}</p>
                    <a href={accsUrl} class="mt-4 block rounded-xl bg-primary px-4 py-2 text-center font-semibold text-primary-foreground transition-colors hover:bg-primary/90">
                        {t('destination.detail.viewAll', 'Ver todos')}
                    </a>
                </div>
                <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
                    <h3 class="font-semibold text-foreground">{t('destination.detail.eventsTitle', 'Eventos')}</h3>
                    <p class="mt-2 text-3xl font-bold text-primary">{eventCount}</p>
                    <p class="mt-1 text-sm text-muted-foreground">{tPlural('destination.detail.eventCount', eventCount, { count: eventCount })}</p>
                    <a href={eventsUrl} class="mt-4 block rounded-xl bg-primary px-4 py-2 text-center font-semibold text-primary-foreground transition-colors hover:bg-primary/90">
                        {t('destination.detail.viewAll', 'Ver todos')}
                    </a>
                </div>
            </aside>
        </div>

        <!-- Accommodations section -->
        <section aria-labelledby="dest-accs-h" class="scroll-reveal-left mt-14">
            <h2 id="dest-accs-h" class="mb-6 text-2xl font-bold text-foreground">
                {t('destination.detail.accommodationsIn', 'Alojamientos en')} {destinationName}
            </h2>
            {previewAccs.length > 0 ? (
                <>
                    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                        {previewAccs.map((card) => <AccommodationCard card={card} locale={locale} />)}
                    </div>
                    {accommodations.length > PREVIEW_LIMIT && (
                        <div class="mt-8 text-center">
                            <a href={accsUrl} class="inline-block rounded-xl border-2 border-primary px-6 py-2.5 font-semibold text-primary transition-colors hover:bg-primary hover:text-primary-foreground">
                                {t('destination.detail.viewAll', 'Ver todos')} ({accommodationCount})
                            </a>
                        </div>
                    )}
                </>
            ) : (
                <EmptyState
                    title={t('destination.detail.noAccommodations', 'Sin alojamientos aun')}
                    message={t('destination.detail.noAccommodationsMessage', 'Todavia no hay alojamientos registrados en este destino.')}
                />
            )}
        </section>

        <!-- Events section -->
        <section aria-labelledby="dest-evts-h" class="scroll-reveal-right mt-14">
            <h2 id="dest-evts-h" class="mb-6 text-2xl font-bold text-foreground">
                {t('destination.detail.eventsIn', 'Eventos en')} {destinationName}
            </h2>
            {previewEvts.length > 0 ? (
                <>
                    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                        {previewEvts.map((card) => <EventCard card={card} locale={locale} />)}
                    </div>
                    {events.length > PREVIEW_LIMIT && (
                        <div class="mt-8 text-center">
                            <a href={eventsUrl} class="inline-block rounded-xl border-2 border-primary px-6 py-2.5 font-semibold text-primary transition-colors hover:bg-primary hover:text-primary-foreground">
                                {t('destination.detail.viewAll', 'Ver todos')} ({eventCount})
                            </a>
                        </div>
                    )}
                </>
            ) : (
                <EmptyState
                    title={t('destination.detail.noEvents', 'Sin eventos aun')}
                    message={t('destination.detail.noEventsMessage', 'Todavia no hay eventos registrados en este destino.')}
                />
            )}
        </section>
    </div>
</BaseLayout>
