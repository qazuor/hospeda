---
/**
 * @file destinos/[...path].astro
 * @description Destination detail page with hierarchical catch-all routing.
 * Handles paths like /destinos/entre-rios/ and /destinos/entre-rios/colon/.
 * @route /{lang}/destinos/{...path}/
 * @rendering SSR + ISR 24h
 */

import DetailLayout from '@/layouts/DetailLayout.astro';
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro';
import AccommodationCard from '@/components/shared/cards/AccommodationCard.astro';
import EventCard from '@/components/shared/cards/EventCard.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { destinationsApi, accommodationsApi, eventsApi } from '@/lib/api/endpoints';
import { toAccommodationCardProps, toEventCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { Image } from 'astro:assets';
import { LocationIcon } from '@repo/icons';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { path } = Astro.params;

if (!path) return new Response(null, { status: 404 });

// Single segment = slug lookup, multi-segment = hierarchical path lookup
const segments = path.split('/').filter(Boolean);
const result = segments.length === 1
	? await destinationsApi.getBySlug({ slug: segments[0] })
	: await destinationsApi.getByPath({ path: `/${path}` });

if (!result.ok) return new Response(null, { status: 404 });

const dest = result.data as Record<string, unknown>;
const name = String(dest.name || '');
const description = String(dest.summary || dest.description || '');
const slug = String(dest.slug || '');
const destId = String(dest.id || '');
const featuredImage = String(dest.featuredImage || '/assets/images/placeholder-destination.svg');
const destType = String(dest.destinationType || '');

// Fetch previews (3 accommodations + 3 events)
let accCards: ReturnType<typeof toAccommodationCardProps>[] = [];
let eventCards: ReturnType<typeof toEventCardProps>[] = [];

try {
	const [accResult, eventsResult] = await Promise.all([
		accommodationsApi.getByDestination({ destinationId: destId, pageSize: 3 }),
		eventsApi.list({ pageSize: 3 }),
	]);

	accCards = accResult.ok
		? accResult.data.items.map((item) => toAccommodationCardProps({ item: item as unknown as Record<string, unknown> }))
		: [];
	eventCards = eventsResult.ok
		? eventsResult.data.items.map((item) => toEventCardProps({ item: item as unknown as Record<string, unknown> }))
		: [];
} catch (err) {
	console.error('[destinos/detail] Error fetching previews:', err);
}

// Build breadcrumb items from path segments
const pathSegments = path.split('/').filter(Boolean);
const breadcrumbItems = [
	{ label: t('destinations.title', 'Destinos'), path: 'destinos' },
	...pathSegments.map((segment, i) => ({
		label: segment.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
		...(i < pathSegments.length - 1 ? { path: `destinos/${pathSegments.slice(0, i + 1).join('/')}` } : {}),
	})),
];

// TouristDestination JSON-LD
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'TouristDestination',
	name,
	description,
	image: featuredImage,
	url: `${Astro.site ?? Astro.url.origin}${Astro.url.pathname}`,
};
---

<DetailLayout
	locale={locale}
	title={name}
	description={description}
	showBreadcrumbs={true}
	showSidebar={true}
>
	<JsonLd slot="head-extra" data={jsonLd} />

	<Breadcrumbs slot="breadcrumbs" locale={locale} items={breadcrumbItems} />

	<Fragment slot="page-header">
		<h1 class="dest-detail__title">{name}</h1>
		{destType && (
			<span class="dest-detail__type">
				<LocationIcon size={16} aria-hidden="true" />
				{t(`destinations.types.${destType.toLowerCase()}`, destType)}
			</span>
		)}
	</Fragment>

	<div class="dest-detail">
		<!-- Hero -->
		<div class="dest-detail__hero">
			{featuredImage && !featuredImage.includes('placeholder') ? (
				<Image
					src={featuredImage}
					alt={name}
					width={1200}
					height={675}
					format="webp"
					loading="eager"
					class="dest-detail__hero-img"
				/>
			) : (
				<img
					src={featuredImage}
					alt={name}
					loading="eager"
					class="dest-detail__hero-img"
					width="1200"
					height="675"
				/>
			)}
		</div>

		<!-- Description -->
		<div class="dest-detail__description" set:html={String(dest.contentHtml || description)} />

		<!-- Map placeholder -->
		<section class="dest-detail__section">
			<h2 class="dest-detail__section-title">{t('destinations.detail.location', 'Ubicación')}</h2>
			<!-- TODO: MapView island (T-022) -->
			<div class="dest-detail__placeholder">
				<p>{t('destinations.detail.mapPlaceholder', 'Mapa interactivo próximamente')}</p>
			</div>
		</section>

		<!-- Accommodation preview -->
		{accCards.length > 0 && (
			<section class="dest-detail__section">
				<div class="dest-detail__section-header">
					<h2 class="dest-detail__section-title">{t('destinations.detail.accommodations', 'Alojamientos')}</h2>
					<a href={buildUrl({ locale, path: `destinos/${slug}/alojamientos` })} class="dest-detail__view-all">
						{t('destinations.detail.viewAll', 'Ver todos')} →
					</a>
				</div>
				<div class="dest-detail__preview-grid">
					{accCards.map((card, i) => (
						<div data-reveal="up" style={`transition-delay: ${i * 100}ms`}>
							<AccommodationCard data={card} locale={locale} />
						</div>
					))}
				</div>
			</section>
		)}

		<!-- Events preview -->
		{eventCards.length > 0 && (
			<section class="dest-detail__section">
				<div class="dest-detail__section-header">
					<h2 class="dest-detail__section-title">{t('destinations.detail.events', 'Eventos')}</h2>
					<a href={buildUrl({ locale, path: `destinos/${slug}/eventos` })} class="dest-detail__view-all">
						{t('destinations.detail.viewAll', 'Ver todos')} →
					</a>
				</div>
				<div class="dest-detail__preview-grid">
					{eventCards.map((card, i) => (
						<div data-reveal="up" style={`transition-delay: ${i * 100}ms`}>
							<EventCard data={card} locale={locale} />
						</div>
					))}
				</div>
			</section>
		)}
	</div>

	<!-- Sidebar -->
	<div slot="sidebar" class="dest-sidebar">
		<div class="dest-sidebar__card">
			<h3 class="dest-sidebar__card-title">{t('destinations.detail.stats', 'Información')}</h3>
			<!-- TODO: Counts (accommodations, events, attractions) from API -->
			<div class="dest-sidebar__placeholder">
				<p>{t('destinations.detail.statsPlaceholder', 'Estadísticas del destino')}</p>
			</div>
		</div>
	</div>
</DetailLayout>

<style>
	.dest-detail__hero { margin-bottom: var(--space-6); border-radius: var(--radius-card); overflow: hidden; }
	.dest-detail__hero-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }

	.dest-detail__title { font-family: var(--font-heading); font-weight: 700; font-size: clamp(1.75rem, 4vw, 2.5rem); color: var(--foreground); margin: 0 0 var(--space-2); }
	.dest-detail__type { display: inline-flex; align-items: center; gap: 0.25rem; font-family: var(--font-sans); font-size: var(--text-body-sm); color: var(--muted-foreground); margin-bottom: var(--space-6); }

	.dest-detail__description { font-family: var(--font-sans); line-height: 1.7; color: var(--foreground); margin-bottom: var(--space-8); }
	.dest-detail__description :global(p) { margin-bottom: var(--space-4); }

	.dest-detail__section { margin-bottom: var(--space-8); }
	.dest-detail__section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-4); }
	.dest-detail__section-title { font-family: var(--font-heading); font-weight: 600; font-size: var(--text-xl); color: var(--foreground); margin: 0; }
	.dest-detail__view-all { font-family: var(--font-sans); font-size: var(--text-body-sm); color: var(--brand-accent); text-decoration: none; }
	.dest-detail__view-all:hover { text-decoration: underline; }

	.dest-detail__preview-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-card-gap); }
	.dest-detail__placeholder { background-color: var(--card); border: 1px dashed var(--border); border-radius: var(--radius-card); padding: var(--space-8); text-align: center; color: var(--muted-foreground); }

	.dest-sidebar__card { background-color: var(--card); border-radius: var(--radius-card); padding: var(--space-6); box-shadow: var(--shadow-card); margin-bottom: var(--space-4); }
	.dest-sidebar__card-title { font-family: var(--font-heading); font-weight: 600; font-size: var(--text-lg); color: var(--foreground); margin: 0 0 var(--space-4); }
	.dest-sidebar__placeholder { color: var(--muted-foreground); font-family: var(--font-sans); font-size: var(--text-body-sm); }

	@media (max-width: 768px) { .dest-detail__preview-grid { grid-template-columns: 1fr; } }
</style>
