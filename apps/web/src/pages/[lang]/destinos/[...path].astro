---
/**
 * @file destinos/[...path].astro
 * @description Destination detail page with hierarchical catch-all routing.
 * Handles paths like /destinos/entre-rios/ and /destinos/entre-rios/colon/.
 * @route /{lang}/destinos/{...path}/
 * @rendering SSR + ISR 24h
 */

import DetailLayout from '@/layouts/DetailLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import AccommodationCard from '@/components/shared/cards/AccommodationCard.astro';
import EventCard from '@/components/shared/cards/EventCard.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import BreadcrumbJsonLd from '@/components/seo/BreadcrumbJsonLd.astro';
import { LocationMap } from '@/components/maps/LocationMap.client';
import DestinationGallery from '@/components/destination/DestinationGallery.astro';
import DestinationAttractionsGrid from '@/components/destination/DestinationAttractionsGrid.astro';
import DestinationRatingBreakdown from '@/components/destination/DestinationRatingBreakdown.astro';
import DestinationStatsCard from '@/components/destination/DestinationStatsCard.astro';
import DestinationFaqPlaceholder from '@/components/destination/DestinationFaqPlaceholder.astro';
import DestinationClimatePlaceholder from '@/components/destination/DestinationClimatePlaceholder.astro';
import DestinationReviewsSection from '@/components/destination/DestinationReviewsSection.astro';
import DestinationRelatedPosts from '@/components/destination/DestinationRelatedPosts.astro';
import DestinationNearbySection from '@/components/destination/DestinationNearbySection.astro';
import {
	destinationsApi,
	accommodationsApi,
	eventsApi,
	postsApi,
	userBookmarksPublicApi
} from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { toAccommodationCardProps, toEventCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { Image } from 'astro:assets';
import { LocationIcon, FavoriteIcon } from '@repo/icons';
import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';

const locale = Astro.locals.locale as SupportedLocale;
const { t, tPlural } = createTranslations(locale);
const { path } = Astro.params;

if (!path) return new Response(null, { status: 404 });

// Single segment = slug lookup, multi-segment = hierarchical path lookup
const segments = path.split('/').filter(Boolean);
const result = segments.length === 1
	? await destinationsApi.getBySlug({ slug: segments[0] })
	: await destinationsApi.getByPath({ path: `/${path}` });

if (!result.ok) return new Response(null, { status: 404 });

const dest = result.data as Record<string, unknown>;
const name = String(dest.name || '');
const summary = String(dest.summary || '');
const description = String(dest.description || summary);
const slug = String(dest.slug || '');
const destId = String(dest.id || '');
const destType = String(dest.destinationType || '');

// --- Media (featuredImage + gallery) ----------------------------------------
// The API returns media as an object { featuredImage: { url, caption }, gallery: [...] }.
// We tolerate either shape (legacy string or new object) so the page never blows up.
interface MediaImage { readonly url: string; readonly caption?: string; readonly description?: string }
const mediaRaw = dest.media as
	| { featuredImage?: MediaImage; gallery?: ReadonlyArray<MediaImage> }
	| undefined;
const PLACEHOLDER = '/assets/images/placeholder-destination.svg';
const featuredImageObj: MediaImage =
	mediaRaw?.featuredImage && typeof mediaRaw.featuredImage === 'object'
		? mediaRaw.featuredImage
		: typeof dest.featuredImage === 'string' && dest.featuredImage
		  ? { url: dest.featuredImage, caption: name }
		  : { url: PLACEHOLDER, caption: name };
const galleryImages: ReadonlyArray<MediaImage> = mediaRaw?.gallery ?? [];

// --- Domain data passed to the new section components -----------------------
const attractions = (dest.attractions as ReadonlyArray<{
	readonly id: string;
	readonly name: string;
	readonly slug?: string;
	readonly description?: string;
	readonly icon?: string;
	readonly isFeatured?: boolean;
	readonly displayWeight?: number;
}>) ?? [];

const ratingBreakdown = dest.rating as Record<string, number | undefined> | null | undefined;

// --- Previews (accommodations, events, posts) and counts --------------------
let accCards: ReturnType<typeof toAccommodationCardProps>[] = [];
let eventCards: ReturnType<typeof toEventCardProps>[] = [];
let relatedPosts: ReadonlyArray<unknown> = [];
let nearbyDestinations: ReadonlyArray<unknown> = [];
let accCount = 0;
let eventsCount = 0;
let stats: {
	accommodationsCount: number;
	reviewsCount: number;
	averageRating: number;
	attractionsCount: number;
	eventsCount: number;
} = {
	accommodationsCount: 0,
	reviewsCount: 0,
	averageRating: 0,
	attractionsCount: 0,
	eventsCount: 0
};

const parentDestinationId =
	typeof dest.parentDestinationId === 'string' && dest.parentDestinationId
		? dest.parentDestinationId
		: null;

try {
	const [
		accResult,
		accCountResult,
		eventsResult,
		eventsCountResult,
		statsResult,
		postsResult,
		siblingsResult
	] = await Promise.allSettled([
		accommodationsApi.getByDestination({ destinationId: destId, pageSize: 3 }),
		accommodationsApi.getByDestination({ destinationId: destId, pageSize: 1 }),
		eventsApi.list({ pageSize: 3, destinationId: destId }),
		eventsApi.list({ pageSize: 1, destinationId: destId }),
		destinationsApi.getStats({ id: destId }),
		postsApi.list({ destinationId: destId, pageSize: 4 }),
		parentDestinationId
			? destinationsApi.getChildren({ id: parentDestinationId })
			: Promise.resolve({ ok: false } as const)
	]);

	if (accResult.status === 'fulfilled' && accResult.value.ok) {
		accCards = accResult.value.data.items.map((item) =>
			toAccommodationCardProps({ item: item as unknown as Record<string, unknown> })
		);
	}
	if (accCountResult.status === 'fulfilled' && accCountResult.value.ok) {
		accCount = accCountResult.value.data.pagination?.total ?? 0;
	}
	if (eventsResult.status === 'fulfilled' && eventsResult.value.ok) {
		eventCards = eventsResult.value.data.items.map((item) =>
			toEventCardProps({ item: item as unknown as Record<string, unknown> })
		);
	}
	if (eventsCountResult.status === 'fulfilled' && eventsCountResult.value.ok) {
		eventsCount = eventsCountResult.value.data.pagination?.total ?? 0;
	}

	if (statsResult.status === 'fulfilled' && statsResult.value.ok) {
		stats = {
			accommodationsCount: statsResult.value.data.accommodationsCount,
			reviewsCount: statsResult.value.data.reviewsCount,
			averageRating: statsResult.value.data.averageRating,
			attractionsCount: statsResult.value.data.attractionsCount,
			eventsCount: statsResult.value.data.eventsCount
		};
	} else {
		// Fall back to the locally derived counts so the sidebar still has something useful
		stats = {
			accommodationsCount: accCount,
			reviewsCount: 0,
			averageRating: 0,
			attractionsCount: attractions.length,
			eventsCount
		};
	}

	if (postsResult.status === 'fulfilled' && postsResult.value.ok) {
		relatedPosts = postsResult.value.data.items ?? [];
	}

	if (siblingsResult.status === 'fulfilled' && siblingsResult.value.ok) {
		const siblings = siblingsResult.value.data.children ?? [];
		// Drop the current destination from the siblings list and cap at 8 so
		// the carousel stays focused. The component will further cap visible cards.
		nearbyDestinations = siblings
			.filter((d) => (d as { id?: string }).id !== destId)
			.slice(0, 8);
	}
} catch (err) {
	console.error('[destinos/detail] Error fetching previews:', err);
}

// --- Auth -------------------------------------------------------------------
const userId = Astro.locals.user?.id ?? null;
const isAuthenticated = userId !== null;

// --- Bookmark count + favorite status (graceful degradation) ----------------
let bookmarkCount: number | undefined;
let initialIsFavorited: boolean | undefined;
let initialBookmarkId: string | null = null;

try {
	const countResult = await userBookmarksPublicApi.count({
		entityType: 'DESTINATION',
		entityId: destId
	});
	if (countResult.ok) {
		bookmarkCount = countResult.data.count;
	}
} catch {
	// Graceful degradation: counter not shown if fetch fails
}

if (isAuthenticated) {
	try {
		const statusResult = await userBookmarksApi.checkStatus({
			entityId: destId,
			entityType: 'DESTINATION'
		});
		if (statusResult.ok) {
			initialIsFavorited = statusResult.data.isFavorited;
			initialBookmarkId = statusResult.data.bookmarkId;
		}
	} catch {
		// Graceful degradation: FavoriteButton hydrates itself on mount
	}
}

// --- Breadcrumbs ------------------------------------------------------------
const pathSegments = path.split('/').filter(Boolean);
const breadcrumbItems = [
	{ label: t('destinations.title', 'Destinos'), path: 'destinos' },
	...pathSegments.map((segment, i) => ({
		label: segment.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
		...(i < pathSegments.length - 1
			? { path: `destinos/${pathSegments.slice(0, i + 1).join('/')}` }
			: {})
	}))
];

// --- TouristDestination JSON-LD --------------------------------------------
const destLocation = dest.location as
	| { coordinates?: { lat?: string; long?: string } }
	| undefined;
const destCoords = destLocation?.coordinates;
const destLat = destCoords?.lat ? Number.parseFloat(destCoords.lat) : null;
const destLng = destCoords?.long ? Number.parseFloat(destCoords.long) : null;
const hasDestCoords = Number.isFinite(destLat) && Number.isFinite(destLng);

const jsonLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'TouristDestination',
	name,
	description: summary || description,
	image: featuredImageObj.url,
	url: `${Astro.site ?? Astro.url.origin}${Astro.url.pathname}`,
	...(hasDestCoords
		? {
				geo: {
					'@type': 'GeoCoordinates',
					latitude: destLat,
					longitude: destLng
				}
		  }
		: {})
};

// --- Breadcrumb JSON-LD (REQ-096-37 / T-068) -------------------------------
const siteOriginDest = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const breadcrumbJsonLdItems = [
	{ name: t('nav.home', 'Inicio'), url: `${siteOriginDest}/${locale}/` },
	{ name: t('destinations.title', 'Destinos'), url: `${siteOriginDest}/${locale}/destinos/` },
	...pathSegments.map((segment, i) => ({
		name: segment.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
		url: `${siteOriginDest}/${locale}/destinos/${pathSegments.slice(0, i + 1).join('/')}/`
	}))
];

// Whether the destination's plain `description` field carries HTML (the
// editor stores Tiptap-rendered HTML). We assume description is plain text
// and rely on the optional contentHtml field for rich content.
const richDescription = typeof dest.contentHtml === 'string' ? dest.contentHtml : null;
---

<DetailLayout
	locale={locale}
	title={name}
	description={summary || description}
	showBreadcrumbs={true}
	showSidebar={true}
>
	<JsonLd slot="head-extra" data={jsonLd} />
	<BreadcrumbJsonLd slot="head-extra" items={breadcrumbJsonLdItems} />

	<Breadcrumbs slot="breadcrumbs" locale={locale} items={breadcrumbItems} />

	<Fragment slot="page-header">
		<div class="dest-detail__header-top-row">
			<div class="dest-detail__header-left">
				<h1 class="dest-detail__title">{name}</h1>
				{destType && (
					<span class="dest-detail__type">
						<LocationIcon size={16} aria-hidden="true" />
						{t(`destination.types.${destType}`, destType)}
					</span>
				)}
			</div>
			<FavoriteButton
				client:load
				entityId={destId}
				entityType="DESTINATION"
				initialIsFavorited={initialIsFavorited}
				initialBookmarkId={initialBookmarkId}
				isAuthenticated={isAuthenticated}
				variant="standalone"
				locale={locale}
				class="dest-detail__favorite-btn"
			/>
		</div>
		{bookmarkCount !== undefined && (
			<span
				class="dest-detail__bookmark-count"
				aria-label={tPlural('destination.detail.bookmark_count', bookmarkCount)}
			>
				<FavoriteIcon size={14} weight="fill" aria-hidden="true" />
				{tPlural('destination.detail.bookmark_count', bookmarkCount)}
			</span>
		)}
	</Fragment>

	<div class="dest-detail">
		<!-- Hero -->
		<div class="dest-detail__hero">
			{featuredImageObj.url && !featuredImageObj.url.includes('placeholder') ? (
				<Image
					src={featuredImageObj.url}
					alt={featuredImageObj.caption ?? name}
					width={1200}
					height={675}
					format="webp"
					loading="eager"
					class="dest-detail__hero-img"
				/>
			) : (
				<img
					src={featuredImageObj.url}
					alt={featuredImageObj.caption ?? name}
					loading="eager"
					class="dest-detail__hero-img"
					width="1200"
					height="675"
				/>
			)}
		</div>

		<!-- Description (rich HTML if available, else plain text) -->
		<div class="dest-detail__section dest-detail__description">
			{richDescription ? (
				<div set:html={richDescription} />
			) : (
				<p>{description}</p>
			)}
		</div>

		<!-- Photo gallery (extras beyond the hero) -->
		{galleryImages.length > 0 && (
			<div class="dest-detail__section">
				<DestinationGallery
					featuredImage={featuredImageObj}
					gallery={galleryImages}
					destinationName={name}
					locale={locale}
				/>
			</div>
		)}

		<!-- What to do here -->
		{attractions.length > 0 && (
			<div class="dest-detail__section">
				<DestinationAttractionsGrid
					attractions={attractions}
					locale={locale}
				/>
			</div>
		)}

		<!-- Rating breakdown -->
		{ratingBreakdown && (
			<div class="dest-detail__section">
				<h2 class="dest-detail__section-title">
					{t('destination.detail.rating.title', 'Calificación por dimensión')}
				</h2>
				<DestinationRatingBreakdown
					rating={ratingBreakdown}
					locale={locale}
				/>
			</div>
		)}

		<!-- Reviews section (preview + modal) -->
		<div class="dest-detail__section">
			<DestinationReviewsSection
				destinationId={destId}
				averageRating={stats.averageRating}
				reviewsCount={stats.reviewsCount}
				locale={locale}
			/>
		</div>

		<!-- Interactive map (SPEC-097) -->
		<section class="dest-detail__section">
			<h2 class="dest-detail__section-title">
				{t('destinations.detail.location', 'Ubicación')}
			</h2>
			{hasDestCoords ? (
				<LocationMap
					client:only="react"
					mode="exact"
					lat={destLat as number}
					lng={destLng as number}
					zoom={11}
					markerLabel={name}
					ariaLabel={t('maps.ariaLabelDestination')}
					i18nStrings={{
						attribution: t('maps.attribution'),
						approximateDisclaimer: t('maps.approximateDisclaimer'),
						markerLabel: name
					}}
				/>
			) : (
				<div class="dest-detail__placeholder">
					<p>{t('destinations.detail.mapPlaceholder', 'Ubicación no disponible')}</p>
				</div>
			)}
		</section>

		<!-- FAQ placeholder (real FAQ data is not yet in the destination schema) -->
		<div class="dest-detail__section">
			<DestinationFaqPlaceholder locale={locale} />
		</div>

		<!-- Climate placeholder (will be populated via external weather API) -->
		<div class="dest-detail__section">
			<DestinationClimatePlaceholder locale={locale} />
		</div>

		<!-- Accommodation preview -->
		<section class="dest-detail__section">
			<div class="dest-detail__section-header">
				<h2 class="dest-detail__section-title">
					{t('destination.detailPage.accommodationsIn', 'Alojamientos en')} {name}
				</h2>
				{accCards.length > 0 && (
					<a
						href={buildUrl({ locale, path: `destinos/${slug}/alojamientos` })}
						class="dest-detail__view-all"
					>
						{t('destination.detailPage.viewAll', 'Ver todos')} →
					</a>
				)}
			</div>
			{accCards.length > 0 ? (
				<div class="dest-detail__preview-grid">
					{accCards.map((card, i) => (
						<div data-reveal="up" style={`transition-delay: ${i * 100}ms`}>
							<AccommodationCard data={card} locale={locale} />
						</div>
					))}
				</div>
			) : (
				<div class="dest-detail__empty-state">
					<p class="dest-detail__empty-title">
						{t('destination.detailPage.noAccommodations', 'No hay alojamientos disponibles')}
					</p>
					<p class="dest-detail__empty-message">
						{t(
							'destination.detailPage.noAccommodationsMessage',
							'Próximamente agregaremos alojamientos en este destino.'
						)}
					</p>
				</div>
			)}
		</section>

		<!-- Events preview -->
		<section class="dest-detail__section">
			<div class="dest-detail__section-header">
				<h2 class="dest-detail__section-title">
					{t('destination.detailPage.eventsIn', 'Eventos en')} {name}
				</h2>
				{eventCards.length > 0 && (
					<a
						href={buildUrl({ locale, path: `destinos/${slug}/eventos` })}
						class="dest-detail__view-all"
					>
						{t('destination.detailPage.viewAll', 'Ver todos')} →
					</a>
				)}
			</div>
			{eventCards.length > 0 ? (
				<div class="dest-detail__preview-grid">
					{eventCards.map((card, i) => (
						<div data-reveal="up" style={`transition-delay: ${i * 100}ms`}>
							<EventCard data={card} locale={locale} />
						</div>
					))}
				</div>
			) : (
				<div class="dest-detail__empty-state">
					<p class="dest-detail__empty-title">
						{t('destination.detailPage.noEvents', 'No hay eventos próximos')}
					</p>
					<p class="dest-detail__empty-message">
						{t(
							'destination.detailPage.noEventsMessage',
							'No hay eventos programados para este destino en este momento.'
						)}
					</p>
				</div>
			)}
		</section>

		<!-- Related posts (filtered by destinationId on the server) -->
		<section class="dest-detail__section">
			{relatedPosts.length > 0 ? (
				<DestinationRelatedPosts
					posts={relatedPosts}
					destinationName={name}
					locale={locale}
				/>
			) : (
				<>
					<h2 class="dest-detail__section-title">
						{t('destination.detail.relatedPosts.title', 'Sobre {{name}}', { name })}
					</h2>
					<div class="dest-detail__empty-state">
						<p class="dest-detail__empty-title">
							{t('destination.detail.relatedPosts.empty', 'Todavía no hay notas sobre este destino')}
						</p>
						<p class="dest-detail__empty-message">
							{t(
								'destination.detail.relatedPosts.emptyMessage',
								'Estamos preparando contenido para que conozcas más sobre este destino.'
							)}
						</p>
					</div>
				</>
			)}
		</section>

		<!-- Other destinations in the area (siblings of the same parent) -->
		{nearbyDestinations.length > 0 && (
			<section class="dest-detail__section">
				<DestinationNearbySection
					destinations={nearbyDestinations}
					locale={locale}
					isAuthenticated={isAuthenticated}
				/>
			</section>
		)}
	</div>

	<!-- Sidebar -->
	<div slot="sidebar" class="dest-sidebar">
		<DestinationStatsCard stats={stats} locale={locale} />
	</div>
</DetailLayout>

<style>
	.dest-detail__hero {
		margin-bottom: 1.5rem;
		border-radius: var(--radius-card);
		overflow: hidden;
	}
	.dest-detail__hero-img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.dest-detail__header-top-row {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
	}
	.dest-detail__header-left {
		flex: 1;
		min-width: 0;
	}
	.dest-detail__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		color: var(--core-foreground);
		margin: 0 0 0.5rem;
	}
	.dest-detail__type {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		font-family: var(--font-sans);
		font-size: 0.875rem;
		color: var(--core-muted-foreground);
		margin-bottom: 1rem;
	}
	.dest-detail__bookmark-count {
		display: inline-flex;
		align-items: center;
		gap: 0.3em;
		font-family: var(--font-sans);
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--core-muted-foreground);
		margin-bottom: 1rem;
	}
	.dest-detail__bookmark-count :global(svg) {
		color: var(--rating-star);
	}

	.dest-detail__description {
		font-family: var(--font-sans);
		line-height: 1.7;
		color: var(--core-foreground);
	}
	.dest-detail__description :global(p) {
		margin-bottom: 1rem;
	}
	.dest-detail__description :global(p:last-child) {
		margin-bottom: 0;
	}

	.dest-detail__section {
		margin-bottom: 2rem;
	}
	.dest-detail__section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1rem;
	}
	.dest-detail__section-title {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 1.5rem;
		color: var(--core-foreground);
		margin: 0 0 1rem;
	}
	.dest-detail__view-all {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		color: var(--brand-accent);
		text-decoration: none;
	}
	.dest-detail__view-all:hover {
		text-decoration: underline;
	}

	.dest-detail__preview-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-card-gap);
	}

	.dest-detail__placeholder {
		background-color: var(--core-card);
		border: 1px dashed var(--border);
		border-radius: var(--radius-card);
		padding: 2rem;
		text-align: center;
		color: var(--core-muted-foreground);
	}

	.dest-detail__empty-state {
		background-color: var(--core-card);
		border: 1px dashed var(--border);
		border-radius: var(--radius-organic-sm);
		padding: 2rem 1.5rem;
		text-align: center;
	}
	.dest-detail__empty-title {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 1rem;
		color: var(--core-foreground);
		margin: 0 0 0.5rem;
	}
	.dest-detail__empty-message {
		font-family: var(--font-sans);
		font-size: 0.9rem;
		color: var(--core-muted-foreground);
		margin: 0;
	}

	.dest-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	@media (max-width: 768px) {
		.dest-detail__preview-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
