---
/**
 * @file destinos/mapa.astro
 * @description Map view of destinations listing. Full-width Leaflet map with
 * exact markers (destinations, unlike accommodations, expose precise coords).
 * @route /{lang}/destinos/mapa/
 * @rendering SSR
 */

import DefaultLayout from '@/layouts/DefaultLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import { ListingMap } from '@/components/maps/ListingMap.client';
import { destinationsApi } from '@/lib/api/endpoints';
import { toDestinationCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t, tPlural } = createTranslations(locale);

// Fetch a higher cap for the map view; destinations are typically a small set
// but allow up to 100 to avoid surprises if the catalog grows.
const MAP_FETCH_CAP = 100;

const result = await destinationsApi.list({ page: 1, pageSize: MAP_FETCH_CAP, destinationType: 'CITY' });

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.pagination.total : 0;
const cards = items.map((item) => toDestinationCardProps({ item: item as unknown as Record<string, unknown>, locale }));

const mapItems = cards
	.filter((c) => c.coordinates?.lat && c.coordinates?.long)
	.map((c) => {
		const count = c.accommodationsCount;
		return {
			id: c.slug,
			slug: c.slug,
			name: c.name,
			thumbnailUrl: c.featuredImage?.url,
			accommodationsCount: count,
			accommodationsLabel: typeof count === 'number'
				? tPlural('destination.card.accommodation', count, { count })
				: undefined,
			detailHref: buildUrl({ locale, path: `destinos/${c.slug}` }),
			coordinates: {
				lat: Number.parseFloat(c.coordinates!.lat),
				lng: Number.parseFloat(c.coordinates!.long),
			},
		};
	})
	.filter((item) => Number.isFinite(item.coordinates.lat) && Number.isFinite(item.coordinates.lng));

const LITORAL_CENTER: [number, number] = [-31.8, -58.5];
const LITORAL_ZOOM = 8;
const mapCenter: [number, number] = mapItems.length > 0
	? [mapItems[0].coordinates.lat, mapItems[0].coordinates.lng]
	: LITORAL_CENTER;

const listHref = buildUrl({ locale, path: 'destinos' });
---

<DefaultLayout
	locale={locale}
	title={`${t('destinations.title', 'Destinos')} — ${t('accommodations.viewToggle.map', 'Mapa')}`}
	description={t('destinations.description', 'Explorá los destinos turísticos del Litoral Entrerriano.')}
	noindex={true}
>
	<div class="dest-listing">
		<div class="dest-listing__header section section--warm">
			<div class="dest-listing__header-container">
				<Breadcrumbs
					locale={locale}
					items={[
						{ label: t('destinations.title', 'Destinos'), path: 'destinos' },
						{ label: t('accommodations.viewToggle.map', 'Mapa') },
					]}
				/>
				<ListingPageHeader
					locale={locale}
					tagline={t('destinations.tagline', 'Explorá la región')}
					title={t('destinations.title', 'Destinos')}
					totalCount={total}
				/>
			</div>
		</div>

		<div class="dest-listing__wave" aria-hidden="true">
			<svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
				<path d="M0,64 C288,120 576,0 864,64 C1152,128 1440,32 1440,32 L1440,0 L0,0 Z" fill="var(--surface-warm, #fdf6f0)" />
			</svg>
		</div>

		<div class="dest-listing__body">
			<div class="dest-listing__container">
				{hasError && !result.ok && <ErrorBanner locale={locale} error={result.error} entityName="destinos" />}

				{!hasError && cards.length === 0 && (
					<EmptyState locale={locale} variant="empty" />
				)}

				{!hasError && cards.length > 0 && (
					<div class="view-toggle" role="tablist" aria-label={t('accommodations.viewToggle.ariaLabel', 'Vista')}>
						<a href={listHref} class="view-toggle__btn" role="tab" aria-selected="false">
							{t('accommodations.viewToggle.list', 'Lista')}
						</a>
						<span class="view-toggle__btn view-toggle__btn--active" role="tab" aria-selected="true">
							{t('accommodations.viewToggle.map', 'Mapa')}
						</span>
					</div>
				)}

				{!hasError && cards.length > 0 && mapItems.length > 0 && (
					<div class="dest-listing-map">
						<ListingMap
							client:only="react"
							mode="destination-list"
							items={mapItems}
							initialCenter={mapCenter}
							initialZoom={LITORAL_ZOOM}
							ariaLabel={t('maps.ariaLabelDestination')}
							i18nStrings={{
								attribution: t('maps.attribution'),
								approximateDisclaimer: t('maps.approximateDisclaimer'),
								viewDetails: t('maps.viewDetails', 'Ver más'),
							}}
						/>
					</div>
				)}
			</div>
		</div>
	</div>
</DefaultLayout>

<style>
	.dest-listing__header-container,
	.dest-listing__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.dest-listing__header {
		padding: 3rem 0 1.5rem;
	}

	.dest-listing__wave { margin-top: -1px; line-height: 0; }
	.dest-listing__wave svg { width: 100%; height: 80px; display: block; }

	.dest-listing__body { padding: var(--space-section-sm) 0; }

	.view-toggle {
		display: inline-flex;
		gap: var(--space-2, 8px);
		padding: 4px;
		margin: 0 0 var(--space-4, 16px);
		background-color: var(--surface-warm, #faf6f0);
		border-radius: var(--radius-pill, 9999px);
	}
	.view-toggle__btn {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-pill, 9999px);
		color: var(--core-muted-foreground);
		text-decoration: none;
		transition: background-color var(--duration-normal, 0.4s) ease, color var(--duration-normal, 0.4s) ease;
		cursor: pointer;
	}
	.view-toggle__btn:hover { color: var(--core-foreground); }
	.view-toggle__btn--active {
		background-color: var(--brand-accent);
		color: white;
		font-weight: 500;
		cursor: default;
	}

	.dest-listing-map {
		width: 100%;
		min-height: 600px;
		margin: 0 0 var(--space-6, 24px);
	}
	@media (max-width: 768px) {
		.dest-listing-map { min-height: 480px; }
	}
</style>
