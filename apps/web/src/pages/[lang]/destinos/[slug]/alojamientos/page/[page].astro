---
/**
 * Paginated destination accommodations route.
 *
 * Rewrites to the accommodations index with the `page` query parameter so
 * the single index page can handle all pagination without duplicating logic.
 * Page 1 redirects to the canonical base URL (no /page/ segment) to avoid
 * duplicate content.
 *
 * @route /[lang]/destinos/[slug]/alojamientos/page/[page]/
 * @rendering SSR (on-demand, no prerender)
 */

import { getLocaleFromParams } from '../../../../../../lib/page-helpers';

const { slug, page } = Astro.params;
const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

if (!slug) {
    return Astro.redirect(`/${locale}/destinos/`);
}

const pageNum = Number.parseInt(page ?? '1', 10);

if (Number.isNaN(pageNum) || pageNum < 1) {
    return Astro.redirect(`/${locale}/destinos/${slug}/alojamientos/`);
}

/** Page 1 must use the canonical base URL — no /page/ segment. */
if (pageNum === 1) {
    return Astro.redirect(`/${locale}/destinos/${slug}/alojamientos/`);
}

/** Rewrite to the index page; it reads `page` from the query string. */
return Astro.rewrite(`/${locale}/destinos/${slug}/alojamientos/?page=${pageNum}`);
---
