---
/**
 * @file destinos/[slug]/alojamientos/index.astro
 * @description Accommodations within a specific destination.
 * @route /{lang}/destinos/{slug}/alojamientos/
 * @rendering SSR + ISR 24h
 */
import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/ListingPageHeader.astro';
import AccommodationCard from '@/components/shared/AccommodationCard.astro';
import EmptyState from '@/components/shared/EmptyState.astro';
import ErrorBanner from '@/components/shared/ErrorBanner.astro';
import Pagination from '@/components/shared/Pagination.astro';
import { accommodationsApi, destinationsApi } from '@/lib/api/endpoints';
import { toAccommodationCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { slug } = Astro.params;
if (!slug) return new Response(null, { status: 404 });

const destResult = await destinationsApi.getBySlug({ slug });
if (!destResult.ok) return new Response(null, { status: 404 });
const dest = destResult.data as Record<string, unknown>;
const destId = String(dest.id || '');
const destName = String(dest.name || slug);

const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const result = await accommodationsApi.getByDestination({ destinationId: destId, page, pageSize: 9 });
const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.total : 0;
const totalPages = result.ok ? Math.ceil(total / 9) : 0;
const cards = items.map((item) => toAccommodationCardProps({ item: item as unknown as Record<string, unknown> }));
const baseUrl = buildUrl({ locale, path: `destinos/${slug}/alojamientos` });
---

<ListingLayout locale={locale} title={`${t('accommodations.title', 'Alojamientos')} en ${destName}`} showFilters={false}>
	<Breadcrumbs slot="breadcrumbs" locale={locale} items={[{ label: t('destinations.title', 'Destinos'), path: 'destinos' }, { label: destName, path: `destinos/${slug}` }, { label: t('accommodations.title', 'Alojamientos') }]} />
	<ListingPageHeader slot="page-header" locale={locale} tagline={destName} title={t('accommodations.title', 'Alojamientos')} totalCount={total} />
	{hasError && !result.ok && <ErrorBanner locale={locale} error={result.error} entityName="alojamientos" />}
	{!hasError && cards.length === 0 && <EmptyState locale={locale} variant="empty" actionUrl={buildUrl({ locale, path: `destinos/${slug}` })} />}
	{!hasError && cards.length > 0 && (
		<div class="grid">{cards.map((card, i) => (<div data-reveal="up" style={`transition-delay: ${Math.min(i, 6) * 100}ms`}><AccommodationCard data={card} locale={locale} /></div>))}</div>
	)}
	{totalPages > 1 && <Pagination slot="pagination" currentPage={page} totalPages={totalPages} baseUrl={baseUrl.slice(0, -1)} locale={locale} />}
</ListingLayout>

<style>
	.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-card-gap); }
	@media (max-width: 1024px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>
