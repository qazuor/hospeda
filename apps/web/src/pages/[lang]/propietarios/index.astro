---
/**
 * Property Owners (Propietarios) landing page.
 * Marketing page presenting the value proposition for accommodation owners
 * to list their properties on Hospeda: benefits, how it works, FAQ, and CTA.
 *
 * Rendering: SSG (pre-rendered at build time for all supported locales).
 * Route: /[lang]/propietarios/
 */
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../../lib/page-helpers';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import BackgroundPattern from '../../../components/shared/BackgroundPattern.astro';
import DecorativeElement from '../../../components/shared/DecorativeElement.astro';
import GradientButton from '../../../components/shared/GradientButton.astro';
import AccordionFAQ from '../../../components/shared/AccordionFAQ.astro';
import {
    SearchIcon,
    DashboardIcon,
    StarIcon,
    StatisticsIcon,
    ChatIcon,
    SettingsIcon,
} from '@repo/icons';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { createT } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';
import {
    OWNER_HERO,
    OWNER_BENEFITS,
    OWNER_HOW_IT_WORKS,
    OWNER_FAQ,
    OWNER_FINAL_CTA,
} from '../../../lib/owners-page-data';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/propietarios/');

/** Translation helper bound to this locale. */
const t = createT(locale);

const pageTitle = t('owners.page.title', 'Propietarios - Publica tu alojamiento en Hospeda');
const pageDescription = t(
    'owners.page.description',
    'Llega a miles de viajeros y gestiona tu alojamiento con herramientas profesionales. Publica en Hospeda hoy.'
);
const breadcrumbLabel = t('owners.page.breadcrumb', 'Propietarios');

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items.
 */
const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
    { label: breadcrumbLabel, href: buildUrl({ locale, path: 'propietarios' }) },
] as const;

/** Localized page content from the shared data module. */
const hero = OWNER_HERO[locale];
const benefits = OWNER_BENEFITS[locale];
const howItWorks = OWNER_HOW_IT_WORKS[locale];
const faq = OWNER_FAQ[locale];
const finalCta = OWNER_FINAL_CTA[locale];

/**
 * FAQPage JSON-LD structured data for search engine rich results.
 */
const faqJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.faqs.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
        },
    })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale}
        type="website"
    />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} slot="head" />

    <div class="relative overflow-hidden">
        <BackgroundPattern pattern="/images/pattern-waves.svg" size="80px 80px" opacity="opacity-30" />
        <DecorativeElement src="/images/deco-multi-pins.svg" position="top-16 right-4 md:right-12" size="w-20 md:w-28" opacity="opacity-40" />
        <DecorativeElement src="/images/deco-flecha-curva.svg" position="bottom-32 left-4 md:left-12" size="w-16 md:w-24" opacity="opacity-35" rotate="rotate-12" />

    <div class="container mx-auto max-w-7xl px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />
    </div>

    <!-- Hero section -->
    <section id="hero" class="py-16" aria-labelledby="hero-heading">
        <div class="container mx-auto max-w-4xl px-4 text-center">
            <h1
                id="hero-heading"
                class="mb-6 text-4xl font-bold leading-tight text-foreground md:text-5xl lg:text-6xl"
            >
                {hero.headline}
            </h1>
            <p class="mb-10 text-xl leading-relaxed text-muted-foreground md:text-2xl">
                {hero.subheadline}
            </p>
            <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
                <GradientButton
                    href={buildUrl({ locale, path: 'auth/signup' })}
                    label={hero.ctaPrimary}
                    showArrow={true}
                />
                <a
                    href={buildUrl({ locale, path: 'precios/propietarios' })}
                    class="inline-flex items-center justify-center rounded-full border-2 border-primary px-8 py-2 text-sm font-medium text-primary transition-colors hover:bg-primary hover:text-primary-foreground focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                >
                    {hero.ctaSecondary}
                </a>
            </div>
        </div>
    </section>

    <!-- Benefits section -->
    <section id="benefits" class="scroll-reveal py-16 bg-muted/30" aria-labelledby="benefits-heading">
        <div class="container mx-auto max-w-7xl px-4">
            <header class="mb-12 text-center">
                <h2
                    id="benefits-heading"
                    class="mb-4 text-3xl font-bold text-foreground md:text-4xl"
                >
                    {benefits.sectionTitle}
                </h2>
                <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
                    {benefits.sectionSubtitle}
                </p>
            </header>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {benefits.benefits.map((benefit) => (
                    <article class="flex flex-col gap-4 rounded-xl border border-border bg-card p-6 shadow-sm transition-shadow hover:shadow-md">
                        <div
                            class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 text-primary"
                            aria-hidden="true"
                        >
                            {benefit.icon === 'search' && <SearchIcon size="lg" weight="duotone" />}
                            {benefit.icon === 'dashboard' && <DashboardIcon size="lg" weight="duotone" />}
                            {benefit.icon === 'star' && <StarIcon size="lg" weight="duotone" />}
                            {benefit.icon === 'statistics' && <StatisticsIcon size="lg" weight="duotone" />}
                            {benefit.icon === 'chat' && <ChatIcon size="lg" weight="duotone" />}
                            {benefit.icon === 'settings' && <SettingsIcon size="lg" weight="duotone" />}
                        </div>
                        <h3 class="text-xl font-semibold text-foreground">{benefit.title}</h3>
                        <p class="leading-relaxed text-muted-foreground">{benefit.description}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <!-- How it works section -->
    <section id="how-it-works" class="scroll-reveal py-16" aria-labelledby="how-it-works-heading">
        <div class="container mx-auto max-w-4xl px-4">
            <header class="mb-12 text-center">
                <h2
                    id="how-it-works-heading"
                    class="mb-4 text-3xl font-bold text-foreground md:text-4xl"
                >
                    {howItWorks.sectionTitle}
                </h2>
                <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
                    {howItWorks.sectionSubtitle}
                </p>
            </header>
            <ol class="space-y-8" aria-label={howItWorks.sectionTitle}>
                {howItWorks.steps.map((step) => (
                    <li class="flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-6">
                        <div
                            class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-primary text-2xl font-bold text-primary-foreground"
                            aria-hidden="true"
                        >
                            {step.number}
                        </div>
                        <div class="pt-1">
                            <h3 class="mb-2 text-xl font-semibold text-foreground">{step.title}</h3>
                            <p class="leading-relaxed text-muted-foreground">{step.description}</p>
                        </div>
                    </li>
                ))}
            </ol>
        </div>
    </section>

    <!-- FAQ section -->
    <section id="faq" class="scroll-reveal py-16 bg-muted/30" aria-labelledby="faq-heading">
        <div class="container mx-auto max-w-3xl px-4">
            <header class="mb-10 text-center">
                <h2
                    id="faq-heading"
                    class="text-3xl font-bold text-foreground md:text-4xl"
                >
                    {faq.sectionTitle}
                </h2>
            </header>
            <AccordionFAQ
                items={faq.faqs}
                ariaLabel={faq.sectionTitle}
                allowMultiple={false}
            />
        </div>
    </section>

    <!-- Final CTA section (full-width gradient) -->
    <section
        id="final-cta"
        class="bg-gradient-to-r from-primary to-hospeda-river py-16"
        aria-labelledby="final-cta-heading"
    >
        <div class="container mx-auto max-w-3xl px-4 text-center">
            <h2
                id="final-cta-heading"
                class="mb-4 text-3xl font-bold text-primary-foreground md:text-4xl"
            >
                {finalCta.title}
            </h2>
            <p class="mb-10 text-lg leading-relaxed text-primary-foreground/90">
                {finalCta.subtitle}
            </p>
            <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
                <a
                    href={buildUrl({ locale, path: 'auth/signup' })}
                    class="inline-flex items-center justify-center rounded-full bg-card px-8 py-3 text-lg font-semibold text-primary transition-colors hover:bg-card/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-card"
                >
                    {finalCta.ctaPrimary}
                </a>
                <a
                    href={buildUrl({ locale, path: 'precios/propietarios' })}
                    class="inline-flex items-center justify-center rounded-full border-2 border-primary-foreground px-8 py-3 text-lg font-semibold text-primary-foreground transition-colors hover:bg-primary-foreground/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-foreground"
                >
                    {finalCta.ctaSecondary}
                </a>
            </div>
        </div>
    </section>
    </div>
</BaseLayout>
