---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../../lib/page-helpers';

/**
 * Property Owners (Propietarios) landing page.
 * Presents the value proposition for accommodation owners to list on Hospeda.
 *
 * @route /[lang]/propietarios/
 * @rendering SSG (Static Site Generation)
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import JsonLd from '../../../components/seo/JsonLd.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import {
	SearchIcon,
	DashboardIcon,
	StarIcon,
	StatisticsIcon,
	ChatIcon,
	SettingsIcon,
	CheckIcon,
} from '@repo/icons';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { t } from '../../../lib/i18n';
import { OWNER_HERO, OWNER_BENEFITS, OWNER_HOW_IT_WORKS, OWNER_FAQ, OWNER_FINAL_CTA } from '../../../lib/owners-page-data';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const pageTitle = t({ locale, namespace: 'owners', key: 'page.title' });
const pageDescription = t({ locale, namespace: 'owners', key: 'page.description' });
const breadcrumbLabel = t({ locale, namespace: 'owners', key: 'page.breadcrumb' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: breadcrumbLabel, href: `/${locale}/propietarios/` },
];

const hero = OWNER_HERO[locale];
const benefits = OWNER_BENEFITS[locale];
const howItWorks = OWNER_HOW_IT_WORKS[locale];
const faq = OWNER_FAQ[locale];
const finalCta = OWNER_FINAL_CTA[locale];

/**
 * FAQPage JSON-LD structured data
 */
const faqJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faq.faqs.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={pageDescription}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
	/>
	<JsonLd slot="head" data={faqJsonLd} />

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<!-- Hero Section -->
		<Section id="hero">
			<div class="mx-auto max-w-4xl text-center">
				<h1 class="mb-6 text-4xl font-bold leading-tight text-text-primary md:text-5xl lg:text-6xl">
					{hero.headline}
				</h1>
				<p class="mb-10 text-xl leading-relaxed text-text-secondary md:text-2xl">
					{hero.subheadline}
				</p>
				<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a
						href={`/${locale}/auth/signup/`}
						class="inline-flex items-center justify-center rounded-lg bg-primary px-8 py-4 text-lg font-semibold text-white transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
					>
						{hero.ctaPrimary}
					</a>
					<a
						href={`/${locale}/precios/propietarios/`}
						class="inline-flex items-center justify-center rounded-lg border-2 border-primary px-8 py-4 text-lg font-semibold text-primary transition-colors hover:bg-primary hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
					>
						{hero.ctaSecondary}
					</a>
				</div>
			</div>
		</Section>

		<!-- Benefits Grid Section -->
		<Section
			id="benefits"
			title={benefits.sectionTitle}
			subtitle={benefits.sectionSubtitle}
		>
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{benefits.benefits.map((benefit) => (
					<article class="flex flex-col gap-4 rounded-xl bg-surface p-6 shadow-sm transition-shadow hover:shadow-md">
						<div
							class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 text-primary"
							aria-hidden="true"
						>
							{benefit.icon === 'search' && <SearchIcon size="lg" weight="duotone" />}
							{benefit.icon === 'dashboard' && <DashboardIcon size="lg" weight="duotone" />}
							{benefit.icon === 'star' && <StarIcon size="lg" weight="duotone" />}
							{benefit.icon === 'statistics' && <StatisticsIcon size="lg" weight="duotone" />}
							{benefit.icon === 'chat' && <ChatIcon size="lg" weight="duotone" />}
							{benefit.icon === 'settings' && <SettingsIcon size="lg" weight="duotone" />}
						</div>
						<h3 class="text-xl font-semibold text-text-primary">{benefit.title}</h3>
						<p class="leading-relaxed text-text-secondary">{benefit.description}</p>
					</article>
				))}
			</div>
		</Section>

		<!-- How It Works Section -->
		<Section
			id="how-it-works"
			title={howItWorks.sectionTitle}
			subtitle={howItWorks.sectionSubtitle}
			class="bg-surface/50"
		>
			<ol class="mx-auto max-w-4xl space-y-8" aria-label={howItWorks.sectionTitle}>
				{howItWorks.steps.map((step) => (
					<li class="flex flex-col gap-4 sm:flex-row sm:items-start sm:gap-6">
						<div
							class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-primary text-2xl font-bold text-white"
							aria-hidden="true"
						>
							{step.number}
						</div>
						<div class="pt-1">
							<h3 class="mb-2 text-xl font-semibold text-text-primary">{step.title}</h3>
							<p class="leading-relaxed text-text-secondary">{step.description}</p>
						</div>
					</li>
				))}
			</ol>
		</Section>

		<!-- FAQ Section -->
		<Section id="faq" title={faq.sectionTitle}>
			<div class="mx-auto max-w-3xl space-y-4">
				{faq.faqs.map((item, index) => (
					<details
						class="group rounded-xl border border-border bg-surface shadow-sm transition-shadow hover:shadow-md"
					>
						<summary
							class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 font-semibold text-text-primary marker:hidden focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary [&::-webkit-details-marker]:hidden"
							id={`faq-question-${index}`}
						>
							<span>{item.question}</span>
							<span
								class="ml-2 shrink-0 text-primary transition-transform duration-200 group-open:rotate-180"
								aria-hidden="true"
							>
								<CheckIcon size="sm" weight="bold" />
							</span>
						</summary>
						<div class="border-t border-border px-6 pb-5 pt-4">
							<p class="leading-relaxed text-text-secondary">{item.answer}</p>
						</div>
					</details>
				))}
			</div>
		</Section>
	</Container>

	<!-- Final CTA Section (full-width gradient) -->
	<section
		id="final-cta"
		class="bg-gradient-to-r from-primary to-primary-dark py-16"
		aria-labelledby="final-cta-title"
	>
		<Container>
			<div class="mx-auto max-w-3xl text-center">
				<h2
					id="final-cta-title"
					class="mb-4 text-3xl font-bold text-white md:text-4xl"
				>
					{finalCta.title}
				</h2>
				<p class="mb-10 text-lg leading-relaxed text-white/90">
					{finalCta.subtitle}
				</p>
				<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a
						href={`/${locale}/auth/signup/`}
						class="inline-flex items-center justify-center rounded-lg bg-white dark:bg-surface px-8 py-4 text-lg font-semibold text-primary transition-colors hover:bg-white/90 dark:hover:bg-surface/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
					>
						{finalCta.ctaPrimary}
					</a>
					<a
						href={`/${locale}/precios/propietarios/`}
						class="inline-flex items-center justify-center rounded-lg border-2 border-white dark:border-surface px-8 py-4 text-lg font-semibold text-white transition-colors hover:bg-white/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
					>
						{finalCta.ctaSecondary}
					</a>
				</div>
			</div>
		</Container>
	</section>
</BaseLayout>
