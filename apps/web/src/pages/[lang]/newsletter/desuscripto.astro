---
/**
 * @file [lang]/newsletter/desuscripto.astro
 * @description Unsubscribe confirmation page (SPEC-101 T-101-36).
 *
 * Landing page the API redirects the user to after a successful
 * `GET /api/v1/public/newsletter/unsubscribe?token=…`.
 *
 * Per UX §5.4: NO marketing content on this page. Just the
 * confirmation message and a small re-subscribe escape hatch in case
 * the unsubscribe was a mistake.
 *
 * Server-rendered, no JavaScript, noindex.
 */

import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { MailIcon } from '@repo/icons';

const lang = (Astro.params.lang ?? 'es') as SupportedLocale;
const { t } = createTranslations(lang);

const pageTitle = t('newsletter.unsubscribePage.title', 'Tu suscripción fue cancelada.');
const pageDescription = t(
    'newsletter.unsubscribePage.description',
    'Ya no recibirás emails de Hospeda.'
);
const resubscribeLink = t(
    'newsletter.unsubscribePage.resubscribeLink',
    'Si fue un error, volver a suscribirme'
);

// Re-subscribe target: authenticated users go to the account preferences
// page (resubscribe is one click there); guests go through signin with
// a redirect so the post-login flow lands them on the same page. The
// session check happens via Astro.locals.user (populated by middleware
// — narrowed via an explicit cast because the project's App.Locals type
// does not yet declare `user`; same pattern as MobileMenuIsland.astro).
const locals = Astro.locals as { user?: { id: string; email: string } | null };
const isAuthenticated = Boolean(locals.user);
const resubscribeHref = isAuthenticated
    ? `/${lang}/mi-cuenta/newsletter/`
    : `/${lang}/auth/signin/?redirect=${encodeURIComponent(`/${lang}/mi-cuenta/newsletter/`)}`;

// Split title to underline the last word with a handwritten accent.
const titleWords = pageTitle.trim().split(/\s+/);
const titleAccent = titleWords.pop() ?? pageTitle;
const titleMain = titleWords.join(' ');
---

<DefaultLayout
    locale={lang}
    title={pageTitle}
    description={pageDescription}
    noindex={true}
>
    <main class="newsletter-unsub">
        <div class="newsletter-unsub__decoratives" aria-hidden="true">
            <div class="newsletter-unsub__blob"></div>
            <span class="newsletter-unsub__dot newsletter-unsub__dot--1"></span>
            <span class="newsletter-unsub__dot newsletter-unsub__dot--2"></span>
        </div>
        <div class="newsletter-unsub__card">
            <div class="newsletter-unsub__icon-wrap" aria-hidden="true">
                <MailIcon size={96} weight="duotone" />
            </div>
            <h1 class="newsletter-unsub__title">
                {titleMain && <>{titleMain}{' '}</>}
                <span class="newsletter-unsub__title-accent">
                    {titleAccent}
                    <svg
                        class="newsletter-unsub__title-underline"
                        viewBox="0 0 200 18"
                        preserveAspectRatio="none"
                        aria-hidden="true"
                    >
                        <path
                            d="M 4 12 Q 50 2, 100 10 T 196 8"
                            stroke="currentColor"
                            stroke-width="4"
                            stroke-linecap="round"
                            fill="none"
                        />
                    </svg>
                </span>
            </h1>
            <p class="newsletter-unsub__description">{pageDescription}</p>

            <a class="newsletter-unsub__resubscribe" href={resubscribeHref}>
                {resubscribeLink}
            </a>
        </div>
    </main>
</DefaultLayout>

<style>
    .newsletter-unsub {
        position: relative;
        max-width: 560px;
        margin: 0 auto;
        padding: clamp(5rem, 12vw, 10rem) var(--space-4);
    }

    .newsletter-unsub__decoratives {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .newsletter-unsub__blob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(280px, 60vw, 520px);
        height: clamp(280px, 60vw, 520px);
        border-radius: 50%;
        background: radial-gradient(
            circle at 50% 50%,
            oklch(from var(--brand-primary) l c h / 0.14),
            oklch(from var(--brand-primary) l c h / 0.05) 55%,
            transparent 75%
        );
        filter: blur(4px);
    }

    .newsletter-unsub__dot {
        position: absolute;
        border-radius: 50%;
    }
    .newsletter-unsub__dot--1 {
        top: 18%;
        left: 12%;
        width: 12px;
        height: 12px;
        background-color: oklch(from var(--brand-primary) l c h / 0.28);
    }
    .newsletter-unsub__dot--2 {
        bottom: 22%;
        right: 14%;
        width: 9px;
        height: 9px;
        background-color: oklch(from var(--brand-accent) l c h / 0.3);
    }

    .newsletter-unsub__card {
        position: relative;
        z-index: 1;
        background-color: var(--surface-elevated);
        border-radius: var(--radius-lg);
        padding: var(--space-8) var(--space-6);
        text-align: center;
    }

    .newsletter-unsub__icon-wrap {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 128px;
        height: 128px;
        margin-bottom: var(--space-5);
        border-radius: 50%;
        background-color: oklch(from var(--brand-primary) l c h / 0.12);
        color: var(--brand-primary);
        box-shadow: 0 8px 24px oklch(from var(--brand-primary) l c h / 0.18);
    }

    .newsletter-unsub__title-accent {
        position: relative;
        display: inline-block;
    }

    .newsletter-unsub__title-underline {
        position: absolute;
        left: -3%;
        right: -3%;
        bottom: -0.08em;
        width: 106%;
        height: 0.32em;
        color: var(--brand-primary);
        opacity: 0.7;
        pointer-events: none;
    }

    .newsletter-unsub__title {
        margin: 0 0 var(--space-3);
        font-family: var(--font-heading);
        font-size: var(--text-h3);
        line-height: 1.2;
    }

    .newsletter-unsub__description {
        margin: 0 0 var(--space-6);
        font-size: var(--text-body);
        line-height: 1.5;
    }

    .newsletter-unsub__resubscribe {
        display: inline-block;
        font-size: var(--text-body-sm);
        color: var(--primary);
        text-decoration: underline;
    }
</style>
