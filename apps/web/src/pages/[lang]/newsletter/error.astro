---
/**
 * @file [lang]/newsletter/error.astro
 * @description Verification error page (SPEC-101 T-101-37).
 *
 * Where the API redirects when a verify / unsubscribe token is bad:
 *   GET /api/v1/public/newsletter/error/?reason={token_expired|invalid_token}
 *
 * The page reads the `reason` query and renders a friendly message
 * (no tech jargon) plus a recovery action:
 *   - token_expired + authenticated → resend button (POST /resend-verification)
 *   - token_expired + guest         → sign-in link (with redirect back here)
 *   - invalid_token (any auth)      → generic "this link is no longer valid"
 *
 * Server-rendered, noindex. The resend action below the headline is a
 * tiny inline form that POSTs to the protected endpoint and reloads.
 */

import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { AlertCircleIcon } from '@repo/icons';

const lang = (Astro.params.lang ?? 'es') as SupportedLocale;
const { t } = createTranslations(lang);

const rawReason = (Astro.url.searchParams.get('reason') ?? '').trim();
const reason: 'token_expired' | 'invalid_token' =
    rawReason === 'token_expired' ? 'token_expired' : 'invalid_token';

// App.Locals does not declare `user` yet — same workaround as
// MobileMenuIsland.astro / desuscripto.astro.
const locals = Astro.locals as { user?: { id: string; email: string } | null };
const isAuthenticated = Boolean(locals.user);

const titleKey =
    reason === 'token_expired'
        ? 'newsletter.errorPage.tokenExpiredTitle'
        : 'newsletter.errorPage.invalidTokenTitle';
const titleFb =
    reason === 'token_expired' ? 'El enlace expiró' : 'Enlace inválido';

const descriptionKey =
    reason === 'token_expired'
        ? 'newsletter.errorPage.tokenExpiredDescription'
        : 'newsletter.errorPage.invalidTokenDescription';
const descriptionFb =
    reason === 'token_expired'
        ? 'El enlace de confirmación expiró. Podés solicitar uno nuevo.'
        : 'El enlace de confirmación no es válido.';

const pageTitle = t(titleKey, titleFb);
const pageDescription = t(descriptionKey, descriptionFb);

// Split title to underline the last word with a handwritten accent.
const titleWords = pageTitle.trim().split(/\s+/);
const titleAccent = titleWords.pop() ?? pageTitle;
const titleMain = titleWords.join(' ');

const resendLabel = t('newsletter.errorPage.resendButton', 'Reenviar email de confirmación');
const signInHref = `/${lang}/auth/signin/?redirect=${encodeURIComponent(
    `/${lang}/newsletter/error/?reason=${reason}`
)}`;
---

<DefaultLayout
    locale={lang}
    title={pageTitle}
    description={pageDescription}
    noindex={true}
>
    <main class="newsletter-error">
        <div class="newsletter-error__decoratives" aria-hidden="true">
            <div class="newsletter-error__blob"></div>
            <span class="newsletter-error__dot newsletter-error__dot--1"></span>
            <span class="newsletter-error__dot newsletter-error__dot--2"></span>
        </div>
        <div class="newsletter-error__card">
            <div class="newsletter-error__icon-wrap" aria-hidden="true">
                <AlertCircleIcon size={96} weight="duotone" />
            </div>
            <h1 class="newsletter-error__title">
                {titleMain && <>{titleMain}{' '}</>}
                <span class="newsletter-error__title-accent">
                    {titleAccent}
                    <svg
                        class="newsletter-error__title-underline"
                        viewBox="0 0 200 18"
                        preserveAspectRatio="none"
                        aria-hidden="true"
                    >
                        <path
                            d="M 4 12 Q 50 2, 100 10 T 196 8"
                            stroke="currentColor"
                            stroke-width="4"
                            stroke-linecap="round"
                            fill="none"
                        />
                    </svg>
                </span>
            </h1>
            <p class="newsletter-error__description">{pageDescription}</p>

            {reason === 'token_expired' && (
                <>
                    {isAuthenticated ? (
                        <form
                            method="post"
                            action="/api/v1/protected/newsletter/resend-verification"
                            class="newsletter-error__resend"
                        >
                            <button class="newsletter-error__button" type="submit">
                                {resendLabel}
                            </button>
                        </form>
                    ) : (
                        <a class="newsletter-error__button" href={signInHref}>
                            {resendLabel}
                        </a>
                    )}
                </>
            )}
        </div>
    </main>
</DefaultLayout>

<style>
    .newsletter-error {
        position: relative;
        max-width: 560px;
        margin: 0 auto;
        padding: clamp(5rem, 12vw, 10rem) var(--space-4);
    }

    .newsletter-error__decoratives {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .newsletter-error__blob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(280px, 60vw, 520px);
        height: clamp(280px, 60vw, 520px);
        border-radius: 50%;
        background: radial-gradient(
            circle at 50% 50%,
            oklch(0.62 0.2 30 / 0.16),
            oklch(0.62 0.2 30 / 0.05) 55%,
            transparent 75%
        );
        filter: blur(4px);
    }

    .newsletter-error__dot {
        position: absolute;
        border-radius: 50%;
    }
    .newsletter-error__dot--1 {
        top: 18%;
        right: 12%;
        width: 12px;
        height: 12px;
        background-color: oklch(0.62 0.2 30 / 0.3);
    }
    .newsletter-error__dot--2 {
        bottom: 22%;
        left: 14%;
        width: 9px;
        height: 9px;
        background-color: oklch(from var(--brand-accent) l c h / 0.3);
    }

    .newsletter-error__card {
        position: relative;
        z-index: 1;
        background-color: var(--surface-elevated);
        border-radius: var(--radius-lg);
        padding: var(--space-8) var(--space-6);
        text-align: center;
    }

    .newsletter-error__icon-wrap {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 128px;
        height: 128px;
        margin-bottom: var(--space-5);
        border-radius: 50%;
        background-color: oklch(0.62 0.2 30 / 0.12);
        color: oklch(0.55 0.2 30);
        box-shadow: 0 8px 24px oklch(0.62 0.2 30 / 0.18);
    }

    .newsletter-error__title-accent {
        position: relative;
        display: inline-block;
    }

    .newsletter-error__title-underline {
        position: absolute;
        left: -3%;
        right: -3%;
        bottom: -0.08em;
        width: 106%;
        height: 0.32em;
        color: oklch(0.55 0.2 30);
        opacity: 0.7;
        pointer-events: none;
    }

    .newsletter-error__title {
        margin: 0 0 var(--space-3);
        font-family: var(--font-heading);
        font-size: var(--text-h3);
        line-height: 1.2;
    }

    .newsletter-error__description {
        margin: 0 0 var(--space-6);
        font-size: var(--text-body);
        line-height: 1.5;
    }

    .newsletter-error__resend {
        margin: 0;
    }

    .newsletter-error__button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-2) var(--space-5);
        border: none;
        border-radius: var(--radius-button);
        background-color: var(--primary);
        color: var(--primary-foreground);
        font-size: var(--text-button);
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
    }
</style>
