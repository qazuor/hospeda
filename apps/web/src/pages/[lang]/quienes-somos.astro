---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../lib/page-helpers';

/**
 * About Us page - information about Hospeda platform, mission, values, and the region.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../lib/page-helpers';
import { t } from '../../lib/i18n';
import { CheckIcon, UsersIcon, CheckCircleIcon, GlobeIcon } from '@repo/icons';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const pageTitle = t({ locale, namespace: 'about', key: 'page.title' });
const pageDescription = t({ locale, namespace: 'about', key: 'page.description' });
const heroText = t({ locale, namespace: 'about', key: 'page.heroText' });
const missionTitle = t({ locale, namespace: 'about', key: 'page.missionTitle' });
const missionText = t({ locale, namespace: 'about', key: 'page.missionText' });
const valuesTitle = t({ locale, namespace: 'about', key: 'page.valuesTitle' });
const regionTitle = t({ locale, namespace: 'about', key: 'page.regionTitle' });
const regionText1 = t({ locale, namespace: 'about', key: 'page.regionText1' });
const regionText2 = t({ locale, namespace: 'about', key: 'page.regionText2' });
const ctaTitle = t({ locale, namespace: 'about', key: 'page.ctaTitle' });
const ctaText = t({ locale, namespace: 'about', key: 'page.ctaText' });
const ctaButton = t({ locale, namespace: 'about', key: 'page.ctaButton' });

/**
 * Values content built from i18n keys
 */
const values = [
	{
		title: t({ locale, namespace: 'about', key: 'page.values.authenticity.title' }),
		text: t({ locale, namespace: 'about', key: 'page.values.authenticity.text' }),
	},
	{
		title: t({ locale, namespace: 'about', key: 'page.values.community.title' }),
		text: t({ locale, namespace: 'about', key: 'page.values.community.text' }),
	},
	{
		title: t({ locale, namespace: 'about', key: 'page.values.quality.title' }),
		text: t({ locale, namespace: 'about', key: 'page.values.quality.text' }),
	},
	{
		title: t({ locale, namespace: 'about', key: 'page.values.sustainability.title' }),
		text: t({ locale, namespace: 'about', key: 'page.values.sustainability.text' }),
	},
];

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: pageTitle, href: `/${locale}/quienes-somos/` },
];

/**
 * Icon components in order corresponding to values array entries:
 * Authenticity, Community, Quality, Sustainability
 */
const valueIcons = [CheckIcon, UsersIcon, CheckCircleIcon, GlobeIcon];
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={pageDescription}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-4xl">
				<!-- Hero Section -->
				<article id="hero" class="mb-12 text-center">
					<h1 class="mb-6 text-4xl font-bold text-text-primary md:text-5xl">
						{pageTitle}
					</h1>
					<p class="text-xl leading-relaxed text-text-secondary">
						{heroText}
					</p>
				</article>

				<!-- Mission Section -->
				<article id="mission" class="mb-12">
					<div class="rounded-lg bg-bg p-8 shadow-sm">
						<h2 class="mb-4 text-3xl font-semibold text-text-primary">{missionTitle}</h2>
						<p class="text-lg leading-relaxed text-text-secondary">
							{missionText}
						</p>
					</div>
				</article>

				<!-- Values Section -->
				<article id="values" class="mb-12">
					<h2 class="mb-8 text-center text-3xl font-semibold text-text-primary">
						{valuesTitle}
					</h2>
					<div class="grid gap-8 md:grid-cols-2">
						{
							values.map((value, index) => {
								const IconComponent = valueIcons[index];
								return (
									<div class="flex flex-col items-center text-center">
										<div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10">
											<IconComponent
												size={32}
												className="text-primary"
												aria-hidden="true"
											/>
										</div>
										<h3 class="mb-2 text-xl font-semibold text-text-primary">
											{value.title}
										</h3>
										<p class="text-text-secondary">{value.text}</p>
									</div>
								);
							})
						}
					</div>
				</article>

				<!-- Region Section -->
				<article id="region" class="mb-12">
					<div class="rounded-lg bg-bg p-8 shadow-sm">
						<h2 class="mb-4 text-3xl font-semibold text-text-primary">{regionTitle}</h2>
						<p class="mb-4 text-lg leading-relaxed text-text-secondary">
							{regionText1}
						</p>
						<p class="text-lg leading-relaxed text-text-secondary">
							{regionText2}
						</p>
					</div>
				</article>

				<!-- Contact CTA Section -->
				<article id="contact-cta" class="mb-12">
					<div
						class="rounded-lg bg-primary/10 p-8 text-center shadow-sm transition-shadow hover:shadow-md"
					>
						<h2 class="mb-4 text-3xl font-semibold text-text-primary">
							{ctaTitle}
						</h2>
						<p class="mb-6 text-lg leading-relaxed text-text-secondary">
							{ctaText}
						</p>
						<a
							href={`/${locale}/contacto/`}
							class="inline-block rounded-lg bg-primary px-8 py-3 font-semibold text-white transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
						>
							{ctaButton}
						</a>
					</div>
				</article>
			</div>
		</Section>
	</Container>
</BaseLayout>
