---
/**
 * About Us page.
 * Describes Hospeda's mission, core values, the Litoral region context,
 * and includes a contact CTA at the bottom.
 *
 * Rendering: SSG (pre-rendered at build time for all supported locales).
 * Route: /[lang]/quienes-somos/
 */
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../lib/page-helpers';

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import BackgroundPattern from '../../components/shared/BackgroundPattern.astro';
import DecorativeElement from '../../components/shared/DecorativeElement.astro';
import GradientButton from '../../components/shared/GradientButton.astro';
import { CheckIcon, UsersIcon, CheckCircleIcon, GlobeIcon } from '@repo/icons';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../lib/page-helpers';
import { createT } from '../../lib/i18n';
import { buildUrl } from '../../lib/urls';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/quienes-somos/');

/** Translation helper bound to this locale. */
const t = createT(locale);

const pageTitle = t('about.page.title', 'Quienes somos');
const pageDescription = t('about.page.description', 'Conoce al equipo detras de Hospeda y nuestra mision');
const heroText = t('about.page.heroText', 'Conectamos viajeros con los mejores alojamientos del Litoral argentino');
const missionTitle = t('about.page.missionTitle', 'Nuestra mision');
const missionText = t('about.page.missionText', 'Facilitar la conexion entre viajeros y propietarios locales para impulsar el turismo regional');
const valuesTitle = t('about.page.valuesTitle', 'Nuestros valores');
const regionTitle = t('about.page.regionTitle', 'La region del Litoral');
const regionText1 = t('about.page.regionText1', 'Entre Rios es una provincia de Argentina con una riqueza natural y cultural unica');
const regionText2 = t('about.page.regionText2', 'Desde sus playas fluviales hasta su famoso Carnaval, la region ofrece experiencias memorables');
const ctaTitle = t('about.page.ctaTitle', 'Queres saber mas?');
const ctaText = t('about.page.ctaText', 'Escribinos y te respondemos a la brevedad');
const ctaButton = t('about.page.ctaButton', 'Contactanos');

/**
 * Values content built from i18n keys.
 * Icon components correspond to values in order: Authenticity, Community, Quality, Sustainability.
 */
const values = [
    {
        icon: CheckIcon,
        title: t('about.page.values.authenticity.title', 'Autenticidad'),
        text: t('about.page.values.authenticity.text', 'Promovemos experiencias genuinas y locales')
    },
    {
        icon: UsersIcon,
        title: t('about.page.values.community.title', 'Comunidad'),
        text: t('about.page.values.community.text', 'Trabajamos junto a las comunidades locales')
    },
    {
        icon: CheckCircleIcon,
        title: t('about.page.values.quality.title', 'Calidad'),
        text: t('about.page.values.quality.text', 'Verificamos cada alojamiento para garantizar la mejor experiencia')
    },
    {
        icon: GlobeIcon,
        title: t('about.page.values.sustainability.title', 'Sustentabilidad'),
        text: t('about.page.values.sustainability.text', 'Impulsamos el turismo responsable con el medio ambiente')
    }
] as const;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items.
 */
const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
    { label: pageTitle, href: buildUrl({ locale, path: 'quienes-somos' }) }
] as const;
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale}
        type="website"
    />

    <div class="relative overflow-hidden">
        <BackgroundPattern pattern="/images/pattern-topo.svg" size="80px 80px" opacity="opacity-35" />
        <DecorativeElement src="/images/deco-rio-uruguay.svg" position="top-12 right-4 md:right-12" size="w-24 md:w-36" opacity="opacity-40" />
        <DecorativeElement src="/images/deco-kayak.svg" position="bottom-12 left-4 md:left-16" size="w-20 md:w-32" opacity="opacity-35" rotate="rotate-6" />

    <div class="container mx-auto max-w-7xl px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />

        <div class="mx-auto max-w-4xl py-8">
            <!-- Hero section -->
            <header class="mb-12 text-center" id="hero">
                <h1 class="mb-6 text-4xl font-bold text-foreground md:text-5xl">
                    {pageTitle}
                </h1>
                <p class="text-xl leading-relaxed text-muted-foreground">
                    {heroText}
                </p>
            </header>

            <!-- Mission section -->
            <section id="mission" class="scroll-reveal mb-12" aria-labelledby="mission-heading">
                <div class="rounded-xl border border-border bg-card p-8 shadow-sm">
                    <h2
                        id="mission-heading"
                        class="mb-4 text-3xl font-semibold text-foreground"
                    >
                        {missionTitle}
                    </h2>
                    <p class="text-lg leading-relaxed text-muted-foreground">
                        {missionText}
                    </p>
                </div>
            </section>

            <!-- Values section -->
            <section id="values" class="scroll-reveal mb-12" aria-labelledby="values-heading">
                <h2
                    id="values-heading"
                    class="mb-8 text-center text-3xl font-semibold text-foreground"
                >
                    {valuesTitle}
                </h2>
                <div class="grid gap-8 md:grid-cols-2">
                    {values.map(({ icon: IconComponent, title, text }) => (
                        <div class="flex flex-col items-center text-center">
                            <div
                                class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
                                aria-hidden="true"
                            >
                                <IconComponent
                                    size={32}
                                    className="text-primary"
                                    aria-hidden="true"
                                />
                            </div>
                            <h3 class="mb-2 text-xl font-semibold text-foreground">
                                {title}
                            </h3>
                            <p class="text-muted-foreground">{text}</p>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Region section -->
            <section id="region" class="scroll-reveal mb-12" aria-labelledby="region-heading">
                <div class="rounded-xl border border-border bg-card p-8 shadow-sm">
                    <h2
                        id="region-heading"
                        class="mb-4 text-3xl font-semibold text-foreground"
                    >
                        {regionTitle}
                    </h2>
                    <p class="mb-4 text-lg leading-relaxed text-muted-foreground">
                        {regionText1}
                    </p>
                    <p class="text-lg leading-relaxed text-muted-foreground">
                        {regionText2}
                    </p>
                </div>
            </section>

            <!-- Contact CTA section -->
            <section
                id="contact-cta"
                class="mb-12"
                aria-labelledby="cta-heading"
            >
                <div class="rounded-xl border border-border bg-primary/10 p-8 text-center shadow-sm transition-shadow hover:shadow-md">
                    <h2
                        id="cta-heading"
                        class="mb-4 text-3xl font-semibold text-foreground"
                    >
                        {ctaTitle}
                    </h2>
                    <p class="mb-6 text-lg leading-relaxed text-muted-foreground">
                        {ctaText}
                    </p>
                    <GradientButton
                        href={buildUrl({ locale, path: 'contacto' })}
                        label={ctaButton}
                        showArrow={true}
                    />
                </div>
            </section>
        </div>
    </div>
    </div>
</BaseLayout>
