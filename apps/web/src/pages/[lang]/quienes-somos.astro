---
export const prerender = true;

export function getStaticPaths() {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

/**
 * About Us page - information about Hospeda platform, mission, values, and the region.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import { isValidLocale, type SupportedLocale } from '../../lib/i18n';
import { CheckIcon, UsersIcon, CheckCircleIcon, GlobeIcon } from '@repo/icons';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * Localized page titles
 */
const titles: Record<SupportedLocale, string> = {
	es: 'Quienes Somos',
	en: 'About Us',
	pt: 'Sobre Nós',
};

/**
 * Localized meta descriptions
 */
const descriptions: Record<SupportedLocale, string> = {
	es: 'Descubre la misión, valores y propósito de Hospeda, la plataforma que conecta viajeros con alojamientos auténticos en el Litoral argentino',
	en: 'Discover the mission, values and purpose of Hospeda, the platform connecting travelers with authentic accommodations in the Argentine Litoral region',
	pt: 'Descubra a missão, valores e propósito da Hospeda, a plataforma que conecta viajantes com acomodações autênticas no Litoral argentino',
};

/**
 * Localized home breadcrumb labels
 */
const homeLabels: Record<SupportedLocale, string> = {
	es: 'Inicio',
	en: 'Home',
	pt: 'Início',
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: homeLabels[locale], href: `/${locale}/` },
	{ label: titles[locale], href: `/${locale}/quienes-somos/` },
];
---

<BaseLayout title={titles[locale]} description={descriptions[locale]} locale={locale}>
	<SEOHead
		slot="head"
		title={titles[locale]}
		description={descriptions[locale]}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-4xl">
				<!-- Hero Section -->
				<article id="hero" class="mb-12 text-center">
					<h1 class="mb-6 text-4xl font-bold text-text-primary md:text-5xl">
						{titles[locale]}
					</h1>
					<p class="text-xl leading-relaxed text-text-secondary">
						Hospeda es la plataforma que conecta viajeros con alojamientos auténticos y
						experiencias únicas en Concepción del Uruguay y la región del Litoral
						argentino. Creemos en el turismo responsable y en el valor de las conexiones
						genuinas.
					</p>
				</article>

				<!-- Mission Section -->
				<article id="mission" class="mb-12">
					<div class="rounded-lg bg-bg p-8 shadow-sm">
						<h2 class="mb-4 text-3xl font-semibold text-text-primary">Nuestra Misión</h2>
						<p class="text-lg leading-relaxed text-text-secondary">
							Conectar viajeros con alojamientos auténticos en la región del Litoral
							argentino, promoviendo el turismo responsable y sustentable. Facilitamos el
							descubrimiento de experiencias únicas y fomentamos el desarrollo económico
							local a través del turismo comunitario.
						</p>
					</div>
				</article>

				<!-- Values Section -->
				<article id="values" class="mb-12">
					<h2 class="mb-8 text-center text-3xl font-semibold text-text-primary">
						Nuestros Valores
					</h2>
					<div class="grid gap-8 md:grid-cols-2">
						<!-- Value 1: Authenticity -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<CheckIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Autenticidad</h3>
							<p class="text-text-secondary">
								Promovemos experiencias genuinas que reflejan la cultura y hospitalidad
								local del Litoral argentino.
							</p>
						</div>

						<!-- Value 2: Community -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<UsersIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Comunidad</h3>
							<p class="text-text-secondary">
								Fortalecemos el tejido social local apoyando emprendimientos turísticos y
								generando oportunidades económicas.
							</p>
						</div>

						<!-- Value 3: Quality -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<CheckCircleIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Calidad</h3>
							<p class="text-text-secondary">
								Nos comprometemos a ofrecer alojamientos verificados con altos estándares de
								confort y servicio.
							</p>
						</div>

						<!-- Value 4: Sustainability -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<GlobeIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Sustentabilidad</h3>
							<p class="text-text-secondary">
								Fomentamos prácticas turísticas responsables que preservan el patrimonio
								natural y cultural de la región.
							</p>
						</div>
					</div>
				</article>

				<!-- Region Section -->
				<article id="region" class="mb-12">
					<div class="rounded-lg bg-bg p-8 shadow-sm">
						<h2 class="mb-4 text-3xl font-semibold text-text-primary">Nuestra Región</h2>
						<p class="mb-4 text-lg leading-relaxed text-text-secondary">
							Concepción del Uruguay y la región del Litoral argentino ofrecen una
							combinación única de historia, naturaleza y cultura. Desde las costas del Río
							Uruguay hasta los paisajes rurales, nuestra región es el escenario perfecto
							para experiencias turísticas auténticas.
						</p>
						<p class="text-lg leading-relaxed text-text-secondary">
							La región se caracteriza por su rica herencia cultural, arquitectura colonial,
							festividades tradicionales, gastronomía local y la calidez de su gente.
							Promovemos el descubrimiento de estos tesoros a través de alojamientos que
							reflejan la identidad local.
						</p>
					</div>
				</article>

				<!-- Contact CTA Section -->
				<article id="contact-cta" class="mb-12">
					<div
						class="rounded-lg bg-primary/10 p-8 text-center shadow-sm transition-shadow hover:shadow-md"
					>
						<h2 class="mb-4 text-3xl font-semibold text-text-primary">
							Conectemos y Crezcamos Juntos
						</h2>
						<p class="mb-6 text-lg leading-relaxed text-text-secondary">
							¿Tienes preguntas o deseas formar parte de nuestra red de alojamientos? Nos
							encantaría conocerte y trabajar juntos para fortalecer el turismo en la
							región.
						</p>
						<a
							href={`/${locale}/contacto/`}
							class="inline-block rounded-lg bg-primary px-8 py-3 font-semibold text-white transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
						>
							Contáctanos
						</a>
					</div>
				</article>
			</div>
		</Section>
	</Container>
</BaseLayout>
