---
/**
 * @file [slug].astro
 * @description Accommodation detail page.
 *
 * Displays comprehensive information about a single accommodation:
 * - Hero image gallery with lightbox
 * - Title, category badge, star rating, location
 * - Rich-text description rendered from TipTap JSON
 * - Amenities grid
 * - Pricing sidebar with check-in / check-out times
 * - Interactive map showing the property location
 * - Reviews section (authenticated-aware server island)
 * - FAQ accordion
 * - Share and favourite buttons
 * - Related accommodations (up to 3 cards)
 * - Breadcrumb with destination hierarchy
 * - LodgingBusiness JSON-LD structured data
 *
 * Rendering: SSG (prerender = true) + server:defer islands for auth-aware content.
 * Route: /[lang]/alojamientos/[slug]
 */

export const prerender = true;

import type { AccommodationPublic } from '@repo/schemas';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import LodgingBusinessJsonLd from '../../../components/seo/LodgingBusinessJsonLd.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import AmenitiesList from '../../../components/shared/AmenitiesList.astro';
import AccordionFAQ from '../../../components/shared/AccordionFAQ.astro';
import AccommodationCard from '../../../components/shared/AccommodationCard.astro';
import FavoriteButtonIsland from '../../../components/shared/FavoriteButtonIsland.astro';
import ReviewListIsland from '../../../components/review/ReviewListIsland.astro';
import { ImageGallery } from '../../../components/shared/ImageGallery.client';
import { ShareButtons } from '../../../components/shared/ShareButtons.client';
import { MapView } from '../../../components/shared/MapView.client';
import { accommodationsApi } from '../../../lib/api/endpoints';
import { fetchAllPages } from '../../../lib/api/client';
import { createT } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';
import { extractFeaturedImageUrl, extractGalleryUrls } from '../../../lib/media';
import { renderTiptapContent } from '../../../lib/tiptap-renderer';
import { sanitizeHtml } from '../../../lib/sanitize-html';
import { toAccommodationCardProps } from '../../../lib/api/transforms';
import { getSiteUrl } from '../../../lib/env';
import { SUPPORTED_LOCALES, getLocaleFromParams } from '../../../lib/page-helpers';

/**
 * Generate static paths for all accommodation slugs across all locales.
 * Uses fetchAllPages to paginate through the full catalog.
 */
export async function getStaticPaths() {
    const accommodations = await fetchAllPages({
        fetcher: (p) => accommodationsApi.list(p),
    });

    return SUPPORTED_LOCALES.flatMap((lang) =>
        accommodations
            .filter((a) => Boolean(a.slug))
            .map((a) => ({
                params: { lang, slug: a.slug },
                props: { accommodation: a },
            }))
    );
}

// --- Locale validation ---

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const { slug } = Astro.params;

// --- Accommodation data ---
// Props come from getStaticPaths. Fallback fetch for dev/preview environments.
let accommodation = Astro.props.accommodation as AccommodationPublic | undefined;
if (!accommodation) {
    const result = await accommodationsApi.getBySlug({ slug: slug ?? '' });
    if (!result.ok) {
        return Astro.redirect(buildUrl({ locale, path: '404' }));
    }
    accommodation = result.data;
}

// --- Media extraction ---

const accRecord = accommodation as unknown as Record<string, unknown>;
const featuredImageUrl = extractFeaturedImageUrl(accRecord, '/images/placeholder-accommodation.svg');
const galleryUrls = extractGalleryUrls(accRecord);

/** Gallery images: prefer multi-image gallery, fall back to featured image. */
const galleryImages = galleryUrls.length > 0
    ? galleryUrls.map((url) => ({ src: url, alt: String(accommodation.name ?? '') }))
    : [{ src: featuredImageUrl, alt: String(accommodation.name ?? '') }];

// --- Rich-text description ---

const descriptionHtml = sanitizeHtml({
    html: renderTiptapContent({
        // description is stored as TipTap JSON in the API
        content: accommodation.description as Parameters<typeof renderTiptapContent>[0]['content'],
    }),
});

// --- Similar accommodations ---

const simResult = await accommodationsApi.list({ pageSize: 4 });
const allAccommodations = simResult.ok ? simResult.data.items : [];
const relatedCards = allAccommodations
    .filter((a) => a.id !== accommodation.id)
    .slice(0, 3)
    .map((item) => toAccommodationCardProps({ item: item as Record<string, unknown> }));

// --- Translations ---

const t = createT(locale);

const labels = {
    home: t('nav.home', 'Inicio'),
    accommodations: t('nav.accommodations', 'Alojamientos'),
    description: t('accommodations.detail.description', 'Descripcion'),
    amenities: t('accommodations.detail.amenities', 'Comodidades'),
    location: t('accommodations.detail.location', 'Ubicacion'),
    reviews: t('accommodations.detail.reviews', 'Resenas'),
    faq: t('accommodations.detail.faq', 'Preguntas frecuentes'),
    similar: t('accommodations.detail.similar', 'Alojamientos similares'),
    perNight: t('accommodations.detail.perNight', 'noche'),
    checkIn: t('accommodations.detail.checkIn', 'Check-in'),
    checkOut: t('accommodations.detail.checkOut', 'Check-out'),
    reviewsLabel: t('accommodations.detail.reviewsLabel', 'resenas'),
    inquire: t('accommodations.detail.inquire', 'Consultar precio'),
    noAmenities: t('accommodations.detail.noAmenities', 'Sin comodidades registradas'),
    noFaq: t('accommodations.detail.noFaq', 'Sin preguntas frecuentes'),
    noSimilar: t('accommodations.detail.noSimilar', 'Sin alojamientos similares'),
} as const;

// --- Breadcrumb ---

const breadcrumbItems = [
    { label: labels.home, href: buildUrl({ locale }) },
    { label: labels.accommodations, href: buildUrl({ locale, path: 'alojamientos' }) },
    { label: String(accommodation.name ?? ''), href: buildUrl({ locale, path: `alojamientos/${accommodation.slug}` }) },
];

// --- Page URL (for sharing and canonical) ---

const pageUrl = buildUrl({ locale, path: `alojamientos/${accommodation.slug}` });

// --- Map marker ---

const locationObj = accommodation.location as Record<string, unknown> | undefined;
const lat = Number(locationObj?.lat ?? -32.4833);
const lng = Number(locationObj?.lng ?? -58.2333);
const address = String(locationObj?.address ?? '');
const city = String(locationObj?.city ?? '');
const province = String(locationObj?.state ?? locationObj?.province ?? '');

const mapMarkers = [
    {
        id: accommodation.id,
        lat,
        lng,
        title: String(accommodation.name ?? ''),
        popup: address,
    },
];

// --- Pricing ---

const priceData = accommodation.price as Record<string, unknown> | undefined;
const priceAmount = Number(priceData?.price ?? priceData?.amount ?? 0);
const priceCurrency = String(priceData?.currency ?? 'ARS');
const priceDisplay = priceAmount > 0
    ? `${priceCurrency === 'ARS' ? '$' : priceCurrency}${priceAmount.toLocaleString('es-AR')}`
    : null;

// --- Amenities ---

type AmenityItem = { name: string; icon?: string; slug: string; displayWeight?: number };

const rawAmenities = accommodation.amenities as Array<Record<string, unknown>> | undefined;
const amenities: readonly AmenityItem[] = rawAmenities
    ? rawAmenities.map((rel) => {
          const nested = (rel.amenity ?? rel) as Record<string, unknown>;
          return {
              slug: String(nested.slug ?? nested.name ?? ''),
              name: String(nested.description ?? nested.name ?? rel.name ?? ''),
              icon: nested.icon ? String(nested.icon) : undefined,
              displayWeight: Number(nested.displayWeight ?? 50),
          };
      }).filter((a) => Boolean(a.slug))
    : [];

// --- FAQ ---

type FaqItem = { question: string; answer: string };
const rawFaqs = (accommodation as unknown as Record<string, unknown>).faqs as Array<Record<string, unknown>> | undefined;
const faqs: readonly FaqItem[] = rawFaqs
    ? rawFaqs.map((f) => ({
          question: String(f.question ?? ''),
          answer: String(f.answer ?? ''),
      })).filter((f) => Boolean(f.question))
    : [];

// --- Extra info (check-in / check-out) ---

const extraInfo = accommodation.extraInfo as Record<string, unknown> | undefined;
const checkInTime = String(extraInfo?.checkIn ?? extraInfo?.checkInTime ?? '14:00');
const checkOutTime = String(extraInfo?.checkOut ?? extraInfo?.checkOutTime ?? '10:00');

// --- SEO ---

const seoDescription = `${String(accommodation.name ?? '')} en ${city}, ${province}`;
const canonicalUrl = `${getSiteUrl()}${pageUrl}`;

// --- JSON-LD address ---

const jsonLdAddress = {
    streetAddress: address,
    addressLocality: city,
    addressRegion: province,
    addressCountry: 'AR',
};
---

<BaseLayout
    title={String(accommodation.name ?? '')}
    description={seoDescription}
    locale={locale}
>
    <SEOHead
        slot="head"
        title={String(accommodation.name ?? '')}
        description={seoDescription}
        canonical={canonicalUrl}
        image={featuredImageUrl}
        locale={locale}
    />
    <LodgingBusinessJsonLd
        slot="head"
        name={String(accommodation.name ?? '')}
        description={seoDescription}
        url={canonicalUrl}
        image={featuredImageUrl}
        address={jsonLdAddress}
        priceRange={priceDisplay ?? undefined}
        amenities={amenities.map((a) => a.name)}
    />

    <div class="container mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
        {/* Breadcrumb */}
        <Breadcrumb items={breadcrumbItems} />

        {/* Image gallery with view transition morphing */}
        <div class="mt-4" transition:name={`entity-${slug}`}>
            <ImageGallery client:visible images={galleryImages} locale={locale} />
        </div>

        {/* Main content grid */}
        <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-3">

            {/* ─── Left column (2/3) ─────────────────────────────── */}
            <div class="space-y-10 lg:col-span-2">

                {/* Header: type badge, name, location, rating, actions */}
                <header>
                    <div class="flex flex-wrap items-start justify-between gap-4">
                        <div class="flex-1 min-w-0">
                            {/* Accommodation type badge */}
                            <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary">
                                {String(accommodation.type ?? '')}
                            </span>

                            {/* Name */}
                            <h1 class="mt-2 text-2xl font-bold leading-tight text-foreground sm:text-3xl">
                                {accommodation.name}
                            </h1>

                            {/* Location */}
                            {(city || province) && (
                                <p class="mt-1 text-muted-foreground">
                                    {[address, city, province].filter(Boolean).join(', ')}
                                </p>
                            )}

                            {/* Rating */}
                            <div class="mt-3 flex items-center gap-2">
                                <span class="rounded-md bg-primary px-2 py-1 text-sm font-bold text-primary-foreground">
                                    {Number(accommodation.averageRating ?? 0).toFixed(1)}
                                </span>
                                <span class="text-sm text-muted-foreground">
                                    ({Number(accommodation.reviewsCount ?? 0)} {labels.reviewsLabel})
                                </span>
                            </div>
                        </div>

                        {/* Action buttons */}
                        <div class="flex items-center gap-2 flex-shrink-0">
                            <FavoriteButtonIsland
                                entityId={accommodation.id}
                                entityType="accommodation"
                                entityName={String(accommodation.name ?? '')}
                                locale={locale}
                            >
                                <div
                                    slot="fallback"
                                    class="h-10 w-10 animate-pulse rounded-full bg-muted"
                                    aria-hidden="true"
                                />
                            </FavoriteButtonIsland>

                            <ShareButtons
                                client:visible
                                url={canonicalUrl}
                                title={String(accommodation.name ?? '')}
                                locale={locale}
                            />
                        </div>
                    </div>
                </header>

                {/* Description */}
                {descriptionHtml && (
                    <section aria-labelledby="description-heading" class="scroll-reveal-left">
                        <h2 id="description-heading" class="mb-4 text-xl font-bold text-foreground">
                            {labels.description}
                        </h2>
                        <div class="prose prose-headings:text-foreground prose-p:text-muted-foreground prose-a:text-primary prose-strong:text-foreground max-w-none" set:html={descriptionHtml} />
                    </section>
                )}

                {/* Amenities */}
                <section aria-labelledby="amenities-heading" class="scroll-reveal">
                    <h2 id="amenities-heading" class="mb-4 text-xl font-bold text-foreground">
                        {labels.amenities}
                    </h2>
                    {amenities.length > 0 ? (
                        <AmenitiesList amenities={amenities} />
                    ) : (
                        <p class="text-muted-foreground">{labels.noAmenities}</p>
                    )}
                </section>

                {/* Location map */}
                <section aria-labelledby="location-heading">
                    <h2 id="location-heading" class="mb-4 text-xl font-bold text-foreground">
                        {labels.location}
                    </h2>
                    <MapView
                        client:visible
                        markers={mapMarkers}
                        center={[lat, lng]}
                        zoom={15}
                        height="400px"
                        locale={locale}
                    />
                </section>

                {/* Reviews */}
                <section aria-labelledby="reviews-heading" class="scroll-reveal">
                    <h2 id="reviews-heading" class="mb-4 text-xl font-bold text-foreground">
                        {labels.reviews}
                    </h2>
                    <ReviewListIsland
                        server:defer
                        reviews={[]}
                        totalCount={Number(accommodation.reviewsCount ?? 0)}
                        locale={locale}
                        hasMore={false}
                    />
                </section>

                {/* FAQ */}
                {faqs.length > 0 && (
                    <section aria-labelledby="faq-heading">
                        <h2 id="faq-heading" class="mb-4 text-xl font-bold text-foreground">
                            {labels.faq}
                        </h2>
                        <AccordionFAQ items={faqs} ariaLabel={labels.faq} />
                    </section>
                )}
            </div>

            {/* ─── Right sidebar (1/3) ──────────────────────────── */}
            <aside class="lg:sticky lg:top-6 lg:self-start" aria-label="Pricing and availability">
                <div class="rounded-xl border border-border bg-card p-6 shadow-sm">

                    {/* Price */}
                    <div class="mb-4 border-b border-border pb-4">
                        {priceDisplay ? (
                            <div class="flex items-baseline gap-1">
                                <span class="text-2xl font-bold text-foreground">{priceDisplay}</span>
                                <span class="text-sm text-muted-foreground">/ {labels.perNight}</span>
                            </div>
                        ) : (
                            <p class="text-base font-semibold text-primary">{labels.inquire}</p>
                        )}
                    </div>

                    {/* Check-in / Check-out */}
                    <dl class="mb-6 space-y-3 text-sm">
                        <div class="flex items-center justify-between">
                            <dt class="text-muted-foreground">{labels.checkIn}</dt>
                            <dd class="font-medium text-foreground">{checkInTime}</dd>
                        </div>
                        <div class="flex items-center justify-between">
                            <dt class="text-muted-foreground">{labels.checkOut}</dt>
                            <dd class="font-medium text-foreground">{checkOutTime}</dd>
                        </div>
                    </dl>

                    {/* Contact CTA */}
                    <a
                        href={buildUrl({ locale, path: 'contacto' })}
                        class="block w-full rounded-lg bg-primary px-4 py-3 text-center text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2"
                    >
                        {labels.inquire}
                    </a>
                </div>
            </aside>
        </div>

        {/* ─── Related accommodations ─────────────────────────────── */}
        {relatedCards.length > 0 && (
            <section class="scroll-reveal mt-16" aria-labelledby="similar-heading">
                <h2 id="similar-heading" class="mb-6 text-2xl font-bold text-foreground">
                    {labels.similar}
                </h2>
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                    {relatedCards.map((card) => (
                        <AccommodationCard card={card} locale={locale} />
                    ))}
                </div>
            </section>
        )}
    </div>
</BaseLayout>
