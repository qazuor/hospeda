---
export const prerender = true;

/**
 * Accommodation Detail Page
 *
 * Displays comprehensive information about a single accommodation including:
 * - Image gallery with lightbox
 * - Description, amenities, location map
 * - Reviews and FAQ section
 * - Similar accommodations recommendations
 * - Booking sidebar with pricing and check-in/check-out times
 *
 * Rendering: SSG + ISR (24h revalidation)
 * Route: /[lang]/alojamientos/[slug]
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import Badge from '../../../components/ui/Badge.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import LodgingBusinessJsonLd from '../../../components/seo/LodgingBusinessJsonLd.astro';
import AccommodationCard from '../../../components/accommodation/AccommodationCard.astro';
import AmenitiesList from '../../../components/accommodation/AmenitiesList.astro';
import { ImageGallery } from '../../../components/ui/ImageGallery.client.tsx';
import { ShareButtons } from '../../../components/ui/ShareButtons.client.tsx';
import FavoriteButtonIsland from '../../../components/ui/FavoriteButtonIsland.astro';
import { AccordionFAQ } from '../../../components/ui/AccordionFAQ.client.tsx';
import { MapView } from '../../../components/map/MapView.client.tsx';
import ReviewListIsland from '../../../components/review/ReviewListIsland.astro';
import PriceDisplay from '../../../components/ui/PriceDisplay.astro';
import { isValidLocale, type SupportedLocale } from '../../../lib/i18n';
import { renderTiptapContent } from '../../../lib/tiptap-renderer';
import { accommodationsApi } from '../../../lib/api/endpoints';
import { fetchAllPages } from '../../../lib/api/client';
import { extractFeaturedImageUrl, extractGalleryUrls } from '../../../lib/media';

const { lang, slug } = Astro.params;

// Validate locale and redirect to default if invalid
if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * getStaticPaths - Generate static paths for all accommodations
 */
export async function getStaticPaths() {
  const locales = ['es', 'en', 'pt'];
  const accommodations = await fetchAllPages({
    fetcher: (p) => accommodationsApi.list(p),
  });

  return locales.flatMap((lang) =>
    accommodations
      .filter((a) => a.slug)
      .map((a) => ({
        params: { lang, slug: a.slug },
        props: { accommodation: a },
      }))
  );
}

// Fetch accommodation from props (getStaticPaths) or API (fallback)
let accommodation = Astro.props.accommodation;
if (!accommodation) {
  const result = await accommodationsApi.getBySlug({ slug: slug || '' });
  if (!result.ok) {
    return Astro.redirect(`/${locale}/alojamientos/`);
  }
  accommodation = result.data;
}

// Extract image URLs from nested media structure
const accRecord = accommodation as Record<string, unknown>;
const accommodationImage = extractFeaturedImageUrl(accRecord, '/images/placeholder-accommodation.svg');
const accommodationGallery = extractGalleryUrls(accRecord);
const galleryImages = accommodationGallery.length > 0
  ? accommodationGallery.map((url) => ({ src: url, alt: String(accommodation.name || '') }))
  : [{ src: accommodationImage, alt: String(accommodation.name || '') }];

// Render TipTap content to HTML
const renderedDescription = renderTiptapContent({ content: accommodation.description });

// Fetch similar accommodations from API
const simResult = await accommodationsApi.list({ pageSize: 4 });
const allAccommodations = simResult.ok ? simResult.data.items : [];
const similarCards = allAccommodations
  .filter((a) => a.id !== accommodation.id)
  .slice(0, 3)
  .map((item) => {
    const a = item as Record<string, unknown>;
    return {
      slug: String(a.slug || ''),
      name: String(a.name || ''),
      summary: String(a.summary || a.description || ''),
      type: String(a.type || a.accommodationType || ''),
      featuredImage: extractFeaturedImageUrl(a, '/images/placeholder-accommodation.svg'),
      averageRating: Number(a.averageRating || 0),
      reviewsCount: Number(a.reviewsCount || 0),
      location: (a.location as { city: string; state: string }) || { city: '', state: '' },
      isFeatured: Boolean(a.isFeatured),
    };
  });

// Reviews will be integrated later - use empty array for now
const mockReviews: unknown[] = [];

// Localized texts
const texts: Record<SupportedLocale, {
  home: string;
  accommodations: string;
  description: string;
  amenities: string;
  location: string;
  reviews: string;
  faq: string;
  similar: string;
  perNight: string;
  share: string;
  checkIn: string;
  checkOut: string;
  stars: string;
  reviewsLabel: string;
  bookNow: string;
}> = {
  es: {
    home: 'Inicio',
    accommodations: 'Alojamientos',
    description: 'Descripción',
    amenities: 'Servicios',
    location: 'Ubicación',
    reviews: 'Reseñas',
    faq: 'Preguntas frecuentes',
    similar: 'Alojamientos similares',
    perNight: 'por noche',
    share: 'Compartir',
    checkIn: 'Check-in',
    checkOut: 'Check-out',
    stars: 'estrellas',
    reviewsLabel: 'reseñas',
    bookNow: 'Reservar ahora',
  },
  en: {
    home: 'Home',
    accommodations: 'Accommodations',
    description: 'Description',
    amenities: 'Amenities',
    location: 'Location',
    reviews: 'Reviews',
    faq: 'Frequently Asked Questions',
    similar: 'Similar Accommodations',
    perNight: 'per night',
    share: 'Share',
    checkIn: 'Check-in',
    checkOut: 'Check-out',
    stars: 'stars',
    reviewsLabel: 'reviews',
    bookNow: 'Book now',
  },
  pt: {
    home: 'Início',
    accommodations: 'Acomodações',
    description: 'Descrição',
    amenities: 'Serviços',
    location: 'Localização',
    reviews: 'Avaliações',
    faq: 'Perguntas frequentes',
    similar: 'Acomodações similares',
    perNight: 'por noite',
    share: 'Compartilhar',
    checkIn: 'Check-in',
    checkOut: 'Check-out',
    stars: 'estrelas',
    reviewsLabel: 'avaliações',
    bookNow: 'Reservar agora',
  },
};

const t = texts[locale];

// Breadcrumb navigation items
const breadcrumbItems = [
  { label: t.home, href: `/${locale}/` },
  { label: t.accommodations, href: `/${locale}/alojamientos/` },
  { label: accommodation.name },
];

// Page URL for sharing and canonical
const pageUrl = `/${locale}/alojamientos/${accommodation.slug}/`;

// Map markers for location
const mapMarkers = [
  {
    id: accommodation.id,
    lat: accommodation.location?.lat || -32.4833,
    lng: accommodation.location?.lng || -58.2333,
    title: accommodation.name,
    popup: accommodation.location?.address || ''
  }
];
---

<BaseLayout
  title={accommodation.name}
  description={`${accommodation.name} - ${accommodation.location?.city || ''}`}
  locale={locale}
  image={accommodationImage}
>
  <SEOHead
    slot="head"
    title={accommodation.name}
    description={`${accommodation.name} en ${accommodation.location?.city || ''}, ${accommodation.location?.province || ''}`}
    image={accommodationImage}
    locale={locale}
  />
  <LodgingBusinessJsonLd
    slot="head"
    name={accommodation.name}
    description={accommodation.location?.address || ''}
    image={accommodationImage}
    rating={accommodation.rating || 0}
    reviewCount={accommodation.reviewCount || 0}
    priceRange={`$${accommodation.pricePerNight || 0}`}
    address={accommodation.location?.address || ''}
    url={pageUrl}
  />

  <Container>
    <Breadcrumb items={breadcrumbItems} class="py-4" />

    <!-- Image Gallery -->
    <div transition:name={`entity-${slug}`}>
      <ImageGallery client:visible images={galleryImages} />
    </div>

    <!-- Main content grid -->
    <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-3">
      <!-- Left column (2/3) -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Header -->
        <div>
          <div class="flex items-start justify-between">
            <div>
              <Badge variant="primary" label={accommodation.type || 'HOTEL'} />
              <h1 class="mt-2 text-3xl font-bold">{accommodation.name}</h1>
              <p class="mt-1 text-gray-600">
                {accommodation.location?.address || ''}, {accommodation.location?.city || ''}, {accommodation.location?.province || ''}
              </p>
            </div>
            <div class="flex items-center gap-2">
              <FavoriteButtonIsland
                server:defer
                entityId={accommodation.id}
                entityType="accommodation"
                entityName={accommodation.name}
              >
                <div slot="fallback" class="h-10 w-10 animate-pulse rounded-full bg-gray-200" />
              </FavoriteButtonIsland>
              <ShareButtons
                client:visible
                url={pageUrl}
                title={accommodation.name}
              />
            </div>
          </div>
          <!-- Rating -->
          <div class="mt-3 flex items-center gap-2">
            <span class="rounded-md bg-primary px-2 py-1 text-sm font-bold text-white">
              {accommodation.rating || 0}
            </span>
            <span class="text-sm text-gray-600">
              ({accommodation.reviewCount || 0} {t.reviewsLabel})
            </span>
          </div>
        </div>

        <!-- Description -->
        <section>
          <h2 class="mb-4 text-2xl font-bold">{t.description}</h2>
          <div class="prose max-w-none" set:html={renderedDescription} />
        </section>

        <!-- Amenities -->
        <section>
          <h2 class="mb-4 text-2xl font-bold">{t.amenities}</h2>
          <AmenitiesList amenities={accommodation.amenities || []} />
        </section>

        <!-- Location Map -->
        <section>
          <h2 class="mb-4 text-2xl font-bold">{t.location}</h2>
          <MapView
            client:visible
            markers={mapMarkers}
            center={[accommodation.location?.lat || -32.4833, accommodation.location?.lng || -58.2333]}
            zoom={15}
            height="400px"
          />
        </section>

        <!-- Reviews -->
        <section>
          <h2 class="mb-4 text-2xl font-bold">{t.reviews}</h2>
          <ReviewListIsland
            server:defer
            reviews={mockReviews}
            totalCount={accommodation.reviewCount || 0}
            locale={locale}
            hasMore={false}
          >
            <div slot="fallback" class="space-y-4 animate-pulse">
              <div class="h-4 w-3/4 rounded bg-gray-200" />
              <div class="h-4 w-1/2 rounded bg-gray-200" />
              <div class="h-4 w-2/3 rounded bg-gray-200" />
            </div>
          </ReviewListIsland>
        </section>

        <!-- FAQ -->
        <section>
          <h2 class="mb-4 text-2xl font-bold">{t.faq}</h2>
          <AccordionFAQ
            client:visible
            items={accommodation.faqs || []}
          />
        </section>
      </div>

      <!-- Right sidebar (1/3) -->
      <aside class="lg:sticky lg:top-4 lg:self-start">
        <div class="rounded-lg border border-gray-200 p-6 shadow-sm">
          <!-- Price -->
          <div class="mb-4">
            <PriceDisplay amountARS={accommodation.pricePerNight || 0} locale={locale} showDisclaimer={false} />
            <span class="text-sm text-gray-600"> / {t.perNight}</span>
          </div>

          <!-- Check-in/out -->
          <div class="mb-6 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-600">{t.checkIn}</span>
              <span class="font-medium">{accommodation.checkIn || '14:00'}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">{t.checkOut}</span>
              <span class="font-medium">{accommodation.checkOut || '10:00'}</span>
            </div>
          </div>

          <!-- CTA button -->
          <a
            href="#"
            class="block w-full rounded-md bg-primary px-4 py-3 text-center font-semibold text-white transition-colors hover:bg-primary-dark"
          >
            {t.bookNow}
          </a>
        </div>
      </aside>
    </div>

    <!-- Similar Accommodations -->
    <Section title={t.similar} class="mt-12">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {similarCards.map((accommodation) => (
          <AccommodationCard
            accommodation={accommodation}
            locale={locale}
          />
        ))}
      </div>
    </Section>
  </Container>
</BaseLayout>
