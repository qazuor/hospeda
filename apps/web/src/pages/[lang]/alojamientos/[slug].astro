---
/**
 * @file alojamientos/[slug].astro
 * @description Accommodation detail page. Orchestrates all detail components,
 * related content carousels, and LodgingBusiness JSON-LD.
 * @route /{lang}/alojamientos/{slug}/
 * @rendering SSR (on-demand)
 */

import DetailLayout from '@/layouts/DetailLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import LodgingBusinessJsonLd from '@/components/seo/LodgingBusinessJsonLd.astro';
import BreadcrumbJsonLd from '@/components/seo/BreadcrumbJsonLd.astro';
import FAQPageJsonLd from '@/components/seo/FAQPageJsonLd.astro';
import { ImageGallery } from '@/components/ImageGallery.client';
import DetailHeader from '@/components/accommodation/DetailHeader.astro';
import QuickFacts from '@/components/accommodation/QuickFacts.astro';
import Description from '@/components/accommodation/Description.astro';
import { renderContent as renderRich } from '@/lib/render-content';
import { renderPlain } from '@/lib/render-plain';
import AmenitiesGrid from '@/components/accommodation/AmenitiesGrid.astro';
import FeaturesGrid from '@/components/accommodation/FeaturesGrid.astro';
import ReviewPreview from '@/components/accommodation/ReviewPreview.astro';
import { ReviewsModal } from '@/components/accommodation/ReviewsModal.client';
import { ReviewSidebarCard } from '@/components/accommodation/ReviewSidebarCard.client';
import FaqAccordion from '@/components/accommodation/FaqAccordion.astro';
import LocationSection from '@/components/accommodation/LocationSection.astro';
import RelatedCarousel from '@/components/accommodation/RelatedCarousel.astro';
import PricingSidebar from '@/components/accommodation/PricingSidebar.astro';
import OwnerCard from '@/components/accommodation/OwnerCard.astro';
import { ContactHost } from '@/components/accommodation/ContactHost.client';
import { AccommodationViewTracker } from '@/components/analytics/AccommodationViewTracker.client';
import { AiChatWidget } from '@/components/accommodation/AiChatWidget';
import { protectedConversationsApi } from '@/lib/api/endpoints-protected';
import { getApiUrl } from '@/lib/env';
import AccommodationCard from '@/components/shared/cards/AccommodationCard.astro';
import RelatedPostCard from '@/components/shared/cards/RelatedPostCard.astro';
import EventCardHorizontal from '@/components/shared/cards/EventCardHorizontal.astro';
import { accommodationsApi, postsApi, eventsApi, userBookmarksPublicApi } from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { toAccommodationDetailPageProps, toAccommodationCardProps, toEventCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { pickLocalizedSeo } from '@/lib/seo';

export const prerender = false;

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { slug } = Astro.params;

if (!slug) return new Response(null, { status: 404 });

// --- Hero search context (forwarded from listing) ---
// Builds an initial message for the contact form when the visitor arrives
// from the home hero search with dates and/or guests selected.
const ctxCheckIn = Astro.url.searchParams.get('checkIn') ?? undefined;
const ctxCheckOut = Astro.url.searchParams.get('checkOut') ?? undefined;
const ctxAdultsRaw = Astro.url.searchParams.get('adults');
const ctxChildrenRaw = Astro.url.searchParams.get('children');
const ctxAdults = ctxAdultsRaw ? Number(ctxAdultsRaw) : undefined;
const ctxChildren = ctxChildrenRaw ? Number(ctxChildrenRaw) : undefined;

/** Format ISO `YYYY-MM-DD` to a locale-aware label without TZ shift. */
function fmtIsoDay(iso: string): string {
	const [y, m, d] = iso.split('-').map(Number);
	if (!y || !m || !d) return iso;
	return new Intl.DateTimeFormat(locale === 'en' ? 'en-US' : locale === 'pt' ? 'pt-BR' : 'es-AR', {
		day: '2-digit',
		month: 'long',
		year: 'numeric',
		timeZone: 'UTC',
	}).format(new Date(Date.UTC(y, m - 1, d, 12)));
}

const hasCtxDates = Boolean(ctxCheckIn || ctxCheckOut);
const hasCtxGuests =
	(ctxAdults !== undefined && !Number.isNaN(ctxAdults) && ctxAdults > 0) ||
	(ctxChildren !== undefined && !Number.isNaN(ctxChildren) && ctxChildren > 0);

let prefilledMessage: string | undefined;
if (hasCtxDates || hasCtxGuests) {
	const parts: string[] = [t('conversations.form.prefill.intro', 'Hola, me interesa este alojamiento.')];

	if (ctxCheckIn && ctxCheckOut) {
		parts.push(
			t('conversations.form.prefill.dateRange', 'Estoy mirando del {from} al {to}.', {
				from: fmtIsoDay(ctxCheckIn),
				to: fmtIsoDay(ctxCheckOut),
			})
		);
	} else if (ctxCheckIn) {
		parts.push(
			t('conversations.form.prefill.dateFrom', 'Estoy mirando a partir del {from}.', {
				from: fmtIsoDay(ctxCheckIn),
			})
		);
	} else if (ctxCheckOut) {
		parts.push(
			t('conversations.form.prefill.dateTo', 'Estoy mirando hasta el {to}.', {
				to: fmtIsoDay(ctxCheckOut),
			})
		);
	}

	if (hasCtxGuests) {
		const a = ctxAdults && !Number.isNaN(ctxAdults) ? ctxAdults : 0;
		const c = ctxChildren && !Number.isNaN(ctxChildren) ? ctxChildren : 0;
		if (c > 0) {
			parts.push(
				t('conversations.form.prefill.guests', 'Somos {adults} adultos y {children} niños.', {
					adults: a,
					children: c,
				})
			);
		} else if (a > 0) {
			parts.push(
				t('conversations.form.prefill.guestsAdultsOnly', 'Somos {adults} adultos.', {
					adults: a,
				})
			);
		}
	}

	parts.push(t('conversations.form.prefill.outro', '¿Me podrías confirmar disponibilidad?'));
	prefilledMessage = parts.join(' ');
}

// --- Primary fetch ---
const result = await accommodationsApi.getBySlug({ slug });
if (!result.ok || !result.data) return new Response(null, { status: 404 });

const rawAccommodation = result.data as Record<string, unknown>;
const accommodation = toAccommodationDetailPageProps({ item: rawAccommodation, locale });

// Extract lifecycle fields directly from raw API response (not in AccommodationDetailData)
const accommodationLifecycleState = String(rawAccommodation.lifecycleState ?? 'ACTIVE');
const accommodationDeletedAt = rawAccommodation.deletedAt
    ? String(rawAccommodation.deletedAt)
    : null;

// --- Parallel secondary fetches with graceful degradation ---
const [similarResult, ownerPropsResult, postsResult, eventsResult, reviewsResult] =
    await Promise.allSettled([
        accommodationsApi.getSimilar({ id: accommodation.id, limit: 6 }),
        accommodationsApi.listByOwner({ userId: accommodation.owner.id, pageSize: 7 }),
        postsApi.list({ destinationId: accommodation.destination.id, pageSize: 4 }),
        eventsApi.list({ destinationId: accommodation.destination.id, pageSize: 6 }),
        accommodationsApi.getReviews({ id: accommodation.id, page: 1, pageSize: 100 })
    ]);

/** Safely extract array from a settled API result. */
function extractItems(settled: PromiseSettledResult<unknown>): Record<string, unknown>[] {
    if (settled.status === 'rejected') return [];
    const val = settled.value as { ok?: boolean; data?: unknown };
    if (!val?.ok) return [];
    const d = val.data;
    if (Array.isArray(d)) return d as Record<string, unknown>[];
    if (d && typeof d === 'object') {
        const obj = d as Record<string, unknown>;
        if (Array.isArray(obj.items)) return obj.items as Record<string, unknown>[];
        if (Array.isArray(obj.data)) return obj.data as Record<string, unknown>[];
    }
    return [];
}

const similarCards = extractItems(similarResult)
    .slice(0, 6)
    .map((item) => toAccommodationCardProps({ item, locale }));
const ownerCards = extractItems(ownerPropsResult)
    .filter((item) => String(item.id) !== accommodation.id)
    .slice(0, 6)
    .map((item) => toAccommodationCardProps({ item, locale }));
// Compute the average rating for each sub-category from the loaded reviews.
// Cheap O(n × 6) scan over up to 100 reviews — runs once at SSR time.
const reviewItems = extractItems(reviewsResult);
const RATING_CATEGORIES = [
    'cleanliness',
    'hospitality',
    'services',
    'accuracy',
    'communication',
    'location'
] as const;
const ratingBreakdown = (() => {
    if (reviewItems.length === 0) return undefined;
    const sums: Record<string, number> = {};
    const counts: Record<string, number> = {};
    for (const review of reviewItems) {
        const rating = review.rating as Record<string, unknown> | undefined;
        if (!rating) continue;
        for (const cat of RATING_CATEGORIES) {
            const v = rating[cat];
            if (typeof v === 'number' && Number.isFinite(v)) {
                sums[cat] = (sums[cat] ?? 0) + v;
                counts[cat] = (counts[cat] ?? 0) + 1;
            }
        }
    }
    const out: Record<string, number> = {};
    for (const cat of RATING_CATEGORIES) {
        if ((counts[cat] ?? 0) > 0) {
            out[cat] = (sums[cat] ?? 0) / (counts[cat] ?? 1);
        }
    }
    return Object.keys(out).length > 0 ? out : undefined;
})();

// Posts and events: pass raw items for lightweight cards
const postItems = extractItems(postsResult);
const eventItems = extractItems(eventsResult).slice(0, 6);

// --- Auth ---
const userId = Astro.locals.user?.id ?? null;
const isAuthenticated = userId !== null;
const currentUser = Astro.locals.user
    ? {
          id: Astro.locals.user.id,
          name: (Astro.locals.user as { name?: string | null }).name ?? null,
          email: (Astro.locals.user as { email?: string | null }).email ?? null
      }
    : null;

// --- Review eligibility: only allow leaving a review if the visitor has
// already initiated a conversation with this property's host. Acts as a
// lightweight "has the visitor actually engaged with this property?" check
// — strong enough to block drive-by reviews, weak enough to not require
// a verified stay/booking workflow we don't have yet.
let canLeaveReview = false;
if (isAuthenticated) {
    try {
        const cookieHeader = Astro.request.headers.get('cookie') ?? undefined;
        const convResult = await protectedConversationsApi.list({
            accommodationId: accommodation.id,
            pageSize: 1,
            cookieHeader
        });
        canLeaveReview = convResult.ok && (convResult.data.items?.length ?? 0) > 0;
    } catch {
        // Fail-closed: any error reading the inbox means we hide the form
        // rather than risk surfacing it to someone who shouldn't see it.
        canLeaveReview = false;
    }
}

// --- Bookmark count + favorite status (graceful degradation, never blocks render) ---
let bookmarkCount: number | undefined;
let initialIsFavorited: boolean | undefined;
let initialBookmarkId: string | null = null;

try {
    const countResult = await userBookmarksPublicApi.count({
        entityType: 'ACCOMMODATION',
        entityId: accommodation.id
    });
    if (countResult.ok) {
        bookmarkCount = countResult.data.count;
    }
} catch {
    // Graceful degradation: counter not shown if fetch fails
}

if (isAuthenticated) {
    try {
        const statusResult = await userBookmarksApi.checkStatus({
            entityId: accommodation.id,
            entityType: 'ACCOMMODATION'
        });
        if (statusResult.ok) {
            initialIsFavorited = statusResult.data.isFavorited;
            initialBookmarkId = statusResult.data.bookmarkId;
        }
    } catch {
        // Graceful degradation: FavoriteButton hydrates itself on mount
    }
}

// Look up existing conversation for authenticated user (graceful degradation)
let existingConversationId: string | null = null;
if (userId) {
    try {
        const convResult = await protectedConversationsApi.list({ page: 1, pageSize: 50 });
        if (convResult.ok) {
            const match = convResult.data.items.find(
                (c) => c.accommodationId === accommodation.id
            );
            existingConversationId = match?.id ?? null;
        }
    } catch {
        // Graceful degradation: show form if lookup fails
    }
}

// --- Gallery images for ImageGallery island ---
// Build a unified GalleryImage[] from galleryItems (preferred) or URL-only images list.
// SPEC-186: pass the FULL gallery — the island owns all capping (count-aware grid
// shows a bounded preview and a "+N más" overlay for the rest).
const galleryImages = (() => {
    const featured = {
        url: accommodation.featuredImage || '/images/placeholder-accommodation.svg',
        alt: accommodation.name
    };
    const extras =
        accommodation.media.galleryItems.length > 0
            ? accommodation.media.galleryItems.map((item) => ({
                  url: item.url,
                  alt: item.caption ?? accommodation.name,
                  caption: item.caption
              }))
            : accommodation.media.images.map((url) => ({
                  url,
                  alt: accommodation.name
              }));
    return [featured, ...extras];
})();

// --- SEO ---
// Stored seo.* overrides are authored in the source locale (es); on en/pt
// prefer the localized name/summary so the <title> isn't Spanish (SPEC-212).
const seoTitle = pickLocalizedSeo({
    stored: accommodation.seo?.title,
    fallback: `${accommodation.name} | Hospeda`,
    locale
});
const seoDescription = pickLocalizedSeo({
    stored: accommodation.seo?.description,
    fallback: accommodation.summary,
    locale
});

// --- OG card (PHOTO mode) ---
// Use the entity featured image (skip the local placeholder so brand mode kicks
// in instead of rendering a placeholder photo card). Subtitle = locality; rating
// only when there is a real average (>0).
const ogFeaturedImage =
    accommodation.featuredImage && !accommodation.featuredImage.includes('placeholder')
        ? accommodation.featuredImage
        : undefined;
const ogRating = accommodation.averageRating > 0 ? accommodation.averageRating.toFixed(1) : undefined;
const ogSubtitle = accommodation.destination?.name || undefined;

// --- Description rendering ---
// SPEC-187 FR-4 contract:
// presence of `accommodation.richDescription` is the ONLY signal that the
// page may render rich HTML. Do not evaluate entitlements here — the API
// gate already omitted the field when the owner is not entitled.
const safeDescriptionText = renderPlain({
    raw: accommodation.description ?? ''
});
const richDescriptionSiteOrigin = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const safeRichDescriptionHtml = accommodation.richDescription
    ? renderRich({
          raw: accommodation.richDescription,
          siteOrigin: richDescriptionSiteOrigin
      })
    : '';

// --- JSON-LD (LodgingBusiness) ---
const ACCOMMODATION_TYPE_MAP: Readonly<Record<string, string>> = {
    HOTEL: 'Hotel', HOSTEL: 'Hostel', MOTEL: 'Motel', RESORT: 'Resort', CAMPING: 'Campground'
};
const lodgingAccommodationType =
    ACCOMMODATION_TYPE_MAP[accommodation.type.toUpperCase()] ?? 'LodgingBusiness';

const lodgingGeo =
    accommodation.location.lat != null && accommodation.location.lng != null
        ? { latitude: accommodation.location.lat, longitude: accommodation.location.lng }
        : undefined;

const lodgingAggregateRating =
    accommodation.averageRating > 0
        ? {
              ratingValue: accommodation.averageRating,
              reviewCount: accommodation.reviewsCount,
              bestRating: 5,
              worstRating: 1,
          }
        : undefined;

const lodgingNumberOfRooms =
    accommodation.extraInfo?.bedrooms != null ? accommodation.extraInfo.bedrooms : undefined;

const lodgingAmenities =
    accommodation.amenities.length > 0
        ? accommodation.amenities.map((a) => a.name)
        : undefined;

// --- Breadcrumb JSON-LD (REQ-096-37 / T-068) ---
const siteOrigin = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const breadcrumbItems = [
    { name: t('nav.home', 'Inicio'), url: `${siteOrigin}/${locale}/` },
    {
        name: t('accommodations.title', 'Alojamientos'),
        url: `${siteOrigin}/${locale}/alojamientos/`
    },
    { name: accommodation.name, url: `${siteOrigin}${Astro.url.pathname}` }
];

// --- FAQPage JSON-LD when FAQs exist (REQ-096-37 / T-067) ---
const faqSections = accommodation.faqs.map((faq) => ({
    heading: faq.question,
    body: faq.answer
}));
---

<DetailLayout
    locale={locale}
    title={seoTitle}
    description={seoDescription}
    ogImage={ogFeaturedImage}
    ogType="Alojamiento"
    ogSubtitle={ogSubtitle}
    ogRating={ogRating}
    showBreadcrumbs={true}
    showSidebar={true}
>
    <LodgingBusinessJsonLd
        slot="head-extra"
        name={accommodation.name}
        description={accommodation.summary}
        url={Astro.url.href}
        image={accommodation.featuredImage}
        address={{
            streetAddress: '',
            addressLocality: accommodation.destination.name,
            addressRegion: '',
            addressCountry: 'AR',
        }}
        accommodationType={lodgingAccommodationType}
        geo={lodgingGeo}
        aggregateRating={lodgingAggregateRating}
        numberOfRooms={lodgingNumberOfRooms}
        amenities={lodgingAmenities}
    />
    <BreadcrumbJsonLd slot="head-extra" items={breadcrumbItems} />
    {faqSections.length > 0 && (
        <FAQPageJsonLd slot="head-extra" sections={faqSections} />
    )}

    <Breadcrumbs
        slot="breadcrumbs"
        locale={locale}
        items={[
            { label: t('accommodations.title'), path: 'alojamientos' },
            { label: accommodation.name }
        ]}
    />

    <Fragment slot="page-header">
        <DetailHeader
            accommodation={accommodation}
            lang={locale}
            accommodationId={accommodation.id}
            isAuthenticated={isAuthenticated}
            initialIsFavorited={initialIsFavorited}
            initialBookmarkId={initialBookmarkId}
            bookmarkCount={bookmarkCount}
        />
    </Fragment>

    <!-- Main content -->
    <div class="acc-detail">
        <ImageGallery
            images={galleryImages}
            variant="detail"
            locale={locale}
            viewAllHref={`/${locale}/alojamientos/${slug}/fotos/`}
            client:visible
        />
        <QuickFacts extraInfo={accommodation.extraInfo} lang={locale} />
        {accommodation.richDescription ? (
            <section class="description-rich">
                {accommodation.summary && (
                    <div class="description-rich__summary">
                        <p>{accommodation.summary}</p>
                    </div>
                )}
                <div class="description-rich__body" set:html={safeRichDescriptionHtml} />
            </section>
        ) : (
            <Description summary={accommodation.summary} descriptionText={safeDescriptionText} />
        )}

        <FeaturesGrid features={accommodation.features} smokingAllowed={accommodation.extraInfo?.smokingAllowed ?? null} lang={locale} />
        <AmenitiesGrid amenities={accommodation.amenities} lang={locale} />

        <ReviewPreview accommodation={accommodation} ratingBreakdown={ratingBreakdown} lang={locale}>
            <ReviewsModal
                client:idle
                accommodationId={accommodation.id}
                reviewsCount={accommodation.reviewsCount}
                locale={locale}
            />
        </ReviewPreview>

        <FaqAccordion faqs={accommodation.faqs} lang={locale} />
        <LocationSection
            destination={accommodation.destination}
            approximateLocation={accommodation.approximateLocation}
            accommodationName={accommodation.name}
            lang={locale}
        />
    </div>

    <!-- Related content carousels (outside two-column grid, full width) -->
    {similarCards.length > 0 && (
        <RelatedCarousel title={t('accommodations.detail.related.similar')} ariaLabel={t('accommodations.detail.related.similar')} lang={locale} count={similarCards.length}>
            {similarCards.map((card) => <AccommodationCard data={card} locale={locale} />)}
        </RelatedCarousel>
    )}

    {ownerCards.length > 0 && (
        <RelatedCarousel title={t('accommodations.detail.owner.otherProperties', undefined, { name: accommodation.owner.name })} ariaLabel={t('accommodations.detail.owner.otherProperties', undefined, { name: accommodation.owner.name })} lang={locale} count={ownerCards.length}>
            {ownerCards.map((card) => <AccommodationCard data={card} locale={locale} />)}
        </RelatedCarousel>
    )}

    {postItems.length > 0 && (
        <RelatedCarousel title={t('accommodations.detail.related.posts')} ariaLabel={t('accommodations.detail.related.posts')} lang={locale} count={postItems.length}>
            {postItems.map((item) => (
                <RelatedPostCard
                    id={String(item.id || '')}
                    slug={String(item.slug || '')}
                    title={String(item.title || '')}
                    summary={String(item.summary || item.description || '')}
                    featuredImage={item.featuredImage ? String(item.featuredImage) : null}
                    destinationName={accommodation.destination.name}
                    publishedAt={item.publishedAt ? String(item.publishedAt) : null}
                    lang={locale}
                />
            ))}
        </RelatedCarousel>
    )}

    {eventItems.length > 0 && (
        <RelatedCarousel title={t('accommodations.detail.related.events', undefined, { destination: accommodation.destination.name })} ariaLabel={t('accommodations.detail.related.events', undefined, { destination: accommodation.destination.name })} lang={locale} count={eventItems.length}>
            {eventItems.map((item) => <EventCardHorizontal data={toEventCardProps({ item, locale })} locale={locale} isAuthenticated={isAuthenticated} />)}
        </RelatedCarousel>
    )}

    <!-- Analytics tracker (headless, SPEC-140) -->
    <AccommodationViewTracker
        client:idle
        slug={slug}
        accommodationId={accommodation.id}
        locale={locale}
    />

    <!-- AI chat widget (SPEC-200) — only for authenticated users -->
    {isAuthenticated && (
        <AiChatWidget
            client:idle
            accommodationId={accommodation.id}
            locale={locale}
            apiUrl={getApiUrl()}
        />
    )}

    <!-- Sidebar -->
    <Fragment slot="sidebar">
        <div class="acc-sidebar">
            <PricingSidebar price={accommodation.price} extraInfo={accommodation.extraInfo} lang={locale} />
            <OwnerCard owner={accommodation.owner} accommodationId={accommodation.id} userId={userId} lang={locale}>
                <ContactHost
                    client:idle
                    accommodation={{
                        id: accommodation.id,
                        lifecycleState: accommodationLifecycleState,
                        deletedAt: accommodationDeletedAt
                    }}
                    currentUser={currentUser}
                    existingConversationId={existingConversationId}
                    locale={locale}
                    initialMessage={prefilledMessage}
                />
            </OwnerCard>
            {isAuthenticated && (
                <ReviewSidebarCard
                    client:visible
                    accommodationId={accommodation.id}
                    accommodationName={accommodation.name}
                    canLeaveReview={canLeaveReview}
                    locale={locale}
                    apiUrl={getApiUrl()}
                />
            )}
        </div>
    </Fragment>
</DetailLayout>

<style>
    .acc-detail {
        display: flex;
        flex-direction: column;
        gap: var(--space-8, 32px);
    }
    .acc-sidebar {
        display: flex;
        flex-direction: column;
        gap: var(--space-4, 16px);
    }
    .description-rich__summary {
        background-color: var(--surface-warm);
        border-left: 4px solid var(--brand-accent);
        border-radius: var(--radius-button, 8px);
        padding: var(--space-4, 16px) var(--space-5, 20px);
        margin-bottom: var(--space-5, 20px);
    }
    .description-rich__summary p {
        font-family: var(--font-sans);
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--core-foreground);
        margin: 0;
    }
    .description-rich__body {
        font-family: var(--font-sans);
        color: var(--core-foreground);
    }
</style>
