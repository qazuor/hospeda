---
/**
 * @file alojamientos/index.astro
 * @description Accommodations listing page with filter sidebar, card grid,
 * pagination, and ItemList JSON-LD structured data.
 * @route /{lang}/alojamientos/
 * @rendering SSR + ISR 24h
 */

import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import AccommodationCard from '@/components/shared/cards/AccommodationCard.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import Pagination from '@/components/shared/feedback/Pagination.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import AccommodationTypeBadge from '@/components/shared/ui/AccommodationTypeBadge.astro';
import { AccommodationTypeEnum } from '@repo/schemas';
import { FilterSidebar } from '@/components/shared/filters/FilterSidebar.client';
import type { FilterGroup } from '@/components/shared/filters/FilterSidebar.client';
import { accommodationsApi, amenitiesApi, destinationsApi, featuresApi } from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { toAccommodationCardProps } from '@/lib/api/transforms';
import { webLogger } from '@/lib/logger';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { getAccommodationTypeLabel } from '@/lib/colors';
import { buildAccommodationListingSummary, DEFAULT_TYPE_GRAMMAR } from '@/lib/accommodation-listing-summary';
import type { CatalogEntry, SummaryLocale } from '@/lib/accommodation-listing-summary';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);

// Read pagination and filter params from URL
const url = Astro.url;
const page = Math.max(1, Number(url.searchParams.get('page')) || 1);
const pageSize = 20;

// Extract filter params
const q = url.searchParams.get('q') ?? undefined;
const types = url.searchParams.get('types') ?? undefined;
const destinationIds = url.searchParams.get('destinationIds') ?? undefined;
const minPrice = url.searchParams.get('minPrice') ? Number(url.searchParams.get('minPrice')) : undefined;
const maxPrice = url.searchParams.get('maxPrice') ? Number(url.searchParams.get('maxPrice')) : undefined;
const sortBy = url.searchParams.get('sortBy') ?? undefined;
// SPEC-098 T-052 — `mostSaved` should default to descending so accommodations
// with the most active bookmarks appear first. Other fields keep their existing
// behavior (server-side fallback to `asc`).
const explicitSortOrder = url.searchParams.get('sortOrder') as 'asc' | 'desc' | null;
const sortOrder: 'asc' | 'desc' | undefined =
    explicitSortOrder ?? (sortBy === 'mostSaved' ? 'desc' : undefined);
const isFeatured = url.searchParams.get('isFeatured') === 'true' ? true : undefined;
const minGuests = url.searchParams.get('minGuests') ? Number(url.searchParams.get('minGuests')) : undefined;
const maxGuests = url.searchParams.get('maxGuests') ? Number(url.searchParams.get('maxGuests')) : undefined;
const minBedrooms = url.searchParams.get('minBedrooms') ? Number(url.searchParams.get('minBedrooms')) : undefined;
const maxBedrooms = url.searchParams.get('maxBedrooms') ? Number(url.searchParams.get('maxBedrooms')) : undefined;
const minBathrooms = url.searchParams.get('minBathrooms') ? Number(url.searchParams.get('minBathrooms')) : undefined;
const maxBathrooms = url.searchParams.get('maxBathrooms') ? Number(url.searchParams.get('maxBathrooms')) : undefined;
const minRating = url.searchParams.get('minRating') ? Number(url.searchParams.get('minRating')) : undefined;
const amenitiesParam = url.searchParams.get('amenities') ?? undefined;
const featuresParam = url.searchParams.get('features') ?? undefined;
const includeNoPrice = url.searchParams.get('includeNoPrice') === 'true' ? true : undefined;
const includeNoReviews = url.searchParams.get('includeNoReviews') === 'true' ? true : undefined;

// Fetch destinations for filter dropdown
const destinationsResult = await destinationsApi.list({ pageSize: 100, sortBy: 'name', sortOrder: 'asc' });
const destinations = destinationsResult.ok ? destinationsResult.data.items : [];

// Fetch amenities for filter chips
const amenitiesResult = await amenitiesApi.list({ pageSize: 100, isActive: true, sortBy: 'name', sortOrder: 'asc' });
const amenities = amenitiesResult.ok ? amenitiesResult.data.items : [];

// Fetch features for filter chips
const featuresResult = await featuresApi.list({ pageSize: 100, sortBy: 'displayWeight', sortOrder: 'desc' });
const features = featuresResult.ok ? featuresResult.data.items : [];

// Fetch accommodations
const result = await accommodationsApi.list({
	page,
	pageSize,
	q,
	types,
	destinationIds,
	minPrice,
	maxPrice,
	sortBy,
	sortOrder,
	isFeatured,
	minGuests,
	maxGuests,
	minBedrooms,
	maxBedrooms,
	minBathrooms,
	maxBathrooms,
	minRating,
	amenities: amenitiesParam,
	features: featuresParam,
	includeAmenities: true,
	includeNoPrice,
	includeNoReviews,
});

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.pagination.total : 0;
const totalPages = result.ok ? result.data.pagination.totalPages : 0;

// Transform items for cards
const baseCards = items.map((item) => toAccommodationCardProps({ item: item as unknown as Record<string, unknown> }));

// SPEC-098 T-041 — Pre-hydrate FavoriteButton state for authenticated users.
// We issue a single bulk-check request for all the entity IDs on the current
// page instead of one /check per card. Guests skip this call entirely; their
// FavoriteButton renders in guest mode (auth-required popover on click).
//
// On any failure (network error, 5xx, etc.) we silently degrade — each
// FavoriteButton can still hydrate itself via its own /check fallback so the
// page render is never blocked.
const isAuthenticated = Boolean(Astro.locals.user);
type FavoriteCheckEntry = { readonly isBookmarked: boolean; readonly bookmarkId: string | null };
let favoriteChecks: Readonly<Record<string, FavoriteCheckEntry>> = {};
if (isAuthenticated && baseCards.length > 0) {
    try {
        const bulkResult = await userBookmarksApi.checkBulk({
            entityType: 'ACCOMMODATION',
            entityIds: baseCards.map((card) => card.id)
        });
        if (bulkResult.ok) {
            favoriteChecks = bulkResult.data.checks;
        } else {
            webLogger.warn(
                { error: bulkResult.error },
                'Bulk bookmark check failed; falling back to per-card hydration'
            );
        }
    } catch (error) {
        webLogger.warn(
            { error: error instanceof Error ? error.message : String(error) },
            'Bulk bookmark check threw; falling back to per-card hydration'
        );
    }
}

const cards = baseCards.map((card) => {
    const entry = favoriteChecks[card.id];
    if (!entry) return card;
    return {
        ...card,
        isFavorited: entry.isBookmarked,
        favoriteBookmarkId: entry.bookmarkId
    };
});

// --- Natural language filter summary ---
// Build catalogs from the fetched data for the summary builder.
// Destinations, amenities, and features use id→name from the API.
// The summary module maps these keys to human-readable labels per locale.
const summaryLocale = (locale === 'en' ? 'en' : 'es') as SummaryLocale;

const destinationCatalog: readonly CatalogEntry[] = destinations.map((d) => ({
	key: d.id,
	label: { es: d.name, en: d.name }
}));
const amenityCatalog: readonly CatalogEntry[] = amenities.map((a) => ({
	key: a.id,
	label: { es: a.name, en: a.name }
}));
const featureCatalog: readonly CatalogEntry[] = features.map((f) => ({
	key: f.id,
	label: { es: f.name, en: f.name }
}));

// When types are active the API already filters by type, so `total` is the
// type-specific count (equivalent to `subjectTotal`). Pass it explicitly so the
// builder can render "hoteles" instead of the generic "hospedajes".
const typesArray = types?.split(',').filter(Boolean) ?? [];
const filterSummary = buildAccommodationListingSummary({
	locale: summaryLocale,
	filters: {
		types: typesArray.length > 0 ? typesArray : undefined,
		text: q,
		price: (minPrice !== undefined || maxPrice !== undefined || includeNoPrice)
			? { min: minPrice, max: maxPrice, includeWithoutPrice: includeNoPrice }
			: undefined,
		destinations: destinationIds?.split(',').filter(Boolean),
		guests: minGuests,
		amenities: amenitiesParam?.split(',').filter(Boolean),
		services: featuresParam?.split(',').filter(Boolean),
		minRating,
		includeWithoutRating: includeNoReviews,
		bedrooms: minBedrooms,
		bathrooms: minBathrooms,
		featured: isFeatured ?? null,
	},
	counts: {
		shown: cards.length,
		globalTotal: total,
		// When types are filtered, `total` is already the type-specific count
		// from the API, so it doubles as `subjectTotal`.
		subjectTotal: typesArray.length > 0 ? total : undefined,
	},
	sort: sortBy ? { key: sortBy, direction: sortOrder ?? 'asc' } : undefined,
	catalogs: {
		types: DEFAULT_TYPE_GRAMMAR,
		destinations: destinationCatalog,
		amenities: amenityCatalog,
		services: featureCatalog,
	},
});

// Filter configuration for sidebar
// Order: search → featured (toggle, inline) → type → destination → amenities → features → price → rest
const filterGroups: FilterGroup[] = [
	{
		id: 'q',
		label: t('accommodations.sidebar.search', 'Búsqueda por texto'),
		type: 'search',
		placeholder: t('accommodations.sidebar.searchPlaceholder', 'Buscar por nombre o descripción...'),
	},
	{
		id: 'isFeatured',
		label: t('accommodations.sidebar.featured', 'Solo destacados'),
		type: 'toggle',
	},
	{
		id: 'types',
		label: t('accommodations.sidebar.type', 'Tipo de Alojamiento'),
		type: 'checkbox',
		options: [
			{ value: 'APARTMENT', label: getAccommodationTypeLabel({ type: 'APARTMENT', t }) },
			{ value: 'HOUSE', label: getAccommodationTypeLabel({ type: 'HOUSE', t }) },
			{ value: 'COUNTRY_HOUSE', label: getAccommodationTypeLabel({ type: 'COUNTRY_HOUSE', t }) },
			{ value: 'CABIN', label: getAccommodationTypeLabel({ type: 'CABIN', t }) },
			{ value: 'HOTEL', label: getAccommodationTypeLabel({ type: 'HOTEL', t }) },
			{ value: 'HOSTEL', label: getAccommodationTypeLabel({ type: 'HOSTEL', t }) },
			{ value: 'CAMPING', label: getAccommodationTypeLabel({ type: 'CAMPING', t }) },
			{ value: 'ROOM', label: getAccommodationTypeLabel({ type: 'ROOM', t }) },
			{ value: 'RESORT', label: getAccommodationTypeLabel({ type: 'RESORT', t }) },
		],
	},
	{
		id: 'destinationIds',
		label: t('accommodations.sidebar.destination', 'Destino'),
		type: 'select-search',
		options: destinations.map((d) => ({ value: d.id, label: d.name })),
		maxVisible: 8,
	},
	{
		id: 'amenities',
		label: t('accommodations.sidebar.amenities', 'Comodidades'),
		type: 'icon-chips',
		options: amenities.map((a) => ({ value: a.id, label: a.name, icon: a.icon ?? undefined })),
		maxVisible: 10,
	},
	{
		id: 'features',
		label: t('accommodations.sidebar.features', 'Características'),
		type: 'icon-chips',
		options: features.map((f) => ({ value: f.id, label: f.name, icon: f.icon ?? undefined })),
		maxVisible: 10,
	},
	{
		id: 'price',
		label: t('accommodations.sidebar.priceRange', 'Precio por noche'),
		type: 'dual-range',
		min: 5000,
		max: 150000,
		step: 1000,
		format: 'currency',
		includeNullLabel: t('accommodations.sidebar.includeNoPrice', 'Incluir sin precio'),
		includeNullParam: 'includeNoPrice',
	},
	{
		id: 'minGuests',
		label: t('accommodations.sidebar.adults', 'Adultos'),
		type: 'stepper',
		min: 0,
		max: 20,
		defaultValue: 0,
		suffix: t('accommodations.chips.guests', 'huéspedes'),
	},
	{
		id: 'minRating',
		label: t('accommodations.sidebar.rating', 'Calificación'),
		type: 'stars',
		includeNullLabel: t('accommodations.sidebar.includeNoReviews', 'Incluir sin calificación'),
		includeNullParam: 'includeNoReviews',
	},
	{
		id: 'minBedrooms',
		label: t('accommodations.sidebar.bedrooms', 'Dormitorios'),
		type: 'stepper',
		min: 0,
		max: 10,
		defaultValue: 0,
	},
	{
		id: 'minBathrooms',
		label: t('accommodations.sidebar.bathrooms', 'Baños'),
		type: 'stepper',
		min: 0,
		max: 10,
		defaultValue: 0,
	},
];

const sortOptions = [
	{ value: 'relevance', label: t('accommodations.sort.relevance', 'Relevancia') },
	{ value: 'price_asc', label: t('accommodations.sort.priceAsc', 'Precio: menor a mayor') },
	{ value: 'price_desc', label: t('accommodations.sort.priceDesc', 'Precio: mayor a menor') },
	{ value: 'rating', label: t('accommodations.sort.rating', 'Mejor valorados') },
	{ value: 'recent', label: t('accommodations.sort.recent', 'Más recientes') },
	// SPEC-098 T-052 — orders by total active bookmarks (descending) via the
	// `mostSaved` synthetic sort field on the public accommodation list endpoint.
	{ value: 'mostSaved', label: t('ui.sort.most_bookmarked', 'Más guardados') },
];

// ItemList JSON-LD
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: t('accommodations.title', 'Alojamientos'),
	numberOfItems: total,
	itemListElement: cards.map((card, i) => ({
		'@type': 'ListItem',
		position: (page - 1) * pageSize + i + 1,
		url: `${Astro.site ?? Astro.url.origin}${buildUrl({ locale, path: `alojamientos/${card.slug}` })}`,
		name: card.name,
	})),
};

const baseUrl = buildUrl({ locale, path: 'alojamientos' });

/**
 * Quick-filter type badges shown above the listing grid. Uses the canonical
 * enum so any new accommodation type is picked up automatically. The slug
 * for the route is the lowercased enum value with `_` → `-` (e.g.
 * `COUNTRY_HOUSE` → `country-house`) to match `tipo/[type]/index.astro`.
 */
const typeBadges = Object.values(AccommodationTypeEnum).map((value) => {
    const enumValue = String(value);
    const slug = enumValue.toLowerCase().replace(/_/g, '-');
    return {
        type: enumValue,
        href: buildUrl({ locale, path: `/alojamientos/tipo/${slug}/` })
    };
});

// Build initial filter params for the sidebar (avoids hydration flash)
const initialParams: Record<string, string> = {};
if (q) initialParams.q = q;
if (types) initialParams.types = types;
if (destinationIds) initialParams.destinationIds = destinationIds;
if (minPrice !== undefined) initialParams.minPrice = String(minPrice);
if (maxPrice !== undefined) initialParams.maxPrice = String(maxPrice);
if (sortBy) initialParams.sortBy = sortBy;
if (isFeatured) initialParams.isFeatured = 'true';
if (minGuests !== undefined) initialParams.minGuests = String(minGuests);
if (minBedrooms !== undefined) initialParams.minBedrooms = String(minBedrooms);
if (minBathrooms !== undefined) initialParams.minBathrooms = String(minBathrooms);
if (minRating !== undefined) initialParams.minRating = String(minRating);
if (amenitiesParam) initialParams.amenities = amenitiesParam;
if (featuresParam) initialParams.features = featuresParam;
if (includeNoPrice) initialParams.includeNoPrice = 'true';
if (includeNoReviews) initialParams.includeNoReviews = 'true';
---

<ListingLayout
	locale={locale}
	title={t('accommodations.title', 'Alojamientos')}
	description={t('accommodations.description', 'Encontrá los mejores alojamientos del Litoral Entrerriano.')}
	showFilters={true}
	filterPosition="left"
>
	<JsonLd slot="head-extra" data={jsonLd} />

	<Breadcrumbs
		slot="breadcrumbs"
		locale={locale}
		items={[{ label: t('accommodations.title', 'Alojamientos') }]}
	/>

	<ListingPageHeader
		slot="page-header"
		locale={locale}
		tagline={t('accommodations.tagline', 'Encontrá tu lugar ideal')}
		title={t('accommodations.title', 'Alojamientos')}
		totalCount={total}
		filterSummary={filterSummary}
	/>

	<FilterSidebar
		slot="filters"
		client:load
		locale={locale}
		filters={filterGroups}
		sortOptions={sortOptions}
		initialParams={initialParams}
	/>

	<nav
		class="acc-type-badges"
		aria-label={t('accommodations.typeChips.ariaLabel', 'Filtrar por tipo de alojamiento')}
	>
		{typeBadges.map(({ type, href }) => (
			<AccommodationTypeBadge type={type} locale={locale} size="sm" href={href} />
		))}
	</nav>

	{!hasError && cards.length > 0 && (
		<div class="view-toggle" role="tablist" aria-label={t('accommodations.viewToggle.ariaLabel', 'Vista')}>
			<span
				class="view-toggle__btn view-toggle__btn--active"
				role="tab"
				aria-selected="true"
			>
				{t('accommodations.viewToggle.list', 'Lista')}
			</span>
			<a
				href={(() => {
					const sp = new URLSearchParams(url.searchParams);
					sp.delete('page');
					const qs = sp.toString();
					const base = buildUrl({ locale, path: 'alojamientos/mapa' });
					return qs ? `${base}?${qs}` : base;
				})()}
				class="view-toggle__btn"
				role="tab"
				aria-selected="false"
			>
				{t('accommodations.viewToggle.map', 'Mapa')}
			</a>
		</div>
	)}

	{hasError && !result.ok && (
		<ErrorBanner locale={locale} error={result.error} entityName="alojamientos" />
	)}

	{!hasError && cards.length === 0 && (
		<EmptyState
			locale={locale}
			variant="no-results"
			actionUrl={baseUrl}
		/>
	)}

	{!hasError && cards.length > 0 && (
		<div class="acc-grid">
			{cards.map((card, i) => (
				<div data-reveal="up" style={`transition-delay: ${Math.min(i, 6) * 100}ms`}>
					<AccommodationCard data={card} locale={locale} isAuthenticated={isAuthenticated} />
				</div>
			))}
		</div>
	)}

	{totalPages > 1 && (
		<Pagination
			slot="pagination"
			currentPage={page}
			totalPages={totalPages}
			baseUrl={baseUrl.slice(0, -1)}
			locale={locale}
			searchParams={(() => {
				const sp = new URLSearchParams();
				if (q) sp.set('q', q);
				if (types) sp.set('types', types);
				if (destinationIds) sp.set('destinationIds', destinationIds);
				if (minPrice !== undefined) sp.set('minPrice', String(minPrice));
				if (maxPrice !== undefined) sp.set('maxPrice', String(maxPrice));
				if (sortBy) sp.set('sortBy', sortBy);
				if (sortOrder) sp.set('sortOrder', sortOrder);
				if (isFeatured) sp.set('isFeatured', 'true');
				if (minGuests !== undefined) sp.set('minGuests', String(minGuests));
				if (minBedrooms !== undefined) sp.set('minBedrooms', String(minBedrooms));
				if (minBathrooms !== undefined) sp.set('minBathrooms', String(minBathrooms));
				if (minRating !== undefined) sp.set('minRating', String(minRating));
				if (amenitiesParam) sp.set('amenities', amenitiesParam);
				if (featuresParam) sp.set('features', featuresParam);
				if (includeNoPrice) sp.set('includeNoPrice', 'true');
				if (includeNoReviews) sp.set('includeNoReviews', 'true');
				return sp;
			})()}
		/>
	)}
</ListingLayout>


<style>
	/*
	 * Responsive grid: auto-fill with a 260px minimum so the browser determines
	 * how many columns fit rather than relying on fixed breakpoints that break
	 * when the sidebar narrows the available content area.
	 */
	.acc-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: var(--space-card-gap);
	}

	@media (max-width: 480px) {
		.acc-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Dim the grid while a filter navigation is in flight */
	:global([data-filters-loading]) .acc-grid {
		opacity: 0.4;
		pointer-events: none;
		transition: opacity 0.2s ease;
	}

	/* Quick-filter type badges row above the listing grid.
	 * Mirrors the home featured-section ergonomics: wrap on desktop,
	 * horizontal scroll-snap on narrow viewports. */
	.acc-type-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: var(--space-4, 16px);
	}
	@media (max-width: 767px) {
		.acc-type-badges {
			flex-wrap: nowrap;
			overflow-x: auto;
			overflow-y: hidden;
			scroll-snap-type: x mandatory;
			-webkit-overflow-scrolling: touch;
			padding-bottom: 4px;
			mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
			-webkit-mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
		}
		.acc-type-badges::-webkit-scrollbar {
			display: none;
		}
	}

	/* View toggle (Lista / Mapa) */
	.view-toggle {
		display: inline-flex;
		gap: var(--space-2, 8px);
		padding: 4px;
		margin: var(--space-4, 16px) 0;
		background-color: var(--surface-warm, #faf6f0);
		border-radius: var(--radius-pill, 9999px);
	}
	.view-toggle__btn {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-pill, 9999px);
		color: var(--muted-foreground, #555);
		text-decoration: none;
		transition: background-color var(--duration-normal, 0.4s) ease, color var(--duration-normal, 0.4s) ease;
		cursor: pointer;
	}
	.view-toggle__btn:hover {
		color: var(--foreground);
	}
	.view-toggle__btn--active {
		background-color: var(--accent, #f59e0b);
		color: white;
		font-weight: 500;
		cursor: default;
	}
</style>
