---
/**
 * @file alojamientos/index.astro
 * @description Accommodations listing page with filter sidebar, card grid,
 * pagination, and ItemList JSON-LD structured data.
 * @route /{lang}/alojamientos/
 * @rendering SSR + ISR 24h
 */

import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import AccommodationCard from '@/components/shared/cards/AccommodationCard.astro';
import AccommodationGridSkeleton from '@/components/skeletons/AccommodationGridSkeleton.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import Pagination from '@/components/shared/feedback/Pagination.astro';
import ItemListJsonLd from '@/components/seo/ItemListJsonLd.astro';
import AccommodationTypeBadge from '@/components/shared/ui/AccommodationTypeBadge.astro';
import ScrollableNav from '@/components/shared/ui/ScrollableNav.astro';
import { AccommodationTypeEnum } from '@repo/schemas';
import { FilterSidebar } from '@/components/shared/filters/FilterSidebar.client';
import type { FilterGroup } from '@/components/shared/filters/FilterSidebar.client';
import { accommodationsApi, amenitiesApi, destinationsApi, featuresApi } from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { toAccommodationCardProps } from '@/lib/api/transforms';
import { webLogger } from '@/lib/logger';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { getAccommodationTypeLabel } from '@/lib/colors';
import { buildAccommodationListingSummary, DEFAULT_TYPE_GRAMMAR } from '@/lib/accommodation-listing-summary';
import type { CatalogEntry, SummaryLocale } from '@/lib/accommodation-listing-summary';
import { resolveI18nText } from '@/lib/resolve-i18n-text';
import { getApiUrl } from '@/lib/env';
import { SearchChatPanel } from '@/components/ai-search/SearchChatPanel.client';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { t: tEs } = createTranslations('es');
const { t: tEn } = createTranslations('en');

// Read pagination and filter params from URL
const url = Astro.url;
const page = Math.max(1, Number(url.searchParams.get('page')) || 1);
const pageSize = 20;

// Extract filter params
const q = url.searchParams.get('q') ?? undefined;
const types = url.searchParams.get('types') ?? undefined;
const destinationIds = url.searchParams.get('destinationIds') ?? undefined;
const minPrice = url.searchParams.get('minPrice') ? Number(url.searchParams.get('minPrice')) : undefined;
const maxPrice = url.searchParams.get('maxPrice') ? Number(url.searchParams.get('maxPrice')) : undefined;
/**
 * Maps the URL's user-friendly sort key (e.g. `featured`, `priceAsc`) to the
 * backend `(sortBy, sortOrder)` pair. Encoding direction in the key lets the
 * UI offer pre-baked options like "Mejor valorados" / "Precio menor a mayor"
 * without exposing a separate direction toggle.
 *
 * All sortBy fields here MUST be whitelisted in
 * `apps/api/src/routes/accommodation/public/list.ts > ALLOWED_SORT_FIELDS`.
 * `price` and `mostSaved` are synthetic fields handled by the model.
 */
const SORT_OPTION_MAP: Record<string, { sortBy: string; sortOrder: 'asc' | 'desc' }> = {
    featured:     { sortBy: 'isFeatured',    sortOrder: 'desc' },
    mostSaved:    { sortBy: 'mostSaved',     sortOrder: 'desc' },
    ratingDesc:   { sortBy: 'averageRating', sortOrder: 'desc' },
    mostReviewed: { sortBy: 'reviewsCount',  sortOrder: 'desc' },
    newest:       { sortBy: 'createdAt',     sortOrder: 'desc' },
    nameAsc:      { sortBy: 'name',          sortOrder: 'asc'  },
    nameDesc:     { sortBy: 'name',          sortOrder: 'desc' },
    priceAsc:     { sortBy: 'price',         sortOrder: 'asc'  },
    priceDesc:    { sortBy: 'price',         sortOrder: 'desc' },
    // Synthetic — backend orders by haversine distance from the geo center
    // when `latitude`/`longitude` are present, otherwise drops the field and
    // falls through to the id tiebreaker.
    distance:     { sortBy: 'distance',      sortOrder: 'asc'  }
};
/** Default sort key when the URL has no `sortBy`. */
const DEFAULT_SORT_KEY = 'featured';

const rawSortKey = url.searchParams.get('sortBy') ?? DEFAULT_SORT_KEY;

// Public quick-amenity boolean shortcuts. The backend resolves these to
// canonical amenity IDs server-side (PR fix/accommodation-backend-filters-sort).
const hasWifi = url.searchParams.get('hasWifi') === 'true' ? true : undefined;
const hasPool = url.searchParams.get('hasPool') === 'true' ? true : undefined;
const hasParking = url.searchParams.get('hasParking') === 'true' ? true : undefined;
const allowsPets = url.searchParams.get('allowsPets') === 'true' ? true : undefined;
const isFeatured = url.searchParams.get('isFeatured') === 'true' ? true : undefined;
// `minGuests` is no longer exposed as its own field — it's derived from
// `adults + children` further down so a couple looking for "2 adultos +
// 0 niños" actually filters out 1-person studios. The variable is computed
// below once `adults` / `childrenCount` are parsed.
const minBedrooms = url.searchParams.get('minBedrooms') ? Number(url.searchParams.get('minBedrooms')) : undefined;
const minBathrooms = url.searchParams.get('minBathrooms') ? Number(url.searchParams.get('minBathrooms')) : undefined;
const minRating = url.searchParams.get('minRating') ? Number(url.searchParams.get('minRating')) : undefined;
const amenitiesParam = url.searchParams.get('amenities') ?? undefined;
const featuresParam = url.searchParams.get('features') ?? undefined;
// `includeNoPrice` / `includeNoReviews` are default-ON now: the corresponding
// sidebar checkboxes start checked, so the URL only carries the param when the
// user explicitly opts OUT. Only forward the explicit-OFF case to the API
// (passing `true` always would push an unknown param the listing endpoint
// rejects with INVALID_PAGINATION_PARAMS).
const includeNoPrice =
    url.searchParams.get('includeNoPrice') === 'false' ? false : undefined;
const includeNoReviews =
    url.searchParams.get('includeNoReviews') === 'false' ? false : undefined;

// Geo radius (composite filter) — the backend haversine clause needs the
// full triplet; missing or non-numeric values are silently ignored, matching
// the model-layer guard.
const latitudeRaw = url.searchParams.get('latitude');
const longitudeRaw = url.searchParams.get('longitude');
const radiusRaw = url.searchParams.get('radius');
const latitude = latitudeRaw !== null ? Number.parseFloat(latitudeRaw) : Number.NaN;
const longitude = longitudeRaw !== null ? Number.parseFloat(longitudeRaw) : Number.NaN;
const radius = radiusRaw !== null ? Number.parseFloat(radiusRaw) : Number.NaN;
const hasGeoRadius =
	Number.isFinite(latitude) && Number.isFinite(longitude) && Number.isFinite(radius);

// Resolve the encoded sort key. `distance` is only meaningful when the geo
// filter is active, so degrade it to the default if the URL still carries
// `?sortBy=distance` but the user removed the geo center. The backend would
// silently drop it too, but cleaning it up here keeps the SortPopover label
// matching what's actually being applied.
const sortKey =
	rawSortKey === 'distance' && !hasGeoRadius ? DEFAULT_SORT_KEY : rawSortKey;
const sortResolved = SORT_OPTION_MAP[sortKey] ?? SORT_OPTION_MAP[DEFAULT_SORT_KEY];
const sortBy = sortResolved.sortBy;
const sortOrder = sortResolved.sortOrder;

// --- Hero search context ---
// `checkIn` / `checkOut` arrive from the home hero search bar; the listing
// surfaces them in the sidebar but doesn't filter by them yet (no real-time
// availability) — they're forwarded to the detail page so the contact form
// can pre-fill the message.
//
// `adults` / `children` DO filter — their sum is sent to the API as
// `minGuests` further down so a 3+2 party doesn't see 1-bedroom studios.
const checkIn = url.searchParams.get('checkIn') ?? undefined;
const checkOut = url.searchParams.get('checkOut') ?? undefined;
const adultsParam = url.searchParams.get('adults');
const childrenParam = url.searchParams.get('children');
const adults = adultsParam ? Number(adultsParam) : undefined;
const childrenCount = childrenParam ? Number(childrenParam) : undefined;

// Derived guest-capacity filter: sum of adults + children. Used to filter
// accommodations that fit the party size. Falls back to defaults (2 + 0)
// when the URL hasn't been touched.
const guestCount = (adults ?? 2) + (childrenCount ?? 0);
const minGuests = guestCount > 0 ? guestCount : undefined;

// Build a query suffix to forward search context to each accommodation detail link.
const contextQueryParams = new URLSearchParams();
if (checkIn) contextQueryParams.set('checkIn', checkIn);
if (checkOut) contextQueryParams.set('checkOut', checkOut);
if (adults !== undefined && !Number.isNaN(adults)) contextQueryParams.set('adults', String(adults));
if (childrenCount !== undefined && !Number.isNaN(childrenCount)) contextQueryParams.set('children', String(childrenCount));
const contextQuery = contextQueryParams.toString() || undefined;

// Fetch destinations for filter dropdown (CITY only — accommodations are
// browsed by city, not by parent administrative regions).
const destinationsResult = await destinationsApi.list({ destinationType: 'CITY', pageSize: 100 });
const destinations = destinationsResult.ok ? destinationsResult.data.items : [];

// Fetch amenities for filter chips
const amenitiesResult = await amenitiesApi.list({ pageSize: 100, isActive: true, sortBy: 'name', sortOrder: 'asc' });
const amenities = amenitiesResult.ok ? amenitiesResult.data.items : [];

// Fetch features for filter chips
const featuresResult = await featuresApi.list({ pageSize: 100, sortBy: 'displayWeight', sortOrder: 'desc' });
const features = featuresResult.ok ? featuresResult.data.items : [];

// Fetch accommodations
const result = await accommodationsApi.list({
	page,
	pageSize,
	q,
	types,
	destinationIds,
	minPrice,
	maxPrice,
	sortBy,
	sortOrder,
	isFeatured,
	minGuests,
	minBedrooms,
	minBathrooms,
	minRating,
	amenities: amenitiesParam,
	features: featuresParam,
	includeAmenities: true,
	includeNoPrice,
	includeNoReviews,
	hasWifi,
	hasPool,
	hasParking,
	allowsPets,
	latitude: hasGeoRadius ? latitude : undefined,
	longitude: hasGeoRadius ? longitude : undefined,
	radius: hasGeoRadius ? radius : undefined,
});

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.pagination.total : 0;
const totalPages = result.ok ? result.data.pagination.totalPages : 0;

// Transform items for cards
const baseCards = items.map((item) => toAccommodationCardProps({ item: item as unknown as Record<string, unknown>, locale }));

// SPEC-098 T-041 — Pre-hydrate FavoriteButton state for authenticated users.
// We issue a single bulk-check request for all the entity IDs on the current
// page instead of one /check per card. Guests skip this call entirely; their
// FavoriteButton renders in guest mode (auth-required popover on click).
//
// On any failure (network error, 5xx, etc.) we silently degrade — each
// FavoriteButton can still hydrate itself via its own /check fallback so the
// page render is never blocked.
const isAuthenticated = Boolean(Astro.locals.user);
type FavoriteCheckEntry = { readonly isBookmarked: boolean; readonly bookmarkId: string | null };
let favoriteChecks: Readonly<Record<string, FavoriteCheckEntry>> = {};
if (isAuthenticated && baseCards.length > 0) {
    try {
        const bulkResult = await userBookmarksApi.checkBulk({
            entityType: 'ACCOMMODATION',
            entityIds: baseCards.map((card) => card.id)
        });
        if (bulkResult.ok) {
            favoriteChecks = bulkResult.data.checks;
        } else {
            webLogger.warn(
                'Bulk bookmark check failed; falling back to per-card hydration',
                { error: bulkResult.error }
            );
        }
    } catch (error) {
        webLogger.warn(
            'Bulk bookmark check threw; falling back to per-card hydration',
            { error: error instanceof Error ? error.message : String(error) }
        );
    }
}

const cards = baseCards.map((card) => {
    const entry = favoriteChecks[card.id];
    if (!entry) return card;
    return {
        ...card,
        isFavorited: entry.isBookmarked,
        favoriteBookmarkId: entry.bookmarkId
    };
});

// --- Natural language filter summary ---
// Build catalogs from the fetched data for the summary builder.
// Destinations, amenities, and features use id→name from the API.
// The summary module maps these keys to human-readable labels per locale.
const summaryLocale = (locale === 'en' ? 'en' : 'es') as SummaryLocale;

const destinationCatalog: readonly CatalogEntry[] = destinations.map((d) => ({
	key: d.id,
	label: { es: d.name, en: d.name }
}));
// SPEC-266: `name` was dropped from the amenities/features catalog. `slug` is
// now the canonical identifier and is also the i18n key segment.
// slug is nullish per schema; coerce to '' to satisfy the t() signature.
const amenityCatalog: readonly CatalogEntry[] = amenities.map((a) => ({
	key: a.id,
	label: {
		es: tEs(`accommodations.amenityNames.${a.slug ?? ''}`, a.slug ?? undefined),
		en: tEn(`accommodations.amenityNames.${a.slug ?? ''}`, a.slug ?? undefined)
	}
}));
const featureCatalog: readonly CatalogEntry[] = features.map((f) => ({
	key: f.id,
	label: {
		es: tEs(`accommodations.featureNames.${f.slug ?? ''}`, f.slug ?? undefined),
		en: tEn(`accommodations.featureNames.${f.slug ?? ''}`, f.slug ?? undefined)
	}
}));

// When types are active the API already filters by type, so `total` is the
// type-specific count (equivalent to `subjectTotal`). Pass it explicitly so the
// builder can render "hoteles" instead of the generic "hospedajes".
const typesArray = types?.split(',').filter(Boolean) ?? [];
const filterSummary = buildAccommodationListingSummary({
	locale: summaryLocale,
	filters: {
		types: typesArray.length > 0 ? typesArray : undefined,
		text: q,
		price: (minPrice !== undefined || maxPrice !== undefined || includeNoPrice)
			? { min: minPrice, max: maxPrice, includeWithoutPrice: includeNoPrice }
			: undefined,
		destinations: destinationIds?.split(',').filter(Boolean),
		guests: minGuests,
		amenities: amenitiesParam?.split(',').filter(Boolean),
		services: featuresParam?.split(',').filter(Boolean),
		minRating,
		includeWithoutRating: includeNoReviews,
		bedrooms: minBedrooms,
		bathrooms: minBathrooms,
		featured: isFeatured ?? null,
	},
	counts: {
		shown: cards.length,
		globalTotal: total,
		// When types are filtered, `total` is already the type-specific count
		// from the API, so it doubles as `subjectTotal`.
		subjectTotal: typesArray.length > 0 ? total : undefined,
	},
	sort: sortBy ? { key: sortBy, direction: sortOrder ?? 'asc' } : undefined,
	catalogs: {
		types: DEFAULT_TYPE_GRAMMAR,
		destinations: destinationCatalog,
		amenities: amenityCatalog,
		services: featureCatalog,
	},
});

// Filter configuration for sidebar.
// Sectioned layout: 5 themed groups (Ubicación / Tipo y Características /
// Fechas / Capacidad / Precio y Calidad). `section-header` entries divide
// the panel with small-caps headers; the FilterSidebar switches to
// declaration-order rendering when any section-header is declared, so inline
// toggles (`isFeatured`) land under their intended section.
//
// `dates`, `adults`, and `children` live inside the sidebar even though they
// don't narrow the result set today (no availability system) — they're
// forwarded to the accommodation detail link so the contact form can
// pre-fill the message. `emitWhenAtDefault: true` on the steppers keeps the
// URL carrying the values even at their defaults so the context survives
// pagination.
const filterGroups: FilterGroup[] = [
	// Free-text search lives at the very top, OUTSIDE any section, so it reads
	// as a global filter independent of the themed categories below.
	{
		id: 'q',
		label: t('accommodations.sidebar.search', 'Búsqueda por texto'),
		type: 'search',
		placeholder: t('accommodations.sidebar.searchPlaceholder', 'Buscar por nombre o descripción...'),
	},
	{
		id: 'section-location',
		type: 'section-header',
		label: t('accommodations.sidebar.section.location', 'Ubicación'),
		icon: 'MapIcon',
	},
	{
		id: 'destinationIds',
		label: t('accommodations.sidebar.destination', 'Destino'),
		type: 'select-search',
		options: destinations.map((d) => ({ value: d.id, label: d.name, featured: Boolean(d.isFeatured) })),
		maxVisible: 8,
	},
	{
		id: 'location',
		label: t('accommodations.sidebar.geoRadius', 'Cerca de'),
		type: 'geo-radius',
		// Build the anchor list from destinations that ship explicit lat/long
		// coordinates. Strings are parsed once here (the schema stores them as
		// strings) so the runtime payload is plain numbers.
		destinationOptions: destinations
			.map((d) => {
				const coords = d.location?.coordinates;
				const lat = coords ? Number.parseFloat(coords.lat) : Number.NaN;
				const long = coords ? Number.parseFloat(coords.long) : Number.NaN;
				if (!Number.isFinite(lat) || !Number.isFinite(long)) return null;
				return { value: d.id, label: d.name, lat, long, featured: Boolean(d.isFeatured) };
			})
			.filter((opt): opt is { value: string; label: string; lat: number; long: number; featured: boolean } => opt !== null),
		radiusPresets: [5, 10, 25, 50, 100],
		defaultCollapsed: true,
		destinationModeLabel: t('accommodations.sidebar.geoRadius.destinationMode', 'Un destino'),
		browserModeLabel: t('accommodations.sidebar.geoRadius.browserMode', 'Mi ubicación'),
		destinationPlaceholder: t('accommodations.sidebar.geoRadius.destinationPlaceholder', 'Elegí un destino'),
		browserCtaLabel: t('accommodations.sidebar.geoRadius.browserCta', 'Usar mi ubicación'),
		browserPendingLabel: t('accommodations.sidebar.geoRadius.browserPending', 'Detectando…'),
		browserErrorLabel: t('accommodations.sidebar.geoRadius.browserError', 'No pudimos detectar tu ubicación. Revisá los permisos del navegador.'),
		radiusUnitLabel: t('accommodations.sidebar.geoRadius.radiusUnit', 'km'),
	},
	{
		id: 'section-type',
		type: 'section-header',
		label: t('accommodations.sidebar.section.type', 'Tipo y características'),
		icon: 'AccommodationIcon',
	},
	{
		id: 'isFeatured',
		label: t('accommodations.sidebar.featured', 'Solo destacados'),
		type: 'toggle',
	},
	{
		id: 'types',
		label: t('accommodations.sidebar.type', 'Tipo de Alojamiento'),
		type: 'checkbox',
		options: [
			{ value: 'APARTMENT', label: getAccommodationTypeLabel({ type: 'APARTMENT', t }) },
			{ value: 'HOUSE', label: getAccommodationTypeLabel({ type: 'HOUSE', t }) },
			{ value: 'COUNTRY_HOUSE', label: getAccommodationTypeLabel({ type: 'COUNTRY_HOUSE', t }) },
			{ value: 'CABIN', label: getAccommodationTypeLabel({ type: 'CABIN', t }) },
			{ value: 'HOTEL', label: getAccommodationTypeLabel({ type: 'HOTEL', t }) },
			{ value: 'HOSTEL', label: getAccommodationTypeLabel({ type: 'HOSTEL', t }) },
			{ value: 'CAMPING', label: getAccommodationTypeLabel({ type: 'CAMPING', t }) },
			{ value: 'ROOM', label: getAccommodationTypeLabel({ type: 'ROOM', t }) },
			{ value: 'RESORT', label: getAccommodationTypeLabel({ type: 'RESORT', t }) },
			{ value: 'APART_HOTEL', label: getAccommodationTypeLabel({ type: 'APART_HOTEL', t }) },
			{ value: 'ESTANCIA', label: getAccommodationTypeLabel({ type: 'ESTANCIA', t }) },
			{ value: 'BED_AND_BREAKFAST', label: getAccommodationTypeLabel({ type: 'BED_AND_BREAKFAST', t }) },
		],
	},
	{
		id: 'amenities',
		label: t('accommodations.sidebar.amenities', 'Comodidades'),
		type: 'icon-chips',
		// SPEC-266: `name` dropped; use `slug` as the i18n key segment.
		options: amenities.map((a) => ({ value: a.id, label: t(`accommodations.amenityNames.${a.slug ?? ''}`, a.slug ?? undefined), icon: a.icon ?? undefined })),
		maxVisible: 10,
		// Quick-filter shortcuts rendered ABOVE the regular amenity chips.
		// Each `value` is the URL boolean param name that the backend resolves
		// to canonical amenity IDs server-side (with slug variants — e.g.
		// `hasPool` matches both `pool` and `heated_pool`).
		priorityOptions: [
			{ value: 'hasWifi', label: t('accommodations.quickAmenity.wifi', 'WiFi'), icon: 'WifiIcon' },
			{ value: 'hasPool', label: t('accommodations.quickAmenity.pool', 'Pileta'), icon: 'PoolIcon' },
			{ value: 'hasParking', label: t('accommodations.quickAmenity.parking', 'Estacionamiento'), icon: 'CarIcon' },
			{ value: 'allowsPets', label: t('accommodations.quickAmenity.pets', 'Acepta mascotas'), icon: 'DogIcon' },
		],
	},
	{
		id: 'features',
		label: t('accommodations.sidebar.features', 'Características'),
		type: 'icon-chips',
		// SPEC-266: `name` dropped; resolve label from i18n by slug.
		options: features.map((f) => ({ value: f.id, label: t(`accommodations.featureNames.${f.slug ?? ''}`, f.slug ?? undefined), icon: f.icon ?? undefined })),
		maxVisible: 10,
	},
	{
		id: 'section-dates',
		type: 'section-header',
		label: t('accommodations.sidebar.section.dates', 'Fechas'),
		icon: 'CalendarDotsIcon',
	},
	{
		id: 'dates',
		label: t('accommodations.sidebar.dates', 'Llegada y salida'),
		type: 'date-range',
		mode: 'bounds',
		checkInPlaceholder: t('accommodations.contextBar.checkIn', 'Llegada'),
		checkOutPlaceholder: t('accommodations.contextBar.checkOut', 'Salida'),
		description: t(
			'accommodations.sidebar.dates.helper',
			'Por ahora informativo: la disponibilidad en tiempo real está en desarrollo y todavía no afecta los resultados.'
		),
	},
	{
		id: 'section-capacity',
		type: 'section-header',
		label: t('accommodations.sidebar.section.capacity', 'Capacidad'),
		icon: 'UsersIcon',
	},
	{
		id: 'adults',
		label: t('accommodations.sidebar.adults', 'Adultos'),
		type: 'stepper',
		min: 1,
		max: 10,
		defaultValue: 2,
		emitWhenAtDefault: true,
	},
	{
		id: 'children',
		label: t('accommodations.sidebar.children', 'Niños'),
		type: 'stepper',
		min: 0,
		max: 6,
		defaultValue: 0,
		emitWhenAtDefault: true,
		description: t('accommodations.sidebar.children.helper', '(menores de 5 años)'),
	},
	{
		id: 'minBedrooms',
		label: t('accommodations.sidebar.bedrooms', 'Dormitorios'),
		type: 'stepper',
		min: 0,
		max: 10,
		defaultValue: 0,
	},
	{
		id: 'minBathrooms',
		label: t('accommodations.sidebar.bathrooms', 'Baños'),
		type: 'stepper',
		min: 0,
		max: 10,
		defaultValue: 0,
	},
	{
		id: 'section-price-quality',
		type: 'section-header',
		label: t('accommodations.sidebar.section.priceAndQuality', 'Precio y calidad'),
		icon: 'PriceIcon',
	},
	{
		id: 'price',
		label: t('accommodations.sidebar.priceRange', 'Precio por noche'),
		type: 'dual-range',
		min: 5000,
		max: 150000,
		step: 1000,
		format: 'currency',
		includeNullLabel: t('accommodations.sidebar.includeNoPrice', 'Incluir sin precio'),
		includeNullParam: 'includeNoPrice',
		defaultIncludeNull: true,
	},
	{
		id: 'minRating',
		label: t('accommodations.sidebar.rating', 'Calificación mínima'),
		type: 'stars',
		includeNullLabel: t('accommodations.sidebar.includeNoReviews', 'Incluir sin calificación'),
		includeNullParam: 'includeNoReviews',
		defaultIncludeNull: true,
	},
];

// Sort options expose 9 encoded keys, each resolved to a concrete
// `(sortBy, sortOrder)` pair via the SORT_OPTION_MAP at the top of this
// file. Default = `featured` so paid / promoted accommodations land at the
// top of the first page. All sortBy values are whitelisted in the API
// route's ALLOWED_SORT_FIELDS — see PR fix/accommodation-backend-filters-sort.
const sortOptions = [
	{ value: 'featured',     label: t('accommodations.sort.featured',     'Destacados primero') },
	{ value: 'mostSaved',    label: t('accommodations.sort.mostSaved',    'Más guardados') },
	{ value: 'ratingDesc',   label: t('accommodations.sort.ratingDesc',   'Mejor valorados') },
	{ value: 'mostReviewed', label: t('accommodations.sort.mostReviewed', 'Más reseñados') },
	{ value: 'newest',       label: t('accommodations.sort.newest',       'Recién agregados') },
	{ value: 'nameAsc',      label: t('accommodations.sort.nameAsc',      'Nombre (A-Z)') },
	{ value: 'nameDesc',     label: t('accommodations.sort.nameDesc',     'Nombre (Z-A)') },
	{ value: 'priceAsc',     label: t('accommodations.sort.priceAsc',     'Precio: menor a mayor') },
	{ value: 'priceDesc',    label: t('accommodations.sort.priceDesc',    'Precio: mayor a menor') },
	// Distance sort is only meaningful while the geo-radius filter is active
	// (otherwise the backend has no center to measure from and silently
	// drops the field). Surface it as an option only when the user already
	// picked a destination / "Mi ubicación" so the menu stays uncluttered
	// for the common case.
	...(hasGeoRadius
		? [{ value: 'distance', label: t('accommodations.sort.distance', 'Más cercanos') }]
		: []),
];

// ItemList JSON-LD — built from the visible page of cards. Routed through the
// reusable ItemListJsonLd component (which wraps JsonLd) so escaping stays on
// the single canonical JSON-LD path (SPEC-157 D-1).
const itemListEntries = cards.map((card) => ({
	url: new URL(buildUrl({ locale, path: `alojamientos/${card.slug}` }), Astro.site ?? Astro.url.origin).href,
	name: card.name,
}));

const baseUrl = buildUrl({ locale, path: 'alojamientos' });

// Self-canonical for paginated pages (SPEC-157 follow-up). Pages 2+ are served
// at `/{locale}/alojamientos/page/{n}/` via an Astro.rewrite to this listing
// with `?page=n`. Because the rewrite makes `Astro.url.pathname` the base path
// (dropping the `/page/n/` segment), ListingLayout's default
// `canonicalPath = Astro.url.pathname` would canonicalize every paginated page
// back to page 1. We rebuild the real crawlable URL from the page number so
// each paginated page self-canonicalizes and stays indexable.
const canonicalPath = page > 1 ? `${baseUrl}page/${page}/` : baseUrl;

/**
 * Quick-filter type badges shown above the listing grid. Uses the canonical
 * enum so any new accommodation type is picked up automatically. The slug
 * for the route is the lowercased enum value with `_` → `-` (e.g.
 * `COUNTRY_HOUSE` → `country-house`) to match `tipo/[type]/index.astro`.
 */
const typeBadges = Object.values(AccommodationTypeEnum).map((value) => {
    const enumValue = String(value);
    const slug = enumValue.toLowerCase().replace(/_/g, '-');
    return {
        type: enumValue,
        href: buildUrl({ locale, path: `/alojamientos/tipo/${slug}/` })
    };
});

// Build initial filter params for the sidebar (avoids hydration flash).
// The encoded `sortKey` is what the SortPopover reads — NOT the resolved
// backend sortBy column, which is internal to this page.
const initialParams: Record<string, string> = {};
if (q) initialParams.q = q;
if (types) initialParams.types = types;
if (destinationIds) initialParams.destinationIds = destinationIds;
if (minPrice !== undefined) initialParams.minPrice = String(minPrice);
if (maxPrice !== undefined) initialParams.maxPrice = String(maxPrice);
initialParams.sortBy = sortKey;
if (isFeatured) initialParams.isFeatured = 'true';
if (minBedrooms !== undefined) initialParams.minBedrooms = String(minBedrooms);
if (minBathrooms !== undefined) initialParams.minBathrooms = String(minBathrooms);
if (minRating !== undefined) initialParams.minRating = String(minRating);
if (amenitiesParam) initialParams.amenities = amenitiesParam;
if (featuresParam) initialParams.features = featuresParam;
// Default-checked include-null toggles only emit `=false` when the user opts
// out. Anything else (absent, 'true') means checked — see reducer comments.
if (includeNoPrice === false) initialParams.includeNoPrice = 'false';
if (includeNoReviews === false) initialParams.includeNoReviews = 'false';
// Trip-context fields: always seed defaults so the sidebar steppers /
// date inputs render with their last-known values (or 2 adults / 0 kids /
// no dates on a fresh visit).
if (checkIn) initialParams.checkIn = checkIn;
if (checkOut) initialParams.checkOut = checkOut;
initialParams.adults = String(adults ?? 2);
initialParams.children = String(childrenCount ?? 0);
// Quick-amenity boolean shortcuts (priority chips inside the Comodidades group).
if (hasWifi) initialParams.hasWifi = 'true';
if (hasPool) initialParams.hasPool = 'true';
if (hasParking) initialParams.hasParking = 'true';
if (allowsPets) initialParams.allowsPets = 'true';
if (hasGeoRadius) {
	initialParams.latitude = String(latitude);
	initialParams.longitude = String(longitude);
	initialParams.radius = String(radius);
}

// ---------------------------------------------------------------------------
// Empty state recovery: removable filter chips + secondary suggestions.
// Only built when there are zero results AND at least one filter is active.
// ---------------------------------------------------------------------------
const activeFilterChips: { label: string; removeUrl: string }[] = [];

/** Build a URL identical to the current one minus the given keys. */
const urlWithoutKeys = (keys: readonly string[]): string => {
	const sp = new URLSearchParams(url.searchParams);
	for (const k of keys) sp.delete(k);
	sp.delete('page');
	const qs = sp.toString();
	return qs ? `${baseUrl}?${qs}` : baseUrl;
};

/** Build a URL with a single value removed from a comma-separated list param. */
const urlWithoutListValue = (key: string, value: string): string => {
	const sp = new URLSearchParams(url.searchParams);
	const current = (sp.get(key) ?? '').split(',').filter(Boolean);
	const next = current.filter((v) => v !== value);
	if (next.length > 0) sp.set(key, next.join(','));
	else sp.delete(key);
	sp.delete('page');
	const qs = sp.toString();
	return qs ? `${baseUrl}?${qs}` : baseUrl;
};

if (q) {
	activeFilterChips.push({ label: `"${q}"`, removeUrl: urlWithoutKeys(['q']) });
}
for (const typeValue of typesArray) {
	activeFilterChips.push({
		label: getAccommodationTypeLabel({ type: typeValue, t }),
		removeUrl: urlWithoutListValue('types', typeValue),
	});
}
if (destinationIds) {
	for (const id of destinationIds.split(',').filter(Boolean)) {
		const dest = destinations.find((d) => d.id === id);
		if (dest) {
			activeFilterChips.push({
				label: dest.name,
				removeUrl: urlWithoutListValue('destinationIds', id),
			});
		}
	}
}
if (amenitiesParam) {
	for (const id of amenitiesParam.split(',').filter(Boolean)) {
		const a = amenities.find((x) => x.id === id);
		if (a) {
			// SPEC-266: `name` dropped; use `slug` as i18n key.
			activeFilterChips.push({
				label: t(`accommodations.amenityNames.${a.slug ?? ''}`, a.slug ?? undefined),
				removeUrl: urlWithoutListValue('amenities', id),
			});
		}
	}
}
if (featuresParam) {
	for (const id of featuresParam.split(',').filter(Boolean)) {
		const f = features.find((x) => x.id === id);
		if (f) {
			// SPEC-266: `name` dropped; resolve label from i18n by slug.
			activeFilterChips.push({
				label: t(`accommodations.featureNames.${f.slug ?? ''}`, f.slug ?? undefined),
				removeUrl: urlWithoutListValue('features', id),
			});
		}
	}
}
if (minPrice !== undefined || maxPrice !== undefined) {
	const priceLabel = t('accommodations.emptyChip.price', 'Precio');
	activeFilterChips.push({
		label: priceLabel,
		removeUrl: urlWithoutKeys(['minPrice', 'maxPrice', 'includeNoPrice']),
	});
}
if (isFeatured) {
	activeFilterChips.push({
		label: t('accommodations.emptyChip.featured', 'Solo destacados'),
		removeUrl: urlWithoutKeys(['isFeatured']),
	});
}
if (minRating !== undefined) {
	activeFilterChips.push({
		label: `${minRating}+ ★`,
		removeUrl: urlWithoutKeys(['minRating', 'includeNoReviews']),
	});
}
// `minGuests` is derived from adults + children — no standalone chip; the
// user adjusts party size from the sidebar steppers instead.
if (minBedrooms !== undefined && minBedrooms > 0) {
	activeFilterChips.push({
		label: `${minBedrooms}+ ${t('accommodations.sidebar.bedrooms', 'Dormitorios')}`,
		removeUrl: urlWithoutKeys(['minBedrooms']),
	});
}
if (minBathrooms !== undefined && minBathrooms > 0) {
	activeFilterChips.push({
		label: `${minBathrooms}+ ${t('accommodations.sidebar.bathrooms', 'Baños')}`,
		removeUrl: urlWithoutKeys(['minBathrooms']),
	});
}

/** Secondary recovery links shown alongside the "clear all" CTA. */
const emptyStateSuggestions = [
	{
		label: t('accommodations.emptySuggestion.viewMap', 'Ver en mapa'),
		url: buildUrl({ locale, path: 'alojamientos/mapa' }),
	},
	{
		label: t('accommodations.emptySuggestion.popular', 'Ver más reservados'),
		url: `${baseUrl}?sortBy=mostSaved`,
	},
	{
		label: t('accommodations.emptySuggestion.allDestinations', 'Explorar destinos'),
		url: buildUrl({ locale, path: 'destinos' }),
	},
];
---

<ListingLayout
	locale={locale}
	title={t('accommodations.title', 'Alojamientos')}
	description={t('accommodations.description', 'Encontrá los mejores alojamientos del Litoral Entrerriano.')}
	canonicalPath={canonicalPath}
	showFilters={true}
	filterPosition="left"
	ogTagline={t('accommodations.tagline', 'Encontrá tu lugar ideal')}
>
	<ItemListJsonLd
		slot="head-extra"
		name={t('accommodations.title', 'Alojamientos')}
		items={itemListEntries}
		numberOfItems={total}
		startPosition={(page - 1) * pageSize + 1}
	/>

	<Breadcrumbs
		slot="breadcrumbs"
		locale={locale}
		items={[{ label: t('accommodations.title', 'Alojamientos') }]}
	/>

	<ListingPageHeader
		slot="page-header"
		locale={locale}
		tagline={t('accommodations.tagline', 'Encontrá tu lugar ideal')}
		title={t('accommodations.title', 'Alojamientos')}
		totalCount={total}
		filterSummary={filterSummary}
	/>

	<FilterSidebar
		slot="filters"
		client:load
		locale={locale}
		filters={filterGroups}
		sortOptions={sortOptions}
		initialParams={initialParams}
	/>

	<ScrollableNav
		ariaLabel={t('accommodations.typeChips.ariaLabel', 'Filtrar por tipo de alojamiento')}
		innerClass="acc-type-badges"
	>
		{typeBadges.map(({ type, href }) => (
			<AccommodationTypeBadge type={type} locale={locale} size="sm" href={href} />
		))}
	</ScrollableNav>

	{!hasError && cards.length > 0 && (
		<div class="view-toggle" role="tablist" aria-label={t('accommodations.viewToggle.ariaLabel', 'Vista')}>
			<span
				class="view-toggle__btn view-toggle__btn--active"
				role="tab"
				aria-selected="true"
			>
				{t('accommodations.viewToggle.list', 'Lista')}
			</span>
			<a
				href={(() => {
					const sp = new URLSearchParams(url.searchParams);
					sp.delete('page');
					const qs = sp.toString();
					const base = buildUrl({ locale, path: 'alojamientos/mapa' });
					return qs ? `${base}?${qs}` : base;
				})()}
				class="view-toggle__btn"
				role="tab"
				aria-selected="false"
			>
				{t('accommodations.viewToggle.map', 'Mapa')}
			</a>
		</div>
	)}

	<!--
	    Conversational AI search panel (SPEC-212) — chat-based natural-language
	    search that replaces the SPEC-199 single-shot NL input. Placed above the
	    results grid so the user finds it immediately after the type-badge nav.
	    Uses client:load because the panel should be ready for interaction without
	    requiring scroll (it sits near the top of the main content area).
	-->
	<SearchChatPanel
		client:load
		locale={locale}
		apiUrl={getApiUrl()}
		isAuthenticated={isAuthenticated}
		currentUrl={Astro.url.href}
		destinations={Object.fromEntries(destinations.map((d) => [d.id, d.name]))}
		pageType={typesArray[0]}
	/>

	{hasError && !result.ok && (
		<ErrorBanner locale={locale} error={result.error} entityName="alojamientos" />
	)}

	{!hasError && cards.length === 0 && (
		<EmptyState
			locale={locale}
			variant="no-results"
			actionUrl={baseUrl}
			activeFilters={activeFilterChips}
			suggestions={emptyStateSuggestions}
		/>
	)}

	{!hasError && cards.length > 0 && (
		<>
			<div class="acc-grid">
				{cards.map((card, i) => (
					<div data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
						{/* First row of the listing grid (auto-fill minmax(260px)) fits
						    3 cards at 1024–1280px viewport with the filter sidebar open.
						    Marking them eager prioritises LCP image loading above the fold. */}
						<AccommodationCard
							data={card}
							locale={locale}
							isAuthenticated={isAuthenticated}
							linkQuery={contextQuery}
							eager={i < 3}
						/>
					</div>
				))}
			</div>
			{/*
			 * Skeleton swaps in while a filter navigation is in flight
			 * (html[data-filters-loading]). Stays in the DOM so it renders
			 * instantly when the flag flips — no JS needed at swap time.
			 */}
			<div class="acc-grid-skeleton" aria-hidden="true">
				<AccommodationGridSkeleton />
			</div>
		</>
	)}

	{totalPages > 1 && (
		<Pagination
			slot="pagination"
			currentPage={page}
			totalPages={totalPages}
			baseUrl={baseUrl.slice(0, -1)}
			locale={locale}
			searchParams={(() => {
				// Forward every URL param except `page` so pagination links
				// preserve the full filter/sort/context set. Cheaper and more
				// future-proof than re-listing every supported field.
				const sp = new URLSearchParams(url.searchParams);
				sp.delete('page');
				return sp;
			})()}
		/>
	)}

</ListingLayout>


<style>
	/*
	 * Responsive grid: auto-fill with a 260px minimum so the browser determines
	 * how many columns fit rather than relying on fixed breakpoints that break
	 * when the sidebar narrows the available content area.
	 */
	.acc-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: var(--space-card-gap);
	}

	@media (max-width: 480px) {
		.acc-grid {
			grid-template-columns: 1fr;
		}
	}

	/*
	 * Filter navigation feedback: while filtering, hide the (now stale) real
	 * grid and surface the skeleton so the user sees instant "loading"
	 * feedback instead of a dimmed list with the old results showing through.
	 */
	.acc-grid-skeleton {
		display: none;
	}

	:global([data-filters-loading]) .acc-grid {
		display: none;
	}

	:global([data-filters-loading]) .acc-grid-skeleton {
		display: block;
	}

	/* Quick-filter type badges row above the listing grid.
	 * Scroll affordance (overflow/fade/arrows) is provided by the
	 * <ScrollableNav> wrapper — this rule only sets the row spacing. */
	.acc-type-badges {
		gap: 0.5rem;
		margin-bottom: var(--space-4, 16px);
	}

	/* View toggle (Lista / Mapa) */
	.view-toggle {
		display: inline-flex;
		gap: var(--space-2, 8px);
		padding: 4px;
		margin: var(--space-4, 16px) 0;
		background-color: var(--surface-warm, #faf6f0);
		border-radius: var(--radius-pill, 9999px);
		border: 1px solid transparent;
	}
	.view-toggle__btn {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-pill, 9999px);
		color: var(--core-muted-foreground);
		text-decoration: none;
		transition: background-color var(--duration-normal, 0.4s) ease, color var(--duration-normal, 0.4s) ease;
		cursor: pointer;
	}
	.view-toggle__btn:hover {
		color: var(--core-foreground);
	}
	.view-toggle__btn--active {
		background-color: var(--brand-accent);
		color: white;
		font-weight: 500;
		cursor: default;
	}

	/*
	 * Mobile: turn the toggle into a fixed bottom tab bar (Airbnb / Booking
	 * pattern) so users can switch views from any scroll position. Stays
	 * solid (opaque background + shadow) to read against cards behind it.
	 *
	 * z-index 150 sits above page content but below:
	 * - drawer overlay (300) / drawer panel (400) — drawer covers it
	 * - mobile menu overlay (9100) — menu covers it
	 * - feedback FAB (max int) — feedback FAB is now hidden whenever those
	 *   surfaces open, so no overlap conflict.
	 *
	 * Hidden while any blocking overlay is open via `:global(html[...])`.
	 */
	@media (max-width: 767px) {
		.view-toggle {
			position: fixed;
			/* Lift above the cookie banner (or any future bottom overlay) via
			 * the shared --bottom-safe-inset token defined in global.css. */
			bottom: calc(1.5rem + var(--bottom-safe-inset, 0px));
			left: 50%;
			transform: translateX(-50%);
			z-index: 150;
			margin: 0;
			/* Frosted-glass surface (see global.css → --frost-* tokens). Lets the
			 * content underneath show through with a soft blur so the toggle
			 * doesn't read as a flat patch over cards / the map. */
			background-color: var(--frost-bg-light);
			backdrop-filter: blur(var(--frost-blur));
			-webkit-backdrop-filter: blur(var(--frost-blur));
			border-color: var(--frost-border);
			box-shadow: 0 4px 18px oklch(0 0 0 / 0.18), 0 1px 3px oklch(0 0 0 / 0.08);
		}

		:global(html[data-filters-drawer-open]) .view-toggle,
		:global(html[data-search-panel-open]) .view-toggle,
		:global(html[data-mobile-menu-open]) .view-toggle {
			visibility: hidden;
			pointer-events: none;
		}
	}
</style>
