---
export const prerender = false;

/**
 * Accommodation List page - Airbnb-style redesign.
 * SSR page with URL query params for search, filters, sorting, and pagination.
 *
 * @route /[lang]/alojamientos/
 * @rendering SSR (Server-Side Rendering) - filters require dynamic query params
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import AccommodationCardDetailed from '../../../components/accommodation/AccommodationCardDetailed.astro';
import SearchBar from '../../../components/accommodation/SearchBar.astro';
import { FilterChipsBar } from '../../../components/accommodation/FilterChipsBar.client';
import ActiveFilters from '../../../components/accommodation/ActiveFilters.astro';
import SortDropdown from '../../../components/accommodation/SortDropdown.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import AccommodationErrorState from '../../../components/error/AccommodationErrorState.astro';
import Pagination from '../../../components/ui/Pagination.astro';
import type { AccommodationPublic } from '@repo/schemas';
import { getLocaleFromParams, type SupportedLocale } from '../../../lib/page-helpers';
import { t as i18nT } from '../../../lib/i18n';
import { accommodationsApi } from '../../../lib/api/endpoints';
import { toAccommodationDetailedProps } from '../../../lib/api/transforms';

/** API response shape with optional relations and nested data */
interface AccommodationWithRelations extends AccommodationPublic {
    readonly location?: {
        readonly city?: string;
        readonly state?: string | null;
    };
    readonly reviewsCount?: number;
    readonly extraInfo?: {
        readonly capacity?: number;
        readonly bedrooms?: number;
        readonly beds?: number;
        readonly bathrooms?: number;
    };
    readonly price?: {
        readonly amount: number;
        readonly currency: string;
    };
}

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');
const basePath = `/${locale}/alojamientos/`;

// ─── Read ALL query params ──────────────────────────────────────────────────
const sp = Astro.url.searchParams;
const q = sp.get('q') || undefined;
const typeFilter = sp.get('type') || undefined;
const sortParam = sp.get('sortBy') || 'featured';

// Map user-friendly sort values to actual DB column names + direction
const SORT_MAP: Record<string, { sortBy: string; sortOrder: 'asc' | 'desc' }> = {
    featured: { sortBy: 'isFeatured', sortOrder: 'desc' },
    price_asc: { sortBy: 'name', sortOrder: 'asc' }, // price is JSONB, fallback to name
    price_desc: { sortBy: 'name', sortOrder: 'desc' }, // price is JSONB, fallback to name
    rating: { sortBy: 'averageRating', sortOrder: 'desc' },
    recent: { sortBy: 'createdAt', sortOrder: 'desc' },
    name: { sortBy: 'name', sortOrder: 'asc' },
};
const sortConfig = SORT_MAP[sortParam] ?? SORT_MAP.featured;
const sortBy = sortConfig.sortBy;
const sortOrder = sortConfig.sortOrder;
const page = Number.parseInt(sp.get('page') || '1', 10);
const perPage = 12;

// Price filters
const minPrice = sp.get('minPrice') ? Number(sp.get('minPrice')) : undefined;
const maxPrice = sp.get('maxPrice') ? Number(sp.get('maxPrice')) : undefined;
const currency = sp.get('currency') || undefined;

// Capacity filters
const minGuests = sp.get('minGuests') ? Number(sp.get('minGuests')) : undefined;
const minBedrooms = sp.get('minBedrooms') ? Number(sp.get('minBedrooms')) : undefined;
const minBathrooms = sp.get('minBathrooms') ? Number(sp.get('minBathrooms')) : undefined;

// Rating filter
const minRating = sp.get('minRating') ? Number(sp.get('minRating')) : undefined;

// Boolean filters
const hasWifi = sp.get('hasWifi') === 'true' ? true : undefined;
const hasPool = sp.get('hasPool') === 'true' ? true : undefined;
const allowsPets = sp.get('allowsPets') === 'true' ? true : undefined;
const hasParking = sp.get('hasParking') === 'true' ? true : undefined;

// ─── Fetch data ─────────────────────────────────────────────────────────────
const result = await accommodationsApi.list({
    page,
    pageSize: perPage,
    q,
    sortBy,
    sortOrder,
    type: typeFilter,
    includeAmenities: true,
    includeFeatures: true,
    minPrice,
    maxPrice,
    currency,
    minGuests,
    minBedrooms,
    minBathrooms,
    minRating,
    hasWifi,
    hasPool,
    allowsPets,
    hasParking,
});

const apiError = !result.ok;
const accommodations = result.ok ? (result.data.items as AccommodationWithRelations[]) : [];
const pagination = result.ok
    ? result.data.pagination
    : { page: 1, pageSize: perPage, total: 0, totalPages: 0, hasNextPage: false, hasPreviousPage: false };

// ─── Build filter state for components ──────────────────────────────────────
/** Collect current query params as a flat record for FilterChipsBar */
const currentFilters: Record<string, string> = {};
for (const [key, value] of sp.entries()) {
    if (key !== 'page') currentFilters[key] = value;
}

/** Preserve params for search bar */
const preserveParams: Record<string, string> = { ...currentFilters };
delete preserveParams.q;

/** Accommodation type options for the type filter dropdown */
const typeOptions: Record<string, readonly { readonly value: string; readonly label: string }[]> = {
    es: [
        { value: 'HOTEL', label: 'Hotel' }, { value: 'CABIN', label: 'Cabaña' },
        { value: 'APARTMENT', label: 'Departamento' }, { value: 'HOUSE', label: 'Casa' },
        { value: 'COUNTRY_HOUSE', label: 'Casa de campo' }, { value: 'HOSTEL', label: 'Hostal' },
        { value: 'CAMPING', label: 'Camping' }, { value: 'ROOM', label: 'Habitación' },
        { value: 'MOTEL', label: 'Motel' }, { value: 'RESORT', label: 'Resort' },
    ],
    en: [
        { value: 'HOTEL', label: 'Hotel' }, { value: 'CABIN', label: 'Cabin' },
        { value: 'APARTMENT', label: 'Apartment' }, { value: 'HOUSE', label: 'House' },
        { value: 'COUNTRY_HOUSE', label: 'Country house' }, { value: 'HOSTEL', label: 'Hostel' },
        { value: 'CAMPING', label: 'Camping' }, { value: 'ROOM', label: 'Room' },
        { value: 'MOTEL', label: 'Motel' }, { value: 'RESORT', label: 'Resort' },
    ],
    pt: [
        { value: 'HOTEL', label: 'Hotel' }, { value: 'CABIN', label: 'Cabana' },
        { value: 'APARTMENT', label: 'Apartamento' }, { value: 'HOUSE', label: 'Casa' },
        { value: 'COUNTRY_HOUSE', label: 'Chácara' }, { value: 'HOSTEL', label: 'Hostel' },
        { value: 'CAMPING', label: 'Camping' }, { value: 'ROOM', label: 'Quarto' },
        { value: 'MOTEL', label: 'Motel' }, { value: 'RESORT', label: 'Resort' },
    ],
};

// ─── Localized texts via i18n ────────────────────────────────────────────────
/** Helper to translate accommodation list page keys */
const tList = (key: string) => i18nT({ locale, namespace: 'accommodations', key: `listPage.${key}` });

const breadcrumbItems = [
    { label: tList('home'), href: `/${locale}/` },
    { label: tList('breadcrumb'), href: basePath },
];

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// ─── Transform accommodations for cards ─────────────────────────────────────
const cards = accommodations.map((acc) =>
    toAccommodationDetailedProps({ item: acc as unknown as Record<string, unknown> })
);

/** Search params to pass to Pagination (preserves filters when paginating) */
const paginationSearchParams = new URLSearchParams();
for (const [key, value] of Object.entries(currentFilters)) {
    paginationSearchParams.set(key, value);
}
---

<BaseLayout title={tList('title')} description={tList('description')} locale={locale}>
    <SEOHead
        slot="head"
        title={tList('title')}
        description={tList('description')}
        canonical={canonicalUrl}
        locale={locale}
    />

    <Container>
        <Breadcrumb items={breadcrumbItems} class="py-4" />

        <!-- Page Title -->
        <h1 class="mb-4 font-serif text-3xl font-bold text-text sm:text-4xl">
            {tList('title')}
        </h1>

        <!-- Search Bar -->
        <div class="mb-4">
            <SearchBar query={q ?? ''} locale={locale} preserveParams={preserveParams} />
        </div>

        <!-- Filter Chips Bar -->
        <div class="mb-4">
            <FilterChipsBar
                client:idle
                currentFilters={currentFilters}
                locale={locale}
                accommodationTypes={typeOptions[locale] ?? typeOptions.es}
            />
        </div>

        <!-- Results count + Sort + Active Filters -->
        <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-sm text-text-secondary">
                {tList('showing')} <span class="font-medium text-text">{accommodations.length}</span> {tList('of')} <span class="font-medium text-text">{pagination.total}</span> {tList('results')}
            </p>
            <SortDropdown currentSort={sortParam} locale={locale} />
        </div>

        <!-- Active filter tags -->
        {Object.keys(currentFilters).length > 0 && (
            <div class="mb-6">
                <ActiveFilters filters={currentFilters} locale={locale} basePath={basePath} />
            </div>
        )}

        <!-- Accommodation Grid -->
        {apiError ? (
            <AccommodationErrorState locale={locale} retryHref={basePath} />
        ) : cards.length > 0 ? (
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {cards.map((card) => (
                    <AccommodationCardDetailed
                        id={card.id}
                        slug={card.slug}
                        name={card.name}
                        type={card.type}
                        images={card.images}
                        location={card.location}
                        capacity={card.capacity}
                        bedrooms={card.bedrooms}
                        beds={card.beds}
                        bathrooms={card.bathrooms}
                        averageRating={card.averageRating}
                        reviewsCount={card.reviewsCount}
                        price={card.price}
                        isFeatured={card.isFeatured}
                        locale={locale}
                    />
                ))}
            </div>
        ) : (
            <EmptyState
                title={tList('noResults')}
                message={tList('noResultsMessage')}
                cta={{ label: tList('clearFilters'), href: basePath }}
            />
        )}

        <!-- Pagination (query-param mode) -->
        <Pagination
            currentPage={page}
            totalPages={pagination.totalPages}
            baseUrl={basePath.endsWith('/') ? basePath.slice(0, -1) : basePath}
            locale={locale}
            searchParams={paginationSearchParams}
        />
    </Container>
</BaseLayout>
