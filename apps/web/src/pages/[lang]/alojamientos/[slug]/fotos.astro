---
/**
 * @file alojamientos/[slug]/fotos.astro
 * @description Full photo gallery sub-page with fixed-ratio CSS grid layout.
 * All media items open via GLightbox. Replaces the former columns masonry.
 * Breakpoints: >=1024px → 3 cols, 640-1023px → 2 cols, <640px → 1 col.
 * Cell ratio: 4/3 (galleryHalf preset, c_fill crop).
 * @route /{lang}/alojamientos/{slug}/fotos/
 * @rendering SSR (on-demand)
 */

import DetailLayout from '@/layouts/DetailLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { accommodationsApi } from '@/lib/api/endpoints';
import { toAccommodationDetailPageProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { getMediaUrl } from '@repo/media';

export const prerender = false;

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { slug } = Astro.params;

if (!slug) return new Response(null, { status: 404 });

const result = await accommodationsApi.getBySlug({ slug });
if (!result.ok || !result.data) return new Response(null, { status: 404 });

const accommodation = toAccommodationDetailPageProps({
    item: result.data as Record<string, unknown>
});

// Build gallery items: featured image first, then gallery images, then videos
function extractYoutubeId(url: string): string | null {
    const m = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
    return m?.[1] ?? null;
}

interface GalleryItem {
    type: 'image' | 'video';
    /** Full-size URL used as the GLightbox href (large/uncropped). */
    src: string;
    /**
     * Original thumb URL (YouTube poster or raw image URL).
     * Kept for video fallback chaining.
     */
    thumb: string;
    /**
     * Grid cell thumbnail URL — applies galleryHalf preset (c_fill, 4:3, 640px)
     * for Cloudinary images. Non-Cloudinary URLs (YouTube posters) pass through
     * unchanged (getMediaUrl returns them as-is).
     */
    thumbGrid: string;
    thumbFallback?: string;
    alt: string;
    caption?: string;
    description?: string;
}

const galleryItems: GalleryItem[] = [];

// Featured image first
if (accommodation.featuredImage && !accommodation.featuredImage.includes('placeholder')) {
    const featuredSrc = accommodation.featuredImage;
    galleryItems.push({
        type: 'image',
        src: featuredSrc,
        thumb: featuredSrc,
        // Apply galleryHalf preset for the grid cell thumbnail (4:3, c_fill, 640px).
        // Non-Cloudinary URLs pass through unchanged.
        thumbGrid: getMediaUrl(featuredSrc, { preset: 'galleryHalf' }),
        alt: accommodation.name
    });
}

// Gallery images (skip duplicate of featured). Prefer galleryItems so captions
// survive (GAP-078-136); fall back to the URL list for legacy payloads.
const galleryEntries = accommodation.media.galleryItems.length > 0
    ? accommodation.media.galleryItems
    : accommodation.media.images.map((url) => ({ url }));
for (const entry of galleryEntries) {
    if (entry.url !== accommodation.featuredImage) {
        galleryItems.push({
            type: 'image',
            src: entry.url,
            thumb: entry.url,
            // Grid thumbnail: c_fill 4:3 crop via galleryHalf preset.
            thumbGrid: getMediaUrl(entry.url, { preset: 'galleryHalf' }),
            alt: entry.caption ?? accommodation.name,
            caption: entry.caption,
            description: entry.description
        });
    }
}

// Videos — YouTube poster URLs are not Cloudinary; getMediaUrl passes them through.
for (const entry of accommodation.media.videos) {
    const ytId = extractYoutubeId(entry.url);
    const posterUrl = ytId
        ? `https://img.youtube.com/vi/${ytId}/maxresdefault.jpg`
        : accommodation.featuredImage;
    galleryItems.push({
        type: 'video',
        src: entry.url,
        thumb: posterUrl,
        // YouTube poster: non-Cloudinary → passes through unchanged (no c_fill crop).
        thumbGrid: getMediaUrl(posterUrl, { preset: 'galleryHalf' }),
        thumbFallback: ytId ? `https://img.youtube.com/vi/${ytId}/hqdefault.jpg` : undefined,
        alt: entry.caption ?? `${accommodation.name} - video`,
        caption: entry.caption,
        description: entry.description
    });
}

const seoTitle = `${t('accommodations.detail.gallery.photosSubpage')} - ${accommodation.name} | Hospeda`;
const backUrl = `/${locale}/alojamientos/${slug}/`;

const jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'ImageGallery',
    name: `${t('accommodations.detail.gallery.photosSubpage')} - ${accommodation.name}`,
    url: Astro.url.href,
    image: galleryItems.filter((i) => i.type === 'image').map((i) => i.src)
};
---

<DetailLayout
    locale={locale}
    title={seoTitle}
    description={accommodation.summary}
    showBreadcrumbs={true}
    showSidebar={false}
>
    <JsonLd slot="head-extra" data={jsonLd} />

    <Breadcrumbs
        slot="breadcrumbs"
        locale={locale}
        items={[
            { label: t('accommodations.title'), path: 'alojamientos' },
            { label: accommodation.name, path: `alojamientos/${slug}` },
            { label: t('accommodations.detail.gallery.photosSubpage') }
        ]}
    />

    <Fragment slot="page-header">
        <h1 class="fotos__title">{t('accommodations.detail.gallery.photosSubpage')} - {accommodation.name}</h1>
    </Fragment>

    <div class="fotos">
        <div class="fotos__back-row">
            <a href={backUrl} class="fotos__back">
                {t('accommodations.detail.gallery.backToAccommodation')}
            </a>
        </div>

        <div class="fotosGrid">
            {galleryItems.map((item, i) => (
                <div class="fotosCell">
                    <a
                        href={item.src}
                        data-glightbox
                        data-gallery="accommodation-gallery"
                        data-title={item.caption ?? undefined}
                        data-description={item.description ?? undefined}
                        aria-label={t('accommodations.detail.gallery.viewFullscreen', { n: i + 1 })}
                        class="fotos__link"
                    >
                        <img
                            src={item.thumbGrid}
                            alt={item.alt}
                            loading="lazy"
                            decoding="async"
                            class="fotos__cellImg"
                            data-fallback={item.thumbFallback ?? undefined}
                        />
                        {item.type === 'video' && (
                            <span class="fotos__play" aria-hidden="true">&#9654;</span>
                        )}
                    </a>
                </div>
            ))}
        </div>

        <div class="fotos__footer">
            <a href={backUrl} class="fotos__back fotos__back--footer">
                {t('accommodations.detail.gallery.backToAccommodation')}
            </a>
        </div>
    </div>
</DetailLayout>

<style>
    .fotos__title {
        font-family: var(--font-heading);
        font-size: clamp(1.3rem, 3vw, 2rem);
        font-weight: 700;
        color: var(--core-foreground);
        margin: 0;
    }
    .fotos__back-row {
        margin-bottom: var(--space-5, 20px);
    }
    .fotos__back {
        font-family: var(--font-sans);
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--brand-primary);
        text-decoration: none;
    }
    .fotos__back:hover {
        text-decoration: underline;
    }
    /*
     * Fixed-ratio grid — replaces the former columns masonry.
     * Spec §5: >=1024px = 3 cols, 640-1023px = 2 cols, <640px = 1 col.
     * Cell ratio: 4/3 (galleryHalf preset, c_fill crop).
     * SPEC-186 §6 class names: .fotosGrid / .fotosCell.
     */
    .fotosGrid {
        display: grid;
        /* Desktop (>=1024px): 3 equal columns. */
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-card-gap, 16px);
    }
    /* Tablet: 640px–1023px → 2 columns. */
    @media (max-width: 1023px) {
        .fotosGrid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    /* Mobile: <640px → 1 column. */
    @media (max-width: 639px) {
        .fotosGrid {
            grid-template-columns: 1fr;
        }
    }

    .fotosCell {
        /* Fixed 4:3 ratio reserves space before image loads → zero CLS. */
        aspect-ratio: 4 / 3;
        overflow: hidden;
        border-radius: var(--radius-card, 24px);
        position: relative;
    }

    .fotos__link {
        display: block;
        width: 100%;
        height: 100%;
        position: relative;
    }

    /* Cell image fills the fixed-ratio container via object-fit: cover. */
    .fotos__cellImg {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        object-position: center;
        transition: transform var(--duration-normal, 0.4s) ease;
    }
    .fotos__link:hover .fotos__cellImg {
        transform: scale(1.04);
    }
    .fotos__play {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: oklch(0 0 0 / 0.35);
        color: white;
        font-size: 2.5rem;
        pointer-events: none;
    }
    .fotos__footer {
        display: flex;
        justify-content: center;
        margin-top: var(--space-6, 24px);
        padding-top: var(--space-6, 24px);
        border-top: 1px solid var(--border, oklch(0.9 0 0));
    }
    .fotos__back--footer {
        padding: var(--space-2, 8px) var(--space-5, 20px);
        border: 1px solid var(--border, oklch(0.8 0 0));
        border-radius: var(--radius-button, 8px);
        transition: all var(--duration-normal, 0.4s) ease;
    }
    .fotos__back--footer:hover {
        background-color: var(--brand-primary);
        color: white;
        border-color: var(--brand-primary);
        text-decoration: none;
    }
</style>
