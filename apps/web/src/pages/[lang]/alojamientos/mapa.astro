---
/**
 * @file alojamientos/mapa.astro
 * @description Map view of accommodations listing. Full-width Leaflet map
 * with FilterSidebar and toggle to switch back to list view. Pagination is
 * replaced by a higher fetch cap (200 items) bounded by viewport bbox.
 * @route /{lang}/alojamientos/mapa/
 * @rendering SSR
 */

import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import { AccommodationsListingMap } from '@/components/maps/AccommodationsListingMap.client';
import { FilterSidebar } from '@/components/shared/filters/FilterSidebar.client';
import type { FilterGroup } from '@/components/shared/filters/FilterSidebar.client';
import { accommodationsApi, amenitiesApi, destinationsApi, featuresApi } from '@/lib/api/endpoints';
import { toAccommodationCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { resolveI18nText } from '@/lib/resolve-i18n-text';
import { getAccommodationTypeLabel, getBadgeStatusColor } from '@/lib/colors';
import { formatPrice } from '@/lib/format-utils';
import { buildAccommodationListingSummary, DEFAULT_TYPE_GRAMMAR } from '@/lib/accommodation-listing-summary';
import type { CatalogEntry, SummaryLocale } from '@/lib/accommodation-listing-summary';

const locale = Astro.locals.locale as SupportedLocale;
const { t, tPlural } = createTranslations(locale);

// SPEC-098 T-044: Pass authentication state to AccommodationsListingMap so
// the popup FavoriteButton can behave correctly for guests vs. signed-in users.
const isAuthenticated = !!Astro.locals.user;

// Map view fetches up to MAP_FETCH_CAP items in the current viewport bbox.
// No traditional pagination — clusters keep rendering manageable.
const MAP_FETCH_CAP = 100;

const url = Astro.url;

// Extract filter params (same as list view, minus pagination)
const q = url.searchParams.get('q') ?? undefined;
const types = url.searchParams.get('types') ?? undefined;
const destinationIds = url.searchParams.get('destinationIds') ?? undefined;
const minPrice = url.searchParams.get('minPrice') ? Number(url.searchParams.get('minPrice')) : undefined;
const maxPrice = url.searchParams.get('maxPrice') ? Number(url.searchParams.get('maxPrice')) : undefined;
const sortBy = url.searchParams.get('sortBy') ?? undefined;
// SPEC-098 T-052 — `mostSaved` defaults to descending so the most-bookmarked
// accommodations appear first.
const explicitSortOrder = url.searchParams.get('sortOrder') as 'asc' | 'desc' | null;
const sortOrder: 'asc' | 'desc' | undefined =
    explicitSortOrder ?? (sortBy === 'mostSaved' ? 'desc' : undefined);
const isFeatured = url.searchParams.get('isFeatured') === 'true' ? true : undefined;
// `minGuests` is now derived from adults + children (see further down). The
// raw URL param is no longer surfaced as its own filter to keep the UI in
// sync with the list view.
const minBedrooms = url.searchParams.get('minBedrooms') ? Number(url.searchParams.get('minBedrooms')) : undefined;
const minBathrooms = url.searchParams.get('minBathrooms') ? Number(url.searchParams.get('minBathrooms')) : undefined;
const minRating = url.searchParams.get('minRating') ? Number(url.searchParams.get('minRating')) : undefined;
const amenitiesParam = url.searchParams.get('amenities') ?? undefined;
const featuresParam = url.searchParams.get('features') ?? undefined;
// Same default-ON semantics as the list view: absent param = checked. Only
// forward the explicit-OFF case to the API (the listing endpoint rejects an
// unknown `?includeNoPrice=true` with INVALID_PAGINATION_PARAMS, so we keep
// the param absent when the toggle is at its default-on state).
const includeNoPrice =
    url.searchParams.get('includeNoPrice') === 'false' ? false : undefined;
const includeNoReviews =
    url.searchParams.get('includeNoReviews') === 'false' ? false : undefined;
// Trip-context (forwarded to detail link, not filtered server-side).
const checkIn = url.searchParams.get('checkIn') ?? undefined;
const checkOut = url.searchParams.get('checkOut') ?? undefined;
const adultsParam = url.searchParams.get('adults');
const childrenParam = url.searchParams.get('children');
const adultsContext = adultsParam ? Number(adultsParam) : undefined;
const childrenContext = childrenParam ? Number(childrenParam) : undefined;
// Derived guest-capacity filter — sum of adults + children. See list view
// for the rationale.
const guestCount = (adultsContext ?? 2) + (childrenContext ?? 0);
const minGuests = guestCount > 0 ? guestCount : undefined;

// Fetch destinations for filter dropdown (CITY only — accommodations are
// browsed by city, not by parent administrative regions).
const destinationsResult = await destinationsApi.list({ destinationType: 'CITY', pageSize: 100 });
const destinations = destinationsResult.ok ? destinationsResult.data.items : [];

// Fetch amenities for filter chips
const amenitiesResult = await amenitiesApi.list({ pageSize: 100, isActive: true, sortBy: 'name', sortOrder: 'asc' });
const amenities = amenitiesResult.ok ? amenitiesResult.data.items : [];

// Fetch features for filter chips
const featuresResult = await featuresApi.list({ pageSize: 100, sortBy: 'displayWeight', sortOrder: 'desc' });
const features = featuresResult.ok ? featuresResult.data.items : [];

// Fetch up to MAP_FETCH_CAP accommodations for the initial map view.
// Subsequent panning will refetch via useViewportSearch with bbox params.
const result = await accommodationsApi.list({
	page: 1,
	pageSize: MAP_FETCH_CAP,
	q,
	types,
	destinationIds,
	minPrice,
	maxPrice,
	sortBy,
	sortOrder,
	isFeatured,
	minGuests,
	minBedrooms,
	minBathrooms,
	minRating,
	amenities: amenitiesParam,
	features: featuresParam,
	includeAmenities: true,
	includeNoPrice,
	includeNoReviews,
});

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.pagination.total : 0;

const cards = items.map((item) => toAccommodationCardProps({ item: item as unknown as Record<string, unknown> }));

const LITORAL_CENTER: [number, number] = [-31.8, -58.5];
const LITORAL_ZOOM = 8;
const firstWithCoords = cards.find((c) => c.approximateLocation);
const mapCenter: [number, number] = firstWithCoords?.approximateLocation
	? [firstWithCoords.approximateLocation.lat, firstWithCoords.approximateLocation.lng]
	: LITORAL_CENTER;
const mapHasItems = cards.some((c) => c.approximateLocation);

// Filter summary
const summaryLocale = (locale === 'en' ? 'en' : 'es') as SummaryLocale;
const destinationCatalog: readonly CatalogEntry[] = destinations.map((d) => ({ key: d.id, label: { es: resolveI18nText(d.name, 'es'), en: resolveI18nText(d.name, 'en') } }));
const amenityCatalog: readonly CatalogEntry[] = amenities.map((a) => ({ key: a.id, label: { es: resolveI18nText(a.name, 'es'), en: resolveI18nText(a.name, 'en') } }));
const featureCatalog: readonly CatalogEntry[] = features.map((f) => ({ key: f.id, label: { es: resolveI18nText(f.name, 'es'), en: resolveI18nText(f.name, 'en') } }));

const typesArray = types?.split(',').filter(Boolean) ?? [];
const filterSummary = buildAccommodationListingSummary({
	locale: summaryLocale,
	filters: {
		types: typesArray.length > 0 ? typesArray : undefined,
		text: q,
		price: (minPrice !== undefined || maxPrice !== undefined || includeNoPrice)
			? { min: minPrice, max: maxPrice, includeWithoutPrice: includeNoPrice }
			: undefined,
		destinations: destinationIds?.split(',').filter(Boolean),
		guests: minGuests,
		amenities: amenitiesParam?.split(',').filter(Boolean),
		services: featuresParam?.split(',').filter(Boolean),
		minRating,
		includeWithoutRating: includeNoReviews,
		bedrooms: minBedrooms,
		bathrooms: minBathrooms,
		featured: isFeatured ?? null,
	},
	counts: {
		shown: cards.length,
		globalTotal: total,
		subjectTotal: typesArray.length > 0 ? total : undefined,
	},
	sort: sortBy ? { key: sortBy, direction: sortOrder ?? 'asc' } : undefined,
	catalogs: {
		types: DEFAULT_TYPE_GRAMMAR,
		destinations: destinationCatalog,
		amenities: amenityCatalog,
		services: featureCatalog,
	},
});

// Filter sidebar config (same as list view)
const filterGroups: FilterGroup[] = [
	{ id: 'q', label: t('accommodations.sidebar.search', 'Búsqueda por texto'), type: 'search', placeholder: t('accommodations.sidebar.searchPlaceholder', 'Buscar por nombre o descripción...') },
	{ id: 'isFeatured', label: t('accommodations.sidebar.featured', 'Solo destacados'), type: 'toggle' },
	{
		id: 'types',
		label: t('accommodations.sidebar.type', 'Tipo de Alojamiento'),
		type: 'checkbox',
		options: [
			{ value: 'APARTMENT', label: getAccommodationTypeLabel({ type: 'APARTMENT', t }) },
			{ value: 'HOUSE', label: getAccommodationTypeLabel({ type: 'HOUSE', t }) },
			{ value: 'COUNTRY_HOUSE', label: getAccommodationTypeLabel({ type: 'COUNTRY_HOUSE', t }) },
			{ value: 'CABIN', label: getAccommodationTypeLabel({ type: 'CABIN', t }) },
			{ value: 'HOTEL', label: getAccommodationTypeLabel({ type: 'HOTEL', t }) },
			{ value: 'HOSTEL', label: getAccommodationTypeLabel({ type: 'HOSTEL', t }) },
			{ value: 'CAMPING', label: getAccommodationTypeLabel({ type: 'CAMPING', t }) },
			{ value: 'ROOM', label: getAccommodationTypeLabel({ type: 'ROOM', t }) },
			{ value: 'RESORT', label: getAccommodationTypeLabel({ type: 'RESORT', t }) },
			{ value: 'APART_HOTEL', label: getAccommodationTypeLabel({ type: 'APART_HOTEL', t }) },
			{ value: 'ESTANCIA', label: getAccommodationTypeLabel({ type: 'ESTANCIA', t }) },
			{ value: 'BED_AND_BREAKFAST', label: getAccommodationTypeLabel({ type: 'BED_AND_BREAKFAST', t }) },
		],
	},
	{
		id: 'destinationIds',
		label: t('accommodations.sidebar.destination', 'Destino'),
		type: 'select-search',
		options: destinations.map((d) => ({ value: d.id, label: d.name })),
		maxVisible: 8,
	},
	{
		id: 'amenities',
		label: t('accommodations.sidebar.amenities', 'Comodidades'),
		type: 'icon-chips',
		options: amenities.map((a) => ({ value: a.id, label: resolveI18nText(a.name, locale), icon: a.icon ?? undefined })),
		maxVisible: 10,
	},
	{
		id: 'features',
		label: t('accommodations.sidebar.features', 'Características'),
		type: 'icon-chips',
		options: features.map((f) => ({ value: f.id, label: resolveI18nText(f.name, locale), icon: f.icon ?? undefined })),
		maxVisible: 10,
	},
	{
		id: 'dates',
		label: t('accommodations.sidebar.dates', 'Llegada y salida'),
		type: 'date-range',
		mode: 'bounds',
		checkInPlaceholder: t('accommodations.contextBar.checkIn', 'Llegada'),
		checkOutPlaceholder: t('accommodations.contextBar.checkOut', 'Salida'),
		description: t(
			'accommodations.sidebar.dates.helper',
			'Por ahora informativo: la disponibilidad en tiempo real está en desarrollo y todavía no afecta los resultados.'
		),
	},
	{
		id: 'adults',
		label: t('accommodations.sidebar.adults', 'Adultos'),
		type: 'stepper',
		min: 1,
		max: 10,
		defaultValue: 2,
		emitWhenAtDefault: true,
	},
	{
		id: 'children',
		label: t('accommodations.sidebar.children', 'Niños'),
		type: 'stepper',
		min: 0,
		max: 6,
		defaultValue: 0,
		emitWhenAtDefault: true,
		description: t('accommodations.sidebar.children.helper', '(menores de 5 años)'),
	},
	{ id: 'minBedrooms', label: t('accommodations.sidebar.bedrooms', 'Dormitorios'), type: 'stepper', min: 0, max: 10, defaultValue: 0 },
	{ id: 'minBathrooms', label: t('accommodations.sidebar.bathrooms', 'Baños'), type: 'stepper', min: 0, max: 10, defaultValue: 0 },
	{
		id: 'price',
		label: t('accommodations.sidebar.priceRange', 'Precio por noche'),
		type: 'dual-range',
		min: 5000,
		max: 150000,
		step: 1000,
		format: 'currency',
		includeNullLabel: t('accommodations.sidebar.includeNoPrice', 'Incluir sin precio'),
		includeNullParam: 'includeNoPrice',
		defaultIncludeNull: true,
	},
	{ id: 'minRating', label: t('accommodations.sidebar.rating', 'Calificación'), type: 'stars', includeNullLabel: t('accommodations.sidebar.includeNoReviews', 'Incluir sin calificación'), includeNullParam: 'includeNoReviews', defaultIncludeNull: true },
];

const sortOptions = [
	{ value: 'relevance', label: t('accommodations.sort.relevance', 'Relevancia') },
	{ value: 'price_asc', label: t('accommodations.sort.priceAsc', 'Precio: menor a mayor') },
	{ value: 'price_desc', label: t('accommodations.sort.priceDesc', 'Precio: mayor a menor') },
	{ value: 'rating', label: t('accommodations.sort.rating', 'Mejor valorados') },
	{ value: 'recent', label: t('accommodations.sort.recent', 'Más recientes') },
	// SPEC-098 T-052 — orders by total active bookmarks (descending) via the
	// `mostSaved` synthetic sort field on the public accommodation list endpoint.
	{ value: 'mostSaved', label: t('ui.sort.most_bookmarked', 'Más guardados') },
];

// Build initial filter params for the sidebar
const initialParams: Record<string, string> = {};
if (q) initialParams.q = q;
if (types) initialParams.types = types;
if (destinationIds) initialParams.destinationIds = destinationIds;
if (minPrice !== undefined) initialParams.minPrice = String(minPrice);
if (maxPrice !== undefined) initialParams.maxPrice = String(maxPrice);
if (sortBy) initialParams.sortBy = sortBy;
if (isFeatured) initialParams.isFeatured = 'true';
// `minGuests` is derived (adults + children), not a user-facing filter.
if (minBedrooms !== undefined) initialParams.minBedrooms = String(minBedrooms);
if (minBathrooms !== undefined) initialParams.minBathrooms = String(minBathrooms);
if (minRating !== undefined) initialParams.minRating = String(minRating);
if (amenitiesParam) initialParams.amenities = amenitiesParam;
if (featuresParam) initialParams.features = featuresParam;
// Default-checked include-null toggles: only carry the param when OFF.
if (includeNoPrice === false) initialParams.includeNoPrice = 'false';
if (includeNoReviews === false) initialParams.includeNoReviews = 'false';
if (checkIn) initialParams.checkIn = checkIn;
if (checkOut) initialParams.checkOut = checkOut;
initialParams.adults = String(adultsContext ?? 2);
initialParams.children = String(childrenContext ?? 0);

// Build the URL pointing back to the list view, preserving every active filter.
const listHref = (() => {
	const sp = new URLSearchParams(url.searchParams);
	const qs = sp.toString();
	const base = buildUrl({ locale, path: 'alojamientos' });
	return qs ? `${base}?${qs}` : base;
})();

// Build per-id maps for popup enrichment. Resolved on the page so the island
// stays i18n-agnostic and we don't need to serialize functions.
const TYPE_KEYS = ['APARTMENT', 'HOUSE', 'COUNTRY_HOUSE', 'CABIN', 'HOTEL', 'HOSTEL', 'CAMPING', 'ROOM', 'RESORT'] as const;
const typeLabels: Record<string, string> = {};
for (const key of TYPE_KEYS) {
	typeLabels[key] = getAccommodationTypeLabel({ type: key, t });
}
const detailHrefById: Record<string, string> = {};
const reviewsLabelById: Record<string, string> = {};
const photosLabelById: Record<string, string> = {};
const priceLabelById: Record<string, string> = {};
for (const card of cards) {
	detailHrefById[card.id] = buildUrl({ locale, path: `alojamientos/${card.slug}` });
	if (card.reviewsCount > 0) {
		reviewsLabelById[card.id] = `(${tPlural('review.list.totalReviews', card.reviewsCount, { count: card.reviewsCount })})`;
	}
	if ((card.photoCount ?? 0) > 0) {
		photosLabelById[card.id] = tPlural('common.photos', card.photoCount ?? 0, { count: card.photoCount ?? 0 });
	}
	if (card.price?.amount != null && card.price?.currency) {
		priceLabelById[card.id] = formatPrice({
			amount: card.price.amount,
			currency: card.price.currency,
			locale,
		});
	}
}

// Sidebar cards (mobile bottom sheet / desktop pane) mirror AccommodationCard
// visually. The page resolves all the locale-aware copy + status colors once
// here so the island can stay i18n-agnostic.
const newColors = getBadgeStatusColor({ status: 'new' });
---

<ListingLayout
	locale={locale}
	title={`${t('accommodations.title', 'Alojamientos')} — ${t('accommodations.viewToggle.map', 'Mapa')}`}
	description={t('accommodations.description', 'Encontrá los mejores alojamientos del Litoral Entrerriano.')}
	showFilters={true}
	filterPosition="left"
>
	<Breadcrumbs
		slot="breadcrumbs"
		locale={locale}
		items={[
			{ label: t('accommodations.title', 'Alojamientos'), path: 'alojamientos' },
			{ label: t('accommodations.viewToggle.map', 'Mapa') },
		]}
	/>

	<ListingPageHeader
		slot="page-header"
		locale={locale}
		tagline={t('accommodations.tagline', 'Encontrá tu lugar ideal')}
		title={t('accommodations.title', 'Alojamientos')}
		totalCount={total}
		filterSummary={filterSummary}
	/>

	<FilterSidebar
		slot="filters"
		client:load
		locale={locale}
		filters={filterGroups}
		sortOptions={sortOptions}
		initialParams={initialParams}
	/>

	{!hasError && cards.length > 0 && (
		<div class="view-toggle" role="tablist" aria-label={t('accommodations.viewToggle.ariaLabel', 'Vista')}>
			<a
				href={listHref}
				class="view-toggle__btn"
				role="tab"
				aria-selected="false"
			>
				{t('accommodations.viewToggle.list', 'Lista')}
			</a>
			<span
				class="view-toggle__btn view-toggle__btn--active"
				role="tab"
				aria-selected="true"
			>
				{t('accommodations.viewToggle.map', 'Mapa')}
			</span>
		</div>
	)}

	{hasError && !result.ok && (
		<ErrorBanner locale={locale} error={result.error} entityName="alojamientos" />
	)}

	{!hasError && cards.length === 0 && (
		<EmptyState
			locale={locale}
			variant="no-results"
			actionUrl={buildUrl({ locale, path: 'alojamientos' })}
		/>
	)}

	{!hasError && cards.length > 0 && mapHasItems && (
		<div class="acc-listing-map" id="acc-listing-map">
			<AccommodationsListingMap
				client:only="react"
				initialItems={cards}
				initialCenter={mapCenter}
				initialZoom={LITORAL_ZOOM}
				ariaLabel={t('maps.ariaLabelAccommodation')}
				typeLabels={typeLabels}
				detailHrefById={detailHrefById}
				reviewsLabelById={reviewsLabelById}
				photosLabelById={photosLabelById}
				priceLabelById={priceLabelById}
				featuredLabel={t('home.accommodations.badge.featured', 'Destacado')}
				newLabel={t('home.accommodations.badge.new', 'Nuevo')}
				newBg={newColors.bg}
				newText={newColors.text}
				priceFromLabel={t('home.accommodations.price.from', 'Desde')}
				pricePerNightLabel={t('home.accommodations.price.perNight', '/noche')}
				priceConsultLabel={t('home.accommodations.price.consult', 'Consultar')}
				ctaLabel={`${t('common.readMore', 'Ver más')} →`}
				amenitiesLabel={t('home.accommodations.amenities.label', 'Amenidades')}
				showSidebar={true}
				isAuthenticated={isAuthenticated}
				locale={locale}
				sidebarI18n={{
					resultsHeading: t('maps.sidebar.resultsHeading', 'Resultados en el mapa'),
					resultsCountOne: t('maps.sidebar.resultsCount_one', '{{count}} alojamiento'),
					resultsCountOther: t('maps.sidebar.resultsCount_other', '{{count}} alojamientos'),
					emptyState: t('maps.sidebar.emptyState', 'No hay alojamientos en esta zona.'),
					openSheet: t('maps.sidebar.openSheet', 'Ver tarjetas'),
					openSheetCountOne: t('maps.sidebar.openSheetCount_one', 'Ver {{count}} resultado'),
					openSheetCountOther: t('maps.sidebar.openSheetCount_other', 'Ver {{count}} resultados'),
					closeSheet: t('maps.sidebar.closeSheet', 'Cerrar'),
				}}
				i18nStrings={{
					attribution: t('maps.attribution'),
					approximateDisclaimer: t('maps.approximateDisclaimer'),
					viewDetails: t('maps.viewDetails', 'Ver más'),
				}}
			/>
		</div>
	)}
</ListingLayout>

<style>
	.view-toggle {
		display: inline-flex;
		gap: var(--space-2, 8px);
		padding: 4px;
		margin: var(--space-4, 16px) 0;
		background-color: var(--surface-warm, #faf6f0);
		border-radius: var(--radius-pill, 9999px);
		border: 1px solid transparent;
	}
	.view-toggle__btn {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-pill, 9999px);
		color: var(--core-muted-foreground);
		text-decoration: none;
		transition: background-color var(--duration-normal, 0.4s) ease, color var(--duration-normal, 0.4s) ease;
		cursor: pointer;
	}
	.view-toggle__btn:hover {
		color: var(--core-foreground);
	}
	.view-toggle__btn--active {
		background-color: var(--brand-accent);
		color: white;
		font-weight: 500;
		cursor: default;
	}

	/* Mobile: float the toggle over the top of the fullscreen map, centered.
	 * The bottom row of the map view is reserved for Filtros (left) + Ver
	 * tarjetas (right), so the Lista/Mapa selector hovers near the top
	 * instead of competing for the bottom-center slot. */
	@media (max-width: 767px) {
		.view-toggle {
			position: fixed;
			top: calc(var(--navbar-height, 80px) + var(--wave-bar-compact, 77px) + 8px);
			left: 50%;
			transform: translateX(-50%);
			z-index: 200;
			margin: 0;
			/* Frosted-glass surface — see global.css → --frost-* tokens. */
			background-color: var(--frost-bg-light);
			backdrop-filter: blur(var(--frost-blur));
			-webkit-backdrop-filter: blur(var(--frost-blur));
			border-color: var(--frost-border);
			box-shadow: 0 4px 12px oklch(0 0 0 / 0.12), 0 1px 3px oklch(0 0 0 / 0.06);
		}

		/* Hide while a blocking overlay is open — same set the sheet trigger
		 * and filters trigger already honor. */
		:global(html[data-filters-drawer-open]) .view-toggle,
		:global(html[data-search-panel-open]) .view-toggle,
		:global(html[data-mobile-menu-open]) .view-toggle {
			visibility: hidden;
			pointer-events: none;
		}
	}

	.acc-listing-map {
		width: 100%;
		min-height: 600px;
		margin: var(--space-4, 16px) 0 var(--space-6, 24px);
	}
	/* Mobile: turn the map into a near-fullscreen pane so the user lands on
	 * a real map view instead of a strip under the header. Height fills the
	 * viewport below the navbar and the compact wave bar; --wave-bar-compact
	 * is published by the auto-scroll script after measuring the bar in its
	 * compact state. The fallback (88px) keeps the layout sane on first
	 * paint before measurement.
	 *
	 * Width breaks out of the parent container padding via the classic
	 * full-bleed trick so the map uses 100% of the viewport width.
	 */
	@media (max-width: 768px) {
		.acc-listing-map {
			/* Default to the wave bar's expected compact height (77px without
			 * the decorative SVG — see the :global(.wave-header__wave) rule
			 * below). Keeping a static value avoids a layout flash between
			 * first paint and the moment the script publishes the measured
			 * value, which left a tile-less gray strip in the map. */
			height: calc(
				100svh - var(--navbar-height, 80px) - var(--wave-bar-compact, 77px)
			);
			min-height: 0;
			margin: 0;
			width: 100vw;
			margin-left: calc(50% - 50vw);
			margin-right: calc(50% - 50vw);
			/* Clip the inner React island's content (disclaimer + warm bg
			 * fringes) to the box so they don't show below the map. */
			overflow: hidden;
		}

		/* Make the React island (astro-island custom element) propagate the
		 * full height down to the .root / leaflet container — without this,
		 * astro-island defaults to display:inline-like behavior and the inner
		 * `.root { height: 100% }` collapses to its content height instead of
		 * filling .acc-listing-map. */
		.acc-listing-map :global(astro-island) {
			display: block;
			width: 100%;
			height: 100%;
		}

		/* Mobile fullscreen map: drop the rounded corners and translucent
		 * disclaimer pane from the desktop card look. We still need the
		 * disclaimer copy visible somewhere, so it's painted as a small
		 * overlay pinned to the top-right corner instead. */
		.acc-listing-map :global([class*="root"]) {
			border-radius: 0;
			box-shadow: none;
		}
		.acc-listing-map :global([class*="disclaimer"]) {
			position: absolute;
			/* Slot the disclaimer below the floating Lista/Mapa toggle on
			 * mobile (toggle ends ~57px into the map) so the two never
			 * overlap, even on a 320px viewport where horizontal room is
			 * tight. Top-LEFT keeps the right side clear for the user. */
			top: 64px;
			left: 8px;
			max-width: 50%;
			padding: 6px 10px;
			font-size: 0.625rem;
			line-height: 1.3;
			border-radius: var(--radius-button, 8px);
			border: none;
			background-color: var(--core-card-a90);
			backdrop-filter: blur(4px);
			-webkit-backdrop-filter: blur(4px);
			z-index: 500;
			pointer-events: none;
		}

		/* Hide the decorative wave SVG on the fullscreen-map view: its bottom
		 * half is transparent and would reveal the page background between
		 * the bar and the map. Booking/Airbnb-style flat handoff instead. */
		:global(.wave-header__wave) {
			display: none;
		}
	}
</style>

<script>
	/*
	 * Mobile fullscreen-map setup. On narrow viewports the map page collapses
	 * to: navbar + compact wave header + map filling the rest of the viewport.
	 * Steps on every astro:page-load (so View Transitions still trigger it):
	 *   1. Tag the wave header with `data-locked-compact` so the observer in
	 *      WaveHeader.astro keeps the bar permanently compact for this page.
	 *      Without this lock, scrolling back near the top would expand the bar
	 *      and reveal the breadcrumbs row that we want hidden.
	 *   2. Wait one frame for the compact class + CSS transition to apply,
	 *      then measure the bar and publish its height as
	 *      `--wave-bar-compact`. The map's CSS uses that var to size itself
	 *      so the bottom edge lands exactly at the viewport bottom.
	 *   3. Smooth-scroll so the map top lands flush below the compact bar
	 *      (only if the user landed at the top — respect restored scroll on
	 *      back navigation).
	 */
	function setupMobileFullscreenMap() {
		if (window.matchMedia('(min-width: 768px)').matches) return;
		const waveHeader = document.querySelector<HTMLElement>('.wave-header');
		const mapEl = document.getElementById('acc-listing-map');
		if (!waveHeader || !mapEl) return;

		// Opt out of the browser's automatic scroll restoration on this page:
		// we always want the map fullscreen landing, even on reload. Otherwise
		// the restored scroll position fires between DOMContentLoaded and our
		// setTimeout below, leaving the map a strip below the fold.
		if ('scrollRestoration' in history) {
			history.scrollRestoration = 'manual';
		}

		// Lock the wave header in compact mode. The observer inside
		// WaveHeader.astro respects this flag (it both bails on init and
		// re-asserts compact on every intersection callback) so the bar can't
		// expand back out when scrollY lands at the top.
		waveHeader.dataset.lockedCompact = 'true';
		waveHeader.classList.add('wave-header--compact');

		const navbarHeight =
			parseFloat(
				getComputedStyle(document.documentElement).getPropertyValue('--navbar-height')
			) || 80;

		// Wait for the CSS transition (~300ms) before measuring.
		window.setTimeout(() => {
			const bar = waveHeader.querySelector<HTMLElement>('.wave-header__bar');
			const barHeight = bar?.offsetHeight ?? 88;
			document.documentElement.style.setProperty(
				'--wave-bar-compact',
				`${barHeight}px`
			);

			const target =
				mapEl.getBoundingClientRect().top +
				window.scrollY -
				navbarHeight -
				barHeight;
			window.scrollTo({ top: Math.max(0, target), behavior: 'smooth' });
		}, 340);
	}

	// Fire on first paint (DOMContentLoaded) and on every SPA navigation
	// (astro:page-load). The fullscreen-map setup is idempotent so re-runs
	// are safe — the data attribute and class are no-ops when already set.
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupMobileFullscreenMap, { once: true });
	} else {
		setupMobileFullscreenMap();
	}
	document.addEventListener('astro:page-load', setupMobileFullscreenMap);
</script>
