---
export const prerender = true;

/**
 * Returns static paths for all locale + type combinations.
 * 3 locales x 7 types = 21 pre-rendered pages.
 * Combined with ISR (configured globally), pages revalidate on-demand.
 */
export function getStaticPaths() {
  const locales = SUPPORTED_LOCALES;
  const types = ['hotel', 'hostel', 'cabin', 'apartment', 'camping', 'estancia', 'posada'] as const;

  return locales.flatMap((lang) =>
    types.map((type) => ({ params: { lang, type } }))
  );
}

/**
 * Accommodation by Type page.
 * Displays filtered list of accommodations by type (hotel, hostel, cabin, etc.).
 * Validates locale and type parameters, redirects if invalid.
 *
 * @route /[lang]/alojamientos/tipo/[type]/
 * @rendering SSG + ISR (Static Site Generation with Incremental Static Regeneration)
 */
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import SEOHead from '../../../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../../../components/ui/Breadcrumb.astro';
import Container from '../../../../../components/ui/Container.astro';
import Section from '../../../../../components/ui/Section.astro';
import EmptyState from '../../../../../components/ui/EmptyState.astro';
import Pagination from '../../../../../components/ui/Pagination.astro';
import AccommodationCardFeatured from '../../../../../components/accommodation/AccommodationCardFeatured.astro';
import { getLocaleFromParams, SUPPORTED_LOCALES } from '../../../../../lib/page-helpers';
import { accommodationsApi } from '../../../../../lib/api/endpoints';
import { toAccommodationCardProps } from '../../../../../lib/api/transforms';
import { t } from '../../../../../lib/i18n';

const { type } = Astro.params;

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Allowed accommodation types
 */
const ALLOWED_TYPES = [
	'hotel',
	'hostel',
	'cabin',
	'apartment',
	'camping',
	'estancia',
	'posada',
] as const;

type AccommodationType = (typeof ALLOWED_TYPES)[number];

/**
 * Validate accommodation type parameter
 */
if (!type || !ALLOWED_TYPES.includes(type as AccommodationType)) {
	return Astro.redirect(`/${locale}/alojamientos/`);
}

const accommodationType = type as AccommodationType;

const typeName = t({ locale, namespace: 'accommodations', key: `typePage.typeDetails.${accommodationType}.name` });
const typeDescription = t({ locale, namespace: 'accommodations', key: `typePage.typeDetails.${accommodationType}.description` });
const pageTitle = t({ locale, namespace: 'accommodations', key: `typePage.typeDetails.${accommodationType}.pageTitle` });
const breadcrumbHome = t({ locale, namespace: 'accommodations', key: 'typePage.labels.breadcrumbHome' });
const breadcrumbAccommodations = t({ locale, namespace: 'accommodations', key: 'typePage.labels.breadcrumbAccommodations' });
const emptyTitle = t({ locale, namespace: 'accommodations', key: 'typePage.labels.emptyTitle', params: { type: typeName.toLowerCase() } });
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: breadcrumbHome, href: `/${locale}/` },
	{ label: breadcrumbAccommodations, href: `/${locale}/alojamientos/` },
	{ label: typeName, href: `/${locale}/alojamientos/tipo/${accommodationType}/` },
];

/**
 * Get pagination parameters from URL.
 * Astro.url.searchParams works for both SSG and ISR modes.
 */
const page = Number.parseInt(Astro.url.searchParams.get('page') || '1', 10);
const pageSize = 12;

/**
 * Fetch accommodations filtered by type
 */
const apiResult = await accommodationsApi.list({ page, pageSize, type: accommodationType });

const accommodations = apiResult.ok ? apiResult.data.items : [];
const pagination = apiResult.ok ? apiResult.data.pagination : null;

/**
 * Generate empty state message
 */
const emptyMessage = emptyTitle;
---

<BaseLayout title={pageTitle} description={typeDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={typeDescription}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- Type Header Section -->
				<article id="type-header" class="mb-12 text-center">
					<h1 class="mb-6 text-4xl font-bold text-text-primary md:text-5xl">
						{typeName}
					</h1>
					<p class="text-xl leading-relaxed text-text-secondary">
						{typeDescription}
					</p>
				</article>

				<!-- Accommodation Grid Section -->
				<article id="accommodation-grid" class="mb-12">
					{
						accommodations.length > 0 ? (
							<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
								{accommodations.map((accommodation) => (
									<AccommodationCardFeatured accommodation={toAccommodationCardProps({ item: accommodation as Record<string, unknown> })} locale={locale} />
								))}
							</div>
						) : (
							<EmptyState title={emptyMessage} message={breadcrumbAccommodations} />
						)
					}
				</article>

				<!-- Pagination Section -->
				{
					pagination && pagination.totalPages > 1 && (
						<article id="pagination" class="mb-12">
							<Pagination
								currentPage={pagination.page as number}
								totalPages={pagination.totalPages as number}
								baseUrl={`/${locale}/alojamientos/tipo/${accommodationType}`}
								locale={locale}
							/>
						</article>
					)
				}
			</div>
		</Section>
	</Container>
</BaseLayout>
