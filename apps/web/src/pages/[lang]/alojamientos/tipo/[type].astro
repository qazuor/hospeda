---
/**
 * Accommodation by Type page.
 * Displays filtered list of accommodations by type (hotel, hostel, cabin, etc.).
 * Validates locale and type parameters, redirects if invalid.
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SEOHead from '../../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../../components/ui/Breadcrumb.astro';
import Container from '../../../../components/ui/Container.astro';
import Section from '../../../../components/ui/Section.astro';
import EmptyState from '../../../../components/ui/EmptyState.astro';
import AccommodationCard from '../../../../components/accommodation/AccommodationCard.astro';
import { isValidLocale, type SupportedLocale } from '../../../../lib/i18n';
import { accommodationsApi } from '../../../../lib/api/endpoints';

const { lang, type } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * Allowed accommodation types
 */
const ALLOWED_TYPES = [
	'hotel',
	'hostel',
	'cabin',
	'apartment',
	'camping',
	'estancia',
	'posada',
] as const;

type AccommodationType = (typeof ALLOWED_TYPES)[number];

/**
 * Validate accommodation type parameter
 */
if (!type || !ALLOWED_TYPES.includes(type as AccommodationType)) {
	return Astro.redirect(`/${locale}/alojamientos/`);
}

const accommodationType = type as AccommodationType;

/**
 * Localized type names (plural)
 */
const typeNames: Record<SupportedLocale, Record<AccommodationType, string>> = {
	es: {
		hotel: 'Hoteles',
		hostel: 'Hostels',
		cabin: 'Cabañas',
		apartment: 'Apartamentos',
		camping: 'Campings',
		estancia: 'Estancias',
		posada: 'Posadas',
	},
	en: {
		hotel: 'Hotels',
		hostel: 'Hostels',
		cabin: 'Cabins',
		apartment: 'Apartments',
		camping: 'Campgrounds',
		estancia: 'Ranch Houses',
		posada: 'Inns',
	},
	pt: {
		hotel: 'Hotéis',
		hostel: 'Hostels',
		cabin: 'Cabanas',
		apartment: 'Apartamentos',
		camping: 'Campings',
		estancia: 'Estâncias',
		posada: 'Pousadas',
	},
};

/**
 * Localized type descriptions
 */
const typeDescriptions: Record<SupportedLocale, Record<AccommodationType, string>> = {
	es: {
		hotel: 'Descubre los mejores hoteles en Concepción del Uruguay y la región del Litoral argentino. Comodidad y servicios de calidad para tu estadía.',
		hostel: 'Encuentra hostels económicos y con ambiente joven. Ideal para viajeros que buscan conectar con otros aventureros.',
		cabin: 'Cabañas acogedoras en entornos naturales. Perfectas para escapadas románticas o vacaciones familiares en la naturaleza.',
		apartment: 'Apartamentos equipados para estadías cortas y largas. La comodidad de sentirte como en casa durante tu viaje.',
		camping: 'Campings con infraestructura completa para disfrutar al aire libre. Conecta con la naturaleza en la región del Litoral.',
		estancia: 'Estancias tradicionales argentinas que ofrecen experiencias auténticas de campo y cultura gaucha.',
		posada: 'Posadas familiares con calidez y hospitalidad local. Alojamientos con encanto y atención personalizada.',
	},
	en: {
		hotel: 'Discover the best hotels in Concepción del Uruguay and the Argentine Litoral region. Comfort and quality services for your stay.',
		hostel: 'Find budget-friendly hostels with a youthful atmosphere. Ideal for travelers looking to connect with other adventurers.',
		cabin: 'Cozy cabins in natural settings. Perfect for romantic getaways or family vacations in nature.',
		apartment: 'Fully equipped apartments for short and long stays. The comfort of feeling at home during your trip.',
		camping: 'Campgrounds with complete infrastructure to enjoy the outdoors. Connect with nature in the Litoral region.',
		estancia: 'Traditional Argentine ranch houses offering authentic countryside and gaucho culture experiences.',
		posada: 'Family-run inns with warmth and local hospitality. Charming accommodations with personalized service.',
	},
	pt: {
		hotel: 'Descubra os melhores hotéis em Concepción del Uruguay e na região do Litoral argentino. Conforto e serviços de qualidade para sua estadia.',
		hostel: 'Encontre hostels econômicos com ambiente jovem. Ideal para viajantes que buscam conectar com outros aventureiros.',
		cabin: 'Cabanas aconchegantes em ambientes naturais. Perfeitas para escapadas românticas ou férias em família na natureza.',
		apartment: 'Apartamentos equipados para estadias curtas e longas. O conforto de se sentir em casa durante sua viagem.',
		camping: 'Campings com infraestrutura completa para aproveitar ao ar livre. Conecte-se com a natureza na região do Litoral.',
		estancia: 'Estâncias tradicionais argentinas que oferecem experiências autênticas de campo e cultura gaúcha.',
		posada: 'Pousadas familiares com calor e hospitalidade local. Acomodações com charme e atendimento personalizado.',
	},
};

/**
 * Localized page titles
 */
const pageTitles: Record<SupportedLocale, Record<AccommodationType, string>> = {
	es: {
		hotel: 'Alojamientos - Hoteles',
		hostel: 'Alojamientos - Hostels',
		cabin: 'Alojamientos - Cabañas',
		apartment: 'Alojamientos - Apartamentos',
		camping: 'Alojamientos - Campings',
		estancia: 'Alojamientos - Estancias',
		posada: 'Alojamientos - Posadas',
	},
	en: {
		hotel: 'Accommodations - Hotels',
		hostel: 'Accommodations - Hostels',
		cabin: 'Accommodations - Cabins',
		apartment: 'Accommodations - Apartments',
		camping: 'Accommodations - Campgrounds',
		estancia: 'Accommodations - Ranch Houses',
		posada: 'Accommodations - Inns',
	},
	pt: {
		hotel: 'Acomodações - Hotéis',
		hostel: 'Acomodações - Hostels',
		cabin: 'Acomodações - Cabanas',
		apartment: 'Acomodações - Apartamentos',
		camping: 'Acomodações - Campings',
		estancia: 'Acomodações - Estâncias',
		posada: 'Acomodações - Pousadas',
	},
};

/**
 * Localized common labels
 */
const labels: Record<SupportedLocale, Record<string, string>> = {
	es: {
		home: 'Inicio',
		accommodations: 'Alojamientos',
		noResults: 'No hay alojamientos de tipo {type} disponibles',
	},
	en: {
		home: 'Home',
		accommodations: 'Accommodations',
		noResults: 'No {type} accommodations available',
	},
	pt: {
		home: 'Início',
		accommodations: 'Acomodações',
		noResults: 'Não há acomodações do tipo {type} disponíveis',
	},
};

const typeName = typeNames[locale][accommodationType];
const typeDescription = typeDescriptions[locale][accommodationType];
const pageTitle = pageTitles[locale][accommodationType];
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: labels[locale].home, href: `/${locale}/` },
	{ label: labels[locale].accommodations, href: `/${locale}/alojamientos/` },
	{ label: typeName, href: `/${locale}/alojamientos/tipo/${accommodationType}/` },
];

/**
 * Get pagination parameters from URL
 */
const url = new URL(Astro.request.url);
const page = Number.parseInt(url.searchParams.get('page') || '1', 10);
const pageSize = 12;

/**
 * Fetch accommodations filtered by type
 */
const apiResult = await accommodationsApi.list({ page, pageSize, type: accommodationType });

const accommodations = apiResult.ok ? apiResult.data.items : [];
const pagination = apiResult.ok ? apiResult.data.pagination : null;

/**
 * Generate empty state message
 */
const emptyMessage = labels[locale].noResults.replace('{type}', typeName.toLowerCase());
---

<BaseLayout title={pageTitle} description={typeDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={typeDescription}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- Type Header Section -->
				<article id="type-header" class="mb-12 text-center">
					<h1 class="mb-6 text-4xl font-bold text-text-primary md:text-5xl">
						{typeName}
					</h1>
					<p class="text-xl leading-relaxed text-text-secondary">
						{typeDescription}
					</p>
				</article>

				<!-- Accommodation Grid Section -->
				<article id="accommodation-grid" class="mb-12">
					{
						accommodations.length > 0 ? (
							<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
								{accommodations.map((accommodation) => (
									<AccommodationCard accommodation={accommodation as any} locale={locale} />
								))}
							</div>
						) : (
							<EmptyState title={emptyMessage} message={labels[locale].accommodations} />
						)
					}
				</article>

				<!-- Pagination Section -->
				{
					pagination && pagination.totalPages > 1 && (
						<article id="pagination" class="mb-12">
							<nav aria-label="Pagination" class="flex items-center justify-center gap-2">
								{pagination.hasPreviousPage && (
									<a
										href={`/${locale}/alojamientos/tipo/${accommodationType}/?page=${pagination.page - 1}`}
										class="rounded-md border border-border bg-bg px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:bg-surface"
									>
										← Anterior
									</a>
								)}

								<span class="px-4 py-2 text-sm text-text-secondary">
									Página {pagination.page} de {pagination.totalPages}
								</span>

								{pagination.hasNextPage && (
									<a
										href={`/${locale}/alojamientos/tipo/${accommodationType}/?page=${pagination.page + 1}`}
										class="rounded-md border border-border bg-bg px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:bg-surface"
									>
										Siguiente →
									</a>
								)}
							</nav>
						</article>
					)
				}
			</div>
		</Section>
	</Container>
</BaseLayout>
