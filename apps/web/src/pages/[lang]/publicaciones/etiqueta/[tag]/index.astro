---
/**
 * @file publicaciones/etiqueta/[tag]/index.astro
 * @description Blog posts filtered by PostTag slug (SPEC-086 PostTag subsystem).
 *
 * PostTags are the public SEO taxonomy for blog posts, completely separate from
 * the user-tag subsystem (SPEC-086 D-001, D-024). Only ACTIVE PostTags are shown
 * and only posts linked via r_post_post_tag are returned.
 *
 * Flow:
 *  1. Fetch all ACTIVE PostTags from GET /api/v1/public/posts/tags.
 *  2. Find the matching PostTag by slug from URL param.
 *  3. If not found → 404 (AC-F14, no internal label leak).
 *  4. Filter posts via GET /api/v1/public/posts?tags={postTagId}.
 *
 * @route /{lang}/publicaciones/etiqueta/{tag}/
 * @rendering SSR + ISR 24h
 */
import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import ArticleCard from '@/components/shared/cards/ArticleCard.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import Pagination from '@/components/shared/feedback/Pagination.astro';
import { postTagsApi, postsApi } from '@/lib/api/endpoints';
import { toArticleCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { tag: tagSlug } = Astro.params;
const isAuthenticated = Boolean(Astro.locals.user);

if (!tagSlug) return new Response(null, { status: 404 });

// ── Step 1: Resolve PostTag slug → PostTag (ACTIVE only, AC-F14) ──────────────
// Fetching all tags is fast (realistic volume: 50–200, cached 10 min, no pagination)
const postTagsResult = await postTagsApi.list();
if (!postTagsResult.ok) return new Response(null, { status: 404 });

const allPostTags = postTagsResult.data;
const matchedTag = allPostTags.find((pt) => pt.slug === tagSlug);

// AC-F14: non-existent slug → 404. No internal label or system-tag leaks.
if (!matchedTag) return new Response(null, { status: 404 });

const tagName = matchedTag.name;
const tagId = matchedTag.id;

// ── Step 2: Fetch posts filtered by PostTag UUID ───────────────────────────────
const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const result = await postsApi.list({ page, pageSize: 9, tags: tagId });

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.pagination.total : 0;
const totalPages = result.ok ? result.data.pagination.totalPages : 0;
const cards = items.map((item) => toArticleCardProps({ item: item as unknown as Record<string, unknown>, locale }));
const baseUrl = buildUrl({ locale, path: `publicaciones/etiqueta/${tagSlug}` });
---

<ListingLayout
    locale={locale}
    title={`#${tagName} - ${t('blog.title', 'Publicaciones')}`}
    description={`${t('blog.byTag.description', 'Publicaciones con etiqueta')} ${tagName}`}
    showFilters={false}
    noindex={true}
>
    <Breadcrumbs
        slot="breadcrumbs"
        locale={locale}
        items={[
            { label: t('blog.title', 'Publicaciones'), path: 'publicaciones' },
            { label: t('blog.detail.tags', 'Etiquetas') },
            { label: `#${tagName}` }
        ]}
    />

    <ListingPageHeader
        slot="page-header"
        locale={locale}
        tagline={t('blog.byTag.tagline', 'Etiqueta')}
        title={`#${tagName}`}
        totalCount={total}
    />

    {hasError && !result.ok && (
        <ErrorBanner locale={locale} error={result.error} entityName="publicaciones" />
    )}

    {!hasError && cards.length === 0 && (
        <EmptyState
            locale={locale}
            variant="no-results"
            actionUrl={buildUrl({ locale, path: 'publicaciones' })}
        />
    )}

    {!hasError && cards.length > 0 && (
        <div class="grid">
            {cards.map((card, i) => (
                <div data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
                    <ArticleCard data={card} locale={locale} isAuthenticated={isAuthenticated} />
                </div>
            ))}
        </div>
    )}

    {totalPages > 1 && (
        <Pagination
            slot="pagination"
            currentPage={page}
            totalPages={totalPages}
            baseUrl={baseUrl.slice(0, -1)}
            locale={locale}
        />
    )}
</ListingLayout>

<style>
    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-card-gap);
    }
    @media (max-width: 1024px) { .grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>
