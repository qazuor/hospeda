---
/**
 * Posts by Tag page.
 * Displays a filtered list of blog posts for a given tag slug.
 * Tag slugs are dynamic and unknown at build time, so this page uses SSR.
 *
 * @route /[lang]/publicaciones/etiqueta/[tag]/
 * @rendering SSR (on-demand, tags are unknown at build time)
 */
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import SEOHead from '../../../../../components/seo/SEOHead.astro';
import JsonLd from '../../../../../components/seo/JsonLd.astro';
import Breadcrumb from '../../../../../components/ui/Breadcrumb.astro';
import Container from '../../../../../components/ui/Container.astro';
import Section from '../../../../../components/ui/Section.astro';
import EmptyState from '../../../../../components/ui/EmptyState.astro';
import Pagination from '../../../../../components/ui/Pagination.astro';
import BlogPostCard from '../../../../../components/blog/BlogPostCard.astro';
import { getLocaleFromParams } from '../../../../../lib/page-helpers';
import { tagsApi } from '../../../../../lib/api/endpoints-protected';
import { apiClient } from '../../../../../lib/api/client';
import type { PaginatedResponse } from '../../../../../lib/api/types';
import { t } from '../../../../../lib/i18n';
import { toPostCardProps } from '../../../../../lib/api/transforms';

const { tag } = Astro.params;

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Validate tag param
 */
if (!tag || typeof tag !== 'string' || tag.trim() === '') {
  return Astro.redirect(`/${locale}/publicaciones/`);
}

const tagSlug = tag.trim();

/**
 * Fetch tag metadata by slug.
 * If not found, redirect to the posts listing page.
 */
const tagResult = await tagsApi.getBySlug({ slug: tagSlug });

if (!tagResult.ok || !tagResult.data) {
  return Astro.redirect(`/${locale}/publicaciones/`);
}

const tagData = tagResult.data as { id: string; name: string; slug: string };

/**
 * Get pagination parameter from URL query string.
 * Supports ?page=N for both direct access and pagination rewrites.
 */
const page = Number.parseInt(Astro.url.searchParams.get('page') || '1', 10);
const pageSize = 12;

/**
 * Fetch posts filtered by tag UUID.
 * The posts API list endpoint accepts a `tags` query param (array of UUIDs).
 * We pass the single tag id as a string; the API handles coercion.
 */
const postsResult = await apiClient.getList<Record<string, unknown>>({
  path: '/api/v1/public/posts',
  params: { page, pageSize, tags: tagData.id }
});

const posts = postsResult.ok ? postsResult.data.items : [];
const pagination = postsResult.ok ? postsResult.data.pagination : null;

/**
 * Build canonical URL for SEO
 */
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const tagName = tagData.name;

const pageTitle = t({ locale, namespace: 'blog', key: 'tagPage.title', params: { tag: tagName } });
const metaDescription = t({ locale, namespace: 'blog', key: 'tagPage.description', params: { tag: tagName } });
const breadcrumbHome = t({ locale, namespace: 'blog', key: 'tagPage.breadcrumb.home' });
const breadcrumbPosts = t({ locale, namespace: 'blog', key: 'tagPage.breadcrumb.posts' });
const breadcrumbTag = t({ locale, namespace: 'blog', key: 'tagPage.breadcrumb.tag', params: { tag: tagName } });
const heading = t({ locale, namespace: 'blog', key: 'tagPage.heading', params: { tag: tagName } });
const subHeading = t({ locale, namespace: 'blog', key: 'tagPage.subHeading', params: { tag: tagName } });
const emptyStateMessage = t({ locale, namespace: 'blog', key: 'tagPage.emptyState', params: { tag: tagName } });

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
  { label: breadcrumbHome, href: `/${locale}/` },
  { label: breadcrumbPosts, href: `/${locale}/publicaciones/` },
  { label: breadcrumbTag, href: `/${locale}/publicaciones/etiqueta/${tagSlug}/` },
];

/**
 * CollectionPage + BreadcrumbList JSON-LD structured data
 */
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: pageTitle,
      description: metaDescription,
      url: canonicalUrl,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbItems.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.label,
        item: new URL(item.href, Astro.site).href,
      })),
    },
  ],
};
---

<BaseLayout title={pageTitle} description={metaDescription} locale={locale}>
  <SEOHead
    slot="head"
    title={pageTitle}
    description={metaDescription}
    canonical={canonicalUrl}
    locale={locale}
    type="website"
  />
  <JsonLd slot="head" data={collectionJsonLd} />

  <Container>
    <Breadcrumb items={breadcrumbItems} />

    <Section>
      <div class="mx-auto max-w-6xl">
        <!-- Tag Header Section -->
        <article id="tag-header" class="mb-12 text-center">
          <h1 class="mb-4 text-4xl font-bold text-text-primary md:text-5xl">
            {heading}
          </h1>
          <p class="text-xl leading-relaxed text-text-secondary">
            {subHeading}
          </p>
        </article>

        <!-- Posts Grid Section -->
        <article id="posts-grid" class="mb-12">
          {
            posts.length > 0 ? (
              <div
                class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
                role="region"
                aria-label={pageTitle}
              >
                {posts.map((post) => (
                  <BlogPostCard
                    post={toPostCardProps({ item: post as Record<string, unknown> })}
                    locale={locale}
                  />
                ))}
              </div>
            ) : (
              <EmptyState
                title={emptyStateMessage}
                message={emptyStateMessage}
              />
            )
          }
        </article>

        <!-- Pagination Section -->
        {
          pagination && pagination.totalPages > 1 && (
            <article id="pagination" class="mb-12">
              <Pagination
                currentPage={pagination.page as number}
                totalPages={pagination.totalPages as number}
                baseUrl={`/${locale}/publicaciones/etiqueta/${tagSlug}`}
                locale={locale}
              />
            </article>
          )
        }
      </div>
    </Section>
  </Container>
</BaseLayout>
