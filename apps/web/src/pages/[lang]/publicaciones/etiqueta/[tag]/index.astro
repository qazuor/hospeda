---
/**
 * @file publicaciones/etiqueta/[tag]/index.astro
 * @description Blog posts filtered by tag. Displays a grid of posts for a given
 * tag slug, with breadcrumb, hero, grid, and pagination.
 *
 * Rendering: SSR (server-rendered on demand) — tag slugs are unknown at build time.
 * Query params: `page`.
 *
 * @route /[lang]/publicaciones/etiqueta/[tag]/
 */

import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import SEOHead from '../../../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../../../components/shared/Breadcrumb.astro';
import EmptyState from '../../../../../components/shared/EmptyState.astro';
import Pagination from '../../../../../components/shared/Pagination.astro';
import FeaturedArticleCard from '../../../../../components/shared/FeaturedArticleCard.astro';
import SecondaryArticleCard from '../../../../../components/shared/SecondaryArticleCard.astro';
import { createT } from '../../../../../lib/i18n';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../../../lib/page-helpers';
import { buildUrl } from '../../../../../lib/urls';
import { apiClient } from '../../../../../lib/api/client';
import { tagsApi } from '../../../../../lib/api/endpoints';
import { toPostCardProps } from '../../../../../lib/api/transforms';
import type { SupportedLocale } from '../../../../../lib/i18n';

/** Validate and extract locale from route params. Redirect on invalid locale. */
const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/publicaciones/');

/** Validate tag param. */
const { tag } = Astro.params;
if (!tag || typeof tag !== 'string' || tag.trim() === '') {
    return Astro.redirect(`/${locale}/publicaciones/`);
}

const tagSlug = tag.trim();

const t = createT(locale as SupportedLocale);

/**
 * Fetch tag metadata by slug.
 * If not found, redirect to the posts listing page.
 */
const tagResult = await tagsApi.getBySlug({ slug: tagSlug });

if (!tagResult.ok || !tagResult.data) {
    return Astro.redirect(`/${locale}/publicaciones/`);
}

const tagData = tagResult.data;
const tagName = tagData.name;

// --- Query params ---
const url       = new URL(Astro.request.url);
const page      = Math.max(1, Number.parseInt(url.searchParams.get('page') || '1', 10));
const pageSize  = 9;

/**
 * Fetch posts filtered by tag UUID.
 * Uses apiClient directly because postsApi.list does not expose a `tags` param.
 */
const apiResult = await apiClient.getList<Record<string, unknown>>({
    path: '/api/v1/public/posts',
    params: { page, pageSize, tags: tagData.id }
});

const apiError   = !apiResult.ok;
const posts      = apiResult.ok ? apiResult.data.items : [];
const pagination = apiResult.ok ? apiResult.data.pagination : null;

const postCards = posts.map((post) => toPostCardProps({ item: post as Record<string, unknown> }));

// --- Translations ---
const pageTitle       = t('blog.tagPage.title',       'Publicaciones: {tag}', { tag: tagName });
const pageDescription = t('blog.tagPage.description', 'Articulos etiquetados como {tag}', { tag: tagName });
const heroHeading     = t('blog.tagPage.heroHeading', 'Etiqueta: {tag}', { tag: tagName });
const heroDescription = t('blog.tagPage.heroDescription', 'Articulos y guias sobre {tag} en el Litoral argentino', { tag: tagName });
const allPostsLabel   = t('blog.tagPage.allPostsTitle', 'Publicaciones con esta etiqueta');
const emptyTitle      = t('blog.tagPage.emptyState',   'No se encontraron publicaciones');
const emptyMessage    = t('blog.tagPage.emptyMessage', 'No hay publicaciones con la etiqueta {tag}', { tag: tagName });

// --- Canonical URL ---
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// --- Breadcrumb ---
const postsLabel      = t('blog.listPage.title', 'Publicaciones');
const tagBreadcrumb   = t('blog.tagPage.breadcrumb', '{tag}', { tag: tagName });

const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale as SupportedLocale], href: buildUrl({ locale: locale as SupportedLocale }) },
    { label: postsLabel, href: buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' }) },
    { label: tagBreadcrumb, href: buildUrl({ locale: locale as SupportedLocale, path: `publicaciones/etiqueta/${tagSlug}` }) }
] as const;

/** Pagination search params preserved across pages (no extra filters in this view). */
const paginationParams = new URLSearchParams();
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    locale={locale}
>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale as SupportedLocale}
        type="website"
    />

    <div class="container mx-auto max-w-6xl px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />

        {/* Hero section */}
        <section aria-labelledby="tag-hero-heading" class="mb-12 mt-4 text-center">
            <h1
                id="tag-hero-heading"
                class="mb-4 text-4xl font-bold tracking-tight text-foreground md:text-5xl"
            >
                {heroHeading}
            </h1>
            <p class="mx-auto max-w-2xl text-lg leading-relaxed text-muted-foreground">
                {heroDescription}
            </p>
        </section>

        {/* Posts grid */}
        <section aria-labelledby="tag-posts-heading" class="mb-16">
            <h2 id="tag-posts-heading" class="mb-6 text-xl font-semibold text-foreground">
                {allPostsLabel}
            </h2>

            {apiError ? (
                <EmptyState
                    title={t('blog.tagPage.errorTitle', 'Error al cargar publicaciones')}
                    message={t('blog.tagPage.errorMessage', 'No se pudieron cargar las publicaciones. Por favor intenta de nuevo.')}
                    cta={{
                        label: t('blog.tagPage.retryLabel', 'Reintentar'),
                        href: buildUrl({ locale: locale as SupportedLocale, path: `publicaciones/etiqueta/${tagSlug}` })
                    }}
                />
            ) : postCards.length === 0 ? (
                <EmptyState
                    title={emptyTitle}
                    message={emptyMessage}
                    cta={{
                        label: t('blog.tagPage.viewAllLabel', 'Ver todas las publicaciones'),
                        href: buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' })
                    }}
                />
            ) : (
                <div class="grid gap-8 lg:grid-cols-12 lg:gap-10">
                    {/* First post: featured (large) layout */}
                    {postCards[0] && (
                        <FeaturedArticleCard article={postCards[0]} locale={locale} />
                    )}

                    {/* Remaining posts: secondary (compact) layout in a stacked column */}
                    {postCards.length > 1 && (
                        <div class="flex flex-col gap-6 lg:col-span-5">
                            {postCards.slice(1).map((post) => (
                                <SecondaryArticleCard article={post} locale={locale} />
                            ))}
                        </div>
                    )}
                </div>
            )}
        </section>

        {/* Pagination */}
        {pagination && pagination.totalPages > 1 && (
            <Pagination
                currentPage={pagination.page}
                totalPages={pagination.totalPages}
                baseUrl={buildUrl({ locale: locale as SupportedLocale, path: `publicaciones/etiqueta/${tagSlug}` }).replace(/\/$/, '')}
                locale={locale as SupportedLocale}
                searchParams={paginationParams.toString() ? paginationParams : undefined}
            />
        )}
    </div>
</BaseLayout>
