---
/**
 * @file publicaciones/[slug].astro
 * @description Blog post detail page with BlogPosting JSON-LD.
 * @route /{lang}/publicaciones/{slug}/
 * @rendering SSR + ISR 24h
 */

import DetailLayout from '@/layouts/DetailLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ArticleJsonLd from '@/components/seo/ArticleJsonLd.astro';
import BreadcrumbJsonLd from '@/components/seo/BreadcrumbJsonLd.astro';
import { ShareButtons } from '@/components/ShareButtons.client';
import PostDetailHeader from '@/components/post/PostDetailHeader.astro';
import PostContent from '@/components/post/PostContent.astro';
import PostTableOfContents from '@/components/post/PostTableOfContents.astro';
import PostAuthorCard from '@/components/post/PostAuthorCard.astro';
import PostRelatedEntityCard from '@/components/post/PostRelatedEntityCard.astro';
import PostSponsorshipBanner from '@/components/post/PostSponsorshipBanner.astro';
import RelatedPostCard from '@/components/shared/cards/RelatedPostCard.astro';
import TagChips from '@/components/TagChips.astro';
import { ImageGallery } from '@/components/ImageGallery.client';
import { ReadingProgressBar } from '@/components/post/ReadingProgressBar.client';
import { buildUrl } from '@/lib/urls';
import { postsApi, userBookmarksPublicApi } from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { getPostCategoryColor } from '@/lib/colors';
import { getExpiryStatus } from '@/lib/format-expires';
import { getMediaUrl } from '@repo/media';
import { renderContent } from '@/lib/render-content';
import { extractToc } from '@/lib/extract-toc';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { slug } = Astro.params;

if (!slug) return new Response(null, { status: 404 });

const result = await postsApi.getBySlug({ slug });
if (!result.ok) return new Response(null, { status: 404 });

const post = result.data as Record<string, unknown>;
const postId = String(post.id || '');
const title = String(post.title || '');
const summary = String(post.summary || post.excerpt || '');
const category = String(post.category || '');
const publishedAt = String(post.publishedAt || post.createdAt || '');
const updatedAt = post.updatedAt ? String(post.updatedAt) : undefined;
const readingTime = Number(post.readingTimeMinutes || 0);
const authorObj = post.author as Record<string, unknown> | undefined;
const categoryColors = getPostCategoryColor(category.toLowerCase());

// --- Media (gallery + videos) ---
// Real shape per PostPublicSchema + seed: `media.featuredImage.url`, `media.gallery[].url`,
// `media.videos[].url`. An older implementation read the cover as a top-level flat string,
// which never existed on the schema — hence the placeholder always won.
interface RawMediaImage {
	url?: string;
	caption?: string;
	description?: string;
}
interface RawMediaVideo {
	url?: string;
	caption?: string;
	description?: string;
}
interface RawMedia {
	featuredImage?: RawMediaImage | null;
	gallery?: ReadonlyArray<RawMediaImage> | null;
	videos?: ReadonlyArray<RawMediaVideo> | null;
}
const mediaObj = (post.media ?? null) as RawMedia | null;
const featuredImage = mediaObj?.featuredImage?.url || '/assets/images/placeholder-blog.svg';
const hasRealFeatured = Boolean(mediaObj?.featuredImage?.url);

const galleryImages: ReadonlyArray<{ readonly url: string; readonly alt: string; readonly caption?: string }> = (() => {
	const items: Array<{ url: string; alt: string; caption?: string }> = [];
	if (mediaObj?.featuredImage?.url) {
		items.push({
			url: mediaObj.featuredImage.url,
			alt: mediaObj.featuredImage.caption ?? title,
			caption: mediaObj.featuredImage.caption,
		});
	}
	if (Array.isArray(mediaObj?.gallery)) {
		for (const img of mediaObj.gallery as ReadonlyArray<RawMediaImage>) {
			if (img?.url) {
				items.push({
					url: img.url,
					alt: img.caption ?? title,
					caption: img.caption,
				});
			}
		}
	}
	return items;
})();

const postVideos: ReadonlyArray<{ readonly url: string; readonly caption?: string; readonly description?: string }> = (() => {
	if (!Array.isArray(mediaObj?.videos)) return [];
	return (mediaObj?.videos as ReadonlyArray<RawMediaVideo>)
		.filter((v): v is RawMediaVideo & { url: string } => Boolean(v?.url))
		.map((v) => ({ url: v.url, caption: v.caption, description: v.description }));
})();

// SPEC-086 D-024: user-tags (`post.tags`) are an internal subsystem with no
// public web UI — DO NOT render them as public links.
// PostTags (`post.postTags`) are the public SEO taxonomy and ARE rendered
// below the article body, linking to `/{lang}/publicaciones/etiqueta/{slug}/`.
// SPEC-086 D-002: tags without a slug cannot be rendered as filter links — skip them defensively.
const rawPostTags = Array.isArray(post.postTags) ? post.postTags : [];
const postTags: readonly { readonly id: string; readonly name: string; readonly slug: string }[] = rawPostTags
    .filter((tag): tag is Record<string, unknown> => tag !== null && typeof tag === 'object')
    .map((tag) => ({
        id: String(tag.id ?? ''),
        name: String(tag.name ?? ''),
        slug: String(tag.slug ?? ''),
    }))
    .filter((tag) => tag.slug && tag.name);

const rawAuthorAvatar = String(authorObj?.profilePicture || authorObj?.image || authorObj?.avatarUrl || '');
const authorAvatar = rawAuthorAvatar ? getMediaUrl(rawAuthorAvatar, { preset: 'avatar' }) : '';

const authorForCard = authorObj
	? {
			id: String(authorObj.id || ''),
			displayName: authorObj.displayName ? String(authorObj.displayName) : null,
			firstName: authorObj.firstName ? String(authorObj.firstName) : null,
			lastName: authorObj.lastName ? String(authorObj.lastName) : null,
			profilePicture: authorAvatar || null,
			bio: authorObj.bio ? String(authorObj.bio) : null,
			slug: authorObj.slug ? String(authorObj.slug) : null,
	  }
	: null;

// --- Auth ---
const userId = Astro.locals.user?.id ?? null;
const isAuthenticated = userId !== null;

// --- Bookmark count + favorite status (graceful degradation) ---
let bookmarkCount: number | undefined;
let initialIsFavorited: boolean | undefined;
let initialBookmarkId: string | null = null;

if (postId) {
	try {
		const countResult = await userBookmarksPublicApi.count({ entityType: 'POST', entityId: postId });
		if (countResult.ok) bookmarkCount = countResult.data.count;
	} catch { /* graceful */ }

	if (isAuthenticated) {
		try {
			const statusResult = await userBookmarksApi.checkStatus({ entityId: postId, entityType: 'POST' });
			if (statusResult.ok) {
				initialIsFavorited = statusResult.data.isFavorited;
				initialBookmarkId = statusResult.data.bookmarkId;
			}
		} catch { /* graceful */ }
	}
}

// --- Expiry ---
const postExpiresAt = post.expiresAt ? String(post.expiresAt) : undefined;
const expiryStatus = getExpiryStatus({ expiresAt: postExpiresAt });
const showExpiryBanner = expiryStatus.status === 'expiring-soon' || expiryStatus.status === 'expired';
const expiryDateLabel = postExpiresAt
    ? new Date(postExpiresAt).toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })
    : '';

// --- Render content (markdown → HTML, then sanitize) ---
// Body fields may arrive as markdown (seed format), HTML (TipTap admin output),
// or plain text. `renderContent` handles all three through a single pipeline.
const siteOrigin = Astro.site?.href ?? Astro.url.origin;
const safeContentHtml = renderContent({
	raw: String(post.contentHtml || post.content || summary),
	siteOrigin,
});

// --- TOC headings extracted from sanitized HTML ---
const tocHeadings = extractToc({ html: safeContentHtml });

// --- SEO override ---
const seoPost = post.seo as Record<string, unknown> | undefined;
const seoTitle = seoPost?.title ? String(seoPost.title) : title;
const seoDescription = seoPost?.description ? String(seoPost.description) : summary;

// --- Related posts ---
let relatedPosts: ReadonlyArray<Record<string, unknown>> = [];
const relatedDestinationId = post.relatedDestinationId ? String(post.relatedDestinationId) : null;

try {
	const relResult = relatedDestinationId
		? await postsApi.list({ destinationId: relatedDestinationId, pageSize: 4 })
		: await postsApi.list({ category, pageSize: 4 });

	if (relResult.ok) {
		const items = (relResult.data as { items?: unknown[]; data?: unknown[] }).items
			?? (relResult.data as { items?: unknown[]; data?: unknown[] }).data
			?? [];
		relatedPosts = (items as Record<string, unknown>[]).filter((p) => p.id !== postId).slice(0, 4);
	}
} catch { /* graceful */ }

// --- Related entity for sidebar ---
const relatedDestRaw = post.relatedDestination as Record<string, unknown> | undefined;
const relatedAccRaw = post.relatedAccommodation as Record<string, unknown> | undefined;
const relatedEventRaw = post.relatedEvent as Record<string, unknown> | undefined;

type EntityType = 'destination' | 'accommodation' | 'event';

interface RelatedEntity {
	readonly id: string;
	readonly name: string;
	readonly slug: string;
	readonly summary?: string | null;
	readonly image?: string | null;
	readonly type: EntityType;
}

function toRelatedEntity(raw: Record<string, unknown>, type: EntityType): RelatedEntity | null {
	const id = raw.id ? String(raw.id) : '';
	const name = raw.name ? String(raw.name) : '';
	const entitySlug = raw.slug ? String(raw.slug) : '';
	if (!id || !name || !entitySlug) return null;
	return {
		id,
		name,
		slug: entitySlug,
		summary: raw.summary ? String(raw.summary) : null,
		image: raw.featuredImage ? String(raw.featuredImage) : null,
		type,
	};
}

const relatedEntity: RelatedEntity | null =
	(relatedDestRaw && toRelatedEntity(relatedDestRaw, 'destination')) ||
	(relatedAccRaw && toRelatedEntity(relatedAccRaw, 'accommodation')) ||
	(relatedEventRaw && toRelatedEntity(relatedEventRaw, 'event')) ||
	null;

// --- Sponsorship ---
const sponsorship = post.sponsorship as Record<string, unknown> | undefined;

// --- JSON-LD ---
const siteBase = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const articleAuthorName =
	authorForCard?.displayName ||
	[authorForCard?.firstName, authorForCard?.lastName].filter(Boolean).join(' ') ||
	'';

// Speakable selectors (AEO / voice): the article headline and lead/summary
// rendered by PostDetailHeader.astro. Class names are the stable BEM-lite
// selectors `.post-header__title` (h1) and `.post-header__summary` (lead p).
// The summary element is only rendered when a summary exists, so include it
// conditionally to avoid pointing voice assistants at a missing node.
const speakableSelectors: ReadonlyArray<string> = [
	'.post-header__title',
	...(summary ? ['.post-header__summary'] : []),
];

const siteOriginClean = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const breadcrumbItems = [
	{ name: t('nav.home', 'Inicio'), url: `${siteOriginClean}/${locale}/` },
	{ name: t('blog.title', 'Publicaciones'), url: `${siteOriginClean}/${locale}/publicaciones/` },
	{ name: title, url: `${siteOriginClean}${Astro.url.pathname}` },
];
---

<DetailLayout
	locale={locale}
	title={seoTitle}
	description={seoDescription}
	ogImage={hasRealFeatured ? featuredImage : undefined}
	ogType="Guía"
	ogMetaType="article"
	articlePublishedTime={publishedAt || undefined}
	articleModifiedTime={updatedAt && updatedAt > publishedAt ? updatedAt : undefined}
	showBreadcrumbs={true}
	showSidebar={true}
>
	{articleAuthorName ? (
		<ArticleJsonLd
			slot="head-extra"
			headline={title}
			description={seoDescription}
			url={`${siteBase}${Astro.url.pathname}`}
			image={featuredImage !== '/assets/images/placeholder-blog.svg' ? featuredImage : undefined}
			datePublished={publishedAt}
			dateModified={updatedAt && updatedAt > publishedAt ? updatedAt : undefined}
			author={{ name: articleAuthorName }}
			articleType="BlogPosting"
			speakableCssSelectors={speakableSelectors}
		/>
	) : (
		<ArticleJsonLd
			slot="head-extra"
			headline={title}
			description={seoDescription}
			url={`${siteBase}${Astro.url.pathname}`}
			image={featuredImage !== '/assets/images/placeholder-blog.svg' ? featuredImage : undefined}
			datePublished={publishedAt}
			dateModified={updatedAt && updatedAt > publishedAt ? updatedAt : undefined}
			author={{ name: 'Hospeda' }}
			articleType="BlogPosting"
			speakableCssSelectors={speakableSelectors}
		/>
	)}
	<BreadcrumbJsonLd slot="head-extra" items={breadcrumbItems} />

	<ReadingProgressBar client:idle />

	<Breadcrumbs
		slot="breadcrumbs"
		locale={locale}
		items={[
			{ label: t('blog.title', 'Publicaciones'), path: 'publicaciones' },
			{ label: title },
		]}
	/>

	<Fragment slot="page-header">
		<PostDetailHeader
			title={title}
			summary={summary}
			category={category}
			categoryColor={{ bg: categoryColors.bg, text: categoryColors.text }}
			publishedAt={publishedAt}
			updatedAt={updatedAt ?? null}
			readingTimeMinutes={readingTime}
			bookmarkCount={bookmarkCount}
			postId={postId}
			locale={locale}
			isAuthenticated={isAuthenticated}
			initialIsFavorited={initialIsFavorited}
			initialBookmarkId={initialBookmarkId}
			author={authorForCard ? {
				id: authorForCard.id,
				name: authorForCard.displayName || [authorForCard.firstName, authorForCard.lastName].filter(Boolean).join(' ') || '',
				slug: authorForCard.slug,
			} : null}
			likes={Number(post.likes ?? 0)}
			comments={Number(post.comments ?? 0)}
			shares={Number(post.shares ?? 0)}
			isFeatured={Boolean(post.isFeatured)}
			isNews={Boolean(post.isNews)}
		/>
	</Fragment>

	{showExpiryBanner && (
		<div class:list={['post-expiry-banner', { 'post-expiry-banner--expired': expiryStatus.status === 'expired' }]}>
			{expiryStatus.status === 'expired'
				? t('blog.detail.expiredOn', `Publicación expirada el ${expiryDateLabel}`).replace('{{date}}', expiryDateLabel)
				: t('blog.detail.expiresOn', `Esta publicación expira el ${expiryDateLabel}`).replace('{{date}}', expiryDateLabel)
			}
		</div>
	)}

	<article class="post-detail">
		<!-- Cover + gallery -->
		{hasRealFeatured && galleryImages.length > 0 ? (
			<div class="post-detail__gallery">
				<ImageGallery
					images={galleryImages}
					variant="cover-plus-grid"
					locale={locale}
					client:visible
				/>
			</div>
		) : (
			<div class="post-detail__cover">
				<img
					src={featuredImage}
					alt={title}
					loading="eager"
					class="post-detail__cover-img"
					width="1200"
					height="675"
				/>
			</div>
		)}

		<!-- Post body -->
		<PostContent safeContentHtml={safeContentHtml} />

		<!-- Videos (if any) -->
		{postVideos.length > 0 && (
			<section class="post-detail__videos" aria-label={t('blog.detail.videosTitle', 'Videos')}>
				<h2 class="post-detail__videos-title">{t('blog.detail.videosTitle', 'Videos')}</h2>
				<div class="post-detail__videos-grid">
					{postVideos.map((video) => (
						<figure class="post-detail__video">
							<div class="post-detail__video-frame">
								<video
									src={video.url}
									controls
									preload="metadata"
									class="post-detail__video-el"
								>
									<track kind="captions" />
								</video>
							</div>
							{video.caption && (
								<figcaption class="post-detail__video-caption">{video.caption}</figcaption>
							)}
						</figure>
					))}
				</div>
			</section>
		)}

		<!-- PostTags (SPEC-086): public SEO taxonomy linking to tag-filtered listings -->
		{postTags.length > 0 && (
			<div class="post-detail__tags">
				<TagChips
					ariaLabel={t('blog.detail.tags.title', 'Etiquetas de la publicación')}
					chips={postTags.map((tag) => ({
						label: tag.name,
						href: buildUrl({ locale, path: `publicaciones/etiqueta/${tag.slug}` }),
					}))}
				/>
			</div>
		)}

		<!-- Sponsorship (after content) -->
		{sponsorship && (
			<PostSponsorshipBanner
				sponsorship={{
					message: sponsorship.message ? String(sponsorship.message) : null,
					websiteUrl: sponsorship.websiteUrl ? String(sponsorship.websiteUrl) : null,
					sponsorName: sponsorship.sponsorName ? String(sponsorship.sponsorName) : null,
					logoUrl: sponsorship.logoUrl ? String(sponsorship.logoUrl) : null,
				}}
				locale={locale}
			/>
		)}

		<!-- Share buttons -->
		<div class="post-detail__share">
			<ShareButtons
				url={`${siteBase}${Astro.url.pathname}`}
				title={title}
				locale={locale}
				client:visible
			/>
		</div>

		<!-- Related posts -->
		{relatedPosts.length > 0 && (
			<section class="post-detail__related">
				<h2 class="post-detail__related-title">
					{t('blog.detail.relatedPosts', 'Publicaciones relacionadas')}
				</h2>
				<div class="post-detail__related-grid">
					{relatedPosts.map((p) => (
						<RelatedPostCard
							id={String(p.id || '')}
							slug={String(p.slug || '')}
							title={String(p.title || '')}
							summary={String(p.summary || p.excerpt || '')}
							featuredImage={
								(p.media as { featuredImage?: { url?: string } } | null | undefined)
									?.featuredImage?.url ?? null
							}
							publishedAt={p.publishedAt ? String(p.publishedAt) : null}
							lang={locale}
						/>
					))}
				</div>
			</section>
		)}
	</article>

	<!-- Sidebar -->
	<div slot="sidebar" class="post-sidebar">
		<PostTableOfContents headings={tocHeadings} locale={locale} />

		{authorForCard && authorForCard.id && (
			<PostAuthorCard author={authorForCard} locale={locale} />
		)}

		{relatedEntity && (
			<PostRelatedEntityCard entity={relatedEntity} locale={locale} />
		)}
	</div>
</DetailLayout>

<style>
	.post-expiry-banner {
		margin-bottom: 1rem;
		padding: 0.75rem 1rem;
		border-radius: var(--radius-md);
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		font-weight: 500;
		background-color: var(--warning-a10);
		border: 1px solid var(--warning-a35);
		color: var(--core-foreground);
	}

	.post-expiry-banner--expired {
		background-color: var(--muted, oklch(0.9 0 0));
		border-color: var(--border);
		color: var(--core-muted-foreground);
	}

	.post-detail {
		min-width: 0;
	}

	.post-detail__cover {
		margin-bottom: var(--space-6, 1.5rem);
		border-radius: var(--radius-card);
		overflow: hidden;
	}

	.post-detail__cover-img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.post-detail__gallery {
		margin-bottom: var(--space-6, 1.5rem);
	}

	.post-detail__videos {
		margin-top: var(--space-8, 2rem);
		padding-top: var(--space-6, 1.5rem);
		border-top: 1px solid var(--border);
	}

	.post-detail__videos-title {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 1.35rem;
		color: var(--core-foreground);
		margin: 0 0 1.25rem;
	}

	.post-detail__videos-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: var(--space-card-gap, 1.5rem);
	}

	.post-detail__video {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.post-detail__video-frame {
		border-radius: var(--radius-card);
		overflow: hidden;
		background-color: var(--surface-warm);
	}

	.post-detail__video-el {
		width: 100%;
		aspect-ratio: 16 / 9;
		display: block;
	}

	.post-detail__video-caption {
		font-family: var(--font-sans);
		font-size: 0.85rem;
		line-height: 1.4;
		color: var(--core-muted-foreground);
		text-align: center;
	}

	.post-detail__tags {
		margin-top: var(--space-6, 1.5rem);
	}

	.post-detail__share {
		margin-top: var(--space-6, 1.5rem);
		display: flex;
		justify-content: flex-start;
	}

	.post-detail__related {
		margin-top: var(--space-8, 2rem);
		padding-top: var(--space-6, 1.5rem);
		border-top: 1px solid var(--border);
	}

	.post-detail__related-title {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 1.35rem;
		color: var(--core-foreground);
		margin: 0 0 1.25rem;
	}

	.post-detail__related-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-card-gap, 1.5rem);
	}

	.post-sidebar {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	@media (max-width: 640px) {
		.post-detail__related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
