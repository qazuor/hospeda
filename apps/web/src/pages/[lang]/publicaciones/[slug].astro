---
/**
 * @file publicaciones/[slug].astro
 * @description Blog post detail page. Displays full article content with metadata,
 * author info, tags, share buttons, JSON-LD Article schema, and related posts.
 *
 * Rendering: SSG with prerender + API fallback for unpublished paths.
 * Route: /[lang]/publicaciones/[slug]/
 */

export const prerender = true;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import ArticleJsonLd from '../../../components/seo/ArticleJsonLd.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import Badge from '../../../components/shared/Badge.astro';
import EmptyState from '../../../components/shared/EmptyState.astro';
import SecondaryArticleCard from '../../../components/shared/SecondaryArticleCard.astro';
import { ShareButtons } from '../../../components/shared/ShareButtons.client';
import { CalendarIcon, ClockIcon, UserIcon, TagIcon, ShareIcon } from '@repo/icons';
import { createT, SUPPORTED_LOCALES, type SupportedLocale } from '../../../lib/i18n';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { buildUrl } from '../../../lib/urls';
import { postsApi } from '../../../lib/api/endpoints';
import { fetchAllPages } from '../../../lib/api/client';
import { toPostCardProps } from '../../../lib/api/transforms';
import { renderTiptapContent } from '../../../lib/tiptap-renderer';
import { sanitizeHtml } from '../../../lib/sanitize-html';
import { formatDate, toBcp47Locale } from '@repo/i18n';
import type { PostPublic } from '@repo/schemas';
import type { TiptapDocument } from '../../../lib/tiptap-renderer';

/**
 * Generates static paths for all blog posts across all supported locales.
 * Fetches all published posts and maps each to locale + slug combinations.
 */
export async function getStaticPaths() {
    const posts = await fetchAllPages<PostPublic>({
        fetcher: (p) => postsApi.list(p),
    });

    return SUPPORTED_LOCALES.flatMap((lang) =>
        posts
            .filter((p) => Boolean(p.slug))
            .map((p) => ({
                params: { lang, slug: p.slug },
                props: { post: p },
            }))
    );
}

// --- Locale validation ---
const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/publicaciones/');

const { slug } = Astro.params;
const t = createT(locale as SupportedLocale);

// --- Post data: from props (SSG) or API fallback ---
let post = Astro.props.post as PostPublic | undefined;

if (!post) {
    const result = await postsApi.getBySlug({ slug: slug ?? '' });
    if (!result.ok) {
        return Astro.redirect(buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' }));
    }
    post = result.data;
}

// --- Related posts (up to 3, excluding current) ---
const relResult = await postsApi.list({ pageSize: 4 });
const allPosts = relResult.ok ? relResult.data.items : [];
const relatedPosts = allPosts
    .filter((p) => p.id !== post?.id)
    .slice(0, 3)
    .map((p) => toPostCardProps({ item: p as Record<string, unknown> }));

// --- Render TipTap content to sanitized HTML ---
const renderedContent = sanitizeHtml({
    html: renderTiptapContent({ content: post.content as TiptapDocument | null | undefined }),
});

// --- Localized labels ---
const labelHome         = HOME_BREADCRUMB[locale as SupportedLocale];
const labelBlog         = t('blog.detail.blog',         'Publicaciones');
const labelTags         = t('blog.detail.tags',         'Etiquetas');
const labelShare        = t('blog.detail.share',        'Compartir');
const labelReadingTime  = t('blog.detail.readingTime',  'min de lectura');
const labelRelatedPosts = t('blog.detail.relatedPosts', 'Publicaciones relacionadas');
const labelNoRelated    = t('blog.detail.noRelated',    'No hay publicaciones relacionadas');

// --- Date formatting ---
const publishDate   = new Date(post.publishedAt ?? Date.now());
const formattedDate = formatDate({
    date: publishDate,
    locale: toBcp47Locale(locale),
    options: { year: 'numeric', month: 'long', day: 'numeric' },
});

// --- Derived values ---
const authorName  = (post.author as Record<string, unknown> | undefined)?.name
    ? String((post.author as Record<string, unknown>).name)
    : 'Anonymous';
const authorAvatar = (post.author as Record<string, unknown> | undefined)?.avatar
    ? String((post.author as Record<string, unknown>).avatar)
    : '/images/placeholder-avatar.svg';
const coverImage  = String((post as Record<string, unknown>).coverImage ?? '/images/placeholder-blog.svg');
const tags        = Array.isArray((post as Record<string, unknown>).tags)
    ? ((post as Record<string, unknown>).tags as unknown[]).map(String)
    : [];
const readingTime = Number((post as Record<string, unknown>).readingTimeMinutes ?? 5);
const category    = String((post as Record<string, unknown>).category ?? 'Blog');

// --- URLs ---
const pageUrl      = buildUrl({ locale: locale as SupportedLocale, path: `publicaciones/${post.slug}` });
const canonicalUrl = new URL(pageUrl, Astro.site).href;

// --- Breadcrumb items ---
const breadcrumbItems = [
    { label: labelHome, href: buildUrl({ locale: locale as SupportedLocale }) },
    { label: labelBlog, href: buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' }) },
    { label: post.title, href: pageUrl },
] as const;
---

<BaseLayout title={post.title} description={String((post as Record<string, unknown>).excerpt ?? '')} locale={locale}>
    <SEOHead
        slot="head"
        title={post.title}
        description={String((post as Record<string, unknown>).excerpt ?? '')}
        canonical={canonicalUrl}
        image={coverImage}
        type="article"
        locale={locale as SupportedLocale}
    />
    <ArticleJsonLd
        slot="head"
        headline={post.title}
        description={String((post as Record<string, unknown>).excerpt ?? '')}
        url={canonicalUrl}
        image={coverImage}
        datePublished={String(post.publishedAt ?? new Date().toISOString())}
        dateModified={String((post as Record<string, unknown>).updatedAt ?? post.publishedAt ?? new Date().toISOString())}
        author={{ name: authorName }}
    />

    <div class="container mx-auto max-w-4xl px-4 py-8">

        <!-- Breadcrumb -->
        <Breadcrumb items={breadcrumbItems} />

        <article aria-labelledby="post-title">

            <!-- Featured image -->
            <div class="mb-6 overflow-hidden rounded-2xl">
                <img
                    src={coverImage}
                    alt={post.title}
                    class="aspect-video w-full object-cover"
                    loading="eager"
                    transition:name={`entity-${slug}`}
                />
            </div>

            <!-- Category badge -->
            <div class="mb-4">
                <Badge variant="primary" class="text-sm">
                    {category}
                </Badge>
            </div>

            <!-- Title -->
            <h1
                id="post-title"
                class="mb-6 text-3xl font-bold leading-tight text-foreground md:text-4xl"
            >
                {post.title}
            </h1>

            <!-- Author + metadata row -->
            <div class="mb-8 flex flex-wrap items-center gap-4 border-b border-border pb-6">
                <div class="flex items-center gap-3">
                    <img
                        src={authorAvatar}
                        alt={authorName}
                        class="h-10 w-10 rounded-full object-cover"
                        loading="lazy"
                        aria-hidden="true"
                    />
                    <div>
                        <p class="flex items-center gap-1.5 text-sm font-medium text-foreground">
                            <UserIcon size={14} aria-hidden="true" />
                            {authorName}
                        </p>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
                    <time
                        datetime={publishDate.toISOString()}
                        class="flex items-center gap-1.5"
                    >
                        <CalendarIcon size={14} aria-hidden="true" />
                        {formattedDate}
                    </time>

                    <span class="flex items-center gap-1.5" aria-label={`${readingTime} ${labelReadingTime}`}>
                        <ClockIcon size={14} aria-hidden="true" />
                        {readingTime} {labelReadingTime}
                    </span>
                </div>
            </div>

            <!-- Article body (TipTap rendered + sanitized HTML) -->
            <div
                class="prose prose-lg max-w-none prose-headings:text-foreground prose-p:text-muted-foreground prose-a:text-primary prose-strong:text-foreground prose-blockquote:border-primary prose-blockquote:text-muted-foreground prose-code:text-accent prose-pre:bg-muted"
                set:html={renderedContent}
            />

            <!-- Tags section -->
            {tags.length > 0 && (
                <div class="mt-10 border-t border-border pt-6">
                    <h2 class="mb-3 flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
                        <TagIcon size={14} aria-hidden="true" />
                        {labelTags}
                    </h2>
                    <div class="flex flex-wrap gap-2">
                        {tags.map((tag) => (
                            <Badge variant="outline" class="text-xs">
                                {tag}
                            </Badge>
                        ))}
                    </div>
                </div>
            )}

            <!-- Share section -->
            <div class="mt-6 border-t border-border pt-6">
                <h2 class="mb-3 flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
                    <ShareIcon size={14} aria-hidden="true" />
                    {labelShare}
                </h2>
                <ShareButtons
                    client:visible
                    url={canonicalUrl}
                    title={post.title}
                    text={String((post as Record<string, unknown>).excerpt ?? '')}
                    locale={locale as SupportedLocale}
                />
            </div>

        </article>

        <!-- Related posts -->
        {relatedPosts.length > 0 ? (
            <section aria-labelledby="related-posts-heading" class="scroll-reveal mt-16">
                <h2
                    id="related-posts-heading"
                    class="mb-8 text-2xl font-bold text-foreground"
                >
                    {labelRelatedPosts}
                </h2>
                <div class="flex flex-col gap-6 sm:grid sm:grid-cols-2 lg:grid-cols-3">
                    {relatedPosts.map((related) => (
                        <SecondaryArticleCard article={related} locale={locale} />
                    ))}
                </div>
            </section>
        ) : (
            <section aria-labelledby="related-posts-heading" class="scroll-reveal mt-16">
                <h2
                    id="related-posts-heading"
                    class="mb-4 text-2xl font-bold text-foreground"
                >
                    {labelRelatedPosts}
                </h2>
                <EmptyState
                    title={labelNoRelated}
                    message=""
                    cta={{
                        label: labelBlog,
                        href: buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' })
                    }}
                />
            </section>
        )}

    </div>
</BaseLayout>
