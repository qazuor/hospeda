---
export const prerender = true;

/**
 * Blog post detail page.
 * Displays full article content with metadata, author info, tags, and related posts.
 *
 * Rendering: SSG + ISR (24h revalidation)
 * Route: /[lang]/publicaciones/[slug]
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import Badge from '../../../components/ui/Badge.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import ArticleJsonLd from '../../../components/seo/ArticleJsonLd.astro';
import { ShareButtons } from '../../../components/ui/ShareButtons.client.tsx';
import BlogPostCard from '../../../components/blog/BlogPostCard.astro';
import { SUPPORTED_LOCALES, getLocaleFromParams } from '../../../lib/page-helpers';
import { renderTiptapContent } from '../../../lib/tiptap-renderer';
import { sanitizeHtml } from '../../../lib/sanitize-html';
import { postsApi } from '../../../lib/api/endpoints';
import { fetchAllPages } from '../../../lib/api/client';
import { toPostCardProps } from '../../../lib/api/transforms';
import { formatDate, toBcp47Locale } from '@repo/i18n';
import { t as i18nT } from '../../../lib/i18n';

const { slug } = Astro.params;

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * getStaticPaths - Generate static paths for all posts
 */
export async function getStaticPaths() {
	const locales = SUPPORTED_LOCALES;
	const posts = await fetchAllPages({
		fetcher: (p) => postsApi.list(p),
	});

	return locales.flatMap((lang) =>
		posts
			.filter((p) => p.slug)
			.map((p) => ({
				params: { lang, slug: p.slug },
				props: { post: p },
			}))
	);
}

// Fetch post from props (getStaticPaths) or API (fallback)
let post = Astro.props.post;
if (!post) {
	const result = await postsApi.getBySlug({ slug: slug || '' });
	if (!result.ok) {
		return Astro.redirect(`/${locale}/publicaciones/`);
	}
	post = result.data;
}

// Fetch related posts from API
const relResult = await postsApi.list({ pageSize: 4 });
const allPosts = relResult.ok ? relResult.data.items : [];
const relatedPosts = allPosts
	.filter((p) => p.id !== post.id)
	.slice(0, 3)
	.map((p) => ({ post: toPostCardProps({ item: p as Record<string, unknown> }) }));

/**
 * Render TipTap content to HTML
 */
const renderedContent = sanitizeHtml({ html: renderTiptapContent({ content: post.content }) });

/**
 * Localized labels from i18n
 */
const blogLabel = i18nT({ locale, namespace: 'blog', key: 'detail.blog' });
const relatedPostsLabel = i18nT({ locale, namespace: 'blog', key: 'detail.relatedPosts' });
const shareLabel = i18nT({ locale, namespace: 'blog', key: 'detail.share' });
const tagsLabel = i18nT({ locale, namespace: 'blog', key: 'detail.tags' });
const readingTimeLabel = i18nT({ locale, namespace: 'blog', key: 'detail.readingTime' });
const homeLabel = i18nT({ locale, namespace: 'blog', key: 'detail.home' });

/**
 * Format publication date according to locale
 */
const publishDate = new Date(post.publishedAt || Date.now());
const formattedDate = formatDate({
	date: publishDate,
	locale: toBcp47Locale(locale),
	options: { year: 'numeric', month: 'long', day: 'numeric' },
});

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: homeLabel, href: `/${locale}/` },
	{ label: blogLabel, href: `/${locale}/publicaciones/` },
	{ label: post.category || 'Blog', href: `/${locale}/publicaciones/` },
];

/**
 * Page URL for sharing and canonical
 */
const pageUrl = `/${locale}/publicaciones/${post.slug}/`;
const canonicalUrl = new URL(pageUrl, Astro.site).href;
---

<BaseLayout title={post.title} description={post.excerpt || ''} locale={locale}>
	<SEOHead
		slot="head"
		title={post.title}
		description={post.excerpt || ''}
		canonical={canonicalUrl}
		image={post.coverImage || '/images/placeholder-blog.svg'}
		type="article"
		locale={locale}
	/>
	<ArticleJsonLd
		slot="head"
		headline={post.title}
		description={post.excerpt || ''}
		url={canonicalUrl}
		image={post.coverImage || '/images/placeholder-blog.svg'}
		datePublished={post.publishedAt || new Date().toISOString()}
		author={{ name: post.author?.name || 'Anonymous' }}
	/>

	<Container>
		<!-- Breadcrumbs -->
		<Breadcrumb items={breadcrumbItems} />

		<article class="mx-auto max-w-3xl">
			<!-- Featured Image -->
			<img
				src={post.coverImage || '/images/placeholder-blog.svg'}
				alt={post.title}
				class="mb-6 aspect-video w-full rounded-lg object-cover"
				loading="eager"
				transition:name={`entity-${slug}`}
			/>

			<!-- Category badge -->
			<Badge label={post.category || 'Blog'} variant="primary" class="mb-3" />

			<!-- Title -->
			<h1 class="mb-4 text-3xl font-bold text-text-primary md:text-4xl">
				{post.title}
			</h1>

			<!-- Author info + meta -->
			<div class="mb-8 flex items-center gap-4 text-text-secondary">
				<img
					src={post.author?.avatar || '/images/placeholder-avatar.svg'}
					alt={post.author?.name || 'Anonymous'}
					class="h-10 w-10 rounded-full object-cover"
					loading="lazy"
				/>
				<div>
					<p class="font-medium text-text">{post.author?.name || 'Anonymous'}</p>
					<p class="text-sm">
						{formattedDate} · {post.readingTime || 5}
						{readingTimeLabel}
					</p>
				</div>
			</div>

			<!-- Content (TipTap rendered) -->
			<div class="prose prose-lg max-w-none" set:html={renderedContent} />

			<!-- Tags -->
			<div class="mt-8 border-t pt-6">
				<h3 class="mb-3 text-sm font-semibold uppercase text-text-tertiary">
					{tagsLabel}
				</h3>
				<div class="flex flex-wrap gap-2">
					{
						(post.tags || []).map((tag: string) => (
							<Badge label={tag} variant="outline" />
						))
					}
				</div>
			</div>

			<!-- Share -->
			<div class="mt-6 border-t pt-6">
				<h3 class="mb-3 text-sm font-semibold uppercase text-text-tertiary">
					{shareLabel}
				</h3>
				<ShareButtons client:visible url={canonicalUrl} title={post.title} />
			</div>
		</article>

		<!-- Related Posts -->
		<Section title={relatedPostsLabel} class="mt-12">
			<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{
					relatedPosts.map((rp) => (
						<BlogPostCard {...rp} locale={locale} />
					))
				}
			</div>
		</Section>
	</Container>
</BaseLayout>
