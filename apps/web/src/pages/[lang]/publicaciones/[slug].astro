---
/**
 * @file publicaciones/[slug].astro
 * @description Blog post detail page with BlogPosting JSON-LD.
 * @route /{lang}/publicaciones/{slug}/
 * @rendering SSR + ISR 24h
 */

import DetailLayout from '@/layouts/DetailLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import BreadcrumbJsonLd from '@/components/seo/BreadcrumbJsonLd.astro';
import Badge from '@/components/shared/ui/Badge.astro';
import { ShareButtons } from '@/components/ShareButtons.client';
import { postsApi, userBookmarksPublicApi } from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { formatDate } from '@/lib/format-utils';
import { Image } from 'astro:assets';
import { getPostCategoryColor } from '@/lib/colors';
import { getMediaUrl } from '@repo/media';

const locale = Astro.locals.locale as SupportedLocale;
const { t, tPlural } = createTranslations(locale);
const { slug } = Astro.params;

if (!slug) return new Response(null, { status: 404 });

const result = await postsApi.getBySlug({ slug });
if (!result.ok) return new Response(null, { status: 404 });

const post = result.data as Record<string, unknown>;
const postId = String(post.id || '');
const title = String(post.title || '');
const summary = String(post.summary || post.excerpt || '');
const category = String(post.category || '');
const publishedAt = String(post.publishedAt || post.createdAt || '');
const updatedAt = post.updatedAt ? String(post.updatedAt) : undefined;
const featuredImage = String(post.featuredImage || '/assets/images/placeholder-post.svg');
const readingTime = Number(post.readingTimeMinutes || 0);
const authorObj = post.author as Record<string, unknown> | undefined;
const authorName = String(authorObj?.displayName || authorObj?.name || '');
const authorSlug = authorObj?.slug ? String(authorObj.slug) : null;
const rawAuthorAvatar = String(authorObj?.image || authorObj?.avatarUrl || '');
// Route Cloudinary-hosted author avatars through the `avatar` preset so a
// 150x150 face-cropped variant is delivered. Non-Cloudinary URLs pass through
// unchanged (getMediaUrl contract). Empty strings stay empty to keep the
// conditional render below unchanged.
const authorAvatar = rawAuthorAvatar
	? getMediaUrl(rawAuthorAvatar, { preset: 'avatar' })
	: '';
// SPEC-086 D-024: user-tags are an internal subsystem with no public web UI.
// The `post.tags` field from the API contains user-tags (no slug — D-002).
// PostTags (public SEO taxonomy) are a separate subsystem not yet returned
// in the post detail API response. Do NOT render user-tags as public links.
// This array is kept for future postTags support when the API includes them.
const postTags: readonly { readonly name: string; readonly slug: string }[] = [];
const categoryColors = getPostCategoryColor(category.toLowerCase());

// --- Auth ---
const userId = Astro.locals.user?.id ?? null;
const isAuthenticated = userId !== null;

// --- Bookmark count + favorite status (graceful degradation) ---
let bookmarkCount: number | undefined;
let initialIsFavorited: boolean | undefined;
let initialBookmarkId: string | null = null;

if (postId) {
	try {
		const countResult = await userBookmarksPublicApi.count({
			entityType: 'POST',
			entityId: postId
		});
		if (countResult.ok) {
			bookmarkCount = countResult.data.count;
		}
	} catch {
		// Graceful degradation: counter not shown if fetch fails
	}

	if (isAuthenticated) {
		try {
			const statusResult = await userBookmarksApi.checkStatus({
				entityId: postId,
				entityType: 'POST'
			});
			if (statusResult.ok) {
				initialIsFavorited = statusResult.data.isFavorited;
				initialBookmarkId = statusResult.data.bookmarkId;
			}
		} catch {
			// Graceful degradation: FavoriteButton hydrates itself on mount
		}
	}
}

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description: summary,
	image: featuredImage,
	url: `${Astro.site ?? Astro.url.origin}${Astro.url.pathname}`,
	datePublished: publishedAt,
	...(updatedAt ? { dateModified: updatedAt } : {}),
	...(authorName ? { author: { '@type': 'Person', name: authorName } } : {}),
	publisher: {
		'@type': 'Organization',
		name: 'Hospeda',
		url: 'https://hospeda.com.ar',
	},
};

// --- Breadcrumb JSON-LD (REQ-096-37 / T-068) ---
const siteOrigin = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const breadcrumbItems = [
	{ name: t('nav.home', 'Inicio'), url: `${siteOrigin}/${locale}/` },
	{ name: t('blog.title', 'Publicaciones'), url: `${siteOrigin}/${locale}/publicaciones/` },
	{ name: title, url: `${siteOrigin}${Astro.url.pathname}` },
];
---

<DetailLayout
	locale={locale}
	title={title}
	description={summary}
	showBreadcrumbs={true}
	showSidebar={false}
>
	<JsonLd slot="head-extra" data={jsonLd} />
	<BreadcrumbJsonLd slot="head-extra" items={breadcrumbItems} />

	<Breadcrumbs
		slot="breadcrumbs"
		locale={locale}
		items={[
			{ label: t('blog.title', 'Publicaciones'), path: 'publicaciones' },
			{ label: title },
		]}
	/>

	<Fragment slot="page-header">
		<div class="post-detail__header-top-row">
			<h1 class="post-detail__title">{title}</h1>
			{postId && (
				<FavoriteButton
					client:load
					entityId={postId}
					entityType="POST"
					initialIsFavorited={initialIsFavorited}
					initialBookmarkId={initialBookmarkId}
					isAuthenticated={isAuthenticated}
					variant="standalone"
					locale={locale}
					class="post-detail__favorite-btn"
				/>
			)}
		</div>
		<div class="post-detail__meta">
			<span class="post-detail__category" style={`background-color: ${categoryColors.bg}; color: ${categoryColors.text};`}>
				{t(`blog.categories.${category.toLowerCase()}`, category)}
			</span>
			{publishedAt && (
				<time class="post-detail__date" datetime={publishedAt}>
					{formatDate({ date: publishedAt, locale })}
				</time>
			)}
			{readingTime > 0 && (
				<span class="post-detail__reading-time">
					{readingTime} min {t('blog.detail.readingTime', 'de lectura')}
				</span>
			)}
			{bookmarkCount !== undefined && (
				<span class="post-detail__bookmark-count" aria-label={tPlural('blog.detail.bookmark_count', bookmarkCount)}>
					<span class="post-detail__bookmark-icon" aria-hidden="true">♥</span>
					{tPlural('blog.detail.bookmark_count', bookmarkCount)}
				</span>
			)}
		</div>
	</Fragment>

	<article class="post-detail">
		<!-- Cover image -->
		<div class="post-detail__cover">
			{featuredImage && !featuredImage.includes('placeholder') ? (
				<Image
					src={featuredImage}
					alt={title}
					width={1200}
					height={675}
					format="webp"
					loading="eager"
					class="post-detail__cover-img"
				/>
			) : (
				<img
					src={featuredImage}
					alt={title}
					loading="eager"
					class="post-detail__cover-img"
					width="1200"
					height="675"
				/>
			)}
		</div>

		<!-- Author -->
		{authorName && (
			<div class="post-detail__author">
				{authorAvatar ? (
					<img
						src={authorAvatar}
						alt={authorName}
						class="post-detail__author-avatar"
						width={40}
						height={40}
						loading="lazy"
						decoding="async"
					/>
				) : null}
				{authorSlug ? (
					<a
						href={buildUrl({ locale, path: `publicaciones/autor/${authorSlug}` })}
						class="post-detail__author-name post-detail__author-link"
					>
						{authorName}
					</a>
				) : (
					<span class="post-detail__author-name">{authorName}</span>
				)}
			</div>
		)}

		<!-- Content (TipTap) -->
		<div class="post-detail__content" set:html={String(post.contentHtml || post.content || summary)} />

		<!-- PostTags (SPEC-086: public SEO taxonomy — rendered as clickable chips) -->
		{postTags.length > 0 && (
			<div class="post-detail__tags">
				{postTags.map((tag: { readonly name: string; readonly slug: string }) => (
					<a
						href={buildUrl({ locale, path: `publicaciones/etiqueta/${tag.slug}` })}
						class="post-detail__tag"
					>
						#{tag.name}
					</a>
				))}
			</div>
		)}

		<!-- Share buttons -->
		<div class="post-detail__share">
			<ShareButtons
				url={`${Astro.site ?? Astro.url.origin}${Astro.url.pathname}`}
				title={title}
				locale={locale}
				client:visible
			/>
		</div>
	</article>
</DetailLayout>

<style>
	.post-detail { max-width: 75ch; margin: 0 auto; }

	.post-detail__cover { margin-bottom: var(--space-6); border-radius: var(--radius-card); overflow: hidden; }
	.post-detail__cover-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }

	.post-detail__header-top-row { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--space-3); }
	.post-detail__meta { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; margin-bottom: var(--space-3); }
	.post-detail__category { padding: 0.25rem 0.75rem; border-radius: var(--radius-pill); font-family: var(--font-sans); font-size: var(--text-body-sm); font-weight: 600; }
	.post-detail__date, .post-detail__reading-time { font-family: var(--font-sans); font-size: var(--text-body-sm); color: var(--muted-foreground); }
	.post-detail__bookmark-count { display: inline-flex; align-items: center; gap: 0.3em; font-family: var(--font-sans); font-size: 0.8rem; font-weight: 500; color: var(--muted-foreground); border-left: 1px solid var(--border); padding-left: var(--space-2, 8px); margin-left: var(--space-1, 4px); }
	.post-detail__bookmark-icon { font-size: 0.75rem; color: var(--destructive); line-height: 1; }

	.post-detail__title { font-family: var(--font-heading); font-weight: 700; font-size: clamp(1.75rem, 4vw, 2.75rem); color: var(--foreground); line-height: 1.2; margin: 0 0 var(--space-4); }

	.post-detail__author { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-8); }
	.post-detail__author-avatar { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; }
	.post-detail__author-name { font-family: var(--font-sans); font-weight: 500; color: var(--foreground); }
	.post-detail__author-link { text-decoration: none; transition: color var(--duration-fast) ease; }
	.post-detail__author-link:hover { color: var(--brand-accent); text-decoration: underline; }

	.post-detail__content { font-family: var(--font-sans); font-size: var(--text-body-lg); line-height: 1.8; color: var(--foreground); margin-bottom: var(--space-8); }
	.post-detail__content :global(h2) { font-family: var(--font-heading); font-weight: 600; font-size: var(--text-xl); margin-top: var(--space-8); margin-bottom: var(--space-4); }
	.post-detail__content :global(h3) { font-family: var(--font-heading); font-weight: 600; font-size: var(--text-lg); margin-top: var(--space-6); margin-bottom: var(--space-3); }
	.post-detail__content :global(p) { margin-bottom: var(--space-4); }
	.post-detail__content :global(img) { width: 100%; border-radius: var(--radius-card); margin: var(--space-6) 0; }

	.post-detail__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-6); }
	.post-detail__tag { padding: 0.375rem 0.75rem; background-color: var(--muted); border-radius: var(--radius-pill); font-family: var(--font-sans); font-size: var(--text-body-sm); color: var(--muted-foreground); text-decoration: none; transition: background-color var(--duration-fast) ease; }
	.post-detail__tag:hover { background-color: var(--border); color: var(--foreground); }
	.post-detail__share { margin-top: var(--space-6); display: flex; justify-content: flex-start; }
</style>
