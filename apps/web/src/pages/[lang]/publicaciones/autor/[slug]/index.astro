---
/**
 * @file publicaciones/autor/[slug]/index.astro
 * @description Posts by author. Requires user-by-slug endpoint (T-016).
 * @route /{lang}/publicaciones/autor/{slug}/
 * @rendering SSR + ISR 24h
 */
// TODO: Requires GET /api/v1/public/users/by-slug/{slug} endpoint (T-016)
import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/ListingPageHeader.astro';
import EmptyState from '@/components/shared/EmptyState.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { slug } = Astro.params;
if (!slug) return new Response(null, { status: 404 });
const authorName = slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
---

<ListingLayout locale={locale} title={`${authorName} - ${t('blog.title', 'Publicaciones')}`} showFilters={false}>
	<Breadcrumbs slot="breadcrumbs" locale={locale} items={[{ label: t('blog.title', 'Publicaciones'), path: 'publicaciones' }, { label: authorName }]} />
	<ListingPageHeader slot="page-header" locale={locale} tagline={t('blog.byAuthor.tagline', 'Autor')} title={authorName} />
	<EmptyState locale={locale} variant="empty" message={t('blog.byAuthor.comingSoon', 'Funcionalidad en desarrollo. Volvé pronto.')} actionUrl={buildUrl({ locale, path: 'publicaciones' })} actionLabel={t('blog.byAuthor.viewAll', 'Ver todas las publicaciones')} />
</ListingLayout>
