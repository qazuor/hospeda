---
/**
 * @file publicaciones/categoria/[category]/index.astro
 * @description Posts filtered by category.
 * @route /{lang}/publicaciones/categoria/{category}/
 * @rendering SSR + ISR 24h
 */

import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/ListingPageHeader.astro';
import ArticleCard from '@/components/shared/ArticleCard.astro';
import EmptyState from '@/components/shared/EmptyState.astro';
import ErrorBanner from '@/components/shared/ErrorBanner.astro';
import Pagination from '@/components/shared/Pagination.astro';
import { postsApi } from '@/lib/api/endpoints';
import { toPostCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { category: catSlug } = Astro.params;

const VALID: Record<string, string> = {
	events: 'EVENTS', culture: 'CULTURE', gastronomy: 'GASTRONOMY', nature: 'NATURE',
	tourism: 'TOURISM', general: 'GENERAL', sport: 'SPORT', carnival: 'CARNIVAL',
	nightlife: 'NIGHTLIFE', history: 'HISTORY', traditions: 'TRADITIONS', wellness: 'WELLNESS',
	family: 'FAMILY', tips: 'TIPS', art: 'ART', beach: 'BEACH', rural: 'RURAL', festivals: 'FESTIVALS',
};

const catEnum = catSlug ? VALID[catSlug] : undefined;
if (!catEnum) return new Response(null, { status: 404 });

const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const result = await postsApi.list({ page, pageSize: 9, category: catEnum });
const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.total : 0;
const totalPages = result.ok ? Math.ceil(total / 9) : 0;
const cards = items.map((item) => toPostCardProps({ item: item as unknown as Record<string, unknown> }));
const catLabel = t(`blog.categories.${catSlug}`, catSlug ?? '');
const baseUrl = buildUrl({ locale, path: `publicaciones/categoria/${catSlug}` });
---

<ListingLayout locale={locale} title={`${catLabel} - ${t('blog.title', 'Publicaciones')}`} description={`Publicaciones de ${catLabel}`} showFilters={false}>
	<Breadcrumbs slot="breadcrumbs" locale={locale} items={[{ label: t('blog.title', 'Publicaciones'), path: 'publicaciones' }, { label: catLabel }]} />
	<ListingPageHeader slot="page-header" locale={locale} tagline={t('blog.byCategory.tagline', 'Categoría')} title={catLabel} totalCount={total} />

	{hasError && !result.ok && <ErrorBanner locale={locale} error={result.error} entityName="publicaciones" />}
	{!hasError && cards.length === 0 && <EmptyState locale={locale} variant="no-results" actionUrl={buildUrl({ locale, path: 'publicaciones' })} />}
	{!hasError && cards.length > 0 && (
		<div class="grid">
			{cards.map((card, i) => (<div data-reveal="up" style={`transition-delay: ${Math.min(i, 6) * 100}ms`}><ArticleCard data={card} locale={locale} /></div>))}
		</div>
	)}
	{totalPages > 1 && <Pagination slot="pagination" currentPage={page} totalPages={totalPages} baseUrl={baseUrl.slice(0, -1)} locale={locale} />}
</ListingLayout>

<style>
	.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-card-gap); }
	@media (max-width: 1024px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>
