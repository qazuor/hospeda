---
/**
 * @file publicaciones/categoria/[category]/index.astro
 * @description Posts filtered by category.
 * @route /{lang}/publicaciones/categoria/{category}/
 * @rendering SSR + ISR 24h
 */

import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import ArticleCard from '@/components/shared/cards/ArticleCard.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import Pagination from '@/components/shared/feedback/Pagination.astro';
import { postsApi } from '@/lib/api/endpoints';
import { toArticleCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { resolvePostCategorySlug } from '@/lib/post-category';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { category: catSlug } = Astro.params;
const isAuthenticated = Boolean(Astro.locals.user);

// Normalize the slug to lowercase so uppercase inbound URLs (e.g. /CULTURE/)
// resolve cleanly. The helper is case-insensitive internally.
const catEnum = resolvePostCategorySlug({ slug: catSlug });
if (!catEnum) return new Response(null, { status: 404 });

// Canonical lowercase slug for URLs and i18n key lookups.
const catSlugLower = catEnum.toLowerCase();

const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const result = await postsApi.list({ page, pageSize: 9, category: catEnum });
const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.pagination.total : 0;
const totalPages = result.ok ? result.data.pagination.totalPages : 0;
const cards = items.map((item) => toArticleCardProps({ item: item as unknown as Record<string, unknown>, locale }));
const catLabel = t(`blog.categories.${catSlugLower}`, catSlugLower);
const baseUrl = buildUrl({ locale, path: `publicaciones/categoria/${catSlugLower}` });
---

<ListingLayout locale={locale} title={`${catLabel} - ${t('blog.title', 'Publicaciones')}`} description={`Publicaciones de ${catLabel}`} showFilters={false} noindex={true}>
	<Breadcrumbs slot="breadcrumbs" locale={locale} items={[{ label: t('blog.title', 'Publicaciones'), path: 'publicaciones' }, { label: catLabel }]} />
	<ListingPageHeader slot="page-header" locale={locale} tagline={t('blog.byCategory.tagline', 'Categoría')} title={catLabel} totalCount={total} />

	{hasError && !result.ok && <ErrorBanner locale={locale} error={result.error} entityName="publicaciones" />}
	{!hasError && cards.length === 0 && <EmptyState locale={locale} variant="no-results" actionUrl={buildUrl({ locale, path: 'publicaciones' })} />}
	{!hasError && cards.length > 0 && (
		<div class="grid">
			{cards.map((card, i) => (<div data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100"><ArticleCard data={card} locale={locale} isAuthenticated={isAuthenticated} /></div>))}
		</div>
	)}
	{totalPages > 1 && <Pagination slot="pagination" currentPage={page} totalPages={totalPages} baseUrl={baseUrl.slice(0, -1)} locale={locale} />}
</ListingLayout>

<style>
	.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-card-gap); }
	@media (max-width: 1024px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>
