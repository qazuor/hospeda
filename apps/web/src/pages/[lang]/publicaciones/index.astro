---
/**
 * @file publicaciones/index.astro
 * @description Blog posts listing page with filter sidebar, ArticleCard grid,
 * and pagination.
 *
 * Rendering strategy: SSR + ISR 24h.
 * Pagination is URL-based (server-side), so there is NO client-side loading
 * state. Skeleton cards are shown only in the `hasError` branch as a visual
 * placeholder alongside the ErrorBanner — never as a JS loading indicator.
 *
 * EmptyState logic:
 *   - Filters active + empty list → "No encontramos publicaciones con esos filtros" + "Limpiar filtros" CTA
 *   - No filters + empty list    → "Aún no hay publicaciones disponibles" (no CTA)
 *
 * @route /{lang}/publicaciones/
 */

import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import ArticleCard from '@/components/shared/cards/ArticleCard.astro';
import ArticleCardSkeleton from '@/components/shared/cards/ArticleCardSkeleton.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import Pagination from '@/components/shared/feedback/Pagination.astro';
import TagChips from '@/components/TagChips.astro';
import { FilterSidebar } from '@/components/shared/filters/FilterSidebar.client';
import { postsApi } from '@/lib/api/endpoints';
import { toArticleCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);

const url = Astro.url;
const page = Math.max(1, Number(url.searchParams.get('page')) || 1);
const pageSize = 9;
const q = url.searchParams.get('q') ?? undefined;
const category = url.searchParams.get('category') ?? undefined;
const sortBy = url.searchParams.get('sortBy') ?? 'publishedAt';
// SPEC-098 T-052b — `mostSaved` defaults to descending so posts with
// the most active bookmarks appear first. Other fields keep their existing
// `desc` default (newest-first for `publishedAt`).
const sortOrder = (url.searchParams.get('sortOrder') as 'asc' | 'desc') ?? 'desc';

const result = await postsApi.list({ page, pageSize, q, category, sortBy, sortOrder });

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.pagination.total : 0;
const totalPages = result.ok ? result.data.pagination.totalPages : 0;
const cards = items.map((item) => toArticleCardProps({ item: item as unknown as Record<string, unknown> }));

/**
 * Detect whether any non-default filters are active. Used to choose between
 * the two empty-state variants (with-filters vs. no-filters).
 * Checked against: q, category, sortBy (non-default), page > 1.
 */
const DEFAULT_SORT = 'publishedAt';
const hasActiveFilters =
	Boolean(q) ||
	Boolean(category) ||
	(sortBy !== DEFAULT_SORT) ||
	page > 1;

/** Canonical URL for this listing (no query params) — used as "clear filters" target. */
const baseUrl = buildUrl({ locale, path: 'publicaciones' });

const filterGroups = [
	{
		id: 'q',
		label: t('blog.filters.search', 'Buscar'),
		type: 'search' as const,
	},
	{
		id: 'category',
		label: t('blog.filters.category', 'Categoría'),
		type: 'checkbox' as const,
		options: [
			{ value: 'CULTURE', label: t('blog.categories.culture', 'Cultura') },
			{ value: 'GASTRONOMY', label: t('blog.categories.gastronomy', 'Gastronomía') },
			{ value: 'NATURE', label: t('blog.categories.nature', 'Naturaleza') },
			{ value: 'TOURISM', label: t('blog.categories.tourism', 'Turismo') },
			{ value: 'SPORT', label: t('blog.categories.sport', 'Deporte') },
			{ value: 'HISTORY', label: t('blog.categories.history', 'Historia') },
			{ value: 'EVENTS', label: t('blog.categories.events', 'Eventos') },
			{ value: 'CARNIVAL', label: t('blog.categories.carnival', 'Carnaval') },
			{ value: 'WELLNESS', label: t('blog.categories.wellness', 'Bienestar') },
			{ value: 'FAMILY', label: t('blog.categories.family', 'Familia') },
			{ value: 'TIPS', label: t('blog.categories.tips', 'Consejos') },
		],
	},
] as const;

const sortOptions = [
	{ value: 'publishedAt', label: t('blog.sort.newest', 'Más recientes') },
	{ value: 'title', label: t('blog.sort.title', 'Título') },
	// SPEC-098 T-052b — orders by total active bookmarks (descending) via the
	// `mostSaved` synthetic sort field on the public post list endpoint.
	{ value: 'mostSaved', label: t('ui.sort.most_bookmarked', 'Más guardados') },
] as const;

/** Quick-filter chips: top post categories */
const postCategoryChips = [
    { label: t('blog.categories.culture', 'Cultura'), href: buildUrl({ locale, path: '/publicaciones/categoria/CULTURE/' }) },
    { label: t('blog.categories.gastronomy', 'Gastronomía'), href: buildUrl({ locale, path: '/publicaciones/categoria/GASTRONOMY/' }) },
    { label: t('blog.categories.nature', 'Naturaleza'), href: buildUrl({ locale, path: '/publicaciones/categoria/NATURE/' }) },
    { label: t('blog.categories.tourism', 'Turismo'), href: buildUrl({ locale, path: '/publicaciones/categoria/TOURISM/' }) },
    { label: t('blog.categories.history', 'Historia'), href: buildUrl({ locale, path: '/publicaciones/categoria/HISTORY/' }) },
    { label: t('blog.categories.events', 'Eventos'), href: buildUrl({ locale, path: '/publicaciones/categoria/EVENTS/' }) },
    { label: t('blog.categories.carnival', 'Carnaval'), href: buildUrl({ locale, path: '/publicaciones/categoria/CARNIVAL/' }) },
    { label: t('blog.categories.tips', 'Consejos'), href: buildUrl({ locale, path: '/publicaciones/categoria/TIPS/' }) },
] as const;
---

<ListingLayout
	locale={locale}
	title={t('blog.title', 'Publicaciones')}
	description={t('blog.description', 'Artículos sobre cultura, gastronomía, turismo y más del Litoral Entrerriano.')}
	showFilters={true}
	filterPosition="left"
>
	<Breadcrumbs
		slot="breadcrumbs"
		locale={locale}
		items={[{ label: t('blog.title', 'Publicaciones') }]}
	/>

	<ListingPageHeader
		slot="page-header"
		locale={locale}
		tagline={t('blog.tagline', 'Descubrí historias')}
		title={t('blog.title', 'Publicaciones')}
		totalCount={total}
	/>

	<FilterSidebar
		slot="filters"
		client:load
		locale={locale}
		filters={filterGroups}
		sortOptions={sortOptions}
		defaultSort="publishedAt"
	/>

	<TagChips
		chips={postCategoryChips}
		ariaLabel={t('blog.categoryChips.ariaLabel', 'Filtrar por categoría de publicación')}
	/>

	{/* API error: show skeleton grid as visual placeholder alongside ErrorBanner.
	    This is the ONLY place skeletons appear — there is no client-side loading
	    state because pagination is URL-based (server-side renders each page). */}
	{hasError && (
		<>
			<ErrorBanner locale={locale} error={result.error} entityName="publicaciones" />
			<div class="posts-grid" aria-hidden="true">
				{Array.from({ length: pageSize }).map(() => (
					<ArticleCardSkeleton />
				))}
			</div>
		</>
	)}

	{/* Empty state — no API error, but no results */}
	{!hasError && cards.length === 0 && hasActiveFilters && (
		<EmptyState
			locale={locale}
			variant="no-results"
			message={t('blog.empty.withFilters.title', 'No encontramos publicaciones con esos filtros')}
			actionUrl={baseUrl}
			actionLabel={t('blog.empty.withFilters.cta', 'Limpiar filtros')}
		/>
	)}

	{!hasError && cards.length === 0 && !hasActiveFilters && (
		<EmptyState
			locale={locale}
			variant="empty"
			message={t('blog.empty.noFilters.title', 'Aún no hay publicaciones disponibles')}
		/>
	)}

	{!hasError && cards.length > 0 && (
		<div class="posts-grid">
			{cards.map((card, i) => (
				<div data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
					<ArticleCard data={card} locale={locale} />
				</div>
			))}
		</div>
	)}

	{totalPages > 1 && (
		<Pagination slot="pagination" currentPage={page} totalPages={totalPages} baseUrl={baseUrl.slice(0, -1)} locale={locale} />
	)}
</ListingLayout>

<style>
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-card-gap);
	}

	@media (max-width: 1024px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 640px)  { .posts-grid { grid-template-columns: 1fr; } }
</style>
