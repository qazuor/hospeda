---
/**
 * Blog list page - displays all blog posts with category filters.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import SectionTitle from '../../../components/ui/SectionTitle.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import PostErrorState from '../../../components/error/PostErrorState.astro';
import Pagination from '../../../components/ui/Pagination.astro';
import BlogPostCard from '../../../components/blog/BlogPostCard.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { postsApi } from '../../../lib/api/endpoints';
import { toPostCardProps } from '../../../lib/api/transforms';
import { t } from '../../../lib/i18n';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Localized labels from i18n
 */
const pageTitle = t({ locale, namespace: 'blog', key: 'listPage.title' });
const pageDescription = t({ locale, namespace: 'blog', key: 'listPage.description' });
const heroHeading = t({ locale, namespace: 'blog', key: 'listPage.heroHeading' });
const heroDescription = t({ locale, namespace: 'blog', key: 'listPage.heroDescription' });
const featuredTitle = t({ locale, namespace: 'blog', key: 'listPage.featuredTitle' });
const emptyStateText = t({ locale, namespace: 'blog', key: 'listPage.emptyState' });
const catAll = t({ locale, namespace: 'blog', key: 'listPage.categories.all' });
const catDestinations = t({ locale, namespace: 'blog', key: 'listPage.categories.destinations' });
const catAccommodations = t({ locale, namespace: 'blog', key: 'listPage.categories.accommodations' });
const catEvents = t({ locale, namespace: 'blog', key: 'listPage.categories.events' });
const catGastronomy = t({ locale, namespace: 'blog', key: 'listPage.categories.gastronomy' });
const catTips = t({ locale, namespace: 'blog', key: 'listPage.categories.tips' });

/**
 * Get query parameters from URL
 */
const url = new URL(Astro.request.url);
const q = url.searchParams.get('q') || '';
const page = Number.parseInt(url.searchParams.get('page') || '1', 10);
const pageSize = 12;
const sortBy = url.searchParams.get('sortBy') || 'createdAt';
const sortOrder = (url.searchParams.get('sortOrder') || 'desc') as 'asc' | 'desc';
const category = url.searchParams.get('categoria') || '';

/**
 * Fetch posts from API
 */
const apiResult = await postsApi.list({ page, pageSize, q, sortBy, sortOrder, category: category || undefined });

const apiError = !apiResult.ok;
const posts = apiResult.ok ? apiResult.data.items : [];
const pagination = apiResult.ok ? apiResult.data.pagination : null;

/**
 * Get featured post
 */
const featuredResult = await postsApi.getFeatured();
const featuredPostRaw = featuredResult.ok && featuredResult.data.items.length > 0 ? featuredResult.data.items[0] as Record<string, unknown> : null;
const featuredPost = featuredPostRaw ? toPostCardProps({ item: featuredPostRaw }) : null;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: pageTitle, href: `/${locale}/publicaciones/` },
];

const postCards = posts.map((post) =>
	toPostCardProps({ item: post as Record<string, unknown> })
);
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={pageDescription}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- Hero Section -->
				<article id="hero" class="mb-12 text-center">
					<SectionTitle as="h1" class="mb-6">
						{heroHeading}
					</SectionTitle>
					<p class="mx-auto max-w-3xl text-xl leading-relaxed text-text-secondary">
						{heroDescription}
					</p>
				</article>

				<!-- Featured Post Area -->
				{
					featuredPost && (
						<article id="featured-post" class="mb-12">
							<SectionTitle as="h2" size="1.5rem" weight="semibold" class="mb-6">
								{featuredTitle}
							</SectionTitle>

							<div class="rounded-lg border border-border bg-bg p-8 shadow-sm transition-shadow hover:shadow-md">
								<div class="grid gap-8 md:grid-cols-2">
									{/* Featured Image */}
									{featuredPost.featuredImage && (
										<div class="aspect-video rounded-md overflow-hidden">
											<img
												src={featuredPost.featuredImage}
												alt={featuredPost.title || 'Featured post'}
												class="h-full w-full object-cover"
												loading="eager"
											/>
										</div>
									)}

									{/* Post Content */}
									<div class="flex flex-col justify-between">
										<div>
											{featuredPost.category && (
												<div class="mb-3">
													<span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">
														{featuredPost.category}
													</span>
												</div>
											)}
											<h3 class="mb-3 text-2xl font-bold text-text-primary">
												<a href={`/${locale}/publicaciones/${featuredPost.slug}/`} class="hover:text-primary">
													{featuredPost.title || 'Publicación destacada'}
												</a>
											</h3>
											<p class="mb-4 text-text-secondary line-clamp-3">
												{featuredPost.summary || featuredPost.content || ''}
											</p>
											{featuredPost.publishedAt && (
												<time datetime={featuredPost.publishedAt} class="text-sm text-text-tertiary">
													{new Date(featuredPost.publishedAt).toLocaleDateString(locale)}
												</time>
											)}
										</div>
									</div>
								</div>
							</div>
						</article>
					)
				}

				<!-- Category Filter -->
				<article id="category-filter" class="mb-12">
					<nav aria-label="Category filter">
						<div class="flex flex-wrap justify-center gap-3">
							<a
								href={`/${locale}/publicaciones/`}
								class={
									!category
										? 'rounded-full border border-primary bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
										: 'rounded-full border border-border bg-bg px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:border-primary hover:bg-primary/5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
								}
								aria-current={!category ? 'page' : undefined}
							>
								{catAll}
							</a>
							<a
								href={`/${locale}/publicaciones/?categoria=destinos`}
								class={
									category === 'destinos'
										? 'rounded-full border border-primary bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
										: 'rounded-full border border-border bg-bg px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:border-primary hover:bg-primary/5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
								}
								aria-current={category === 'destinos' ? 'page' : undefined}
							>
								{catDestinations}
							</a>
							<a
								href={`/${locale}/publicaciones/?categoria=alojamientos`}
								class={
									category === 'alojamientos'
										? 'rounded-full border border-primary bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
										: 'rounded-full border border-border bg-bg px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:border-primary hover:bg-primary/5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
								}
								aria-current={category === 'alojamientos' ? 'page' : undefined}
							>
								{catAccommodations}
							</a>
							<a
								href={`/${locale}/publicaciones/?categoria=eventos`}
								class={
									category === 'eventos'
										? 'rounded-full border border-primary bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
										: 'rounded-full border border-border bg-bg px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:border-primary hover:bg-primary/5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
								}
								aria-current={category === 'eventos' ? 'page' : undefined}
							>
								{catEvents}
							</a>
							<a
								href={`/${locale}/publicaciones/?categoria=gastronomia`}
								class={
									category === 'gastronomia'
										? 'rounded-full border border-primary bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
										: 'rounded-full border border-border bg-bg px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:border-primary hover:bg-primary/5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
								}
								aria-current={category === 'gastronomia' ? 'page' : undefined}
							>
								{catGastronomy}
							</a>
							<a
								href={`/${locale}/publicaciones/?categoria=consejos`}
								class={
									category === 'consejos'
										? 'rounded-full border border-primary bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
										: 'rounded-full border border-border bg-bg px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:border-primary hover:bg-primary/5 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2'
								}
								aria-current={category === 'consejos' ? 'page' : undefined}
							>
								{catTips}
							</a>
						</div>
					</nav>
				</article>

				<!-- Posts Grid -->
				<article id="posts-grid" class="mb-16">
					{
						postCards.length > 0 ? (
							<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="region" aria-label="Blog posts">
								{postCards.map((post) => (
									<BlogPostCard
										post={post}
										locale={locale}
									/>
								))}
							</div>
						) : apiError ? (
							<PostErrorState locale={locale} />
						) : (
							<EmptyState title={emptyStateText} message={emptyStateText} />
						)
					}
				</article>

				<!-- Pagination -->
				{pagination && (
					<Pagination
						currentPage={pagination.page}
						totalPages={pagination.totalPages}
						baseUrl={`/${locale}/publicaciones`}
						locale={locale}
					/>
				)}
			</div>
		</Section>
	</Container>
</BaseLayout>
