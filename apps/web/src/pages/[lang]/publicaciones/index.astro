---
/**
 * @file publicaciones/index.astro
 * @description Blog list page. Displays all blog posts with hero section,
 * featured post, category filter links, post grid, and pagination.
 *
 * Rendering: SSR (server-rendered on demand) with locale validation.
 * Query params: `page`, `q`, `sortBy`, `sortOrder`, `categoria`.
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import BackgroundPattern from '../../../components/shared/BackgroundPattern.astro';
import DecorativeElement from '../../../components/shared/DecorativeElement.astro';
import EmptyState from '../../../components/shared/EmptyState.astro';
import Pagination from '../../../components/shared/Pagination.astro';
import FeaturedArticleCard from '../../../components/shared/FeaturedArticleCard.astro';
import SecondaryArticleCard from '../../../components/shared/SecondaryArticleCard.astro';
import { createT } from '../../../lib/i18n';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { buildUrl, buildUrlWithParams } from '../../../lib/urls';
import { postsApi } from '../../../lib/api/endpoints';
import { toPostCardProps } from '../../../lib/api/transforms';
import type { SupportedLocale } from '../../../lib/i18n';

/** Validate and extract locale from route params. Redirect on invalid locale. */
const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/publicaciones/');

const t = createT(locale as SupportedLocale);

// --- Translations ---
const pageTitle       = t('blog.listPage.title',       'Publicaciones');
const pageDescription = t('blog.listPage.description', 'Articulos, guias y consejos sobre el Litoral argentino');
const heroHeading     = t('blog.listPage.heroHeading', 'Blog y Publicaciones');
const heroDescription = t('blog.listPage.heroDescription', 'Descubri articulos, guias de viaje y consejos para explorar el Litoral argentino');
const featuredLabel   = t('blog.listPage.featuredTitle', 'Articulo Destacado');
const emptyTitle      = t('blog.listPage.emptyState',    'No se encontraron publicaciones');
const emptyMessage    = t('blog.listPage.emptyMessage',  'Intenta con otra busqueda o categoria');
const catAll            = t('blog.listPage.categories.all',            'Todas');
const catDestinations   = t('blog.listPage.categories.destinations',   'Destinos');
const catAccommodations = t('blog.listPage.categories.accommodations', 'Alojamientos');
const catEvents         = t('blog.listPage.categories.events',         'Eventos');
const catGastronomy     = t('blog.listPage.categories.gastronomy',     'Gastronomia');
const catTips           = t('blog.listPage.categories.tips',           'Consejos');
const allPostsLabel     = t('blog.listPage.allPostsTitle', 'Todas las publicaciones');

// --- Query params ---
const url       = new URL(Astro.request.url);
const q         = url.searchParams.get('q') || '';
const page      = Math.max(1, Number.parseInt(url.searchParams.get('page') || '1', 10));
const pageSize  = 9;
const sortBy    = url.searchParams.get('sortBy') || 'createdAt';
const sortOrder = (url.searchParams.get('sortOrder') || 'desc') as 'asc' | 'desc';
const category  = url.searchParams.get('categoria') || '';

// --- API calls ---
const [apiResult, featuredResult] = await Promise.all([
    postsApi.list({ page, pageSize, q, sortBy, sortOrder, category: category || undefined }),
    postsApi.getFeatured()
]);

const apiError   = !apiResult.ok;
const posts      = apiResult.ok ? apiResult.data.items : [];
const pagination = apiResult.ok ? apiResult.data.pagination : null;

const featuredRaw  = featuredResult.ok && featuredResult.data.items.length > 0
    ? featuredResult.data.items[0] as Record<string, unknown>
    : null;
const featuredPost = featuredRaw ? toPostCardProps({ item: featuredRaw }) : null;

const postCards = posts.map((post) => toPostCardProps({ item: post as Record<string, unknown> }));

// --- Canonical URL ---
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// --- Breadcrumb ---
const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale as SupportedLocale], href: buildUrl({ locale: locale as SupportedLocale }) },
    { label: pageTitle, href: buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' }) }
] as const;

// --- Category filter config ---

interface CategoryLink {
    readonly slug: string;
    readonly label: string;
}

const categories: readonly CategoryLink[] = [
    { slug: '',            label: catAll },
    { slug: 'destinos',    label: catDestinations },
    { slug: 'alojamientos', label: catAccommodations },
    { slug: 'eventos',     label: catEvents },
    { slug: 'gastronomia', label: catGastronomy },
    { slug: 'consejos',    label: catTips }
] as const;

/**
 * Build the href for a category filter link.
 * Uses the base blog URL for "all", or appends `?categoria=slug` for specific categories.
 */
function buildCategoryUrl(slug: string): string {
    const base = buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' });
    return slug
        ? buildUrlWithParams({ locale: locale as SupportedLocale, path: 'publicaciones', params: { categoria: slug } })
        : base;
}

/** Pagination search params for query-param mode (preserves active category). */
const paginationParams = new URLSearchParams();
if (category) paginationParams.set('categoria', category);
if (q) paginationParams.set('q', q);
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    locale={locale}
>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale as SupportedLocale}
        type="website"
    />

    <div class="container mx-auto max-w-6xl px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />

        {/* Hero section */}
        <section aria-labelledby="blog-hero-heading" class="relative mb-12 mt-4 overflow-hidden rounded-xl py-8 text-center">
            <BackgroundPattern pattern="/images/patterns/pattern-grid.svg" size="60px 60px" opacity="opacity-30" />
            <DecorativeElement src="/images/decoratives/deco-brujula.svg" position="top-3 left-4 md:left-12" size="w-14 md:w-18" opacity="opacity-50" />
            <DecorativeElement src="/images/decoratives/deco-ruta-punteada.svg" position="bottom-2 right-4 md:right-10" size="w-20 md:w-28" opacity="opacity-40" />
            <div class="relative">
                <h1
                    id="blog-hero-heading"
                    class="mb-4 text-4xl font-bold tracking-tight text-foreground md:text-5xl"
                >
                    {heroHeading}
                </h1>
                <p class="mx-auto max-w-2xl text-lg leading-relaxed text-muted-foreground">
                    {heroDescription}
                </p>
            </div>
        </section>

        {/* Featured post */}
        {featuredPost && (
            <section aria-labelledby="featured-post-heading" class="scroll-reveal-left mb-12">
                <h2
                    id="featured-post-heading"
                    class="mb-6 text-xl font-semibold text-foreground"
                >
                    {featuredLabel}
                </h2>
                <div class="grid gap-8 lg:grid-cols-12 lg:gap-10">
                    <FeaturedArticleCard article={featuredPost} locale={locale} />
                </div>
            </section>
        )}

        {/* Category filter */}
        <nav aria-label={t('blog.listPage.categoryFilterLabel', 'Filtrar por categoria')} class="mb-10">
            <ul class="flex flex-wrap justify-center gap-2" role="list">
                {categories.map((cat) => {
                    const isActive = cat.slug === category;
                    return (
                        <li>
                            <a
                                href={buildCategoryUrl(cat.slug)}
                                aria-current={isActive ? 'page' : undefined}
                                class:list={[
                                    'inline-block rounded-full border px-4 py-2 text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary',
                                    isActive
                                        ? 'border-primary bg-primary text-primary-foreground'
                                        : 'border-border bg-card text-foreground hover:border-primary hover:bg-primary/5 hover:text-primary'
                                ]}
                            >
                                {cat.label}
                            </a>
                        </li>
                    );
                })}
            </ul>
        </nav>

        {/* Posts grid */}
        <section aria-labelledby="posts-section-heading" class="scroll-reveal mb-16">
            <h2 id="posts-section-heading" class="mb-6 text-xl font-semibold text-foreground">
                {allPostsLabel}
            </h2>

            {apiError ? (
                <EmptyState
                    title={t('blog.listPage.errorTitle', 'Error al cargar publicaciones')}
                    message={t('blog.listPage.errorMessage', 'No se pudieron cargar las publicaciones. Por favor intenta de nuevo.')}
                    cta={{
                        label: t('blog.listPage.retryLabel', 'Reintentar'),
                        href: buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' })
                    }}
                />
            ) : postCards.length === 0 ? (
                <EmptyState
                    title={emptyTitle}
                    message={emptyMessage}
                    cta={{
                        label: t('blog.listPage.viewAllLabel', 'Ver todas'),
                        href: buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' })
                    }}
                />
            ) : (
                <div class="grid gap-8 lg:grid-cols-12 lg:gap-10">
                    {/* First post: featured (large) layout */}
                    {postCards[0] && (
                        <FeaturedArticleCard article={postCards[0]} locale={locale} />
                    )}

                    {/* Remaining posts: secondary (compact) layout in a stacked column */}
                    {postCards.length > 1 && (
                        <div class="flex flex-col gap-6 lg:col-span-5">
                            {postCards.slice(1).map((post) => (
                                <SecondaryArticleCard article={post} locale={locale} />
                            ))}
                        </div>
                    )}
                </div>
            )}
        </section>

        {/* Pagination */}
        {pagination && pagination.totalPages > 1 && (
            <Pagination
                currentPage={pagination.page}
                totalPages={pagination.totalPages}
                baseUrl={buildUrl({ locale: locale as SupportedLocale, path: 'publicaciones' }).replace(/\/$/, '')}
                locale={locale as SupportedLocale}
                searchParams={paginationParams.toString() ? paginationParams : undefined}
            />
        )}
    </div>
</BaseLayout>
