---
/**
 * @file publicaciones/index.astro
 * @description Blog posts listing page with filter sidebar, ArticleCard grid,
 * and pagination.
 *
 * URL params:
 * - page             — pagination (default: 1)
 * - q                — full-text search (matches title + content via PostService.getSearchableColumns)
 * - category         — post category enum value
 * - sortBy           — encoded sort key, see SORT_OPTION_MAP below
 *                      (newest | oldest | mostSaved | featured | titleAsc | titleDesc).
 *                      Direction lives inside the key, so no separate `sortOrder` param.
 * - isFeatured       — boolean: only featured posts
 * - destinationId    — filter by destination UUID (server maps to relatedDestinationId)
 * - publishedAfter   — ISO yyyy-mm-dd lower bound on `publishedAt`
 * - publishedBefore  — ISO yyyy-mm-dd upper bound on `publishedAt`
 *
 * Rendering strategy: SSR + ISR 24h.
 * Pagination is URL-based (server-side), so there is NO client-side loading
 * state. Skeleton cards are shown only in the `hasError` branch as a visual
 * placeholder alongside the ErrorBanner — never as a JS loading indicator.
 *
 * EmptyState logic:
 *   - Filters active + empty list → "No encontramos publicaciones con esos filtros" + "Limpiar filtros" CTA
 *   - No filters + empty list    → "Aún no hay publicaciones disponibles" (no CTA)
 *
 * @route /{lang}/publicaciones/
 */

import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import ContributionBanner from '@/components/contributions/ContributionBanner.astro';
import ArticleCard from '@/components/shared/cards/ArticleCard.astro';
import ArticleCardSkeleton from '@/components/shared/cards/ArticleCardSkeleton.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import Pagination from '@/components/shared/feedback/Pagination.astro';
import ItemListJsonLd from '@/components/seo/ItemListJsonLd.astro';
import TagChips from '@/components/TagChips.astro';
import { FilterSidebar } from '@/components/shared/filters/FilterSidebar.client';
import {
    buildPostListingSummary,
    DEFAULT_POST_CATEGORIES
} from '@/lib/post-listing-summary';
import { destinationsApi, postsApi } from '@/lib/api/endpoints';
import { toArticleCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);

// Auth flag forwarded to ArticleCard so the FavoriteButton picks the
// toggle-favorite flow instead of the guest auth-required popover.
const isAuthenticated = Boolean(Astro.locals.user);

const url = Astro.url;
const page = Math.max(1, Number(url.searchParams.get('page')) || 1);
const pageSize = 9;
const q = url.searchParams.get('q') ?? undefined;
const category = url.searchParams.get('category') ?? undefined;

/**
 * Maps the URL's user-friendly sort key (e.g. `newest`, `mostSaved`) to the
 * backend `(sortBy, sortOrder)` pair. Encoding direction in the key lets the
 * UI offer pre-baked options like "Recién publicadas" / "Más antiguas" without
 * exposing a separate direction toggle.
 *
 * All sortBy fields here must be whitelisted in
 * `apps/api/src/routes/post/public/list.ts > ALLOWED_SORT_FIELDS`. `mostSaved`
 * is a synthetic field backed by a correlated subquery on `user_bookmarks`
 * handled by `PostModel.findAll` override (SPEC-098 T-052b).
 */
const SORT_OPTION_MAP: Record<string, { sortBy: string; sortOrder: 'asc' | 'desc' }> = {
    newest:    { sortBy: 'publishedAt', sortOrder: 'desc' },
    oldest:    { sortBy: 'publishedAt', sortOrder: 'asc'  },
    mostSaved: { sortBy: 'mostSaved',   sortOrder: 'desc' },
    featured:  { sortBy: 'isFeatured',  sortOrder: 'desc' },
    titleAsc:  { sortBy: 'title',       sortOrder: 'asc'  },
    titleDesc: { sortBy: 'title',       sortOrder: 'desc' }
};
/** Default sort key — used when the URL has no `sortBy`. */
const DEFAULT_SORT_KEY = 'newest';

const sortKey = url.searchParams.get('sortBy') ?? DEFAULT_SORT_KEY;
const sortResolved = SORT_OPTION_MAP[sortKey] ?? SORT_OPTION_MAP[DEFAULT_SORT_KEY];

/** Parse the new sidebar filters from URL. */
const isFeaturedParam = url.searchParams.get('isFeatured');
const isFeatured: boolean | undefined =
    isFeaturedParam === 'true' ? true : undefined;
const destinationId = url.searchParams.get('destinationId') ?? undefined;
const publishedAfterFilter = url.searchParams.get('publishedAfter') ?? undefined;
const publishedBeforeFilter = url.searchParams.get('publishedBefore') ?? undefined;

/**
 * Fetch destinations once for the sidebar's location filter. Filter to CITY
 * type only — listings show posts by city, not by country/region/department.
 * Capped at 100 — sufficient for the current scope; revisit if the catalog
 * grows past that.
 */
const destinationsResult = await destinationsApi.list({
    destinationType: 'CITY',
    pageSize: 100
});
const destinations = destinationsResult.ok ? destinationsResult.data.items : [];

/**
 * The sidebar date-range emits ISO `YYYY-MM-DD` strings. Widen the bounds to
 * cover the full local day so the inclusive lower bound starts at midnight
 * and the inclusive upper bound ends at 23:59:59.
 */
const publishedAfter = publishedAfterFilter ? `${publishedAfterFilter}T00:00:00` : undefined;
const publishedBefore = publishedBeforeFilter ? `${publishedBeforeFilter}T23:59:59` : undefined;

const result = await postsApi.list({
    page,
    pageSize,
    q,
    category,
    sortBy: sortResolved.sortBy,
    sortOrder: sortResolved.sortOrder,
    isFeatured: isFeatured ?? undefined,
    destinationId,
    publishedAfter,
    publishedBefore
});

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.pagination.total : 0;
const totalPages = result.ok ? result.data.pagination.totalPages : 0;
const cards = items.map((item) => toArticleCardProps({ item: item as unknown as Record<string, unknown> }));

/**
 * Build a human-readable summary like "Mostrando 3 de 4 publicaciones..." to
 * replace the generic "N resultados encontrados" line in the wave header.
 * Mirrors the events pattern via the parallel `post-listing-summary` module.
 */
const summaryLocale: 'es' | 'en' = locale === 'pt' ? 'es' : locale;
const destinationCatalog = destinations.map((d) => ({
    key: d.id,
    label: { es: d.name, en: d.name } as const
}));
const filterSummary = buildPostListingSummary({
    locale: summaryLocale,
    filters: {
        text: q,
        category,
        destinationId,
        publishedAfter: publishedAfterFilter,
        publishedBefore: publishedBeforeFilter,
        isFeatured
    },
    counts: { shown: cards.length, total },
    sort: { sortKey },
    catalogs: {
        destinations: destinationCatalog,
        categories: DEFAULT_POST_CATEGORIES
    }
});

/**
 * Detect whether any non-default filters are active. Used to choose between
 * the two empty-state variants (with-filters vs. no-filters).
 */
const hasActiveFilters =
    Boolean(q) ||
    Boolean(category) ||
    isFeatured === true ||
    Boolean(destinationId) ||
    Boolean(publishedAfterFilter) ||
    Boolean(publishedBeforeFilter) ||
    sortKey !== DEFAULT_SORT_KEY ||
    page > 1;

/** Canonical URL for this listing (no query params) — used as "clear filters" target. */
const baseUrl = buildUrl({ locale, path: 'publicaciones' });

// Self-canonical for paginated pages (SPEC-157 follow-up). Pages 2+ are served
// at `/{locale}/publicaciones/page/{n}/` via an Astro.rewrite to this listing
// with `?page=n`; the rewrite drops the `/page/n/` segment from
// Astro.url.pathname, so we rebuild the crawlable URL from the page number to
// keep each paginated page self-canonical and indexable (not canonicalized to
// page 1).
const canonicalPath = page > 1 ? `${baseUrl}page/${page}/` : baseUrl;

/**
 * Build the `filterGroups` config for FilterSidebar.
 * Order matches the approved UX: search → featured toggle → category → date range → destination.
 */
const filterGroups = [
    {
        id: 'q',
        label: t('blog.filters.search', 'Buscar'),
        type: 'search' as const
    },
    {
        id: 'isFeatured',
        label: t('blog.filters.featured', 'Solo destacadas'),
        type: 'toggle' as const
    },
    {
        id: 'category',
        label: t('blog.filters.category', 'Categoría'),
        type: 'checkbox' as const,
        options: [
            { value: 'CULTURE',      label: t('blog.categories.culture',      'Cultura') },
            { value: 'GASTRONOMY',   label: t('blog.categories.gastronomy',   'Gastronomía') },
            { value: 'NATURE',       label: t('blog.categories.nature',       'Naturaleza') },
            { value: 'TOURISM',      label: t('blog.categories.tourism',      'Turismo') },
            { value: 'SPORT',        label: t('blog.categories.sport',        'Deporte') },
            { value: 'HISTORY',      label: t('blog.categories.history',      'Historia') },
            { value: 'EVENTS',       label: t('blog.categories.events',       'Eventos') },
            { value: 'CARNIVAL',     label: t('blog.categories.carnival',     'Carnaval') },
            { value: 'WELLNESS',     label: t('blog.categories.wellness',     'Bienestar') },
            { value: 'FAMILY',       label: t('blog.categories.family',       'Familia') },
            { value: 'TIPS',         label: t('blog.categories.tips',         'Consejos') },
            { value: 'NIGHTLIFE',    label: t('blog.categories.nightlife',    'Noche') },
            { value: 'TRADITIONS',   label: t('blog.categories.traditions',   'Tradiciones') },
            { value: 'ART',          label: t('blog.categories.art',          'Arte') },
            { value: 'BEACH',        label: t('blog.categories.beach',        'Playa') },
            { value: 'RURAL',        label: t('blog.categories.rural',        'Rural') },
            { value: 'FESTIVALS',    label: t('blog.categories.festivals',    'Festivales') },
            { value: 'GENERAL',      label: t('blog.categories.general',      'General') }
        ]
    },
    {
        id: 'date',
        label: t('blog.filters.publishedDate', 'Fecha de publicación'),
        type: 'date-range' as const,
        checkInPlaceholder: t('blog.filters.publishedFrom', 'Desde'),
        checkOutPlaceholder: t('blog.filters.publishedTo', 'Hasta'),
        fromParam: 'publishedAfter',
        toParam: 'publishedBefore',
        mode: 'bounds' as const,
        allowPastDates: true
    },
    {
        id: 'destinationId',
        label: t('blog.filters.location', 'Destino'),
        type: 'select-search' as const,
        options: destinations.map((d) => ({ value: d.id, label: d.name, featured: Boolean(d.isFeatured) })),
        maxVisible: 8,
        maxSelections: 1
    }
] as const;

const sortOptions = [
    { value: 'newest',    label: t('blog.sort.newest',    'Recién publicadas') },
    { value: 'oldest',    label: t('blog.sort.oldest',    'Más antiguas') },
    { value: 'mostSaved', label: t('blog.sort.mostSaved', 'Más guardadas') },
    { value: 'featured',  label: t('blog.sort.featured',  'Destacadas primero') },
    { value: 'titleAsc',  label: t('blog.sort.titleAsc',  'Título (A-Z)') },
    { value: 'titleDesc', label: t('blog.sort.titleDesc', 'Título (Z-A)') }
] as const;

/**
 * Build the `initialParams` record for FilterSidebar so server-rendered state
 * matches the URL on first paint (avoids hydration flash). Keys match the URL
 * param names emitted by FilterSidebar's reducer.
 */
const sidebarInitialParams: Record<string, string> = {};
if (q)                          sidebarInitialParams['q'] = q;
if (category)                   sidebarInitialParams['category'] = category;
if (isFeaturedParam === 'true') sidebarInitialParams['isFeatured'] = 'true';
if (destinationId)              sidebarInitialParams['destinationId'] = destinationId;
if (publishedAfterFilter)       sidebarInitialParams['publishedAfter'] = publishedAfterFilter;
if (publishedBeforeFilter)      sidebarInitialParams['publishedBefore'] = publishedBeforeFilter;
sidebarInitialParams['sortBy']  = sortKey;

/**
 * Build URLSearchParams to pass to Pagination so it preserves all active
 * filters across page navigations.
 */
const paginationParams = new URLSearchParams(url.searchParams);
paginationParams.delete('page');

// ItemList JSON-LD entries — the visible page of article cards. ArticleCardData
// exposes `title` (not `name`); route through the reusable ItemListJsonLd
// component (SPEC-157 D-1 canonical JSON-LD path).
const itemListEntries = cards.map((card) => ({
    url: new URL(buildUrl({ locale, path: `publicaciones/${card.slug}` }), Astro.site ?? Astro.url.origin).href,
    name: card.title,
}));

/** Quick-filter chips: top post categories. Hrefs use lowercase slugs consistent
 * with the [category] route which normalises incoming slugs via resolvePostCategorySlug. */
const postCategoryChips = [
    { label: t('blog.categories.culture',    'Cultura'),     href: buildUrl({ locale, path: '/publicaciones/categoria/culture/' }) },
    { label: t('blog.categories.gastronomy', 'Gastronomía'), href: buildUrl({ locale, path: '/publicaciones/categoria/gastronomy/' }) },
    { label: t('blog.categories.nature',     'Naturaleza'),  href: buildUrl({ locale, path: '/publicaciones/categoria/nature/' }) },
    { label: t('blog.categories.tourism',    'Turismo'),     href: buildUrl({ locale, path: '/publicaciones/categoria/tourism/' }) },
    { label: t('blog.categories.history',    'Historia'),    href: buildUrl({ locale, path: '/publicaciones/categoria/history/' }) },
    { label: t('blog.categories.events',     'Eventos'),     href: buildUrl({ locale, path: '/publicaciones/categoria/events/' }) },
    { label: t('blog.categories.carnival',   'Carnaval'),    href: buildUrl({ locale, path: '/publicaciones/categoria/carnival/' }) },
    { label: t('blog.categories.tips',       'Consejos'),    href: buildUrl({ locale, path: '/publicaciones/categoria/tips/' }) }
] as const;
---

<ListingLayout
    locale={locale}
    title={t('blog.title', 'Publicaciones')}
    description={t('blog.description', 'Artículos sobre cultura, gastronomía, turismo y más del Litoral Entrerriano.')}
    canonicalPath={canonicalPath}
    showFilters={true}
    filterPosition="left"
>
    {/* RSS feed-discovery hints — one per supported locale (SPEC-157 REQ-6) */}
    <link
        slot="head-extra"
        rel="alternate"
        type="application/rss+xml"
        title={t('blog.rss.title', 'Publicaciones RSS')}
        href={buildUrl({ locale, path: 'publicaciones/rss.xml' })}
    />

    <ItemListJsonLd
        slot="head-extra"
        name={t('blog.title', 'Publicaciones')}
        items={itemListEntries}
        numberOfItems={total}
        startPosition={(page - 1) * pageSize + 1}
    />

    <Breadcrumbs
        slot="breadcrumbs"
        locale={locale}
        items={[{ label: t('blog.title', 'Publicaciones') }]}
    />

    <ListingPageHeader
        slot="page-header"
        locale={locale}
        tagline={t('blog.tagline', 'Descubrí historias')}
        title={t('blog.title', 'Publicaciones')}
        totalCount={total}
        filterSummary={filterSummary}
    />

    <FilterSidebar
        slot="filters"
        client:load
        locale={locale}
        filters={filterGroups}
        sortOptions={sortOptions}
        defaultSort={DEFAULT_SORT_KEY}
        initialParams={sidebarInitialParams}
    />

    <TagChips
        chips={postCategoryChips}
        ariaLabel={t('blog.categoryChips.ariaLabel', 'Filtrar por categoría de publicación')}
    />

    {/* API error: show skeleton grid as visual placeholder alongside ErrorBanner. */}
    {hasError && (
        <>
            <ErrorBanner locale={locale} error={result.error} entityName="publicaciones" />
            <div class="posts-grid" aria-hidden="true">
                {Array.from({ length: pageSize }).map(() => (
                    <ArticleCardSkeleton />
                ))}
            </div>
        </>
    )}

    {!hasError && cards.length === 0 && hasActiveFilters && (
        <EmptyState
            locale={locale}
            variant="no-results"
            message={t('blog.empty.withFilters.title', 'No encontramos publicaciones con esos filtros')}
            actionUrl={baseUrl}
            actionLabel={t('blog.empty.withFilters.cta', 'Limpiar filtros')}
        />
    )}

    {!hasError && cards.length === 0 && !hasActiveFilters && (
        <EmptyState
            locale={locale}
            variant="empty"
            message={t('blog.empty.noFilters.title', 'Aún no hay publicaciones disponibles')}
        />
    )}

    {!hasError && cards.length > 0 && (
        <div class="posts-grid">
            {cards.map((card, i) => (
                <div data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
                    <ArticleCard data={card} locale={locale} isAuthenticated={isAuthenticated} />
                </div>
            ))}
        </div>
    )}

    <!-- Editor-recruitment banner (SPEC-191 FR-8): after the grid, before
         pagination. page/[page].astro is a rewrite — single mount covers all pages. -->
    <ContributionBanner
        title={t('contributions.banner.editors.title', '¿Te gusta escribir?')}
        description={t(
            'contributions.banner.editors.description',
            'Buscamos editores voluntarios para el blog y la agenda de eventos.'
        )}
        ctaLabel={t('contributions.banner.editors.cta', 'Sumate como editor')}
        ctaHref={buildUrl({ locale, path: 'colaborar/editores' })}
        source="blog_listing"
        variant="editors"
    />

    {totalPages > 1 && (
        <Pagination
            slot="pagination"
            currentPage={page}
            totalPages={totalPages}
            baseUrl={baseUrl.slice(0, -1)}
            locale={locale}
            searchParams={paginationParams}
        />
    )}
</ListingLayout>

<style>
    .posts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-card-gap);
    }

    @media (max-width: 1024px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px)  { .posts-grid { grid-template-columns: 1fr; } }
</style>
