---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../lib/page-helpers';

/**
 * HTML Sitemap page - organized list of all site sections and pages.
 *
 * Rendering: SSG (pre-rendered for all supported locales)
 * Route: /[lang]/mapa-del-sitio/
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import { createT } from '../../lib/i18n';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../lib/page-helpers';
import { buildUrl } from '../../lib/urls';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const t = createT(locale);

const pageTitle = t('common.sitemap.title', 'Mapa del sitio');
const pageDescription = t('common.sitemap.description', 'Explora todas las secciones y paginas disponibles en Hospeda.');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items for the page.
 */
const breadcrumbItems = [
  { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
  { label: pageTitle, href: buildUrl({ locale, path: 'mapa-del-sitio' }) },
];

/**
 * Sitemap sections with their links, organized by site area.
 * All hrefs use buildUrl() for locale-aware, trailing-slash-safe URLs.
 */
const sitemapSections = [
  {
    id: 'principal',
    heading: t('common.sitemap.sections.principal', 'Principal'),
    links: [
      { label: t('common.sitemap.links.home', 'Inicio'), href: buildUrl({ locale }) },
      { label: t('common.sitemap.links.about', 'Quienes somos'), href: buildUrl({ locale, path: 'quienes-somos' }) },
      { label: t('common.sitemap.links.benefits', 'Beneficios'), href: buildUrl({ locale, path: 'beneficios' }) },
      { label: t('common.sitemap.links.contact', 'Contacto'), href: buildUrl({ locale, path: 'contacto' }) },
    ],
  },
  {
    id: 'alojamientos',
    heading: t('common.sitemap.sections.alojamientos', 'Alojamientos'),
    links: [
      { label: t('common.sitemap.links.browseAccommodations', 'Ver alojamientos'), href: buildUrl({ locale, path: 'alojamientos' }) },
    ],
  },
  {
    id: 'destinos',
    heading: t('common.sitemap.sections.destinos', 'Destinos'),
    links: [
      { label: t('common.sitemap.links.browseDestinations', 'Ver destinos'), href: buildUrl({ locale, path: 'destinos' }) },
    ],
  },
  {
    id: 'eventos',
    heading: t('common.sitemap.sections.eventos', 'Eventos'),
    links: [
      { label: t('common.sitemap.links.browseEvents', 'Ver eventos'), href: buildUrl({ locale, path: 'eventos' }) },
    ],
  },
  {
    id: 'publicaciones',
    heading: t('common.sitemap.sections.blog', 'Blog'),
    links: [
      { label: t('common.sitemap.links.blogListing', 'Publicaciones'), href: buildUrl({ locale, path: 'publicaciones' }) },
    ],
  },
  {
    id: 'cuenta',
    heading: t('common.sitemap.sections.cuenta', 'Mi cuenta'),
    links: [
      { label: t('common.sitemap.links.signIn', 'Iniciar sesion'), href: buildUrl({ locale, path: 'auth/signin' }) },
      { label: t('common.sitemap.links.signUp', 'Registrarse'), href: buildUrl({ locale, path: 'auth/signup' }) },
      { label: t('common.sitemap.links.forgotPassword', 'Recuperar contrasena'), href: buildUrl({ locale, path: 'auth/forgot-password' }) },
    ],
  },
  {
    id: 'informacion',
    heading: t('common.sitemap.sections.informacion', 'Informacion legal'),
    links: [
      { label: t('common.sitemap.links.terms', 'Terminos y condiciones'), href: buildUrl({ locale, path: 'terminos-condiciones' }) },
      { label: t('common.sitemap.links.privacy', 'Politica de privacidad'), href: buildUrl({ locale, path: 'privacidad' }) },
      { label: t('common.sitemap.links.sitemap', 'Mapa del sitio'), href: buildUrl({ locale, path: 'mapa-del-sitio' }) },
    ],
  },
] as const;
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
  <SEOHead
    slot="head"
    title={pageTitle}
    description={pageDescription}
    canonical={canonicalUrl}
    locale={locale}
    type="website"
  />

  <div class="container mx-auto max-w-5xl px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <!-- Page Header -->
    <header class="mb-12 mt-6 text-center">
      <h1 class="mb-4 text-4xl font-bold text-foreground md:text-5xl">
        {pageTitle}
      </h1>
      <p class="text-lg text-muted-foreground">
        {pageDescription}
      </p>
    </header>

    <!-- Sitemap Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sitemapSections.map((section) => (
        <article class="rounded-lg border border-border bg-card p-6 shadow-sm">
          <h2 class="mb-4 text-xl font-semibold text-card-foreground">
            {section.heading}
          </h2>
          <nav aria-label={section.heading}>
            <ul class="space-y-2">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-muted-foreground transition-colors hover:text-primary hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
