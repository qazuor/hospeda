---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../lib/page-helpers';

/**
 * HTML Sitemap page - organized list of all site pages by section.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../lib/page-helpers';
import { t } from '../../lib/i18n';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const pageTitle = t({ locale, namespace: 'common', key: 'sitemap.title' });
const pageDescription = t({ locale, namespace: 'common', key: 'sitemap.description' });

/** Helper to get a sitemap section heading from i18n */
const section = (key: string) => t({ locale, namespace: 'common', key: `sitemap.sections.${key}` });

/** Helper to get a sitemap link label from i18n */
const link = (key: string) => t({ locale, namespace: 'common', key: `sitemap.links.${key}` });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: pageTitle, href: `/${locale}/mapa-del-sitio/` },
];

/**
 * Sitemap sections with links
 */
const sitemapSections = [
	{
		id: 'principal',
		heading: section('principal'),
		links: [
			{ label: link('home'), href: `/${locale}/` },
			{ label: link('about'), href: `/${locale}/quienes-somos/` },
			{ label: link('benefits'), href: `/${locale}/beneficios/` },
			{ label: link('contact'), href: `/${locale}/contacto/` },
		],
	},
	{
		id: 'alojamientos',
		heading: section('alojamientos'),
		links: [
			{ label: link('browseAccommodations'), href: `/${locale}/alojamientos/` },
			{ label: link('searchAccommodations'), href: `/${locale}/alojamientos/buscar/` },
			{ label: link('byType'), href: `/${locale}/alojamientos/tipo/` },
		],
	},
	{
		id: 'destinos',
		heading: section('destinos'),
		links: [
			{ label: link('browseDestinations'), href: `/${locale}/destinos/` },
		],
	},
	{
		id: 'eventos',
		heading: section('eventos'),
		links: [{ label: link('browseEvents'), href: `/${locale}/eventos/` }],
	},
	{
		id: 'blog',
		heading: section('blog'),
		links: [{ label: link('blogListing'), href: `/${locale}/blog/` }],
	},
	{
		id: 'cuenta',
		heading: section('cuenta'),
		links: [
			{ label: link('signIn'), href: `/${locale}/auth/signin/` },
			{ label: link('signUp'), href: `/${locale}/auth/signup/` },
			{ label: link('forgotPassword'), href: `/${locale}/auth/forgot-password/` },
		],
	},
	{
		id: 'informacion',
		heading: section('informacion'),
		links: [
			{ label: link('terms'), href: `/${locale}/terminos-y-condiciones/` },
			{ label: link('privacy'), href: `/${locale}/politica-de-privacidad/` },
			{ label: link('sitemap'), href: `/${locale}/mapa-del-sitio/` },
		],
	},
];
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={pageDescription}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-5xl">
				<!-- Page Header -->
				<header class="mb-12 text-center">
					<h1 class="mb-4 text-4xl font-bold text-text-primary md:text-5xl">
						{pageTitle}
					</h1>
					<p class="text-lg text-text-secondary">
						{pageDescription}
					</p>
				</header>

				<!-- Sitemap Grid -->
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
					{
						sitemapSections.map((section) => (
							<article class="rounded-lg bg-bg p-6 shadow-sm">
								<h2 class="mb-4 text-xl font-semibold text-text-primary">
									{section.heading}
								</h2>
								<nav aria-label={`${section.heading} navigation`}>
									<ul class="space-y-2">
										{section.links.map((link) => (
											<li>
												<a
													href={link.href}
													class="text-text-secondary transition-colors hover:text-primary hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
												>
													{link.label}
												</a>
											</li>
										))}
									</ul>
								</nav>
							</article>
						))
					}
				</div>
			</div>
		</Section>
	</Container>
</BaseLayout>
