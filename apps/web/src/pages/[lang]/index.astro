---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../lib/page-helpers';

/**
 * Localized homepage for Hospeda platform (web3).
 * Static shell with Server Islands for dynamic featured content.
 *
 * Rendering: SSG + Server Islands
 * Route: /[lang]/
 */
import AccommodationsSection from '../../components/sections/AccommodationsSection.astro';
import DestinationsSection from '../../components/sections/DestinationsSection.astro';
import EventsSection from '../../components/sections/EventsSection.astro';
import PostsSection from '../../components/sections/PostsSection.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import ReviewsSection from '../../components/sections/ReviewsSection.astro';
import StatsSection from '../../components/sections/StatsSection.astro';
import ListPropertySection from '../../components/sections/ListPropertySection.astro';
import ParallaxDivider from '../../components/shared/ParallaxDivider.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AccommodationGridSkeleton from '../../components/skeletons/AccommodationGridSkeleton.astro';
import DestinationGridSkeleton from '../../components/skeletons/DestinationGridSkeleton.astro';
import EventGridSkeleton from '../../components/skeletons/EventGridSkeleton.astro';
import PostGridSkeleton from '../../components/skeletons/PostGridSkeleton.astro';
import { HERO_IMAGE_SOURCES } from '../../data/hero';
import { createT } from '../../lib/i18n';
import { getLocaleFromParams } from '../../lib/page-helpers';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const t = createT(locale);

const pageTitle = t('home.page.title', 'Alojamientos turisticos en Entre Rios');
const pageDescription = t('home.page.description', 'Descubri los mejores alojamientos turisticos en Concepcion del Uruguay y el Litoral argentino.');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/** Preload first hero image for instant LCP (remaining images preloaded by React) */
const heroPreloadSrc = HERO_IMAGE_SOURCES[0]?.src.src;

const parallax1Title = t('home.parallax.river.title', 'Donde el rio se encuentra con la serenidad');
const parallax1Subtitle = t('home.parallax.river.subtitle', 'Playas de arena fina a orillas del Rio Uruguay');
const parallax2Title = t('home.parallax.carnival.title', 'Vivi la fiesta mas grande del pais');
const parallax2Subtitle = t('home.parallax.carnival.subtitle', 'El Carnaval de Gualeguaychu te espera cada verano');
const parallax3Title = t('home.parallax.termas.title', 'Relaja cuerpo y mente en aguas termales');
const parallax3Subtitle = t('home.parallax.termas.subtitle', 'Descubri el poder curativo de nuestras termas naturales');
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale} isHero isHomepage>
  <SEOHead slot="head" title={pageTitle} description={pageDescription} canonical={canonicalUrl} locale={locale} />
  {heroPreloadSrc && (
    <link slot="head" rel="preload" as="image" href={heroPreloadSrc} fetchpriority="high" />
  )}

  <!-- 1. Hero Section (fullscreen slideshow + search form) -->
  <HeroSection locale={locale} />

    <!-- 2. Featured Accommodations (Server Island) -->
    <AccommodationsSection server:defer locale={locale}>
      <AccommodationGridSkeleton slot="fallback" />
    </AccommodationsSection>

    <!-- 3. Featured Destinations (Server Island) -->
    <DestinationsSection server:defer locale={locale}>
      <DestinationGridSkeleton slot="fallback" />
    </DestinationsSection>

    <!-- Parallax divider 1: Rio Uruguay -->
    <div class="relative z-[7] -mt-10 md:-mt-12">
      <ParallaxDivider
        image="/images/parallax/parallax-rio-uruguay.jpg"
        title={parallax1Title}
        subtitle={parallax1Subtitle}
        topWaveClass="fill-secondary"
        bottomWaveClass="fill-background"
        variant="cloud1"
      />
    </div>

    <!-- 4. Events (Server Island) -->
    <EventsSection server:defer locale={locale}>
      <EventGridSkeleton slot="fallback" />
    </EventsSection>

    <!-- Parallax divider 2: Carnaval -->
    <div class="relative z-[5] -mt-10 md:-mt-12">
      <ParallaxDivider
        image="/images/parallax/parallax-carnaval.jpg"
        title={parallax2Title}
        subtitle={parallax2Subtitle}
        topWaveClass="fill-background"
        bottomWaveClass="fill-muted"
        variant="cloud2"
      />
    </div>

    <!-- 5. Blog Posts (Server Island) -->
    <PostsSection server:defer locale={locale}>
      <PostGridSkeleton slot="fallback" />
    </PostsSection>

    <!-- Parallax divider 3: Termas -->
    <div class="relative z-[3] -mt-10 md:-mt-12">
      <ParallaxDivider
        image="/images/parallax/parallax-termas-er.jpg"
        title={parallax3Title}
        subtitle={parallax3Subtitle}
        topWaveClass="fill-muted"
        bottomWaveClass="fill-background"
        variant="cloud3"
      />
    </div>

    <!-- 6. Reviews -->
    <ReviewsSection locale={locale} />

    <!-- 7. Stats -->
    <StatsSection locale={locale} />

  <!-- 8. Owner CTA -->
  <ListPropertySection locale={locale} />
</BaseLayout>
