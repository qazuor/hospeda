---
export const prerender = true;

export function getStaticPaths() {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

/**
 * Localized homepage for Hospeda platform.
 * Static shell with Server Islands for dynamic featured content.
 * Hero uses split layout with teal bg + hero image.
 * Featured sections use server:defer with skeleton fallbacks.
 * Includes new regional visual identity (SPEC-015).
 *
 * Rendering: SSG + Server Islands
 * Route: /[lang]/
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import HeroSection from '../../components/content/HeroSection.astro';
import FeaturedSection from '../../components/content/FeaturedSection.astro';
import FeaturedAccommodations from '../../components/content/FeaturedAccommodations.astro';
import FeaturedDestinations from '../../components/content/FeaturedDestinations.astro';
import FeaturedEvents from '../../components/content/FeaturedEvents.astro';
import FeaturedPosts from '../../components/content/FeaturedPosts.astro';
import StatisticsSection from '../../components/content/StatisticsSection.astro';
import CategoryIconsSection from '../../components/content/CategoryIconsSection.astro';
import TestimonialsSection from '../../components/content/TestimonialsSection.astro';
import NewsletterSection from '../../components/content/NewsletterSection.astro';
import OwnerCTASection from '../../components/content/OwnerCTASection.astro';
import AccommodationCardSkeleton from '../../components/ui/AccommodationCardSkeleton.astro';
import DestinationCardSkeleton from '../../components/ui/DestinationCardSkeleton.astro';
import EventCardSkeleton from '../../components/ui/EventCardSkeleton.astro';
import BlogPostCardSkeleton from '../../components/ui/BlogPostCardSkeleton.astro';
import { isValidLocale, type SupportedLocale } from '../../lib/i18n';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

const texts: Record<SupportedLocale, {
	heroAccentSubtitle: string;
	heroHeadline: string;
	heroSubheadline: string;
	searchTypePlaceholder: string;
	searchDestinationPlaceholder: string;
	searchCheckInPlaceholder: string;
	searchCheckOutPlaceholder: string;
	searchCtaLabel: string;
	searchLoadingText: string;
	searchAriaLabel: string;
	featuredAccommodations: string;
	featuredDestinations: string;
	upcomingEvents: string;
	latestBlog: string;
	viewAll: string;
	pageTitle: string;
	pageDescription: string;
}> = {
	es: {
		heroAccentSubtitle: 'Descubri el Litoral',
		heroHeadline: 'Tu aventura empieza en la costa del Uruguay',
		heroSubheadline: 'Encontra alojamientos unicos en Concepcion del Uruguay y la region del Litoral argentino',
		searchTypePlaceholder: 'Tipo de alojamiento',
		searchDestinationPlaceholder: 'Donde queres ir?',
		searchCheckInPlaceholder: 'Fecha de llegada',
		searchCheckOutPlaceholder: 'Fecha de salida',
		searchCtaLabel: 'Buscar',
		searchLoadingText: 'Cargando...',
		searchAriaLabel: 'Buscar alojamientos',
		featuredAccommodations: 'Alojamientos destacados',
		featuredDestinations: 'Destinos populares',
		upcomingEvents: 'Proximos eventos',
		latestBlog: 'Ultimas publicaciones',
		viewAll: 'Ver todos',
		pageTitle: 'Inicio',
		pageDescription: 'Descubre alojamientos unicos en Concepcion del Uruguay y el Litoral argentino. Hoteles, cabanas, departamentos y mas.',
	},
	en: {
		heroAccentSubtitle: 'Discover the Litoral',
		heroHeadline: 'Your adventure starts on the Uruguay coast',
		heroSubheadline: 'Find unique accommodations in Concepcion del Uruguay and the Argentine Litoral region',
		searchTypePlaceholder: 'Accommodation type',
		searchDestinationPlaceholder: 'Where do you want to go?',
		searchCheckInPlaceholder: 'Check-in date',
		searchCheckOutPlaceholder: 'Check-out date',
		searchCtaLabel: 'Search',
		searchLoadingText: 'Loading...',
		searchAriaLabel: 'Search accommodations',
		featuredAccommodations: 'Featured Accommodations',
		featuredDestinations: 'Popular Destinations',
		upcomingEvents: 'Upcoming Events',
		latestBlog: 'Latest Posts',
		viewAll: 'View all',
		pageTitle: 'Home',
		pageDescription: 'Discover unique accommodations in Concepcion del Uruguay and the Argentine Litoral. Hotels, cabins, apartments and more.',
	},
	pt: {
		heroAccentSubtitle: 'Descubra o Litoral',
		heroHeadline: 'Sua aventura comeca na costa do Uruguai',
		heroSubheadline: 'Encontre acomodacoes unicas em Concepcion del Uruguay e a regiao do Litoral argentino',
		searchTypePlaceholder: 'Tipo de acomodacao',
		searchDestinationPlaceholder: 'Para onde voce quer ir?',
		searchCheckInPlaceholder: 'Data de chegada',
		searchCheckOutPlaceholder: 'Data de saida',
		searchCtaLabel: 'Buscar',
		searchLoadingText: 'Carregando...',
		searchAriaLabel: 'Buscar acomodacoes',
		featuredAccommodations: 'Acomodacoes em destaque',
		featuredDestinations: 'Destinos populares',
		upcomingEvents: 'Proximos eventos',
		latestBlog: 'Ultimas publicacoes',
		viewAll: 'Ver todos',
		pageTitle: 'Inicio',
		pageDescription: 'Descubra acomodacoes unicas em Concepcion del Uruguay e o Litoral argentino. Hoteis, cabanas, apartamentos e mais.',
	},
};

const t = texts[locale];
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const apiBaseUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001';

/**
 * Hero carousel images showcasing the region.
 * Images are in /public/images/hero/.
 */
/**
 * Curated hero images (8 best picks from diverse categories).
 * Covers: rio, playa, isla, carnaval, architectural, fiesta.
 */
const heroImages = [
  '/images/hero/rio1.jpg',
  '/images/hero/playa1.jpg',
  '/images/hero/isla1.jpg',
  '/images/hero/carnaval1.webp',
  '/images/hero/palacio1.jpg',
  '/images/hero/fiestaplaya1.webp',
  '/images/hero/playa3.jpg',
  '/images/hero/rio3.jpg',
] as const;

/** Social proof badge text by locale */
const socialProofTexts: Record<SupportedLocale, string> = {
  es: '4500+ huespedes eligieron Hospeda',
  en: '4500+ guests chose Hospeda',
  pt: '4500+ hospedes escolheram Hospeda',
};

/**
 * Hardcoded testimonials for the homepage carousel.
 * Will be replaced with API data when testimonials endpoint is available.
 */
const TESTIMONIALS = [
	{
		id: 'testimonial-1',
		quote: 'Encontramos la cabana perfecta para nuestras vacaciones en familia. El proceso de reserva fue muy simple.',
		author: 'Maria Garcia',
		image: '/images/testimonials/maria.jpg',
		location: 'Concepcion del Uruguay',
		rating: 5,
	},
	{
		id: 'testimonial-2',
		quote: 'Excelente plataforma para encontrar alojamiento en el Litoral. Muy buenas opciones y precios.',
		author: 'Carlos Rodriguez',
		image: '/images/testimonials/carlos.jpg',
		location: 'Colon, Entre Rios',
		rating: 4,
	},
	{
		id: 'testimonial-3',
		quote: 'Hospeda nos ayudo a descubrir lugares increibles que no conociamos. Totalmente recomendado.',
		author: 'Laura Martinez',
		image: '/images/testimonials/laura.jpg',
		location: 'Gualeguaychu',
		rating: 5,
	},
];
---

<BaseLayout title={t.pageTitle} description={t.pageDescription} locale={locale} isHero>
	<SEOHead
		slot="head"
		title={t.pageTitle}
		description={t.pageDescription}
		canonical={canonicalUrl}
		locale={locale}
	/>

	<!-- 1. Hero Section with split layout + image carousel -->
	<HeroSection
		heroImages={heroImages}
		accentSubtitle={t.heroAccentSubtitle}
		headline={t.heroHeadline}
		subheadline={t.heroSubheadline}
		searchLabels={{
			typePlaceholder: t.searchTypePlaceholder,
			destinationPlaceholder: t.searchDestinationPlaceholder,
			checkInPlaceholder: t.searchCheckInPlaceholder,
			checkOutPlaceholder: t.searchCheckOutPlaceholder,
			ctaLabel: t.searchCtaLabel,
			loadingText: t.searchLoadingText,
			searchAriaLabel: t.searchAriaLabel,
		}}
		locale={locale}
		apiBaseUrl={apiBaseUrl}
		firstSectionFill="#F0E6D6"
		socialProofText={socialProofTexts[locale]}
	/>

	<!-- 2. Featured Accommodations (Server Island) -->
	<FeaturedSection
		title={t.featuredAccommodations}
		viewAllHref={`/${locale}/alojamientos/`}
		viewAllLabel={t.viewAll}
	>
		<FeaturedAccommodations server:defer locale={locale}>
			<div slot="fallback" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				<AccommodationCardSkeleton />
				<AccommodationCardSkeleton />
				<AccommodationCardSkeleton />
				<AccommodationCardSkeleton class="hidden sm:block" />
				<AccommodationCardSkeleton class="hidden lg:block" />
				<AccommodationCardSkeleton class="hidden lg:block" />
			</div>
		</FeaturedAccommodations>
	</FeaturedSection>

	<!-- 3. Featured Destinations (Server Island) - sand texture background -->
	<FeaturedSection
		title={t.featuredDestinations}
		viewAllHref={`/${locale}/destinos/`}
		viewAllLabel={t.viewAll}
		class="bg-bg-warm texture-sand"
	>
		<FeaturedDestinations server:defer locale={locale}>
			<div slot="fallback" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				<DestinationCardSkeleton />
				<DestinationCardSkeleton class="hidden sm:block" />
				<DestinationCardSkeleton class="hidden lg:block" />
			</div>
		</FeaturedDestinations>
	</FeaturedSection>

	<!-- 4. Statistics Section (glassmorphism over river photo) -->
	<StatisticsSection locale={locale} />

	<!-- 5. Featured Events (Server Island) -->
	<FeaturedSection
		title={t.upcomingEvents}
		viewAllHref={`/${locale}/eventos/`}
		viewAllLabel={t.viewAll}
	>
		<FeaturedEvents server:defer locale={locale}>
			<div slot="fallback" class="grid grid-cols-1 gap-6 lg:grid-cols-2">
				<EventCardSkeleton />
				<EventCardSkeleton class="hidden lg:block" />
			</div>
		</FeaturedEvents>
	</FeaturedSection>

	<!-- 6. Category Icons Section (warm texture background) -->
	<CategoryIconsSection locale={locale} />

	<!-- 7. Featured Blog Posts (Server Island) - alternate background -->
	<FeaturedSection
		title={t.latestBlog}
		viewAllHref={`/${locale}/publicaciones/`}
		viewAllLabel={t.viewAll}
		class="bg-surface-alt"
	>
		<FeaturedPosts server:defer locale={locale}>
			<div slot="fallback" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				<BlogPostCardSkeleton />
				<BlogPostCardSkeleton />
				<BlogPostCardSkeleton class="hidden sm:block" />
			</div>
		</FeaturedPosts>
	</FeaturedSection>

	<!-- 8. Testimonials Section (postcard style on sand texture) -->
	<TestimonialsSection locale={locale} testimonials={TESTIMONIALS} />

	<!-- 9. Newsletter Section (illustrated river background) -->
	<NewsletterSection locale={locale} />

	<!-- 10. Owner CTA Section (split layout with illustration) -->
	<OwnerCTASection locale={locale} />
</BaseLayout>
