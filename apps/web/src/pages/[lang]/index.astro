---
/**
 * @file Homepage
 * @description Static homepage rendered with BaseLayout for all supported locales.
 * Renders all 10 content sections in alternating bg-background / bg-surface-warm order.
 */
import AboutUsSection from "@/components/sections/AboutUsSection.astro";
import CategoryTiles from "@/components/CategoryTiles.astro";
import OrganizationJsonLd from "@/components/seo/OrganizationJsonLd.astro";
import WebSiteJsonLd from "@/components/seo/WebSiteJsonLd.astro";
import countryHousesImg from "@/assets/images/categories/country-houses.jpg";
import hotelsImg from "@/assets/images/categories/hotels.jpg";
import apartmentsImg from "@/assets/images/categories/apartments.jpg";
import musicImg from "@/assets/images/categories/music.jpg";
import cultureImg from "@/assets/images/categories/culture.jpg";
import gastronomyImg from "@/assets/images/categories/gastronomy.jpg";
import postsImg from "@/assets/images/categories/posts.jpg";
import CtaOwnersSection from "@/components/sections/CtaOwnersSection.astro";
import DestinationsSection from "@/components/sections/DestinationsSection.astro";
import FeaturedAccommodationsSection from "@/components/sections/FeaturedAccommodationsSection.astro";
import HeroSection from "@/components/sections/HeroSection.astro";
import LatestArticlesSection from "@/components/sections/LatestArticlesSection.astro";
import NextEventsSection from "@/components/sections/NextEventsSection.astro";
import NextEventsSectionSkeleton from "@/components/skeletons/NextEventsSectionSkeleton.astro";
import PartnersSection from "@/components/sections/PartnersSection.astro";
import StatsSection from "@/components/sections/StatsSection.astro";
import TestimonialsSection from "@/components/sections/TestimonialsSection.astro";
import type { StatItemData } from "@/data/types";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { destinationsApi, statsApi } from "@/lib/api/endpoints";
import { BRAND_NAME, ORGANIZATION_INFO, SOCIAL_PROFILE_URLS } from "@/lib/constants";
import { getSiteUrl } from "@/lib/env";
import { shouldShowSocialProof } from "@/lib/home-guards";
import { createTranslations } from "@/lib/i18n";
import type { SupportedLocale } from "@/lib/i18n";
import { buildUrl } from "@/lib/urls";
import type { GetStaticPaths } from "astro";

export const prerender = true;

export const getStaticPaths = (() => {
    return [{ params: { lang: "es" } }, { params: { lang: "en" } }, { params: { lang: "pt" } }];
}) satisfies GetStaticPaths;

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);

// Site-level structured data (SPEC-157 REQ-5)
// Logo: android-chrome-512x512.png is a 512×512 square PNG — the recommended
// format for schema.org Organization logo (Google requires min 112×112, 1:1).
const siteUrl = getSiteUrl().replace(/\/$/, '');
const logoUrl = `${siteUrl}/android-chrome-512x512.png`;

// Fetch city destinations for the search bar (SSG — fetched at build time)
const destinationsResult = await destinationsApi.list({
    destinationType: "CITY",
    pageSize: 50,
});
const destinations = destinationsResult.ok
    ? destinationsResult.data.items.map((d) => ({
          id: String(d.id),
          slug: String(d.slug),
          name: String(d.name),
          isFeatured: Boolean(d.isFeatured),
      }))
    : [];

// Fetch platform stats for the stats section (SSG — fetched at build time)
const statsResult = await statsApi.getPlatformStats();
const platformStats: readonly StatItemData[] = statsResult.ok
    ? [
          { icon: "BuildingIcon", value: statsResult.data.accommodations, labelKey: "home.statistics.accommodations" },
          { icon: "CompassIcon", value: statsResult.data.destinations, labelKey: "home.statistics.destinations" },
          { icon: "StarIcon", value: statsResult.data.reviews, labelKey: "home.statistics.reviews" },
          { icon: "PostIcon", value: statsResult.data.posts, labelKey: "home.statistics.posts" },
          { icon: "CalendarDotsIcon", value: statsResult.data.events, labelKey: "home.statistics.events" },
      ]
    : [];

// Build hero "social proof" from real platform stats. Hide the block entirely
// when there are no reviews yet so we never render "0+" or "0/5" placeholders.
const socialProof = (() => {
    if (!statsResult.ok) return undefined;
    const reviewsCount = statsResult.data.reviews;
    const averageRating = statsResult.data.averageRating;
    if (!shouldShowSocialProof({ reviewsCount, averageRating })) return undefined;
    const reviewsLabel = formatSocialProofCount(reviewsCount);
    return {
        count: reviewsLabel,
        rating: `${averageRating.toFixed(1)}/5`,
        ratingOf: reviewsLabel,
        avatars: statsResult.data.recentReviewerAvatars,
    } as const;
})();

/**
 * Rounds a count down to the nearest "marketing" milestone (10, 50, 100, ...)
 * and appends a "+" suffix so the badge reads naturally ("500+", "1k+") instead
 * of leaking exact figures that change between page builds.
 */
function formatSocialProofCount(value: number): string {
    if (value >= 1000) {
        const thousands = Math.floor(value / 1000);
        return `${thousands}k+`;
    }
    if (value >= 100) return `${Math.floor(value / 100) * 100}+`;
    if (value >= 10) return `${Math.floor(value / 10) * 10}+`;
    return `${value}+`;
}

/** Category tiles for the "Explorá por categoría" section. */
const categoryTiles = [
    {
        title: t("home.categoryTiles.tiles.countryHouses.title", "Casas quintas"),
        description: t("home.categoryTiles.tiles.countryHouses.description", "Espacio, parque y quincho para escapadas en familia"),
        href: buildUrl({ locale, path: "/alojamientos/tipo/country-house/" }),
        image: countryHousesImg,
    },
    {
        title: t("home.categoryTiles.tiles.hotels.title", "Hoteles"),
        description: t("home.categoryTiles.tiles.hotels.description", "Comodidad y servicio premium en el corazón de la ciudad"),
        href: buildUrl({ locale, path: "/alojamientos/tipo/hotel/" }),
        image: hotelsImg,
    },
    {
        title: t("home.categoryTiles.tiles.apartments.title", "Departamentos"),
        description: t("home.categoryTiles.tiles.apartments.description", "Comodidad urbana cerca de todo, ideales para parejas y escapadas cortas"),
        href: buildUrl({ locale, path: "/alojamientos/tipo/apartment/" }),
        image: apartmentsImg,
    },
    {
        title: t("home.categoryTiles.tiles.music.title", "Música"),
        description: t("home.categoryTiles.tiles.music.description", "Festivales y shows en vivo para todos los gustos"),
        href: buildUrl({ locale, path: "/eventos/categoria/music/" }),
        image: musicImg,
    },
    {
        title: t("home.categoryTiles.tiles.culture.title", "Cultura"),
        description: t("home.categoryTiles.tiles.culture.description", "Arte, historia y patrimonio del Litoral Entrerriano"),
        href: buildUrl({ locale, path: "/eventos/categoria/culture/" }),
        image: cultureImg,
    },
    {
        title: t("home.categoryTiles.tiles.gastronomy.title", "Gastronomía"),
        description: t("home.categoryTiles.tiles.gastronomy.description", "Sabores únicos de la cocina regional y nacional"),
        href: buildUrl({ locale, path: "/eventos/categoria/gastronomy/" }),
        image: gastronomyImg,
    },
    {
        title: t("home.categoryTiles.tiles.posts.title", "Artículos"),
        description: t("home.categoryTiles.tiles.posts.description", "Historias, consejos e inspiración para tu próximo viaje"),
        href: buildUrl({ locale, path: "/publicaciones/" }),
        image: postsImg,
    },
] as const;
---

<DefaultLayout
    locale={locale}
    title={t("home.title")}
    description={t("home.description")}
    canonicalPath={`/${locale}/`}
    ogTagline={t("home.hero.tagline", "Descubrí el Litoral")}
>
    <!-- Site-level structured data (SPEC-157 REQ-5) -->
    <WebSiteJsonLd slot="head-extra" name={BRAND_NAME} url={siteUrl} locale={locale} />
    <OrganizationJsonLd
        slot="head-extra"
        name={BRAND_NAME}
        url={siteUrl}
        logo={logoUrl}
        sameAs={SOCIAL_PROFILE_URLS}
        description={ORGANIZATION_INFO.description}
        telephone={ORGANIZATION_INFO.telephone}
        email={ORGANIZATION_INFO.email}
        address={ORGANIZATION_INFO.address}
        areaServed={ORGANIZATION_INFO.areaServed}
        foundingDate={ORGANIZATION_INFO.foundingDate}
    />

    <!-- 1. Hero -->
    <HeroSection locale={locale} socialProof={socialProof} destinations={destinations} />

    <!-- 2. Featured Accommodations -->
    <FeaturedAccommodationsSection locale={locale} />

    <!-- 3. Category Tiles -->
    <CategoryTiles
        tiles={categoryTiles}
        sectionTitle={t("home.categoryTiles.sectionTitle", "Explorá por categoría")}
        sectionTagline={t("home.categoryTiles.sectionTagline", "Para cada gusto")}
    />

    <!-- 4. Destinations -->
    <DestinationsSection locale={locale} />

    <!-- 5. Next Events -->
    <NextEventsSection server:defer locale={locale}>
        <NextEventsSectionSkeleton slot="fallback" />
    </NextEventsSection>

    <!-- 6. About Us -->
    <AboutUsSection locale={locale} />

    <!-- 7. Latest Articles -->
    <LatestArticlesSection locale={locale} />

    <!-- 8. CTA Owners -->
    <CtaOwnersSection locale={locale} />

    <!-- 9. Testimonials -->
    <TestimonialsSection locale={locale} />

    <!-- 10. Stats -->
    <StatsSection locale={locale} stats={platformStats} suffixes={["+", "+", "+", "+", "+"]} />

    <!-- 11. Partners -->
    <PartnersSection locale={locale} />
</DefaultLayout>
