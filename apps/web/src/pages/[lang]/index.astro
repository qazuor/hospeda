---
/**
 * @file Homepage
 * @description Static homepage rendered with BaseLayout for all supported locales.
 * Renders all 10 content sections in alternating bg-background / bg-surface-warm order.
 */
import AboutUsSection from "@/components/sections/AboutUsSection.astro";
import CategoryTiles from "@/components/CategoryTiles.astro";
import CtaOwnersSection from "@/components/sections/CtaOwnersSection.astro";
import DestinationsSection from "@/components/sections/DestinationsSection.astro";
import FeaturedAccommodationsSection from "@/components/sections/FeaturedAccommodationsSection.astro";
import HeroSection from "@/components/sections/HeroSection.astro";
import LatestArticlesSection from "@/components/sections/LatestArticlesSection.astro";
import NextEventsSection from "@/components/sections/NextEventsSection.astro";
import PartnersSection from "@/components/sections/PartnersSection.astro";
import StatsSection from "@/components/sections/StatsSection.astro";
import TestimonialsSection from "@/components/sections/TestimonialsSection.astro";
import type { StatItemData } from "@/data/types";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { destinationsApi, statsApi } from "@/lib/api/endpoints";
import { createTranslations } from "@/lib/i18n";
import type { SupportedLocale } from "@/lib/i18n";
import { buildUrl } from "@/lib/urls";
import type { GetStaticPaths } from "astro";

export const prerender = true;

export const getStaticPaths = (() => {
    return [{ params: { lang: "es" } }, { params: { lang: "en" } }, { params: { lang: "pt" } }];
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const locale = lang as SupportedLocale;
const { t } = createTranslations(locale);

// Fetch city destinations for the search bar (SSG — fetched at build time)
const destinationsResult = await destinationsApi.list({
    destinationType: "CITY",
    pageSize: 50,
});
const destinations = destinationsResult.ok
    ? destinationsResult.data.items.map((d) => ({
          id: String(d.id),
          slug: String(d.slug),
          name: String(d.name),
      }))
    : [];

// TODO: Replace with real social proof data from testimonials/stats API
const socialProofMock = {
    count: "500+",
    rating: "4.8/5",
    ratingOf: "de 500+",
} as const;

// Fetch platform stats for the stats section (SSG — fetched at build time)
const statsResult = await statsApi.getPlatformStats();
const platformStats: readonly StatItemData[] = statsResult.ok
    ? [
          { icon: "BuildingIcon", value: statsResult.data.accommodations, labelKey: "home.statistics.accommodations" },
          { icon: "CompassIcon", value: statsResult.data.destinations, labelKey: "home.statistics.destinations" },
          { icon: "StarIcon", value: statsResult.data.reviews, labelKey: "home.statistics.reviews" },
          { icon: "PostIcon", value: statsResult.data.posts, labelKey: "home.statistics.posts" },
          { icon: "CalendarDotsIcon", value: statsResult.data.events, labelKey: "home.statistics.events" },
      ]
    : [];

/** Category tiles for the "Explorá por categoría" section. */
const categoryTiles = [
    {
        title: t("home.categoryTiles.cabins.title", "Cabañas"),
        description: t("home.categoryTiles.cabins.description", "Rodeate de naturaleza en las mejores cabañas del Litoral"),
        href: buildUrl({ locale, path: "/alojamientos/tipo/cabin/" }),
    },
    {
        title: t("home.categoryTiles.hotels.title", "Hoteles"),
        description: t("home.categoryTiles.hotels.description", "Comodidad y servicio premium en el corazón de la ciudad"),
        href: buildUrl({ locale, path: "/alojamientos/tipo/hotel/" }),
    },
    {
        title: t("home.categoryTiles.houses.title", "Casas"),
        description: t("home.categoryTiles.houses.description", "Sentite como en casa con todo el espacio que necesitás"),
        href: buildUrl({ locale, path: "/alojamientos/tipo/house/" }),
    },
    {
        title: t("home.categoryTiles.music.title", "Música"),
        description: t("home.categoryTiles.music.description", "Festivales y shows en vivo para todos los gustos"),
        href: buildUrl({ locale, path: "/eventos/categoria/music/" }),
    },
    {
        title: t("home.categoryTiles.culture.title", "Cultura"),
        description: t("home.categoryTiles.culture.description", "Arte, historia y patrimonio del Litoral Entrerriano"),
        href: buildUrl({ locale, path: "/eventos/categoria/culture/" }),
    },
    {
        title: t("home.categoryTiles.gastronomy.title", "Gastronomía"),
        description: t("home.categoryTiles.gastronomy.description", "Sabores únicos de la cocina regional y nacional"),
        href: buildUrl({ locale, path: "/eventos/categoria/gastronomy/" }),
    },
    {
        title: t("home.categoryTiles.posts.title", "Artículos"),
        description: t("home.categoryTiles.posts.description", "Historias, consejos e inspiración para tu próximo viaje"),
        href: buildUrl({ locale, path: "/publicaciones/" }),
    },
] as const;
---

<DefaultLayout
    locale={locale}
    title="Inicio"
    description="Descubrí los mejores alojamientos, destinos y experiencias del Litoral Entrerriano."
    canonicalPath={`/${locale}/`}
>
    <!-- 1. Hero -->
    <HeroSection locale={locale} socialProof={socialProofMock} destinations={destinations} />

    <!-- 2. Featured Accommodations -->
    <FeaturedAccommodationsSection locale={locale} />

    <!-- 3. Category Tiles -->
    <CategoryTiles
        tiles={categoryTiles}
        sectionTitle={t("home.categoryTiles.sectionTitle", "Explorá por categoría")}
        sectionTagline={t("home.categoryTiles.sectionTagline", "Para cada gusto")}
    />

    <!-- 4. Destinations -->
    <DestinationsSection locale={locale} />

    <!-- 5. Next Events -->
    <NextEventsSection locale={locale} />

    <!-- 5. About Us -->
    <AboutUsSection locale={locale} />

    <!-- 6. Latest Articles -->
    <LatestArticlesSection locale={locale} />

    <!-- 8. CTA Owners -->
    <CtaOwnersSection locale={locale} />

    <!-- 7. Testimonials -->
    <TestimonialsSection locale={locale} />

    <!-- 9. Stats -->
    <StatsSection locale={locale} stats={platformStats} suffixes={["+", "+", "+", "+", "+"]} />

    <!-- 10. Partners -->
    <PartnersSection locale={locale} />
</DefaultLayout>
