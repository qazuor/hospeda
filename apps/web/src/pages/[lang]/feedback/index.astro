---
/**
 * @file feedback/index.astro
 * @description Standalone feedback page with minimal dependencies.
 * Intentionally avoids BaseLayout/DefaultLayout so it remains functional
 * even when the main site shell is broken. Only loads the FeedbackForm
 * React island with client:load for immediate interactivity.
 * @route /{lang}/feedback/
 * @rendering SSR (no ISR, no caching)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { getApiUrl, getSiteUrl, getTurnstileSiteKey } from '@/lib/env';
import { buildUrl } from '@/lib/urls';
import { FeedbackForm, parseFeedbackParams } from '@repo/feedback';
import type { ReportTypeId } from '@repo/feedback';

const locale = Astro.locals.locale as SupportedLocale;
const t = createT(locale);
const apiUrl = getApiUrl();
const siteUrl = getSiteUrl();
const turnstileSiteKey = getTurnstileSiteKey();
const homeUrl = buildUrl({ locale, path: '' });

const user = Astro.locals.user as { id?: string; email?: string; name?: string } | undefined;

// Parse error context from query params (passed by ErrorBanner)
const queryParams = parseFeedbackParams(Astro.url.search);
const prefillData = {
	type: (queryParams.type ?? 'bug-js') as ReportTypeId,
	title: queryParams.title ?? '',
	description: queryParams.description ?? '',
	errorInfo: queryParams.error
		? { message: queryParams.error, stack: queryParams.stack }
		: undefined,
};
const hasErrorContext = Boolean(queryParams.source === 'error-banner');
---

<html lang={locale} data-theme="light">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="robots" content="noindex, nofollow" />
	<title>{t('feedback.title', 'Reportar problema')} | Hospeda</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Geologica:wght@400;500;600;700&family=Roboto:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="feedback-standalone">
	<div class="feedback-standalone__container">
		<header class="feedback-standalone__header">
			<a href={homeUrl} class="feedback-standalone__logo" aria-label="Volver a Hospeda">
				<img src="/assets/images/logo.svg" alt="Hospeda" width="120" height="32" />
			</a>
		</header>

		<main class="feedback-standalone__main">
			<h1 class="feedback-standalone__title">
				{hasErrorContext
					? t('feedback.standalone.titleError', '¿Algo no funcionó bien?')
					: t('feedback.standalone.title', '¿Encontraste un problema?')
				}
			</h1>
			<p class="feedback-standalone__desc">
				{hasErrorContext
					? t('feedback.standalone.descError', 'Ya precargamos los datos del error. Agregá cualquier detalle adicional que nos ayude a resolverlo.')
					: t('feedback.standalone.description', 'Contanos qué pasó para que podamos solucionarlo lo antes posible.')
				}
			</p>

			<div class="feedback-standalone__form feedback-root">
				<FeedbackForm
					client:load
					apiUrl={apiUrl}
					appSource="web"
					userEmail={user?.email}
					userName={user?.name}
					prefillData={prefillData}
					turnstileSiteKey={turnstileSiteKey}
				/>
			</div>
		</main>

		<footer class="feedback-standalone__footer">
			<a href={homeUrl}>{t('feedback.standalone.backToHome', 'Volver a Hospeda')}</a>
		</footer>
	</div>
</body>
</html>

<style is:global>
	/* Minimal reset for standalone page */
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	/*
	 * Standalone tokens in sRGB hex. This page intentionally bypasses
	 * BaseLayout, so it cannot rely on the global token stylesheet (which
	 * also carries the SPEC-176 sRGB fallback). Using raw `oklch()` here
	 * left every token invalid on browsers without oklch support (e.g.
	 * Chrome 109), rendering the form transparent (BETA-45). Values are the
	 * sRGB equivalents of the previous oklch tokens.
	 */
	:root {
		--font-heading: 'Geologica', sans-serif;
		--font-sans: 'Roboto', sans-serif;
		--foreground: #1f2227;
		--muted-foreground: #6e7278;
		--background: #fcfcfa;
		--card: #ffffff;
		--border: #dcdee1;
		--input: #dcdee1;
		--primary: #0f74c5;
		--primary-foreground: #ffffff;
		--destructive: #cc272e;
		--accent: #ede8d9;
		--accent-foreground: #1f2227;
		--muted: #f0f2f5;
		--ring: #0f74c5;
		--radius-card: 24px;
		--radius-button: 8px;
	}
</style>

<style>
	.feedback-standalone {
		min-height: 100vh;
		background-color: var(--background);
		font-family: var(--font-sans);
		color: var(--foreground);
		display: flex;
		justify-content: center;
	}

	.feedback-standalone__container {
		width: 100%;
		max-width: 600px;
		padding: 2rem 1.5rem;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	.feedback-standalone__header {
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 2rem;
	}

	.feedback-standalone__logo {
		display: inline-block;
		opacity: 0.7;
		transition: opacity 0.2s ease;
	}

	.feedback-standalone__logo:hover {
		opacity: 1;
	}

	.feedback-standalone__main {
		flex: 1;
	}

	.feedback-standalone__title {
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 4vw, 2rem);
		font-weight: 600;
		color: var(--foreground);
		margin-bottom: 0.5rem;
		line-height: 1.3;
	}

	.feedback-standalone__desc {
		font-size: 1rem;
		color: var(--muted-foreground);
		line-height: 1.6;
		margin-bottom: 2rem;
	}

	.feedback-standalone__form {
		background-color: var(--card);
		border: 1px solid var(--border);
		border-radius: var(--radius-card);
		padding: 1.5rem;
	}

	.feedback-standalone__footer {
		padding-top: 2rem;
		margin-top: 2rem;
		border-top: 1px solid var(--border);
		text-align: center;
	}

	.feedback-standalone__footer a {
		font-size: 0.875rem;
		color: var(--muted-foreground);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.feedback-standalone__footer a:hover {
		color: var(--primary);
	}
</style>
