---
/**
 * Search results page - displays search results grouped by entity type.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 * This page uses noindex to prevent search result pages from being indexed by search engines.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import EmptyState from '../../components/ui/EmptyState.astro';
import GenericErrorState from '../../components/error/GenericErrorState.astro';
import AccommodationCardFeatured from '../../components/accommodation/AccommodationCardFeatured.astro';
import DestinationCard from '../../components/destination/DestinationCard.astro';
import EventCard from '../../components/event/EventCard.astro';
import BlogPostCard from '../../components/blog/BlogPostCard.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../lib/page-helpers';
import { t as i18nT } from '../../lib/i18n';
import { accommodationsApi, destinationsApi, eventsApi, postsApi } from '../../lib/api/endpoints';
import { toAccommodationCardProps, toDestinationCardProps, toEventCardProps, toPostCardProps } from '../../lib/api/transforms';
import { SearchIcon } from '@repo/icons';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Get search query from URL parameters
 */
const query = Astro.url.searchParams.get('q') || '';

/** Helper to translate search results page keys */
const tSearch = (key: string) => i18nT({ locale, namespace: 'search', key: `resultsPage.${key}` });

/** Localized page text via i18n */
const pageTitle = tSearch('title');
const pageDescription = tSearch('description');
const searchHeading = tSearch('heading');
const searchPlaceholder = tSearch('placeholder');
const catAccommodations = tSearch('categories.accommodations');
const catDestinations = tSearch('categories.destinations');
const catEvents = tSearch('categories.events');
const catPosts = tSearch('categories.posts');
const emptyStateText = tSearch('emptyState');
const emptySuggestion = tSearch('emptySuggestion');
const popularSearchesHeading = tSearch('popularSearches');
const viewAllAccommodations = tSearch('viewAll.accommodations');
const viewAllDestinations = tSearch('viewAll.destinations');
const viewAllEvents = tSearch('viewAll.events');
const viewAllPosts = tSearch('viewAll.posts');
const resultsFound = tSearch('resultsFound');
const noResultsFound = tSearch('noResults');

/**
 * Popular search terms - localized via i18n
 */
const popularSearches = [0, 1, 2, 3].map((i) => ({
	label: tSearch(`popular.${i}.label`),
	href: `/${locale}/busqueda/?q=${tSearch(`popular.${i}.query`)}`,
}));

/**
 * Fetch search results from API when query is present
 */
let accommodations: Record<string, unknown>[] = [];
let destinations: Record<string, unknown>[] = [];
let events: Record<string, unknown>[] = [];
let posts: Record<string, unknown>[] = [];
let apiError = false;

if (query) {
	const [accommodationsResult, destinationsResult, eventsResult, postsResult] = await Promise.all([
		accommodationsApi.list({ q: query, pageSize: 6 }),
		destinationsApi.list({ q: query, pageSize: 6 }),
		eventsApi.list({ q: query, pageSize: 6 }),
		postsApi.list({ q: query, pageSize: 6 }),
	]);

	accommodations = accommodationsResult.ok ? accommodationsResult.data.items : [];
	destinations = destinationsResult.ok ? destinationsResult.data.items : [];
	events = eventsResult.ok ? eventsResult.data.items : [];
	posts = postsResult.ok ? postsResult.data.items : [];
	apiError = !accommodationsResult.ok && !destinationsResult.ok && !eventsResult.ok && !postsResult.ok;
}

const totalResults = accommodations.length + destinations.length + events.length + posts.length;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: pageTitle, href: `/${locale}/busqueda/` },
];
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={pageDescription}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- Search Header -->
				{
					query && (
						<article id="search-header" class="mb-8">
							<h1 class="text-3xl font-bold text-text-primary md:text-4xl">
								{searchHeading} <span class="text-primary">"{query}"</span>
							</h1>
						</article>
					)
				}

				<!-- Search Input Form -->
				<article id="search-form" class="mb-12">
					<form method="GET" action={`/${locale}/busqueda`} class="mx-auto max-w-3xl">
						<div class="relative">
							<div class="absolute left-4 top-1/2 -translate-y-1/2">
								<SearchIcon size={20} className="text-text-tertiary" aria-hidden="true" />
							</div>
							<input
								type="search"
								name="q"
								value={query}
								placeholder={searchPlaceholder}
								class="w-full rounded-lg border border-border bg-bg py-3 pl-12 pr-4 text-text-primary placeholder-text-tertiary transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
								aria-label={searchPlaceholder}
								required
							/>
						</div>
					</form>
				</article>

				{
					query ? (
						<>
							{/* Show total results count */}
							<div class="mb-8 text-center">
								<p class="text-lg text-text-secondary">
									{totalResults > 0
										? `${resultsFound} ${totalResults}`
										: noResultsFound
									}
								</p>
							</div>

							{/* Search Results */}
							{totalResults > 0 ? (
								<article id="search-results" class="space-y-12">
									{/* Accommodations Results */}
									{accommodations.length > 0 && (
										<section id="accommodations-results">
											<h2 class="mb-6 text-2xl font-semibold text-text-primary">
												{catAccommodations}{' '}
												<span class="text-text-tertiary">({accommodations.length})</span>
											</h2>
											<div
												class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
												role="region"
												aria-label={catAccommodations}
											>
												{accommodations.map((accommodation) => (
													<AccommodationCardFeatured
														accommodation={toAccommodationCardProps({ item: accommodation as Record<string, unknown> })}
														locale={locale}
													/>
												))}
											</div>
											<div class="mt-4 text-center">
												<a
													href={`/${locale}/alojamientos/?q=${encodeURIComponent(query)}`}
													class="text-sm text-primary hover:underline"
												>
													{viewAllAccommodations}
												</a>
											</div>
										</section>
									)}

									{/* Destinations Results */}
									{destinations.length > 0 && (
										<section id="destinations-results">
											<h2 class="mb-6 text-2xl font-semibold text-text-primary">
												{catDestinations}{' '}
												<span class="text-text-tertiary">({destinations.length})</span>
											</h2>
											<div
												class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
												role="region"
												aria-label={catDestinations}
											>
												{destinations.map((destination) => (
													<DestinationCard
														destination={toDestinationCardProps({ item: destination as Record<string, unknown> })}
														locale={locale}
													/>
												))}
											</div>
											<div class="mt-4 text-center">
												<a
													href={`/${locale}/destinos/?q=${encodeURIComponent(query)}`}
													class="text-sm text-primary hover:underline"
												>
													{viewAllDestinations}
												</a>
											</div>
										</section>
									)}

									{/* Events Results */}
									{events.length > 0 && (
										<section id="events-results">
											<h2 class="mb-6 text-2xl font-semibold text-text-primary">
												{catEvents}{' '}
												<span class="text-text-tertiary">({events.length})</span>
											</h2>
											<div
												class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
												role="region"
												aria-label={catEvents}
											>
												{events.map((event) => (
													<EventCard
														event={toEventCardProps({ item: event as Record<string, unknown> })}
														locale={locale}
													/>
												))}
											</div>
											<div class="mt-4 text-center">
												<a
													href={`/${locale}/eventos/?q=${encodeURIComponent(query)}`}
													class="text-sm text-primary hover:underline"
												>
													{viewAllEvents}
												</a>
											</div>
										</section>
									)}

									{/* Posts Results */}
									{posts.length > 0 && (
										<section id="posts-results">
											<h2 class="mb-6 text-2xl font-semibold text-text-primary">
												{catPosts}{' '}
												<span class="text-text-tertiary">({posts.length})</span>
											</h2>
											<div
												class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
												role="region"
												aria-label={catPosts}
											>
												{posts.map((post) => (
													<BlogPostCard
														post={toPostCardProps({ item: post as Record<string, unknown> })}
														locale={locale}
													/>
												))}
											</div>
											<div class="mt-4 text-center">
												<a
													href={`/${locale}/publicaciones/?q=${encodeURIComponent(query)}`}
													class="text-sm text-primary hover:underline"
												>
													{viewAllPosts}
												</a>
											</div>
										</section>
									)}
								</article>
							) : apiError ? (
								<GenericErrorState
									title={emptyStateText}
									message={emptySuggestion}
									retryHref={`/${locale}/busqueda/?q=${encodeURIComponent(query)}`}
									homeHref={`/${locale}/`}
									locale={locale}
								/>
							) : (
								<EmptyState
									title={emptyStateText}
									message={emptySuggestion}
								/>
							)}
						</>
					) : (
						<>
							<!-- Empty State (no query) -->
							<article id="empty-state" class="py-12 text-center">
								<div class="mx-auto max-w-2xl">
									<h1 class="mb-4 text-3xl font-bold text-text-primary">
										{emptyStateText}
									</h1>
									<p class="mb-8 text-lg text-text-secondary">{emptySuggestion}</p>

									<!-- Popular Searches -->
									<div class="mt-12">
										<h2 class="mb-6 text-xl font-semibold text-text-primary">
											{popularSearchesHeading}
										</h2>
										<div class="flex flex-wrap justify-center gap-3">
											{popularSearches.map((search) => (
												<a
													href={search.href}
													class="rounded-full bg-bg px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:bg-primary hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
												>
													{search.label}
												</a>
											))}
										</div>
									</div>
								</div>
							</article>
						</>
					)
				}
			</div>
		</Section>
	</Container>
</BaseLayout>
