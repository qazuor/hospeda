---
/**
 * Search results page.
 * Displays results grouped by entity type (accommodations, destinations, events, posts)
 * based on a query string from the URL. Uses noindex to prevent search engine indexing.
 *
 * Rendering: SSR (on-demand) — content depends on the `?q` query param at request time.
 * Route: /[lang]/busqueda/
 */
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import EmptyState from '../../components/shared/EmptyState.astro';
import AccommodationCard from '../../components/shared/AccommodationCard.astro';
import DestinationCard from '../../components/shared/DestinationCard.astro';
import EventCard from '../../components/shared/EventCard.astro';
import FeaturedArticleCard from '../../components/shared/FeaturedArticleCard.astro';
import { SearchIcon } from '@repo/icons';
import {
    getLocaleFromParams,
    HOME_BREADCRUMB
} from '../../lib/page-helpers';
import { createT } from '../../lib/i18n';
import { buildUrl, buildUrlWithParams } from '../../lib/urls';
import { accommodationsApi, destinationsApi, eventsApi, postsApi } from '../../lib/api/endpoints';
import {
    toAccommodationCardProps,
    toDestinationCardProps,
    toEventCardProps,
    toPostCardProps
} from '../../lib/api/transforms';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/busqueda/');

/** Translation helper bound to this locale. */
const t = createT(locale);

/** Search query extracted from URL search params. */
const query = Astro.url.searchParams.get('q') ?? '';

const pageTitle = t('search.resultsPage.title', 'Busqueda');
const pageDescription = t('search.resultsPage.description', 'Resultados de busqueda en Hospeda');
const searchHeading = t('search.resultsPage.heading', 'Resultados para');
const searchPlaceholder = t('search.resultsPage.placeholder', 'Busca alojamientos, destinos, eventos...');
const catAccommodations = t('search.resultsPage.categories.accommodations', 'Alojamientos');
const catDestinations = t('search.resultsPage.categories.destinations', 'Destinos');
const catEvents = t('search.resultsPage.categories.events', 'Eventos');
const catPosts = t('search.resultsPage.categories.posts', 'Publicaciones');
const emptyStateTitle = t('search.resultsPage.emptyState', 'No encontramos resultados');
const emptySuggestion = t('search.resultsPage.emptySuggestion', 'Proba con otros terminos o explora el sitio');
const popularSearchesHeading = t('search.resultsPage.popularSearches', 'Busquedas populares');
const viewAllAccommodations = t('search.resultsPage.viewAll.accommodations', 'Ver todos los alojamientos');
const viewAllDestinations = t('search.resultsPage.viewAll.destinations', 'Ver todos los destinos');
const viewAllEvents = t('search.resultsPage.viewAll.events', 'Ver todos los eventos');
const viewAllPosts = t('search.resultsPage.viewAll.posts', 'Ver todas las publicaciones');
const resultsFoundLabel = t('search.resultsPage.resultsFound', 'Resultados encontrados');
const noResultsLabel = t('search.resultsPage.noResults', 'No se encontraron resultados');

/**
 * Popular search terms resolved from i18n.
 * Filtered to exclude entries with empty labels.
 */
const popularSearches = [0, 1, 2, 3]
    .map((i) => ({
        label: t(`search.resultsPage.popular.${i}.label`, ''),
        href: buildUrlWithParams({
            locale,
            path: 'busqueda',
            params: { q: t(`search.resultsPage.popular.${i}.query`, '') }
        })
    }))
    .filter((s) => Boolean(s.label));

/**
 * Fetch search results in parallel when a query is present.
 * Each fetch is independent so a single failing endpoint does not block the rest.
 */
let accommodations: Record<string, unknown>[] = [];
let destinations: Record<string, unknown>[] = [];
let events: Record<string, unknown>[] = [];
let posts: Record<string, unknown>[] = [];
let apiError = false;

if (query) {
    const [accResult, destResult, evtResult, postResult] = await Promise.all([
        accommodationsApi.list({ q: query, pageSize: 6 }),
        destinationsApi.list({ q: query, pageSize: 6 }),
        eventsApi.list({ q: query, pageSize: 6 }),
        postsApi.list({ q: query, pageSize: 6 })
    ]);

    accommodations = accResult.ok
        ? (accResult.data.items as Record<string, unknown>[])
        : [];
    destinations = destResult.ok
        ? (destResult.data.items as Record<string, unknown>[])
        : [];
    events = evtResult.ok
        ? (evtResult.data.items as Record<string, unknown>[])
        : [];
    posts = postResult.ok
        ? (postResult.data.items as Record<string, unknown>[])
        : [];

    apiError = !accResult.ok && !destResult.ok && !evtResult.ok && !postResult.ok;
}

const totalResults =
    accommodations.length + destinations.length + events.length + posts.length;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items.
 */
const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
    { label: pageTitle, href: buildUrl({ locale, path: 'busqueda' }) }
] as const;
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale}
        type="website"
        noindex={true}
    />

    <div class="container mx-auto max-w-7xl px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />

        <section class="mx-auto max-w-6xl py-8">
            <!-- Search heading (only when a query is present) -->
            {query && (
                <header class="mb-8">
                    <h1 class="text-3xl font-bold text-foreground md:text-4xl">
                        {searchHeading}{' '}
                        <span class="text-primary">"{query}"</span>
                    </h1>
                </header>
            )}

            <!-- Search input form -->
            <div class="mb-12">
                <form
                    method="GET"
                    action={buildUrl({ locale, path: 'busqueda' })}
                    class="mx-auto max-w-3xl"
                >
                    <div class="relative">
                        <div class="pointer-events-none absolute inset-y-0 left-4 flex items-center">
                            <SearchIcon
                                size={20}
                                className="text-muted-foreground"
                                aria-hidden="true"
                            />
                        </div>
                        <input
                            type="search"
                            name="q"
                            value={query}
                            placeholder={searchPlaceholder}
                            class="w-full rounded-xl border border-border bg-background py-3 pl-12 pr-4 text-foreground placeholder:text-muted-foreground transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                            aria-label={searchPlaceholder}
                            required
                        />
                    </div>
                </form>
            </div>

            {query ? (
                <>
                    <!-- Results count -->
                    <div class="mb-8 text-center">
                        <p class="text-lg text-muted-foreground">
                            {totalResults > 0
                                ? `${resultsFoundLabel}: ${totalResults}`
                                : noResultsLabel}
                        </p>
                    </div>

                    {totalResults > 0 ? (
                        <div class="space-y-12">
                            <!-- Accommodations results -->
                            {accommodations.length > 0 && (
                                <section aria-labelledby="accommodations-heading">
                                    <h2
                                        id="accommodations-heading"
                                        class="mb-6 text-2xl font-semibold text-foreground"
                                    >
                                        {catAccommodations}{' '}
                                        <span class="text-muted-foreground">({accommodations.length})</span>
                                    </h2>
                                    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                                        {accommodations.map((item) => (
                                            <AccommodationCard
                                                card={toAccommodationCardProps({ item })}
                                                locale={locale}
                                            />
                                        ))}
                                    </div>
                                    <div class="mt-4 text-center">
                                        <a
                                            href={buildUrlWithParams({
                                                locale,
                                                path: 'alojamientos',
                                                params: { q: query }
                                            })}
                                            class="text-sm text-primary hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary"
                                        >
                                            {viewAllAccommodations}
                                        </a>
                                    </div>
                                </section>
                            )}

                            <!-- Destinations results -->
                            {destinations.length > 0 && (
                                <section aria-labelledby="destinations-heading">
                                    <h2
                                        id="destinations-heading"
                                        class="mb-6 text-2xl font-semibold text-foreground"
                                    >
                                        {catDestinations}{' '}
                                        <span class="text-muted-foreground">({destinations.length})</span>
                                    </h2>
                                    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                                        {destinations.map((item, index) => (
                                            <DestinationCard
                                                card={toDestinationCardProps({ item })}
                                                index={index}
                                                locale={locale}
                                            />
                                        ))}
                                    </div>
                                    <div class="mt-4 text-center">
                                        <a
                                            href={buildUrlWithParams({
                                                locale,
                                                path: 'destinos',
                                                params: { q: query }
                                            })}
                                            class="text-sm text-primary hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary"
                                        >
                                            {viewAllDestinations}
                                        </a>
                                    </div>
                                </section>
                            )}

                            <!-- Events results -->
                            {events.length > 0 && (
                                <section aria-labelledby="events-heading">
                                    <h2
                                        id="events-heading"
                                        class="mb-6 text-2xl font-semibold text-foreground"
                                    >
                                        {catEvents}{' '}
                                        <span class="text-muted-foreground">({events.length})</span>
                                    </h2>
                                    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                                        {events.map((item) => (
                                            <EventCard
                                                card={toEventCardProps({ item })}
                                                locale={locale}
                                            />
                                        ))}
                                    </div>
                                    <div class="mt-4 text-center">
                                        <a
                                            href={buildUrlWithParams({
                                                locale,
                                                path: 'eventos',
                                                params: { q: query }
                                            })}
                                            class="text-sm text-primary hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary"
                                        >
                                            {viewAllEvents}
                                        </a>
                                    </div>
                                </section>
                            )}

                            <!-- Posts results -->
                            {posts.length > 0 && (
                                <section aria-labelledby="posts-heading">
                                    <h2
                                        id="posts-heading"
                                        class="mb-6 text-2xl font-semibold text-foreground"
                                    >
                                        {catPosts}{' '}
                                        <span class="text-muted-foreground">({posts.length})</span>
                                    </h2>
                                    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                                        {posts.map((item) => (
                                            <FeaturedArticleCard
                                                article={toPostCardProps({ item })}
                                                locale={locale}
                                            />
                                        ))}
                                    </div>
                                    <div class="mt-4 text-center">
                                        <a
                                            href={buildUrlWithParams({
                                                locale,
                                                path: 'publicaciones',
                                                params: { q: query }
                                            })}
                                            class="text-sm text-primary hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary"
                                        >
                                            {viewAllPosts}
                                        </a>
                                    </div>
                                </section>
                            )}
                        </div>
                    ) : apiError ? (
                        <EmptyState
                            title={emptyStateTitle}
                            message={emptySuggestion}
                            cta={{
                                label: t('search.resultsPage.retryLabel', 'Intentar de nuevo'),
                                href: buildUrlWithParams({
                                    locale,
                                    path: 'busqueda',
                                    params: { q: query }
                                })
                            }}
                        />
                    ) : (
                        <EmptyState
                            title={emptyStateTitle}
                            message={emptySuggestion}
                        />
                    )}
                </>
            ) : (
                <!-- No query: show popular searches -->
                <div class="py-12 text-center">
                    <div class="mx-auto max-w-2xl">
                        <h1 class="mb-4 text-3xl font-bold text-foreground">
                            {emptyStateTitle}
                        </h1>
                        <p class="mb-8 text-lg text-muted-foreground">{emptySuggestion}</p>

                        {popularSearches.length > 0 && (
                            <div class="mt-12">
                                <h2 class="mb-6 text-xl font-semibold text-foreground">
                                    {popularSearchesHeading}
                                </h2>
                                <div class="flex flex-wrap justify-center gap-3">
                                    {popularSearches.map((search) => (
                                        <a
                                            href={search.href}
                                            class="rounded-full border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary hover:bg-primary hover:text-primary-foreground focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                                        >
                                            {search.label}
                                        </a>
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>
                </div>
            )}
        </section>
    </div>
</BaseLayout>
