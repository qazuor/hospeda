---
/**
 * Privacy Policy page.
 * Displays legal information about data collection, usage, cookies, sharing, security,
 * and user rights. The last-updated date is formatted in the active locale.
 *
 * Rendering: SSG (pre-rendered at build time for all supported locales).
 * Route: /[lang]/privacidad/
 */
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../lib/page-helpers';

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import { formatDate, toBcp47Locale } from '@repo/i18n';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../lib/page-helpers';
import { createT } from '../../lib/i18n';
import { buildUrl } from '../../lib/urls';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/privacidad/');

/** Translation helper bound to this locale. */
const t = createT(locale);

const pageTitle = t('privacy.page.title', 'Politica de privacidad');
const pageDescription = t('privacy.page.description', 'Informacion sobre como Hospeda recopila y usa tus datos personales');

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items.
 */
const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
    { label: pageTitle, href: buildUrl({ locale, path: 'privacidad' }) }
] as const;

/**
 * Last-updated date formatted according to the user's active locale.
 */
const lastUpdated = formatDate({ date: new Date(), locale: toBcp47Locale(locale) });
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale}
        type="website"
    />

    <div class="container mx-auto max-w-7xl px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />

        <div class="prose prose-lg mx-auto max-w-4xl py-8">
            <h1 class="mb-8 text-4xl font-bold text-foreground">
                {pageTitle}
            </h1>

            <div class="space-y-8">
                <!-- Section 1: Informacion que recopilamos -->
                <article id="section-1">
                    <h2 class="mb-4 text-2xl font-semibold text-foreground">
                        {t('privacy.sections.informationCollection.title', '1. Informacion que recopilamos')}
                    </h2>
                    <p class="text-muted-foreground">
                        {t('privacy.sections.informationCollection.body', 'Recopilamos informacion personal que usted nos proporciona directamente, como nombre, correo electronico, telefono y direccion. Tambien recopilamos datos de uso automaticamente cuando navega en nuestra plataforma, incluyendo direccion IP, tipo de navegador y paginas visitadas.')}
                    </p>
                </article>

                <!-- Section 2: Uso de la informacion -->
                <article id="section-2">
                    <h2 class="mb-4 text-2xl font-semibold text-foreground">
                        {t('privacy.sections.informationUse.title', '2. Uso de la informacion')}
                    </h2>
                    <p class="text-muted-foreground">
                        {t('privacy.sections.informationUse.body', 'Utilizamos su informacion para proporcionar y mejorar nuestros servicios, procesar transacciones, enviar notificaciones importantes y personalizar su experiencia. Tambien podemos usar sus datos para fines de analisis, marketing y seguridad.')}
                    </p>
                </article>

                <!-- Section 3: Cookies -->
                <article id="section-3">
                    <h2 class="mb-4 text-2xl font-semibold text-foreground">
                        {t('privacy.sections.cookiesTracking.title', '3. Cookies')}
                    </h2>
                    <p class="text-muted-foreground">
                        {t('privacy.sections.cookiesTracking.body', 'Utilizamos cookies y tecnologias similares para mejorar la funcionalidad de nuestro sitio web, analizar el trafico y personalizar contenido. Puede configurar su navegador para rechazar cookies, aunque esto puede afectar algunas funcionalidades de la plataforma.')}
                    </p>
                </article>

                <!-- Section 4: Compartir datos -->
                <article id="section-4">
                    <h2 class="mb-4 text-2xl font-semibold text-foreground">
                        {t('privacy.sections.informationSharing.title', '4. Compartir datos')}
                    </h2>
                    <p class="text-muted-foreground">
                        {t('privacy.sections.informationSharing.body', 'No vendemos su informacion personal. Compartimos datos con proveedores de servicios que nos ayudan a operar la plataforma, siempre bajo estrictos acuerdos de confidencialidad. Tambien podemos compartir informacion cuando sea requerido por ley.')}
                    </p>
                </article>

                <!-- Section 5: Seguridad -->
                <article id="section-5">
                    <h2 class="mb-4 text-2xl font-semibold text-foreground">
                        {t('privacy.sections.dataSecurity.title', '5. Seguridad')}
                    </h2>
                    <p class="text-muted-foreground">
                        {t('privacy.sections.dataSecurity.body', 'Implementamos medidas de seguridad tecnicas y organizativas para proteger su informacion personal contra acceso no autorizado, perdida o destruccion. Sin embargo, ningun sistema de transmision por internet es completamente seguro.')}
                    </p>
                </article>

                <!-- Section 6: Derechos del usuario -->
                <article id="section-6">
                    <h2 class="mb-4 text-2xl font-semibold text-foreground">
                        {t('privacy.sections.yourRights.title', '6. Derechos del usuario')}
                    </h2>
                    <p class="text-muted-foreground">
                        {t('privacy.sections.yourRights.body', 'Usted tiene derecho a acceder, rectificar, eliminar u oponerse al procesamiento de sus datos personales. Tambien puede solicitar la portabilidad de sus datos o retirar su consentimiento en cualquier momento. Para ejercer estos derechos, contactenos a traves de los canales disponibles.')}
                    </p>
                </article>

                <!-- Section 7: Contacto -->
                <article id="section-7">
                    <h2 class="mb-4 text-2xl font-semibold text-foreground">
                        {t('privacy.sections.contact.title', '7. Contacto')}
                    </h2>
                    <p class="text-muted-foreground">
                        {t('privacy.sections.contact.body', 'Si tiene preguntas o inquietudes sobre nuestra politica de privacidad o el tratamiento de sus datos personales, puede contactarnos a traves de los canales de comunicacion disponibles en nuestra plataforma. Responderemos a sus consultas a la brevedad.')}
                    </p>
                    <p class="mt-4">
                        <a
                            href={buildUrl({ locale, path: 'contacto' })}
                            class="text-primary underline underline-offset-4 transition-colors hover:text-primary/80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                        >
                            {t('privacy.page.contactLink', 'Ir a la pagina de contacto')}
                        </a>
                    </p>
                </article>
            </div>

            <!-- Last updated footer -->
            <footer class="mt-12 border-t border-border pt-6">
                <p class="text-sm text-muted-foreground">
                    {t('privacy.page.lastUpdated', 'Ultima actualizacion')}: {lastUpdated}
                </p>
            </footer>
        </div>
    </div>
</BaseLayout>
