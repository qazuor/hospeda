---
/**
 * @file busqueda/index.astro
 * @description Global search page. SSR shell: reads ?q= from URL.
 * - q.length < 2: renders search input + popular tag shortcuts.
 * - q.length >= 2: fetches from GET /api/v1/public/search?q={q}, renders 4
 *   grouped sections (Alojamientos, Destinos, Eventos, Publicaciones).
 * @route /{lang}/busqueda/
 * @rendering SSR (dynamic — always fresh)
 */

import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { SearchResultsLive } from '@/components/search/SearchResultsLive.client';
import { searchApi } from '@/lib/api/endpoints';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import type { PublicSearchResponse } from '@/lib/api/endpoints';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const q = (Astro.url.searchParams.get('q') ?? '').trim();
const hasQuery = q.length >= 2;

// Fetch search results server-side when q is long enough
let initialResults: PublicSearchResponse | null = null;
if (hasQuery) {
	const result = await searchApi.search({ q, limit: 5 });
	if (result.ok) {
		initialResults = result.data;
	}
}

const popularTags = ['Cabañas', 'Colón', 'Termas', 'Carnaval', 'Eventos', 'Entre Ríos'] as const;
---

<DefaultLayout
	locale={locale}
	title={q ? `${q} — ${t('search.title', 'Búsqueda')}` : t('search.title', 'Búsqueda')}
	description={t('search.description', 'Buscá alojamientos, destinos, eventos y publicaciones en el Litoral Entrerriano.')}
	noindex={true}
>
	<div class="search-page">
		<div class="search-page__container">
			<h1 class="search-page__title">{t('search.title', 'Búsqueda')}</h1>

			<!-- Live island: handles debounced re-fetching client-side -->
			<SearchResultsLive
				client:load
				initialQuery={q}
				initialResults={initialResults}
				locale={locale}
				popularTags={popularTags as unknown as string[]}
				searchBaseUrl={buildUrl({ locale, path: 'busqueda' })}
			/>
		</div>
	</div>
</DefaultLayout>

<style>
	.search-page__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: var(--space-section-sm) var(--space-container-x);
	}

	.search-page__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		color: var(--core-foreground);
		margin: 0 0 var(--space-6);
		text-align: center;
	}
</style>
