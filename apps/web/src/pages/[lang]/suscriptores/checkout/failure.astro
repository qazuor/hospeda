---
/**
 * @file suscriptores/checkout/failure.astro
 * @description MercadoPago return page for rejected payment state.
 * No auth required — MP may redirect without an active session.
 * Reads URL query params to determine failure reason and shows
 * a user-friendly explanation with a retry CTA and support link.
 *
 * Sensitive data (payment_id, preference_id) is intentionally
 * NOT rendered in HTML — query params are used only for internal
 * reason mapping logic.
 *
 * @route /{lang}/suscriptores/checkout/failure/
 * @rendering SSR (no prerender — query params must be read server-side)
 */

import CheckoutResult from '@/components/billing/CheckoutResult.astro';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { resolveSubscriptionPlansPath } from '@/lib/account-roles';
import { resolveReasonI18nKey } from '@/lib/checkout/resolve-reason';
import { createTranslations } from '@/lib/i18n';
import { parseSessionUser, requestHasSessionCookie } from '@/lib/middleware-helpers';
import { buildUrl } from '@/lib/urls';

export const prerender = false;

const locale = Astro.locals.locale;
const { t } = createTranslations(locale);

/**
 * Only the status_detail value is used — never the payment_id or
 * other sensitive identifiers.
 *
 * Reference: https://www.mercadopago.com.ar/developers/es/docs/checkout-api/response-handling/collection-results
 */
const statusDetail = Astro.url.searchParams.get('status_detail');

const reasonKey = resolveReasonI18nKey(statusDetail);
const reasonMessage = t(
	reasonKey,
	t(
		'billing.checkout.failure.genericMessage',
		'No pudimos procesar tu pago. Revisá los datos e intentá de nuevo.'
	)
);

// Role-aware retry target (BETA-201): an owner whose owner-plan payment failed
// should retry on the owner plans page; a tourist — or an anonymous MercadoPago
// return with no session cookie — belongs on the tourist page. The middleware
// does NOT parse the session for /suscriptores/* (public), so resolve the actor
// here. Gate the get-session round-trip behind `requestHasSessionCookie` first:
// an unconditional `parseSessionUser` on a public page floods the API auth
// rate-limit bucket (see NextEventsSection.astro / middleware.ts). A null role
// (anonymous / failed lookup) maps to the tourist page (safe default).
const cookieHeader = Astro.request.headers.get('cookie');
const sessionUser = requestHasSessionCookie(cookieHeader)
	? await parseSessionUser({ cookieHeader })
	: null;
const planesUrl = buildUrl({
	locale,
	path: resolveSubscriptionPlansPath({ role: sessionUser?.role ?? null })
});
const supportUrl = buildUrl({ locale, path: 'contacto' });

// The retry CTA is now role-variant (per-visitor), so this page must never be
// shared from a CDN edge cache — otherwise the first visitor's role would leak
// to the next. The sibling pricing pages opt INTO edge caching; this one opts OUT.
Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<MarketingLayout
	locale={locale}
	title={t('billing.checkout.failure.pageTitle', 'Pago rechazado')}
	description={t('billing.checkout.failure.title', 'El pago no pudo procesarse')}
>
	<CheckoutResult
		variant="failure"
		title={t('billing.checkout.failure.title', 'El pago no pudo procesarse')}
		body={reasonMessage}
		primaryCta={{
			href: planesUrl,
			label: t('billing.checkout.failure.retryCta', 'Intentar de nuevo'),
		}}
		secondaryCta={{
			href: supportUrl,
			label: t('billing.checkout.failure.supportCta', 'Contactar soporte'),
		}}
	/>
</MarketingLayout>
