---
/**
 * @file suscriptores/checkout/failure.astro
 * @description MercadoPago return page for rejected payment state.
 * No auth required — MP may redirect without an active session.
 * Reads URL query params to determine failure reason and shows
 * a user-friendly explanation with a retry CTA and support link.
 *
 * Sensitive data (payment_id, preference_id) is intentionally
 * NOT rendered in HTML — query params are used only for internal
 * reason mapping logic.
 *
 * @route /{lang}/suscriptores/checkout/failure/
 * @rendering SSR (no prerender — query params must be read server-side)
 */

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { resolveReasonI18nKey } from '@/lib/checkout/resolve-reason';

export const prerender = false;

const { lang } = Astro.params;
const locale = (lang ?? 'es') as SupportedLocale;
const { t } = createTranslations(locale);

/**
 * Only the status_detail value is used — never the payment_id or
 * other sensitive identifiers.
 *
 * Reference: https://www.mercadopago.com.ar/developers/es/docs/checkout-api/response-handling/collection-results
 */
const statusDetail = Astro.url.searchParams.get('status_detail');

const reasonKey = resolveReasonI18nKey(statusDetail);
const reasonMessage = t(reasonKey, t('billing.checkout.failure.genericMessage', 'No pudimos procesar tu pago. Revisá los datos e intentá de nuevo.'));

const planesUrl = buildUrl({ locale, path: 'suscriptores/planes' });
const supportUrl = buildUrl({ locale, path: 'contacto' });
---

<MarketingLayout
	locale={locale}
	title={t('billing.checkout.failure.pageTitle', 'Pago rechazado — Hospeda')}
	description={t('billing.checkout.failure.title', 'El pago no pudo procesarse')}
>
	<section class="checkout-result section">
		<div class="checkout-result__container" data-reveal="up">
			<div class="checkout-result__icon checkout-result__icon--failure" aria-hidden="true">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 64 64"
					fill="none"
					width="80"
					height="80"
					aria-hidden="true"
				>
					<circle cx="32" cy="32" r="30" stroke="currentColor" stroke-width="4" />
					<path
						d="M22 22l20 20M42 22L22 42"
						stroke="currentColor"
						stroke-width="4"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
				</svg>
			</div>

			<h1 class="checkout-result__title">
				{t('billing.checkout.failure.title', 'El pago no pudo procesarse')}
			</h1>

			<p class="checkout-result__body">
				{reasonMessage}
			</p>

			<div class="checkout-result__actions">
				<a href={planesUrl} class="checkout-result__cta checkout-result__cta--primary">
					{t('billing.checkout.failure.retryCta', 'Intentar de nuevo')}
				</a>
				<a href={supportUrl} class="checkout-result__cta checkout-result__cta--secondary">
					{t('billing.checkout.failure.supportCta', 'Contactar soporte')}
				</a>
			</div>
		</div>
	</section>
</MarketingLayout>

<style>
	.checkout-result {
		min-height: 60vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.checkout-result__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: var(--space-section) var(--space-container-x);
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-6);
	}

	.checkout-result__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100px;
		height: 100px;
		border-radius: 50%;
	}

	.checkout-result__icon--failure {
		color: var(--color-error, oklch(0.55 0.22 25));
		background-color: oklch(from var(--color-error, oklch(0.55 0.22 25)) l c h / 0.1);
	}

	.checkout-result__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		color: var(--foreground);
		margin: 0;
	}

	.checkout-result__body {
		font-family: var(--font-sans);
		font-size: var(--text-body-lg);
		color: var(--muted-foreground);
		margin: 0;
		max-width: 55ch;
	}

	.checkout-result__actions {
		margin-top: var(--space-4);
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		justify-content: center;
	}

	.checkout-result__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-3) var(--space-8);
		font-family: var(--font-sans);
		font-weight: 600;
		font-size: var(--text-body-lg);
		border-radius: var(--radius-button);
		text-decoration: none;
		transition: opacity var(--duration-normal) ease;
	}

	.checkout-result__cta:hover {
		opacity: 0.85;
	}

	.checkout-result__cta--primary {
		background-color: var(--accent);
		color: var(--accent-foreground, #fff);
	}

	.checkout-result__cta--secondary {
		background-color: transparent;
		color: var(--muted-foreground);
		border: 1.5px solid var(--border, oklch(0.85 0.01 240));
	}

	.checkout-result__cta--secondary:hover {
		background-color: var(--surface-warm);
		opacity: 1;
	}

	@media (max-width: 768px) {
		.checkout-result__container {
			padding: var(--space-12) var(--space-container-x);
		}

		.checkout-result__actions {
			flex-direction: column;
			align-items: stretch;
		}
	}
</style>
