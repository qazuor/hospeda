---
/**
 * @file suscriptores/checkout/pending.astro
 * @description MercadoPago return page for pending payment state.
 * No auth required — MP may redirect without an active session.
 * Informs the user that their payment is being processed and directs
 * them to /mi-cuenta to verify status once confirmed.
 *
 * @route /{lang}/suscriptores/checkout/pending/
 * @rendering SSR (no prerender — consistent with success/failure siblings)
 */

import CheckoutResult from '@/components/billing/CheckoutResult.astro';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

export const prerender = false;

const locale = Astro.locals.locale;
const { t } = createTranslations(locale);

const miCuentaUrl = buildUrl({ locale, path: 'mi-cuenta' });
---

<MarketingLayout
	locale={locale}
	title={t('billing.checkout.pending.pageTitle', 'Pago en proceso — Hospeda')}
	description={t('billing.checkout.pending.title', 'Tu pago está siendo procesado')}
>
	<CheckoutResult
		variant="pending"
		title={t('billing.checkout.pending.title', 'Tu pago está siendo procesado')}
		body={t(
			'billing.checkout.pending.body',
			'Puede demorar hasta 24 horas en confirmarse. Te avisaremos por email cuando se acredite.'
		)}
		primaryCta={{
			href: miCuentaUrl,
			label: t('billing.checkout.pending.cta', 'Verificar estado'),
		}}
	/>
</MarketingLayout>
