---
/**
 * @file suscriptores/checkout/success.astro
 * @description MercadoPago return page for the paid-checkout success flow.
 * No auth required for the render itself — MP may redirect without an active
 * session — but the polling island calls a protected endpoint.
 *
 * Two paths (HOS-151 Bug A):
 * - IMMEDIATE: an annual Checkout-Pro redirect carries `?collection_status=approved`,
 *   and a no-card trial / comp grant carries `?effect=trial|comp` (appended by
 *   PlanPurchaseButton). These resolve to the success state on the first render
 *   with zero polling.
 * - POLLED: a recurring MercadoPago preapproval redirect carries NEITHER, so the
 *   local subscription may still be flipping from `pending_provider` to `active`
 *   via the webhook / polling-fallback cron. The `CheckoutStatusPoller` island
 *   reads the `localSubscriptionId` stashed in sessionStorage before the redirect
 *   and polls `GET /billing/subscriptions/:localId/status` until it activates or
 *   a ~90s timeout is reached. Before this fix the page hung on
 *   "Verificando estado del pago..." forever for every paid conversion.
 *
 * @route /{lang}/suscriptores/checkout/success/
 * @rendering SSR (no prerender — query params must be read server-side)
 */

import CheckoutResult from '@/components/billing/CheckoutResult.astro';
import { CheckoutStatusPoller } from '@/components/billing/CheckoutStatusPoller.client';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

export const prerender = false;

const locale = Astro.locals.locale;
const { t } = createTranslations(locale);

const collectionStatus = Astro.url.searchParams.get('collection_status');

// PlanPurchaseButton appends `?effect=comp` (or, only from an API that predates
// HOS-171, `?effect=trial`) to this in-app success sentinel URL when the granted
// effect has NO MercadoPago preapproval to verify (see
// StartPaidSubscriptionResponse `appliedEffect`). Those resolve immediately with
// no payment in flight.
//
// `trial` is retained deliberately even though card-first no longer grants a
// no-card trial: the API and the web deploy as separate Coolify resources, so an
// old API can still answer with it mid-rollout, and dropping the branch would
// send that customer to the poller to wait on a payment that never existed
// (HOS-151 Bug A's exact symptom). Remove it with the enum, in a later cleanup.
const effectParam = Astro.url.searchParams.get('effect');
const isTrial = effectParam === 'trial';
const isComp = effectParam === 'comp';

// IMMEDIATE success: an approved annual Checkout-Pro charge, or a no-card
// trial / comp grant. Anything else is a recurring preapproval return that the
// polling island resolves (HOS-151 Bug A).
const isImmediateSuccess = collectionStatus === 'approved' || isTrial || isComp;

// PlanPurchaseButton appends `?promoIgnored=1` when the server accepted a promo
// code that ended up doing nothing. Since HOS-171 that means only one thing: a
// trial_extension code with no trial to lengthen. It is NOT "a discount was
// discarded in favour of the trial" — a discount and a trial now coexist.
const promoIgnored = Astro.url.searchParams.get('promoIgnored') === '1';

const miCuentaUrl = buildUrl({ locale, path: 'mi-cuenta' });

const title = isTrial
	? t('billing.checkout.success.trialTitle', '¡Tu prueba gratis arrancó!')
	: t('billing.checkout.success.title', '¡Tu suscripción está activa!');

const body = isTrial
	? t(
			'billing.checkout.success.trialSubtitle',
			'Ya podés empezar a usar tu plan. No te cobramos nada: tu prueba gratuita está activa y no registramos ninguna tarjeta.'
		)
	: t('billing.checkout.success.subtitle', 'Tu pago fue aprobado correctamente');

const promoIgnoredNote = promoIgnored
	? t(
			'billing.checkout.success.promoIgnoredNote',
			'Tu código de descuento no se aplicó porque activaste la prueba gratis.'
		)
	: undefined;
---

<MarketingLayout
	locale={locale}
	title={t('billing.checkout.success.pageTitle', 'Pago aprobado')}
	description={t('billing.checkout.success.subtitle', 'Tu pago fue aprobado correctamente')}
>
	{
		isImmediateSuccess ? (
			<CheckoutResult
				variant="success"
				title={title}
				body={body}
				{...(promoIgnoredNote ? { note: promoIgnoredNote } : {})}
				primaryCta={{
					href: miCuentaUrl,
					label: t('billing.checkout.success.cta', 'Ir a mi cuenta'),
				}}
			/>
		) : (
			<CheckoutStatusPoller client:load locale={locale} miCuentaUrl={miCuentaUrl} />
		)
	}
</MarketingLayout>
