---
/**
 * @file suscriptores/checkout/success.astro
 * @description MercadoPago return page for the paid-checkout success flow.
 * No auth required for the render itself — MP may redirect without an active
 * session — but the polling island calls a protected endpoint.
 *
 * Two paths (HOS-151 Bug A):
 * - IMMEDIATE: an annual Checkout-Pro redirect carries `?collection_status=approved`,
 *   and a no-card trial / comp grant carries `?effect=trial|comp` (appended by
 *   PlanPurchaseButton). These resolve to the success state on the first render
 *   with zero polling.
 * - POLLED: a recurring MercadoPago preapproval redirect carries NEITHER, so the
 *   local subscription may still be flipping from `pending_provider` to `active`
 *   via the webhook / polling-fallback cron. The `CheckoutStatusPoller` island
 *   reads the `localSubscriptionId` stashed in sessionStorage before the redirect
 *   and polls `GET /billing/subscriptions/:localId/status` until it activates or
 *   a ~90s timeout is reached. Before this fix the page hung on
 *   "Verificando estado del pago..." forever for every paid conversion.
 *
 * HOS-191 Path C ("share link" checkout) adds a third redirect shape: MercadoPago's
 * `back_url` return carries `?preapproval_id=...` (no `collection_status`). That
 * falls into the POLLED branch, but before polling starts the `CheckoutStatusPoller`
 * island first links the preapproval to the pending local subscription via
 * `POST /billing/subscriptions/link-preapproval` — see that component's docstring.
 *
 * @route /{lang}/suscriptores/checkout/success/
 * @rendering SSR (no prerender — query params must be read server-side)
 */

import CheckoutResult from '@/components/billing/CheckoutResult.astro';
import { CheckoutStatusPoller } from '@/components/billing/CheckoutStatusPoller.client';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

export const prerender = false;

const locale = Astro.locals.locale;
const { t } = createTranslations(locale);

const collectionStatus = Astro.url.searchParams.get('collection_status');

// PlanPurchaseButton appends `?effect=comp` to this in-app success sentinel URL.
// A comp grant has NO MercadoPago preapproval to verify (see
// StartPaidSubscriptionResponse `appliedEffect`), so it resolves immediately with
// no payment in flight.
//
// A trial does NOT come through here: since HOS-171 it is `free_trial` on the
// paid preapproval, so it takes the normal MercadoPago redirect and resolves
// through the polling island like any other checkout.
const isComp = Astro.url.searchParams.get('effect') === 'comp';

// IMMEDIATE success: an approved annual Checkout-Pro charge, or a comp grant.
// Anything else is a recurring preapproval return that the polling island
// resolves (HOS-151 Bug A).
const isImmediateSuccess = collectionStatus === 'approved' || isComp;

// HOS-191 Path C: MercadoPago's hosted share-link `back_url` return carries
// this. Forwarded to `CheckoutStatusPoller`, which links it to the pending
// local subscription before polling starts (see that component's docstring).
const preapprovalId = Astro.url.searchParams.get('preapproval_id');

// PlanPurchaseButton appends `?promoIgnored=1` when the server accepted a promo
// code that ended up doing nothing. Since HOS-171 that means only one thing: a
// trial_extension code with no trial to lengthen. It is NOT "a discount was
// discarded in favour of the trial" — a discount and a trial now coexist.
const promoIgnored = Astro.url.searchParams.get('promoIgnored') === '1';

const miCuentaUrl = buildUrl({ locale, path: 'mi-cuenta' });

const title = t('billing.checkout.success.title', '¡Tu suscripción está activa!');

const body = t('billing.checkout.success.subtitle', 'Tu pago fue aprobado correctamente');

const promoIgnoredNote = promoIgnored
	? t(
			'billing.checkout.success.promoIgnoredNote',
			'Tu código no se aplicó: es para extender una prueba gratis y esta suscripción no tiene una.'
		)
	: undefined;
---

<MarketingLayout
	locale={locale}
	title={t('billing.checkout.success.pageTitle', 'Pago aprobado')}
	description={t('billing.checkout.success.subtitle', 'Tu pago fue aprobado correctamente')}
>
	{
		isImmediateSuccess ? (
			<CheckoutResult
				variant="success"
				title={title}
				body={body}
				{...(promoIgnoredNote ? { note: promoIgnoredNote } : {})}
				primaryCta={{
					href: miCuentaUrl,
					label: t('billing.checkout.success.cta', 'Ir a mi cuenta'),
				}}
			/>
		) : (
			<CheckoutStatusPoller
				client:load
				locale={locale}
				miCuentaUrl={miCuentaUrl}
				preapprovalId={preapprovalId}
			/>
		)
	}
</MarketingLayout>
