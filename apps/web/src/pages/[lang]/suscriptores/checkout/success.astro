---
/**
 * @file suscriptores/checkout/success.astro
 * @description MercadoPago return page for approved payment state.
 * No auth required — MP may redirect without an active session.
 * Reads URL query params to determine collection_status and shows
 * appropriate confirmation or verification message.
 *
 * @route /{lang}/suscriptores/checkout/success/
 * @rendering SSR (no prerender — query params must be read server-side)
 */

import CheckoutResult from '@/components/billing/CheckoutResult.astro';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

export const prerender = false;

const locale = Astro.locals.locale;
const { t } = createTranslations(locale);

const collectionStatus = Astro.url.searchParams.get('collection_status');
const isApproved = collectionStatus === 'approved';

const miCuentaUrl = buildUrl({ locale, path: 'mi-cuenta' });

const title = isApproved
	? t('billing.checkout.success.title', '¡Tu suscripción está activa!')
	: t('billing.checkout.success.verifyingStatus', 'Verificando estado del pago...');

const body = isApproved
	? t('billing.checkout.success.subtitle', 'Tu pago fue aprobado correctamente')
	: t(
			'billing.checkout.success.verifyingSubtitle',
			'Estamos confirmando tu pago. Esto puede tardar unos instantes.'
		);
---

<MarketingLayout
	locale={locale}
	title={t('billing.checkout.success.pageTitle', 'Pago aprobado — Hospeda')}
	description={t('billing.checkout.success.subtitle', 'Tu pago fue aprobado correctamente')}
>
	<CheckoutResult
		variant={isApproved ? 'success' : 'pending'}
		title={title}
		body={body}
		primaryCta={{
			href: miCuentaUrl,
			label: t('billing.checkout.success.cta', 'Ir a mi cuenta'),
		}}
	/>
</MarketingLayout>
