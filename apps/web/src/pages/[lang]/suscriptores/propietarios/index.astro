---
/**
 * @file suscriptores/propietarios/index.astro
 * @description Property owners landing page with hero, benefits, how-it-works, FAQ, and CTA.
 * Matches Figma design: full-width marketing sections.
 * @route /{lang}/suscriptores/propietarios/
 * @rendering SSG (prerender)
 */

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import MarketingHero from '@/components/marketing/MarketingHero.astro';
import GradientButton from '@/components/shared/ui/GradientButton.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { HomeIcon, LocationIcon, MapIcon, SettingsIcon, ShieldIcon, SparkleIcon, StarIcon } from '@repo/icons';
import type { GetStaticPaths } from 'astro';

interface BenefitDefinition {
	readonly Icon: typeof MapIcon;
	readonly titleKey: string;
	readonly titleFb: string;
	readonly descKey: string;
	readonly descFb: string;
}

export const prerender = true;

export const getStaticPaths = (() => {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const locale = lang as SupportedLocale;
const { t } = createTranslations(locale);

const benefits: ReadonlyArray<BenefitDefinition> = [
	{
		Icon: MapIcon,
		titleKey: 'owners.benefits.1.title',
		titleFb: 'Visibilidad regional',
		descKey: 'owners.benefits.1.desc',
		descFb: 'Llegá a miles de viajeros que buscan alojamiento en la costa del río Uruguay y el litoral entrerriano.',
	},
	{
		Icon: SettingsIcon,
		titleKey: 'owners.benefits.2.title',
		titleFb: 'Gestión simple',
		descKey: 'owners.benefits.2.desc',
		descFb: 'Publicá, editá y gestioná tus propiedades desde un solo lugar. Panel de control intuitivo y fácil de usar.',
	},
	{
		Icon: ShieldIcon,
		titleKey: 'owners.benefits.3.title',
		titleFb: 'Sin comisiones ocultas',
		descKey: 'owners.benefits.3.desc',
		descFb: 'Planes transparentes con precios fijos. Sabés exactamente cuánto pagás, sin sorpresas en cada reserva.',
	},
];

const steps = [
	{ num: '01', titleKey: 'owners.steps.1.title', titleFb: 'Registrate', descKey: 'owners.steps.1.desc', descFb: 'Creá tu cuenta de propietario en menos de 2 minutos. Solo necesitás un email.' },
	{ num: '02', titleKey: 'owners.steps.2.title', titleFb: 'Publicá', descKey: 'owners.steps.2.desc', descFb: 'Cargá fotos, descripción, servicios y precios de tu alojamiento.' },
	{ num: '03', titleKey: 'owners.steps.3.title', titleFb: 'Recibí consultas', descKey: 'owners.steps.3.desc', descFb: 'Los viajeros te contactan directamente. Vos manejás las reservas.' },
	{ num: '04', titleKey: 'owners.steps.4.title', titleFb: 'Crecé', descKey: 'owners.steps.4.desc', descFb: 'Accedé a estadísticas, destacá tu publicación y llegá a más viajeros.' },
] as const;

const faqs = [
	{ qKey: 'owners.faq.1.q', qFb: '¿Cuánto cuesta publicar mi alojamiento?', aKey: 'owners.faq.1.a', aFb: 'Ofrecemos planes desde gratuitos hasta premium. El plan básico te permite publicar sin costo.' },
	{ qKey: 'owners.faq.2.q', qFb: '¿Cómo recibo las reservas?', aKey: 'owners.faq.2.a', aFb: 'Los viajeros te contactan directamente por WhatsApp, email o teléfono. Vos manejás todo.' },
	{ qKey: 'owners.faq.3.q', qFb: '¿Puedo publicar más de una propiedad?', aKey: 'owners.faq.3.a', aFb: 'Sí, podés publicar todas las propiedades que quieras desde una misma cuenta.' },
	{ qKey: 'owners.faq.4.q', qFb: '¿Qué tipo de alojamientos puedo publicar?', aKey: 'owners.faq.4.a', aFb: 'Casas quintas, cabañas, departamentos, hoteles, apart hotels, campings y más.' },
] as const;

// Split heading to underline the last word with a handwritten accent.
const heroHeadingFull = t('owners.hero.title', 'Publicá tu alojamiento y llegá a miles de viajeros');
const heroHeadingWords = heroHeadingFull.trim().split(/\s+/);
const heroHeadingAccent = heroHeadingWords.pop() ?? heroHeadingFull;
const heroHeadingMain = heroHeadingWords.join(' ');

const faqJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((faq) => ({
		'@type': 'Question',
		name: t(faq.qKey, faq.qFb),
		acceptedAnswer: {
			'@type': 'Answer',
			text: t(faq.aKey, faq.aFb),
		},
	})),
};
---

<MarketingLayout
	locale={locale}
	title={t('owners.title', 'Publicá tu alojamiento')}
	description={t('owners.description', 'Publicá tu propiedad en Hospeda y llegá a miles de viajeros del litoral entrerriano.')}
>
	<JsonLd slot="head-extra" data={faqJsonLd} />

	<!-- Hero -->
	<MarketingHero
		tagline={t('owners.hero.tagline', 'Para propietarios')}
		titleMain={heroHeadingMain}
		titleAccent={heroHeadingAccent}
		subtitle={t('owners.hero.desc', 'Hospeda conecta tu propiedad con viajeros que buscan experiencias auténticas en el litoral entrerriano. Sin comisiones ocultas, con herramientas simples y soporte dedicado.')}
	>
		<Fragment slot="icon-1"><HomeIcon size="md" weight="duotone" /></Fragment>
		<Fragment slot="icon-2"><StarIcon size="md" weight="duotone" /></Fragment>
		<Fragment slot="icon-3"><SparkleIcon size="md" weight="duotone" /></Fragment>
		<Fragment slot="cta">
			<GradientButton
				href={buildUrl({ locale, path: 'auth/signup' })}
				label={t('owners.hero.cta', 'Empezar ahora')}
				variant="primary"
				icon="true"
			/>
		</Fragment>
	</MarketingHero>

	<!-- Benefits -->
	<section class="owners-benefits section">
		<div class="owners-benefits__decoratives" aria-hidden="true">
			<span class="owners-benefits__watermark">
				<ShieldIcon size={180} weight="duotone" />
			</span>
			<svg
				class="owners-benefits__wave"
				viewBox="0 0 800 60"
				preserveAspectRatio="none"
				aria-hidden="true"
			>
				<path
					d="M 0 30 Q 100 5, 200 30 T 400 30 T 600 30 T 800 30"
					stroke="currentColor"
					stroke-width="2"
					stroke-dasharray="3 7"
					stroke-linecap="round"
					fill="none"
				/>
			</svg>
			<span class="owners-benefits__dot owners-benefits__dot--1"></span>
			<span class="owners-benefits__dot owners-benefits__dot--2"></span>
			<span class="owners-benefits__dot owners-benefits__dot--3"></span>
			<span class="owners-benefits__dot owners-benefits__dot--4"></span>
		</div>
		<div class="owners-benefits__container">
			<p class="owners-benefits__tagline" data-reveal="up">{t('owners.benefits.tagline', '¿Por qué Hospeda?')}</p>
			<h2 class="owners-benefits__title" data-reveal="up">{t('owners.benefits.title', 'Beneficios para propietarios')}</h2>
			<div class="owners-benefits__grid">
				{benefits.map((b, i) => (
					<div class="owners-benefit-card" data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
						<div class="owners-benefit-card__icon" aria-hidden="true">
							<b.Icon size={28} weight="regular" />
						</div>
						<h3 class="owners-benefit-card__title">{t(b.titleKey, b.titleFb)}</h3>
						<p class="owners-benefit-card__desc">{t(b.descKey, b.descFb)}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- How it works -->
	<section class="owners-steps section section--warm">
		<div class="owners-steps__container">
			<p class="owners-steps__tagline" data-reveal="up">{t('owners.steps.tagline', 'Es así de fácil')}</p>
			<h2 class="owners-steps__title" data-reveal="up">{t('owners.steps.title', '¿Cómo funciona?')}</h2>
			<div class="owners-steps__grid">
				<svg
					class="owners-steps__path"
					viewBox="0 0 1200 80"
					preserveAspectRatio="none"
					aria-hidden="true"
				>
					<path
						d="M 80 50 Q 280 0, 480 45 T 880 35 T 1120 45"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-dasharray="4 8"
						stroke-linecap="round"
						fill="none"
					/>
				</svg>
				{steps.map((s, i) => (
					<div class="owners-step" data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
						<span class="owners-step__num">{s.num}</span>
						<h3 class="owners-step__title">{t(s.titleKey, s.titleFb)}</h3>
						<p class="owners-step__desc">{t(s.descKey, s.descFb)}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section class="owners-faq section">
		<span class="owners-faq__watermark" aria-hidden="true">?</span>
		<div class="owners-faq__container">
			<p class="owners-faq__tagline" data-reveal="up">{t('owners.faq.tagline', 'Resolvé tus dudas')}</p>
			<h2 class="owners-faq__title" data-reveal="up">{t('owners.faq.title', 'Preguntas frecuentes')}</h2>
			<div class="owners-faq__list" data-reveal="up">
				{faqs.map((faq) => (
					<details class="owners-faq__item">
						<summary class="owners-faq__question">{t(faq.qKey, faq.qFb)}</summary>
						<p class="owners-faq__answer">{t(faq.aKey, faq.aFb)}</p>
					</details>
				))}
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="owners-cta section section--dark">
		<div class="owners-cta__decoratives" aria-hidden="true">
			<div class="owners-cta__blob"></div>
			<svg
				class="owners-cta__route"
				viewBox="0 0 200 60"
				preserveAspectRatio="none"
				aria-hidden="true"
			>
				<path
					d="M 4 30 Q 50 5, 100 28 T 188 32"
					stroke="currentColor"
					stroke-width="2"
					stroke-dasharray="3 6"
					stroke-linecap="round"
					fill="none"
				/>
			</svg>
			<span class="owners-cta__pin">
				<LocationIcon size="md" weight="duotone" />
			</span>
		</div>
		<div class="owners-cta__container" data-reveal="up">
			<p class="owners-cta__tagline">{t('owners.cta.tagline', '¿Listo para empezar?')}</p>
			<h2 class="owners-cta__title">{t('owners.cta.title', 'Publicá tu alojamiento hoy')}</h2>
			<p class="owners-cta__desc">
				{t('owners.cta.desc', 'Unite a los cientos de propietarios que ya confían en Hospeda para mostrar sus alojamientos al mundo.')}
			</p>
			<GradientButton
				href={buildUrl({ locale, path: 'auth/signup' })}
				label={t('owners.cta.button', 'Empezar ahora')}
				variant="accent"
				icon="true"
			/>
		</div>
	</section>
</MarketingLayout>

<style>

	@media (prefers-reduced-motion: reduce) {
		.owners-hero__shape,
		.owners-hero__badge {
			animation: none;
		}
	}

	/* Benefits */
	.owners-benefits__container,
	.owners-steps__container,
	.owners-faq__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
		text-align: center;
	}

	.owners-benefits__tagline,
	.owners-steps__tagline,
	.owners-faq__tagline,
	.owners-cta__tagline {
		font-family: var(--font-decorative);
		font-weight: 700;
		font-size: clamp(1.1rem, 2.5vw, 1.4rem);
		color: var(--brand-accent);
		margin: 0 0 var(--space-2);
	}

	.owners-benefits__title,
	.owners-steps__title,
	.owners-faq__title,
	.owners-cta__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		color: var(--core-foreground);
		margin: 0 0 var(--space-8);
	}

	.owners-benefits__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-card-gap);
		text-align: left;
	}

	.owners-benefit-card {
		background-color: var(--core-card);
		border-radius: var(--radius-card);
		padding: var(--space-6);
		box-shadow: var(--shadow-card);
		transition:
			transform var(--duration-normal) ease,
			box-shadow var(--duration-normal) ease;
	}

	.owners-benefit-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-card-hover);
	}

	.owners-benefit-card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		border-radius: var(--radius-md);
		background-color: var(--brand-primary-a10);
		color: var(--brand-primary);
		margin-bottom: var(--space-4);
	}

	.owners-benefit-card__title {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: var(--text-lg);
		color: var(--core-foreground);
		margin: 0 0 var(--space-2);
	}

	.owners-benefit-card__desc {
		font-family: var(--font-sans);
		font-size: var(--text-body);
		color: var(--core-muted-foreground);
		line-height: 1.6;
		margin: 0;
	}

	/* Steps */
	.owners-steps__grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-card-gap);
	}

	.owners-step__num {
		font-family: var(--font-heading);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		color: var(--brand-primary-a20);
		display: block;
		margin-bottom: var(--space-3);
	}

	.owners-step__title {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: var(--text-lg);
		color: var(--core-foreground);
		margin: 0 0 var(--space-2);
	}

	.owners-step__desc {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
		line-height: 1.6;
		margin: 0;
	}

	/* FAQ */
	.owners-faq__list {
		max-width: 700px;
		margin: 0 auto;
		text-align: left;
	}

	.owners-faq__item {
		border-bottom: 1px solid var(--border);
		padding: var(--space-4) 0;
	}

	.owners-faq__question {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: var(--text-body-lg);
		color: var(--core-foreground);
		cursor: pointer;
		list-style: none;
		padding: var(--space-2) 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3);
	}

	.owners-faq__question::-webkit-details-marker { display: none; }

	.owners-faq__question::after {
		content: "";
		flex-shrink: 0;
		width: 12px;
		height: 12px;
		border-right: 2px solid currentColor;
		border-bottom: 2px solid currentColor;
		transform: rotate(45deg);
		transition: transform var(--duration-normal) ease;
	}

	.owners-faq__item[open] > .owners-faq__question::after {
		transform: rotate(-135deg);
	}

	.owners-faq__answer {
		font-family: var(--font-sans);
		font-size: var(--text-body);
		color: var(--core-muted-foreground);
		line-height: 1.6;
		padding: var(--space-2) 0 var(--space-4);
		margin: 0;
	}

	/* CTA */
	.owners-cta {
		text-align: center;
	}

	.owners-cta__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.owners-cta__tagline { color: var(--brand-accent-a80); }

	.owners-cta__title {
		color: var(--surface-dark-foreground);
		margin: 0 0 var(--space-4);
	}

	.owners-cta__desc {
		font-family: var(--font-sans);
		font-size: var(--text-body-lg);
		color: var(--surface-dark-foreground-a75);
		max-width: 55ch;
		margin: 0 auto var(--space-6);
		line-height: 1.6;
	}

	/* Benefits decoratives */
	.owners-benefits {
		position: relative;
		overflow: hidden;
	}

	.owners-benefits__decoratives {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.owners-benefits__watermark {
		position: absolute;
		bottom: -30px;
		right: -40px;
		color: var(--brand-primary);
		opacity: 0.05;
		display: inline-flex;
		transform: rotate(-12deg);
	}

	.owners-benefits__wave {
		position: absolute;
		top: 28%;
		left: -5%;
		width: 65%;
		height: 60px;
		color: var(--brand-accent);
		opacity: 0.35;
	}

	.owners-benefits__dot {
		position: absolute;
		border-radius: 50%;
	}

	.owners-benefits__dot--1 {
		top: 15%;
		left: 8%;
		width: 10px;
		height: 10px;
		background-color: var(--brand-primary-a25);
	}

	.owners-benefits__dot--2 {
		top: 22%;
		right: 12%;
		width: 14px;
		height: 14px;
		background-color: var(--brand-accent-a30);
	}

	.owners-benefits__dot--3 {
		bottom: 18%;
		left: 18%;
		width: 8px;
		height: 8px;
		background-color: var(--brand-primary-a30);
	}

	.owners-benefits__dot--4 {
		bottom: 30%;
		right: 22%;
		width: 12px;
		height: 12px;
		background-color: var(--brand-accent-a20);
	}

	.owners-benefits__container {
		position: relative;
		z-index: 1;
	}

	/* Steps path */
	.owners-steps {
		position: relative;
		overflow: hidden;
	}

	.owners-steps__grid {
		position: relative;
	}

	.owners-steps__path {
		position: absolute;
		top: 24%;
		left: 0;
		width: 100%;
		height: 80px;
		color: var(--brand-primary);
		opacity: 0.35;
		pointer-events: none;
		z-index: 0;
	}

	.owners-step {
		position: relative;
		z-index: 1;
	}

	/* FAQ watermark */
	.owners-faq {
		position: relative;
		overflow: hidden;
	}

	.owners-faq__watermark {
		position: absolute;
		top: -8%;
		right: -4%;
		font-family: var(--font-decorative);
		font-size: clamp(12rem, 22vw, 26rem);
		font-weight: 700;
		color: var(--brand-primary);
		opacity: 0.06;
		line-height: 0.85;
		pointer-events: none;
		user-select: none;
		z-index: 0;
	}

	.owners-faq__container {
		position: relative;
		z-index: 1;
	}

	/* CTA decoratives */
	.owners-cta {
		position: relative;
		overflow: hidden;
	}

	.owners-cta__decoratives {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.owners-cta__blob {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: clamp(360px, 50vw, 720px);
		height: clamp(360px, 50vw, 720px);
		border-radius: 50%;
		background: radial-gradient(
			circle at 50% 50%,
			var(--brand-accent-a20),
			var(--brand-primary-a12) 55%,
			transparent 75%
		);
		filter: blur(4px);
	}

	.owners-cta__route {
		position: absolute;
		top: 22%;
		right: 6%;
		width: clamp(140px, 18vw, 220px);
		height: clamp(48px, 6vw, 70px);
		color: var(--brand-accent);
		opacity: 0.55;
	}

	.owners-cta__pin {
		position: absolute;
		top: calc(22% + clamp(36px, 4.5vw, 52px));
		right: 5%;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background-color: var(--core-card);
		box-shadow: var(--shadow-card);
		color: var(--brand-accent);
	}

	.owners-cta__container {
		position: relative;
		z-index: 1;
	}

	@media (max-width: 900px) {
		.owners-benefits__watermark,
		.owners-benefits__wave,
		.owners-steps__path,
		.owners-cta__route,
		.owners-cta__pin {
			display: none;
		}
	}

	/* Responsive */
	@media (max-width: 768px) {
		.owners-hero__container { grid-template-columns: 1fr; }
		.owners-hero__image { order: -1; }
		.owners-benefits__grid { grid-template-columns: 1fr; }
		.owners-steps__grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 480px) {
		.owners-steps__grid { grid-template-columns: 1fr; }
	}
</style>
