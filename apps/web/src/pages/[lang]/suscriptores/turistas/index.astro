---
/**
 * @file suscriptores/turistas/index.astro
 * @description Tourist pricing page. Thin wrapper around <PricingCardsGrid>;
 * page-specific copy, metadata, and JSON-LD live here, the card UI itself
 * is shared with /suscriptores/planes/.
 *
 * Reads pricing directly from @repo/billing config (single source of truth).
 *
 * @route /{lang}/suscriptores/turistas/
 * @rendering SSG (prerender=true) — billing config lives in code; price changes
 *   ship via deploy and SSG regenerates automatically.
 */

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PricingCardsGrid from '@/components/billing/PricingCardsGrid.astro';
import PriceSpecificationJsonLd from '@/components/seo/PriceSpecificationJsonLd.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { getIntlLocale } from '@/lib/pricing-plans';
import { buildUrl } from '@/lib/urls';
import { ALL_PLANS } from '@repo/billing';
import { BeachUmbrellaIcon, CompassIcon, SunIcon } from '@repo/icons';
import type { GetStaticPaths } from 'astro';

export const prerender = true;

export const getStaticPaths = (() => {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}) satisfies GetStaticPaths;

const locale = (Astro.params.lang ?? 'es') as SupportedLocale;
const { t } = createTranslations(locale);

// Read tourist plans straight from the billing config. Same source the rest
// of the system reads from (checkout, entitlements, admin viewer).
const touristPlans = ALL_PLANS.filter((plan) => plan.category === 'tourist' && plan.isActive)
	.slice()
	.sort((a, b) => a.sortOrder - b.sortOrder);

const intlLocale = getIntlLocale(locale);
const highlightedSlug = touristPlans[1]?.slug ?? 'tourist-plus';
const hasPlans = touristPlans.length > 0;

// Build absolute URL for each plan (used by JSON-LD Offer entries).
const siteOrigin = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const planPageUrl = `${siteOrigin}${buildUrl({ locale, path: 'suscriptores/turistas' })}`;

const jsonLdPlans = touristPlans.map((plan) => ({
	name: plan.name,
	description: plan.description,
	priceCurrency: 'ARS',
	price: plan.monthlyPriceArs / 100,
	url: planPageUrl,
}));

// Split heading to underline the last word with a handwritten accent.
const headingFull = t('pricing.tourist.heading', 'Planes para turistas');
const headingWords = headingFull.trim().split(/\s+/);
const headingAccent = headingWords.pop() ?? headingFull;
const headingMain = headingWords.join(' ');
---

<MarketingLayout
	locale={locale}
	title={t('pricing.tourist.title', 'Planes para turistas')}
	description={t(
		'pricing.tourist.description',
		'Suscribite y disfrutá de beneficios exclusivos en tus viajes por el litoral.'
	)}
>
	{hasPlans && <PriceSpecificationJsonLd slot="head-extra" plans={jsonLdPlans} />}

	<section class="pricing-hero section section--warm">
		<div class="pricing-hero__decoratives" aria-hidden="true">
			<div class="pricing-hero__blob"></div>
			<div class="pricing-hero__floating pricing-hero__floating--umbrella">
				<BeachUmbrellaIcon size="md" weight="duotone" />
			</div>
			<div class="pricing-hero__floating pricing-hero__floating--compass">
				<CompassIcon size="md" weight="duotone" />
			</div>
			<div class="pricing-hero__floating pricing-hero__floating--sun">
				<SunIcon size="md" weight="duotone" />
			</div>
		</div>

		<div class="pricing-hero__container" data-reveal="up">
			<p class="pricing-hero__tagline">{t('pricing.tourist.tagline', 'Planes y precios')}</p>
			<h1 class="pricing-hero__title">
				{headingMain && <>{headingMain}{' '}</>}
				<span class="pricing-hero__title-accent">
					{headingAccent}
					<svg
						class="pricing-hero__title-underline"
						viewBox="0 0 200 18"
						preserveAspectRatio="none"
						aria-hidden="true"
					>
						<path
							d="M 4 12 Q 50 2, 100 10 T 196 8"
							stroke="currentColor"
							stroke-width="4"
							stroke-linecap="round"
							fill="none"
						/>
					</svg>
				</span>
			</h1>
			<p class="pricing-hero__subtitle">
				{t(
					'pricing.tourist.subtitle',
					'Elegí el plan que mejor se adapte a tu forma de viajar.'
				)}
			</p>
		</div>
	</section>

	<section class="pricing-cards section" aria-labelledby="pricing-cards-heading">
		<PricingCardsGrid
			locale={locale}
			plans={touristPlans}
			highlightedSlug={highlightedSlug}
			intlLocale={intlLocale}
			sectionHeading={t(
				'pricing.tourist.cardsHeading',
				'Comparativa de planes para turistas'
			)}
			emptyMessage={t('pricing.tourist.empty', 'Planes no disponibles en este momento.')}
			emptyActionUrl={buildUrl({ locale, path: 'contacto' })}
			emptyActionLabel={t('pricing.empty.contact', 'Contactanos')}
			ctaText={t('pricing.cta', 'Empezar')}
		/>
	</section>
</MarketingLayout>

<style>
	.pricing-hero {
		position: relative;
		overflow: hidden;
	}

	.pricing-hero__decoratives {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.pricing-hero__blob {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: clamp(360px, 50vw, 640px);
		height: clamp(360px, 50vw, 640px);
		border-radius: 50%;
		background: radial-gradient(
			circle at 35% 35%,
			oklch(from var(--brand-primary) l c h / 0.16),
			oklch(from var(--brand-accent) l c h / 0.08) 55%,
			transparent 75%
		);
		filter: blur(2px);
	}

	.pricing-hero__title-accent {
		position: relative;
		display: inline-block;
	}

	.pricing-hero__title-underline {
		position: absolute;
		left: -3%;
		right: -3%;
		bottom: -0.08em;
		width: 106%;
		height: 0.32em;
		color: var(--brand-accent);
		opacity: 0.75;
		pointer-events: none;
	}

	.pricing-hero__floating {
		position: absolute;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		border-radius: 50%;
		background-color: var(--core-card);
		box-shadow: var(--shadow-card);
		animation: pricing-hero-float 6s ease-in-out infinite;
	}

	.pricing-hero__floating--umbrella {
		top: 18%;
		left: clamp(4%, 8vw, 12%);
		color: var(--brand-accent);
		animation-delay: 0s;
	}

	.pricing-hero__floating--compass {
		top: 48%;
		right: clamp(4%, 7vw, 11%);
		color: var(--brand-primary);
		animation-delay: 1.5s;
	}

	.pricing-hero__floating--sun {
		bottom: 14%;
		left: clamp(8%, 12vw, 18%);
		color: oklch(0.72 0.16 75);
		animation-delay: 3s;
	}

	@keyframes pricing-hero-float {
		0%, 100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-10px);
		}
	}

	@media (max-width: 900px) {
		.pricing-hero__deco--arrow,
		.pricing-hero__floating {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.pricing-hero__floating {
			animation: none;
		}
	}

	.pricing-hero__container {
		position: relative;
		z-index: 1;
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
		text-align: center;
	}

	.pricing-hero__tagline {
		font-family: var(--font-decorative);
		font-size: clamp(1.1rem, 2.5vw, 1.4rem);
		color: var(--brand-accent);
		font-style: italic;
		margin: 0 0 var(--space-2);
	}

	.pricing-hero__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		color: var(--core-foreground);
		margin: 0 0 var(--space-4);
	}

	.pricing-hero__subtitle {
		font-family: var(--font-sans);
		font-size: var(--text-body-lg);
		color: var(--core-muted-foreground);
		max-width: 50ch;
		margin: 0 auto;
	}
</style>
