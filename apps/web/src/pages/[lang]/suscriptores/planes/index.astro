---
/**
 * @file suscriptores/planes/index.astro
 * @description Owner pricing page. Thin wrapper around <PricingCardsGrid>;
 * page-specific copy, metadata, and JSON-LD live here, the card UI itself
 * is shared with /suscriptores/turistas/.
 *
 * Fetches pricing from the public API at runtime (SSR) so that operator
 * price edits in admin are reflected without a site redeploy (SPEC-168 D3).
 * Cache-Control: s-maxage=300, stale-while-revalidate=60 lets Cloudflare
 * serve cached HTML for up to 5 minutes while revalidating in the background.
 * T-017 will add a Cloudflare cache purge on plan save to force immediate
 * refresh after an admin edit.
 *
 * @route /{lang}/suscriptores/planes/
 * @rendering SSR (prerender=false) — fetches /api/v1/public/plans at request
 *   time; Cache-Control: s-maxage=300, stale-while-revalidate=60.
 */

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import MarketingHero from '@/components/marketing/MarketingHero.astro';
import PricingCardsGrid from '@/components/billing/PricingCardsGrid.astro';
import PriceSpecificationJsonLd from '@/components/seo/PriceSpecificationJsonLd.astro';
import GradientButton from '@/components/shared/ui/GradientButton.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { getIntlLocale } from '@/lib/pricing-plans';
import { buildUrl } from '@/lib/urls';
import {
	fetchPublicPlans,
	filterPlansByCategory,
	PRICING_CACHE_MAX_AGE_SECONDS,
	PRICING_CACHE_SWR_SECONDS,
} from '@/lib/billing/fetch-plans';
import { BarChartIcon, BuildingIcon, StarIcon } from '@repo/icons';

export const prerender = false;

const locale = (Astro.params.lang ?? 'es') as SupportedLocale;
const { t } = createTranslations(locale);

// Set Cache-Control so Cloudflare caches the rendered HTML at the CDN edge.
// s-maxage=300: serve from cache for up to 5 minutes.
// stale-while-revalidate=60: revalidate in the background while serving stale.
// T-017 adds a targeted purge on plan save for immediate invalidation.
Astro.response.headers.set(
	'Cache-Control',
	`s-maxage=${PRICING_CACHE_MAX_AGE_SECONDS}, stale-while-revalidate=${PRICING_CACHE_SWR_SECONDS}`
);

// Fetch active plans from the public API endpoint at runtime.
const fetchResult = await fetchPublicPlans();
const ownerPlans = fetchResult.ok
	? filterPlansByCategory(fetchResult.plans, 'owner')
	: [];

const intlLocale = getIntlLocale(locale);
const highlightedSlug = ownerPlans[1]?.slug ?? 'owner-pro';
const hasPlans = ownerPlans.length > 0;

// Build absolute URL for each plan (used by JSON-LD Offer entries).
const siteOrigin = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const planPageUrl = `${siteOrigin}${buildUrl({ locale, path: 'suscriptores/planes' })}`;

const jsonLdPlans = ownerPlans.map((plan) => ({
	name: plan.name,
	description: plan.description,
	priceCurrency: 'ARS',
	// schema.org `price` expects major currency units (pesos), not cents.
	price: plan.monthlyPriceArs / 100,
	url: planPageUrl,
}));

// Split heading to underline the last word with a handwritten accent.
const headingFull = t('pricing.owner.heading', 'Planes para propietarios');
const headingWords = headingFull.trim().split(/\s+/);
const headingAccent = headingWords.pop() ?? headingFull;
const headingMain = headingWords.join(' ');
---

<MarketingLayout
	locale={locale}
	title={t('pricing.owner.title', 'Planes para propietarios')}
	description={t(
		'pricing.owner.description',
		'Publicá tu alojamiento con el plan que mejor se adapte a tu negocio.'
	)}
>
	{hasPlans && <PriceSpecificationJsonLd slot="head-extra" plans={jsonLdPlans} />}

	<MarketingHero
		tagline={t('pricing.owner.tagline', 'Planes y precios')}
		titleMain={headingMain}
		titleAccent={headingAccent}
		subtitle={t(
			'pricing.owner.subtitle',
			'Elegí el plan que mejor se adapte a tu propiedad y objetivos.'
		)}
	>
		<Fragment slot="icon-1"><BuildingIcon size="md" weight="duotone" /></Fragment>
		<Fragment slot="icon-2"><StarIcon size="md" weight="duotone" /></Fragment>
		<Fragment slot="icon-3"><BarChartIcon size="md" weight="duotone" /></Fragment>
	</MarketingHero>

	<section class="pricing-cards section" aria-labelledby="pricing-cards-heading">
		<PricingCardsGrid
			locale={locale}
			plans={ownerPlans}
			highlightedSlug={highlightedSlug}
			intlLocale={intlLocale}
			sectionHeading={t(
				'pricing.owner.cardsHeading',
				'Comparativa de planes para propietarios'
			)}
			emptyMessage={t('pricing.owner.empty', 'Planes no disponibles en este momento.')}
			emptyActionUrl={buildUrl({ locale, path: 'contacto' })}
			emptyActionLabel={t('pricing.empty.contact', 'Contactanos')}
			ctaText={t('pricing.cta', 'Empezar')}
		/>
	</section>

	<section class="comparison-link section">
		<div class="comparison-link__container">
			<GradientButton
				href={buildUrl({ locale, path: 'suscriptores/planes/comparar' })}
				label={t('pricing.comparison.link', 'Ver comparativa detallada')}
				variant="outline-primary"
				icon="true"
			/>
		</div>
	</section>
</MarketingLayout>

<style>
	.comparison-link__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
		text-align: center;
	}
</style>
