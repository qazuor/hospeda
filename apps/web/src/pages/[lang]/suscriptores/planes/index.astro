---
/**
 * @file suscriptores/planes/index.astro
 * @description Owner pricing page showing owner plan cards.
 * Reads pricing directly from @repo/billing config (single source of truth).
 * @route /{lang}/suscriptores/planes/
 * @rendering SSG (prerender=true) — billing config lives in code; price changes
 *   ship via deploy and SSG regenerates automatically.
 */

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { PlanPurchaseButton } from '@/components/billing/PlanPurchaseButton.client';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import PriceSpecificationJsonLd from '@/components/seo/PriceSpecificationJsonLd.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { ALL_PLANS } from '@repo/billing';
import { getEntitlementName, getPlanDescription, getPlanName } from '@/lib/billing-i18n';
import type { GetStaticPaths } from 'astro';

export const prerender = true;

export const getStaticPaths = (() => {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}) satisfies GetStaticPaths;

const lang = (Astro.params.lang ?? 'es') as SupportedLocale;
const locale = lang;
const { t } = createTranslations(locale);

// Read owner plans straight from the billing config. This is the same source
// every other consumer (checkout, entitlements, admin viewer) reads from, so
// what we display here is what gets charged.
const ownerPlans = ALL_PLANS
	.filter((plan) => plan.category === 'owner' && plan.isActive)
	.slice()
	.sort((a, b) => a.sortOrder - b.sortOrder);

// ─── Price formatting ──────────────────────────────────────────────────────

/**
 * Format ARS cents to a locale-aware currency string.
 * e.g. 3_500_000 → "$ 35.000" for es-AR
 */
function formatPriceArs(cents: number, displayLocale: string): string {
	const pesos = cents / 100;
	try {
		return new Intl.NumberFormat(displayLocale, {
			style: 'currency',
			currency: 'ARS',
			maximumFractionDigits: 0,
			minimumFractionDigits: 0,
		}).format(pesos);
	} catch {
		return `$${pesos.toLocaleString('es-AR')}`;
	}
}

// Map locale param to BCP47 tag for Intl
const BCP47_MAP: Record<SupportedLocale, string> = {
	es: 'es-AR',
	en: 'en-AR',
	pt: 'pt-BR',
};
const intlLocale = BCP47_MAP[locale] ?? 'es-AR';

// Highlighted plan is the second one (owner-pro / index 1) by convention
const highlightedSlug = ownerPlans[1]?.slug ?? 'owner-pro';

const ctaText = t('pricing.cta', 'Empezar');
const periodLabel = t('pricing.owner.period', '/mes');

// Build absolute URL for each plan (used by JSON-LD Offer entries).
const siteOrigin = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const planPageUrl = `${siteOrigin}${buildUrl({ locale, path: 'suscriptores/planes' })}`;

const jsonLdPlans = ownerPlans.map((plan) => ({
	name: plan.name,
	description: plan.description,
	priceCurrency: 'ARS',
	// schema.org `price` expects major currency units (pesos), not cents.
	price: plan.monthlyPriceArs / 100,
	url: planPageUrl
}));

const hasPlans = ownerPlans.length > 0;
---

<MarketingLayout
	locale={locale}
	title={t('pricing.owner.title', 'Planes para propietarios')}
	description={t('pricing.owner.description', 'Publicá tu alojamiento con el plan que mejor se adapte a tu negocio.')}
>
	{hasPlans && <PriceSpecificationJsonLd slot="head-extra" plans={jsonLdPlans} />}

	<section class="pricing-hero section section--warm">
		<div class="pricing-hero__container" data-reveal="up">
			<p class="pricing-hero__tagline">{t('pricing.owner.tagline', 'Planes y precios')}</p>
			<h1 class="pricing-hero__title">{t('pricing.owner.heading', 'Planes para propietarios')}</h1>
			<p class="pricing-hero__subtitle">
				{t('pricing.owner.subtitle', 'Elegí el plan que mejor se adapte a tu propiedad y objetivos.')}
			</p>
		</div>
	</section>

	<section class="pricing-cards section" aria-labelledby="pricing-cards-heading">
		<div class="pricing-cards__container">
			<h2 id="pricing-cards-heading" class="sr-only">
				{t('pricing.owner.cardsHeading', 'Comparativa de planes para propietarios')}
			</h2>
			{!hasPlans ? (
				<EmptyState
					locale={locale}
					variant="empty"
					message={t('pricing.owner.empty', 'Planes no disponibles en este momento.')}
					actionUrl={buildUrl({ locale, path: 'contacto' })}
					actionLabel={t('pricing.empty.contact', 'Contactanos')}
				/>
			) : (
			<div class="pricing-cards__grid">
				{ownerPlans.map((plan, i) => {
					const isHighlighted = plan.slug === highlightedSlug;
					const formattedPrice = plan.monthlyPriceArs === 0
						? t('pricing.free', 'Gratis')
						: formatPriceArs(plan.monthlyPriceArs, intlLocale);

					return (
						<div
							class:list={['pricing-card', { 'pricing-card--highlighted': isHighlighted }]}
							data-reveal="up"
							data-recommended-label={isHighlighted ? t('pricing.recommended', 'Recomendado') : null}
							style={`transition-delay: ${i * 100}ms`}
						>
							<h3 class="pricing-card__name">{getPlanName({ plan, t })}</h3>
							<p class="pricing-card__desc">{getPlanDescription({ plan, t })}</p>
							<div class="pricing-card__price">
								<span class="pricing-card__amount">
									{formattedPrice}
								</span>
								{plan.monthlyPriceArs > 0 && (
									<span class="pricing-card__period">{periodLabel}</span>
								)}
							</div>
							{plan.hasTrial && plan.trialDays > 0 && (
								<p class="pricing-card__trial">
									{t('pricing.trial', '{days} días gratis').replace(
										'{days}',
										String(plan.trialDays)
									)}
								</p>
							)}
							{plan.entitlements.length > 0 && (
								<ul class="pricing-card__features" aria-label={t('pricing.features.label', 'Incluye')}>
									{plan.entitlements.map((entitlementKey) => (
										<li class="pricing-card__feature">
											<svg
												class="pricing-card__feature-icon"
												xmlns="http://www.w3.org/2000/svg"
												width="18"
												height="18"
												viewBox="0 0 24 24"
												fill="none"
												aria-hidden="true"
											>
												<path
													d="M5 12.5l4.5 4.5L19 7"
													stroke="currentColor"
													stroke-width="2.5"
													stroke-linecap="round"
													stroke-linejoin="round"
												/>
											</svg>
											<span>{getEntitlementName({ key: entitlementKey, t })}</span>
										</li>
									))}
								</ul>
							)}
							<div class="pricing-card__btn-wrapper">
								<PlanPurchaseButton
									client:load
									planId={plan.slug}
									price={plan.monthlyPriceArs}
									currency="ARS"
									ctaText={ctaText}
									locale={locale}
								/>
							</div>
						</div>
					);
				})}
			</div>
			)}
		</div>
	</section>
</MarketingLayout>

<style>
	.pricing-hero__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
		text-align: center;
	}

	.pricing-hero__tagline {
		font-family: var(--font-decorative);
		font-size: clamp(1.1rem, 2.5vw, 1.4rem);
		color: var(--brand-accent);
		font-style: italic;
		margin: 0 0 var(--space-2);
	}

	.pricing-hero__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		color: var(--core-foreground);
		margin: 0 0 var(--space-4);
	}

	.pricing-hero__subtitle {
		font-family: var(--font-sans);
		font-size: var(--text-body-lg);
		color: var(--core-muted-foreground);
		max-width: 50ch;
		margin: 0 auto;
	}

	.pricing-cards__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.pricing-cards__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-card-gap);
		align-items: stretch;
		max-width: 1140px;
		margin: 0 auto;
	}

	.pricing-card {
		background-color: var(--core-card);
		border-radius: var(--radius-card);
		padding: var(--space-8);
		box-shadow: var(--shadow-card);
		border: 2px solid transparent;
		display: flex;
		flex-direction: column;
		transition:
			transform var(--duration-normal) ease,
			box-shadow var(--duration-normal) ease,
			border-color var(--duration-normal) ease;
	}

	.pricing-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-card-hover);
	}

	.pricing-card--highlighted {
		border-color: var(--brand-accent);
		transform: scale(1.02);
		position: relative;
	}

	.pricing-card--highlighted:hover {
		transform: scale(1.02) translateY(-4px);
	}

	.pricing-card--highlighted::before {
		content: attr(data-recommended-label);
		position: absolute;
		top: calc(var(--space-3) * -1);
		left: 50%;
		transform: translateX(-50%);
		background-color: var(--brand-accent);
		color: var(--accent-foreground);
		font-family: var(--font-sans);
		font-weight: 600;
		font-size: var(--text-caption);
		padding: var(--space-1) var(--space-3);
		border-radius: var(--radius-pill);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.pricing-card__name {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: var(--text-xl);
		color: var(--core-foreground);
		margin: 0 0 var(--space-2);
	}

	.pricing-card__desc {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
		margin: 0 0 var(--space-4);
	}

	.pricing-card__price { margin-bottom: var(--space-4); }

	.pricing-card__amount {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		color: var(--core-foreground);
	}

	.pricing-card__period {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
		margin-left: var(--space-1);
	}

	.pricing-card__trial {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--brand-accent);
		font-weight: 600;
		margin: 0 0 var(--space-4);
	}

	.pricing-card__features {
		list-style: none;
		padding: 0;
		margin: 0 0 var(--space-6);
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		flex-grow: 1;
	}

	.pricing-card__feature {
		display: flex;
		align-items: flex-start;
		gap: var(--space-2);
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-foreground);
		line-height: 1.5;
	}

	.pricing-card__feature-icon {
		flex-shrink: 0;
		color: var(--success);
		margin-top: 2px;
	}

	.pricing-card__btn-wrapper {
		display: flex;
		justify-content: center;
		margin-top: auto;
	}

	@media (max-width: 768px) {
		.pricing-cards__grid {
			grid-template-columns: 1fr;
			max-width: 400px;
			margin: 0 auto;
		}
		.pricing-card--highlighted { transform: none; }
	}
</style>
