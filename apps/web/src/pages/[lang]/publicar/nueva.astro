---
/**
 * @file publicar/nueva.astro
 * @description New property creation page. Mounts the CreatePropertyMiniForm
 * island so authenticated hosts can spin up a draft accommodation with the
 * minimum required fields. After the draft is created the host is redirected
 * to the admin panel edit page to complete the rest of the listing.
 *
 * Auth protection: middleware does NOT auto-protect /publicar/* (it's not in
 * PROTECTED_SEGMENTS), so this page does its own in-page auth guard, same
 * pattern as /mi-cuenta/*.
 *
 * @route    /{lang}/publicar/nueva/
 * @rendering SSR (prerender = false — requires authenticated user)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildLoginRedirect } from '@/lib/middleware-helpers';
import { buildUrl } from '@/lib/urls';
import { getAdminUrlOrThrow, getApiUrl } from '@/lib/env';
import { webLogger as logger } from '@/lib/logger';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { CreatePropertyMiniForm } from '@/components/host/CreatePropertyMiniForm.client';
import {
    BuildingsIcon,
    ImageIcon,
    FileTextIcon,
    CheckCircleIcon
} from '@repo/icons';

export const prerender = false;

const locale = Astro.locals.locale as SupportedLocale;

// Auth guard (middleware doesn't cover /publicar/*).
const user = Astro.locals.user;
if (!user) {
    return Astro.redirect(
        buildLoginRedirect({ locale, currentUrl: Astro.url.pathname })
    );
}

const t = createT(locale);

const pageTitle = t('host.pages.nueva.title', 'Nueva propiedad');
const pageDescription = t(
    'host.pages.nueva.description',
    'Publicá tu alojamiento en Hospeda y llegá a miles de viajeros.'
);

// Public env vars are safe to send to the client island.
const apiUrl = import.meta.env.PUBLIC_API_URL as string;
const adminUrl = getAdminUrlOrThrow();

// Resolve admin panel access server-side so the form can branch the
// post-create redirect: HOST users without `access.panelAdmin` would
// otherwise land on /auth/forbidden after being sent to /admin/*.
let canAccessAdminPanel = false;
try {
    const cookieHeader = Astro.request.headers.get('cookie');
    if (cookieHeader) {
        const meResponse = await fetch(`${getApiUrl()}/api/v1/public/auth/me`, {
            headers: { cookie: cookieHeader }
        });
        if (meResponse.ok) {
            const json = (await meResponse.json()) as {
                data?: { actor?: { permissions?: ReadonlyArray<string> } };
            };
            const permissions = json.data?.actor?.permissions ?? [];
            canAccessAdminPanel = permissions.includes('access.panelAdmin');
        }
    }
} catch (error) {
    logger.warn({ error }, 'publicar/nueva: failed to resolve admin panel access');
}

const accountPropertiesUrl = buildUrl({ locale, path: 'mi-cuenta/propiedades' });
---

<MarketingLayout
    locale={locale}
    title={pageTitle}
    description={pageDescription}
>
    <section class="nueva-hero nueva-hero--compact section section--warm">
        <div class="nueva-hero__decoratives" aria-hidden="true">
            <img
                src="/assets/images/shapes/deco-arrow-1.svg"
                alt=""
                class="nueva-hero__deco nueva-hero__deco--arrow"
                loading="eager"
            />
        </div>

        <div class="nueva-hero__container">
            <div class="nueva-hero__text">
                <nav
                    class="nueva-hero__breadcrumb"
                    aria-label={t('host.pages.nueva.breadcrumbLabel', 'Ruta de navegación')}
                >
                    <a
                        href={buildUrl({ locale, path: 'publicar' })}
                        class="nueva-hero__breadcrumb-link"
                    >
                        {t('owners.hero.tagline', 'Para propietarios')}
                    </a>
                    <span class="nueva-hero__breadcrumb-sep" aria-hidden="true">/</span>
                    <span class="nueva-hero__breadcrumb-current" aria-current="page">
                        {pageTitle}
                    </span>
                </nav>

                <p class="nueva-hero__tagline">
                    {t('host.pages.nueva.tagline', 'Empecemos')}
                </p>
                <h1 class="nueva-hero__title">{pageTitle}</h1>
                <p class="nueva-hero__desc">
                    {t(
                        'host.pages.nueva.subtitle',
                        'Empezá con lo esencial. Después completás todos los detalles desde el panel.'
                    )}
                </p>
            </div>

            <aside class="nueva-hero__visual" aria-hidden="true">
                <div class="nueva-hero__blob"></div>
                <div class="nueva-hero__icon-wrap">
                    <BuildingsIcon size={96} weight="duotone" />
                </div>
                <div class="nueva-hero__floating nueva-hero__floating--image">
                    <ImageIcon size="md" weight="duotone" />
                </div>
                <div class="nueva-hero__floating nueva-hero__floating--text">
                    <FileTextIcon size="md" weight="duotone" />
                </div>
                <div class="nueva-hero__floating nueva-hero__floating--check">
                    <CheckCircleIcon size="md" weight="duotone" />
                </div>
            </aside>
        </div>
    </section>

    <section class="nueva-form nueva-form--compact section">
        <div class="nueva-form__container">
            <CreatePropertyMiniForm
                client:load
                locale={locale}
                apiUrl={apiUrl}
                adminUrl={adminUrl}
                accountPropertiesUrl={accountPropertiesUrl}
                canAccessAdminPanel={canAccessAdminPanel}
            />
        </div>
    </section>
</MarketingLayout>

<style>
    /* ── Hero ──────────────────────────────────────────────────────────── */
    .nueva-hero {
        position: relative;
        overflow: hidden;
    }

    /*
     * The "nueva" page is form-first: the hero is context, not the headline.
     * Override .section's generous padding-block so the form is visible
     * above the fold on standard laptop viewports without scrolling.
     *
     * The padding window is tuned to land close to (but still a notch below)
     * the `/publicar/` hero so navigating between both pages doesn't feel
     * like a height "jump" in the vertical rhythm.
     */
    .nueva-hero--compact {
        padding-block: clamp(2rem, 5.5vw, 4rem);
    }

    .nueva-hero__decoratives {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .nueva-hero__deco--arrow {
        position: absolute;
        top: clamp(18%, 22%, 28%);
        right: clamp(2%, 4vw, 6%);
        width: clamp(60px, 8vw, 110px);
        height: auto;
        opacity: 0.5;
        transform: rotate(15deg);
    }

    @media (max-width: 900px) {
        .nueva-hero__deco--arrow { display: none; }
    }

    .nueva-hero__container {
        position: relative;
        z-index: 1;
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--space-container-x);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-6);
        align-items: center;
    }

    .nueva-hero__breadcrumb {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        margin-bottom: var(--space-4);
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
    }

    .nueva-hero__breadcrumb-link {
        color: var(--brand-primary);
        text-decoration: none;
        transition: color var(--duration-fast) ease;
    }

    .nueva-hero__breadcrumb-link:hover {
        color: var(--brand-accent);
        text-decoration: underline;
    }

    .nueva-hero__breadcrumb-sep {
        color: var(--border);
    }

    .nueva-hero__breadcrumb-current {
        color: var(--core-muted-foreground);
    }

    .nueva-hero__tagline {
        font-family: var(--font-decorative);
        font-weight: 700;
        font-size: var(--text-tagline);
        color: var(--brand-accent);
        margin: 0 0 var(--space-2);
    }

    .nueva-hero__title {
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: var(--text-h2);
        color: var(--core-foreground);
        margin: 0 0 var(--space-3);
        line-height: 1.15;
        text-wrap: balance;
    }

    .nueva-hero__desc {
        font-family: var(--font-sans);
        font-size: var(--text-body-lg);
        color: var(--core-muted-foreground);
        line-height: 1.6;
        margin: 0;
        max-width: 60ch;
    }

    /* ── Hero visual aside ─────────────────────────────────────────────── */
    .nueva-hero__visual {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 280px;
    }

    .nueva-hero__blob {
        position: absolute;
        inset: 0;
        margin: auto;
        width: clamp(220px, 24vw, 340px);
        height: clamp(220px, 24vw, 340px);
        border-radius: 50%;
        background: radial-gradient(
            circle at 30% 30%,
            oklch(from var(--brand-primary) l c h / 0.18),
            oklch(from var(--brand-accent) l c h / 0.08) 60%,
            transparent 75%
        );
        filter: blur(2px);
    }

    .nueva-hero__icon-wrap {
        position: relative;
        z-index: 2;
        width: clamp(120px, 13vw, 170px);
        height: clamp(120px, 13vw, 170px);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background-color: var(--core-card);
        border-radius: 50%;
        box-shadow: var(--shadow-card);
        color: var(--brand-primary);
    }

    .nueva-hero__floating {
        position: absolute;
        z-index: 3;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background-color: var(--core-card);
        box-shadow: var(--shadow-card);
        animation: nueva-float 6s ease-in-out infinite;
    }

    .nueva-hero__floating--image {
        top: 10%;
        left: 6%;
        color: var(--brand-primary);
        animation-delay: 0s;
    }

    .nueva-hero__floating--text {
        bottom: 16%;
        left: 2%;
        color: var(--brand-accent);
        animation-delay: 1.5s;
    }

    .nueva-hero__floating--check {
        top: 18%;
        right: 4%;
        color: oklch(0.65 0.18 145);
        animation-delay: 3s;
    }

    @keyframes nueva-float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    @media (prefers-reduced-motion: reduce) {
        .nueva-hero__floating { animation: none; }
    }

    /* ── Form section ──────────────────────────────────────────────────── */
    .nueva-form--compact {
        padding-block: clamp(var(--space-6), 5vw, var(--space-10));
    }

    .nueva-form__container {
        max-width: var(--container-max);
        margin: 0 auto;
        padding: 0 var(--space-container-x);
    }

    /* ── Responsive ────────────────────────────────────────────────────── */
    @media (max-width: 768px) {
        .nueva-hero__container { grid-template-columns: 1fr; }
        .nueva-hero__visual { order: -1; min-height: 240px; }
    }
</style>
