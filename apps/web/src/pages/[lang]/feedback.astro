---
/**
 * Standalone feedback page - crash-resistant, minimal layout.
 *
 * Intentionally avoids BaseLayout, Header, Footer and heavy dependencies
 * so it remains functional even if the main app shell is broken.
 *
 * The FeedbackForm reads window.location.search client-side to pre-fill
 * fields from query params (e.g. ?type=bug&title=...).
 *
 * Rendering: SSR (output: 'server' - no prerender needed)
 * Route: /[lang]/feedback/
 */
import { FeedbackForm, parseFeedbackParams } from '@repo/feedback';
import type { ReportTypeId } from '@repo/feedback';
import { getLocaleFromParams } from '../../lib/page-helpers';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/feedback/');

const apiUrl = import.meta.env.PUBLIC_API_URL;

// Read query params server-side for pre-filling the form
const params = parseFeedbackParams(Astro.url.searchParams.toString());
const prefillData = (params.type || params.title || params.description || params.error) ? {
    type: params.type as ReportTypeId | undefined,
    title: params.title,
    description: params.description,
    errorInfo: params.error ? { message: params.error, stack: params.stack } : undefined
} : undefined;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Reportar un problema - Hospeda</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background-color: #f8fafc;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        color: #1e293b;
      }
      .container {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        padding: 32px;
        max-width: 640px;
        width: 100%;
      }
      .header {
        text-align: center;
        margin-bottom: 24px;
      }
      .header h1 {
        font-size: 20px;
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 8px;
      }
      .header p {
        font-size: 14px;
        color: #64748b;
        line-height: 1.5;
      }
      .fallback {
        text-align: center;
        padding: 40px 20px;
        font-size: 14px;
        color: #64748b;
        line-height: 1.6;
      }
      .fallback a {
        color: #2563eb;
        text-decoration: underline;
      }
      .back-link {
        display: inline-block;
        margin-top: 24px;
        font-size: 13px;
        color: #64748b;
        text-decoration: none;
        transition: color 0.15s ease;
      }
      .back-link:hover {
        color: #2563eb;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Reportar un problema</h1>
        <p>Ayudanos a mejorar reportando cualquier problema que encuentres.</p>
      </div>

      <FeedbackForm
        client:load
        apiUrl={apiUrl}
        appSource="standalone"
        prefillData={prefillData}
      />

      <noscript>
        <div class="fallback">
          <p>Esta pagina requiere JavaScript habilitado.</p>
          <p>
            Si no podes usarla, envia un email a{' '}
            <a href="mailto:feedback@hospeda.com">feedback@hospeda.com</a>
          </p>
        </div>
      </noscript>

      <a href={`/${locale}/`} class="back-link">← Volver al inicio</a>
    </div>
  </body>
</html>
