---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../lib/page-helpers';

/**
 * Benefits page - showcases benefits for tourists and property owners.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Container from '../../components/ui/Container.astro';
import Section from '../../components/ui/Section.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../lib/page-helpers';
import { t } from '../../lib/i18n';
import { HomeIcon, ShieldIcon, LocationIcon, StarIcon, InfoIcon, UserIcon, CheckIcon, UsersIcon } from '@repo/icons';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const title = t({ locale, namespace: 'benefits', key: 'page.title' });
const description = t({ locale, namespace: 'benefits', key: 'page.description' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: title, href: `/${locale}/beneficios/` },
];
---

<BaseLayout title={title} description={description} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- Hero Section -->
				<article id="hero" class="mb-12 text-center">
					<h1 class="mb-6 text-4xl font-bold text-text-primary md:text-5xl">
						{title}
					</h1>
					<p class="text-xl leading-relaxed text-text-secondary">
						Hospeda conecta viajeros con alojamientos auténticos y apoya a propietarios con
						herramientas profesionales. Descubre los beneficios de formar parte de nuestra
						comunidad.
					</p>
				</article>

				<!-- Benefits for Tourists Section -->
				<article id="tourist-benefits" class="mb-16">
					<h2 class="mb-8 text-center text-3xl font-semibold text-text-primary">
						Beneficios para Turistas
					</h2>
					<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
						<!-- Benefit 1: Wide Selection -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<HomeIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">
								Amplia Selección Verificada
							</h3>
							<p class="text-text-secondary">
								Accede a una variedad de alojamientos verificados y de calidad en Concepción
								del Uruguay y la región del Litoral argentino.
							</p>
						</div>

						<!-- Benefit 2: Secure Booking -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<ShieldIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">
								Reservas y Pagos Seguros
							</h3>
							<p class="text-text-secondary">
								Sistema de reservas confiable con pagos seguros a través de MercadoPago. Tu
								información está protegida en todo momento.
							</p>
						</div>

						<!-- Benefit 3: Authentic Experiences -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<LocationIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">
								Experiencias Locales Auténticas
							</h3>
							<p class="text-text-secondary">
								Descubre alojamientos que reflejan la cultura y hospitalidad local. Vive
								experiencias genuinas en cada estadía.
							</p>
						</div>

						<!-- Benefit 4: Real Reviews -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<StarIcon size={32} className="text-primary" weight="regular" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">
								Reseñas Reales de Viajeros
							</h3>
							<p class="text-text-secondary">
								Lee opiniones auténticas de otros viajeros. Toma decisiones informadas basadas
								en experiencias reales.
							</p>
						</div>

						<!-- Benefit 5: Customer Support -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<InfoIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">Soporte al Cliente</h3>
							<p class="text-text-secondary">
								Equipo de soporte dedicado para ayudarte antes, durante y después de tu
								estadía. Estamos aquí para ti.
							</p>
						</div>
					</div>
				</article>

				<!-- Benefits for Property Owners Section -->
				<article id="owner-benefits" class="mb-16">
					<h2 class="mb-8 text-center text-3xl font-semibold text-text-primary">
						Beneficios para Propietarios
					</h2>
					<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
						<!-- Benefit 1: Increased Visibility -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<UserIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">
								Mayor Visibilidad
							</h3>
							<p class="text-text-secondary">
								Alcanza a miles de viajeros que buscan alojamientos en la región. Aumenta tus
								reservas con nuestra plataforma optimizada.
							</p>
						</div>

						<!-- Benefit 2: Easy Management -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<CheckIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">
								Gestión Fácil de Propiedades
							</h3>
							<p class="text-text-secondary">
								Panel de administración intuitivo para gestionar reservas, disponibilidad,
								precios y comunicación con huéspedes.
							</p>
						</div>

						<!-- Benefit 3: Secure Payments -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<ShieldIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">
								Pagos Seguros vía MercadoPago
							</h3>
							<p class="text-text-secondary">
								Recibe pagos de forma segura y confiable. Integración directa con MercadoPago
								para transacciones protegidas.
							</p>
						</div>

						<!-- Benefit 4: Analytics -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<InfoIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">
								Análisis e Informes
							</h3>
							<p class="text-text-secondary">
								Accede a métricas detalladas sobre tus reservas, ocupación y rendimiento.
								Toma decisiones basadas en datos.
							</p>
						</div>

						<!-- Benefit 5: Growing Community -->
						<div class="flex flex-col items-center text-center">
							<div
								class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10"
							>
								<UsersIcon size={32} className="text-primary" aria-hidden="true" />
							</div>
							<h3 class="mb-2 text-xl font-semibold text-text-primary">
								Comunidad en Crecimiento
							</h3>
							<p class="text-text-secondary">
								Forma parte de una red en expansión de propietarios y viajeros. Participa en
								eventos y capacitaciones exclusivas.
							</p>
						</div>
					</div>
				</article>

				<!-- CTA Section -->
				<article id="cta-section" class="mb-12">
					<div
						class="rounded-lg bg-primary/10 p-8 text-center shadow-sm transition-shadow hover:shadow-md"
					>
						<h2 class="mb-4 text-3xl font-semibold text-text-primary">
							Descubre Nuestros Planes
						</h2>
						<p class="mb-8 text-lg leading-relaxed text-text-secondary">
							Explora los planes y precios diseñados para turistas y propietarios. Encuentra
							la opción perfecta para ti.
						</p>
						<div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
							<a
								href={`/${locale}/precios-turistas/`}
								class="inline-block rounded-lg bg-primary px-8 py-3 font-semibold text-white transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
							>
								Ver precios para turistas
							</a>
							<a
								href={`/${locale}/precios-propietarios/`}
								class="inline-block rounded-lg border-2 border-primary bg-white px-8 py-3 font-semibold text-primary transition-colors hover:bg-primary hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
							>
								Ver precios para propietarios
							</a>
						</div>
					</div>
				</article>
			</div>
		</Section>
	</Container>
</BaseLayout>
