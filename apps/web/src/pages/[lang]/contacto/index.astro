---
/**
 * @file contacto/index.astro
 * @description Contact page with contact form placeholder.
 * @route /{lang}/contacto/
 * @rendering SSG (prerender)
 */

import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { ContactForm } from '@/components/ContactForm.client';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import type { GetStaticPaths } from 'astro';

export const prerender = true;

export const getStaticPaths = (() => {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const locale = lang as SupportedLocale;
const { t } = createTranslations(locale);
---

<DefaultLayout
	locale={locale}
	title={t('contact.title', 'Contacto')}
	description={t('contact.description', 'Contactate con el equipo de Hospeda. Estamos para ayudarte.')}
>
	<section class="contact-page section">
		<div class="contact-page__container">
			<p class="contact-page__tagline" data-reveal="up">{t('contact.tagline', 'Escribinos')}</p>
			<h1 class="contact-page__title" data-reveal="up">{t('contact.heading', 'Contacto')}</h1>
			<p class="contact-page__subtitle" data-reveal="up">
				{t('contact.subtitle', '¿Tenés alguna consulta o sugerencia? Completá el formulario y te responderemos a la brevedad.')}
			</p>

			<div class="contact-page__form-area" data-reveal="up">
				<ContactForm locale={locale} client:visible />
			</div>

			<div class="contact-page__info" data-reveal="up">
				<p class="contact-page__info-item">
					<strong>{t('contact.email.label', 'Email')}:</strong>
					<a class="contact-page__info-link" href={`mailto:${t('contact.email.value', 'info@hospeda.com')}`}>
						{t('contact.email.value', 'info@hospeda.com')}
					</a>
				</p>
				<p class="contact-page__info-item">
					<strong>{t('contact.phone.label', 'Teléfono')}:</strong>
					<a class="contact-page__info-link" href={`tel:${t('contact.phone.value', '+54 3442 453797').replace(/\s/g, '')}`}>
						{t('contact.phone.value', '+54 3442 453797')}
					</a>
				</p>
			</div>
		</div>
	</section>
</DefaultLayout>

<style>
	.contact-page__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
		text-align: center;
	}

	.contact-page__tagline {
		font-family: var(--font-decorative);
		font-size: var(--text-tagline);
		color: var(--brand-accent);
		font-style: italic;
		margin: 0 0 var(--space-2, 0.5rem);
	}

	.contact-page__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: var(--text-h2);
		color: var(--core-foreground);
		margin: 0 0 var(--space-4, 1rem);
	}

	.contact-page__subtitle {
		font-family: var(--font-sans);
		font-size: var(--text-body);
		color: var(--core-muted-foreground);
		max-width: 55ch;
		margin: 0 auto var(--space-8, 2rem);
		line-height: 1.6;
	}

	.contact-page__form-area {
		max-width: 640px;
		margin: 0 auto var(--space-8, 2rem);
	}

	.contact-page__info {
		display: flex;
		gap: var(--space-6, 1.5rem);
		justify-content: center;
		flex-wrap: wrap;
	}

	.contact-page__info-item {
		font-family: var(--font-sans);
		font-size: var(--text-body);
		color: var(--core-foreground);
		margin: 0;
	}

	.contact-page__info-link {
		color: var(--brand-primary);
		text-decoration: none;
		margin-left: var(--space-2, 0.5rem);
		transition: color var(--duration-fast) ease;
	}

	.contact-page__info-link:hover,
	.contact-page__info-link:focus-visible {
		color: var(--brand-accent);
		text-decoration: underline;
	}
</style>
