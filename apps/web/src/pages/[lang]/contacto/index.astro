---
/**
 * @file contacto/index.astro
 * @description Contact page: hero with form, channels, location & hours, FAQ.
 * @route /{lang}/contacto/
 * @rendering SSG (prerender)
 */

import { getSiteUrl } from '@/lib/env';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { ContactForm } from '@/components/ContactForm.client';
import SectionHeader from '@/components/shared/layout/SectionHeader.astro';
import ContactFAQ from '@/components/contact/ContactFAQ.astro';
import ContactMiniMap from '@/components/contact/ContactMiniMap.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import {
	EmailIcon,
	PhoneIcon,
	WhatsappIcon,
	LocationIcon,
	ClockIcon,
	CheckCircleIcon,
	ArrowRightIcon,
	InstagramIcon,
	FacebookIcon
} from '@repo/icons';
import type { GetStaticPaths } from 'astro';

export const prerender = true;

export const getStaticPaths = (() => {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const locale = lang as SupportedLocale;
const { t } = createTranslations(locale);

// ─── Contact data (from i18n, with hardcoded coords) ──────────────────────────
const phoneRaw = t('contact.phone.value', '+54 3442 453797');
const phoneHref = phoneRaw.replace(/[^+\d]/g, '');
const whatsappRaw = t('contact.whatsapp.value', '+54 9 3442 453797');
const whatsappHref = whatsappRaw.replace(/[^\d]/g, '');
const emailValue = t('contact.email.value', 'info@hospeda.com');
const addressValue = t('contact.address.value', 'Concepción del Uruguay, Entre Ríos, Argentina');

// Concepción del Uruguay coordinates
const officeLat = -32.4847;
const officeLng = -58.2329;

const trustSignals = [
	t('contact.trust.responseTime', 'Respondemos en menos de 24 hs'),
	t('contact.trust.secure', 'Tus datos están protegidos'),
	t('contact.trust.humans', 'Te atiende una persona, no un bot')
];

const channels = [
	{
		key: 'email',
		title: t('contact.channels.email.title', 'Email'),
		description: t(
			'contact.channels.email.description',
			'Para consultas detalladas y formales.'
		),
		value: emailValue,
		cta: t('contact.channels.email.cta', 'Escribinos un mail'),
		href: `mailto:${emailValue}`,
		external: false
	},
	{
		key: 'phone',
		title: t('contact.channels.phone.title', 'Teléfono'),
		description: t(
			'contact.channels.phone.description',
			'Lunes a viernes, 9 a 18 hs (UTC-3).'
		),
		value: phoneRaw,
		cta: t('contact.channels.phone.cta', 'Llamanos'),
		href: `tel:${phoneHref}`,
		external: false
	},
	{
		key: 'whatsapp',
		title: t('contact.channels.whatsapp.title', 'WhatsApp'),
		description: t(
			'contact.channels.whatsapp.description',
			'Respuesta rápida en horario de oficina.'
		),
		value: whatsappRaw,
		cta: t('contact.channels.whatsapp.cta', 'Chatear por WhatsApp'),
		href: `https://wa.me/${whatsappHref}`,
		external: true
	}
];

const hours = [
	{
		label: t('contact.hours.weekdays', 'Lunes a viernes'),
		value: t('contact.hours.weekdaysValue', '9:00 a 18:00')
	},
	{
		label: t('contact.hours.saturday', 'Sábados'),
		value: t('contact.hours.saturdayValue', '10:00 a 13:00')
	},
	{
		label: t('contact.hours.sunday', 'Domingos y feriados'),
		value: t('contact.hours.sundayValue', 'Cerrado')
	}
];

const socialLinks = [
	{ key: 'instagram', label: 'Instagram', href: 'https://instagram.com/hospeda', Icon: InstagramIcon },
	{ key: 'facebook', label: 'Facebook', href: 'https://facebook.com/hospeda', Icon: FacebookIcon },
	{ key: 'whatsapp', label: 'WhatsApp', href: `https://wa.me/${whatsappHref}`, Icon: WhatsappIcon }
];

// ─── JSON-LD: ContactPage + ContactPoint ──────────────────────────────────────
const siteBase = getSiteUrl();
const contactPageJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ContactPage',
	name: t('contact.title', 'Contacto - Hospeda'),
	description: t('contact.description', 'Contactate con el equipo de Hospeda.'),
	url: new URL(Astro.url.pathname, siteBase).href,
	inLanguage: locale,
	mainEntity: {
		'@type': 'Organization',
		name: 'Hospeda',
		url: siteBase,
		email: emailValue,
		telephone: phoneRaw,
		address: {
			'@type': 'PostalAddress',
			addressLocality: 'Concepción del Uruguay',
			addressRegion: 'Entre Ríos',
			addressCountry: 'AR'
		},
		contactPoint: [
			{
				'@type': 'ContactPoint',
				contactType: 'customer support',
				email: emailValue,
				telephone: phoneRaw,
				availableLanguage: ['Spanish', 'English', 'Portuguese'],
				areaServed: 'AR'
			}
		]
	}
};
---

<DefaultLayout
	locale={locale}
	title={t('contact.title', 'Contacto')}
	description={t('contact.description', 'Contactate con el equipo de Hospeda. Estamos para ayudarte.')}
>
	<script
		slot="head-extra"
		type="application/ld+json"
		set:html={JSON.stringify(contactPageJsonLd)}
	></script>

	<!-- ───── Section 1 — Hero with form ─────────────────────────────────── -->
	<section class="contact-hero section">
		<div class="contact-hero__decoratives" aria-hidden="true">
			<img
				src="/assets/images/shapes/deco-arrow-1.svg"
				alt=""
				class="contact-hero__deco contact-hero__deco--arrow"
				loading="eager"
			/>
		</div>

		<div class="contact-hero__container">
			<div class="contact-hero__content" data-reveal="up">
				<p class="contact-hero__tagline">{t('contact.tagline', 'Escribinos')}</p>
				<h1 class="contact-hero__title">{t('contact.heading', 'Contactanos')}</h1>
				<p class="contact-hero__subtitle">
					{t('contact.subtitle', '¿Tenés alguna consulta o sugerencia? Completá el formulario y te responderemos a la brevedad.')}
				</p>

				<ul class="contact-hero__trust" role="list">
					{trustSignals.map((signal) => (
						<li class="contact-hero__trust-item">
							<span class="contact-hero__trust-icon" aria-hidden="true">
								<CheckCircleIcon size="sm" weight="fill" />
							</span>
							<span>{signal}</span>
						</li>
					))}
				</ul>

				<div class="contact-hero__form" data-reveal="up">
					<ContactForm locale={locale} client:visible />
				</div>
			</div>

			<aside class="contact-hero__visual" aria-hidden="true" data-reveal="right">
				<div class="contact-hero__blob"></div>
				<div class="contact-hero__icon-wrap">
					<EmailIcon size={96} weight="duotone" />
				</div>
				<div class="contact-hero__floating contact-hero__floating--phone">
					<PhoneIcon size="md" weight="duotone" />
				</div>
				<div class="contact-hero__floating contact-hero__floating--chat">
					<WhatsappIcon size="md" weight="duotone" />
				</div>
				<div class="contact-hero__floating contact-hero__floating--pin">
					<LocationIcon size="md" weight="duotone" />
				</div>
			</aside>
		</div>
	</section>

	<!-- ───── Section 2 — Channels ───────────────────────────────────────── -->
	<section class="contact-channels section section--warm">
		<div class="contact-channels__container">
			<SectionHeader
				tagline={t('contact.channels.tagline', 'Otros canales')}
				title={t('contact.channels.title', 'Hablemos como prefieras')}
				subtitle={t('contact.channels.subtitle', 'Elegí el canal que más te convenga. Te respondemos lo antes posible.')}
			/>

			<div class="contact-channels__grid">
				{channels.map((channel, i) => {
					const Icon = channel.key === 'email'
						? EmailIcon
						: channel.key === 'phone'
							? PhoneIcon
							: WhatsappIcon;
					return (
						<a
							href={channel.href}
							class={`contact-channel contact-channel--${channel.key}`}
							data-reveal="up"
							data-stagger-index={Math.min(i, 6)} data-stagger-step="100"
							{...(channel.external && { target: '_blank', rel: 'noopener noreferrer' })}
						>
							<span class="contact-channel__icon" aria-hidden="true">
								<Icon size="lg" weight="duotone" />
							</span>
							<h3 class="contact-channel__title">{channel.title}</h3>
							<p class="contact-channel__description">{channel.description}</p>
							<p class="contact-channel__value">{channel.value}</p>
							<span class="contact-channel__cta">
								{channel.cta}
								<ArrowRightIcon size="sm" weight="bold" />
							</span>
						</a>
					);
				})}
			</div>
		</div>
	</section>

	<!-- ───── Section 3 — Visit us (map + hours + social) ────────────────── -->
	<section class="contact-visit section">
		<div class="contact-visit__container">
			<SectionHeader
				tagline={t('contact.hours.tagline', 'Cuándo estamos')}
				title={t('contact.hours.title', 'Horarios de atención')}
				subtitle={t('contact.hours.subtitle', 'Te respondemos en menos de 24 horas hábiles.')}
			/>

			<div class="contact-visit__grid">
				<div class="contact-visit__map" data-reveal="up">
					<ContactMiniMap
						locale={locale}
						lat={officeLat}
						lng={officeLng}
						label={addressValue}
					/>
				</div>

				<div class="contact-visit__sidebar">
					<article class="contact-visit-card" data-reveal="up" data-stagger-index="1" data-stagger-step="100">
						<header class="contact-visit-card__header">
							<span class="contact-visit-card__icon" aria-hidden="true">
								<ClockIcon size="md" weight="duotone" />
							</span>
							<h3 class="contact-visit-card__title">
								{t('contact.hours.title', 'Horarios')}
							</h3>
						</header>
						<dl class="contact-visit-card__list">
							{hours.map((row) => (
								<div class="contact-visit-card__row">
									<dt>{row.label}</dt>
									<dd>{row.value}</dd>
								</div>
							))}
						</dl>
						<p class="contact-visit-card__note">
							{t('contact.hours.timezone', 'Hora de Argentina (UTC-3)')}
						</p>
					</article>

					<article class="contact-visit-card" data-reveal="up" data-stagger-index="2" data-stagger-step="100">
						<header class="contact-visit-card__header">
							<span class="contact-visit-card__icon" aria-hidden="true">
								<InstagramIcon size="md" weight="duotone" />
							</span>
							<h3 class="contact-visit-card__title">
								{t('contact.channels.social.title', 'Redes sociales')}
							</h3>
						</header>
						<p class="contact-visit-card__note">
							{t('contact.channels.social.description', 'Seguinos para novedades y promos.')}
						</p>
						<ul class="contact-visit-card__social" role="list">
							{socialLinks.map(({ key, label, href, Icon: SocialIcon }) => (
								<li>
									<a
										href={href}
										class="contact-visit-card__social-link"
										target="_blank"
										rel="noopener noreferrer"
										aria-label={label}
									>
										<SocialIcon size="md" weight="duotone" />
									</a>
								</li>
							))}
						</ul>
					</article>
				</div>
			</div>
		</div>
	</section>

	<!-- ───── Section 4 — FAQ ────────────────────────────────────────────── -->
	<section class="contact-faq-section section section--warm">
		<div class="contact-faq-section__container">
			<SectionHeader
				tagline={t('contact.faq.tagline', 'Preguntas frecuentes')}
				title={t('contact.faq.title', 'Antes de escribirnos')}
				subtitle={t('contact.faq.subtitle', 'Quizás tu pregunta ya tiene respuesta.')}
			/>
			<ContactFAQ locale={locale} />
		</div>
	</section>
</DefaultLayout>

<style>
	/* ─── Hero ──────────────────────────────────────────────────────────────── */

	.contact-hero {
		position: relative;
		overflow: hidden;
	}

	.contact-hero__decoratives {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.contact-hero__deco--arrow {
		position: absolute;
		top: clamp(20%, 25%, 30%);
		right: clamp(2%, 4vw, 6%);
		width: clamp(60px, 8vw, 110px);
		height: auto;
		opacity: 0.5;
		transform: rotate(15deg);
	}

	@media (max-width: 900px) {
		.contact-hero__deco--arrow {
			display: none;
		}
	}

	.contact-hero__container {
		position: relative;
		z-index: 1;
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: var(--space-8, 2rem);
		align-items: start;
	}

	@media (min-width: 960px) {
		.contact-hero__container {
			grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
			gap: clamp(2rem, 5vw, 5rem);
		}
	}

	.contact-hero__content {
		display: flex;
		flex-direction: column;
	}

	.contact-hero__tagline {
		font-family: var(--font-decorative);
		font-size: var(--text-tagline);
		color: var(--brand-accent);
		font-style: italic;
		margin: 0 0 var(--space-2, 0.5rem);
	}

	.contact-hero__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: var(--text-h2);
		color: var(--core-foreground);
		margin: 0 0 var(--space-4, 1rem);
		line-height: 1.15;
	}

	.contact-hero__subtitle {
		font-family: var(--font-sans);
		font-size: var(--text-body);
		color: var(--core-muted-foreground);
		max-width: 55ch;
		margin: 0 0 var(--space-5, 1.25rem);
		line-height: 1.6;
	}

	.contact-hero__trust {
		list-style: none;
		padding: 0;
		margin: 0 0 var(--space-6, 1.5rem);
		display: flex;
		flex-direction: column;
		gap: var(--space-2, 0.5rem);
	}

	.contact-hero__trust-item {
		display: flex;
		align-items: center;
		gap: var(--space-2, 0.5rem);
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
	}

	.contact-hero__trust-icon {
		display: inline-flex;
		color: var(--brand-accent);
		flex-shrink: 0;
	}

	.contact-hero__form {
		margin-top: var(--space-4, 1rem);
		max-width: 640px;
		width: 100%;
	}

	/* Hero visual aside */

	.contact-hero__visual {
		position: relative;
		display: none;
		align-items: center;
		justify-content: center;
		min-height: 360px;
	}

	@media (min-width: 960px) {
		.contact-hero__visual {
			display: flex;
			align-self: stretch;
		}
	}

	.contact-hero__blob {
		position: absolute;
		inset: 0;
		margin: auto;
		width: clamp(260px, 28vw, 400px);
		height: clamp(260px, 28vw, 400px);
		border-radius: 50%;
		background: radial-gradient(
			circle at 30% 30%,
			var(--brand-primary-a20),
			var(--brand-accent-a08) 60%,
			transparent 75%
		);
		filter: blur(2px);
	}

	.contact-hero__icon-wrap {
		position: relative;
		z-index: 2;
		width: clamp(140px, 16vw, 200px);
		height: clamp(140px, 16vw, 200px);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background-color: var(--core-card);
		border-radius: 50%;
		box-shadow: var(--shadow-card);
		color: var(--brand-primary);
	}

	.contact-hero__floating {
		position: absolute;
		z-index: 3;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		border-radius: 50%;
		background-color: var(--core-card);
		box-shadow: var(--shadow-card);
		color: var(--brand-accent);
		animation: contact-float 6s ease-in-out infinite;
	}

	.contact-hero__floating--phone {
		top: 12%;
		left: 8%;
		animation-delay: 0s;
	}

	.contact-hero__floating--chat {
		bottom: 18%;
		left: 4%;
		color: oklch(0.65 0.18 145);
		animation-delay: 1.5s;
	}

	.contact-hero__floating--pin {
		top: 18%;
		right: 6%;
		color: var(--brand-primary);
		animation-delay: 3s;
	}

	@keyframes contact-float {
		0%, 100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-10px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-hero__floating {
			animation: none;
		}
	}

	/* ─── Channels section ─────────────────────────────────────────────────── */

	.contact-channels__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.contact-channels__grid {
		margin-top: var(--space-6, 1.5rem);
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-card-gap, 1.5rem);
	}

	@media (min-width: 700px) {
		.contact-channels__grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.contact-channel {
		background-color: var(--core-card);
		border-radius: var(--radius-card);
		padding: var(--space-6, 1.5rem);
		box-shadow: var(--shadow-card);
		display: flex;
		flex-direction: column;
		gap: var(--space-3, 0.75rem);
		text-decoration: none;
		color: inherit;
		transition:
			transform var(--duration-normal) ease,
			box-shadow var(--duration-normal) ease,
			border-color var(--duration-normal) ease;
		border: 1px solid transparent;
	}

	.contact-channel:hover,
	.contact-channel:focus-visible {
		transform: translateY(-6px);
		box-shadow: var(--shadow-card-hover);
		border-color: var(--brand-primary-a20);
		outline: none;
	}

	.contact-channel__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		border-radius: var(--radius-md, 10px);
		background-color: var(--brand-primary-a10);
		color: var(--brand-primary);
		flex-shrink: 0;
	}

	.contact-channel--whatsapp .contact-channel__icon {
		background-color: oklch(0.65 0.18 145 / 0.12);
		color: oklch(0.55 0.18 145);
	}

	.contact-channel--phone .contact-channel__icon {
		background-color: var(--brand-accent-a12);
		color: var(--brand-accent);
	}

	.contact-channel__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: var(--text-h3);
		color: var(--core-foreground);
		margin: 0;
	}

	.contact-channel__description {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
		margin: 0;
		line-height: 1.5;
	}

	.contact-channel__value {
		font-family: var(--font-sans);
		font-size: var(--text-body);
		color: var(--core-foreground);
		font-weight: 600;
		margin: 0;
		word-break: break-word;
	}

	.contact-channel__cta {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2, 0.5rem);
		margin-top: auto;
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: var(--text-body-sm);
		color: var(--brand-primary);
		transition: gap var(--duration-fast) ease;
	}

	.contact-channel:hover .contact-channel__cta,
	.contact-channel:focus-visible .contact-channel__cta {
		gap: var(--space-3, 0.75rem);
		color: var(--brand-accent);
	}

	/* ─── Visit section (map + sidebar) ────────────────────────────────────── */

	.contact-visit__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.contact-visit__grid {
		margin-top: var(--space-6, 1.5rem);
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-card-gap, 1.5rem);
	}

	@media (min-width: 900px) {
		.contact-visit__grid {
			grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
		}
	}

	.contact-visit__map {
		min-height: 360px;
	}

	.contact-visit__sidebar {
		display: flex;
		flex-direction: column;
		gap: var(--space-card-gap, 1.5rem);
	}

	.contact-visit-card {
		background-color: var(--core-card);
		border-radius: var(--radius-card);
		padding: var(--space-6, 1.5rem);
		box-shadow: var(--shadow-card);
		display: flex;
		flex-direction: column;
		gap: var(--space-3, 0.75rem);
	}

	.contact-visit-card__header {
		display: flex;
		align-items: center;
		gap: var(--space-3, 0.75rem);
	}

	.contact-visit-card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: var(--radius-md, 10px);
		background-color: var(--brand-primary-a10);
		color: var(--brand-primary);
	}

	.contact-visit-card__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: var(--text-h4);
		color: var(--core-foreground);
		margin: 0;
	}

	.contact-visit-card__list {
		display: flex;
		flex-direction: column;
		gap: var(--space-2, 0.5rem);
		margin: 0;
		padding: 0;
	}

	.contact-visit-card__row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
