---
/**
 * @file beneficios/index.astro
 * @description Benefits page showing tourist and owner benefits.
 * @route /{lang}/beneficios/
 * @rendering SSG (prerender)
 */

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import MarketingHero from '@/components/marketing/MarketingHero.astro';
import GradientButton from '@/components/shared/ui/GradientButton.astro';
import AboutPageJsonLd from '@/components/seo/AboutPageJsonLd.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import {
	BuildingsIcon,
	ChatIcon,
	EyeIcon,
	FavoriteIcon,
	HomeIcon,
	MapIcon,
	PhoneIcon,
	PriceIcon,
	ReceiptIcon,
	SettingsIcon,
	SparkleIcon,
	StarIcon,
	StatisticsIcon,
} from '@repo/icons';
import type { GetStaticPaths } from 'astro';

export const prerender = true;

export const getStaticPaths = (() => {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const locale = lang as SupportedLocale;
const { t } = createTranslations(locale);

const touristBenefits = [
	{ Icon: BuildingsIcon, titleKey: 'benefits.tourist.1.title', titleFb: 'Variedad de opciones', descKey: 'benefits.tourist.1.desc', descFb: 'Desde cabañas junto al río hasta hoteles en el centro. Encontrá el alojamiento perfecto para tu viaje.' },
	{ Icon: PriceIcon, titleKey: 'benefits.tourist.2.title', titleFb: 'Precios transparentes', descKey: 'benefits.tourist.2.desc', descFb: 'Sin costos ocultos ni sorpresas. Sabés exactamente cuánto pagás antes de reservar.' },
	{ Icon: StarIcon, titleKey: 'benefits.tourist.3.title', titleFb: 'Reseñas verificadas', descKey: 'benefits.tourist.3.desc', descFb: 'Opiniones reales de viajeros que ya se hospedaron. Elegí con confianza.' },
	{ Icon: MapIcon, titleKey: 'benefits.tourist.4.title', titleFb: 'Información local', descKey: 'benefits.tourist.4.desc', descFb: 'Destinos, eventos y guías de viaje para planificar tu escapada al Litoral.' },
	{ Icon: ChatIcon, titleKey: 'benefits.tourist.5.title', titleFb: 'Contacto directo', descKey: 'benefits.tourist.5.desc', descFb: 'Comunicación directa con el propietario. Sin intermediarios ni demoras.' },
] as const;

const ownerBenefits = [
	{ Icon: EyeIcon, titleKey: 'benefits.owner.1.title', titleFb: 'Visibilidad regional', descKey: 'benefits.owner.1.desc', descFb: 'Llegá a miles de viajeros que buscan alojamiento en la costa del río Uruguay.' },
	{ Icon: SettingsIcon, titleKey: 'benefits.owner.2.title', titleFb: 'Gestión simple', descKey: 'benefits.owner.2.desc', descFb: 'Panel de control intuitivo para gestionar tu propiedad, fotos y precios.' },
	{ Icon: ReceiptIcon, titleKey: 'benefits.owner.3.title', titleFb: 'Sin comisiones ocultas', descKey: 'benefits.owner.3.desc', descFb: 'Planes transparentes con precios fijos. Sabés exactamente cuánto pagás.' },
	{ Icon: StatisticsIcon, titleKey: 'benefits.owner.4.title', titleFb: 'Estadísticas detalladas', descKey: 'benefits.owner.4.desc', descFb: 'Accedé a métricas de visitas, consultas y rendimiento de tu publicación.' },
	{ Icon: PhoneIcon, titleKey: 'benefits.owner.5.title', titleFb: 'Soporte dedicado', descKey: 'benefits.owner.5.desc', descFb: 'Equipo de soporte disponible para ayudarte con cualquier consulta.' },
] as const;

// Split titles to underline the last word with a handwritten accent.
const splitLastWord = (full: string): { main: string; accent: string } => {
	const words = full.trim().split(/\s+/);
	const accent = words.pop() ?? full;
	return { main: words.join(' '), accent };
};

const touristHeading = splitLastWord(t('benefits.tourist.title', 'Beneficios para turistas'));
const ownerHeading = splitLastWord(t('benefits.owner.title', 'Beneficios para propietarios'));

const benefitsTitle = t('benefits.title', 'Beneficios');
const benefitsDescription = t(
	'benefits.description',
	'Descubrí los beneficios de usar Hospeda como viajero o propietario.'
);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://hospeda.com.ar').href;
const inLanguageMap: Record<SupportedLocale, string> = {
	es: 'es-AR',
	en: 'en-US',
	pt: 'pt-BR'
};
---

<MarketingLayout
	locale={locale}
	title={benefitsTitle}
	description={benefitsDescription}
>
	<AboutPageJsonLd
		slot="head-extra"
		title={benefitsTitle}
		description={benefitsDescription}
		url={canonicalUrl}
		inLanguage={inLanguageMap[locale]}
	/>

	<MarketingHero
		tagline={t('benefits.hero.tagline', 'Por qué Hospeda')}
		titleMain={t('benefits.hero.titleMain', 'Lo que ofrecemos a nuestra')}
		titleAccent={t('benefits.hero.titleAccent', 'comunidad')}
		subtitle={t(
			'benefits.hero.subtitle',
			'Descubrí los beneficios de usar Hospeda como viajero o como propietario del Litoral entrerriano.'
		)}
	>
		<Fragment slot="icon-1"><FavoriteIcon size="md" weight="duotone" /></Fragment>
		<Fragment slot="icon-2"><HomeIcon size="md" weight="duotone" /></Fragment>
		<Fragment slot="icon-3"><SparkleIcon size="md" weight="duotone" /></Fragment>
	</MarketingHero>

	<!-- Tourist Benefits -->
	<section class="benefits-section benefits-section--tourist section">
		<div class="benefits-section__decoratives" aria-hidden="true">
			<span class="benefits-section__watermark benefits-section__watermark--tourist">
				<FavoriteIcon size={200} weight="duotone" />
			</span>
			<svg
				class="benefits-section__wave benefits-section__wave--tourist"
				viewBox="0 0 800 60"
				preserveAspectRatio="none"
				aria-hidden="true"
			>
				<path
					d="M 0 40 Q 100 10, 200 35 T 400 30 T 600 35 T 800 28"
					stroke="currentColor"
					stroke-width="2"
					stroke-dasharray="3 7"
					stroke-linecap="round"
					fill="none"
				/>
			</svg>
			<span class="benefits-section__dot benefits-section__dot--t1"></span>
			<span class="benefits-section__dot benefits-section__dot--t2"></span>
			<span class="benefits-section__dot benefits-section__dot--t3"></span>
			<span class="benefits-section__dot benefits-section__dot--t4"></span>
		</div>
		<div class="benefits-section__container">
			<p class="benefits-section__tagline" data-reveal="up">{t('benefits.tourist.tagline', 'Para viajeros')}</p>
			<h2 class="benefits-section__title" data-reveal="up">
				{touristHeading.main && <>{touristHeading.main}{' '}</>}
				<span class="benefits-section__title-accent benefits-section__title-accent--tourist">
					{touristHeading.accent}
					<svg
						class="benefits-section__title-underline"
						viewBox="0 0 200 18"
						preserveAspectRatio="none"
						aria-hidden="true"
					>
						<path
							d="M 4 12 Q 50 2, 100 10 T 196 8"
							stroke="currentColor"
							stroke-width="4"
							stroke-linecap="round"
							fill="none"
						/>
					</svg>
				</span>
			</h2>
			<div class="benefits-section__grid">
				{touristBenefits.map((b, i) => {
					const Icon = b.Icon;
					return (
						<div class="benefits-card" data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
							<span class="benefits-card__icon benefits-card__icon--tourist" aria-hidden="true">
								<Icon size="lg" weight="duotone" />
							</span>
							<h3 class="benefits-card__title">{t(b.titleKey, b.titleFb)}</h3>
							<p class="benefits-card__desc">{t(b.descKey, b.descFb)}</p>
						</div>
					);
				})}
			</div>
			<div class="benefits-section__cta" data-reveal="up">
				<GradientButton
					href={buildUrl({ locale, path: 'alojamientos' })}
					label={t('benefits.tourist.cta', 'Explorar alojamientos')}
					variant="primary"
				/>
			</div>
		</div>
	</section>

	<!-- Owner Benefits -->
	<section class="benefits-section benefits-section--owner section section--warm">
		<div class="benefits-section__decoratives" aria-hidden="true">
			<span class="benefits-section__watermark benefits-section__watermark--owner">
				<HomeIcon size={200} weight="duotone" />
			</span>
			<svg
				class="benefits-section__wave benefits-section__wave--owner"
				viewBox="0 0 800 60"
				preserveAspectRatio="none"
				aria-hidden="true"
			>
				<path
					d="M 0 28 Q 100 50, 200 30 T 400 32 T 600 28 T 800 35"
					stroke="currentColor"
					stroke-width="2"
					stroke-dasharray="3 7"
					stroke-linecap="round"
					fill="none"
				/>
			</svg>
			<span class="benefits-section__dot benefits-section__dot--o1"></span>
			<span class="benefits-section__dot benefits-section__dot--o2"></span>
			<span class="benefits-section__dot benefits-section__dot--o3"></span>
			<span class="benefits-section__dot benefits-section__dot--o4"></span>
		</div>
		<div class="benefits-section__container">
			<p class="benefits-section__tagline" data-reveal="up">{t('benefits.owner.tagline', 'Para propietarios')}</p>
			<h2 class="benefits-section__title" data-reveal="up">
				{ownerHeading.main && <>{ownerHeading.main}{' '}</>}
				<span class="benefits-section__title-accent benefits-section__title-accent--owner">
					{ownerHeading.accent}
					<svg
						class="benefits-section__title-underline"
						viewBox="0 0 200 18"
						preserveAspectRatio="none"
						aria-hidden="true"
					>
						<path
							d="M 4 12 Q 50 2, 100 10 T 196 8"
							stroke="currentColor"
							stroke-width="4"
							stroke-linecap="round"
							fill="none"
						/>
					</svg>
				</span>
			</h2>
			<div class="benefits-section__grid">
				{ownerBenefits.map((b, i) => {
					const Icon = b.Icon;
					return (
						<div class="benefits-card" data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
							<span class="benefits-card__icon benefits-card__icon--owner" aria-hidden="true">
								<Icon size="lg" weight="duotone" />
							</span>
							<h3 class="benefits-card__title">{t(b.titleKey, b.titleFb)}</h3>
							<p class="benefits-card__desc">{t(b.descKey, b.descFb)}</p>
						</div>
					);
				})}
			</div>
			<div class="benefits-section__cta" data-reveal="up">
				<GradientButton
					href={buildUrl({ locale, path: 'suscriptores/propietarios' })}
					label={t('benefits.owner.cta', 'Publicá tu alojamiento')}
					variant="accent"
				/>
			</div>
		</div>
	</section>
</MarketingLayout>

<style>
	.benefits-section__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
		text-align: center;
	}

	.benefits-section__tagline {
		font-family: var(--font-decorative);
		font-size: clamp(1.1rem, 2.5vw, 1.4rem);
		color: var(--brand-accent);
		font-style: italic;
		margin: 0 0 var(--space-2);
	}

	.benefits-section__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		color: var(--core-foreground);
		margin: 0 0 var(--space-8);
	}

	.benefits-section__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: var(--space-card-gap);
		text-align: left;
	}

	.benefits-card {
		background-color: var(--core-card);
		border-radius: var(--radius-card);
		padding: var(--space-6);
		box-shadow: var(--shadow-card);
	}

	/* Icon chip: rounded square with tinted background + duotone icon in the
	 * matching brand color. Mirrors the visual rhythm used in the publicar
	 * landing's benefit cards. */
	.benefits-card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		margin-bottom: var(--space-4);
		border-radius: var(--radius-button, 12px);
	}

	.benefits-card__icon--tourist {
		background-color: var(--brand-primary-a12);
		color: var(--brand-primary);
	}

	.benefits-card__icon--owner {
		background-color: var(--brand-accent-a12);
		color: var(--brand-accent);
	}

	.benefits-card__title {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: var(--text-lg);
		color: var(--core-foreground);
		margin: 0 0 var(--space-2);
	}

	.benefits-card__desc {
		font-family: var(--font-sans);
		font-size: var(--text-body);
		color: var(--core-muted-foreground);
		line-height: 1.6;
		margin: 0;
	}

	.benefits-section__cta {
		margin-top: var(--space-8);
	}

	/* ─── Decoratives (per-section personality) ─────────────────────────── */

	.benefits-section {
		position: relative;
		overflow: hidden;
	}

	.benefits-section__decoratives {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.benefits-section__container {
		position: relative;
		z-index: 1;
	}

	/* Handwritten underline under the last word of the title */
	.benefits-section__title-accent {
		position: relative;
		display: inline-block;
	}

	.benefits-section__title-underline {
		position: absolute;
		left: -3%;
		right: -3%;
		bottom: -0.08em;
		width: 106%;
		height: 0.32em;
		opacity: 0.75;
		pointer-events: none;
	}

	.benefits-section__title-accent--tourist .benefits-section__title-underline {
		color: var(--brand-primary);
	}

	.benefits-section__title-accent--owner .benefits-section__title-underline {
		color: var(--brand-accent);
	}

	/* Watermark: oversized icon in a corner, very low opacity */
	.benefits-section__watermark {
		position: absolute;
		display: inline-flex;
		opacity: 0.05;
	}

	.benefits-section__watermark--tourist {
		bottom: -40px;
		right: -50px;
		color: var(--brand-primary);
		transform: rotate(-14deg);
	}

	.benefits-section__watermark--owner {
		top: -30px;
		left: -50px;
		color: var(--brand-accent);
		transform: rotate(18deg);
	}

	/* Dashed wavy line crossing the section */
	.benefits-section__wave {
		position: absolute;
		width: 60%;
		height: 60px;
		opacity: 0.35;
	}

	.benefits-section__wave--tourist {
		top: 12%;
		left: -5%;
		color: var(--brand-primary);
	}

	.benefits-section__wave--owner {
		bottom: 14%;
		right: -5%;
		color: var(--brand-accent);
	}

	/* Ambient dots — varied sizes and opacities */
	.benefits-section__dot {
		position: absolute;
		border-radius: 50%;
	}

	.benefits-section__dot--t1 {
		top: 22%;
		right: 10%;
		width: 12px;
		height: 12px;
		background-color: var(--brand-primary-a30);
	}
	.benefits-section__dot--t2 {
		top: 60%;
		left: 6%;
		width: 9px;
		height: 9px;
		background-color: var(--brand-primary-a20);
	}
	.benefits-section__dot--t3 {
		bottom: 18%;
		right: 22%;
		width: 14px;
		height: 14px;
		background-color: var(--brand-accent-a20);
	}
	.benefits-section__dot--t4 {
		top: 40%;
		right: 4%;
		width: 8px;
		height: 8px;
		background-color: var(--brand-primary-a30);
	}

	.benefits-section__dot--o1 {
		top: 18%;
		left: 10%;
		width: 10px;
		height: 10px;
		background-color: var(--brand-accent-a30);
	}
	.benefits-section__dot--o2 {
		bottom: 25%;
		left: 22%;
		width: 14px;
		height: 14px;
		background-color: var(--brand-accent-a20);
	}
	.benefits-section__dot--o3 {
		top: 35%;
		right: 8%;
		width: 8px;
		height: 8px;
		background-color: var(--brand-primary-a25);
	}
	.benefits-section__dot--o4 {
		bottom: 12%;
		left: 5%;
		width: 12px;
		height: 12px;
		background-color: var(--brand-accent-a30);
	}

	@media (max-width: 900px) {
		.benefits-section__watermark,
		.benefits-section__wave {
			display: none;
		}
	}

</style>
