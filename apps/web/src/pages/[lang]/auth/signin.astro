---
/**
 * Sign in page - allows users to log in to their account.
 * NOTE: This page must NOT be prerendered because it reads `returnUrl` from query params.
 *
 * @route /[lang]/auth/signin/
 * @rendering SSR
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import { SignInClient } from '../../../components/auth/SignIn.client';
import { getLocaleFromParams } from '../../../lib/page-helpers';
import { createT, type SupportedLocale } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const typedLocale = locale as SupportedLocale;

/** Redirect authenticated users to home page. */
if (Astro.locals.user) {
    return Astro.redirect(buildUrl({ locale: typedLocale }));
}

const t = createT(typedLocale);
const title = t('auth-ui.pages.signin.title', 'Iniciar sesion');
const description = t('auth-ui.pages.signin.description', 'Inicia sesion en tu cuenta de Hospeda');

const labels: Record<SupportedLocale, { noAccount: string; signUp: string; forgotPassword: string }> = {
    es: { noAccount: 'No tienes cuenta?', signUp: 'Registrarse', forgotPassword: 'Olvidaste tu contrasena?' },
    en: { noAccount: "Don't have an account?", signUp: 'Sign Up', forgotPassword: 'Forgot password?' },
    pt: { noAccount: 'Nao tem uma conta?', signUp: 'Registrar', forgotPassword: 'Esqueceu a senha?' },
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const currentLabels = labels[typedLocale];

const returnPath = Astro.url.searchParams.get('returnUrl') || buildUrl({ locale: typedLocale, path: 'mi-cuenta' });
const siteOrigin = import.meta.env.PUBLIC_SITE_URL || import.meta.env.HOSPEDA_SITE_URL || Astro.url.origin;
const redirectTo = new URL(returnPath, siteOrigin).href;
---

<BaseLayout title={title} description={description} locale={locale}>
    <SEOHead slot="head" title={title} description={description} canonical={canonicalUrl} locale={locale} noindex={true} />

    <div class="flex min-h-screen items-center justify-center py-12 px-4">
        <div class="w-full max-w-md">
            <div class="rounded-xl border border-border bg-card p-8 shadow-lg">
                <SignInClient client:load redirectTo={redirectTo} showOAuth={true} />

                <div class="mt-4 text-center">
                    <a
                        href={buildUrl({ locale: typedLocale, path: 'auth/forgot-password' })}
                        class="text-sm text-primary transition-colors hover:text-primary/80"
                    >
                        {currentLabels.forgotPassword}
                    </a>
                </div>

                <div class="mt-4 text-center">
                    <span class="text-sm text-muted-foreground">{currentLabels.noAccount}</span>
                    {' '}
                    <a
                        href={buildUrl({ locale: typedLocale, path: 'auth/signup' })}
                        class="text-sm font-medium text-primary transition-colors hover:text-primary/80"
                    >
                        {currentLabels.signUp}
                    </a>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>
