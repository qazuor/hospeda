---
/**
 * @file signin.astro
 * @description Sign-in page — allows users to log in to their account.
 *
 * Authenticated users are immediately redirected — to the post-login destination
 * if a safe `returnUrl`/`redirect` query param is present, otherwise to /mi-cuenta/.
 * The same param is read server-side and passed to the React island so the user
 * lands on the same destination after a successful sign-in.
 *
 * Both `returnUrl` and `redirect` are accepted as query param names so older
 * callsites that built links with `?redirect=...` keep working. `returnUrl`
 * takes precedence when both are present.
 *
 * @route    /[lang]/auth/signin/
 * @rendering SSR (reads `returnUrl`/`redirect` from query params; reads auth state from locals)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { validateCallbackUrl } from '@/lib/auth-callback';
import { getAdminUrl, getSiteUrl, isProduction } from '@/lib/env';
import { buildUrl } from '@/lib/urls';
import AuthLayout from '@/layouts/AuthLayout.astro';
import { SignIn } from '@/components/auth/SignIn.client';
import { HomeIcon, LocationIcon } from '@repo/icons';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

// Determine post-login redirect target from `returnUrl` (canonical) or
// `redirect` (legacy alias) query param. `returnUrl` wins when both are present.
//
// Anchor on `Astro.url.origin` (the actual request host — e.g.
// staging.hospeda.com.ar when the page is served from there) instead of
// HOSPEDA_SITE_URL, so OAuth flows initiated on a host alias don't
// silently redirect users to the canonical apex post-login. The client
// island still falls back to window.location.origin if redirectTo is
// undefined, but here we want a known-good absolute URL up front.
//
// SECURITY: this value is attacker-controlled query input. The naive
// `new URL(returnPath, origin)` resolution does NOT enforce the base
// origin when `returnPath` is an absolute URL — it returns the absolute
// URL verbatim. That makes it a textbook open-redirect vector usable
// for phishing. Reject anything that isn't an obviously-safe relative
// path (single leading slash, no second slash that could be parsed as
// `//evil.com`, no scheme prefix). Fall back to the account dashboard
// when the input looks suspicious.
const rawReturn =
    Astro.url.searchParams.get('returnUrl') ??
    Astro.url.searchParams.get('redirect') ??
    '';
const isSafeRelativePath =
    rawReturn.startsWith('/') &&
    !rawReturn.startsWith('//') &&
    !rawReturn.startsWith('/\\');
const returnPath = isSafeRelativePath ? rawReturn : buildUrl({ locale, path: 'mi-cuenta' });

// SPEC-182: cross-app `callbackUrl` support. The admin panel redirects
// unauthenticated users here with `?callbackUrl={admin-url}` so the web signin
// is the single auth surface. Unlike `returnUrl` (a same-app RELATIVE path),
// `callbackUrl` is an ABSOLUTE cross-origin URL, so it is validated against a
// strict server-side allowlist (validateCallbackUrl) before being honored — an
// unvalidated absolute redirect target is an open-redirect / OAuth-token-leak
// vector. A valid callbackUrl takes precedence over returnUrl as the post-login
// destination; an absent or rejected one falls back to the returnUrl logic
// unchanged.
const rawCallbackUrl = Astro.url.searchParams.get('callbackUrl') ?? '';
const validatedCallbackUrl = rawCallbackUrl
    ? validateCallbackUrl({
          url: rawCallbackUrl,
          siteUrl: getSiteUrl(),
          adminUrl: getAdminUrl(),
          isProduction: isProduction()
      })
    : null;

// Redirect authenticated users to the requested destination (or the account
// dashboard when no safe destination was provided). Without honoring the param
// here, callsites that link to /auth/signin?...=<path> would silently land on
// /mi-cuenta whenever the session is already valid — defeating the purpose of
// the redirect query.
if (Astro.locals.user) {
    return Astro.redirect(validatedCallbackUrl ?? returnPath);
}

const t = createT(locale);

const title = t('auth-ui.pages.signin.title', 'Iniciar sesión');
const description = t(
    'auth-ui.pages.signin.description',
    'Iniciá sesión en tu cuenta de Hospeda'
);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// A valid cross-app callbackUrl is already an absolute, allowlisted URL, so it
// is used verbatim as the island's post-login destination. Otherwise resolve
// the relative returnPath against the current request origin (SPEC-182).
const redirectTo = validatedCallbackUrl ?? new URL(returnPath, Astro.url.origin).href;

// SPEC-120: pick up OAuth failure signal from the API redirect.
//
// Better Auth `^1.4.18` redirects to errorCallbackURL with `?error=<code>`
// (and optionally `&error_description=...`) when the OAuth flow fails — user
// cancel, provider rejection, or any RFC 6749 §4.1.2.1 error. The API wrapper
// also injects `&provider=<name>` so the banner can name the provider.
//
// We validate each value with a strict allowlist regex before forwarding to
// the island: these come straight from a user-controlled redirect chain and
// flow into both i18n key lookups and console.warn output. An unexpected
// `error` code falls back to `'unknown'` (the i18n catch-all key).
const rawErrorCode = Astro.url.searchParams.get('error');
const oauthErrorCode = rawErrorCode
    ? /^[a-z_]{1,64}$/.test(rawErrorCode)
        ? rawErrorCode
        : 'unknown'
    : undefined;

const rawErrorDescription = Astro.url.searchParams.get('error_description');
const oauthErrorDescription = rawErrorDescription
    ? rawErrorDescription.slice(0, 200)
    : undefined;

const rawProvider = Astro.url.searchParams.get('provider');
const oauthProvider =
    rawProvider && /^[a-z]{1,32}$/.test(rawProvider) ? rawProvider : undefined;

const initialOAuthError = oauthErrorCode
    ? {
          code: oauthErrorCode,
          description: oauthErrorDescription,
          provider: oauthProvider
      }
    : undefined;

// Localized secondary link labels via i18n
const noAccountLabel = t('auth-ui.signIn.dontHaveAccount', "Don't have an account?");
const signUpLabel = t('auth-ui.signIn.signUpLink', 'Sign Up');
const forgotPasswordLabel = t('auth-ui.signIn.forgotPassword', 'Forgot password?');
---

<AuthLayout locale={locale} title={title} description={description}>
    <div slot="decoratives" class="signin-deco" aria-hidden="true">
        <div class="signin-deco__blob"></div>
        <span class="signin-deco__shape signin-deco__shape--home">
            <HomeIcon size={84} weight="duotone" />
        </span>
        <span class="signin-deco__badge signin-deco__badge--pin">
            <LocationIcon size="md" weight="duotone" />
        </span>
        <span class="signin-deco__dot signin-deco__dot--1"></span>
        <span class="signin-deco__dot signin-deco__dot--2"></span>
    </div>

    <div class="auth-page-content">
            <SignIn
                client:load
                locale={locale}
                redirectTo={redirectTo}
                externalRedirect={Boolean(validatedCallbackUrl)}
                showOAuth={true}
                initialOAuthError={initialOAuthError}
            />

            <div class="auth-page__links">
                <a
                    href={buildUrl({ locale, path: 'auth/forgot-password' })}
                    class="auth-page__link"
                >
                    {forgotPasswordLabel}
                </a>
            </div>

            <div class="auth-page__footer">
                <span class="auth-page__footer-text">{noAccountLabel}</span>
                {' '}
                <a
                    href={buildUrl({ locale, path: 'auth/signup' })}
                    class="auth-page__link auth-page__link--strong"
                >
                    {signUpLabel}
                </a>
            </div>
    </div>
</AuthLayout>

<style is:global>
    /* Decoratives — rendered inside the AuthLayout 'decoratives' slot, outside .auth-card. */
    .signin-deco {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .signin-deco__blob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(360px, 60vw, 720px);
        height: clamp(360px, 60vw, 720px);
        border-radius: 50%;
        background: radial-gradient(
            circle at 50% 50%,
            var(--brand-primary-a15),
            var(--brand-accent-a05) 55%,
            transparent 75%
        );
        filter: blur(4px);
    }

    .signin-deco__shape {
        position: absolute;
        display: inline-flex;
    }

    .signin-deco__shape--home {
        top: 14%;
        left: 8%;
        color: var(--brand-primary);
        opacity: 0.35;
        transform: rotate(-12deg);
    }

    .signin-deco__badge {
        position: absolute;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background-color: var(--core-card);
        box-shadow: var(--shadow-card);
        color: var(--brand-accent);
    }

    .signin-deco__badge--pin {
        bottom: 18%;
        right: 10%;
    }

    .signin-deco__dot {
        position: absolute;
        border-radius: 50%;
    }
    .signin-deco__dot--1 {
        top: 28%;
        right: 14%;
        width: 12px;
        height: 12px;
        background-color: var(--brand-primary-a30);
    }
    .signin-deco__dot--2 {
        bottom: 28%;
        left: 12%;
        width: 9px;
        height: 9px;
        background-color: var(--brand-accent-a30);
    }

    @media (max-width: 700px) {
        .signin-deco__shape,
        .signin-deco__badge {
            display: none;
        }
    }
</style>

<style>
    .auth-page {
        display: flex;
        min-height: calc(100vh - var(--navbar-height, 5rem));
        align-items: center;
        justify-content: center;
        padding: var(--space-8, 2rem) var(--space-4, 1rem);
    }

    .auth-page__card {
        width: 100%;
        max-width: 28rem;
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
        background-color: var(--core-card);
        padding: var(--space-8, 2rem);
        box-shadow: var(--shadow-card);
    }

    .auth-page__links {
        margin-top: var(--space-4, 1rem);
        text-align: center;
    }

    .auth-page__footer {
        margin-top: var(--space-4, 1rem);
        text-align: center;
    }

    .auth-page__footer-text {
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
    }

    .auth-page__link {
        font-size: var(--text-body-sm);
        color: var(--brand-primary);
        text-decoration: none;
        transition: color var(--duration-fast) ease;
    }

    .auth-page__link:hover {
        color: var(--brand-primary-l85);
    }

    .auth-page__link:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    .auth-page__link--strong {
        font-weight: 600;
    }
</style>
