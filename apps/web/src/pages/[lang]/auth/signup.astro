---
/**
 * @file signup.astro
 * @description Sign-up page — allows users to create a new account.
 *
 * Authenticated users are immediately redirected to /mi-cuenta/.
 * After a successful registration, the API does NOT auto sign-in the user
 * (email verification is required). The user is sent to verify-email-sent
 * where they are instructed to click the verification link in their inbox.
 *
 * @route    /[lang]/auth/signup/
 * @rendering SSR (auth state from locals)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import AuthLayout from '@/layouts/AuthLayout.astro';
import { SignUp } from '@/components/auth/SignUp.client';
import { SparkleIcon, UsersIcon } from '@repo/icons';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

// Redirect authenticated users to their account dashboard.
if (Astro.locals.user) {
    return Astro.redirect(buildUrl({ locale, path: 'mi-cuenta' }));
}

const t = createT(locale);

const title = t('auth-ui.pages.signup.title', 'Crear cuenta');
const description = t('auth-ui.pages.signup.description', 'Creá tu cuenta en Hospeda');

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// After registration, redirect user to a "check your email" page since
// the account is created without an active session (email verification is
// required before sign-in). The verify-email-sent page reassures the user
// and offers to resend the verification email.
//
// Anchor on `Astro.url.origin` (the actual request host) so users
// signing up from staging.hospeda.com.ar don't get bounced to the
// canonical apex post-registration.
const redirectTo = new URL(
    buildUrl({ locale, path: 'auth/verify-email-sent' }),
    Astro.url.origin
).href;

// OAuth providers (Google, Facebook) verify email themselves, so the
// user is fully authenticated when the callback returns. Sending them
// to /auth/verify-email-sent/ would be confusing ("check your inbox"
// when there's no email to check). Land them on the account dashboard
// instead.
const oauthRedirectTo = new URL(
    buildUrl({ locale, path: 'mi-cuenta' }),
    Astro.url.origin
).href;

// Localized secondary link labels via i18n
const haveAccountLabel = t('auth-ui.signUp.alreadyHaveAccount', 'Already have an account?');
const signInLabel = t('auth-ui.signUp.signInLink', 'Sign In');
---

<AuthLayout locale={locale} title={title} description={description}>
    <div slot="decoratives" class="signup-deco" aria-hidden="true">
        <div class="signup-deco__blob"></div>
        <span class="signup-deco__shape signup-deco__shape--sparkle">
            <SparkleIcon size={84} weight="duotone" />
        </span>
        <span class="signup-deco__badge signup-deco__badge--users">
            <UsersIcon size="md" weight="duotone" />
        </span>
        <span class="signup-deco__dot signup-deco__dot--1"></span>
        <span class="signup-deco__dot signup-deco__dot--2"></span>
        <span class="signup-deco__dot signup-deco__dot--3"></span>
    </div>

    <SignUp
        client:load
        locale={locale}
        redirectTo={redirectTo}
        oauthRedirectTo={oauthRedirectTo}
        showOAuth={true}
    />

    <div class="auth-page__footer">
        <span class="auth-page__footer-text">{haveAccountLabel}</span>
        {' '}
        <a
            href={buildUrl({ locale, path: 'auth/signin' })}
            class="auth-page__link auth-page__link--strong"
        >
            {signInLabel}
        </a>
    </div>
</AuthLayout>

<style is:global>
    /* Decoratives — rendered inside the AuthLayout 'decoratives' slot, outside .auth-card. */
    .signup-deco {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .signup-deco__blob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(360px, 60vw, 720px);
        height: clamp(360px, 60vw, 720px);
        border-radius: 50%;
        background: radial-gradient(
            circle at 40% 40%,
            oklch(from var(--brand-accent) l c h / 0.16),
            oklch(from var(--brand-primary) l c h / 0.06) 55%,
            transparent 75%
        );
        filter: blur(4px);
    }

    .signup-deco__shape {
        position: absolute;
        display: inline-flex;
    }

    .signup-deco__shape--sparkle {
        top: 12%;
        right: 9%;
        color: var(--brand-accent);
        opacity: 0.4;
        transform: rotate(15deg);
    }

    .signup-deco__badge {
        position: absolute;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background-color: var(--core-card);
        box-shadow: var(--shadow-card);
        color: var(--brand-primary);
    }

    .signup-deco__badge--users {
        bottom: 16%;
        left: 8%;
    }

    .signup-deco__dot {
        position: absolute;
        border-radius: 50%;
    }
    .signup-deco__dot--1 {
        top: 30%;
        left: 10%;
        width: 10px;
        height: 10px;
        background-color: oklch(from var(--brand-primary) l c h / 0.28);
    }
    .signup-deco__dot--2 {
        top: 22%;
        left: 22%;
        width: 7px;
        height: 7px;
        background-color: oklch(from var(--brand-accent) l c h / 0.32);
    }
    .signup-deco__dot--3 {
        bottom: 26%;
        right: 14%;
        width: 11px;
        height: 11px;
        background-color: oklch(from var(--brand-accent) l c h / 0.25);
    }

    @media (max-width: 700px) {
        .signup-deco__shape,
        .signup-deco__badge {
            display: none;
        }
    }
</style>

<style>
    .auth-page {
        display: flex;
        min-height: calc(100vh - var(--navbar-height, 5rem));
        align-items: center;
        justify-content: center;
        padding: var(--space-8, 2rem) var(--space-4, 1rem);
    }

    .auth-page__card {
        width: 100%;
        max-width: 28rem;
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
        background-color: var(--core-card);
        padding: var(--space-8, 2rem);
        box-shadow: var(--shadow-card);
    }

    .auth-page__footer {
        margin-top: var(--space-6, 1.5rem);
        text-align: center;
    }

    .auth-page__footer-text {
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
    }

    .auth-page__link {
        font-size: var(--text-body-sm);
        color: var(--brand-primary);
        text-decoration: none;
        transition: color var(--duration-fast) ease;
    }

    .auth-page__link:hover {
        color: oklch(from var(--brand-primary) calc(l * 0.85) c h);
    }

    .auth-page__link:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    .auth-page__link--strong {
        font-weight: 600;
    }
</style>
