---
/**
 * @file signup.astro
 * @description Sign-up page — allows users to create a new account.
 *
 * Authenticated users are immediately redirected to /mi-cuenta/.
 * After a successful registration the user is automatically signed in
 * and redirected to the account dashboard.
 *
 * @route    /[lang]/auth/signup/
 * @rendering SSR (auth state from locals)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { getSiteUrl } from '@/lib/env';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import { SignUp } from '@/components/auth/SignUp.client';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

// Redirect authenticated users to their account dashboard.
if (Astro.locals.user) {
    return Astro.redirect(buildUrl({ locale, path: 'mi-cuenta' }));
}

const t = createT(locale);

const title = t('auth-ui.pages.signup.title', 'Crear cuenta');
const description = t('auth-ui.pages.signup.description', 'Crea tu cuenta en Hospeda');

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// After registration, redirect user to their account dashboard.
const siteOrigin = getSiteUrl();
const redirectTo = new URL(buildUrl({ locale, path: 'mi-cuenta' }), siteOrigin).href;

// Localized secondary link labels via i18n
const haveAccountLabel = t('auth-ui.signUp.alreadyHaveAccount', 'Already have an account?');
const signInLabel = t('auth-ui.signUp.signInLink', 'Sign In');
---

<BaseLayout locale={locale} title={title} description={description}>
    <SEOHead
        slot="head"
        title={title}
        description={description}
        canonical={canonicalUrl}
        locale={locale}
        noindex={true}
    />

    <div class="auth-page">
        <div class="auth-page__card">
            <SignUp client:load locale={locale} redirectTo={redirectTo} showOAuth={true} />

            <div class="auth-page__footer">
                <span class="auth-page__footer-text">{haveAccountLabel}</span>
                {' '}
                <a
                    href={buildUrl({ locale, path: 'auth/signin' })}
                    class="auth-page__link auth-page__link--strong"
                >
                    {signInLabel}
                </a>
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .auth-page {
        display: flex;
        min-height: calc(100vh - var(--header-height, 5rem));
        align-items: center;
        justify-content: center;
        padding: var(--space-section) var(--space-4, 1rem);
    }

    .auth-page__card {
        width: 100%;
        max-width: 28rem;
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
        background-color: var(--core-card);
        padding: var(--space-8, 2rem);
        box-shadow: var(--shadow-card);
    }

    .auth-page__footer {
        margin-top: var(--space-6, 1.5rem);
        text-align: center;
    }

    .auth-page__footer-text {
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
    }

    .auth-page__link {
        font-size: var(--text-body-sm);
        color: var(--brand-primary);
        text-decoration: none;
        transition: color var(--duration-fast) ease;
    }

    .auth-page__link:hover {
        color: oklch(from var(--brand-primary) calc(l * 0.85) c h);
    }

    .auth-page__link:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    .auth-page__link--strong {
        font-weight: 600;
    }
</style>
