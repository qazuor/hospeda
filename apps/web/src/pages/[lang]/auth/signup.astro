---
/**
 * Sign up page - allows users to create a new account.
 *
 * @route /[lang]/auth/signup/
 * @rendering SSR
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import { SignUpClient } from '../../../components/auth/SignUp.client';
import { getLocaleFromParams } from '../../../lib/page-helpers';
import { createT, type SupportedLocale } from '../../../lib/i18n';
import { getSiteUrl } from '../../../lib/env';
import { buildUrl } from '../../../lib/urls';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const typedLocale = locale as SupportedLocale;

/** Redirect authenticated users to home page. */
if (Astro.locals.user) {
    return Astro.redirect(buildUrl({ locale: typedLocale }));
}

const t = createT(typedLocale);
const title = t('auth-ui.pages.signup.title', 'Crear cuenta');
const description = t('auth-ui.pages.signup.description', 'Crea tu cuenta en Hospeda');

const labels: Record<SupportedLocale, { haveAccount: string; signIn: string }> = {
    es: { haveAccount: 'Ya tienes cuenta?', signIn: 'Iniciar sesion' },
    en: { haveAccount: 'Already have an account?', signIn: 'Sign In' },
    pt: { haveAccount: 'Ja tem uma conta?', signIn: 'Entrar' },
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const currentLabels = labels[typedLocale];

const siteOrigin = getSiteUrl();
const redirectTo = new URL(buildUrl({ locale: typedLocale, path: 'mi-cuenta' }), siteOrigin).href;
---

<BaseLayout title={title} description={description} locale={locale}>
    <SEOHead slot="head" title={title} description={description} canonical={canonicalUrl} locale={locale} noindex={true} />

    <div class="flex min-h-screen items-center justify-center py-12 px-4">
        <div class="w-full max-w-md">
            <div class="rounded-xl border border-border bg-card p-8 shadow-lg">
                <SignUpClient client:load redirectTo={redirectTo} showOAuth={true} />

                <div class="mt-6 text-center">
                    <span class="text-sm text-muted-foreground">{currentLabels.haveAccount}</span>
                    {' '}
                    <a
                        href={buildUrl({ locale: typedLocale, path: 'auth/signin' })}
                        class="text-sm font-medium text-primary transition-colors hover:text-primary/80"
                    >
                        {currentLabels.signIn}
                    </a>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>
