---
/**
 * @file verify-email.astro
 * @description Email-verification page — handles the token link from a verification email.
 *
 * The verification token is extracted from the `?token=` query string server-side
 * and passed as a prop to the React island so the island never reads the URL itself.
 * On success the user is redirected to the sign-in page.
 *
 * @route    /[lang]/auth/verify-email/
 * @rendering SSR (reads `token` from query params)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import AuthLayout from '@/layouts/AuthLayout.astro';
import { VerifyEmail } from '@/components/auth/VerifyEmail.client';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

const t = createT(locale);

const title = t('auth-ui.pages.verifyEmail.title', 'Verificar correo');
const description = t(
    'auth-ui.pages.verifyEmail.description',
    'Verificación de correo electrónico'
);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// Extract the verification token from the URL query string.
const token = Astro.url.searchParams.get('token') ?? '';

// After successful verification, redirect the user to sign in.
const redirectTo = buildUrl({ locale, path: 'auth/signin' });
---

<AuthLayout locale={locale} title={title} description={description}>
    <div slot="decoratives" class="verify-email-deco" aria-hidden="true">
        <div class="verify-email-deco__blob"></div>
        <span class="verify-email-deco__dot verify-email-deco__dot--1"></span>
        <span class="verify-email-deco__dot verify-email-deco__dot--2"></span>
    </div>

    <VerifyEmail client:load locale={locale} token={token} redirectTo={redirectTo} />
</AuthLayout>

<style is:global>
    /* Decoratives live in the AuthLayout decoratives slot, outside .auth-card.
       Marked global so they survive Astro's scoped-style hashing. */
    .verify-email-deco {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .verify-email-deco__blob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(360px, 60vw, 720px);
        height: clamp(360px, 60vw, 720px);
        border-radius: 50%;
        background: radial-gradient(
            circle at 50% 50%,
            var(--brand-primary-a20),
            var(--brand-accent-a08) 55%,
            transparent 75%
        );
        filter: blur(4px);
    }

    .verify-email-deco__dot {
        position: absolute;
        border-radius: 50%;
    }
    .verify-email-deco__dot--1 {
        top: 14%;
        left: 10%;
        width: 12px;
        height: 12px;
        background-color: var(--brand-primary-a30);
    }
    .verify-email-deco__dot--2 {
        bottom: 18%;
        right: 12%;
        width: 9px;
        height: 9px;
        background-color: var(--brand-accent-a30);
    }
</style>
