---
/**
 * Reset password page - allows users to set a new password with a reset token.
 * Uses the ResetPasswordClient React island for interactive form via Better Auth.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Container from '../../../components/ui/Container.astro';
import { ResetPasswordClient } from '../../../components/auth/ResetPassword.client';
import { getLocaleFromParams } from '../../../lib/page-helpers';
import { t } from '../../../lib/i18n';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const title = t({ locale, namespace: 'auth-ui', key: 'pages.resetPassword.title' });
const description = t({ locale, namespace: 'auth-ui', key: 'pages.resetPassword.description' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const signInUrl = `/${locale}/auth/signin`;

/** Extract the reset token from URL query params */
const token = Astro.url.searchParams.get('token') || '';
---

<BaseLayout title={title} description={description} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<div class="flex min-h-screen items-center justify-center py-12">
			<div class="w-full max-w-md">
				<div class="rounded-lg border border-border bg-bg-secondary p-8 shadow-lg">
					<ResetPasswordClient
						client:load
						token={token}
						signInUrl={signInUrl}
					/>
				</div>
			</div>
		</div>
	</Container>
</BaseLayout>
