---
/**
 * @file reset-password.astro
 * @description Reset-password page — lets users set a new password via a one-time token.
 *
 * The reset token is extracted from the `?token=` query string server-side and
 * passed as a prop to the React island so the island never reads the URL itself.
 *
 * @route    /[lang]/auth/reset-password/
 * @rendering SSR (reads `token` from query params)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import { ResetPassword } from '@/components/auth/ResetPassword.client';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

const t = createT(locale);

const title = t('auth-ui.pages.resetPassword.title', 'Restablecer contraseña');
const description = t(
    'auth-ui.pages.resetPassword.description',
    'Establece una nueva contraseña para tu cuenta'
);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const signInUrl = buildUrl({ locale, path: 'auth/signin' });

// Extract the reset token from the URL query string.
const token = Astro.url.searchParams.get('token') ?? '';
---

<BaseLayout locale={locale} title={title} description={description}>
    <SEOHead
        slot="head"
        title={title}
        description={description}
        canonical={canonicalUrl}
        locale={locale}
        noindex={true}
    />

    <div class="auth-page">
        <div class="auth-page__card">
            <ResetPassword client:load locale={locale} token={token} signInUrl={signInUrl} />
        </div>
    </div>
</BaseLayout>

<style>
    .auth-page {
        display: flex;
        min-height: calc(100vh - var(--header-height, 5rem));
        align-items: center;
        justify-content: center;
        padding: var(--space-8, 2rem) var(--space-4, 1rem);
    }

    .auth-page__card {
        width: 100%;
        max-width: 28rem;
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
        background-color: var(--core-card);
        padding: var(--space-8, 2rem);
        box-shadow: var(--shadow-card);
    }
</style>
