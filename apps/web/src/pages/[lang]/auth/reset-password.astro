---
/**
 * Reset password page - allows users to set a new password with a reset token.
 * Uses the ResetPasswordIsland React island for interactive form via Better Auth.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Container from '../../../components/ui/Container.astro';
import { ResetPasswordIsland } from '../../../components/auth/ResetPasswordIsland';
import { isValidLocale, type SupportedLocale } from '../../../lib/i18n';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * Localized page titles
 */
const titles: Record<SupportedLocale, string> = {
	es: 'Restablecer contraseña',
	en: 'Reset Password',
	pt: 'Redefinir senha',
};

/**
 * Localized meta descriptions
 */
const descriptions: Record<SupportedLocale, string> = {
	es: 'Establece una nueva contraseña para tu cuenta de Hospeda',
	en: 'Set a new password for your Hospeda account',
	pt: 'Defina uma nova senha para sua conta Hospeda',
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const signInUrl = `/${locale}/auth/signin`;

/** Extract the reset token from URL query params */
const token = Astro.url.searchParams.get('token') || '';
---

<BaseLayout title={titles[locale]} description={descriptions[locale]} locale={locale}>
	<SEOHead
		slot="head"
		title={titles[locale]}
		description={descriptions[locale]}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<div class="flex min-h-screen items-center justify-center py-12">
			<div class="w-full max-w-md">
				<div class="rounded-lg border border-border bg-bg-secondary p-8 shadow-lg">
					<ResetPasswordIsland
						client:load
						token={token}
						signInUrl={signInUrl}
					/>
				</div>
			</div>
		</div>
	</Container>
</BaseLayout>
