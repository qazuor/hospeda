---
/**
 * @file reset-password.astro
 * @description Reset-password page — lets users set a new password via a one-time token.
 *
 * The reset token is extracted from the `?token=` query string server-side and
 * passed as a prop to the React island so the island never reads the URL itself.
 *
 * @route    /[lang]/auth/reset-password/
 * @rendering SSR (reads `token` from query params)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import AuthLayout from '@/layouts/AuthLayout.astro';
import { ResetPassword } from '@/components/auth/ResetPassword.client';
import { CheckCircleIcon, ShieldIcon } from '@repo/icons';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

const t = createT(locale);

const title = t('auth-ui.pages.resetPassword.title', 'Restablecer contraseña');
const description = t(
    'auth-ui.pages.resetPassword.description',
    'Establece una nueva contraseña para tu cuenta'
);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const signInUrl = buildUrl({ locale, path: 'auth/signin' });

// Extract the reset token from the URL query string.
const token = Astro.url.searchParams.get('token') ?? '';
---

<AuthLayout locale={locale} title={title} description={description}>
    <div slot="decoratives" class="reset-deco" aria-hidden="true">
        <div class="reset-deco__blob"></div>
        <span class="reset-deco__shape reset-deco__shape--shield">
            <ShieldIcon size={88} weight="duotone" />
        </span>
        <span class="reset-deco__badge reset-deco__badge--check">
            <CheckCircleIcon size="md" weight="duotone" />
        </span>
        <span class="reset-deco__dot reset-deco__dot--1"></span>
        <span class="reset-deco__dot reset-deco__dot--2"></span>
    </div>

    <ResetPassword client:load locale={locale} token={token} signInUrl={signInUrl} />
</AuthLayout>

<style is:global>
    /* Decoratives — rendered inside the AuthLayout 'decoratives' slot, outside .auth-card. */
    .reset-deco {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .reset-deco__blob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(360px, 60vw, 720px);
        height: clamp(360px, 60vw, 720px);
        border-radius: 50%;
        background: radial-gradient(
            circle at 50% 50%,
            oklch(from var(--brand-primary) l c h / 0.16),
            oklch(0.65 0.18 145 / 0.06) 55%,
            transparent 75%
        );
        filter: blur(4px);
    }

    .reset-deco__shape {
        position: absolute;
        display: inline-flex;
    }

    .reset-deco__shape--shield {
        top: 12%;
        left: 7%;
        color: var(--brand-primary);
        opacity: 0.38;
        transform: rotate(-10deg);
    }

    .reset-deco__badge {
        position: absolute;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background-color: var(--core-card);
        box-shadow: var(--shadow-card);
        color: oklch(0.55 0.18 145);
    }

    .reset-deco__badge--check {
        bottom: 18%;
        right: 9%;
    }

    .reset-deco__dot {
        position: absolute;
        border-radius: 50%;
    }
    .reset-deco__dot--1 {
        top: 30%;
        right: 13%;
        width: 11px;
        height: 11px;
        background-color: oklch(from var(--brand-primary) l c h / 0.26);
    }
    .reset-deco__dot--2 {
        bottom: 28%;
        left: 11%;
        width: 9px;
        height: 9px;
        background-color: oklch(0.65 0.18 145 / 0.3);
    }

    @media (max-width: 700px) {
        .reset-deco__shape,
        .reset-deco__badge {
            display: none;
        }
    }
</style>

<style>
    .auth-page {
        display: flex;
        min-height: calc(100vh - var(--navbar-height, 5rem));
        align-items: center;
        justify-content: center;
        padding: var(--space-8, 2rem) var(--space-4, 1rem);
    }

    .auth-page__card {
        width: 100%;
        max-width: 28rem;
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
        background-color: var(--core-card);
        padding: var(--space-8, 2rem);
        box-shadow: var(--shadow-card);
    }
</style>
