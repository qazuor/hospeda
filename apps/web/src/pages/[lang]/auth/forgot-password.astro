---
/**
 * Forgot password page - allows users to request a password reset link.
 *
 * @route /[lang]/auth/forgot-password/
 * @rendering SSR (dynamic)
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import { ForgotPasswordClient } from '../../../components/auth/ForgotPassword.client';
import { getLocaleFromParams } from '../../../lib/page-helpers';
import { createT, type SupportedLocale } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const typedLocale = locale as SupportedLocale;
const t = createT(typedLocale);
const title = t('auth-ui.pages.forgotPassword.title', 'Recuperar contrasena');
const description = t('auth-ui.pages.forgotPassword.description', 'Solicita un enlace para restablecer tu contrasena');

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const resetPasswordUrl = buildUrl({ locale: typedLocale, path: 'auth/reset-password' });
const signInUrl = buildUrl({ locale: typedLocale, path: 'auth/signin' });
---

<BaseLayout title={title} description={description} locale={locale}>
    <SEOHead slot="head" title={title} description={description} canonical={canonicalUrl} locale={locale} noindex={true} />

    <div class="flex min-h-screen items-center justify-center py-12 px-4">
        <div class="w-full max-w-md">
            <div class="rounded-xl border border-border bg-card p-8 shadow-lg">
                <ForgotPasswordClient
                    client:load
                    resetPasswordUrl={resetPasswordUrl}
                    signInUrl={signInUrl}
                />
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    import { getApiUrl } from '../../../lib/env';

    /**
     * Client-side auth guard for SSG auth pages.
     * Checks if user is already authenticated and redirects to home.
     */
    async function redirectIfAuthenticated() {
        try {
            const apiUrl = getApiUrl();
            const res = await fetch(`${apiUrl}/api/auth/get-session`, { credentials: 'include' });
            if (res.ok) {
                const data = await res.json();
                if (data?.user?.id) {
                    const locale = window.location.pathname.split('/')[1] || 'es';
                    window.location.replace(`/${locale}/`);
                }
            }
        } catch {
            // Ignore - user is not authenticated or API is unreachable
        }
    }
    void redirectIfAuthenticated();
</script>
