---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../../lib/page-helpers';

/**
 * Forgot password page - allows users to request a password reset link.
 * Uses the ForgotPasswordClient React island for interactive form via Better Auth.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Container from '../../../components/ui/Container.astro';
import { ForgotPasswordClient } from '../../../components/auth/ForgotPassword.client';
import { getLocaleFromParams } from '../../../lib/page-helpers';
import { t } from '../../../lib/i18n';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const title = t({ locale, namespace: 'auth-ui', key: 'pages.forgotPassword.title' });
const description = t({ locale, namespace: 'auth-ui', key: 'pages.forgotPassword.description' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const resetPasswordUrl = `/${locale}/auth/reset-password`;
const signInUrl = `/${locale}/auth/signin`;
---

<BaseLayout title={title} description={description} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<div class="flex min-h-screen items-center justify-center py-12">
			<div class="w-full max-w-md">
				<div class="rounded-lg border border-border bg-bg-secondary p-8 shadow-lg">
					<ForgotPasswordClient
						client:load
						resetPasswordUrl={resetPasswordUrl}
						signInUrl={signInUrl}
					/>
				</div>
			</div>
		</div>
	</Container>
</BaseLayout>

<script>
	import { getApiUrl } from '../../../lib/env';

	/**
	 * Client-side auth guard for SSG auth pages.
	 * Checks if user is already authenticated and redirects to home.
	 */
	async function redirectIfAuthenticated() {
		try {
			const apiUrl = getApiUrl();
			const res = await fetch(`${apiUrl}/api/auth/get-session`, { credentials: 'include' });
			if (res.ok) {
				const data = await res.json();
				if (data?.user?.id) {
					const locale = window.location.pathname.split('/')[1] || 'es';
					window.location.replace(`/${locale}/`);
				}
			}
		} catch {
			// Ignore - user is not authenticated or API is unreachable
		}
	}
	void redirectIfAuthenticated();
</script>
