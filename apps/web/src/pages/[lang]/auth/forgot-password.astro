---
/**
 * @file forgot-password.astro
 * @description Forgot-password page — lets users request a password-reset email.
 *
 * No server-side auth guard (unauthenticated users need this page).
 * An inline client-side script redirects already-authenticated users away.
 *
 * @route    /[lang]/auth/forgot-password/
 * @rendering SSR
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import { ForgotPassword } from '@/components/auth/ForgotPassword.client';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

const t = createT(locale);

const title = t('auth-ui.pages.forgotPassword.title', 'Recuperar contrasena');
const description = t(
    'auth-ui.pages.forgotPassword.description',
    'Solicita un enlace para restablecer tu contrasena'
);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// The reset-password URL is embedded inside the email sent to the user.
const resetPasswordUrl = buildUrl({ locale, path: 'auth/reset-password' });
const signInUrl = buildUrl({ locale, path: 'auth/signin' });
---

<BaseLayout locale={locale} title={title} description={description}>
    <SEOHead
        slot="head"
        title={title}
        description={description}
        canonical={canonicalUrl}
        locale={locale}
        noindex={true}
    />

    <div class="auth-page">
        <div class="auth-page__card">
            <ForgotPassword
                client:load
                locale={locale}
                resetPasswordUrl={resetPasswordUrl}
                signInUrl={signInUrl}
            />
        </div>
    </div>
</BaseLayout>

<style>
    .auth-page {
        display: flex;
        min-height: calc(100vh - var(--header-height, 5rem));
        align-items: center;
        justify-content: center;
        padding: var(--space-section) var(--space-4, 1rem);
    }

    .auth-page__card {
        width: 100%;
        max-width: 28rem;
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
        background-color: var(--core-card);
        padding: var(--space-8, 2rem);
        box-shadow: var(--shadow-card);
    }
</style>

<script>
    import { getApiUrl } from '@/lib/env';

    /**
     * Client-side guard: redirect already-authenticated users to the locale root.
     * This page is accessible to unauthenticated users so we cannot use a server
     * redirect without parsing the session — the client script is lighter.
     */
    async function redirectIfAuthenticated(): Promise<void> {
        try {
            const apiUrl = getApiUrl();
            const res = await fetch(`${apiUrl}/api/auth/get-session`, { credentials: 'include' });
            if (res.ok) {
                const data = (await res.json()) as { user?: { id?: string } };
                if (data?.user?.id) {
                    const locale = window.location.pathname.split('/')[1] || 'es';
                    window.location.replace(`/${locale}/`);
                }
            }
        } catch {
            // Ignore — user is not authenticated or the API is unreachable.
        }
    }

    void redirectIfAuthenticated();
</script>
