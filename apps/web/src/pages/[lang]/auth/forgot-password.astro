---
/**
 * @file forgot-password.astro
 * @description Forgot-password page — lets users request a password-reset email.
 *
 * No server-side auth guard (unauthenticated users need this page).
 * An inline client-side script redirects already-authenticated users away.
 *
 * @route    /[lang]/auth/forgot-password/
 * @rendering SSR
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import AuthLayout from '@/layouts/AuthLayout.astro';
import { ForgotPassword } from '@/components/auth/ForgotPassword.client';
import { InfoIcon, MailIcon } from '@repo/icons';

// Locale is injected by middleware — always a valid SupportedLocale.
const locale = Astro.locals.locale as SupportedLocale;

const t = createT(locale);

const title = t('auth-ui.pages.forgotPassword.title', 'Recuperar contraseña');
const description = t(
    'auth-ui.pages.forgotPassword.description',
    'Solicitá un enlace para restablecer tu contraseña'
);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// The reset-password URL is embedded inside the email sent to the user.
const resetPasswordUrl = buildUrl({ locale, path: 'auth/reset-password' });
const signInUrl = buildUrl({ locale, path: 'auth/signin' });
---

<AuthLayout locale={locale} title={title} description={description}>
    <div slot="decoratives" class="forgot-deco" aria-hidden="true">
        <div class="forgot-deco__blob"></div>
        <span class="forgot-deco__shape forgot-deco__shape--info">
            <InfoIcon size={76} weight="duotone" />
        </span>
        <span class="forgot-deco__badge forgot-deco__badge--mail">
            <MailIcon size="md" weight="duotone" />
        </span>
        <span class="forgot-deco__dot forgot-deco__dot--1"></span>
        <span class="forgot-deco__dot forgot-deco__dot--2"></span>
    </div>

    <ForgotPassword
        client:load
        locale={locale}
        resetPasswordUrl={resetPasswordUrl}
        signInUrl={signInUrl}
    />
</AuthLayout>

<style is:global>
    /* Decoratives — rendered inside the AuthLayout 'decoratives' slot, outside .auth-card. */
    .forgot-deco {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .forgot-deco__blob {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(360px, 60vw, 720px);
        height: clamp(360px, 60vw, 720px);
        border-radius: 50%;
        background: radial-gradient(
            circle at 50% 50%,
            oklch(from var(--brand-primary) l c h / 0.16),
            oklch(from var(--brand-accent) l c h / 0.06) 55%,
            transparent 75%
        );
        filter: blur(4px);
    }

    .forgot-deco__shape {
        position: absolute;
        display: inline-flex;
    }

    .forgot-deco__shape--info {
        top: 16%;
        left: 9%;
        color: var(--brand-primary);
        opacity: 0.32;
        transform: rotate(-8deg);
    }

    .forgot-deco__badge {
        position: absolute;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background-color: var(--core-card);
        box-shadow: var(--shadow-card);
        color: var(--brand-accent);
    }

    .forgot-deco__badge--mail {
        top: 14%;
        right: 10%;
    }

    .forgot-deco__dot {
        position: absolute;
        border-radius: 50%;
    }
    .forgot-deco__dot--1 {
        bottom: 22%;
        left: 14%;
        width: 11px;
        height: 11px;
        background-color: oklch(from var(--brand-primary) l c h / 0.26);
    }
    .forgot-deco__dot--2 {
        bottom: 30%;
        right: 12%;
        width: 8px;
        height: 8px;
        background-color: oklch(from var(--brand-accent) l c h / 0.3);
    }

    @media (max-width: 700px) {
        .forgot-deco__shape,
        .forgot-deco__badge {
            display: none;
        }
    }
</style>

<style>
    .auth-page {
        display: flex;
        min-height: calc(100vh - var(--navbar-height, 5rem));
        align-items: center;
        justify-content: center;
        padding: var(--space-8, 2rem) var(--space-4, 1rem);
    }

    .auth-page__card {
        width: 100%;
        max-width: 28rem;
        border-radius: var(--radius-card);
        border: 1px solid var(--border);
        background-color: var(--core-card);
        padding: var(--space-8, 2rem);
        box-shadow: var(--shadow-card);
    }
</style>

<script>
    import { getApiUrl } from '@/lib/env';

    /**
     * Client-side guard: redirect already-authenticated users to the locale root.
     * This page is accessible to unauthenticated users so we cannot use a server
     * redirect without parsing the session — the client script is lighter.
     */
    async function redirectIfAuthenticated(): Promise<void> {
        try {
            const apiUrl = getApiUrl();
            const res = await fetch(`${apiUrl}/api/auth/get-session`, { credentials: 'include' });
            if (res.ok) {
                const data = (await res.json()) as { user?: { id?: string } };
                if (data?.user?.id) {
                    const locale = window.location.pathname.split('/')[1] || 'es';
                    window.location.replace(`/${locale}/`);
                }
            }
        } catch {
            // Ignore — user is not authenticated or the API is unreachable.
        }
    }

    void redirectIfAuthenticated();
</script>
