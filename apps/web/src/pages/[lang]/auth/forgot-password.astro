---
export const prerender = true;

export function getStaticPaths() {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

/**
 * Forgot password page - allows users to request a password reset link.
 * Uses the ForgotPasswordIsland React island for interactive form via Better Auth.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Container from '../../../components/ui/Container.astro';
import { ForgotPasswordIsland } from '../../../components/auth/ForgotPasswordIsland';
import { isValidLocale, type SupportedLocale } from '../../../lib/i18n';

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
	return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * Localized page titles
 */
const titles: Record<SupportedLocale, string> = {
	es: 'Recuperar contraseña',
	en: 'Forgot Password',
	pt: 'Esqueci a senha',
};

/**
 * Localized meta descriptions
 */
const descriptions: Record<SupportedLocale, string> = {
	es: 'Recupera tu contraseña de Hospeda. Te enviaremos un enlace para restablecer tu contraseña',
	en: 'Recover your Hospeda password. We will send you a link to reset your password',
	pt: 'Recupere sua senha do Hospeda. Enviaremos um link para redefinir sua senha',
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const resetPasswordUrl = `/${locale}/auth/reset-password`;
const signInUrl = `/${locale}/auth/signin`;
---

<BaseLayout title={titles[locale]} description={descriptions[locale]} locale={locale}>
	<SEOHead
		slot="head"
		title={titles[locale]}
		description={descriptions[locale]}
		canonical={canonicalUrl}
		locale={locale === 'pt' ? 'es' : locale}
		type="website"
		noindex={true}
	/>

	<Container>
		<div class="flex min-h-screen items-center justify-center py-12">
			<div class="w-full max-w-md">
				<div class="rounded-lg border border-border bg-bg-secondary p-8 shadow-lg">
					<ForgotPasswordIsland
						client:load
						resetPasswordUrl={resetPasswordUrl}
						signInUrl={signInUrl}
					/>
				</div>
			</div>
		</div>
	</Container>
</BaseLayout>

<script>
	/**
	 * Client-side auth guard for SSG auth pages.
	 * Checks if user is already authenticated and redirects to home.
	 */
	async function redirectIfAuthenticated() {
		try {
			const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';
			const res = await fetch(`${apiUrl}/api/auth/get-session`, { credentials: 'include' });
			if (res.ok) {
				const data = await res.json();
				if (data?.user?.id) {
					const locale = window.location.pathname.split('/')[1] || 'es';
					window.location.replace(`/${locale}/`);
				}
			}
		} catch {
			// Ignore - user is not authenticated or API is unreachable
		}
	}
	void redirectIfAuthenticated();
</script>
