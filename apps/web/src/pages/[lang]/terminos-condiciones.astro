---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../lib/page-helpers';

/**
 * Terms and Conditions page - legal information about service usage.
 *
 * Rendering: SSG (pre-rendered for all supported locales)
 * Route: /[lang]/terminos-condiciones/
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/seo/SEOHead.astro';
import Breadcrumb from '../../components/shared/Breadcrumb.astro';
import { formatDate, toBcp47Locale } from '@repo/i18n';
import { createT } from '../../lib/i18n';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../lib/page-helpers';
import { buildUrl } from '../../lib/urls';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const t = createT(locale);

const title = t('terms.page.title', 'Terminos y Condiciones');
const description = t('terms.page.description', 'Conoce los terminos y condiciones de uso de la plataforma Hospeda.');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items for the page.
 */
const breadcrumbItems = [
  { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
  { label: title, href: buildUrl({ locale, path: 'terminos-condiciones' }) },
];
---

<BaseLayout title={title} description={description} locale={locale}>
  <SEOHead
    slot="head"
    title={title}
    description={description}
    canonical={canonicalUrl}
    locale={locale}
    type="website"
  />

  <div class="container mx-auto max-w-4xl px-4 py-8">
    <Breadcrumb items={breadcrumbItems} />

    <div class="prose prose-lg mx-auto mt-6">
      <h1 class="mb-8 text-4xl font-bold text-foreground">
        {title}
      </h1>

      <div class="space-y-8">
        <!-- Section 1: Aceptacion de los terminos -->
        <article id="section-1">
          <h2 class="mb-4 text-2xl font-semibold text-foreground">
            1. {t('terms.sections.acceptance.title', 'Aceptacion de los terminos')}
          </h2>
          <p class="text-muted-foreground">
            {t(
              'terms.sections.acceptance.body',
              'Al acceder y utilizar esta plataforma, usted acepta estar sujeto a estos terminos y condiciones de uso. Si no esta de acuerdo con alguno de estos terminos, le pedimos que no utilice nuestros servicios. Este acuerdo constituye un contrato vinculante entre usted y Hospeda.'
            )}
          </p>
        </article>

        <!-- Section 2: Uso del servicio -->
        <article id="section-2">
          <h2 class="mb-4 text-2xl font-semibold text-foreground">
            2. {t('terms.sections.usage.title', 'Uso del servicio')}
          </h2>
          <p class="text-muted-foreground">
            {t(
              'terms.sections.usage.body',
              'Usted se compromete a utilizar nuestros servicios de manera responsable y legal. Esta prohibido usar la plataforma para actividades ilegales, fraudulentas o que violen los derechos de terceros. Nos reservamos el derecho de suspender o cancelar cuentas que incumplan estas normas.'
            )}
          </p>
        </article>

        <!-- Section 3: Cuentas de usuario -->
        <article id="section-3">
          <h2 class="mb-4 text-2xl font-semibold text-foreground">
            3. {t('terms.sections.accounts.title', 'Cuentas de usuario')}
          </h2>
          <p class="text-muted-foreground">
            {t(
              'terms.sections.accounts.body',
              'Para acceder a ciertas funcionalidades, debera crear una cuenta. Es su responsabilidad mantener la confidencialidad de sus credenciales y todas las actividades realizadas bajo su cuenta. Debe notificarnos inmediatamente sobre cualquier uso no autorizado.'
            )}
          </p>
        </article>

        <!-- Section 4: Contenido -->
        <article id="section-4">
          <h2 class="mb-4 text-2xl font-semibold text-foreground">
            4. {t('terms.sections.content.title', 'Contenido')}
          </h2>
          <p class="text-muted-foreground">
            {t(
              'terms.sections.content.body',
              'Los usuarios son responsables del contenido que publican en la plataforma. Al publicar contenido, usted otorga a Hospeda una licencia no exclusiva para usar, reproducir y distribuir dicho contenido. Nos reservamos el derecho de eliminar contenido que consideremos inapropiado.'
            )}
          </p>
        </article>

        <!-- Section 5: Responsabilidad -->
        <article id="section-5">
          <h2 class="mb-4 text-2xl font-semibold text-foreground">
            5. {t('terms.sections.liability.title', 'Responsabilidad')}
          </h2>
          <p class="text-muted-foreground">
            {t(
              'terms.sections.liability.body',
              'Hospeda actua como intermediario entre proveedores de alojamiento y usuarios. No nos hacemos responsables de la calidad, seguridad o legalidad de los servicios ofrecidos por terceros. El uso de la plataforma es bajo su propio riesgo.'
            )}
          </p>
        </article>

        <!-- Section 6: Modificaciones -->
        <article id="section-6">
          <h2 class="mb-4 text-2xl font-semibold text-foreground">
            6. {t('terms.sections.modifications.title', 'Modificaciones')}
          </h2>
          <p class="text-muted-foreground">
            {t(
              'terms.sections.modifications.body',
              'Nos reservamos el derecho de modificar estos terminos y condiciones en cualquier momento. Los cambios entraran en vigor inmediatamente despues de su publicacion en la plataforma. Es su responsabilidad revisar periodicamente estos terminos.'
            )}
          </p>
        </article>

        <!-- Section 7: Contacto -->
        <article id="section-7">
          <h2 class="mb-4 text-2xl font-semibold text-foreground">
            7. {t('terms.sections.contact.title', 'Contacto')}
          </h2>
          <p class="text-muted-foreground">
            {t(
              'terms.sections.contact.body',
              'Si tiene preguntas sobre estos terminos y condiciones, puede contactarnos a traves de los canales de comunicacion disponibles en nuestra plataforma. Haremos nuestro mejor esfuerzo para responder sus consultas a la brevedad.'
            )}
          </p>
          <p class="mt-4">
            <a
              href={buildUrl({ locale, path: 'contacto' })}
              class="text-primary underline underline-offset-4 transition-colors hover:text-primary/80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            >
              {t('terms.sections.contact.cta', 'Ir a la pagina de contacto')}
            </a>
          </p>
        </article>
      </div>

      <div class="mt-12 border-t border-border pt-6">
        <p class="text-sm text-muted-foreground">
          {t('terms.lastUpdated', 'Ultima actualizacion')}:{' '}
          {formatDate({ date: new Date(), locale: toBcp47Locale(locale) })}
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
