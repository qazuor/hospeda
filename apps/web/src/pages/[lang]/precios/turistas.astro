---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../../lib/page-helpers';

/**
 * Tourist pricing page.
 * Displays subscription plans for tourists fetched from the billing API,
 * with locale-specific hardcoded fallback data on failure.
 *
 * Rendering: SSG (pre-rendered at build time for all supported locales)
 * Route: /[lang]/precios/turistas/
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import BackgroundPattern from '../../../components/shared/BackgroundPattern.astro';
import DecorativeElement from '../../../components/shared/DecorativeElement.astro';
import PricingCard from '../../../components/shared/PricingCard.astro';
import { createT } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';
import { getLocaleFromParams } from '../../../lib/page-helpers';
import { fetchTouristPlans } from '../../../lib/pricing-plans';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const t = createT(locale);

const pageTitle = t('billing.pricing.tourist.title', 'Planes para Turistas');
const pageDescription = t('billing.pricing.tourist.description', 'Encontra el plan ideal para explorar los mejores alojamientos del Litoral argentino.');
const pricingBreadcrumb = t('billing.pricing.breadcrumb', 'Precios');
const heroTitle = t('billing.pricing.tourist.hero.title', 'Planes pensados para el viajero');
const heroDescription = t('billing.pricing.tourist.hero.description', 'Accede a funciones exclusivas y encontra el alojamiento perfecto para tu proximo viaje.');
const faqHeading = t('billing.pricing.tourist.faq.heading', 'Preguntas frecuentes');
const ctaTitle = t('billing.pricing.tourist.cta.title', 'Comenzá gratis hoy');
const ctaDescription = t('billing.pricing.tourist.cta.description', 'Registrate sin costo y empieza a explorar los mejores destinos del Litoral.');
const ctaButton = t('billing.pricing.tourist.cta.button', 'Crear cuenta gratis');

/** FAQ items resolved from i18n */
const faqItems = [0, 1, 2].map((i) => ({
    question: t(`billing.pricing.tourist.faq.items.${i}.question`, ''),
    answer: t(`billing.pricing.tourist.faq.items.${i}.answer`, ''),
}));

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items for this page.
 */
const breadcrumbItems = [
    { label: t('nav.home', 'Inicio'), href: buildUrl({ locale, path: '' }) },
    { label: pricingBreadcrumb, href: buildUrl({ locale, path: 'precios' }) },
    { label: pageTitle, href: buildUrl({ locale, path: 'precios/turistas' }) },
] as const;

/**
 * Tourist plans fetched from the billing API.
 * Falls back to locale-specific hardcoded data on any API failure.
 */
const currentPlans = await fetchTouristPlans(locale);
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale}
        type="website"
    />

    <div class="relative overflow-hidden">
        <BackgroundPattern pattern="/images/pattern-crosses.svg" size="50px 50px" opacity="opacity-35" />
        <DecorativeElement src="/images/deco-brujula.svg" position="top-10 left-6 md:left-16" size="w-16 md:w-24" opacity="opacity-40" />
        <DecorativeElement src="/images/deco-ruta-punteada.svg" position="top-1/3 right-4 md:right-12" size="w-20 md:w-32" opacity="opacity-35" rotate="rotate-6" />

    <div class="container mx-auto px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />

        <div class="mx-auto max-w-6xl">

            <!-- Hero Section -->
            <section id="hero" class="mb-12 text-center" aria-labelledby="hero-title">
                <h1
                    id="hero-title"
                    class="mb-6 text-4xl font-bold text-foreground md:text-5xl"
                >
                    {heroTitle}
                </h1>
                <p class="mx-auto max-w-2xl text-xl leading-relaxed text-muted-foreground">
                    {heroDescription}
                </p>
            </section>

            <!-- Pricing Plans Section -->
            <section
                id="pricing-plans"
                class="scroll-reveal mb-16"
                aria-label={pageTitle}
            >
                <div class="grid gap-8 md:grid-cols-3">
                    {currentPlans.map((plan) => (
                        <PricingCard
                            plan={{
                                name: plan.name,
                                price: plan.price,
                                currency: plan.currency,
                                period: plan.period,
                                features: plan.features,
                                cta: plan.cta,
                            }}
                            highlighted={plan.highlighted}
                        />
                    ))}
                </div>
            </section>

            <!-- FAQ Section -->
            <section id="faq" class="scroll-reveal mb-16" aria-labelledby="faq-heading">
                <h2
                    id="faq-heading"
                    class="mb-8 text-center text-3xl font-semibold text-foreground"
                >
                    {faqHeading}
                </h2>
                <div class="mx-auto max-w-3xl space-y-6">
                    {faqItems.map((faq) => (
                        <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
                            <h3 class="mb-3 text-lg font-semibold text-foreground">
                                {faq.question}
                            </h3>
                            <p class="text-muted-foreground leading-relaxed">
                                {faq.answer}
                            </p>
                        </div>
                    ))}
                </div>
            </section>

            <!-- CTA Section -->
            <section id="cta-section" class="mb-12" aria-labelledby="cta-title">
                <div class="rounded-xl border border-border bg-card p-8 text-center shadow-sm transition-shadow hover:shadow-md">
                    <h2
                        id="cta-title"
                        class="mb-4 text-3xl font-semibold text-foreground"
                    >
                        {ctaTitle}
                    </h2>
                    <p class="mb-8 text-lg leading-relaxed text-muted-foreground">
                        {ctaDescription}
                    </p>
                    <a
                        href={`/${locale}/auth/signup/`}
                        class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-3 font-semibold text-primary-foreground transition-colors hover:bg-primary/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                    >
                        {ctaButton}
                    </a>
                </div>
            </section>

        </div>
    </div>
    </div>
</BaseLayout>
