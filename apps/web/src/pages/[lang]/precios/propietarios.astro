---
/**
 * Property owner pricing page.
 * Displays subscription plans for accommodation owners with a hero section,
 * pricing cards, FAQ accordion, and a conversion CTA.
 * Plan data is fetched from the billing API with graceful fallback to
 * locale-specific hardcoded data.
 *
 * Rendering: SSG (pre-rendered at build time for all supported locales).
 * Route: /[lang]/precios/propietarios/
 */
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../../lib/page-helpers';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import JsonLd from '../../../components/seo/JsonLd.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import BackgroundPattern from '../../../components/shared/BackgroundPattern.astro';
import DecorativeElement from '../../../components/shared/DecorativeElement.astro';
import PricingCard from '../../../components/shared/PricingCard.astro';
import AccordionFAQ from '../../../components/shared/AccordionFAQ.astro';
import GradientButton from '../../../components/shared/GradientButton.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { createT } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';
import { fetchOwnerPlans } from '../../../lib/pricing-plans';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/precios/propietarios/');

/** Translation helper bound to this locale. */
const t = createT(locale);

const pageTitle = t('billing.pricing.owner.title', 'Planes para propietarios');
const pageDescription = t('billing.pricing.owner.description', 'Planes de suscripcion para anfitriones en Hospeda');
const pricingBreadcrumb = t('billing.pricing.breadcrumb', 'Precios');
const heroTitle = t('billing.pricing.owner.hero.title', 'Elegia el plan ideal para tu alojamiento');
const heroDescription = t('billing.pricing.owner.hero.description', 'Comenza a recibir reservas hoy mismo con nuestros planes flexibles');
const faqHeading = t('billing.pricing.owner.faq.heading', 'Preguntas frecuentes');
const ctaTitle = t('billing.pricing.owner.cta.title', 'Listo para publicar tu alojamiento?');
const ctaDescription = t('billing.pricing.owner.cta.description', 'Unite a cientos de propietarios que ya confian en Hospeda');
const ctaButton = t('billing.pricing.owner.cta.button', 'Registrarme como propietario');

/**
 * FAQ items resolved from i18n. Empty entries are filtered out to handle
 * missing translations gracefully.
 */
const faqItems = [0, 1, 2]
    .map((i) => ({
        question: t(`billing.pricing.owner.faq.items.${i}.question`, ''),
        answer: t(`billing.pricing.owner.faq.items.${i}.answer`, '')
    }))
    .filter((item) => Boolean(item.question));

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items.
 */
const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
    { label: pricingBreadcrumb, href: buildUrl({ locale, path: 'precios' }) },
    { label: pageTitle, href: buildUrl({ locale, path: 'precios/propietarios' }) }
] as const;

/**
 * Owner plans fetched from the billing API.
 * Returns locale-specific hardcoded fallback data on any failure.
 */
const currentPlans = await fetchOwnerPlans(locale);

/**
 * BreadcrumbList JSON-LD structured data for rich search results.
 */
const breadcrumbJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.label,
        item: Astro.site ? new URL(item.href, Astro.site).href : item.href
    }))
};
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale}
        type="website"
    />
    <JsonLd slot="head" data={breadcrumbJsonLd} />

    <div class="relative overflow-hidden">
        <BackgroundPattern pattern="/images/pattern-diagonal.svg" size="60px 60px" opacity="opacity-30" />
        <DecorativeElement src="/images/deco-multi-pins.svg" position="top-10 left-6 md:left-16" size="w-18 md:w-28" opacity="opacity-40" />
        <DecorativeElement src="/images/deco-olas.svg" position="bottom-0 right-0" size="w-48 md:w-72" opacity="opacity-30" />

    <div class="container mx-auto px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />

        <div class="mx-auto max-w-6xl">
            <!-- Hero section -->
            <section id="hero" class="mb-12 text-center" aria-labelledby="hero-title">
                <h1
                    id="hero-title"
                    class="mb-6 text-4xl font-bold text-foreground md:text-5xl"
                >
                    {heroTitle}
                </h1>
                <p class="mx-auto max-w-2xl text-xl leading-relaxed text-muted-foreground">
                    {heroDescription}
                </p>
            </section>

            <!-- Pricing cards -->
            <section
                id="pricing-plans"
                class="scroll-reveal mb-16"
                aria-label={t('billing.pricing.owner.plans.heading', 'Planes disponibles')}
            >
                <div class="grid gap-8 md:grid-cols-3">
                    {currentPlans.map((plan) => (
                        <PricingCard
                            plan={{
                                name: plan.name,
                                price: plan.price,
                                currency: plan.currency,
                                period: plan.period,
                                features: plan.features,
                                cta: plan.cta
                            }}
                            highlighted={plan.highlighted}
                        />
                    ))}
                </div>
            </section>

            <!-- FAQ section -->
            {faqItems.length > 0 && (
                <section id="faq" class="scroll-reveal mb-16" aria-labelledby="faq-heading">
                    <h2
                        id="faq-heading"
                        class="mb-8 text-center text-3xl font-semibold text-foreground"
                    >
                        {faqHeading}
                    </h2>
                    <div class="mx-auto max-w-3xl">
                        <AccordionFAQ
                            items={faqItems}
                            ariaLabel={faqHeading}
                        />
                    </div>
                </section>
            )}

            <!-- CTA section -->
            <section
                id="cta-section"
                class="mb-12"
                aria-labelledby="cta-title"
            >
                <div class="rounded-xl border border-border bg-primary/10 p-8 text-center shadow-sm transition-shadow hover:shadow-md">
                    <h2
                        id="cta-title"
                        class="mb-4 text-3xl font-semibold text-foreground"
                    >
                        {ctaTitle}
                    </h2>
                    <p class="mb-8 text-lg leading-relaxed text-muted-foreground">
                        {ctaDescription}
                    </p>
                    <GradientButton
                        href={buildUrl({ locale, path: 'registro/propietario' })}
                        label={ctaButton}
                        showArrow={true}
                    />
                </div>
            </section>
        </div>
    </div>
    </div>
</BaseLayout>
