---
export const prerender = true;

export { getStaticLocalePaths as getStaticPaths } from '../../../lib/page-helpers';

/**
 * Property owner pricing page - displays subscription plans for accommodation owners.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 * Plan data is fetched from the API with graceful fallback to hardcoded data.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import JsonLd from '../../../components/seo/JsonLd.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import PricingCard from '../../../components/content/PricingCard.astro';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { fetchOwnerPlans } from '../../../lib/pricing-plans';
import { t } from '../../../lib/i18n';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const pageTitle = t({ locale, namespace: 'billing', key: 'pricing.owner.title' });
const pageDescription = t({ locale, namespace: 'billing', key: 'pricing.owner.description' });
const pricingBreadcrumb = t({ locale, namespace: 'billing', key: 'pricing.breadcrumb' });
const heroTitle = t({ locale, namespace: 'billing', key: 'pricing.owner.hero.title' });
const heroDescription = t({ locale, namespace: 'billing', key: 'pricing.owner.hero.description' });
const faqHeading = t({ locale, namespace: 'billing', key: 'pricing.owner.faq.heading' });
const ctaTitle = t({ locale, namespace: 'billing', key: 'pricing.owner.cta.title' });
const ctaDescription = t({ locale, namespace: 'billing', key: 'pricing.owner.cta.description' });
const ctaButton = t({ locale, namespace: 'billing', key: 'pricing.owner.cta.button' });

/** FAQ items resolved from i18n */
const faqItems = [0, 1, 2].map((i) => ({
	question: t({ locale, namespace: 'billing', key: `pricing.owner.faq.items.${i}.question` }),
	answer: t({ locale, namespace: 'billing', key: `pricing.owner.faq.items.${i}.answer` }),
}));

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: pricingBreadcrumb, href: `/${locale}/precios/` },
	{ label: pageTitle, href: `/${locale}/precios/propietarios/` },
];

/**
 * Fetch owner plans from the API, falling back to hardcoded data on failure.
 */
const currentPlans = await fetchOwnerPlans(locale);

/**
 * BreadcrumbList JSON-LD structured data
 */
const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumbItems.map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.label,
		item: new URL(item.href, Astro.site).href,
	})),
};
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={pageDescription}
		canonical={canonicalUrl}
		locale={locale}
		type="website"
	/>
	<JsonLd slot="head" data={breadcrumbJsonLd} />

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- Hero Section -->
				<article id="hero" class="mb-12 text-center">
					<h1 class="mb-6 text-4xl font-bold text-text-primary md:text-5xl">
						{heroTitle}
					</h1>
					<p class="text-xl leading-relaxed text-text-secondary">
						{heroDescription}
					</p>
				</article>

				<!-- Pricing Cards Section -->
				<article id="pricing-plans" class="mb-16">
					<div class="grid gap-8 md:grid-cols-3">
						{currentPlans.map((plan) => (
							<PricingCard
								plan={{
									name: plan.name,
									price: plan.price,
									currency: plan.currency,
									period: plan.period,
									features: plan.features,
									cta: plan.cta,
								}}
								highlighted={plan.highlighted}
							/>
						))}
					</div>
				</article>

				<!-- FAQ Section -->
				<article id="faq" class="mb-16">
					<h2 class="mb-8 text-center text-3xl font-semibold text-text-primary">
						{faqHeading}
					</h2>
					<div class="mx-auto max-w-3xl space-y-6">
						{faqItems.map((faq) => (
							<div class="rounded-lg bg-surface p-6 shadow-sm">
								<h3 class="mb-3 text-lg font-semibold text-text-primary">
									{faq.question}
								</h3>
								<p class="text-text-secondary">
									{faq.answer}
								</p>
							</div>
						))}
					</div>
				</article>

				<!-- CTA Section -->
				<article id="cta-section" class="mb-12">
					<div class="rounded-lg bg-primary/10 p-8 text-center shadow-sm transition-shadow hover:shadow-md">
						<h2 class="mb-4 text-3xl font-semibold text-text-primary">
							{ctaTitle}
						</h2>
						<p class="mb-8 text-lg leading-relaxed text-text-secondary">
							{ctaDescription}
						</p>
						<a
							href={`/${locale}/registro/propietario/`}
							class="inline-block rounded-lg bg-primary px-8 py-3 font-semibold text-white transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
						>
							{ctaButton}
						</a>
					</div>
				</article>
			</div>
		</Section>
	</Container>
</BaseLayout>
