---
/**
 * @file eventos/en/[slug]/index.astro
 * @description Events at a specific venue/location.
 * @route /{lang}/eventos/en/{slug}/
 * @rendering SSR + ISR 24h
 */
import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import EventCard from '@/components/shared/cards/EventCard.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import Pagination from '@/components/shared/feedback/Pagination.astro';
import { eventsApi, eventLocationsApi } from '@/lib/api/endpoints';
import { toEventCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { slug } = Astro.params;
if (!slug) return new Response(null, { status: 404 });

// Resolve location slug to ID
const locResult = await eventLocationsApi.getBySlug({ slug });
if (!locResult.ok) return new Response(null, { status: 404 });
const locData = locResult.data as Record<string, unknown>;
const locationId = String(locData.id || '');
const locationName = String(locData.name || slug);

const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const result = await eventsApi.getByLocation({ locationId, page, pageSize: 9 });
const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.total : 0;
const totalPages = result.ok ? Math.ceil(total / 9) : 0;
const cards = items.map((item) => toEventCardProps({ item: item as unknown as Record<string, unknown> }));
const baseUrl = buildUrl({ locale, path: `eventos/en/${slug}` });
---

<ListingLayout locale={locale} title={`${locationName} - ${t('events.title', 'Eventos')}`} showFilters={false}>
	<Breadcrumbs slot="breadcrumbs" locale={locale} items={[{ label: t('events.title', 'Eventos'), path: 'eventos' }, { label: locationName }]} />
	<ListingPageHeader slot="page-header" locale={locale} tagline={t('events.byLocation.tagline', 'Lugar')} title={locationName} totalCount={total} />
	{hasError && !result.ok && <ErrorBanner locale={locale} error={result.error} entityName="eventos" />}
	{!hasError && cards.length === 0 && <EmptyState locale={locale} variant="no-results" actionUrl={buildUrl({ locale, path: 'eventos' })} />}
	{!hasError && cards.length > 0 && (
		<div class="grid">{cards.map((card, i) => (<div data-reveal="up" style={`transition-delay: ${Math.min(i, 6) * 100}ms`}><EventCard data={card} locale={locale} /></div>))}</div>
	)}
	{totalPages > 1 && <Pagination slot="pagination" currentPage={page} totalPages={totalPages} baseUrl={baseUrl.slice(0, -1)} locale={locale} />}
</ListingLayout>

<style>
	.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-card-gap); }
	@media (max-width: 1024px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>
