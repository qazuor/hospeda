---
export const prerender = true;

/**
 * Event detail page - displays comprehensive information about a specific event.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 *
 * Rendering: SSG with fallback fetch on-demand
 * Route: /[lang]/eventos/[slug]
 */

import type { EventPublic } from '@repo/schemas';
import { CalendarIcon, ClockIcon, ImageIcon, LocationIcon, TagIcon, UserIcon } from '@repo/icons';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import EventJsonLd from '../../../components/seo/EventJsonLd.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import { ShareButtons } from '../../../components/shared/ShareButtons.client';
import { fetchAllPages } from '../../../lib/api/client';
import { eventsApi as eventsApiEndpoints } from '../../../lib/api/endpoints';
import { extractFeaturedImageUrl } from '../../../lib/media';
import { toEventCardProps } from '../../../lib/api/transforms';
import {
    getLocaleFromParams,
    HOME_BREADCRUMB,
    SUPPORTED_LOCALES
} from '../../../lib/page-helpers';
import { createT } from '../../../lib/i18n';
import { buildUrl } from '../../../lib/urls';
import { formatDate as i18nFormatDate, toBcp47Locale } from '@repo/i18n';

/**
 * Generate static paths for all events across all locales.
 * Pre-renders event detail pages at build time for SSG.
 */
export async function getStaticPaths() {
    const events = await fetchAllPages({
        fetcher: (p) => eventsApiEndpoints.list(p),
    });

    return SUPPORTED_LOCALES.flatMap((lang) =>
        events
            .filter((e) => Boolean(e.slug))
            .map((e) => ({
                params: { lang, slug: e.slug },
                props: { event: e },
            }))
    );
}

const { slug } = Astro.params;
const locale = getLocaleFromParams(Astro.params);

if (!locale) {
    return Astro.redirect('/es/');
}

const t = createT(locale);

/**
 * Fetch event data from API.
 * Uses prop from getStaticPaths if available, otherwise fetches on-demand.
 */
let event = Astro.props.event as EventPublic | undefined;

if (!event) {
    const result = await eventsApiEndpoints.getBySlug({ slug: slug ?? '' });
    if (!result.ok) {
        return Astro.redirect(buildUrl({ locale, path: 'eventos' }));
    }
    event = result.data;
}

/**
 * Extract featured image URL from the nested media structure.
 */
const eventImageUrl = extractFeaturedImageUrl(event as Record<string, unknown>, '');

/**
 * Determine if the event has already ended.
 */
const endDateRaw = (event as Record<string, unknown>).endDate as string | undefined;
const startDateRaw = (event as Record<string, unknown>).startDate as string | undefined;
const isPastEvent = endDateRaw ? new Date(endDateRaw) < new Date() : false;

const eventName = String((event as Record<string, unknown>).name ?? '');
const eventCategory = String((event as Record<string, unknown>).category ?? '');
const eventDescription = String(
    (event as Record<string, unknown>).description ??
    (event as Record<string, unknown>).summary ??
    ''
);
const eventOrganizer = (event as Record<string, unknown>).organizer as string | undefined;
const eventPrice = (event as Record<string, unknown>).price as string | undefined;
const eventTicketUrl = (event as Record<string, unknown>).ticketUrl as string | undefined;
const eventLocation = (event as Record<string, unknown>).location as
    | { name?: string; address?: string; city?: string }
    | undefined;
const eventAgenda = (event as Record<string, unknown>).agenda as
    | Array<{ time?: string; title?: string; description?: string }>
    | undefined;

/**
 * Localized meta description truncated to 155 characters.
 */
const metaDescription =
    eventDescription.length > 155
        ? `${eventDescription.substring(0, 152)}...`
        : eventDescription;

/** BCP-47 locale string for Intl formatting (e.g. 'es-AR'). */
const bcp47Locale = toBcp47Locale(locale);

/**
 * Format a date string for display using the page locale.
 */
function formatDate(dateString: string): string {
    return i18nFormatDate({
        date: dateString,
        locale: bcp47Locale,
        options: { year: 'numeric', month: 'long', day: 'numeric' },
    });
}

/**
 * Format a date string to show only the time portion.
 */
function formatTime(dateString: string): string {
    return i18nFormatDate({
        date: dateString,
        locale: bcp47Locale,
        options: { hour: '2-digit', minute: '2-digit' },
    });
}

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items for this event detail page.
 */
const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale], href: buildUrl({ locale }) },
    { label: t('events.breadcrumb.events', 'Eventos'), href: buildUrl({ locale, path: 'eventos' }) },
    {
        label: eventName,
        href: buildUrl({ locale, path: `eventos/${slug}` }),
    },
];

/**
 * Fetch upcoming events for the related events section.
 * Filter out the current event and limit to 3 results.
 */
const relResult = await eventsApiEndpoints.getUpcoming({ pageSize: 4 });
const relatedEventCards =
    relResult.ok
        ? relResult.data.items
              .filter((e) => e.slug !== slug)
              .slice(0, 3)
              .map((evt) => toEventCardProps({ item: evt as Record<string, unknown> }))
        : [];

/** JSON-LD location object for EventJsonLd. */
const jsonLdLocation = {
    name: eventLocation?.name ?? eventLocation?.city ?? 'Concepcion del Uruguay',
    address: eventLocation?.address ?? eventLocation?.city ?? 'Entre Rios, Argentina',
};
---

<BaseLayout title={eventName} description={metaDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={eventName}
        description={metaDescription}
        canonical={canonicalUrl}
        locale={locale}
        type="article"
        image={eventImageUrl || undefined}
    />

    {startDateRaw && (
        <EventJsonLd
            slot="head"
            name={eventName}
            description={eventDescription || eventName}
            startDate={startDateRaw}
            endDate={endDateRaw}
            url={canonicalUrl}
            image={eventImageUrl || undefined}
            location={jsonLdLocation}
            organizer={eventOrganizer}
        />
    )}

    <div class="container mx-auto max-w-6xl px-4 py-6">
        <Breadcrumb items={breadcrumbItems} />

        <!-- Event header -->
        <article id="event-header" class="mb-8">
            <div class="mb-4 flex flex-wrap items-center gap-3">
                {eventCategory && (
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-sm font-semibold text-primary">
                        <TagIcon size={14} weight="bold" aria-hidden="true" />
                        {eventCategory}
                    </span>
                )}
                {isPastEvent && (
                    <span
                        id="past-event-badge"
                        class="inline-flex items-center rounded-full bg-muted px-3 py-1 text-sm font-semibold text-muted-foreground"
                    >
                        {t('events.detail.pastEvent', 'Evento pasado')}
                    </span>
                )}
            </div>

            <h1 class="mb-6 text-4xl font-bold text-foreground md:text-5xl">
                {eventName}
            </h1>

            <!-- Event metadata row -->
            <div id="event-meta" class="flex flex-wrap gap-6 text-muted-foreground">
                {startDateRaw && (
                    <div class="flex items-center gap-2">
                        <CalendarIcon size={20} className="shrink-0 text-primary" aria-hidden="true" />
                        <div>
                            <span class="font-semibold text-foreground">
                                {t('events.detail.date', 'Fecha')}:
                            </span>
                            <span class="ml-1">{formatDate(startDateRaw)}</span>
                        </div>
                    </div>
                )}

                {startDateRaw && (
                    <div class="flex items-center gap-2">
                        <ClockIcon size={20} className="shrink-0 text-primary" aria-hidden="true" />
                        <div>
                            <span class="font-semibold text-foreground">
                                {t('events.detail.time', 'Hora')}:
                            </span>
                            <span class="ml-1">{formatTime(startDateRaw)}</span>
                        </div>
                    </div>
                )}

                {eventLocation?.name && (
                    <div class="flex items-center gap-2">
                        <LocationIcon size={20} className="shrink-0 text-primary" aria-hidden="true" />
                        <div>
                            <span class="font-semibold text-foreground">
                                {t('events.detail.location', 'Lugar')}:
                            </span>
                            <span class="ml-1">{eventLocation.name}</span>
                        </div>
                    </div>
                )}
            </div>
        </article>

        <!-- Event hero image -->
        <div id="event-image" class="mb-12">
            {eventImageUrl ? (
                <div class="aspect-video w-full overflow-hidden rounded-xl bg-muted">
                    <img
                        src={eventImageUrl}
                        alt={eventName}
                        class="h-full w-full object-cover"
                        loading="eager"
                        transition:name={`entity-${slug}`}
                    />
                </div>
            ) : (
                <div class="aspect-video w-full overflow-hidden rounded-xl bg-muted">
                    <div class="flex h-full items-center justify-center text-muted-foreground">
                        <ImageIcon size={64} weight="regular" aria-hidden="true" />
                    </div>
                </div>
            )}
        </div>

        <!-- Past event notice banner -->
        {isPastEvent && (
            <div
                role="status"
                class="mb-8 rounded-lg border border-border bg-muted px-5 py-4 text-muted-foreground"
            >
                <p class="text-sm font-medium">
                    {t('events.detail.pastEventNotice', 'Este evento ya finalizo. La informacion mostrada corresponde a su ultima edicion.')}
                </p>
            </div>
        )}

        <div class="grid gap-8 lg:grid-cols-3">
            <!-- Main content column -->
            <div class="space-y-8 lg:col-span-2">
                <!-- Description -->
                <article id="event-description" class="rounded-xl bg-card p-6 shadow-sm">
                    <h2 class="mb-4 text-2xl font-semibold text-foreground">
                        {t('events.detail.description', 'Descripcion')}
                    </h2>
                    <p class="text-lg leading-relaxed text-muted-foreground">
                        {eventDescription}
                    </p>
                </article>

                <!-- Agenda -->
                {Array.isArray(eventAgenda) && eventAgenda.length > 0 && (
                    <article id="event-schedule" class="scroll-reveal rounded-xl bg-card p-6 shadow-sm">
                        <h2 class="mb-6 text-2xl font-semibold text-foreground">
                            {t('events.detail.agenda', 'Agenda')}
                        </h2>
                        <ol class="space-y-4">
                            {eventAgenda.map((item, index) => (
                                <li class="flex gap-4">
                                    <div
                                        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 font-semibold text-primary"
                                        aria-hidden="true"
                                    >
                                        {index + 1}
                                    </div>
                                    <div class="flex-1">
                                        <div class="mb-1 flex flex-wrap items-baseline gap-2">
                                            {item.time && (
                                                <span class="text-sm font-semibold text-primary">
                                                    {item.time}
                                                </span>
                                            )}
                                            {item.title && (
                                                <h3 class="font-semibold text-foreground">
                                                    {item.title}
                                                </h3>
                                            )}
                                        </div>
                                        {item.description && (
                                            <p class="text-muted-foreground">{item.description}</p>
                                        )}
                                    </div>
                                </li>
                            ))}
                        </ol>
                    </article>
                )}

                <!-- Share buttons -->
                <article id="share-buttons" class="rounded-xl bg-card p-6 shadow-sm">
                    <h3 class="mb-4 text-lg font-semibold text-foreground">
                        {t('events.detail.shareEvent', 'Compartir evento')}
                    </h3>
                    <ShareButtons
                        client:visible
                        url={canonicalUrl}
                        title={eventName}
                        text={eventDescription.substring(0, 100)}
                        locale={locale}
                    />
                </article>
            </div>

            <!-- Sidebar column -->
            <div class="space-y-6">
                <!-- Pricing / tickets -->
                {(eventPrice || eventTicketUrl) && (
                    <article id="event-pricing" class="scroll-reveal-right rounded-xl bg-card p-6 shadow-sm">
                        <h2 class="mb-4 text-xl font-semibold text-foreground">
                            {t('events.detail.pricing', 'Entradas')}
                        </h2>
                        {eventPrice && (
                            <p class="mb-4 text-2xl font-bold text-primary">{eventPrice}</p>
                        )}
                        {!isPastEvent && eventTicketUrl && (
                            <a
                                href={eventTicketUrl}
                                class="inline-flex w-full items-center justify-center rounded-lg bg-primary px-6 py-3 font-semibold text-primary-foreground transition-colors hover:bg-primary/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                {t('events.detail.getTickets', 'Conseguir entradas')}
                            </a>
                        )}
                    </article>
                )}

                <!-- Organizer info -->
                {eventOrganizer && (
                    <article id="event-organizer" class="rounded-xl bg-card p-6 shadow-sm">
                        <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-muted-foreground">
                            {t('events.detail.organizer', 'Organizador')}
                        </h3>
                        <div class="flex items-center gap-2">
                            <UserIcon size={18} className="shrink-0 text-muted-foreground" aria-hidden="true" />
                            <p class="text-lg font-semibold text-foreground">{eventOrganizer}</p>
                        </div>
                    </article>
                )}

                <!-- Location details -->
                {eventLocation?.address && (
                    <article id="event-location-detail" class="rounded-xl bg-card p-6 shadow-sm">
                        <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-muted-foreground">
                            {t('events.detail.location', 'Lugar')}
                        </h3>
                        <div class="flex items-start gap-2">
                            <LocationIcon size={18} className="mt-0.5 shrink-0 text-muted-foreground" aria-hidden="true" />
                            <div>
                                {eventLocation.name && (
                                    <p class="font-semibold text-foreground">{eventLocation.name}</p>
                                )}
                                <p class="text-muted-foreground">{eventLocation.address}</p>
                                {eventLocation.city && (
                                    <p class="text-sm text-muted-foreground">{eventLocation.city}</p>
                                )}
                            </div>
                        </div>
                    </article>
                )}
            </div>
        </div>

        <!-- Related upcoming events -->
        {relatedEventCards.length > 0 && (
            <section id="related-events" class="scroll-reveal mt-16" aria-label={t('events.detail.relatedEvents', 'Proximos eventos')}>
                <h2 class="mb-8 text-center text-3xl font-semibold text-foreground">
                    {t('events.detail.relatedEvents', 'Proximos eventos')}
                </h2>
                <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                    {relatedEventCards.map((relatedEvent) => (
                        <a
                            href={buildUrl({ locale, path: `eventos/${relatedEvent.slug}` })}
                            class="group block overflow-hidden rounded-xl bg-card shadow-sm ring-1 ring-border transition-shadow hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                        >
                            <div class="aspect-video overflow-hidden bg-muted">
                                {relatedEvent.featuredImage ? (
                                    <img
                                        src={relatedEvent.featuredImage}
                                        alt={relatedEvent.name}
                                        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                                        loading="lazy"
                                    />
                                ) : (
                                    <div class="flex h-full items-center justify-center text-muted-foreground">
                                        <ImageIcon size={40} weight="regular" aria-hidden="true" />
                                    </div>
                                )}
                            </div>
                            <div class="p-4">
                                {relatedEvent.category && (
                                    <span class="mb-2 inline-block text-xs font-semibold uppercase tracking-wide text-primary">
                                        {relatedEvent.category}
                                    </span>
                                )}
                                <h3 class="mb-1 font-semibold text-foreground line-clamp-2 group-hover:text-primary">
                                    {relatedEvent.name}
                                </h3>
                                {relatedEvent.date.start && (
                                    <p class="flex items-center gap-1.5 text-sm text-muted-foreground">
                                        <CalendarIcon size={14} aria-hidden="true" />
                                        {formatDate(relatedEvent.date.start)}
                                    </p>
                                )}
                            </div>
                        </a>
                    ))}
                </div>
            </section>
        )}
    </div>
</BaseLayout>
