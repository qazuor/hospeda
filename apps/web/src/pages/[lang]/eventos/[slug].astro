---
/**
 * @file eventos/[slug].astro
 * @description Event detail page with Event JSON-LD and EventStatus mapping.
 * @route /{lang}/eventos/{slug}/
 * @rendering SSR + ISR 24h
 */

import DetailLayout from '@/layouts/DetailLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import BreadcrumbJsonLd from '@/components/seo/BreadcrumbJsonLd.astro';
import { ShareButtons } from '@/components/ShareButtons.client';
import { eventsApi, userBookmarksPublicApi } from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { formatPrice } from '@/lib/format-utils';
import { Image } from 'astro:assets';
import { sanitizeHtml } from '@/lib/sanitize-html';
import EventDetailHeader from '@/components/event/EventDetailHeader.astro';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { slug } = Astro.params;

if (!slug) return new Response(null, { status: 404 });

const result = await eventsApi.getBySlug({ slug });
if (!result.ok) return new Response(null, { status: 404 });

const event = result.data as Record<string, unknown>;

const eventId = String(event.id || '');
const name = String(event.name || event.title || '');
const description = String(event.summary || event.description || '');
const category = String(event.category || '');
const startDate = String(event.startDate || '');
const endDate = event.endDate ? String(event.endDate) : undefined;
const featuredImage = String(event.featuredImage || '/assets/images/placeholder-event.svg');
const locationObj = event.location as Record<string, unknown> | undefined;
const locationName = String(locationObj?.name || locationObj?.venueName || '');
const locationCity = String(locationObj?.city || '');
const isCancelled = Boolean(event.isCancelled);
const isPast = startDate ? new Date(startDate) < new Date() : false;
const price = event.price as { amount?: number; currency?: string } | undefined;
const organizerObj = event.organizer as Record<string, unknown> | undefined;

// EventStatus mapping per schema.org Event docs (REQ-096-37 / T-067):
//  - cancelled → EventCancelled
//  - rescheduled → EventRescheduled
//  - postponed → EventPostponed
//  - moved online → EventMovedOnline
//  - everything else (active or unknown) → EventScheduled
const isRescheduled = Boolean(event.isRescheduled);
const eventStatus = isCancelled
	? 'EventCancelled'
	: isRescheduled
		? 'EventRescheduled'
		: 'EventScheduled';

// --- Auth ---
const userId = Astro.locals.user?.id ?? null;
const isAuthenticated = userId !== null;

// --- Bookmark count + favorite status (graceful degradation) ---
let bookmarkCount: number | undefined;
let initialIsFavorited: boolean | undefined;
let initialBookmarkId: string | null = null;

if (eventId) {
	try {
		const countResult = await userBookmarksPublicApi.count({
			entityType: 'EVENT',
			entityId: eventId
		});
		if (countResult.ok) {
			bookmarkCount = countResult.data.count;
		}
	} catch {
		// Graceful degradation: counter not shown if fetch fails
	}

	if (isAuthenticated) {
		try {
			const statusResult = await userBookmarksApi.checkStatus({
				entityId: eventId,
				entityType: 'EVENT'
			});
			if (statusResult.ok) {
				initialIsFavorited = statusResult.data.isFavorited;
				initialBookmarkId = statusResult.data.bookmarkId;
			}
		} catch {
			// Graceful degradation: FavoriteButton hydrates itself on mount
		}
	}
}

const canonical = `${Astro.site ?? Astro.url.origin}${Astro.url.pathname}`;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name,
	description,
	startDate,
	...(endDate ? { endDate } : {}),
	eventStatus: `https://schema.org/${eventStatus}`,
	image: featuredImage,
	url: `${Astro.site ?? Astro.url.origin}${Astro.url.pathname}`,
	location: {
		'@type': 'Place',
		name: locationName || locationCity,
		address: { '@type': 'PostalAddress', addressLocality: locationCity },
	},
	...(organizerObj ? { organizer: { '@type': 'Organization', name: String(organizerObj.name || '') } } : {}),
	...(price?.amount ? { offers: { '@type': 'Offer', price: price.amount, priceCurrency: price.currency ?? 'ARS' } } : {}),
};

// --- Breadcrumb JSON-LD (REQ-096-37 / T-068) ---
const siteOrigin = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const breadcrumbItems = [
	{ name: t('nav.home', 'Inicio'), url: `${siteOrigin}/${locale}/` },
	{ name: t('events.title', 'Eventos'), url: `${siteOrigin}/${locale}/eventos/` },
	{ name, url: `${siteOrigin}${Astro.url.pathname}` },
];

// Sanitize event description HTML before injecting via `set:html` to prevent XSS.
// `siteOrigin` is passed so internal links don't get target="_blank".
const safeDescriptionHtml = sanitizeHtml({
	html: String(event.contentHtml || description),
	siteOrigin,
});
---

<DetailLayout
	locale={locale}
	title={name}
	description={description}
	showBreadcrumbs={true}
	showSidebar={true}
>
	<JsonLd slot="head-extra" data={jsonLd} />
	<BreadcrumbJsonLd slot="head-extra" items={breadcrumbItems} />

	<Breadcrumbs
		slot="breadcrumbs"
		locale={locale}
		items={[
			{ label: t('events.title', 'Eventos'), path: 'eventos' },
			{ label: name },
		]}
	/>

	<Fragment slot="page-header">
		<EventDetailHeader
			eventId={eventId}
			name={name}
			category={category}
			startDate={startDate}
			endDate={endDate}
			locationCity={locationCity}
			locationName={locationName}
			isPast={isPast}
			isCancelled={isCancelled}
			bookmarkCount={bookmarkCount}
			locale={locale}
			isAuthenticated={isAuthenticated}
			initialIsFavorited={initialIsFavorited}
			initialBookmarkId={initialBookmarkId}
		/>
	</Fragment>

	<div class="event-detail">
		<!-- Hero -->
		<div class="event-detail__hero">
			{featuredImage && !featuredImage.includes('placeholder') ? (
				<Image
					src={featuredImage}
					alt={name}
					width={1200}
					height={675}
					format="webp"
					loading="eager"
					class="event-detail__hero-img"
				/>
			) : (
				<img
					src={featuredImage}
					alt={name}
					loading="eager"
					class="event-detail__hero-img"
					width="1200"
					height="675"
				/>
			)}
		</div>

		<!-- Description -->
		<div class="event-detail__description" set:html={safeDescriptionHtml} />

		<!-- Share buttons -->
		<div class="event-detail__share">
			<ShareButtons url={canonical} title={name} locale={locale} client:visible />
		</div>
	</div>

	<!-- Sidebar -->
	<div slot="sidebar" class="event-sidebar">
		<div class="event-sidebar__card">
			{price?.amount ? (
				<div class="event-sidebar__price">
					<span class="event-sidebar__price-amount">{formatPrice({ amount: price.amount, currency: price.currency ?? 'ARS', locale })}</span>
				</div>
			) : (
				<p class="event-sidebar__free">{t('events.detail.free', 'Evento gratuito')}</p>
			)}
		</div>

		{organizerObj && (
			<div class="event-sidebar__card">
				<h3 class="event-sidebar__card-title">{t('events.detail.organizer', 'Organizador')}</h3>
				<p class="event-sidebar__organizer-name">{String(organizerObj.name || '')}</p>
			</div>
		)}
	</div>
</DetailLayout>

<style>
	.event-detail__hero { position: relative; margin-bottom: var(--space-6); border-radius: var(--radius-card); overflow: hidden; }
	.event-detail__hero-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }

	.event-detail__description { font-family: var(--font-sans); line-height: 1.7; color: var(--core-foreground); margin-bottom: var(--space-8); }
	.event-detail__description :global(p) { margin-bottom: var(--space-4); }

	.event-sidebar__card { background-color: var(--core-card); border-radius: var(--radius-card); padding: var(--space-6); box-shadow: var(--shadow-card); margin-bottom: var(--space-4); }
	.event-sidebar__price-amount { font-family: var(--font-heading); font-weight: 700; font-size: var(--text-2xl); color: var(--brand-accent); }
	.event-sidebar__free { font-family: var(--font-heading); font-weight: 600; font-size: var(--text-lg); color: var(--core-foreground); margin: 0; }
	.event-sidebar__card-title { font-family: var(--font-heading); font-weight: 600; font-size: var(--text-lg); color: var(--core-foreground); margin: 0 0 var(--space-2); }
	.event-sidebar__organizer-name { font-family: var(--font-sans); color: var(--core-muted-foreground); margin: 0; }
	.event-detail__share { margin-top: var(--space-6); display: flex; justify-content: flex-start; }
</style>
