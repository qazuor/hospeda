---
/**
 * @file eventos/[slug].astro
 * @description Event detail page with Event JSON-LD and EventStatus mapping.
 * @route /{lang}/eventos/{slug}/
 * @rendering SSR + ISR 24h
 */

import DetailLayout from '@/layouts/DetailLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import EventJsonLd from '@/components/seo/EventJsonLd.astro';
import type { EventOffer } from '@/components/seo/EventJsonLd.astro';
import BreadcrumbJsonLd from '@/components/seo/BreadcrumbJsonLd.astro';
import { ShareButtons } from '@/components/ShareButtons.client';
import { ImageGallery } from '@/components/ImageGallery.client';
import EventDetailHeader from '@/components/event/EventDetailHeader.astro';
import EventDetailPricingCard from '@/components/event/EventDetailPricingCard.astro';
import CommentThread from '@/components/comments/CommentThread.astro';
import EventDetailLocationCard from '@/components/event/EventDetailLocationCard.astro';
import EventDetailOrganizerCard from '@/components/event/EventDetailOrganizerCard.astro';
import EventDetailTagsRow from '@/components/event/EventDetailTagsRow.astro';
import { eventsApi, userBookmarksPublicApi } from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { toEventDetailProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { Image } from 'astro:assets';
import { renderContent } from '@/lib/render-content';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { slug } = Astro.params;

if (!slug) return new Response(null, { status: 404 });

const result = await eventsApi.getBySlug({ slug });
if (!result.ok) return new Response(null, { status: 404 });

const event = toEventDetailProps({ item: result.data as Record<string, unknown> });

const {
	id: eventId,
	name,
	summary,
	contentHtml,
	description,
	category,
	startDate,
	endDate,
	featuredImage,
	gallery,
	location,
	pricing,
	organizer,
	tags,
	seo,
	isCancelled,
	isPast,
	eventStatus,
} = event;

// --- Auth ---
const userId = Astro.locals.user?.id ?? null;
const isAuthenticated = userId !== null;

// --- Bookmark count + favorite status (graceful degradation) ---
let bookmarkCount: number | undefined;
let initialIsFavorited: boolean | undefined;
let initialBookmarkId: string | null = null;

if (eventId) {
	try {
		const countResult = await userBookmarksPublicApi.count({
			entityType: 'EVENT',
			entityId: eventId
		});
		if (countResult.ok) {
			bookmarkCount = countResult.data.count;
		}
	} catch {
		// Graceful degradation: counter not shown if fetch fails
	}

	if (isAuthenticated) {
		try {
			const statusResult = await userBookmarksApi.checkStatus({
				entityId: eventId,
				entityType: 'EVENT'
			});
			if (statusResult.ok) {
				initialIsFavorited = statusResult.data.isFavorited;
				initialBookmarkId = statusResult.data.bookmarkId;
			}
		} catch {
			// Graceful degradation: FavoriteButton hydrates itself on mount
		}
	}
}

const siteOrigin = Astro.site?.href.replace(/\/$/, '') ?? Astro.url.origin;
const canonical = `${siteOrigin}${Astro.url.pathname}`;

// --- Description rendering (markdown / HTML / plain text → sanitized HTML) ---
const safeDescriptionHtml = renderContent({
	raw: contentHtml || description || summary,
	siteOrigin,
});

// --- JSON-LD (Event schema.org) ---
// Build offers block from pricing data.
const eventOffersBlock: EventOffer | undefined =
	!pricing.isFree && pricing.price != null
		? {
				type: 'Offer',
				priceCurrency: pricing.currency ?? 'ARS',
				price: pricing.price,
				...(pricing.priceFrom != null ? { lowPrice: pricing.priceFrom } : {}),
				...(pricing.priceTo != null ? { highPrice: pricing.priceTo } : {}),
		  }
		: pricing.priceFrom != null && pricing.priceTo != null
		  ? {
					type: 'AggregateOffer',
					priceCurrency: pricing.currency ?? 'ARS',
					lowPrice: pricing.priceFrom,
					highPrice: pricing.priceTo,
		    }
		  : undefined;

// --- Breadcrumb JSON-LD ---
const breadcrumbItems = [
	{ name: t('nav.home', 'Inicio'), url: `${siteOrigin}/${locale}/` },
	{ name: t('events.title', 'Eventos'), url: `${siteOrigin}/${locale}/eventos/` },
	{ name, url: canonical },
];

// --- Gallery display logic ---
// Show ImageGallery when there are gallery images beyond the featured one.
// When only featuredImage exists, show it as the hero image.
const hasGallery = gallery.length > 0;
const featuredIsPlaceholder = featuredImage.url.includes('placeholder');
---

<DetailLayout
	locale={locale}
	title={seo.title || name}
	description={seo.description || summary}
	ogImage={featuredIsPlaceholder ? undefined : featuredImage.url}
	ogType="Evento"
	ogSubtitle={location.city || location.name || undefined}
	showBreadcrumbs={true}
	showSidebar={true}
>
	<EventJsonLd
		slot="head-extra"
		name={name}
		description={seo.description || summary}
		startDate={startDate}
		endDate={endDate}
		url={canonical}
		image={!featuredIsPlaceholder ? featuredImage.url : undefined}
		location={{
			name: location.name || location.city || '',
			address: location.fullAddress || '',
			addressLocality: location.city || undefined,
		}}
		organizer={organizer?.name}
		eventStatus={`https://schema.org/${eventStatus}`}
		offers={eventOffersBlock}
	/>
	<BreadcrumbJsonLd slot="head-extra" items={breadcrumbItems} />

	<Breadcrumbs
		slot="breadcrumbs"
		locale={locale}
		items={[
			{ label: t('events.title', 'Eventos'), path: 'eventos' },
			{ label: name },
		]}
	/>

	<Fragment slot="page-header">
		<EventDetailHeader
			eventId={eventId}
			name={name}
			category={category}
			startDate={startDate}
			endDate={endDate}
			locationCity={location.city}
			locationName={location.name}
			isPast={isPast}
			isCancelled={isCancelled}
			bookmarkCount={bookmarkCount}
			locale={locale}
			isAuthenticated={isAuthenticated}
			initialIsFavorited={initialIsFavorited}
			initialBookmarkId={initialBookmarkId}
		/>
	</Fragment>

	<div class="event-detail">
		<!-- Gallery or hero image -->
		{hasGallery ? (
			<div class="event-detail__gallery">
				<ImageGallery
					client:visible
					variant="detail"
					images={gallery}
					locale={locale}
				/>
			</div>
		) : (
			<div class="event-detail__hero">
				{!featuredIsPlaceholder ? (
					<Image
						src={featuredImage.url}
						alt={featuredImage.caption || name}
						width={1200}
						height={675}
						format="webp"
						loading="eager"
						class="event-detail__hero-img"
					/>
				) : (
					<img
						src={featuredImage.url}
						alt={name}
						loading="eager"
						class="event-detail__hero-img"
						width="1200"
						height="675"
					/>
				)}
			</div>
		)}

		<!-- Description body -->
		{safeDescriptionHtml && (
			<div class="event-detail__description" set:html={safeDescriptionHtml} />
		)}

		<!-- Comment thread (SPEC-165 T-015: AC-30, reuses the post thread component) -->
		<CommentThread
			entityType="EVENT"
			entityId={eventId}
			locale={locale}
			isAuthenticated={isAuthenticated}
			currentUrl={Astro.url.href}
		/>

		<!-- Tags row (only when tags exist) -->
		{tags.length > 0 && (
			<EventDetailTagsRow tags={tags} locale={locale} />
		)}

		<!-- Share buttons -->
		<div class="event-detail__share">
			<ShareButtons url={canonical} title={name} locale={locale} client:visible />
		</div>
	</div>

	<!-- Sidebar -->
	<div slot="sidebar" class="event-sidebar">
		<!-- Pricing card (always present — shows free or price) -->
		<EventDetailPricingCard pricing={pricing} locale={locale} />

		<!-- Location map (only when GPS coordinates are available) -->
		{location.coordinates && (
			<EventDetailLocationCard
				coordinates={location.coordinates}
				venueName={location.name}
				fullAddress={location.fullAddress}
				locale={locale}
			/>
		)}

		<!-- Organizer card (only when organizer has a name) -->
		{organizer && (
			<EventDetailOrganizerCard
				organizer={organizer}
				locale={locale}
				siteOrigin={siteOrigin}
			/>
		)}
	</div>
</DetailLayout>

<style>
	/* ---- Main column ---- */
	.event-detail__gallery {
		margin-bottom: var(--space-6, 1.5rem);
	}

	.event-detail__hero {
		position: relative;
		margin-bottom: var(--space-6, 1.5rem);
		border-radius: var(--radius-card);
		overflow: hidden;
	}

	.event-detail__hero-img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.event-detail__description {
		font-family: var(--font-sans);
		line-height: 1.7;
		color: var(--core-foreground);
		margin-bottom: var(--space-8, 2rem);
	}

	.event-detail__description :global(p) {
		margin-bottom: var(--space-4, 1rem);
	}

	.event-detail__description :global(h2),
	.event-detail__description :global(h3),
	.event-detail__description :global(h4) {
		font-family: var(--font-heading);
		font-weight: 600;
		color: var(--core-foreground);
		margin: var(--space-6, 1.5rem) 0 var(--space-3, 0.75rem);
	}

	.event-detail__description :global(ul),
	.event-detail__description :global(ol) {
		padding-left: 1.5rem;
		margin-bottom: var(--space-4, 1rem);
	}

	.event-detail__share {
		margin-top: var(--space-6, 1.5rem);
		display: flex;
		justify-content: flex-start;
	}

	/* ---- Sidebar ---- */
	.event-sidebar {
		display: flex;
		flex-direction: column;
		gap: var(--space-4, 1rem);
	}
</style>
