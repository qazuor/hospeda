---
export const prerender = true;

/**
 * Event detail page - displays comprehensive information about a specific event.
 * Validates locale parameter and redirects invalid locales to Spanish (default).
 *
 * Rendering: SSG + ISR (6h revalidation)
 * Route: /[lang]/eventos/[slug]
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import EventJsonLd from '../../../components/seo/EventJsonLd.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Container from '../../../components/ui/Container.astro';
import Section from '../../../components/ui/Section.astro';
import EventCard from '../../../components/event/EventCard.astro';
import { getLocaleFromParams, HOME_BREADCRUMB, SUPPORTED_LOCALES } from '../../../lib/page-helpers';
import { eventsApi } from '../../../lib/api/endpoints';
import { fetchAllPages } from '../../../lib/api/client';
import { CalendarIcon, ClockIcon, LocationIcon, ImageIcon } from '@repo/icons';
import { ShareButtons } from '../../../components/ui/ShareButtons.client';
import { toEventCardProps } from '../../../lib/api/transforms';
import { extractFeaturedImageUrl } from '../../../lib/media';
import { t } from '../../../lib/i18n';

/**
 * Generate static paths for all events across all locales.
 * Pre-renders event detail pages at build time for SSG.
 */
export async function getStaticPaths() {
	const events = await fetchAllPages({
		fetcher: (p) => eventsApi.list(p),
	});

	return SUPPORTED_LOCALES.flatMap((lang) =>
		events
			.filter((e) => e.slug)
			.map((e) => ({
				params: { lang, slug: e.slug },
				props: { event: e },
			}))
	);
}

const { slug } = Astro.params;

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Fetch event data from API.
 * Uses prop from getStaticPaths if available, otherwise fetches on-demand.
 */
let event = Astro.props.event as Record<string, unknown> | undefined;
if (!event) {
	const result = await eventsApi.getBySlug({ slug: slug || '' });
	if (!result.ok) {
		return Astro.redirect(`/${locale}/eventos/`);
	}
	event = result.data;
}

/**
 * Extract featured image URL from nested media structure
 */
const eventImageUrl = extractFeaturedImageUrl(event, '');

/**
 * Calculate if event has ended based on actual end date
 */
const isPastEvent = event.endDate ? new Date(event.endDate) < new Date() : false;

/**
 * Localized page title
 */
const pageTitle = event.name;

/**
 * Localized meta description computed from event data
 */
const eventDescription = event.description || event.summary || '';
const metaDescription = eventDescription.substring(0, 155) + (eventDescription.length > 155 ? '...' : '');

/**
 * Localized events breadcrumb label
 */
const eventsLabel = t({ locale, namespace: 'event', key: 'breadcrumb.events' });

/**
 * Localized section labels
 */
const labelCategory = t({ locale, namespace: 'event', key: 'detail.category' });
const labelDate = t({ locale, namespace: 'event', key: 'detail.date' });
const labelTime = t({ locale, namespace: 'event', key: 'detail.time' });
const labelLocation = t({ locale, namespace: 'event', key: 'detail.location' });
const labelDescription = t({ locale, namespace: 'event', key: 'detail.description' });
const labelAgenda = t({ locale, namespace: 'event', key: 'detail.agenda' });
const labelPricing = t({ locale, namespace: 'event', key: 'detail.pricing' });
const labelOrganizer = t({ locale, namespace: 'event', key: 'detail.organizer' });
const labelGetTickets = t({ locale, namespace: 'event', key: 'detail.getTickets' });
const labelRelatedEvents = t({ locale, namespace: 'event', key: 'detail.relatedEvents' });
const labelShareEvent = t({ locale, namespace: 'event', key: 'detail.shareEvent' });
const labelPastEvent = t({ locale, namespace: 'event', key: 'detail.pastEvent' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
	{ label: HOME_BREADCRUMB[locale], href: `/${locale}/` },
	{ label: eventsLabel, href: `/${locale}/eventos/` },
	{ label: pageTitle, href: `/${locale}/eventos/${slug}/` },
];

/**
 * Fetch related/upcoming events for the related events section.
 * Filter out the current event from the list.
 */
const relResult = await eventsApi.getUpcoming({ pageSize: 4 });
const relatedEventsRaw = relResult.ok
	? relResult.data.items.filter((e) => e.slug !== slug).slice(0, 3)
	: [];

const relatedEventCards = relatedEventsRaw.map((evt) =>
	toEventCardProps({ item: evt as Record<string, unknown> })
);

/**
 * Format date for display
 */
const formatDate = (dateString: string): string => {
	const date = new Date(dateString);
	const options: Intl.DateTimeFormatOptions = {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	};
	return date.toLocaleDateString(locale === 'es' ? 'es-AR' : locale === 'pt' ? 'pt-BR' : 'en-US', options);
};

/**
 * Format time for display
 */
const formatTime = (dateString: string): string => {
	const date = new Date(dateString);
	return date.toLocaleTimeString(locale === 'es' ? 'es-AR' : locale === 'pt' ? 'pt-BR' : 'en-US', {
		hour: '2-digit',
		minute: '2-digit',
	});
};
---

<BaseLayout title={pageTitle} description={metaDescription} locale={locale}>
	<SEOHead
		slot="head"
		title={pageTitle}
		description={metaDescription}
		canonical={canonicalUrl}
		locale={locale}
		type="article"
		image={eventImageUrl || undefined}
	/>

	<EventJsonLd
		slot="head"
		name={event.name}
		description={event.description || event.summary}
		startDate={event.startDate}
		endDate={event.endDate}
		url={canonicalUrl}
		image={eventImageUrl || undefined}
		location={event.location}
		organizer={event.organizer}
	/>

	<Container>
		<Breadcrumb items={breadcrumbItems} />

		<Section>
			<div class="mx-auto max-w-6xl">
				<!-- Event Header -->
				<article id="event-header" class="mb-8">
					<div class="flex flex-wrap items-center gap-3 mb-4">
						<span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-sm font-semibold text-primary">
							{event.category}
						</span>
						{isPastEvent && (
							<span id="past-event-badge" class="inline-flex items-center rounded-full bg-gray-500/10 px-3 py-1 text-sm font-semibold text-gray-600">
								{labelPastEvent}
							</span>
						)}
					</div>

					<h1 class="mb-6 text-4xl font-bold text-text-primary md:text-5xl">
						{event.name}
					</h1>

					<!-- Event Meta Information -->
					<div id="event-meta" class="flex flex-wrap gap-6 text-text-secondary">
						<!-- Date -->
						<div class="flex items-center gap-2">
							<CalendarIcon size={20} className="text-primary" aria-hidden="true" />
							<div>
								<span class="font-semibold">{labelDate}:</span>
								<span class="ml-1">{formatDate(event.startDate)}</span>
							</div>
						</div>

						<!-- Time -->
						<div class="flex items-center gap-2">
							<ClockIcon size={20} className="text-primary" aria-hidden="true" />
							<div>
								<span class="font-semibold">{labelTime}:</span>
								<span class="ml-1">{formatTime(event.startDate)}</span>
							</div>
						</div>

						<!-- Location -->
						{event.location && (
							<div class="flex items-center gap-2">
								<LocationIcon size={20} className="text-primary" aria-hidden="true" />
								<div>
									<span class="font-semibold">{labelLocation}:</span>
									<span class="ml-1">{event.location.name}</span>
								</div>
							</div>
						)}
					</div>
				</article>

				<!-- Event Image Area -->
				<article id="event-image" class="mb-12">
					{eventImageUrl ? (
						<div class="aspect-video w-full overflow-hidden rounded-lg bg-gray-200">
							<img
								src={eventImageUrl}
								alt={event.name}
								class="h-full w-full object-cover"
								loading="eager"
								transition:name={`entity-${slug}`}
							/>
						</div>
					) : (
						<div class="aspect-video w-full overflow-hidden rounded-lg bg-gray-200">
							<div class="flex h-full items-center justify-center text-text-tertiary">
								<ImageIcon size={64} weight="regular" aria-hidden="true" />
							</div>
						</div>
					)}
				</article>

				<div class="grid gap-8 lg:grid-cols-3">
					<!-- Main Content Column -->
					<div class="lg:col-span-2 space-y-8">
						<!-- Description Section -->
						<article id="event-description" class="rounded-lg bg-bg p-6 shadow-sm">
							<h2 class="mb-4 text-2xl font-semibold text-text-primary">
								{labelDescription}
							</h2>
							<p class="text-lg leading-relaxed text-text-secondary">
								{event.description || event.summary}
							</p>
						</article>

						<!-- Agenda Section -->
						{event.agenda && Array.isArray(event.agenda) && event.agenda.length > 0 && (
							<article id="event-schedule" class="rounded-lg bg-bg p-6 shadow-sm">
								<h2 class="mb-6 text-2xl font-semibold text-text-primary">
									{labelAgenda}
								</h2>
								<ol class="space-y-4">
									{event.agenda.map((item: { time?: string; title?: string; description?: string }, index: number) => (
										<li class="flex gap-4">
											<div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 font-semibold text-primary">
												{index + 1}
											</div>
											<div class="flex-1">
												<div class="mb-1 flex items-baseline gap-2">
													<span class="text-sm font-semibold text-primary">{item.time}</span>
													<h3 class="font-semibold text-text-primary">{item.title}</h3>
												</div>
												<p class="text-text-secondary">{item.description}</p>
											</div>
										</li>
									))}
								</ol>
							</article>
						)}

						<!-- Share Buttons -->
						<article id="share-buttons" class="rounded-lg bg-bg p-6 shadow-sm">
							<h3 class="mb-4 text-lg font-semibold text-text-primary">
								{labelShareEvent}
							</h3>
							<ShareButtons
								client:visible
								url={canonicalUrl}
								title={pageTitle}
								text={eventDescription.substring(0, 100)}
							/>
						</article>
					</div>

					<!-- Sidebar Column -->
					<div class="space-y-6">
						<!-- Pricing Section -->
						{(event.price || event.ticketUrl) && (
							<article id="event-pricing" class="rounded-lg bg-bg p-6 shadow-sm">
								<h2 class="mb-4 text-xl font-semibold text-text-primary">
									{labelPricing}
								</h2>
								{event.price && (
									<p class="mb-4 text-2xl font-bold text-primary">
										{event.price}
									</p>
								)}
								{!isPastEvent && event.ticketUrl && (
									<a
										href={event.ticketUrl}
										class="inline-flex w-full items-center justify-center rounded-lg bg-primary px-6 py-3 font-semibold text-white transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
										target="_blank"
										rel="noopener noreferrer"
									>
										{labelGetTickets}
									</a>
								)}
							</article>
						)}

						<!-- Organizer Info -->
						{event.organizer && (
							<article id="event-organizer" class="rounded-lg bg-bg p-6 shadow-sm">
								<h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-text-tertiary">
									{labelOrganizer}
								</h3>
								<p class="text-lg font-semibold text-text-primary">
									{event.organizer}
								</p>
							</article>
						)}
					</div>
				</div>

				<!-- Related Events Section -->
				{relatedEventCards.length > 0 && (
					<article id="related-events" class="mt-12">
						<h2 class="mb-6 text-center text-3xl font-semibold text-text-primary">
							{labelRelatedEvents}
						</h2>
						<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="region" aria-label={labelRelatedEvents}>
							{relatedEventCards.map((event) => (
								<EventCard
									event={event}
									locale={locale}
								/>
							))}
						</div>
					</article>
				)}
			</div>
		</Section>
	</Container>
</BaseLayout>
