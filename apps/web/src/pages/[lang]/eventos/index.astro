---
/**
 * @file eventos/index.astro
 * @description Events listing page with temporal quick-filter chips, category
 * chips, FilterSidebar (search + category + free toggle + price range + sort),
 * EventCard grid, and pagination.
 *
 * URL params:
 * - page             — pagination (default: 1)
 * - q                — full-text search
 * - category         — event category enum value
 * - sortBy           — encoded sort key, see SORT_OPTION_MAP below
 *                      (upcoming | farthest | nameAsc | nameDesc | newest |
 *                       oldest | featured | mostSaved). Direction lives inside
 *                       the key, so no separate `sortOrder` param.
 * - when             — temporal quick-filter (today | week | month | next60 | past)
 * - isFree           — boolean toggle for free events only
 * - includeUnpriced  — when `false`, exclude events without pricing data
 *                      (default behavior is to INCLUDE them)
 * - minPrice         — minimum event price
 * - maxPrice         — maximum event price
 * - isFeatured       — boolean: only featured events
 * - destinationId    — filter by destination UUID
 * - startDateAfter   — ISO yyyy-mm-dd lower bound on event start
 * - startDateBefore  — ISO yyyy-mm-dd upper bound on event start
 *
 * @route /{lang}/eventos/
 * @rendering SSR + ISR 24h
 */

import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/navigation/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/layout/ListingPageHeader.astro';
import ContributionBanner from '@/components/contributions/ContributionBanner.astro';
import EventCardHorizontal from '@/components/shared/cards/EventCardHorizontal.astro';
import EventCardHorizontalSkeleton from '@/components/skeletons/EventCardHorizontalSkeleton.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import ErrorBanner from '@/components/shared/feedback/ErrorBanner.astro';
import Pagination from '@/components/shared/feedback/Pagination.astro';
import ItemListJsonLd from '@/components/seo/ItemListJsonLd.astro';
import TagChips from '@/components/TagChips.astro';
import EventDateFilterChips from '@/components/event/EventDateFilterChips.astro';
import type { EventDateFilter } from '@/components/event/EventDateFilterChips.astro';
import { FilterSidebar } from '@/components/shared/filters/FilterSidebar.client';
import {
    buildEventListingSummary,
    DEFAULT_EVENT_CATEGORIES
} from '@/lib/event-listing-summary';
import { destinationsApi, eventsApi } from '@/lib/api/endpoints';
import { userBookmarksApi } from '@/lib/api/endpoints-protected';
import { toEventCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { webLogger } from '@/lib/logger';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);

const url = Astro.url;
const page = Math.max(1, Number(url.searchParams.get('page')) || 1);
const pageSize = 9;
const q = url.searchParams.get('q') ?? undefined;
const category = url.searchParams.get('category') ?? undefined;
/**
 * Maps the URL's user-friendly sort key (e.g. `upcoming`, `newest`) to the
 * backend `(sortBy, sortOrder)` pair. Encoding direction in the key lets the
 * UI offer pre-baked options like "Más recientes" / "Más antiguos" without
 * exposing a separate direction toggle.
 */
const SORT_OPTION_MAP: Record<string, { sortBy: string; sortOrder: 'asc' | 'desc' }> = {
    upcoming:    { sortBy: 'startDate',  sortOrder: 'asc'  },
    farthest:    { sortBy: 'startDate',  sortOrder: 'desc' },
    nameAsc:     { sortBy: 'name',       sortOrder: 'asc'  },
    nameDesc:    { sortBy: 'name',       sortOrder: 'desc' },
    newest:      { sortBy: 'createdAt',  sortOrder: 'desc' },
    oldest:      { sortBy: 'createdAt',  sortOrder: 'asc'  },
    featured:    { sortBy: 'isFeatured', sortOrder: 'desc' },
    mostSaved:   { sortBy: 'mostSaved',  sortOrder: 'desc' },
};
/** Default sort key — used when the URL has no `sortBy`. */
const DEFAULT_SORT_KEY = 'upcoming';

const sortKey = url.searchParams.get('sortBy') ?? DEFAULT_SORT_KEY;
const sortResolved = SORT_OPTION_MAP[sortKey] ?? SORT_OPTION_MAP[DEFAULT_SORT_KEY];

/** Parse the temporal quick-filter from the `when` query param. */
const rawWhen = url.searchParams.get('when');
const VALID_WHEN_VALUES: ReadonlyArray<EventDateFilter> = ['today', 'week', 'month', 'next60', 'past'];
const when: EventDateFilter = VALID_WHEN_VALUES.includes(rawWhen as EventDateFilter)
    ? (rawWhen as EventDateFilter)
    : 'all';

/** Parse price and free-toggle params.
 * The FilterSidebar dual-range with id='price' emits `minPrice` and `maxPrice`
 * (convention: `min${capitalize(id)}` and `max${capitalize(id)}`).
 */
const isFreeParam = url.searchParams.get('isFree');
const isFree: boolean | undefined = isFreeParam === 'true' ? true : isFreeParam === 'false' ? false : undefined;
const priceMinParam = url.searchParams.get('minPrice');
const priceMaxParam = url.searchParams.get('maxPrice');
const priceMin: number | undefined = priceMinParam ? Number(priceMinParam) : undefined;
const priceMax: number | undefined = priceMaxParam ? Number(priceMaxParam) : undefined;
/**
 * `includeUnpriced` defaults to TRUE server-side. The UI's composite price
 * filter only emits `?includeUnpriced=false` when the user explicitly turns
 * the toggle OFF, otherwise the param is absent.
 */
const includeUnpricedParam = url.searchParams.get('includeUnpriced');
const includeUnpriced: boolean | undefined =
    includeUnpricedParam === 'false' ? false : undefined;

/** New filters added in the eventos sidebar refactor. */
const isFeaturedParam = url.searchParams.get('isFeatured');
const isFeatured: boolean | undefined =
    isFeaturedParam === 'true' ? true : undefined;
const destinationId = url.searchParams.get('destinationId') ?? undefined;
const startDateAfterFilter = url.searchParams.get('startDateAfter') ?? undefined;
const startDateBeforeFilter = url.searchParams.get('startDateBefore') ?? undefined;

/** Compute date range from the `when` temporal filter. */
const now = new Date();

/**
 * Returns a copy of `now` at 00:00:00.000 local time.
 */
function startOfToday(): Date {
    const d = new Date(now);
    d.setHours(0, 0, 0, 0);
    return d;
}

/**
 * Returns a copy of `now` at 23:59:59.999 local time.
 */
function endOfToday(): Date {
    const d = new Date(now);
    d.setHours(23, 59, 59, 999);
    return d;
}

/**
 * Returns a date N days ahead of `startOfToday()` at 23:59:59.999.
 */
function daysAhead(n: number): Date {
    const d = startOfToday();
    d.setDate(d.getDate() + n);
    d.setHours(23, 59, 59, 999);
    return d;
}

let startDateAfter: string | undefined;
let startDateBefore: string | undefined;

/**
 * Fetch destinations once for the sidebar's location filter. Filter to CITY
 * type only — listings show events by city, not by country/region/department.
 * Capped at 100 — sufficient for the current scope; revisit if the catalog
 * grows past that.
 */
const destinationsResult = await destinationsApi.list({
    destinationType: 'CITY',
    pageSize: 100
});
const destinations = destinationsResult.ok ? destinationsResult.data.items : [];

switch (when) {
    case 'today':
        startDateAfter = startOfToday().toISOString();
        startDateBefore = endOfToday().toISOString();
        break;
    case 'week':
        startDateAfter = startOfToday().toISOString();
        startDateBefore = daysAhead(7).toISOString();
        break;
    case 'month':
        startDateAfter = startOfToday().toISOString();
        startDateBefore = daysAhead(30).toISOString();
        break;
    case 'next60':
        startDateAfter = startOfToday().toISOString();
        startDateBefore = daysAhead(60).toISOString();
        break;
    case 'past':
        startDateBefore = startOfToday().toISOString();
        break;
}

/**
 * Sidebar date-range filter takes precedence over the temporal chips when
 * present. The date-range emits ISO `YYYY-MM-DD` so widen the bounds to
 * cover the full local day.
 */
if (startDateAfterFilter) startDateAfter = `${startDateAfterFilter}T00:00:00`;
if (startDateBeforeFilter) startDateBefore = `${startDateBeforeFilter}T23:59:59`;

const result = await eventsApi.list({
    page,
    pageSize,
    q,
    category,
    sortBy: sortResolved.sortBy,
    sortOrder: sortResolved.sortOrder,
    startDateAfter,
    startDateBefore,
    isFree: isFree ?? undefined,
    minPrice: priceMin,
    maxPrice: priceMax,
    includeUnpriced: includeUnpriced ?? undefined,
    isFeatured: isFeatured ?? undefined,
    destinationId,
});

const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
// PaginatedResponse exposes counters under `pagination`, not at the top level.
const total = result.ok ? result.data.pagination.total : 0;
const totalPages = result.ok ? result.data.pagination.totalPages : 0;
const cards = items.map((item) => toEventCardProps({ item: item as unknown as Record<string, unknown>, locale }));

/**
 * Build a human-readable summary like "Mostrando 3 de 4 eventos en Colón..."
 * to replace the generic "N resultados encontrados" line in the wave header.
 * Mirrors the accommodations pattern via the parallel `event-listing-summary`
 * module — see SPEC-XXX (events-summary) for the architecture.
 */
const summaryLocale: 'es' | 'en' = locale === 'pt' ? 'es' : locale;
const destinationCatalog = destinations.map((d) => ({
    key: d.id,
    label: { es: d.name, en: d.name } as const
}));
const filterSummary = buildEventListingSummary({
    locale: summaryLocale,
    filters: {
        text: q,
        category,
        destinationId,
        startDateAfter: startDateAfterFilter,
        startDateBefore: startDateBeforeFilter,
        when,
        isFree,
        price:
            priceMin !== undefined || priceMax !== undefined
                ? { min: priceMin ?? null, max: priceMax ?? null }
                : null,
        includeUnpriced: includeUnpricedParam === 'false' ? false : null,
        isFeatured
    },
    counts: { shown: cards.length, total },
    sort: { sortKey },
    catalogs: {
        destinations: destinationCatalog,
        categories: DEFAULT_EVENT_CATEGORIES
    }
});

/**
 * Build the `filterGroups` config for FilterSidebar.
 * Includes: search, category (checkbox), free toggle, price dual-range.
 * The `isFree` toggle uses the existing `type: 'toggle'` group.
 * The price range uses the existing `type: 'dual-range'` group.
 */
const filterGroups = [
    {
        id: 'q',
        label: t('events.filters.search', 'Buscar'),
        type: 'search' as const,
    },
    {
        id: 'isFeatured',
        label: t('events.filters.featured', 'Solo destacados'),
        type: 'toggle' as const,
    },
    {
        id: 'category',
        label: t('events.filters.category', 'Categoría'),
        type: 'checkbox' as const,
        options: [
            { value: 'MUSIC',      label: t('events.categories.music',      'Música') },
            { value: 'CULTURE',    label: t('events.categories.culture',    'Cultura') },
            { value: 'SPORTS',     label: t('events.categories.sports',     'Deportes') },
            { value: 'GASTRONOMY', label: t('events.categories.gastronomy', 'Gastronomía') },
            { value: 'FESTIVAL',   label: t('events.categories.festival',   'Festival') },
            { value: 'NATURE',     label: t('events.categories.nature',     'Naturaleza') },
            { value: 'THEATER',    label: t('events.categories.theater',    'Teatro') },
            { value: 'WORKSHOP',   label: t('events.categories.workshop',   'Taller') },
            { value: 'OTHER',      label: t('events.categories.other',      'Otros') },
        ],
    },
    {
        id: 'date',
        label: t('events.filters.date', 'Fecha'),
        type: 'date-range' as const,
        checkInPlaceholder: t('events.filters.dateFrom', 'Desde'),
        checkOutPlaceholder: t('events.filters.dateTo', 'Hasta'),
        fromParam: 'startDateAfter',
        toParam: 'startDateBefore',
        mode: 'bounds' as const,
        allowPastDates: true,
    },
    {
        id: 'destinationId',
        label: t('events.filters.location', 'Lugar'),
        type: 'select-search' as const,
        options: destinations.map((d) => ({ value: d.id, label: d.name, featured: Boolean(d.isFeatured) })),
        maxVisible: 8,
        maxSelections: 1,
    },
    {
        id: 'price',
        label: t('events.filters.price', 'Precio'),
        type: 'price-composite' as const,
        min: 0,
        max: 10000,
        step: 100,
        format: 'currency' as const,
        includeUnpricedLabel: t(
            'events.filters.includeUnpricedToggle',
            'Incluir eventos sin información de precio'
        ),
        isFreeLabel: t('events.filters.onlyFree', 'Solo eventos gratuitos'),
        rangeLabel: t('events.filters.priceRange', 'Rango de precio'),
    },
] as const;

/**
 * `mostSaved` is intentionally NOT exposed in the UI options here: the
 * synthetic correlated-subquery sort does not compose with Drizzle's
 * relational query API used by the public list endpoint, so it silently
 * falls back to default ordering (see SPEC-098 T-052a note in the
 * EventModel). The key remains in SORT_OPTION_MAP above so legacy URLs
 * still resolve cleanly when fixed.
 */
const sortOptions = [
    { value: 'upcoming', label: t('events.sort.upcoming', 'Próximos primero') },
    { value: 'farthest', label: t('events.sort.farthest', 'Última fecha primero') },
    { value: 'newest',   label: t('events.sort.newest',   'Recién agregados') },
    { value: 'oldest',   label: t('events.sort.oldest',   'Más antiguos') },
    { value: 'featured', label: t('events.sort.featured', 'Destacados primero') },
    { value: 'nameAsc',  label: t('events.sort.nameAsc',  'Nombre (A-Z)') },
    { value: 'nameDesc', label: t('events.sort.nameDesc', 'Nombre (Z-A)') },
] as const;

const baseUrl = buildUrl({ locale, path: 'eventos' });

// Self-canonical for paginated pages (SPEC-157 follow-up). Pages 2+ are served
// at `/{locale}/eventos/page/{n}/` via an Astro.rewrite to this listing with
// `?page=n`; the rewrite drops the `/page/n/` segment from Astro.url.pathname,
// so we rebuild the crawlable URL from the page number to keep each paginated
// page self-canonical and indexable (instead of canonicalizing to page 1).
const canonicalPath = page > 1 ? `${baseUrl}page/${page}/` : baseUrl;

// Auth state forwarded to FavoriteButton via EventCard so authenticated users
// see their saved state on listing cards (instead of a guest-default heart).
const isAuthenticated = Astro.locals.user ? true : false;

// --- Bulk favorite pre-check (eliminates N+1 per card on mount) -----------
// The public events API does not return isFavorited. Without this block each
// EventCardHorizontal would fire its own /check request on mount. We mirror
// the accommodation pattern: one /check-bulk SSR call, result injected into
// cards so FavoriteButton receives initialIsFavorited and skips hydration.
type FavoriteCheckEntry = { readonly isBookmarked: boolean; readonly bookmarkId: string | null };
let eventFavoriteChecks: Readonly<Record<string, FavoriteCheckEntry>> = {};
if (isAuthenticated && cards.length > 0) {
    try {
        const bulkResult = await userBookmarksApi.checkBulk({
            entityType: 'EVENT',
            entityIds: cards.map((card) => card.id)
        });
        if (bulkResult.ok) {
            eventFavoriteChecks = bulkResult.data.checks;
        } else {
            webLogger.warn('Bulk bookmark check failed on eventos listing; falling back to per-card hydration', {
                error: bulkResult.error
            });
        }
    } catch (error) {
        webLogger.warn('Bulk bookmark check threw on eventos listing; falling back to per-card hydration', {
            error: error instanceof Error ? error.message : String(error)
        });
    }
}

const resolvedCards = cards.map((card) => {
    const entry = eventFavoriteChecks[card.id];
    if (!entry) return card;
    return { ...card, isFavorited: entry.isBookmarked, favoriteBookmarkId: entry.bookmarkId };
});

// Category quick-filter chips are built after `paginationParams` (below) so
// they can filter the listing in place via `?category=ENUM` (preserving the
// active filters) instead of navigating to a separate /categoria/ page.

/**
 * Build the `initialParams` record for FilterSidebar so server-rendered state
 * matches the URL on first paint (avoids hydration flash).
 * Keys match the URL param names emitted by FilterSidebar's reducer.
 * `price` dual-range maps to `priceMin` / `priceMax` via the `id: 'price'` group.
 */
const sidebarInitialParams: Record<string, string> = {};
if (q)              sidebarInitialParams['q']        = q;
if (category)       sidebarInitialParams['category'] = category;
if (isFeaturedParam === 'true') sidebarInitialParams['isFeatured'] = 'true';
if (destinationId)  sidebarInitialParams['destinationId'] = destinationId;
if (startDateAfterFilter)  sidebarInitialParams['startDateAfter']  = startDateAfterFilter;
if (startDateBeforeFilter) sidebarInitialParams['startDateBefore'] = startDateBeforeFilter;
// Composite price filter (id='price') reads `isFree`, `includeUnpriced`,
// `minPrice`, `maxPrice` from the URL. `includeUnpriced` only appears when
// the user explicitly turned it OFF; otherwise the server defaults to TRUE.
if (isFreeParam)    sidebarInitialParams['isFree']   = isFreeParam;
if (priceMinParam)  sidebarInitialParams['minPrice'] = priceMinParam;
if (priceMaxParam)  sidebarInitialParams['maxPrice'] = priceMaxParam;
if (includeUnpricedParam === 'false') sidebarInitialParams['includeUnpriced'] = 'false';
// Hydrate the SortPopover with the active sort key so the user sees their
// previous selection on reload. `sortOrder` is no longer in the URL — the
// direction is encoded inside the sort key (e.g. `nameDesc`, `newest`).
sidebarInitialParams['sortBy'] = sortKey;

/**
 * Build URLSearchParams to pass to Pagination so it preserves all active
 * filters (including `when`, `isFree`, `priceMin`, `priceMax`, `q`, etc.)
 * across page navigations.
 */
const paginationParams = new URLSearchParams(url.searchParams);
paginationParams.delete('page');

/**
 * Category quick-filter chips. Like the temporal chips, these filter the
 * listing in place via `?category=ENUM` (preserving every active filter and
 * resetting to page 1) instead of navigating to a separate /categoria/ page.
 * The chip matching the active category is highlighted; clicking it clears the
 * filter (toggle). Values are the EventCategoryEnum members the API expects.
 */
const CATEGORY_CHIP_DEFS = [
    { value: 'MUSIC', label: t('events.categories.music', 'Música') },
    { value: 'CULTURE', label: t('events.categories.culture', 'Cultura') },
    { value: 'GASTRONOMY', label: t('events.categories.gastronomy', 'Gastronomía') },
    { value: 'FESTIVAL', label: t('events.categories.festival', 'Festival') },
    { value: 'NATURE', label: t('events.categories.nature', 'Naturaleza') },
    { value: 'THEATER', label: t('events.categories.theater', 'Teatro') },
    { value: 'SPORTS', label: t('events.categories.sports', 'Deportes') },
    { value: 'WORKSHOP', label: t('events.categories.workshop', 'Taller') }
] as const;

const categoryChips = CATEGORY_CHIP_DEFS.map(({ value, label }) => {
    const isActive = category === value;
    const params = new URLSearchParams(paginationParams);
    if (isActive) {
        params.delete('category');
    } else {
        params.set('category', value);
    }
    const qs = params.toString();
    return { label, href: qs ? `${baseUrl}?${qs}` : baseUrl, active: isActive };
});

// ItemList JSON-LD entries — the visible page of event cards, routed through
// the reusable ItemListJsonLd component (SPEC-157 D-1 canonical JSON-LD path).
const itemListEntries = cards.map((card) => ({
	url: new URL(buildUrl({ locale, path: `eventos/${card.slug}` }), Astro.site ?? Astro.url.origin).href,
	name: card.name,
}));
---

<ListingLayout
	locale={locale}
	title={t('events.title', 'Eventos')}
	description={t('events.description', 'Descubrí eventos culturales, deportivos y gastronómicos del Litoral.')}
	canonicalPath={canonicalPath}
	showFilters={true}
	filterPosition="left"
>
	{/* RSS feed-discovery hints (SPEC-157 REQ-6) */}
	<link
		slot="head-extra"
		rel="alternate"
		type="application/rss+xml"
		title={t('events.rss.title', 'Eventos RSS')}
		href={buildUrl({ locale, path: 'eventos/rss.xml' })}
	/>

	<ItemListJsonLd
		slot="head-extra"
		name={t('events.title', 'Eventos')}
		items={itemListEntries}
		numberOfItems={total}
		startPosition={(page - 1) * pageSize + 1}
	/>

	<Breadcrumbs
		slot="breadcrumbs"
		locale={locale}
		items={[{ label: t('events.title', 'Eventos') }]}
	/>

	<ListingPageHeader
		slot="page-header"
		locale={locale}
		tagline={t('events.tagline', 'No te pierdas nada')}
		title={t('events.title', 'Eventos')}
		totalCount={total}
		filterSummary={filterSummary}
	/>

	<FilterSidebar
		slot="filters"
		client:load
		locale={locale}
		filters={filterGroups}
		sortOptions={sortOptions}
		defaultSort={DEFAULT_SORT_KEY}
		initialParams={sidebarInitialParams}
	/>

	<!-- Temporal quick-filter chips (above category chips) -->
	<EventDateFilterChips
		locale={locale}
		current={when}
		baseUrl={baseUrl.slice(0, -1)}
		searchParams={paginationParams}
	/>

	<!-- Category chips (below temporal chips) -->
	<TagChips
		chips={categoryChips}
		ariaLabel={t('events.categoryChips.ariaLabel', 'Filtrar por categoría de evento')}
	/>

	{hasError && !result.ok && <ErrorBanner locale={locale} error={result.error} entityName="eventos" />}

	{!hasError && cards.length === 0 && (
		<EmptyState locale={locale} variant="no-results" actionUrl={baseUrl} />
	)}

	{!hasError && resolvedCards.length > 0 && (
		<>
			<div class="events-grid">
				{resolvedCards.map((card, i) => (
					<div data-reveal="up" data-stagger-index={Math.min(i, 6)} data-stagger-step="100">
						<EventCardHorizontal data={card} locale={locale} isAuthenticated={isAuthenticated} />
					</div>
				))}
			</div>
			{/*
			 * Skeleton swaps in while a filter navigation is in flight
			 * (html[data-filters-loading]). Stays in the DOM so it renders
			 * instantly when the flag flips — no JS needed at swap time.
			 */}
			<div class="events-grid-skeleton" aria-hidden="true">
				{Array.from({ length: 9 }).map(() => (
					<EventCardHorizontalSkeleton />
				))}
			</div>
		</>
	)}

	<!-- Editor-recruitment banner (SPEC-191 FR-8): after the grid, before
	     pagination. page/[page].astro is a rewrite — single mount covers all pages. -->
	<ContributionBanner
		title={t('contributions.banner.editors.title', '¿Te gusta escribir?')}
		description={t(
			'contributions.banner.editorsEvents.description',
			'Buscamos editores voluntarios para cargar y curar los eventos de la agenda.'
		)}
		ctaLabel={t('contributions.banner.editors.cta', 'Sumate como editor')}
		ctaHref={buildUrl({ locale, path: 'colaborar/editores' })}
		source="events_listing"
		variant="editors"
	/>

	{totalPages > 1 && (
		<Pagination
			slot="pagination"
			currentPage={page}
			totalPages={totalPages}
			baseUrl={baseUrl.slice(0, -1)}
			locale={locale}
			searchParams={paginationParams}
		/>
	)}
</ListingLayout>

<style>
	.events-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(420px, 100%), 1fr));
		gap: var(--space-card-gap);
	}

	/*
	 * Filter navigation feedback: while filtering, hide the (now stale) real
	 * grid and surface the skeleton so the user sees instant "loading"
	 * feedback instead of a dimmed list with the old results showing through.
	 */
	.events-grid-skeleton {
		display: none;
	}

	:global([data-filters-loading]) .events-grid {
		display: none;
	}

	:global([data-filters-loading]) .events-grid-skeleton {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(420px, 100%), 1fr));
		gap: var(--space-card-gap);
	}
</style>
