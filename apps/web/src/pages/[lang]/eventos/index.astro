---
/**
 * Event List Page
 * Displays filterable list of events with category and timeframe filters.
 * Supports three locales: es, en, pt.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import EventCard from '../../../components/event/EventCard.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import EventErrorState from '../../../components/error/EventErrorState.astro';
import Pagination from '../../../components/ui/Pagination.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import SectionTitle from '../../../components/ui/SectionTitle.astro';
import { getLocaleFromParams } from '../../../lib/page-helpers';
import { eventsApi } from '../../../lib/api/endpoints';
import { toEventCardProps } from '../../../lib/api/transforms';
import { t } from '../../../lib/i18n';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

/**
 * Get query params for filtering events
 */
const url = new URL(Astro.request.url);
const category = url.searchParams.get('category') || '';
const timeframe = url.searchParams.get('timeframe') || 'upcoming';
const q = url.searchParams.get('q') || '';
const page = Number.parseInt(url.searchParams.get('page') || '1', 10);
const pageSize = 12;
const sortBy = url.searchParams.get('sortBy') || 'startDate';

/**
 * Localized page text variables
 */
const pageTitle = t({ locale, namespace: 'events', key: 'listPage.title' });
const pageDescription = t({ locale, namespace: 'events', key: 'listPage.description' });
const homeLabel = t({ locale, namespace: 'events', key: 'listPage.home' });
const eventsLabel = t({ locale, namespace: 'events', key: 'listPage.events' });
const upcomingLabel = t({ locale, namespace: 'events', key: 'listPage.upcoming' });
const pastLabel = t({ locale, namespace: 'events', key: 'listPage.past' });
const allLabel = t({ locale, namespace: 'events', key: 'listPage.all' });
const filterByCategoryLabel = t({ locale, namespace: 'events', key: 'listPage.filterByCategory' });
const allCategoriesLabel = t({ locale, namespace: 'events', key: 'listPage.allCategories' });
const festivalLabel = t({ locale, namespace: 'events', key: 'listPage.festival' });
const fairLabel = t({ locale, namespace: 'events', key: 'listPage.fair' });
const sportLabel = t({ locale, namespace: 'events', key: 'listPage.sport' });
const culturalLabel = t({ locale, namespace: 'events', key: 'listPage.cultural' });
const gastronomyLabel = t({ locale, namespace: 'events', key: 'listPage.gastronomy' });
const noEventsLabel = t({ locale, namespace: 'events', key: 'listPage.noEvents' });
const noEventsDescriptionLabel = t({ locale, namespace: 'events', key: 'listPage.noEventsDescription' });

/**
 * Category filter options
 */
const categories = [
  { value: '', label: allCategoriesLabel },
  { value: 'festival', label: festivalLabel },
  { value: 'fair', label: fairLabel },
  { value: 'sport', label: sportLabel },
  { value: 'cultural', label: culturalLabel },
  { value: 'gastronomy', label: gastronomyLabel },
];

/**
 * Fetch events from API
 */
const apiResult = await eventsApi.list({ page, pageSize, q, sortBy, category: category || undefined });

const apiError = !apiResult.ok;
const events = apiResult.ok ? apiResult.data.items : [];
const pagination = apiResult.ok ? apiResult.data.pagination : null;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
  { label: homeLabel, href: `/${locale}/` },
  { label: eventsLabel, href: `/${locale}/eventos/` },
];

/**
 * Generate canonical URL for SEO
 */
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const eventCards = events.map((evt) =>
  toEventCardProps({ item: evt as Record<string, unknown> })
);
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
  <SEOHead
    slot="head"
    title={pageTitle}
    description={pageDescription}
    canonical={canonicalUrl}
    locale={locale}
  />

  <Container>
    <Breadcrumb items={breadcrumbItems} />

    <SectionTitle as="h1" class="mb-6">{pageTitle}</SectionTitle>

    <!-- Filters bar -->
    <div
      class="mb-8 flex flex-col gap-4 rounded-lg border border-border bg-surface p-4 sm:flex-row sm:items-center sm:justify-between"
    >
      <!-- Timeframe toggle -->
      <div class="flex gap-1 rounded-lg bg-surface-alt p-1" role="tablist">
        {
          ['upcoming', 'past', 'all'].map((tf) => (
            <a
              href={`/${locale}/eventos/?timeframe=${tf}${category ? `&category=${category}` : ''}`}
              role="tab"
              aria-selected={timeframe === tf}
              class:list={[
                'rounded-md px-4 py-2 text-sm font-medium transition-colors',
                timeframe === tf
                  ? 'bg-surface text-primary shadow-sm'
                  : 'text-text-secondary hover:text-text',
              ]}
            >
              {tf === 'upcoming' ? upcomingLabel : tf === 'past' ? pastLabel : allLabel}
            </a>
          ))
        }
      </div>

      <!-- Category filter -->
      <div class="flex items-center gap-2">
        <label for="category-filter" class="whitespace-nowrap text-sm font-medium text-text">
          {filterByCategoryLabel}:
        </label>
        <select
          id="category-filter"
          class="rounded-md border border-border bg-surface px-3 py-2 text-sm text-text focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
        >
          {
            categories.map((cat) => (
              <option value={cat.value} selected={cat.value === category}>
                {cat.label}
              </option>
            ))
          }
        </select>
      </div>
    </div>

    <!-- Events grid -->
    {
      eventCards.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {eventCards.map((event) => (
            <EventCard
              event={event}
              locale={locale}
            />
          ))}
        </div>
      ) : apiError ? (
        <EventErrorState locale={locale} />
      ) : (
        <EmptyState title={noEventsLabel} message={noEventsDescriptionLabel} />
      )
    }

    <!-- Pagination -->
    {pagination && (
      <Pagination
        currentPage={pagination.page}
        totalPages={pagination.totalPages}
        baseUrl={`/${locale}/eventos`}
        locale={locale}
      />
    )}
  </Container>
</BaseLayout>

<script>
  /**
   * Category filter change handler
   * Redirects to filtered URL when category is changed
   */
  const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
  if (categoryFilter) {
    categoryFilter.addEventListener('change', () => {
      const url = new URL(window.location.href);
      if (categoryFilter.value) {
        url.searchParams.set('category', categoryFilter.value);
      } else {
        url.searchParams.delete('category');
      }
      window.location.href = url.toString();
    });
  }
</script>
