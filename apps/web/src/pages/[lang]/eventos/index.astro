---
/**
 * @file eventos/index.astro
 * @description Event list page with timeframe filter tabs (upcoming/past/all),
 * category filter, pagination, and breadcrumb navigation.
 *
 * Rendering: SSR (on-demand) — requires query params for filtering.
 * Route: /[lang]/eventos/
 */

import { createT, type SupportedLocale } from '../../../lib/i18n';
import { buildUrl, buildUrlWithParams } from '../../../lib/urls';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../lib/page-helpers';
import { eventsApi } from '../../../lib/api/endpoints';
import { toEventCardProps } from '../../../lib/api/transforms';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../components/shared/Breadcrumb.astro';
import BackgroundPattern from '../../../components/shared/BackgroundPattern.astro';
import DecorativeElement from '../../../components/shared/DecorativeElement.astro';
import EventCard from '../../../components/shared/EventCard.astro';
import EmptyState from '../../../components/shared/EmptyState.astro';
import Pagination from '../../../components/shared/Pagination.astro';
import { CalendarIcon, ClockIcon, ListIcon } from '@repo/icons';

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const t = createT(locale as SupportedLocale);

/** Parse query params for filtering and pagination. */
const searchParams = Astro.url.searchParams;
const timeframe = searchParams.get('timeframe') || 'upcoming';
const category = searchParams.get('category') || '';
const page = Math.max(1, Number.parseInt(searchParams.get('page') || '1', 10));
const PAGE_SIZE = 12;

/** Localized page text. */
const pageTitle = t('events.listPage.title', 'Eventos');
const pageDescription = t('events.listPage.description', 'Descubri los proximos eventos en Concepcion del Uruguay y el Litoral argentino.');
const upcomingLabel = t('events.listPage.upcoming', 'Proximos');
const pastLabel = t('events.listPage.past', 'Pasados');
const allLabel = t('events.listPage.all', 'Todos');
const filterByCategoryLabel = t('events.listPage.filterByCategory', 'Categoria');
const allCategoriesLabel = t('events.listPage.allCategories', 'Todas');
const festivalLabel = t('events.listPage.festival', 'Festival');
const fairLabel = t('events.listPage.fair', 'Feria');
const sportLabel = t('events.listPage.sport', 'Deporte');
const culturalLabel = t('events.listPage.cultural', 'Cultural');
const gastronomyLabel = t('events.listPage.gastronomy', 'Gastronomia');
const noEventsTitle = t('events.listPage.noEvents', 'Sin eventos');
const noEventsMessage = t('events.listPage.noEventsDescription', 'No hay eventos disponibles para los filtros seleccionados.');
const errorTitle = t('events.listPage.errorTitle', 'Error al cargar eventos');
const errorMessage = t('events.listPage.errorMessage', 'Ocurrio un error al obtener los eventos. Por favor intenta mas tarde.');

/**
 * Category filter options available in the UI.
 */
const categories: readonly { readonly value: string; readonly label: string }[] = [
    { value: '', label: allCategoriesLabel },
    { value: 'festival', label: festivalLabel },
    { value: 'fair', label: fairLabel },
    { value: 'sport', label: sportLabel },
    { value: 'cultural', label: culturalLabel },
    { value: 'gastronomy', label: gastronomyLabel },
] as const;

/**
 * Timeframe tab configuration. Each tab links to the same page with a different
 * `timeframe` query param, preserving the current category filter.
 */
interface TimeframeTab {
    readonly value: string;
    readonly label: string;
}

const timeframeTabs: readonly TimeframeTab[] = [
    { value: 'upcoming', label: upcomingLabel },
    { value: 'past', label: pastLabel },
    { value: 'all', label: allLabel },
] as const;

/**
 * Build a URL for a timeframe tab, preserving the current category.
 */
function buildTimeframeUrl(tf: string): string {
    const params: Record<string, string> = { timeframe: tf };
    if (category) {
        params.category = category;
    }
    return buildUrlWithParams({ locale: locale as SupportedLocale, path: 'eventos', params });
}

/**
 * Build a URL for a category option, preserving the current timeframe.
 */
function buildCategoryUrl(cat: string): string {
    const params: Record<string, string> = { timeframe };
    if (cat) {
        params.category = cat;
    }
    return buildUrlWithParams({ locale: locale as SupportedLocale, path: 'eventos', params });
}

/** API params: map timeframe to sortBy / isFeatured if applicable. */
const apiParams: Parameters<typeof eventsApi.list>[0] = {
    page,
    pageSize: PAGE_SIZE,
    sortBy: 'startDate',
    ...(category ? { category } : {}),
};

const apiResult = await eventsApi.list(apiParams);

const apiError = !apiResult.ok;
const events = apiResult.ok ? apiResult.data.items : [];
const pagination = apiResult.ok ? apiResult.data.pagination : null;

const eventCards = events.map((evt) =>
    toEventCardProps({ item: evt as Record<string, unknown> })
);

/**
 * Breadcrumb items for this page.
 */
const breadcrumbItems = [
    { label: HOME_BREADCRUMB[locale as SupportedLocale], href: buildUrl({ locale: locale as SupportedLocale }) },
    { label: pageTitle, href: buildUrl({ locale: locale as SupportedLocale, path: 'eventos' }) },
] as const;

/**
 * Canonical URL (without query params for SEO).
 */
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Build URLSearchParams to pass to Pagination for query-param mode.
 * Preserves timeframe and category across page navigation.
 */
const paginationParams = new URLSearchParams({ timeframe });
if (category) {
    paginationParams.set('category', category);
}
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={pageDescription}
        canonical={canonicalUrl}
        locale={locale as SupportedLocale}
    />

    <div class="container mx-auto max-w-7xl px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />

        <!-- Page Hero -->
        <header class="relative mb-8 overflow-hidden rounded-xl py-6">
            <BackgroundPattern pattern="/images/patterns/pattern-waves.svg" size="80px 80px" opacity="opacity-40" />
            <DecorativeElement src="/images/decoratives/deco-avion.svg" position="top-2 right-4 md:right-12" size="w-14 md:w-20" opacity="opacity-50" />
            <DecorativeElement src="/images/decoratives/deco-flecha-curva.svg" position="bottom-2 left-4 md:left-12" size="w-16 md:w-24" opacity="opacity-40" />
            <div class="relative">
                <h1 class="text-4xl font-bold text-foreground">{pageTitle}</h1>
                <p class="mt-2 text-lg text-muted-foreground">{pageDescription}</p>
            </div>
        </header>

        <!-- Filters Bar -->
        <div class="mb-8 flex flex-col gap-4 rounded-xl border border-border bg-card p-4 sm:flex-row sm:items-center sm:justify-between">

            <!-- Timeframe Tabs -->
            <nav aria-label={t('events.listPage.timeframeLabel', 'Filtrar por fecha')}>
                <ul class="flex gap-1 rounded-lg bg-muted p-1" role="tablist">
                    {timeframeTabs.map(({ value, label }) => {
                        const isActive = timeframe === value;
                        return (
                            <li role="presentation">
                                <a
                                    href={buildTimeframeUrl(value)}
                                    role="tab"
                                    aria-selected={isActive}
                                    class:list={[
                                        'inline-flex items-center gap-1.5 rounded-md px-4 py-2 text-sm font-medium transition-colors',
                                        isActive
                                            ? 'bg-card text-foreground shadow-sm'
                                            : 'text-muted-foreground hover:text-foreground',
                                    ]}
                                >
                                    {value === 'upcoming' && <CalendarIcon size={14} aria-hidden="true" />}
                                    {value === 'past' && <ClockIcon size={14} aria-hidden="true" />}
                                    {value === 'all' && <ListIcon size={14} aria-hidden="true" />}
                                    {label}
                                </a>
                            </li>
                        );
                    })}
                </ul>
            </nav>

            <!-- Category Filter (HTML links, no JS) -->
            <div class="flex flex-wrap items-center gap-2">
                <span class="text-sm font-medium text-muted-foreground" id="category-filter-label">
                    {filterByCategoryLabel}:
                </span>
                <ul
                    class="flex flex-wrap gap-1"
                    role="list"
                    aria-labelledby="category-filter-label"
                >
                    {categories.map(({ value, label }) => {
                        const isActive = category === value;
                        return (
                            <li>
                                <a
                                    href={buildCategoryUrl(value)}
                                    class:list={[
                                        'inline-block rounded-full border px-3 py-1 text-xs font-medium transition-colors',
                                        isActive
                                            ? 'border-primary bg-primary text-primary-foreground'
                                            : 'border-border bg-card text-muted-foreground hover:border-primary/60 hover:text-foreground',
                                    ]}
                                    aria-current={isActive ? 'true' : undefined}
                                >
                                    {label}
                                </a>
                            </li>
                        );
                    })}
                </ul>
            </div>
        </div>

        <!-- Events Grid or States -->
        {apiError ? (
            <EmptyState
                title={errorTitle}
                message={errorMessage}
                cta={{
                    label: t('events.listPage.retry', 'Volver al inicio'),
                    href: buildUrl({ locale: locale as SupportedLocale }),
                }}
            />
        ) : eventCards.length > 0 ? (
            <section aria-label={pageTitle}>
                <div class="scroll-reveal grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                    {eventCards.map((card) => (
                        <article>
                            <EventCard card={card} locale={locale} />
                        </article>
                    ))}
                </div>

                {pagination && pagination.totalPages > 1 && (
                    <Pagination
                        currentPage={pagination.page}
                        totalPages={pagination.totalPages}
                        baseUrl={buildUrl({ locale: locale as SupportedLocale, path: 'eventos' }).replace(/\/$/, '')}
                        locale={locale as SupportedLocale}
                        searchParams={paginationParams}
                    />
                )}
            </section>
        ) : (
            <EmptyState
                title={noEventsTitle}
                message={noEventsMessage}
                cta={{
                    label: t('events.listPage.viewAll', 'Ver todos los eventos'),
                    href: buildUrlWithParams({
                        locale: locale as SupportedLocale,
                        path: 'eventos',
                        params: { timeframe: 'all' },
                    }),
                }}
            />
        )}
    </div>
</BaseLayout>
