---
/**
 * @file [page].astro
 * @description Pagination rewrite for the event category landing. Validates
 * the page param, redirects page 1 to the canonical (no `/page/1/`) URL, and
 * rewrites to the parent category listing with `?page=N`.
 *
 * Was previously a 301 redirect straight to `/eventos/?category=ENUM&page=N`
 * from when the category page itself was a redirect stub (U7). Now that the
 * category landing is first-class again (SPEC-306), pagination must stay on
 * the category landing — mirrors `alojamientos/tipo/[type]/page/[page].astro`.
 */

const { page: pageParam } = Astro.params;
const page = Number(pageParam);

// Must be a positive integer
if (!Number.isInteger(page) || page < 1) {
    return new Response(null, { status: 404 });
}

// Page 1 → redirect to canonical (no /page/1/ in URL)
if (page === 1) {
    return Astro.redirect(`/${Astro.params.lang}/eventos/categoria/${Astro.params.category}/`, 301);
}

// Rewrite to parent listing with page query param
return Astro.rewrite(
    `/${Astro.params.lang}/eventos/categoria/${Astro.params.category}/?page=${page}`
);
---
