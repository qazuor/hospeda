---
/**
 * Paginated event category listing route.
 *
 * Rewrites to the category index page with the `page` query parameter so
 * the single index page handles all pagination without duplicating logic.
 * Page 1 redirects to the canonical base URL (no /page/ segment) to avoid
 * duplicate content.
 *
 * @route /[lang]/eventos/categoria/[category]/page/[page]/
 * @rendering SSR (on-demand, no prerender)
 */

import { getLocaleFromParams } from '../../../../../../lib/page-helpers';

/**
 * Allowed event category slugs — must stay in sync with the index page and
 * the CATEGORY_API_VALUE map defined there.
 */
const ALLOWED_CATEGORIES = ['festival', 'fair', 'sport', 'cultural', 'gastronomy'] as const;

/** Union type of valid category slugs. */
type EventCategorySlug = (typeof ALLOWED_CATEGORIES)[number];

const { category, page } = Astro.params;
const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

if (!category || !ALLOWED_CATEGORIES.includes(category as EventCategorySlug)) {
    return Astro.redirect(`/${locale}/eventos/`);
}

const pageNum = Number.parseInt(page ?? '1', 10);

if (Number.isNaN(pageNum) || pageNum < 1) {
    return Astro.redirect(`/${locale}/eventos/categoria/${category}/`);
}

/** Page 1 must use the canonical base URL — no /page/ segment. */
if (pageNum === 1) {
    return Astro.redirect(`/${locale}/eventos/categoria/${category}/`);
}

/** Rewrite to the index page; it reads `page` from the query string. */
return Astro.rewrite(`/${locale}/eventos/categoria/${category}/?page=${pageNum}`);
---
