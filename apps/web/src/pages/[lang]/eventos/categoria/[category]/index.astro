---
export const prerender = true;

/**
 * Returns static paths for all locale + category combinations.
 * 3 locales x 5 categories = 15 pre-rendered pages.
 */
export function getStaticPaths() {
  const locales = ['es', 'en', 'pt'] as const;
  const categories = ['festival', 'fair', 'sport', 'cultural', 'gastronomy'] as const;

  return locales.flatMap((lang) =>
    categories.map((category) => ({ params: { lang, category } }))
  );
}

/**
 * Event by Category page.
 * Displays filtered list of events by category (festival, fair, sport, cultural, gastronomy).
 * Validates locale and category parameters, redirects if invalid.
 *
 * @route /[lang]/eventos/categoria/[category]/
 * @rendering SSG (Static Site Generation)
 */
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import SEOHead from '../../../../../components/seo/SEOHead.astro';
import JsonLd from '../../../../../components/seo/JsonLd.astro';
import Breadcrumb from '../../../../../components/ui/Breadcrumb.astro';
import Container from '../../../../../components/ui/Container.astro';
import Section from '../../../../../components/ui/Section.astro';
import EmptyState from '../../../../../components/ui/EmptyState.astro';
import Pagination from '../../../../../components/ui/Pagination.astro';
import EventCard from '../../../../../components/event/EventCard.astro';
import { isValidLocale, type SupportedLocale } from '../../../../../lib/i18n';
import { eventsApi } from '../../../../../lib/api/endpoints';

const { lang, category } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/es/');
}

const locale = lang as SupportedLocale;

/**
 * Allowed event categories (URL slugs)
 */
const ALLOWED_CATEGORIES = [
  'festival',
  'fair',
  'sport',
  'cultural',
  'gastronomy',
] as const;

type EventCategory = (typeof ALLOWED_CATEGORIES)[number];

/**
 * Validate event category parameter
 */
if (!category || !ALLOWED_CATEGORIES.includes(category as EventCategory)) {
  return Astro.redirect(`/${locale}/eventos/`);
}

const eventCategory = category as EventCategory;

/**
 * Map URL slug to API category value (uppercase as used in EventCard)
 */
const categoryApiValue: Record<EventCategory, string> = {
  festival: 'FESTIVAL',
  fair: 'FAIR',
  sport: 'SPORTS',
  cultural: 'CULTURAL',
  gastronomy: 'GASTRONOMY',
};

/**
 * Localized category names (plural)
 */
const categoryNames: Record<SupportedLocale, Record<EventCategory, string>> = {
  es: {
    festival: 'Festivales',
    fair: 'Ferias',
    sport: 'Deportes',
    cultural: 'Culturales',
    gastronomy: 'Gastronomía',
  },
  en: {
    festival: 'Festivals',
    fair: 'Fairs',
    sport: 'Sports',
    cultural: 'Cultural Events',
    gastronomy: 'Gastronomy',
  },
  pt: {
    festival: 'Festivais',
    fair: 'Feiras',
    sport: 'Esportes',
    cultural: 'Eventos Culturais',
    gastronomy: 'Gastronomia',
  },
};

/**
 * Localized category descriptions for SEO
 */
const categoryDescriptions: Record<SupportedLocale, Record<EventCategory, string>> = {
  es: {
    festival: 'Descubre los mejores festivales en Concepción del Uruguay y la región del Litoral argentino. Música, arte y cultura para todos.',
    fair: 'Explora las ferias locales y regionales del Litoral argentino. Artesanías, productos típicos y experiencias únicas.',
    sport: 'Encuentra eventos deportivos en Concepción del Uruguay. Competencias, torneos y actividades para todas las edades.',
    cultural: 'Eventos culturales, exposiciones y actividades artísticas en el Litoral argentino. Descubre el patrimonio cultural de la región.',
    gastronomy: 'Festivales y eventos gastronómicos en Concepción del Uruguay. Sabores únicos de la cocina regional del Litoral.',
  },
  en: {
    festival: 'Discover the best festivals in Concepción del Uruguay and the Argentine Litoral region. Music, art, and culture for everyone.',
    fair: 'Explore local and regional fairs in the Argentine Litoral. Crafts, typical products, and unique experiences.',
    sport: 'Find sporting events in Concepción del Uruguay. Competitions, tournaments, and activities for all ages.',
    cultural: 'Cultural events, exhibitions, and artistic activities in the Argentine Litoral. Discover the cultural heritage of the region.',
    gastronomy: 'Food festivals and gastronomic events in Concepción del Uruguay. Unique flavors of regional Litoral cuisine.',
  },
  pt: {
    festival: 'Descubra os melhores festivais em Concepción del Uruguay e na região do Litoral argentino. Música, arte e cultura para todos.',
    fair: 'Explore as feiras locais e regionais do Litoral argentino. Artesanato, produtos típicos e experiências únicas.',
    sport: 'Encontre eventos esportivos em Concepción del Uruguay. Competições, torneios e atividades para todas as idades.',
    cultural: 'Eventos culturais, exposições e atividades artísticas no Litoral argentino. Descubra o patrimônio cultural da região.',
    gastronomy: 'Festivais e eventos gastronômicos em Concepción del Uruguay. Sabores únicos da culinária regional do Litoral.',
  },
};

/**
 * Localized page titles
 */
const pageTitles: Record<SupportedLocale, Record<EventCategory, string>> = {
  es: {
    festival: 'Eventos - Festivales',
    fair: 'Eventos - Ferias',
    sport: 'Eventos - Deportes',
    cultural: 'Eventos - Culturales',
    gastronomy: 'Eventos - Gastronomía',
  },
  en: {
    festival: 'Events - Festivals',
    fair: 'Events - Fairs',
    sport: 'Events - Sports',
    cultural: 'Events - Cultural',
    gastronomy: 'Events - Gastronomy',
  },
  pt: {
    festival: 'Eventos - Festivais',
    fair: 'Eventos - Feiras',
    sport: 'Eventos - Esportes',
    cultural: 'Eventos - Culturais',
    gastronomy: 'Eventos - Gastronomia',
  },
};

/**
 * Localized common labels
 */
const labels: Record<SupportedLocale, Record<string, string>> = {
  es: {
    home: 'Inicio',
    events: 'Eventos',
    noResults: 'No hay eventos de categoría {category} disponibles',
  },
  en: {
    home: 'Home',
    events: 'Events',
    noResults: 'No {category} events available',
  },
  pt: {
    home: 'Início',
    events: 'Eventos',
    noResults: 'Não há eventos da categoria {category} disponíveis',
  },
};

const categoryName = categoryNames[locale][eventCategory];
const categoryDescription = categoryDescriptions[locale][eventCategory];
const pageTitle = pageTitles[locale][eventCategory];
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/**
 * Breadcrumb navigation items
 */
const breadcrumbItems = [
  { label: labels[locale].home, href: `/${locale}/` },
  { label: labels[locale].events, href: `/${locale}/eventos/` },
  { label: categoryName, href: `/${locale}/eventos/categoria/${eventCategory}/` },
];

/**
 * Get pagination parameters from URL.
 * Astro.url.searchParams works for both SSG and ISR modes.
 */
const page = Number.parseInt(Astro.url.searchParams.get('page') || '1', 10);
const pageSize = 12;

/**
 * Fetch events filtered by category
 */
const apiResult = await eventsApi.list({ page, pageSize, category: categoryApiValue[eventCategory] });

const events = apiResult.ok ? apiResult.data.items : [];
const pagination = apiResult.ok ? apiResult.data.pagination : null;

/**
 * Generate empty state message
 */
const emptyMessage = labels[locale].noResults.replace('{category}', categoryName.toLowerCase());

/**
 * CollectionPage + BreadcrumbList JSON-LD structured data
 */
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: pageTitle,
      description: categoryDescription,
      url: canonicalUrl,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbItems.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.label,
        item: new URL(item.href, Astro.site).href,
      })),
    },
  ],
};
---

<BaseLayout title={pageTitle} description={categoryDescription} locale={locale}>
  <SEOHead
    slot="head"
    title={pageTitle}
    description={categoryDescription}
    canonical={canonicalUrl}
    locale={locale === 'pt' ? 'es' : locale}
    type="website"
  />
  <JsonLd slot="head" data={collectionJsonLd} />

  <Container>
    <Breadcrumb items={breadcrumbItems} />

    <Section>
      <div class="mx-auto max-w-6xl">
        <!-- Category Header Section -->
        <article id="category-header" class="mb-12 text-center">
          <h1 class="mb-6 text-4xl font-bold text-text-primary md:text-5xl">
            {categoryName}
          </h1>
          <p class="text-xl leading-relaxed text-text-secondary">
            {categoryDescription}
          </p>
        </article>

        <!-- Event Grid Section -->
        <article id="event-grid" class="mb-12">
          {
            events.length > 0 ? (
              <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {events.map((event) => (
                  <EventCard event={event} locale={locale} />
                ))}
              </div>
            ) : (
              <EmptyState title={emptyMessage} message={labels[locale].events} />
            )
          }
        </article>

        <!-- Pagination Section -->
        {
          pagination && pagination.totalPages > 1 && (
            <article id="pagination" class="mb-12">
              <Pagination
                currentPage={pagination.page as number}
                totalPages={pagination.totalPages as number}
                baseUrl={`/${locale}/eventos/categoria/${eventCategory}`}
                locale={locale}
              />
            </article>
          )
        }
      </div>
    </Section>
  </Container>
</BaseLayout>
