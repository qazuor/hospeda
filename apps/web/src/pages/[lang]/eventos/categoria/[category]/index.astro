---
/**
 * @file eventos/categoria/[category]/index.astro
 * @description Event category list page. Renders a filtered grid of events
 * pre-scoped to a single category slug (festival, fair, sport, cultural, gastronomy).
 *
 * Rendering: SSR (on-demand).
 * Route: /[lang]/eventos/categoria/[category]/
 */

import { createT, type SupportedLocale } from '../../../../../lib/i18n';
import { buildUrl } from '../../../../../lib/urls';
import { getLocaleFromParams, HOME_BREADCRUMB } from '../../../../../lib/page-helpers';
import { eventsApi } from '../../../../../lib/api/endpoints';
import { toEventCardProps } from '../../../../../lib/api/transforms';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import SEOHead from '../../../../../components/seo/SEOHead.astro';
import Breadcrumb from '../../../../../components/shared/Breadcrumb.astro';
import EventCard from '../../../../../components/shared/EventCard.astro';
import EmptyState from '../../../../../components/shared/EmptyState.astro';
import Pagination from '../../../../../components/shared/Pagination.astro';

/** Allowed event category slugs that map to API values. */
const ALLOWED_CATEGORIES = ['festival', 'fair', 'sport', 'cultural', 'gastronomy'] as const;

/** Union type of valid category slugs. */
type EventCategorySlug = (typeof ALLOWED_CATEGORIES)[number];

const locale = getLocaleFromParams(Astro.params);
if (!locale) return Astro.redirect('/es/');

const t = createT(locale as SupportedLocale);

const { category } = Astro.params;

/** Redirect to events index if the category slug is not recognised. */
if (!category || !ALLOWED_CATEGORIES.includes(category as EventCategorySlug)) {
    return Astro.redirect(buildUrl({ locale: locale as SupportedLocale, path: 'eventos' }));
}

const eventCategory = category as EventCategorySlug;

/**
 * Maps URL slugs to the API-expected category values.
 * The API uses uppercase identifiers for event categories.
 */
const CATEGORY_API_VALUE: Readonly<Record<EventCategorySlug, string>> = {
    festival: 'FESTIVAL',
    fair: 'FAIR',
    sport: 'SPORTS',
    cultural: 'CULTURAL',
    gastronomy: 'GASTRONOMY',
} as const;

/** Localized display name for the category. */
const categoryName = t(
    `events.categoryPage.categories.${eventCategory}.name`,
    eventCategory.charAt(0).toUpperCase() + eventCategory.slice(1)
);

/** Localized description shown in the page hero. */
const categoryDescription = t(
    `events.categoryPage.categories.${eventCategory}.description`,
    t('events.categoryPage.fallback.description', 'Explora los eventos de esta categoria.')
);

/** Page title used in SEO head and the hero heading. */
const pageTitle = t(
    `events.categoryPage.categories.${eventCategory}.pageTitle`,
    categoryName
);

/** Pagination page number from URL search params (SSG with query params resolved at edge). */
const page = Math.max(1, Number.parseInt(Astro.url.searchParams.get('page') || '1', 10));
const PAGE_SIZE = 12;

/** Fetch events filtered by the active category. */
const apiResult = await eventsApi.list({
    page,
    pageSize: PAGE_SIZE,
    sortBy: 'startDate',
    category: CATEGORY_API_VALUE[eventCategory],
});

const apiError = !apiResult.ok;
const events = apiResult.ok ? apiResult.data.items : [];
const pagination = apiResult.ok ? apiResult.data.pagination : null;

const eventCards = events.map((evt) =>
    toEventCardProps({ item: evt as Record<string, unknown> })
);

/**
 * Breadcrumb navigation items for this page.
 * Home > Eventos > [Category name]
 */
const breadcrumbItems = [
    {
        label: HOME_BREADCRUMB[locale as SupportedLocale],
        href: buildUrl({ locale: locale as SupportedLocale }),
    },
    {
        label: t('events.listPage.title', 'Eventos'),
        href: buildUrl({ locale: locale as SupportedLocale, path: 'eventos' }),
    },
    {
        label: categoryName,
        href: buildUrl({
            locale: locale as SupportedLocale,
            path: `eventos/categoria/${eventCategory}`,
        }),
    },
] as const;

/** Canonical URL without query params for clean SEO indexing. */
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

/** Base URL for segment-mode pagination links (page/[N]/ sibling route). */
const paginationBaseUrl = buildUrl({
    locale: locale as SupportedLocale,
    path: `eventos/categoria/${eventCategory}`,
}).replace(/\/$/, '');

/** Localized empty state messages. */
const noEventsTitle = t('events.categoryPage.labels.noEventsTitle', 'Sin eventos');
const noEventsMessage = t(
    'events.categoryPage.labels.noEventsMessage',
    'No hay eventos disponibles en esta categoria por el momento.',
    { category: categoryName }
);
const errorTitle = t('events.listPage.errorTitle', 'Error al cargar eventos');
const errorMessage = t(
    'events.listPage.errorMessage',
    'Ocurrio un error al obtener los eventos. Por favor intenta mas tarde.'
);
---

<BaseLayout title={pageTitle} description={categoryDescription} locale={locale}>
    <SEOHead
        slot="head"
        title={pageTitle}
        description={categoryDescription}
        canonical={canonicalUrl}
        locale={locale as SupportedLocale}
        type="website"
    />

    <div class="container mx-auto max-w-7xl px-4 py-8">
        <Breadcrumb items={breadcrumbItems} />

        <!-- Category hero -->
        <header class="mb-8">
            <h1 class="text-4xl font-bold text-foreground">{pageTitle}</h1>
            <p class="mt-2 text-lg text-muted-foreground">{categoryDescription}</p>
        </header>

        <!-- Back link to full events list -->
        <div class="mb-6">
            <a
                href={buildUrl({ locale: locale as SupportedLocale, path: 'eventos' })}
                class="inline-flex items-center gap-1 text-sm font-medium text-muted-foreground transition-colors hover:text-primary"
            >
                &larr; {t('events.categoryPage.labels.allEvents', 'Ver todos los eventos')}
            </a>
        </div>

        <!-- Event grid or states -->
        {apiError ? (
            <EmptyState
                title={errorTitle}
                message={errorMessage}
                cta={{
                    label: t('events.listPage.retry', 'Volver al inicio'),
                    href: buildUrl({ locale: locale as SupportedLocale }),
                }}
            />
        ) : eventCards.length > 0 ? (
            <section aria-label={pageTitle}>
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                    {eventCards.map((card) => (
                        <article>
                            <EventCard card={card} locale={locale} />
                        </article>
                    ))}
                </div>

                {pagination && pagination.totalPages > 1 && (
                    <Pagination
                        currentPage={pagination.page}
                        totalPages={pagination.totalPages}
                        baseUrl={paginationBaseUrl}
                        locale={locale as SupportedLocale}
                    />
                )}
            </section>
        ) : (
            <EmptyState
                title={noEventsTitle}
                message={noEventsMessage}
                cta={{
                    label: t('events.listPage.viewAll', 'Ver todos los eventos'),
                    href: buildUrl({ locale: locale as SupportedLocale, path: 'eventos' }),
                }}
            />
        )}
    </div>
</BaseLayout>
