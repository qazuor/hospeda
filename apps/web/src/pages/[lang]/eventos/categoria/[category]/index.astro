---
/**
 * @file eventos/categoria/[category]/index.astro
 * @description Permanent (301) redirect to the unified events listing filtered
 * by category (`/{lang}/eventos/?category=ENUM`). The standalone category page
 * was retired (U7): category filtering now happens in place on the main
 * listing, so the sidebar, the other active filters, and filter combination are
 * all preserved. A future SEO spec may reintroduce first-class, indexable
 * category landing pages.
 * @route /{lang}/eventos/categoria/{category}/
 */
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { category: catSlug } = Astro.params;

/** Slug → EventCategoryEnum value that the listing's `?category=` param expects. */
const VALID_CATEGORIES: Record<string, string> = {
	music: 'MUSIC',
	culture: 'CULTURE',
	sports: 'SPORTS',
	gastronomy: 'GASTRONOMY',
	festival: 'FESTIVAL',
	nature: 'NATURE',
	theater: 'THEATER',
	workshop: 'WORKSHOP',
	other: 'OTHER'
};

const catEnum = catSlug ? VALID_CATEGORIES[catSlug] : undefined;
if (!catEnum) return new Response(null, { status: 404 });

// Forward any existing query params (e.g. `page`) and add the category filter.
const params = new URLSearchParams(Astro.url.searchParams);
params.set('category', catEnum);
return Astro.redirect(`${buildUrl({ locale, path: 'eventos' })}?${params.toString()}`, 301);
---
