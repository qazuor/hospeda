---
/**
 * @file eventos/categoria/[category]/index.astro
 * @description Events filtered by category.
 * @route /{lang}/eventos/categoria/{category}/
 * @rendering SSR + ISR 24h
 */

import ListingLayout from '@/layouts/ListingLayout.astro';
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro';
import ListingPageHeader from '@/components/shared/ListingPageHeader.astro';
import EventCard from '@/components/shared/cards/EventCard.astro';
import EmptyState from '@/components/shared/EmptyState.astro';
import ErrorBanner from '@/components/shared/ErrorBanner.astro';
import Pagination from '@/components/shared/Pagination.astro';
import { eventsApi } from '@/lib/api/endpoints';
import { toEventCardProps } from '@/lib/api/transforms';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = Astro.locals.locale as SupportedLocale;
const { t } = createTranslations(locale);
const { category: catSlug } = Astro.params;

const VALID_CATEGORIES: Record<string, string> = {
	music: 'MUSIC', culture: 'CULTURE', sports: 'SPORTS', gastronomy: 'GASTRONOMY',
	festival: 'FESTIVAL', nature: 'NATURE', theater: 'THEATER', workshop: 'WORKSHOP', other: 'OTHER',
};

const catEnum = catSlug ? VALID_CATEGORIES[catSlug] : undefined;
if (!catEnum) return new Response(null, { status: 404 });

const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const result = await eventsApi.list({ page, pageSize: 9, category: catEnum });
const hasError = !result.ok;
const items = result.ok ? result.data.items : [];
const total = result.ok ? result.data.total : 0;
const totalPages = result.ok ? Math.ceil(total / 9) : 0;
const cards = items.map((item) => toEventCardProps({ item: item as unknown as Record<string, unknown> }));
const catLabel = t(`events.categories.${catSlug}`, catSlug ?? '');
const baseUrl = buildUrl({ locale, path: `eventos/categoria/${catSlug}` });
---

<ListingLayout locale={locale} title={`${catLabel} - ${t('events.title', 'Eventos')}`} description={`Eventos de ${catLabel}`} showFilters={false}>
	<Breadcrumbs slot="breadcrumbs" locale={locale} items={[{ label: t('events.title', 'Eventos'), path: 'eventos' }, { label: catLabel }]} />
	<ListingPageHeader slot="page-header" locale={locale} tagline={t('events.byCategory.tagline', 'Categoría')} title={catLabel} totalCount={total} />

	{hasError && !result.ok && <ErrorBanner locale={locale} error={result.error} entityName="eventos" />}
	{!hasError && cards.length === 0 && <EmptyState locale={locale} variant="no-results" actionUrl={buildUrl({ locale, path: 'eventos' })} />}
	{!hasError && cards.length > 0 && (
		<div class="grid">
			{cards.map((card, i) => (<div data-reveal="up" style={`transition-delay: ${Math.min(i, 6) * 100}ms`}><EventCard data={card} locale={locale} /></div>))}
		</div>
	)}
	{totalPages > 1 && <Pagination slot="pagination" currentPage={page} totalPages={totalPages} baseUrl={baseUrl.slice(0, -1)} locale={locale} />}
</ListingLayout>

<style>
	.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-card-gap); }
	@media (max-width: 1024px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>
