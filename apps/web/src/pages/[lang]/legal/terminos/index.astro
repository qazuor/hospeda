---
/**
 * @file legal/terminos/index.astro
 * @description Terms and conditions page with 10 numbered sections and ToC.
 * @route /{lang}/legal/terminos/
 * @rendering SSG (prerender)
 */

import LegalLayout from '@/layouts/LegalLayout.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import type { GetStaticPaths } from 'astro';

export const prerender = true;

export const getStaticPaths = (() => {
	return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const locale = lang as SupportedLocale;
const { t } = createTranslations(locale);

const sections = [
	{ id: 'aceptacion', titleKey: 'terms.section1.title', titleFb: 'Aceptación de los términos', contentKey: 'terms.section1.content', contentFb: 'Al acceder y utilizar la plataforma Hospeda (en adelante, "el Servicio"), usted acepta estar sujeto a estos Términos y Condiciones. Si no está de acuerdo con alguna parte de estos términos, no podrá acceder al Servicio.' },
	{ id: 'uso-servicio', titleKey: 'terms.section2.title', titleFb: 'Uso del servicio', contentKey: 'terms.section2.content', contentFb: 'El Servicio está destinado a facilitar la conexión entre propietarios de alojamientos turísticos y viajeros en la región del litoral entrerriano, Argentina. Usted se compromete a utilizar el Servicio únicamente para fines legítimos y de acuerdo con estos Términos.' },
	{ id: 'registro', titleKey: 'terms.section3.title', titleFb: 'Registro de cuenta', contentKey: 'terms.section3.content', contentFb: 'Para utilizar ciertas funcionalidades del Servicio, deberá crear una cuenta proporcionando información precisa, completa y actualizada. Usted es responsable de mantener la confidencialidad de su contraseña y de todas las actividades que ocurran bajo su cuenta.' },
	{ id: 'publicacion', titleKey: 'terms.section4.title', titleFb: 'Publicación de alojamientos', contentKey: 'terms.section4.content', contentFb: 'Los propietarios que publiquen alojamientos en la plataforma garantizan que la información proporcionada es veraz, precisa y completa. Hospeda se reserva el derecho de revisar, modificar o eliminar cualquier publicación que no cumpla con nuestras políticas.' },
	{ id: 'reservas', titleKey: 'terms.section5.title', titleFb: 'Reservas y pagos', contentKey: 'terms.section5.content', contentFb: 'Las reservas se realizan directamente entre el viajero y el propietario del alojamiento. Hospeda actúa como intermediario facilitando la conexión, pero no es parte directa de la transacción. Los pagos se procesan a través de MercadoPago.' },
	{ id: 'cancelaciones', titleKey: 'terms.section6.title', titleFb: 'Cancelaciones y reembolsos', contentKey: 'terms.section6.content', contentFb: 'Las políticas de cancelación son definidas por cada propietario. Hospeda facilita el proceso de cancelación pero no es responsable de los reembolsos, que dependen de la política del propietario y las condiciones de la reserva.' },
	{ id: 'propiedad-intelectual', titleKey: 'terms.section7.title', titleFb: 'Propiedad intelectual', contentKey: 'terms.section7.content', contentFb: 'Todo el contenido de la plataforma, incluyendo textos, imágenes, logotipos, diseños y software, es propiedad de Hospeda o de sus respectivos titulares. Queda prohibida su reproducción sin autorización expresa.' },
	{ id: 'limitacion', titleKey: 'terms.section8.title', titleFb: 'Limitación de responsabilidad', contentKey: 'terms.section8.content', contentFb: 'Hospeda no garantiza la disponibilidad ininterrumpida del Servicio ni la exactitud de la información proporcionada por terceros. En ningún caso seremos responsables por daños indirectos, incidentales o consecuentes.' },
	{ id: 'modificaciones', titleKey: 'terms.section9.title', titleFb: 'Modificaciones', contentKey: 'terms.section9.content', contentFb: 'Nos reservamos el derecho de modificar estos Términos en cualquier momento. Las modificaciones entrarán en vigor desde su publicación en la plataforma. El uso continuado del Servicio constituye aceptación de los términos modificados.' },
	{ id: 'contacto', titleKey: 'terms.section10.title', titleFb: 'Contacto', contentKey: 'terms.section10.content', contentFb: 'Para consultas sobre estos Términos y Condiciones, podés contactarnos a info@hospeda.com o a través de nuestro formulario de contacto.' },
] as const;
---

<LegalLayout
	locale={locale}
	title={t('terms.title', 'Términos y Condiciones')}
	description={t('terms.description', 'Términos y condiciones de uso de la plataforma Hospeda.')}
	lastUpdated="15 de marzo de 2026"
	showToc={true}
>
	<Fragment slot="toc">
		<ol class="toc-list">
			{sections.map((section, i) => (
				<li>
					<a href={`#${section.id}`} class="toc-link">
						{i + 1}. {t(section.titleKey, section.titleFb)}
					</a>
				</li>
			))}
		</ol>
	</Fragment>

	{sections.map((section, i) => (
		<section id={section.id}>
			<h2>{i + 1}. {t(section.titleKey, section.titleFb)}</h2>
			<p>{t(section.contentKey, section.contentFb)}</p>
		</section>
	))}
</LegalLayout>

<style>
	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.toc-link {
		display: block;
		padding: var(--space-2) var(--space-3);
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--muted-foreground);
		text-decoration: none;
		border-left: 2px solid transparent;
		transition: color var(--duration-fast) ease, border-color var(--duration-fast) ease;
	}

	.toc-link:hover {
		color: var(--foreground);
		border-left-color: var(--brand-accent);
	}
</style>
