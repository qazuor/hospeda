---
export const prerender = false; // SSR for authenticated content

import Layout from '@/layout/MainLayout.astro';
import { ALL_ADDONS } from '@repo/billing';
import type { AddonDefinition } from '@repo/billing';
import { AddonPurchaseButton } from '@/components/pricing';

/**
 * Add-ons and Extra Services Page
 * Allows users to view and purchase add-ons to enhance their subscription
 * Requires authentication
 */

// Check authentication (Clerk injects auth into Astro.locals via middleware)
const { userId } = Astro.locals.auth();

if (!userId) {
  return Astro.redirect('/auth/sign-in?redirect=/mi-cuenta/addons');
}

// Filter active add-ons and sort by sortOrder
const activeAddons = ALL_ADDONS
  .filter(addon => addon.isActive)
  .sort((a, b) => a.sortOrder - b.sortOrder);

// Separate one-time and recurring add-ons
const oneTimeAddons = activeAddons.filter(addon => addon.billingType === 'one_time');
const recurringAddons = activeAddons.filter(addon => addon.billingType === 'recurring');

function formatPrice(priceInCents: number): string {
  const price = priceInCents / 100;
  return new Intl.NumberFormat('es-AR', {
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(price);
}

function getTargetCategoryLabel(categories: string[]): string {
  if (categories.includes('owner') && categories.includes('complex')) {
    return 'Propietarios y Complejos';
  }
  if (categories.includes('owner')) {
    return 'Propietarios';
  }
  if (categories.includes('complex')) {
    return 'Complejos';
  }
  return '';
}

function getAffectedResource(addon: AddonDefinition): string {
  if (addon.affectsLimitKey === 'max_photos_per_accommodation' && addon.limitIncrease) {
    return `+${addon.limitIncrease} fotos por alojamiento`;
  }
  if (addon.affectsLimitKey === 'max_accommodations' && addon.limitIncrease) {
    return `+${addon.limitIncrease} alojamientos`;
  }
  if (addon.affectsLimitKey === 'max_properties' && addon.limitIncrease) {
    return `+${addon.limitIncrease} propiedades`;
  }
  if (addon.grantsEntitlement) {
    return 'Destacado en búsquedas';
  }
  return '';
}

const title = 'Add-ons y Servicios Extra';
const description = 'Potenciá tu publicación con funcionalidades adicionales';
---

<Layout title={title} description={description}>
  <section class="py-16 bg-gray-50 min-h-screen">
    <div class="max-w-5xl mx-auto px-4">
      <!-- Page Header -->
      <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4">
          <div>
            <h1 class="text-4xl font-bold text-gray-900 mb-2">Add-ons y Servicios Extra</h1>
            <p class="text-gray-600">Potenciá tu publicación con funcionalidades adicionales</p>
          </div>
          <a
            href="/mi-cuenta/mis-addons"
            class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 font-semibold text-white transition-colors hover:bg-primary/90 self-start sm:self-auto"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Gestionar mis complementos
          </a>
        </div>
      </div>

      <!-- One-time Add-ons Section -->
      {oneTimeAddons.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Potenciadores (pago único)</h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {oneTimeAddons.map((addon) => (
              <div class="bg-white rounded-xl shadow-lg p-6 flex flex-col">
                <!-- Add-on Header -->
                <div class="mb-4">
                  <h3 class="text-xl font-bold text-gray-900 mb-2">{addon.name}</h3>
                  <p class="text-gray-600 text-sm mb-3">{addon.description}</p>

                  <!-- Badges -->
                  <div class="flex flex-wrap gap-2 mb-3">
                    <span class="px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-xs font-medium">
                      Pago único
                    </span>
                    {addon.durationDays && (
                      <span class="px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-xs font-medium">
                        {addon.durationDays} días
                      </span>
                    )}
                  </div>

                  <!-- What it affects -->
                  {getAffectedResource(addon) && (
                    <div class="mb-3">
                      <p class="text-sm text-gray-700">
                        <strong>Beneficio:</strong> {getAffectedResource(addon)}
                      </p>
                    </div>
                  )}

                  <!-- Target categories -->
                  <div class="mb-4">
                    <span class="text-xs text-gray-500">
                      Para: {getTargetCategoryLabel(addon.targetCategories)}
                    </span>
                  </div>
                </div>

                <!-- Price and CTA -->
                <div class="mt-auto">
                  <div class="mb-4">
                    <span class="text-3xl font-bold text-gray-900">
                      ${formatPrice(addon.priceArs)}
                    </span>
                  </div>
                  <AddonPurchaseButton
                    client:load
                    addonSlug={addon.slug}
                    price={addon.priceArs}
                  />
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Recurring Add-ons Section -->
      {recurringAddons.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Servicios recurrentes</h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {recurringAddons.map((addon) => (
              <div class="bg-white rounded-xl shadow-lg p-6 flex flex-col">
                <!-- Add-on Header -->
                <div class="mb-4">
                  <h3 class="text-xl font-bold text-gray-900 mb-2">{addon.name}</h3>
                  <p class="text-gray-600 text-sm mb-3">{addon.description}</p>

                  <!-- Badges -->
                  <div class="flex flex-wrap gap-2 mb-3">
                    <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-medium">
                      Mensual
                    </span>
                  </div>

                  <!-- What it affects -->
                  {getAffectedResource(addon) && (
                    <div class="mb-3">
                      <p class="text-sm text-gray-700">
                        <strong>Beneficio:</strong> {getAffectedResource(addon)}
                      </p>
                    </div>
                  )}

                  <!-- Target categories -->
                  <div class="mb-4">
                    <span class="text-xs text-gray-500">
                      Para: {getTargetCategoryLabel(addon.targetCategories)}
                    </span>
                  </div>
                </div>

                <!-- Price and CTA -->
                <div class="mt-auto">
                  <div class="mb-4">
                    <span class="text-3xl font-bold text-gray-900">
                      ${formatPrice(addon.priceArs)}
                    </span>
                    <span class="text-sm text-gray-600"> /mes</span>
                  </div>
                  <AddonPurchaseButton
                    client:load
                    addonSlug={addon.slug}
                    price={addon.priceArs}
                  />
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Help Section -->
      <div class="mb-8 bg-blue-50 border border-blue-200 rounded-xl p-6">
        <h3 class="font-semibold text-blue-900 mb-2">¿Necesitás ayuda?</h3>
        <p class="text-blue-800 mb-4">
          Si tenés alguna pregunta sobre los add-ons disponibles o cómo funcionan, nuestro equipo está disponible para ayudarte.
        </p>
        <a
          href="/contacto"
          class="inline-block px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        >
          Contactar soporte
        </a>
      </div>

      <!-- Back link -->
      <div class="text-center">
        <a
          href="/mi-cuenta/suscripcion"
          class="inline-flex items-center gap-2 text-primary hover:underline font-medium"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver a mi suscripción
        </a>
      </div>
    </div>
  </section>
</Layout>
