---
export const prerender = false; // SSR for authenticated content

import Layout from '@/layout/MainLayout.astro';
import { BillingHistory } from '@/components/dashboard';
import { BillingIsland, SubscriptionStatusCard, ActiveAddons, UsageMeters, CheckoutResultBanner } from '@/components/billing';
import { getAuth } from '@clerk/astro/server';

/**
 * Subscription Management Page
 * Consolidated dashboard with subscription, usage, add-ons, and billing
 * Requires authentication
 * Uses BillingIsland + SubscriptionStatusCard from qzpay-react integration
 */

// Check authentication
const { userId } = getAuth(Astro);

if (!userId) {
  return Astro.redirect('/auth/sign-in?redirect=/mi-cuenta/suscripcion');
}

const title = 'Mi Suscripción';
const description = 'Administrá tu plan y facturación';
---

<Layout title={title} description={description}>
  <section class="py-16 bg-gray-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Mi Suscripción</h1>
        <p class="text-gray-600">Administrá tu plan, uso de recursos, complementos y facturación</p>
      </div>

      <!-- Checkout Result Banner -->
      <CheckoutResultBanner client:load />

      <!-- Quick Navigation -->
      <div class="mb-8 flex flex-wrap gap-4">
        <a
          href="/mi-cuenta/addons"
          class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 font-medium text-gray-700 shadow-md transition-colors hover:bg-gray-50"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
          Comprar complementos
        </a>
        <a
          href="/mi-cuenta/mis-addons"
          class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 font-medium text-gray-700 shadow-md transition-colors hover:bg-gray-50"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          Gestionar mis complementos
        </a>
        <a
          href="/mi-cuenta/billing"
          class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 font-medium text-gray-700 shadow-md transition-colors hover:bg-gray-50"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          Panel de facturación completo
        </a>
      </div>

      <!-- Billing Island with QZPay Context -->
      <BillingIsland
        client:load
        apiUrl={import.meta.env.PUBLIC_API_URL || '/api/v1'}
        customerId={userId}
        livemode={import.meta.env.PROD}
      >
        <!-- Current Plan Card -->
        <SubscriptionStatusCard customerId={userId} />

        <!-- Usage Meters (uses useLimits from qzpay-react) -->
        <UsageMeters />
      </BillingIsland>

      <!-- Dashboard Widgets (React Islands) -->
      <div class="space-y-8 mb-8">
        <!-- Active Add-ons (uses direct API fetch) -->
        <ActiveAddons client:load apiUrl={import.meta.env.PUBLIC_API_URL || '/api/v1'} />

        <!-- Billing History -->
        <BillingHistory client:load />
      </div>

      <!-- Payment Method Card -->
      <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Método de pago</h2>

        <div class="text-center py-8">
          <p class="text-gray-600 mb-4">
            Los pagos se procesan a través de Mercado Pago
          </p>
          <p class="text-sm text-gray-500">
            La información de tu método de pago se gestiona de forma segura en Mercado Pago
          </p>
        </div>
      </div>

      <!-- Help Section -->
      <div class="mt-8 bg-blue-50 border border-blue-200 rounded-xl p-6">
        <h3 class="font-semibold text-blue-900 mb-2">¿Necesitás ayuda?</h3>
        <p class="text-blue-800 mb-4">
          Si tenés alguna pregunta sobre tu suscripción o facturación, nuestro equipo está disponible para ayudarte.
        </p>
        <a
          href="/contacto"
          class="inline-block px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        >
          Contactar soporte
        </a>
      </div>
    </div>
  </section>
</Layout>
