---
export const prerender = false;

import MainLayout from '@/layout/MainLayout.astro';
import { getLangFromUrl, useTranslations } from '@/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

/**
 * Mi Cuenta - Main account page
 * Shows user profile info, account links, and settings.
 * Requires authentication via Better Auth session.
 */

interface SessionUser {
    id: string;
    name?: string;
    email?: string;
    image?: string;
    createdAt?: string;
}

let user: SessionUser | null = null;
try {
    const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';
    const cookieHeader = Astro.request.headers.get('cookie') || '';
    const response = await fetch(`${apiUrl}/api/auth/get-session`, {
        headers: { cookie: cookieHeader },
    });
    if (response.ok) {
        const data = await response.json();
        user = data?.user || null;
    }
} catch {
    // Session check failed
}

if (!user) {
    return Astro.redirect('/auth/signin/?redirect=/mi-cuenta/');
}

const displayName = user.name || user.email?.split('@')[0] || 'Usuario';
const initials = displayName
    .split(' ')
    .map((p: string) => p[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();

const title = `${t('nav.myAccount')} - Hospeda`;
const description = 'Tu cuenta personal en Hospeda.';

const sidebarLinks = [
    { label: 'Informacion Personal', href: '#profile', icon: 'user', active: true },
    { label: 'Suscripcion', href: '/mi-cuenta/suscripcion/', icon: 'credit-card', active: false },
    { label: 'Facturacion', href: '/mi-cuenta/billing/', icon: 'receipt', active: false },
    { label: 'Add-ons', href: '/mi-cuenta/mis-addons/', icon: 'puzzle', active: false },
    { label: 'Configuracion', href: '#settings', icon: 'settings', active: false },
];
---

<MainLayout title={title} description={description}>
    <div class='min-h-screen bg-white dark:bg-gray-900 transition-colors duration-200'>
        <!-- Header -->
        <section class='bg-gray-50 dark:bg-gray-800 py-8 border-b border-gray-200 dark:border-gray-700'>
            <div class='container mx-auto px-4'>
                <div class='flex items-center space-x-4'>
                    <div class='w-16 h-16 bg-cyan-600 rounded-full flex items-center justify-center text-white text-xl font-bold'>
                        {user.image ? (
                            <img src={user.image} alt={displayName} class='w-16 h-16 rounded-full object-cover' />
                        ) : (
                            initials
                        )}
                    </div>
                    <div>
                        <h1 class='text-3xl font-bold text-gray-900 dark:text-white'>{displayName}</h1>
                        <p class='text-gray-600 dark:text-gray-400'>{user.email}</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Content -->
        <section class='py-8'>
            <div class='container mx-auto px-4'>
                <div class='grid grid-cols-1 lg:grid-cols-4 gap-8'>
                    <!-- Sidebar Navigation -->
                    <div class='lg:col-span-1'>
                        <nav class='bg-white dark:bg-gray-800 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 sticky top-20'>
                            <div class='p-6'>
                                <h3 class='text-lg font-semibold text-gray-900 dark:text-white mb-4'>{t('nav.myAccount')}</h3>
                                <ul class='space-y-2'>
                                    {sidebarLinks.map((link) => (
                                        <li>
                                            <a
                                                href={link.href}
                                                class={
                                                    link.active
                                                        ? 'flex items-center px-3 py-2 text-cyan-600 dark:text-cyan-400 bg-cyan-50 dark:bg-cyan-900/20 rounded-lg font-medium'
                                                        : 'flex items-center px-3 py-2 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg'
                                                }
                                            >
                                                {link.label}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </nav>
                    </div>

                    <!-- Main Content -->
                    <div class='lg:col-span-3'>
                        <!-- Profile Information -->
                        <div
                            id='profile'
                            class='bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 border border-gray-200 dark:border-gray-700 mb-8'
                        >
                            <h2 class='text-2xl font-bold text-gray-900 dark:text-white mb-6'>Informacion Personal</h2>
                            <div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
                                <div>
                                    <label class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2'>Nombre</label>
                                    <p class='text-gray-900 dark:text-white'>{user.name || 'No especificado'}</p>
                                </div>
                                <div>
                                    <label class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2'>Email</label>
                                    <p class='text-gray-900 dark:text-white'>{user.email}</p>
                                </div>
                                {user.createdAt && (
                                    <div>
                                        <label class='block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2'>Miembro desde</label>
                                        <p class='text-gray-900 dark:text-white'>
                                            {new Date(user.createdAt).toLocaleDateString('es-ES', {
                                                day: 'numeric',
                                                month: 'long',
                                                year: 'numeric',
                                            })}
                                        </p>
                                    </div>
                                )}
                            </div>
                        </div>

                        <!-- Account Settings -->
                        <div
                            id='settings'
                            class='bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 border border-gray-200 dark:border-gray-700'
                        >
                            <h2 class='text-2xl font-bold text-gray-900 dark:text-white mb-6'>Configuracion</h2>
                            <div class='space-y-6'>
                                <div class='flex items-center justify-between py-4 border-b border-gray-200 dark:border-gray-700'>
                                    <div>
                                        <h3 class='font-medium text-gray-900 dark:text-white'>Notificaciones por Email</h3>
                                        <p class='text-gray-600 dark:text-gray-400 text-sm'>Recibe actualizaciones sobre tus reservas</p>
                                    </div>
                                    <span class='text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded'>Proximamente</span>
                                </div>
                                <div class='flex items-center justify-between py-4 border-b border-gray-200 dark:border-gray-700'>
                                    <div>
                                        <h3 class='font-medium text-gray-900 dark:text-white'>Ofertas y Promociones</h3>
                                        <p class='text-gray-600 dark:text-gray-400 text-sm'>Recibe ofertas especiales y descuentos</p>
                                    </div>
                                    <span class='text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 px-2 py-1 rounded'>Proximamente</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</MainLayout>
