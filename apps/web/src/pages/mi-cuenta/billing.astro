---
export const prerender = false; // SSR for authenticated content

import Layout from '@/layout/MainLayout.astro';
import { ActiveAddons } from '@/components/dashboard/ActiveAddons';
import { UsageMeters } from '@/components/dashboard/UsageMeters';
import { BillingHistory } from '@/components/dashboard/BillingHistory';

/**
 * Billing Dashboard Page
 * Consolidated view of user's billing information
 * Requires authentication
 */

// Check authentication (Clerk injects auth into Astro.locals via middleware)
const { userId } = Astro.locals.auth();

if (!userId) {
	return Astro.redirect('/auth/sign-in?redirect=/mi-cuenta/billing');
}

const title = 'Panel de Facturación';
const description = 'Gestión completa de tu facturación y uso de recursos';
---

<Layout title={title} description={description}>
	<section class="min-h-screen bg-gray-50 py-16">
		<div class="mx-auto max-w-7xl px-4">
			<!-- Page Header -->
			<div class="mb-8">
				<h1 class="mb-2 font-bold text-4xl text-gray-900">Panel de Facturación</h1>
				<p class="text-gray-600">
					Administrá tus complementos, monitoreá el uso de recursos y revisá tu historial de pagos
				</p>
			</div>

			<!-- Breadcrumb -->
			<nav class="mb-8" aria-label="Breadcrumb">
				<ol class="flex items-center gap-2 text-sm">
					<li>
						<a href="/mi-cuenta" class="text-primary hover:underline">Mi Cuenta</a>
					</li>
					<li class="text-gray-400">/</li>
					<li class="text-gray-600">Facturación</li>
				</ol>
			</nav>

			<!-- Components Grid -->
			<div class="space-y-8">
				<!-- Usage Meters -->
				<UsageMeters client:load />

				<!-- Active Add-ons -->
				<ActiveAddons client:load />

				<!-- Billing History -->
				<BillingHistory client:load />
			</div>

			<!-- Help Section -->
			<div class="mt-8 rounded-xl border border-blue-200 bg-blue-50 p-6">
				<div class="flex items-start gap-4">
					<svg
						class="mt-1 h-6 w-6 flex-shrink-0 text-blue-600"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
					<div class="flex-1">
						<h3 class="mb-2 font-semibold text-blue-900">¿Necesitás ayuda con tu facturación?</h3>
						<p class="mb-4 text-blue-800">
							Nuestro equipo está disponible para ayudarte con cualquier consulta sobre planes,
							facturación o uso de recursos.
						</p>
						<div class="flex flex-wrap gap-3">
							<a
								href="/contacto"
								class="inline-block rounded-lg bg-blue-600 px-6 py-2 font-semibold text-white transition-colors hover:bg-blue-700"
							>
								Contactar soporte
							</a>
							<a
								href="/precios/propietarios"
								class="inline-block rounded-lg border-2 border-blue-600 bg-white px-6 py-2 font-semibold text-blue-600 transition-colors hover:bg-blue-50"
							>
								Ver planes
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
