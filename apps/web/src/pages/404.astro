---
/**
 * 404 Page Not Found error page.
 * Server-rendered to detect locale from URL path or Accept-Language header.
 * Falls back to Spanish (default locale).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/seo/SEOHead.astro';
import { isValidLocale, parseAcceptLanguage, t } from '../lib/i18n';
import type { SupportedLocale } from '../lib/i18n';

/**
 * Detect locale from URL path first segment, then Accept-Language header.
 */
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const firstSegment = pathSegments[0] ?? '';
let locale: SupportedLocale = 'es';

if (isValidLocale(firstSegment)) {
	locale = firstSegment;
} else {
	locale = parseAcceptLanguage(Astro.request.headers.get('accept-language'));
}

const tError = (key: string) => t({ locale, namespace: 'error', key });

const title = tError('404.title');
const description = tError('404.description');
const heading = tError('404.heading');
const message = tError('404.message');
const goHomeLabel = tError('404.goHome');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<BaseLayout title={title} description={description} noindex={true} locale={locale}>
	<SEOHead
		slot="head"
		title={title}
		description={description}
		canonical={canonicalUrl}
		noindex={true}
		locale={locale}
		type="website"
	/>

	<div class="flex min-h-screen items-center justify-center bg-gradient-to-b from-bg to-bg-alt px-4 py-16">
		<div class="w-full max-w-2xl text-center">
			<!-- Decorative 404 text -->
			<div class="mb-8">
				<span class="text-9xl font-bold text-primary opacity-20" aria-hidden="true">404</span>
			</div>

			<!-- SVG illustration (river/nature themed) -->
			<div class="mb-8 flex justify-center" aria-hidden="true">
				<svg
					width="200"
					height="120"
					viewBox="0 0 200 120"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					class="text-primary opacity-30"
				>
					<!-- Simple river illustration -->
					<path
						d="M0 60 Q 50 40, 100 60 T 200 60 L 200 120 L 0 120 Z"
						fill="currentColor"
						opacity="0.3"
					/>
					<path
						d="M0 70 Q 50 50, 100 70 T 200 70 L 200 120 L 0 120 Z"
						fill="currentColor"
						opacity="0.2"
					/>
					<path
						d="M0 80 Q 50 60, 100 80 T 200 80 L 200 120 L 0 120 Z"
						fill="currentColor"
						opacity="0.1"
					/>

					<!-- Simple trees -->
					<circle cx="30" cy="40" r="12" fill="currentColor" opacity="0.4" />
					<rect x="26" y="45" width="8" height="20" fill="currentColor" opacity="0.3" />

					<circle cx="170" cy="35" r="15" fill="currentColor" opacity="0.4" />
					<rect x="165" y="42" width="10" height="25" fill="currentColor" opacity="0.3" />
				</svg>
			</div>

			<!-- Heading -->
			<h1 class="mb-4 text-4xl font-bold text-text">{heading}</h1>

			<!-- Message -->
			<p class="mx-auto mb-8 max-w-md text-lg text-text-secondary">
				{message}
			</p>

			<!-- Home link -->
			<a
				href={`/${locale}/`}
				class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
			>
				{goHomeLabel}
			</a>
		</div>
	</div>
</BaseLayout>
