---
/**
 * 404 Page Not Found error page.
 *
 * Server-rendered to detect locale from URL path or Accept-Language header.
 * Falls back to Spanish (default locale).
 *
 * Uses `prerender = false` so Astro can access request headers at runtime.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/seo/SEOHead.astro';
import { AlertTriangleIcon, HomeIcon } from '@repo/icons';
import { DEFAULT_LOCALE, isValidLocale, parseAcceptLanguage, createT } from '../lib/i18n';
import type { SupportedLocale } from '../lib/i18n';
import { buildUrl } from '../lib/urls';

export const prerender = false;

/**
 * Detect locale from URL path first segment, then Accept-Language header.
 */
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const firstSegment = pathSegments[0] ?? '';

let locale: SupportedLocale = DEFAULT_LOCALE;
if (isValidLocale(firstSegment)) {
    locale = firstSegment;
} else {
    locale = parseAcceptLanguage(Astro.request.headers.get('accept-language'));
}

const t = createT(locale);

const title = t('error.404.title', 'Pagina no encontrada');
const description = t('error.404.description', 'La pagina que buscas no existe o fue movida.');
const heading = t('error.404.heading', 'Pagina no encontrada');
const message = t('error.404.message', 'Lo sentimos, no pudimos encontrar la pagina que buscas. Puede haber sido movida o eliminada.');
const goHomeLabel = t('error.404.goHome', 'Volver al inicio');

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const homeUrl = buildUrl({ locale });
---

<BaseLayout title={title} description={description} locale={locale}>
    <SEOHead
        slot="head"
        title={title}
        description={description}
        canonical={canonicalUrl}
        noindex={true}
        locale={locale}
        type="website"
    />

    <div class="flex min-h-[80vh] items-center justify-center bg-background px-4 py-16">
        <div class="w-full max-w-lg text-center">

            <!-- Decorative illustration: winding river path leading to a question mark, nature/Litoral theme -->
            <div class="mx-auto mb-6 w-40 h-40" aria-hidden="true">
                <svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                    <!-- Sky background wash -->
                    <ellipse cx="80" cy="55" rx="68" ry="42" class="fill-primary/5"/>

                    <!-- River: winding path from bottom-left to center, then disappearing -->
                    <path d="M10 148 Q30 138 45 128 Q60 118 55 108 Q50 98 65 90 Q78 83 80 72"
                          class="stroke-primary/30" stroke-width="14" stroke-linecap="round" fill="none"/>
                    <!-- River highlight (lighter inner channel) -->
                    <path d="M10 148 Q30 138 45 128 Q60 118 55 108 Q50 98 65 90 Q78 83 80 72"
                          class="stroke-primary/15" stroke-width="6" stroke-linecap="round" fill="none"/>

                    <!-- Riverbank vegetation left: tall totora reeds -->
                    <line x1="24" y1="140" x2="20" y2="115" class="stroke-secondary/60" stroke-width="2.5" stroke-linecap="round"/>
                    <ellipse cx="20" cy="113" rx="3" ry="6" class="fill-secondary/50"/>
                    <line x1="32" y1="136" x2="30" y2="116" class="stroke-secondary/50" stroke-width="2" stroke-linecap="round"/>
                    <ellipse cx="30" cy="114" rx="2.5" ry="5" class="fill-secondary/40"/>

                    <!-- Riverbank vegetation right: low shrubs -->
                    <path d="M96 128 Q102 118 110 122 Q116 114 122 118" class="stroke-secondary/40" stroke-width="2.5" stroke-linecap="round" fill="none"/>
                    <circle cx="108" cy="120" r="5" class="fill-secondary/20 stroke-secondary/40" stroke-width="1.5"/>

                    <!-- Winding dotted trail (the "path" the traveler lost) -->
                    <path d="M80 72 Q85 62 78 52 Q72 44 80 36"
                          class="stroke-accent/50" stroke-width="2" stroke-linecap="round" stroke-dasharray="4 5" fill="none"/>

                    <!-- Map pin at trail end with question mark -->
                    <path d="M80 14 C74 14 68 20 68 27 C68 36 80 50 80 50 C80 50 92 36 92 27 C92 20 86 14 80 14Z"
                          class="fill-primary/15 stroke-primary" stroke-width="2.5"/>
                    <text x="80" y="31" text-anchor="middle" dominant-baseline="middle" font-size="14" font-weight="700" class="fill-primary">?</text>

                    <!-- Small bird silhouettes (freedom / nature) -->
                    <path d="M42 72 Q45 69 48 72" class="stroke-muted-foreground/40" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                    <path d="M52 65 Q55 62 58 65" class="stroke-muted-foreground/30" stroke-width="1.5" stroke-linecap="round" fill="none"/>

                    <!-- Horizon line -->
                    <line x1="16" y1="100" x2="144" y2="100" class="stroke-border/40" stroke-width="1" stroke-dasharray="3 6"/>
                </svg>
            </div>

            <!-- Decorative error code -->
            <div class="mb-6" aria-hidden="true">
                <span class="text-[8rem] font-bold leading-none text-primary opacity-10 select-none">
                    404
                </span>
            </div>

            <!-- Error icon -->
            <div class="mb-6 flex justify-center" aria-hidden="true">
                <AlertTriangleIcon
                    size={64}
                    weight="duotone"
                    className="text-accent"
                />
            </div>

            <!-- Heading -->
            <h1 class="mb-4 text-3xl font-bold text-foreground">
                {heading}
            </h1>

            <!-- Message -->
            <p class="mx-auto mb-8 max-w-md text-base text-muted-foreground">
                {message}
            </p>

            <!-- Home link -->
            <a
                href={homeUrl}
                class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-base font-semibold text-primary-foreground transition-opacity hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
            >
                <HomeIcon size={20} weight="regular" aria-hidden="true" />
                {goHomeLabel}
            </a>
        </div>
    </div>
</BaseLayout>
