---
/**
 * @file 404.astro
 * @description Custom 404 error page with friendly design and navigation actions.
 * Rendered by middleware rewrite when a page is not found.
 */

export const prerender = false;

import ErrorLayout from '@/layouts/ErrorLayout.astro';
import GradientButton from '@/components/shared/ui/GradientButton.astro';
import { SearchIcon, ChatIcon } from '@repo/icons';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

const locale = (Astro.locals?.locale ?? 'es') as SupportedLocale;
const { t } = createTranslations(locale);
const homeUrl = buildUrl({ locale, path: '/' });
const searchUrl = buildUrl({ locale, path: 'busqueda' });
const feedbackUrl = buildUrl({ locale, path: 'feedback' });

const feedbackParams = new URLSearchParams({
	type: 'bug-ui-ux',
	source: 'error-404',
	url: Astro.url.href,
	title: 'Página no encontrada (404)',
	description: `URL: ${Astro.url.pathname}\nEsta página no existe o el enlace está roto.`,
});
const feedbackWithParams = `${feedbackUrl}?${feedbackParams.toString()}`;
---

<ErrorLayout locale={locale} title={t('error.404.title')} description={t('error.404.description')} noindex={true}>
	<div slot="decoratives" class="error-deco error-deco--404" aria-hidden="true">
		<div class="error-deco__blob"></div>
		<svg
			class="error-deco__trail"
			viewBox="0 0 200 100"
			preserveAspectRatio="none"
			aria-hidden="true"
		>
			<path
				d="M 10 80 Q 60 10, 110 50 T 190 30"
				stroke="currentColor"
				stroke-width="2.5"
				stroke-dasharray="4 8"
				stroke-linecap="round"
				fill="none"
			/>
		</svg>
		<span class="error-deco__dot error-deco__dot--1"></span>
		<span class="error-deco__dot error-deco__dot--2"></span>
		<span class="error-deco__dot error-deco__dot--3"></span>
	</div>

	<!-- Illustrated icon -->
	<div class="err500-illustration" aria-hidden="true">
		<svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
			<circle cx="60" cy="60" r="54" stroke="var(--primary, #3b82f6)" stroke-width="1.5" opacity="0.12" />
			<circle cx="60" cy="60" r="40" stroke="var(--primary, #3b82f6)" stroke-width="1.5" opacity="0.08" />
			<!-- Magnifying glass -->
			<circle cx="54" cy="54" r="16" stroke="var(--primary, #3b82f6)" stroke-width="2.5" fill="oklch(from var(--primary, #3b82f6) l c h / 0.06)" />
			<line x1="65" y1="65" x2="78" y2="78" stroke="var(--primary, #3b82f6)" stroke-width="2.5" stroke-linecap="round" />
			<!-- Question mark inside lens -->
			<text x="54" y="59" text-anchor="middle" font-family="sans-serif" font-size="16" font-weight="700" fill="var(--primary, #3b82f6)" opacity="0.6">?</text>
			<!-- Small decorative dots -->
			<circle cx="60" cy="26" r="3" fill="var(--primary, #3b82f6)" opacity="0.15" />
			<circle cx="60" cy="94" r="3" fill="var(--primary, #3b82f6)" opacity="0.15" />
			<circle cx="26" cy="60" r="3" fill="var(--primary, #3b82f6)" opacity="0.15" />
			<circle cx="94" cy="60" r="3" fill="var(--primary, #3b82f6)" opacity="0.15" />
		</svg>
	</div>

	<div class="err500-code" aria-hidden="true">404</div>

	<h1 class="err500-title">{t('error.404.heading')}</h1>
	<p class="err500-message">{t('error.404.message')}</p>

	<div class="err500-actions">
		<GradientButton href={searchUrl} label="Buscar" variant="primary" shape="rounded">
			<SearchIcon slot="leading" size={18} />
		</GradientButton>
		<GradientButton href={feedbackWithParams} label="Reportar enlace roto" variant="outline-primary" shape="rounded">
			<ChatIcon slot="leading" size={18} />
		</GradientButton>
	</div>

	<a href={homeUrl} class="err500-home-link">
		{t('error.404.goHome')}
	</a>
</ErrorLayout>

<style is:global>
	.error-deco {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.error-deco__blob {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: clamp(360px, 60vw, 720px);
		height: clamp(360px, 60vw, 720px);
		border-radius: 50%;
		filter: blur(4px);
	}

	.error-deco--404 .error-deco__blob {
		background: radial-gradient(
			circle at 50% 50%,
			oklch(from var(--brand-primary) l c h / 0.16),
			oklch(from var(--brand-primary) l c h / 0.05) 55%,
			transparent 75%
		);
	}

	.error-deco__trail {
		position: absolute;
		width: clamp(140px, 18vw, 240px);
		height: clamp(60px, 8vw, 110px);
		opacity: 0.4;
	}

	.error-deco--404 .error-deco__trail {
		top: 14%;
		right: 8%;
		color: var(--brand-primary);
		transform: rotate(8deg);
	}

	.error-deco__dot {
		position: absolute;
		border-radius: 50%;
	}

	.error-deco--404 .error-deco__dot--1 {
		top: 22%;
		left: 10%;
		width: 12px;
		height: 12px;
		background-color: oklch(from var(--brand-primary) l c h / 0.28);
	}
	.error-deco--404 .error-deco__dot--2 {
		bottom: 22%;
		left: 16%;
		width: 9px;
		height: 9px;
		background-color: oklch(from var(--brand-accent) l c h / 0.3);
	}
	.error-deco--404 .error-deco__dot--3 {
		bottom: 30%;
		right: 14%;
		width: 14px;
		height: 14px;
		background-color: oklch(from var(--brand-primary) l c h / 0.2);
	}

	@media (max-width: 700px) {
		.error-deco__trail {
			display: none;
		}
	}
</style>
