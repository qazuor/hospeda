---
export const prerender = true;

import Layout from '@/layout/MainLayout.astro';
import { PricingSection } from '@/components/pricing/PricingSection';
import { PLANS_BY_CATEGORY } from '@repo/billing';
import type { PlanDefinition } from '@repo/billing';

/**
 * Tourist Pricing Page
 * Displays pricing plans for tourists
 */

const touristPlans = PLANS_BY_CATEGORY.tourist;

// Define human-readable feature names for tourist plans
const entitlementNames: Record<string, string> = {
  'save-favorites': 'Guardar favoritos',
  'write-reviews': 'Escribir reseñas',
  'read-reviews': 'Leer reseñas',
  'ad-free': 'Sin publicidad',
  'price-alerts': 'Alertas de precio',
  'early-access-events': 'Acceso anticipado a eventos',
  'exclusive-deals': 'Ofertas exclusivas',
  'vip-support': 'Soporte VIP',
  'concierge-service': 'Servicio de conserje',
  'airport-transfers': 'Transfers aeropuerto',
  'vip-promotions-access': 'Promociones VIP'
};

// Define features for each plan
function getTouristPlanFeatures(plan: PlanDefinition) {
  const features: Array<{ name: string; included: boolean }> = [];

  // Add entitlements
  plan.entitlements.forEach(entitlement => {
    const name = entitlementNames[entitlement] || entitlement;
    features.push({ name, included: true });
  });

  // Add limits
  plan.limits.forEach(limit => {
    const value = limit.value === -1 ? 'Ilimitados' : `Hasta ${limit.value}`;
    features.push({ name: `${limit.name}: ${value}`, included: true });
  });

  return features;
}

const badges = {
  'tourist-free': undefined,
  'tourist-plus': 'Recomendado',
  'tourist-vip': undefined
};

const title = 'Planes para Turistas';
const description = 'Descubrí el Litoral Argentino con beneficios exclusivos. Elegí el plan que se adapte a tu estilo de viaje.';
---

<Layout title={title} description={description}>
  <section class="py-16 bg-gradient-to-b from-blue-50 to-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          Planes para Turistas
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Mejorá tu experiencia de viaje con beneficios exclusivos.
          <br />
          <strong>Comenzá gratis y pasá a Plus o VIP cuando quieras.</strong>
        </p>
      </div>

      <PricingSection
        client:load
        plans={touristPlans}
        highlightedPlanSlug="tourist-plus"
        badges={badges}
        showToggle={true}
        getFeatures={getTouristPlanFeatures}
      />

      <!-- Benefits Section -->
      <div class="mt-20 grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl shadow-lg p-8 text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Sin publicidad</h3>
          <p class="text-gray-600">
            Navegá sin interrupciones y disfrutá de una experiencia premium sin anuncios.
          </p>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Ofertas exclusivas</h3>
          <p class="text-gray-600">
            Accedé a descuentos y promociones especiales solo para miembros Plus y VIP.
          </p>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 text-center">
          <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Alertas de precio</h3>
          <p class="text-gray-600">
            Recibí notificaciones cuando bajen los precios de tus alojamientos favoritos.
          </p>
        </div>
      </div>

      <!-- FAQ Section -->
      <div class="mt-20 max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">Preguntas Frecuentes</h2>

        <div class="space-y-6">
          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿El plan gratuito tiene limitaciones?
            </summary>
            <p class="mt-4 text-gray-600">
              El plan gratuito incluye todas las funcionalidades básicas: podés guardar hasta 3 favoritos,
              escribir reseñas y explorar todos los alojamientos. Para funciones premium como alertas de
              precio y sin publicidad, necesitás Plus o VIP.
            </p>
          </details>

          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿Qué incluye el servicio de conserje VIP?
            </summary>
            <p class="mt-4 text-gray-600">
              El servicio de conserje te ayuda a planificar tu viaje completo: desde reservas de restaurantes
              hasta actividades y excursiones. Nuestro equipo VIP está disponible para asistirte con cualquier
              necesidad durante tu estadía.
            </p>
          </details>

          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿Puedo cambiar entre planes?
            </summary>
            <p class="mt-4 text-gray-600">
              Sí, podés mejorar o reducir tu plan en cualquier momento. Al mejorar, el cambio es inmediato.
              Al reducir, el cambio se aplicará al final del período de facturación actual.
            </p>
          </details>

          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿Los precios incluyen impuestos?
            </summary>
            <p class="mt-4 text-gray-600">
              Los precios mostrados son en pesos argentinos (ARS) e incluyen IVA. No hay cargos ocultos
              ni tarifas adicionales.
            </p>
          </details>

          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿Cuáles son las promociones VIP?
            </summary>
            <p class="mt-4 text-gray-600">
              Los propietarios de alojamientos pueden crear promociones exclusivas solo para miembros VIP,
              como descuentos especiales, upgrades gratuitos o servicios adicionales sin cargo.
            </p>
          </details>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="mt-20 text-center bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-12 text-white">
        <h2 class="text-3xl font-bold mb-4">¿Listo para explorar el Litoral?</h2>
        <p class="text-xl mb-8 text-gray-100">
          Creá tu cuenta gratis y comenzá a descubrir alojamientos únicos.
        </p>
        <a
          href="/auth/sign-up?plan=tourist-free"
          class="inline-block bg-white text-blue-600 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-gray-100 transition-colors"
        >
          Crear cuenta gratis
        </a>
      </div>
    </div>
  </section>
</Layout>
