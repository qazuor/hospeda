---
export const prerender = true;

import Layout from '@/layout/MainLayout.astro';
import { BillingIsland, CheckoutResultBanner } from '@/components/billing';
import { PricingSection } from '@/components/pricing/PricingSection';
import { PLANS_BY_CATEGORY } from '@repo/billing';
import type { PlanDefinition, EntitlementKey } from '@repo/billing';
import { getAuth } from '@clerk/astro/server';

const { userId } = getAuth(Astro);
const isAuthenticated = !!userId;

/**
 * Owner Pricing Page
 * Displays pricing plans for accommodation owners
 */

const ownerPlans = PLANS_BY_CATEGORY.owner;

// Define human-readable feature names for owner plans
const entitlementNames: Record<string, string> = {
  'publish-accommodations': 'Publicar alojamientos',
  'edit-accommodation-info': 'Editar información',
  'view-basic-stats': 'Estadísticas básicas',
  'view-advanced-stats': 'Estadísticas avanzadas',
  'respond-reviews': 'Responder reseñas',
  'priority-support': 'Soporte prioritario',
  'featured-listing': 'Listado destacado',
  'custom-branding': 'Marca personalizada',
  'api-access': 'Acceso a API',
  'dedicated-manager': 'Gestor dedicado',
  'create-promotions': 'Crear promociones',
  'social-media-integration': 'Integración redes sociales'
};

// Define features for each plan
function getOwnerPlanFeatures(plan: PlanDefinition) {
  const features: Array<{ name: string; included: boolean }> = [];

  // Add entitlements
  plan.entitlements.forEach(entitlement => {
    const name = entitlementNames[entitlement] || entitlement;
    features.push({ name, included: true });
  });

  // Add limits
  plan.limits.forEach(limit => {
    const value = limit.value === -1 ? 'Ilimitado' : `${limit.value}`;
    features.push({ name: `${limit.name}: ${value}`, included: true });
  });

  return features;
}

const badges = {
  'owner-basico': undefined,
  'owner-pro': 'Más Popular',
  'owner-premium': undefined
};

const title = 'Planes para Propietarios';
const description = 'Elegí el plan ideal para tu alojamiento. Comenzá con 14 días de prueba gratis.';
---

<Layout title={title} description={description}>
  <section class="py-16 bg-gradient-to-b from-primary/5 to-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          Planes para Propietarios
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Publicá tu alojamiento en Hospeda y empezá a recibir reservas.
          <br />
          <strong>Todos los planes incluyen 14 días de prueba gratis.</strong>
        </p>
      </div>

      <!-- Checkout Result Banner -->
      <CheckoutResultBanner client:load />

      <BillingIsland
        client:load
        apiUrl={import.meta.env.PUBLIC_API_URL || '/api/v1'}
        livemode={import.meta.env.PROD}
      >
        <PricingSection
          plans={ownerPlans}
          highlightedPlanSlug="owner-pro"
          badges={badges}
          showToggle={true}
          getFeatures={getOwnerPlanFeatures}
          isAuthenticated={isAuthenticated}
          successUrl="/mi-cuenta/suscripcion?checkout=success"
          cancelUrl="/precios/propietarios?checkout=cancelled"
        />
      </BillingIsland>

      <!-- FAQ Section -->
      <div class="mt-20 max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">Preguntas Frecuentes</h2>

        <div class="space-y-6">
          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿Qué incluye la prueba gratis?
            </summary>
            <p class="mt-4 text-gray-600">
              Durante los 14 días de prueba gratis tenés acceso completo a todas las funcionalidades
              del plan que elijas. No se requiere tarjeta de crédito para comenzar.
            </p>
          </details>

          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿Puedo cambiar de plan después?
            </summary>
            <p class="mt-4 text-gray-600">
              Sí, podés cambiar de plan en cualquier momento desde tu cuenta. Los cambios se aplican
              inmediatamente y se ajusta el costo proporcionalmente.
            </p>
          </details>

          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿Qué métodos de pago aceptan?
            </summary>
            <p class="mt-4 text-gray-600">
              Aceptamos pagos con tarjeta de crédito/débito, transferencia bancaria y Mercado Pago.
              Todas las transacciones son seguras y encriptadas.
            </p>
          </details>

          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿Cómo funciona la facturación anual?
            </summary>
            <p class="mt-4 text-gray-600">
              Con la facturación anual pagás por adelantado 10 meses y obtenés 2 meses gratis.
              Es el equivalente a pagar mensualmente pero con un 16.67% de descuento.
            </p>
          </details>

          <details class="bg-white rounded-lg shadow-md p-6">
            <summary class="font-semibold text-lg cursor-pointer hover:text-primary">
              ¿Puedo cancelar mi suscripción?
            </summary>
            <p class="mt-4 text-gray-600">
              Sí, podés cancelar tu suscripción en cualquier momento. Tu plan seguirá activo hasta
              el final del período de facturación actual.
            </p>
          </details>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="mt-20 text-center bg-primary rounded-2xl p-12 text-white">
        <h2 class="text-3xl font-bold mb-4">¿Listo para comenzar?</h2>
        <p class="text-xl mb-8 text-gray-100">
          Empezá hoy con 14 días de prueba gratis. Sin tarjeta de crédito requerida.
        </p>
        <a
          href="/auth/sign-up?plan=owner-basico"
          class="inline-block bg-white text-primary px-8 py-4 rounded-lg font-semibold text-lg hover:bg-gray-100 transition-colors"
        >
          Comenzar prueba gratis
        </a>
      </div>
    </div>
  </section>
</Layout>
