---
export const prerender = true;

import { SearchResults } from '@/components/search/SearchResults';
import MainLayout from '@/layout/MainLayout.astro';
import { getLangFromUrl, useTranslations } from '@/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = t('search.title');
const description = t('search.description');

const query = Astro.url.searchParams.get('q') || '';
const location = Astro.url.searchParams.get('location') || '';

const apiBaseUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';
---

<MainLayout title={title} description={description}>
    <div class='min-h-screen bg-white dark:bg-gray-900 transition-colors duration-200'>
        <!-- Hero Section -->
        <section
            class='bg-gradient-to-r from-orange-600 to-red-600 dark:from-orange-700 dark:to-red-700 text-white py-16'
        >
            <div class='container mx-auto px-4 text-center'>
                <h1 class='text-4xl md:text-5xl font-bold mb-4'>{t('search.heading')}</h1>
                <p class='text-xl md:text-2xl text-orange-100 max-w-3xl mx-auto'>
                    {t('search.subheading')}
                </p>
            </div>
        </section>

        <SearchResults
            client:load
            initialQuery={query}
            initialLocation={location}
            apiBaseUrl={apiBaseUrl}
        />
    </div>
</MainLayout>
