---
export const prerender = true;

/**
 * Root page - redirects to locale-specific homepage based on Accept-Language header.
 * Implements automatic language detection for internationalized routing.
 */
import { parseAcceptLanguage } from '../lib/i18n';

const acceptLanguage = Astro.request.headers.get('accept-language');
const locale = parseAcceptLanguage(acceptLanguage);

return Astro.redirect(`/${locale}/`);
---
