---
import { MenuIcon } from '@repo/icons';
import { useTranslations } from '@/utils/i18n';
import ThemeToggle from '@/layout/ThemeToggle.astro';
import {
    getHomeUrl,
    getAccommodationsIndexUrl,
    getDestinationsIndexUrl,
    getEventsIndexUrl,
    getBlogIndexUrl,
    getSearchUrl,
    getContactUrl,
    getPricingUrl,
} from '@/utils';
import { normalizeTrailingSlash } from '@reunmedia/astro-normalize-trailing-slash';
import { UserNav } from '@/components/auth/UserNav';

interface Props {
    lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;

/**
 * Checks if a nav link is the active page.
 * Uses exact match for home, startsWith for sections.
 */
const isActive = (href: string): boolean => {
    const normalizedHref = normalizeTrailingSlash(href);
    const normalizedPath = normalizeTrailingSlash(currentPath);
    if (normalizedHref === '/' || normalizedHref === '') {
        return normalizedPath === '/' || normalizedPath === '';
    }
    return normalizedPath.startsWith(normalizedHref);
};

const navLinkClass = (href: string): string =>
    isActive(href) ? 'nav-link nav-link-active' : 'nav-link';

const mobileLinkClass = (href: string): string =>
    isActive(href) ? 'mobile-link mobile-link-active' : 'mobile-link';
---

<header class='sticky top-0 z-50 w-full bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800'>
    <div class='container flex h-16 items-center justify-between'>
        <a href={getHomeUrl()} class='flex items-center space-x-2' aria-label='Hosped.ar - Home'>
            <img src='/logo.webp' alt='Hosped.ar Logo' class='h-10 w-10' loading='lazy' />
            <div class='text-primary-700 dark:text-primary-300 font-display text-2xl font-bold hospedarLogo'>
                Hosped.ar
            </div>
        </a>

        <nav class='hidden md:flex items-center space-x-6' aria-label='Main Navigation'>
            <a href={getHomeUrl()} class={navLinkClass(getHomeUrl())} aria-current={isActive(getHomeUrl()) ? 'page' : undefined}>{t('nav.home')}</a>
            <a href={getAccommodationsIndexUrl()} class={navLinkClass(getAccommodationsIndexUrl())} aria-current={isActive(getAccommodationsIndexUrl()) ? 'page' : undefined}>{t('nav.accommodations')}</a>
            <a href={getDestinationsIndexUrl()} class={navLinkClass(getDestinationsIndexUrl())} aria-current={isActive(getDestinationsIndexUrl()) ? 'page' : undefined}>{t('nav.destinations')}</a>
            <a href={getEventsIndexUrl()} class={navLinkClass(getEventsIndexUrl())} aria-current={isActive(getEventsIndexUrl()) ? 'page' : undefined}>{t('nav.events')}</a>
            <a href={getBlogIndexUrl()} class={navLinkClass(getBlogIndexUrl())} aria-current={isActive(getBlogIndexUrl()) ? 'page' : undefined}>{t('nav.blog')}</a>
            <a href={getSearchUrl()} class={navLinkClass(getSearchUrl())} aria-current={isActive(getSearchUrl()) ? 'page' : undefined}>{t('nav.search')}</a>
            <a href={getContactUrl()} class={navLinkClass(getContactUrl())} aria-current={isActive(getContactUrl()) ? 'page' : undefined}>{t('nav.contact')}</a>
            <a href={getPricingUrl()} class={navLinkClass(getPricingUrl())} aria-current={isActive(getPricingUrl()) ? 'page' : undefined}>{t('nav.pricing')}</a>
        </nav>

        <div class='flex items-center space-x-4'>
            <UserNav client:load />
            <ThemeToggle />

            <!-- Mobile menu toggle button -->
            <button
                id='mobile-menu-button'
                class='md:hidden p-2 rounded-md text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none'
                aria-label='Toggle mobile menu'
                aria-expanded='false'
            >
                <!-- Menu icon (hamburger) - shown when menu is closed -->
                <svg id='menu-icon-open' class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M4 6h16M4 12h16M4 18h16' />
                </svg>
                <!-- Close icon (X) - shown when menu is open -->
                <svg id='menu-icon-close' class='w-6 h-6 hidden' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M6 18L18 6M6 6l12 12' />
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile menu -->
    <div id='mobile-menu' class='md:hidden hidden bg-white dark:bg-gray-900 shadow-md'>
        <div class='container py-3'>
            <nav aria-label='Mobile Navigation'>
                <ul class='space-y-3'>
                    <li><a href={getHomeUrl()} class={mobileLinkClass(getHomeUrl())} aria-current={isActive(getHomeUrl()) ? 'page' : undefined}>{t('nav.home')}</a></li>
                    <li><a href={getAccommodationsIndexUrl()} class={mobileLinkClass(getAccommodationsIndexUrl())} aria-current={isActive(getAccommodationsIndexUrl()) ? 'page' : undefined}>{t('nav.accommodations')}</a></li>
                    <li><a href={getDestinationsIndexUrl()} class={mobileLinkClass(getDestinationsIndexUrl())} aria-current={isActive(getDestinationsIndexUrl()) ? 'page' : undefined}>{t('nav.destinations')}</a></li>
                    <li><a href={getEventsIndexUrl()} class={mobileLinkClass(getEventsIndexUrl())} aria-current={isActive(getEventsIndexUrl()) ? 'page' : undefined}>{t('nav.events')}</a></li>
                    <li><a href={getBlogIndexUrl()} class={mobileLinkClass(getBlogIndexUrl())} aria-current={isActive(getBlogIndexUrl()) ? 'page' : undefined}>{t('nav.blog')}</a></li>
                    <li><a href={getSearchUrl()} class={mobileLinkClass(getSearchUrl())} aria-current={isActive(getSearchUrl()) ? 'page' : undefined}>{t('nav.search')}</a></li>
                    <li><a href={getContactUrl()} class={mobileLinkClass(getContactUrl())} aria-current={isActive(getContactUrl()) ? 'page' : undefined}>{t('nav.contact')}</a></li>
                    <li><a href={getPricingUrl()} class={mobileLinkClass(getPricingUrl())} aria-current={isActive(getPricingUrl()) ? 'page' : undefined}>{t('nav.pricing')}</a></li>
                </ul>
            </nav>
        </div>
    </div>

    <script>
        const btn = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        const iconOpen = document.getElementById('menu-icon-open');
        const iconClose = document.getElementById('menu-icon-close');

        if (btn && menu && iconOpen && iconClose) {
            btn.addEventListener('click', () => {
                const isExpanded = btn.getAttribute('aria-expanded') === 'true';
                menu.classList.toggle('hidden');
                iconOpen.classList.toggle('hidden');
                iconClose.classList.toggle('hidden');
                btn.setAttribute('aria-expanded', String(!isExpanded));
            });
        }
    </script>
</header>
