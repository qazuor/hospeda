---
/**
 * @file BetaPrevNext.astro
 * @description Prev/Next navigation at the bottom of each doc, computed from
 * the linearised collection order.
 */

import type { BetaNavEntry } from '@/lib/beta-nav';

interface Props {
    readonly prev: BetaNavEntry | null;
    readonly next: BetaNavEntry | null;
}

const { prev, next } = Astro.props;

if (!prev && !next) {
    return null;
}
---

<nav class="beta-prev-next" aria-label="Navegación entre páginas">
    {prev ? (
        <a href={prev.url} class="beta-prev-next__link beta-prev-next__link--prev" rel="prev">
            <span class="beta-prev-next__label">← Anterior</span>
            <span class="beta-prev-next__title">{prev.title}</span>
        </a>
    ) : (
        <span class="beta-prev-next__placeholder" aria-hidden="true"></span>
    )}

    {next ? (
        <a href={next.url} class="beta-prev-next__link beta-prev-next__link--next" rel="next">
            <span class="beta-prev-next__label">Siguiente →</span>
            <span class="beta-prev-next__title">{next.title}</span>
        </a>
    ) : (
        <span class="beta-prev-next__placeholder" aria-hidden="true"></span>
    )}
</nav>

<style>
    .beta-prev-next {
        margin-top: var(--space-6, 2.5rem);
        padding-top: var(--space-5, 1.5rem);
        border-top: 1px solid var(--border);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3, 0.75rem);
    }

    .beta-prev-next__link {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        padding: 0.85rem 1rem;
        text-decoration: none;
        background: var(--core-card, var(--surface-warm));
        border: 1px solid var(--border);
        border-radius: var(--radius-md, 10px);
        transition: border-color 0.15s ease, transform 0.15s ease;
    }

    .beta-prev-next__link:hover {
        border-color: var(--brand-primary);
        transform: translateY(-1px);
    }

    .beta-prev-next__link--next {
        text-align: right;
    }

    .beta-prev-next__label {
        font-family: var(--font-sans);
        font-size: 0.75rem;
        color: var(--core-muted-foreground);
        letter-spacing: 0.02em;
    }

    .beta-prev-next__title {
        font-family: var(--font-heading);
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--core-foreground);
        line-height: 1.3;
    }

    .beta-prev-next__placeholder {
        display: block;
    }

    @media (max-width: 640px) {
        .beta-prev-next {
            grid-template-columns: 1fr;
        }
        .beta-prev-next__link--next {
            text-align: left;
        }
    }
</style>
