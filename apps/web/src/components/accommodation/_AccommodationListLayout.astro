---
/**
 * @file _AccommodationListLayout.astro
 * @description Shared layout partial for accommodation listing pages.
 *
 * Renders the full two-column layout (filter sidebar + results area) shared
 * across all accommodation list variants: base listing, type-filtered listing,
 * and their paginated counterparts.
 *
 * Each page file is responsible for:
 *  - Extracting route params and query params
 *  - Fetching data from the API
 *  - Building breadcrumb items and canonical URL
 *  - Computing `initialFilters` and `hasActiveFilters`
 *  - Passing all results as props to this partial
 *
 * This partial owns the HTML structure, i18n labels, and all rendering logic.
 */

import type { SupportedLocale } from '../../lib/i18n';
import { createT } from '../../lib/i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../seo/SEOHead.astro';
import Breadcrumb from '../shared/Breadcrumb.astro';
import AccommodationCard from '../shared/AccommodationCard.astro';
import EmptyState from '../shared/EmptyState.astro';
import Pagination from '../shared/Pagination.astro';
import SortDropdown from '../shared/SortDropdown.astro';
import { FilterSidebar } from './FilterSidebar.client';
import type { AccommodationFilters } from './filter-sidebar.types';
import type { AccommodationCardData } from '../../lib/api/transforms';

/** Shape of a single pagination metadata object returned by the API. */
interface PaginationMeta {
    /** Current page number (1-indexed). */
    readonly page: number;
    /** Total number of pages. */
    readonly totalPages: number;
    /** Total number of matching items across all pages. */
    readonly total: number;
}

/** A single breadcrumb item rendered by Breadcrumb.astro. */
interface BreadcrumbItem {
    readonly label: string;
    readonly href: string;
}

interface Props {
    /** Active locale for i18n and URL generation. */
    readonly locale: SupportedLocale;

    /** Page title displayed in the `<h1>` and passed to SEO. */
    readonly title: string;

    /**
     * Optional page description shown below the title and used for SEO.
     * When omitted the description paragraph is not rendered.
     */
    readonly description?: string;

    /** Canonical URL for the `<link rel="canonical">` tag. */
    readonly canonicalUrl: string;

    /**
     * Ordered breadcrumb items. Last item should represent the current page
     * and will be rendered as plain text (no link).
     */
    readonly breadcrumbItems: readonly BreadcrumbItem[];

    /**
     * Transformed accommodation card data to render in the grid.
     * An empty array triggers the "no results" empty state.
     */
    readonly cards: readonly AccommodationCardData[];

    /**
     * Pagination metadata from the API.
     * `null` when the API call failed or returned no pagination info.
     */
    readonly pagination: PaginationMeta | null;

    /**
     * Whether the API call resulted in an error.
     * When `true` the error empty state is rendered instead of the grid.
     */
    readonly apiError: boolean;

    /** Current sort key (e.g. "featured", "rating"). */
    readonly sortParam: string;

    /**
     * URLSearchParams instance with all active filter params except `page`.
     * Passed to `Pagination` so page links preserve filter state.
     */
    readonly paginationParams: URLSearchParams;

    /**
     * Base URL for pagination links (without trailing slash).
     * Example: `/es/alojamientos` or `/es/alojamientos/tipo/hotel`
     */
    readonly paginationBaseUrl: string;

    /**
     * URL that the "clear filters" link points to.
     * Typically the canonical listing URL without any query params.
     */
    readonly clearFiltersUrl: string;

    /**
     * Canonical "home" URL for the "go back" CTA in the error empty state.
     */
    readonly homeUrl: string;

    /**
     * Whether any filter is currently active (used to show the "filters active"
     * indicator bar and the clear-filters link).
     */
    readonly hasActiveFilters: boolean;

    /**
     * Initial filter state to seed the FilterSidebar React island.
     * Prevents a flash of empty sidebar state on first render.
     */
    readonly initialFilters: Partial<AccommodationFilters>;

    /**
     * Form action URL for the search bar (plain HTML form, no JS router).
     * Typically the base listing URL without query params.
     */
    readonly searchActionUrl: string;

    /**
     * Current value of the text search query param (`q`).
     * Used to pre-fill the search input.
     */
    readonly searchQuery?: string;

    /**
     * Hidden fields to preserve non-`q` filter state across a search form
     * submission. Each entry becomes a `<input type="hidden">` element.
     * Only include params that the search form should carry forward.
     */
    readonly searchHiddenParams?: ReadonlyArray<{ readonly name: string; readonly value: string }>;
}

const {
    locale,
    title,
    description,
    canonicalUrl,
    breadcrumbItems,
    cards,
    pagination,
    apiError,
    sortParam,
    paginationParams,
    paginationBaseUrl,
    clearFiltersUrl,
    homeUrl,
    hasActiveFilters,
    initialFilters,
    searchActionUrl,
    searchQuery,
    searchHiddenParams = [],
} = Astro.props;

const t = createT(locale);
---

<BaseLayout title={title} description={description} locale={locale}>
    <SEOHead
        slot="head"
        title={title}
        description={description ?? ''}
        canonical={canonicalUrl}
        locale={locale}
    />

    <div class="container mx-auto max-w-7xl px-4 py-8">

        <!-- Breadcrumb -->
        <Breadcrumb items={breadcrumbItems} />

        <!-- Page header -->
        <header class="mb-6">
            <h1 class="text-4xl font-bold text-foreground">{title}</h1>
            {description && (
                <p class="mt-2 text-lg text-muted-foreground">{description}</p>
            )}
        </header>

        <!-- Search bar (plain HTML form — no JS island needed) -->
        <form
            method="get"
            action={searchActionUrl}
            class="mb-6"
        >
            <div class="flex gap-2">
                <input
                    type="text"
                    name="q"
                    value={searchQuery ?? ''}
                    placeholder={t('accommodations.listPage.searchPlaceholder', 'Buscar alojamiento...')}
                    class="w-full rounded-full border border-border bg-card px-5 py-3 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                    aria-label={t('accommodations.listPage.searchLabel', 'Buscar alojamientos')}
                />
                {searchHiddenParams.map(({ name, value }) => (
                    <input type="hidden" name={name} value={value} />
                ))}
                <button
                    type="submit"
                    class="shrink-0 rounded-full bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
                >
                    {t('accommodations.listPage.search', 'Buscar')}
                </button>
            </div>
        </form>

        <!-- Two-column layout: sidebar + content -->
        <div class="flex flex-col gap-8 lg:flex-row lg:items-start">

            <!-- Filter Sidebar (React island — client:visible defers hydration until scrolled into view) -->
            <div class="shrink-0 lg:w-72 xl:w-80">
                <FilterSidebar
                    client:visible
                    initialFilters={initialFilters}
                    locale={locale}
                    className="lg:sticky lg:top-24"
                />
            </div>

            <!-- Main content: results count + sort + cards grid + pagination -->
            <section class="min-w-0 flex-1" aria-label={title}>

                <!-- Results bar -->
                <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
                    {!apiError && pagination && (
                        <p class="text-sm text-muted-foreground">
                            {t('accommodations.listPage.showing', 'Mostrando')}{' '}
                            <span class="font-semibold text-foreground">{cards.length}</span>
                            {' '}{t('accommodations.listPage.of', 'de')}{' '}
                            <span class="font-semibold text-foreground">{pagination.total}</span>
                            {' '}{t('accommodations.listPage.results', 'resultados')}
                        </p>
                    )}

                    <SortDropdown currentSort={sortParam} locale={locale} />
                </div>

                <!-- Active filter indicator + clear all link -->
                {hasActiveFilters && (
                    <div class="mb-4 flex items-center justify-between rounded-lg bg-muted px-4 py-2">
                        <span class="text-sm text-muted-foreground">
                            {t('accommodations.listPage.filtersActive', 'Filtros activos aplicados')}
                        </span>
                        <a
                            href={clearFiltersUrl}
                            class="text-sm font-medium text-primary underline-offset-4 hover:underline"
                        >
                            {t('accommodations.listPage.clearFilters', 'Limpiar filtros')}
                        </a>
                    </div>
                )}

                <!-- Cards grid or states -->
                {apiError ? (
                    <EmptyState
                        title={t('accommodations.listPage.errorTitle', 'Error al cargar alojamientos')}
                        message={t('accommodations.listPage.errorMessage', 'No pudimos obtener los alojamientos. Por favor intenta mas tarde.')}
                        cta={{
                            label: t('accommodations.listPage.retry', 'Volver al inicio'),
                            href: homeUrl,
                        }}
                    />
                ) : cards.length > 0 ? (
                    <div class="scroll-reveal grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
                        {cards.map((card) => (
                            <AccommodationCard card={card} locale={locale} />
                        ))}
                    </div>
                ) : (
                    <EmptyState
                        title={t('accommodations.listPage.noResults', 'Sin resultados')}
                        message={t('accommodations.listPage.noResultsMessage', 'No encontramos alojamientos con los filtros aplicados. Intenta con otros criterios.')}
                        cta={{
                            label: t('accommodations.listPage.clearFilters', 'Limpiar filtros'),
                            href: clearFiltersUrl,
                        }}
                    />
                )}

                <!-- Pagination (query-param mode preserves active filters) -->
                {pagination && pagination.totalPages > 1 && (
                    <Pagination
                        currentPage={pagination.page}
                        totalPages={pagination.totalPages}
                        baseUrl={paginationBaseUrl}
                        locale={locale}
                        searchParams={paginationParams}
                    />
                )}
            </section>
        </div>
    </div>
</BaseLayout>
