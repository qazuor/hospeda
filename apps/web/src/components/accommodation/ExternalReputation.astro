---
/**
 * @file ExternalReputation.astro
 * @description "Reputación en otras plataformas" block rendered on the
 * accommodation detail page. Sibling to ReviewPreview, placed after it.
 *
 * Accepts an {@link ExternalReputationBlock} from the public API and renders:
 *
 * Block 1 — Score chips row: compact chip per platform showing rating,
 *   review count, and a deep-link. Chips do NOT contain snippets so they
 *   stay naturally short and even.
 *
 * Block 2 — Featured reviews (Google only): sub-heading + ExternalReviews
 *   island when at least one item has valid TTL snippets.
 *
 * Footer — AC-5.1 "why only Google" explainer always rendered.
 *
 * Renders NOTHING when the block is empty (items array empty).
 *
 * AC-4.5: each chip header (platformLabel) labels the source platform.
 * AC-5.1: googleOnly note always rendered below.
 */

import { ExternalLinkIcon, StarIcon } from '@repo/icons';
import { ExternalReviews } from './ExternalReviews.client';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import type { ExternalReputationBlock, ExternalReputationPlatformItem } from '@repo/schemas';
import styles from './ExternalReputation.module.css';

interface Props {
    /**
     * External reputation block from GET /api/v1/public/accommodations/:id/external-reputation.
     * Render nothing when items is empty.
     */
    readonly reputationData: ExternalReputationBlock;
    /** Active locale for i18n. */
    readonly locale: string;
}

const { reputationData, locale } = Astro.props;
const { t } = createTranslations(locale as SupportedLocale);

// Nothing to render when all platforms are hidden.
const { items } = reputationData;
if (items.length === 0) {
    return;
}

/**
 * Returns the i18n-translated platform name for a given platform key.
 */
function platformLabel(platform: ExternalReputationPlatformItem['platform']): string {
    const key = `external-reputation.platform.${platform.toLowerCase()}` as const;
    return t(key as Parameters<typeof t>[0], platform);
}

/**
 * Determines if a platform item has Google snippets that are still valid.
 * The public schema only includes snippets when TTL is valid at build time
 * (buildExternalReputationBlock strips them). An empty/null array means either
 * not Google, no snippets fetched, or TTL expired.
 */
function hasValidSnippets(item: ExternalReputationPlatformItem): boolean {
    return item.platform === 'GOOGLE' && Array.isArray(item.snippets) && item.snippets.length > 0;
}

/**
 * Determines if a platform item should show the "snippets temporarily unavailable"
 * note. Uses the explicit `snippetsTtlExpired` flag set by buildExternalReputationBlock
 * rather than inferring from missing snippets — prevents showing the note when the
 * owner intentionally disabled reviews (showReviews=false) (FIX L5).
 */
function isGoogleTtlExpired(item: ExternalReputationPlatformItem): boolean {
    return item.snippetsTtlExpired === true;
}

// Derive Block 2 state once so the template stays clean.
const googleItemWithSnippets = items.find(hasValidSnippets);
const googleItemTtlExpired = items.find(
    (item) => item.platform === 'GOOGLE' && isGoogleTtlExpired(item)
);
const showReviewsBlock = googleItemWithSnippets != null || googleItemTtlExpired != null;
---

<section class={styles.section}>
    <h2 class={styles.title}>{t('external-reputation.section.title', 'Reputación en otras plataformas')}</h2>
    <p class={styles.subtitle}>{t('external-reputation.section.subtitle', 'Opiniones de viajeros verificados en los principales sitios de alojamiento')}</p>

    {/* ── Block 1: Score chips row ── */}
    <div class={styles.chips}>
        {items.map((item) => (
            <div class={styles.chip}>
                {/* AC-4.5: platform name as chip heading labels the source */}
                <span class={styles.chipPlatformName}>{platformLabel(item.platform)}</span>

                {/* Rating + review count — or "no data" */}
                {(item.rating != null || item.reviewsCount != null) ? (
                    <div class={styles.chipRating}>
                        {item.rating != null && (
                            <span class={styles.chipRatingValue}>
                                <StarIcon size="sm" weight="fill" color="var(--brand-accent)" aria-hidden="true" />
                                <strong class={styles.chipRatingNumber}>{item.rating.toFixed(1)}</strong>
                            </span>
                        )}
                        {item.reviewsCount != null && (
                            <span class={styles.chipReviewCount}>
                                {t('external-reputation.aggregate.reviewsCount', '{{count}} reseñas', { count: item.reviewsCount })}
                            </span>
                        )}
                    </div>
                ) : (
                    <p class={styles.chipNoData}>{t('external-reputation.aggregate.noData', 'Sin datos disponibles')}</p>
                )}

                {/* Deep link at the bottom of the chip */}
                {item.deepLink && (
                    <a
                        href={item.deepLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        class={styles.chipDeepLink}
                    >
                        <ExternalLinkIcon size="sm" aria-hidden="true" />
                        <span>
                            {t('external-reputation.link.viewOn', 'Ver en {{platform}} →', {
                                platform: platformLabel(item.platform)
                            })}
                        </span>
                    </a>
                )}
            </div>
        ))}
    </div>

    {/* ── Block 2: Featured reviews (Google snippets) ── */}
    {showReviewsBlock && (
        <div class={styles.reviewsBlock}>
            <div class={styles.reviewsBlockHeader}>
                <h3 class={styles.reviewsBlockTitle}>
                    {t('external-reputation.reviews.title', 'Reseñas destacadas')}
                </h3>
                <span class={styles.reviewsBlockVia}>
                    {t('external-reputation.reviews.via', 'vía {{platform}}', {
                        platform: t('external-reputation.platform.google', 'Google')
                    })}
                </span>
            </div>

            {googleItemWithSnippets != null ? (
                <ExternalReviews
                    client:visible
                    snippets={googleItemWithSnippets.snippets!}
                    locale={locale as SupportedLocale}
                />
            ) : googleItemTtlExpired != null ? (
                <p class={styles.ttlNote}>
                    {t('external-reputation.snippets.ttlExpired', 'Las reseñas de texto no están disponibles temporalmente; mostrando solo el puntaje')}
                </p>
            ) : null}
        </div>
    )}

    {/* AC-5.1: "why only Google" explainer — always shown */}
    <p class={styles.googleOnlyNote}>
        {t('external-reputation.snippets.googleOnly', 'Solo Google muestra el texto completo de las reseñas porque ofrece una API oficial. Las demás plataformas muestran el puntaje agregado y un enlace directo por razones legales.')}
    </p>
</section>
