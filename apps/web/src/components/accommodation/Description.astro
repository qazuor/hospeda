---
/**
 * @file Description.astro
 * @description Accommodation summary + full description section.
 * Summary is highlighted with a warm background.
 *
 * SECURITY (SPEC-187 FR-2 / PD-2 / PD-6):
 * `descriptionText` is a plain-text body field that has already been
 * HTML-escaped by `renderPlain` (see `apps/web/src/lib/render-plain.ts`).
 * The text is emitted as a text child, NEVER via `set:html` —
 * re-parsing the escaped entities as HTML would silently re-introduce
 * the XSS surface that the P0 strip migration was designed to close.
 * The previous version of this component piped sanitized HTML through
 * `set:html`; that contract changed when `accommodation.description`
 * was reverted from RICH_TEXT to TEXTAREA in the admin config.
 */

interface Props {
    readonly summary: string;
    /** Plain text body field, already HTML-escaped by `renderPlain`
     *  in the parent page. Emitted as a text child below. */
    readonly descriptionText: string;
}

const { summary, descriptionText } = Astro.props;
---

{summary && (
  <div class="description__summary">
    <p>{summary}</p>
  </div>
)}

{descriptionText && (
  <div class="description__body">
    <p>{descriptionText}</p>
  </div>
)}

<style>
  .description__summary {
    background-color: var(--surface-warm);
    border-left: 4px solid var(--brand-accent);
    border-radius: var(--radius-button, 8px);
    padding: var(--space-4, 16px) var(--space-5, 20px);
    margin-bottom: var(--space-5, 20px);
  }
  .description__summary p {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--core-foreground);
    margin: 0;
  }
  .description__body {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--core-foreground);
  }
  .description__body p {
    margin-bottom: var(--space-3, 12px);
  }
  .description__body p:last-child {
    margin-bottom: 0;
  }
</style>
