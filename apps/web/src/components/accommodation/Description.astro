---
/**
 * @file Description.astro
 * @description Accommodation summary + full description section.
 * Summary is highlighted with a warm background.
 *
 * SECURITY: `descriptionHtml` MUST be sanitized HTML produced by
 * `renderContent` (see `apps/web/src/lib/render-content.ts`). Never pass raw
 * API content here — the parent page is responsible for the conversion.
 */

interface Props {
    readonly summary: string;
    /** Sanitized HTML produced by `renderContent({ raw: accommodation.description, siteOrigin })`. */
    readonly descriptionHtml: string;
}

const { summary, descriptionHtml } = Astro.props;
---

{summary && (
  <div class="description__summary">
    <p>{summary}</p>
  </div>
)}

{descriptionHtml && (
  <div class="description__body" set:html={descriptionHtml} />
)}

<style>
  .description__summary {
    background-color: var(--surface-warm);
    border-left: 4px solid var(--brand-accent);
    border-radius: var(--radius-button, 8px);
    padding: var(--space-4, 16px) var(--space-5, 20px);
    margin-bottom: var(--space-5, 20px);
  }
  .description__summary p {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--core-foreground);
    margin: 0;
  }
  .description__body {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--core-foreground);
  }
  .description__body :global(h2),
  .description__body :global(h3) {
    font-family: var(--font-heading);
    margin-top: var(--space-5, 20px);
  }
  .description__body :global(p) {
    margin-bottom: var(--space-3, 12px);
  }
  .description__body :global(ul),
  .description__body :global(ol) {
    padding-left: var(--space-5, 20px);
    margin-bottom: var(--space-3, 12px);
  }
  .description__body :global(strong) { font-weight: 700; }
  .description__body :global(em) { font-style: italic; }
</style>
