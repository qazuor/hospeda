---
/**
 * Skeleton placeholder for AccommodationCardDetailed.
 * Replicates the card layout with shimmer animation.
 */
---

<article class="animate-pulse overflow-hidden rounded-xl">
    {/* Image skeleton */}
    <div class="aspect-[4/3] w-full rounded-xl bg-surface-alt"></div>

    {/* Content skeleton */}
    <div class="px-1 pt-3 pb-1">
        {/* Type + location line */}
        <div class="mb-2 h-3.5 w-3/5 rounded bg-surface-alt"></div>

        {/* Name line */}
        <div class="mb-2 h-5 w-4/5 rounded bg-surface-alt"></div>

        {/* Specs line */}
        <div class="mb-3 h-3.5 w-2/5 rounded bg-surface-alt"></div>

        {/* Divider */}
        <div class="mb-3 border-t border-border"></div>

        {/* Rating + Price row */}
        <div class="flex items-center justify-between">
            <div class="h-4 w-20 rounded bg-surface-alt"></div>
            <div class="h-5 w-24 rounded bg-surface-alt"></div>
        </div>
    </div>
</article>
