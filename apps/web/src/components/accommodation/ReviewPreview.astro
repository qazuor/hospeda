---
/**
 * @file ReviewPreview.astro
 * @description Review summary: average score + per-category breakdown + a
 * single CTA that opens the modal with the full reviews list. Individual
 * reviews are NOT rendered inline — they would take up too much vertical
 * space on the detail page; the modal owns that view.
 */
import type { AccommodationDetailData } from '@/data/types';
import GradientButton from '@/components/shared/ui/GradientButton.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import RatingBreakdown from './RatingBreakdown.astro';

interface Props {
  readonly accommodation: AccommodationDetailData;
  readonly lang: string;
  /**
   * Optional pre-computed average per rating category
   * (`cleanliness`, `hospitality`, `services`, `accuracy`,
   * `communication`, `location`). When provided, RatingBreakdown
   * renders the per-category bars below the overall score.
   */
  readonly ratingBreakdown?: Readonly<Record<string, number>>;
}

const { accommodation, lang, ratingBreakdown } = Astro.props;
const { t } = createTranslations(lang as SupportedLocale);

const hasReviews = accommodation.reviewsCount > 0;
---

<section class="review-preview">
  <h2 class="review-preview__title">{t('accommodations.detail.reviews')}</h2>

  {!hasReviews ? (
    <p class="review-preview__empty">{t('accommodations.detail.reviewsDetail.noReviews')}</p>
  ) : (
    <>
      <RatingBreakdown
        averageRating={accommodation.averageRating}
        reviewsCount={accommodation.reviewsCount}
        ratingBreakdown={ratingBreakdown}
        lang={lang}
      />

      <GradientButton
        as="button"
        label={t('accommodations.detail.reviewsDetail.viewAll', undefined, { n: accommodation.reviewsCount })}
        variant="outline-primary"
        size="sm"
        shape="rounded"
        class="review-preview__view-all"
        data={{
          'reviews-modal-trigger': '',
          'accommodation-id': accommodation.id,
          'reviews-count': accommodation.reviewsCount,
        }}
      />
    </>
  )}

  <slot />
</section>

<style>
  /* Flex column owns the vertical rhythm via `gap`, so the inline-flex
     button can't end up flush against the rating bars regardless of how
     the GradientButton renders internally. */
  .review-preview {
    display: flex;
    flex-direction: column;
    gap: var(--space-6, 24px);
  }
  .review-preview__title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--core-foreground);
    margin: 0;
  }
  .review-preview__empty {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--core-muted-foreground);
    font-style: italic;
    margin: 0;
  }
  .review-preview__view-all {
    align-self: flex-start;
    padding: 10px 24px;
  }
</style>
