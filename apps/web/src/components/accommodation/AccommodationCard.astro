---
/**
 * Preview card for accommodation listings.
 * Displays featured image, type badge, price badge, name, rating,
 * location, summary, and optional amenity icons row.
 * Data-source agnostic - receives typed props, not DB entities.
 */
import Badge from '../ui/Badge.astro';
import { FavoriteIcon, WifiIcon, PoolIcon, ParkingIcon, AirConditioningIcon, KitchenIcon, PetAllowedIcon } from '@repo/icons';

interface AccommodationCardData {
  slug: string;
  name: string;
  summary: string;
  type: string;
  featuredImage: string;
  averageRating: number;
  reviewsCount: number;
  location: {
    city: string;
    state: string;
  };
  isFeatured: boolean;
  price?: {
    amount: number;
    currency: string;
    period: string;
  };
  amenities?: string[];
}

interface Props {
  accommodation: AccommodationCardData;
  showFavorite?: boolean;
  locale?: string;
}

const { accommodation, showFavorite = false, locale = 'es' } = Astro.props;
const detailUrl = `/${locale}/alojamientos/${accommodation.slug}/`;

/** Format rating to 1 decimal place, defaulting to 0 if not a number */
const numericRating = Number(accommodation.averageRating) || 0;
const formattedRating = numericRating.toFixed(1);

/** Format accommodation type for display */
const typeLabels: Record<string, string> = {
  HOTEL: 'Hotel',
  CABIN: 'Cabana',
  APARTMENT: 'Departamento',
  CAMPING: 'Camping',
  HOSTEL: 'Hostel',
  BNB: 'B&B',
  RURAL: 'Rural',
  BOUTIQUE: 'Boutique',
};
const typeLabel = typeLabels[accommodation.type] ?? accommodation.type;

/** Format price for display */
const formattedPrice = accommodation.price
  ? `${accommodation.price.currency}${accommodation.price.amount.toLocaleString('es-AR')}/${accommodation.price.period}`
  : undefined;

/** Amenity configuration: maps amenity keys to icon components and labels */
const amenityConfig: Record<string, { icon: typeof WifiIcon; label: string }> = {
  wifi: { icon: WifiIcon, label: 'Wi-Fi' },
  pool: { icon: PoolIcon, label: 'Piscina' },
  parking: { icon: ParkingIcon, label: 'Parking' },
  ac: { icon: AirConditioningIcon, label: 'A/C' },
  kitchen: { icon: KitchenIcon, label: 'Cocina' },
  pets: { icon: PetAllowedIcon, label: 'Mascotas' },
};

const allAmenities = accommodation.amenities ?? [];
const displayAmenities = allAmenities.slice(0, 3);
const extraAmenityCount = allAmenities.length - displayAmenities.length;
---

<article class="group overflow-hidden rounded-xl border border-border bg-surface shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
  <!-- Image container -->
  <a href={detailUrl} class="relative block aspect-[4/3] overflow-hidden">
    <img
      src={accommodation.featuredImage}
      alt={accommodation.name}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
      transition:name={`entity-${accommodation.slug}`}
    />
    <!-- Type badge -->
    <div class="absolute left-3 top-3">
      <Badge label={typeLabel} variant="type" />
    </div>
    <!-- Price badge -->
    {formattedPrice && (
      <div class="absolute bottom-3 right-3">
        <Badge label={formattedPrice} variant="price" />
      </div>
    )}
    <!-- Favorite button placeholder -->
    {showFavorite && (
      <div class="absolute right-3 top-3" data-slot="favorite-button">
        <button
          type="button"
          class="flex h-8 w-8 items-center justify-center rounded-full bg-surface/80 text-text-secondary backdrop-blur-sm transition-colors hover:text-error"
          aria-label={`Add ${accommodation.name} to favorites`}
        >
          <FavoriteIcon size={20} className="flex-shrink-0" aria-hidden="true" />
        </button>
      </div>
    )}
  </a>

  <!-- Content -->
  <div class="p-4">
    <h3 class="text-lg font-semibold line-clamp-2" title={accommodation.name}>
      <a href={detailUrl} class="text-text no-underline hover:text-primary">
        {accommodation.name}
      </a>
    </h3>

    <!-- Rating and reviews -->
    {(accommodation.reviewsCount ?? 0) > 0 && (
      <div class="mt-1 flex items-center gap-1.5 text-sm">
        <span class="font-semibold text-warning" aria-label={`Rating: ${formattedRating} out of 5`}>
          ★ {formattedRating}
        </span>
        <span class="text-text-tertiary">
          ({accommodation.reviewsCount})
        </span>
      </div>
    )}

    <!-- Location -->
    <p class="mt-1.5 text-sm text-text-tertiary">
      {accommodation.location?.city}{accommodation.location?.city && accommodation.location?.state ? ', ' : ''}{accommodation.location?.state}
    </p>

    <!-- Summary -->
    <p class="mt-2 line-clamp-2 text-sm text-text-secondary">
      {accommodation.summary}
    </p>

    <!-- Amenity icons row -->
    {displayAmenities.length > 0 && (
      <div class="mt-3 flex items-center gap-3">
        {displayAmenities.map((key) => {
          const config = amenityConfig[key];
          if (!config) return null;
          const AmenityIcon = config.icon;
          return (
            <div class="flex items-center gap-1 text-sm text-text-secondary">
              <AmenityIcon size={16} aria-hidden="true" />
              <span>{config.label}</span>
            </div>
          );
        })}
        {extraAmenityCount > 0 && (
          <span class="text-xs text-text-tertiary">+{extraAmenityCount}</span>
        )}
      </div>
    )}
  </div>
</article>
