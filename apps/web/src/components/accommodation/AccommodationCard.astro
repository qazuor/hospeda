---
/**
 * Preview card for accommodation listings.
 * Displays featured image with overlaid name, location pin, type badge,
 * price badge (top-right), star rating or "no ratings" text,
 * summary, and optional amenity/feature badges.
 * Data-source agnostic - receives typed props, not DB entities.
 */
import Badge from '../ui/Badge.astro';
import { FavoriteIcon, LocationIcon, WifiIcon, PoolIcon, ParkingIcon, AirConditioningIcon, KitchenIcon, PetAllowedIcon } from '@repo/icons';

interface AccommodationCardData {
  slug: string;
  name: string;
  summary: string;
  type: string;
  featuredImage: string;
  averageRating: number;
  reviewsCount: number;
  location: {
    city: string;
    state: string;
  };
  isFeatured: boolean;
  price?: {
    amount: number;
    currency: string;
    period: string;
  };
  amenities?: Array<{ key: string; label: string }>;
  features?: Array<{ key: string; label: string }>;
}

interface Props {
  accommodation: AccommodationCardData;
  showFavorite?: boolean;
  locale?: string;
}

const { accommodation, showFavorite = false, locale = 'es' } = Astro.props;
const detailUrl = `/${locale}/alojamientos/${accommodation.slug}/`;

/** Format rating to 1 decimal place, defaulting to 0 if not a number */
const numericRating = Number(accommodation.averageRating) || 0;
const formattedRating = numericRating.toFixed(1);
const hasReviews = (accommodation.reviewsCount ?? 0) > 0;

/** Generate star display: filled and empty stars */
const fullStars = Math.round(numericRating);
const emptyStars = 5 - fullStars;

/** Localized type labels for accommodation types */
const typeLabels: Record<string, Record<string, string>> = {
  es: {
    HOTEL: 'Hotel',
    CABIN: 'Cabaña',
    APARTMENT: 'Departamento',
    HOUSE: 'Casa',
    COUNTRY_HOUSE: 'Casa de campo',
    HOSTEL: 'Hostal',
    CAMPING: 'Camping',
    ROOM: 'Habitación',
    MOTEL: 'Motel',
    RESORT: 'Resort',
  },
  en: {
    HOTEL: 'Hotel',
    CABIN: 'Cabin',
    APARTMENT: 'Apartment',
    HOUSE: 'House',
    COUNTRY_HOUSE: 'Country house',
    HOSTEL: 'Hostel',
    CAMPING: 'Camping',
    ROOM: 'Room',
    MOTEL: 'Motel',
    RESORT: 'Resort',
  },
  pt: {
    HOTEL: 'Hotel',
    CABIN: 'Cabana',
    APARTMENT: 'Apartamento',
    HOUSE: 'Casa',
    COUNTRY_HOUSE: 'Casa de campo',
    HOSTEL: 'Hostel',
    CAMPING: 'Camping',
    ROOM: 'Quarto',
    MOTEL: 'Motel',
    RESORT: 'Resort',
  },
};

const localeLabels = typeLabels[locale] ?? typeLabels.es;
const typeLabel = localeLabels[accommodation.type] ?? accommodation.type;

/** Format price for display or show "consult" label */
const priceLabels: Record<string, string> = {
  es: 'Consultar precio',
  en: 'Ask for price',
  pt: 'Consultar preco',
};

const noRatingLabels: Record<string, string> = {
  es: 'Sin calificaciones',
  en: 'No ratings',
  pt: 'Sem avaliacoes',
};

const formattedPrice = accommodation.price
  ? `$${accommodation.price.amount.toLocaleString('es-AR')}`
  : undefined;

const consultPriceLabel = priceLabels[locale] ?? priceLabels.es;
const noRatingLabel = noRatingLabels[locale] ?? noRatingLabels.es;

/** Location display: city only, fallback to state */
const locationDisplay = accommodation.location?.city || accommodation.location?.state || '';

/** Combine amenities and features into badge list */
const allBadgeItems: Array<{ key: string; label: string }> = [
  ...(accommodation.amenities ?? []),
  ...(accommodation.features ?? []),
];
const badgeItems = allBadgeItems.slice(0, 4);
const extraBadgeCount = allBadgeItems.length - badgeItems.length;

/** Amenity configuration: maps amenity keys to icon components and labels */
const amenityConfig: Record<string, { icon: typeof WifiIcon; label: string }> = {
  wifi: { icon: WifiIcon, label: 'Wi-Fi' },
  pool: { icon: PoolIcon, label: 'Piscina' },
  parking: { icon: ParkingIcon, label: 'Parking' },
  ac: { icon: AirConditioningIcon, label: 'A/C' },
  kitchen: { icon: KitchenIcon, label: 'Cocina' },
  pets: { icon: PetAllowedIcon, label: 'Mascotas' },
};
---

<article class="group overflow-hidden rounded-xl border border-border bg-surface shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
  <!-- Image container with overlaid name and location -->
  <a href={detailUrl} class="relative block aspect-[4/3] overflow-hidden">
    <img
      src={accommodation.featuredImage}
      alt={accommodation.name}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
      transition:name={`entity-${accommodation.slug}`}
    />

    <!-- Dark gradient overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent" />

    <!-- Type badge (top-left) -->
    <div class="absolute left-3 top-3">
      <Badge label={typeLabel} variant="type" />
    </div>

    <!-- Price badge (top-right) -->
    <div class="absolute right-3 top-3">
      {formattedPrice ? (
        <Badge label={formattedPrice} variant="price-light" />
      ) : (
        <Badge label={consultPriceLabel} variant="secondary" />
      )}
    </div>

    <!-- Favorite button -->
    {showFavorite && (
      <div class="absolute right-3 top-12" data-slot="favorite-button">
        <button
          type="button"
          class="flex h-8 w-8 items-center justify-center rounded-full bg-surface/80 text-text-secondary backdrop-blur-sm transition-colors hover:text-error"
          aria-label={`Add ${accommodation.name} to favorites`}
        >
          <FavoriteIcon size={20} className="flex-shrink-0" aria-hidden="true" />
        </button>
      </div>
    )}

    <!-- Name + Location overlaid on image (bottom) -->
    <div class="absolute bottom-0 left-0 right-0 p-4">
      <h3 class="text-lg font-bold text-white line-clamp-2 drop-shadow-md" title={accommodation.name}>
        {accommodation.name}
      </h3>
      {locationDisplay && (
        <p class="mt-1 flex items-center gap-1 text-sm text-white/90 drop-shadow-sm">
          <LocationIcon size={14} className="flex-shrink-0 text-white" aria-hidden="true" />
          {locationDisplay}
        </p>
      )}
    </div>
  </a>

  <!-- Content -->
  <div class="p-4">
    <!-- Star rating or "no ratings" -->
    {hasReviews ? (
      <div class="flex items-center gap-1.5 text-sm">
        <span class="flex items-center text-warning" aria-label={`Rating: ${formattedRating} out of 5`}>
          {Array.from({ length: fullStars }).map(() => (
            <span aria-hidden="true">&#9733;</span>
          ))}
          {Array.from({ length: emptyStars }).map(() => (
            <span class="text-text-tertiary" aria-hidden="true">&#9733;</span>
          ))}
        </span>
        <span class="font-medium text-text">{formattedRating}</span>
        <span class="text-text-tertiary">
          ({accommodation.reviewsCount})
        </span>
      </div>
    ) : (
      <div class="flex items-center text-sm">
        <span class="text-text-tertiary italic">{noRatingLabel}</span>
      </div>
    )}

    <!-- Summary -->
    <p class="mt-2 line-clamp-3 text-xs text-text-secondary">
      {accommodation.summary}
    </p>

    <!-- Amenity/Feature badges -->
    {badgeItems.length > 0 && (
      <div class="mt-3 flex flex-wrap items-center gap-1.5">
        {badgeItems.map((item) => {
          const config = amenityConfig[item.key.toLowerCase()];
          return config ? (
            <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-2 py-0.5 text-xs text-text-secondary dark:bg-gray-800">
              <config.icon size={12} aria-hidden="true" />
              {config.label}
            </span>
          ) : (
            <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs text-text-secondary dark:bg-gray-800">
              {item.label}
            </span>
          );
        })}
        {extraBadgeCount > 0 && (
          <span class="text-xs text-text-tertiary">+{extraBadgeCount}</span>
        )}
      </div>
    )}
  </div>
</article>
