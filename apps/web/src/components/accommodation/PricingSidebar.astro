---
/**
 * @file PricingSidebar.astro
 * @description Pricing sidebar with price, optional fee/discount breakdown,
 * stay-policy hints (capacity, min/max nights), and a "Consultar" fallback
 * when there is no price.
 */
import type { AccommodationDetailData } from '@/data/types';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import GradientButton from '@/components/shared/ui/GradientButton.astro';
import { UsersIcon, MoonIcon, CalendarIcon, ChevronDownIcon } from '@repo/icons';

interface Props {
  readonly price: AccommodationDetailData['price'];
  readonly extraInfo?: AccommodationDetailData['extraInfo'];
  readonly lang: string;
}

const { price, extraInfo, lang } = Astro.props;
const { t } = createTranslations(lang as SupportedLocale);

const hasPrice = price?.price != null && price.price > 0;
const currency = price?.currency ?? 'ARS';

function formatPrice(amount: number): string {
  return new Intl.NumberFormat(lang === 'pt' ? 'pt-BR' : lang === 'en' ? 'en-US' : 'es-AR', {
    style: 'currency',
    currency,
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  }).format(amount);
}

const fees = price?.additionalFees as Record<string, unknown> | null | undefined;
const discounts = price?.discounts as Record<string, unknown> | null | undefined;

// Stay policy facts derived from extraInfo. Always-rendered when present so
// the card is never empty under the price; the seed currently has these set
// for every accommodation while `additionalFees` and `discounts` are mostly
// empty.
const capacity = typeof extraInfo?.capacity === 'number' ? extraInfo.capacity : null;
const minNights = typeof extraInfo?.minNights === 'number' ? extraInfo.minNights : null;
const maxNights = typeof extraInfo?.maxNights === 'number' ? extraInfo.maxNights : null;

// Pre-process fees and discounts in frontmatter. Both follow AccommodationPriceSchema:
// each entry has { price, currency, isPercent?, isPerStay?, isPerNight?, ... } and the
// container map also carries an optional `others: Array<{name, ...}>` for custom entries.
interface FeeEntry {
  readonly key: string;
  readonly amount: number;
  readonly isPercent: boolean;
  readonly customName?: string;
}
interface DiscountEntry {
  readonly key: string;
  readonly pct: number;
  readonly customName?: string;
}

const isFeeRecord = (v: unknown): v is Record<string, unknown> =>
  v !== null && typeof v === 'object';

const feeEntries: FeeEntry[] = [];
if (fees) {
  for (const [key, val] of Object.entries(fees)) {
    if (key === 'others') {
      if (Array.isArray(val)) {
        for (const other of val) {
          if (!isFeeRecord(other)) continue;
          const amount = typeof other.price === 'number' ? other.price : undefined;
          const name = typeof other.name === 'string' ? other.name : undefined;
          if (amount && name) {
            feeEntries.push({ key: name, amount, isPercent: other.isPercent === true, customName: name });
          }
        }
      }
      continue;
    }
    if (!isFeeRecord(val)) continue;
    const amount = typeof val.price === 'number' ? val.price : undefined;
    if (amount) feeEntries.push({ key, amount, isPercent: val.isPercent === true });
  }
}

const discountEntries: DiscountEntry[] = [];
if (discounts) {
  for (const [key, val] of Object.entries(discounts)) {
    if (key === 'others') {
      if (Array.isArray(val)) {
        for (const other of val) {
          if (!isFeeRecord(other)) continue;
          const pct = typeof other.price === 'number' ? other.price : undefined;
          const name = typeof other.name === 'string' ? other.name : undefined;
          if (typeof pct === 'number' && pct > 0 && name) {
            discountEntries.push({ key: name, pct, customName: name });
          }
        }
      }
      continue;
    }
    if (!isFeeRecord(val)) continue;
    const pct = typeof val.price === 'number' ? val.price : undefined;
    if (typeof pct === 'number' && pct > 0) discountEntries.push({ key, pct });
  }
}

const hasFees = feeEntries.length > 0;
const hasDiscounts = discountEntries.length > 0;
---

<div class="pricing-sidebar">
  {hasPrice && price?.price != null ? (
    <div class="pricing-sidebar__price-block">
      <span class="pricing-sidebar__amount">{formatPrice(price.price)}</span>
      <span class="pricing-sidebar__period">{t('accommodations.detail.pricing.perNightLabel')}</span>
    </div>
  ) : (
    <div class="pricing-sidebar__consult">
      <GradientButton
        href="#contact"
        label={t('accommodations.detail.pricing.consult')}
        variant="accent"
        size="md"
        shape="rounded"
      />
    </div>
  )}

  {(capacity != null || minNights != null || maxNights != null) && (
    <ul class="pricing-sidebar__facts">
      {capacity != null && (
        <li class="pricing-sidebar__fact">
          <span class="pricing-sidebar__fact-icon">
            <UsersIcon size="sm" weight="duotone" aria-hidden="true" />
          </span>
          <span>{t('accommodations.detail.pricing.capacityFact', undefined, { n: capacity })}</span>
        </li>
      )}
      {minNights != null && minNights > 1 && (
        <li class="pricing-sidebar__fact">
          <span class="pricing-sidebar__fact-icon">
            <MoonIcon size="sm" weight="duotone" aria-hidden="true" />
          </span>
          <span>{t('accommodations.detail.pricing.minNightsFact', undefined, { n: minNights })}</span>
        </li>
      )}
      {maxNights != null && maxNights > 0 && maxNights < 30 && (
        <li class="pricing-sidebar__fact">
          <span class="pricing-sidebar__fact-icon">
            <CalendarIcon size="sm" weight="duotone" aria-hidden="true" />
          </span>
          <span>{t('accommodations.detail.pricing.maxNightsFact', undefined, { n: maxNights })}</span>
        </li>
      )}
    </ul>
  )}

  {(hasFees || hasDiscounts) && (
    <details class="pricing-sidebar__breakdown">
      <summary class="pricing-sidebar__breakdown-toggle">
        <span class="pricing-sidebar__breakdown-toggle-label">
          {t('accommodations.detail.pricing.viewBreakdown')}
        </span>
        <span class="pricing-sidebar__breakdown-chevron" aria-hidden="true">
          <ChevronDownIcon size="sm" weight="regular" />
        </span>
      </summary>
      <div class="pricing-sidebar__breakdown-content">
        {hasFees && (
          <div class="pricing-sidebar__breakdown-group">
            <p class="pricing-sidebar__breakdown-heading">
              {t('accommodations.detail.pricing.feesHeading')}
            </p>
            {feeEntries.map(({ key, amount, isPercent, customName }) => (
              <div class="pricing-sidebar__fee-row">
                <span class="pricing-sidebar__fee-name">
                  {customName ?? t(`accommodations.detail.pricing.fees.${key}`, key)}
                </span>
                <span class="pricing-sidebar__fee-amount">{isPercent ? `${amount}%` : formatPrice(amount)}</span>
              </div>
            ))}
          </div>
        )}
        {hasDiscounts && (
          <div class="pricing-sidebar__breakdown-group pricing-sidebar__breakdown-group--discounts">
            <p class="pricing-sidebar__breakdown-heading pricing-sidebar__breakdown-heading--discount">
              {t('accommodations.detail.pricing.discountsHeading')}
            </p>
            {discountEntries.map(({ key, pct, customName }) => (
              <div class="pricing-sidebar__discount-row">
                <span class="pricing-sidebar__discount-name">
                  {customName ?? t(`accommodations.detail.pricing.discounts.${key}`, key)}
                </span>
                <span class="pricing-sidebar__discount-value">-{pct}%</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </details>
  )}
</div>

<style>
  .pricing-sidebar {
    position: relative;
    background-color: var(--core-card);
    border-radius: var(--radius-card, 24px);
    padding: var(--space-6, 24px) var(--space-5, 20px) var(--space-5, 20px);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: transform 200ms ease-out, box-shadow 200ms ease-out;
  }
  .pricing-sidebar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--brand-accent) 0%, var(--brand-secondary) 100%);
  }
  .pricing-sidebar:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover, var(--shadow-card));
  }
  .pricing-sidebar__price-block {
    display: flex;
    align-items: baseline;
    gap: var(--space-2, 8px);
  }
  /* Only render the separator + spacing when there is content below the price
   * (facts list and/or fee breakdown). `:has()` avoids needing a class flag. */
  .pricing-sidebar__price-block:has(+ .pricing-sidebar__facts),
  .pricing-sidebar__price-block:has(+ .pricing-sidebar__breakdown) {
    margin-bottom: var(--space-4, 16px);
    padding-bottom: var(--space-4, 16px);
    border-bottom: 1px solid var(--border);
  }
  .pricing-sidebar__facts:has(+ .pricing-sidebar__breakdown) {
    margin-bottom: var(--space-4, 16px);
    padding-bottom: var(--space-4, 16px);
    border-bottom: 1px solid var(--border);
  }
  .pricing-sidebar__facts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 8px);
  }
  .pricing-sidebar__fact {
    display: flex;
    align-items: center;
    gap: var(--space-2, 8px);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--core-foreground);
    line-height: 1.4;
  }
  .pricing-sidebar__fact-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    color: var(--brand-primary);
  }
  .pricing-sidebar__amount {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--brand-accent);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .pricing-sidebar__period {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--core-muted-foreground);
  }
  .pricing-sidebar__consult {
    text-align: center;
    padding: var(--space-4, 16px) 0;
  }
  .pricing-sidebar__breakdown-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--brand-primary);
    cursor: pointer;
    list-style: none;
    padding: var(--space-1, 4px) 0;
    border-radius: var(--radius-sm, 6px);
    transition: color 150ms ease;
  }
  .pricing-sidebar__breakdown-toggle::-webkit-details-marker { display: none; }
  .pricing-sidebar__breakdown-toggle::marker { display: none; }
  .pricing-sidebar__breakdown-toggle:hover {
    color: var(--brand-accent);
  }
  .pricing-sidebar__breakdown-toggle-label {
    flex: 1;
  }
  .pricing-sidebar__breakdown-chevron {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    transition: transform 200ms ease;
  }
  details[open] .pricing-sidebar__breakdown-chevron {
    transform: rotate(180deg);
  }
  .pricing-sidebar__breakdown-content {
    padding-top: var(--space-3, 12px);
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 12px);
  }
  .pricing-sidebar__breakdown-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1, 4px);
  }
  .pricing-sidebar__breakdown-group--discounts {
    padding-top: var(--space-2, 8px);
    border-top: 1px dashed var(--border);
  }
  .pricing-sidebar__breakdown-heading {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--core-muted-foreground);
    margin-bottom: var(--space-1, 4px);
  }
  .pricing-sidebar__breakdown-heading--discount {
    color: var(--success);
  }
  @media (prefers-reduced-motion: reduce) {
    .pricing-sidebar,
    .pricing-sidebar:hover {
      transform: none;
      transition: none;
    }
  }
  .pricing-sidebar__fee-row,
  .pricing-sidebar__discount-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3, 12px);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    padding: var(--space-1, 4px) 0;
    border-bottom: 1px solid var(--border);
  }
  .pricing-sidebar__fee-row:last-child,
  .pricing-sidebar__discount-row:last-child {
    border-bottom: none;
  }
  .pricing-sidebar__fee-name,
  .pricing-sidebar__discount-name {
    color: var(--core-muted-foreground);
    flex: 1;
  }
  .pricing-sidebar__fee-amount {
    color: var(--core-foreground);
    font-weight: 500;
    white-space: nowrap;
  }
  .pricing-sidebar__discount-value {
    color: var(--success);
    font-weight: 600;
    white-space: nowrap;
  }
</style>
