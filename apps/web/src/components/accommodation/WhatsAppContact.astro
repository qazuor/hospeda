---
/**
 * @file WhatsAppContact.astro
 * @description Gated WhatsApp contact block for an accommodation detail page (HOS-19).
 *
 * Renders one of three states, decided by the page from the VIEWER's plan:
 *   1. `showUpsell` → a "subscribe to see WhatsApp" prompt (anonymous / free /
 *      any viewer without `CAN_CONTACT_WHATSAPP_DISPLAY`). No number is shown.
 *   2. `number` + `direct` (tourist-vip+ / owner-pro+) → a one-click `wa.me`
 *      deep link button.
 *   3. `number` + not `direct` (tourist-plus+ / owner-basico+) → the number as
 *      selectable text (display only; no click-to-chat link).
 *
 * The number is resolved per-viewer on the protected endpoint
 * `GET /protected/accommodations/:id/whatsapp` and is NEVER present on the
 * shared-cached public payload, so it can never leak to an unentitled viewer.
 *
 * Hydration: none — fully static Astro component (the page fetched everything
 * in SSR).
 */
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';

interface Props {
    /** The WhatsApp number, or null when the viewer is not entitled to it. */
    readonly number: string | null;
    /** Whether the viewer may use the one-click `wa.me` deep link (VIP+). */
    readonly direct: boolean;
    /** Render the subscribe upsell instead of a number. */
    readonly showUpsell: boolean;
    /** Accommodation name, used in the prefilled WhatsApp message. */
    readonly accommodationName: string;
    /** Locale-aware href to the plans page (upsell CTA target). */
    readonly plansHref: string;
    readonly locale: SupportedLocale;
}

const { number, direct, showUpsell, accommodationName, plansHref, locale } = Astro.props;
const { t } = createTranslations(locale);

// Nothing to render unless we have a number to show or an upsell to offer.
if (!showUpsell && !number) return;

const title = t('accommodations.detail.whatsapp.title', 'Contacto por WhatsApp');

// --- wa.me deep link (direct tier only) ---
// Sanitize the phone: strip everything except a leading '+' and digits, as
// wa.me expects an E.164-like number without spaces or separators.
let waUrl: string | null = null;
if (number && direct) {
    const phone = number.startsWith('+')
        ? `+${number.slice(1).replace(/\D/g, '')}`
        : number.replace(/\D/g, '');
    const message = t(
        'accommodations.detail.whatsapp.messageTemplate',
        'Hola, me interesa obtener más información sobre {{name}}'
    ).replace('{{name}}', accommodationName);
    waUrl = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
}

const ctaLabel = t('accommodations.detail.whatsapp.cta', 'Consultar por WhatsApp');
const numberLabel = t('accommodations.detail.whatsapp.numberLabel', 'WhatsApp del anfitrión');
const upsellText = t(
    'accommodations.detail.whatsapp.upsellText',
    'Suscribite a Plus para ver el WhatsApp del anfitrión.'
);
const upsellCta = t('accommodations.detail.whatsapp.upsellCta', 'Ver planes');
---

<section class="acc-whatsapp">
    <h3 class="acc-whatsapp__title">{title}</h3>

    {showUpsell ? (
        <div class="acc-whatsapp__upsell">
            <p class="acc-whatsapp__upsell-text">{upsellText}</p>
            <a class="acc-whatsapp__upsell-cta" href={plansHref}>{upsellCta}</a>
        </div>
    ) : waUrl ? (
        <a
            href={waUrl}
            class="acc-whatsapp__btn"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={ctaLabel}
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                width="20"
                height="20"
                aria-hidden="true"
            >
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
            </svg>
            <span>{ctaLabel}</span>
        </a>
    ) : (
        <p class="acc-whatsapp__number" aria-label={numberLabel}>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                width="18"
                height="18"
                aria-hidden="true"
            >
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
            </svg>
            <span>{number}</span>
        </p>
    )}
</section>

<style>
    .acc-whatsapp {
        display: flex;
        flex-direction: column;
        gap: var(--space-3, 12px);
        padding: var(--space-5, 20px);
        background-color: var(--surface-warm);
        border-radius: var(--radius-card, 24px);
        border: 1px solid var(--border);
    }

    .acc-whatsapp__title {
        font-family: var(--font-heading);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--core-foreground);
        margin: 0;
    }

    .acc-whatsapp__btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 24px;
        border-radius: var(--radius-button, 8px);
        background-color: #25d366;
        color: white;
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: opacity 200ms ease-out;
        width: fit-content;
    }

    .acc-whatsapp__btn:hover {
        opacity: 0.85;
    }

    .acc-whatsapp__btn:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    .acc-whatsapp__number {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 0;
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 1rem;
        color: #128c7e;
        user-select: text;
    }

    .acc-whatsapp__upsell {
        display: flex;
        flex-direction: column;
        gap: var(--space-3, 12px);
    }

    .acc-whatsapp__upsell-text {
        margin: 0;
        font-family: var(--font-sans);
        font-size: 0.95rem;
        color: var(--core-foreground-muted, var(--core-foreground));
    }

    .acc-whatsapp__upsell-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 20px;
        border-radius: var(--radius-button, 8px);
        background-color: var(--brand-primary);
        color: white;
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        width: fit-content;
        transition: opacity 200ms ease-out;
    }

    .acc-whatsapp__upsell-cta:hover {
        opacity: 0.85;
    }

    .acc-whatsapp__upsell-cta:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }
</style>
