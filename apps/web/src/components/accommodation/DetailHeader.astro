---
/**
 * @file DetailHeader.astro
 * @description Accommodation detail page header with name, badges, destination, and rating.
 */
import type { AccommodationDetailData } from '@/data/types';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { getAccommodationTypeLabel, getBadgeStatusColor } from '@/lib/colors';
import RatingStars from '@/components/shared/RatingStars.astro';

interface Props {
  readonly accommodation: AccommodationDetailData;
  readonly lang: string;
}

const { accommodation, lang } = Astro.props;
const { t } = createTranslations(lang as SupportedLocale);

const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
const isNew = (Date.now() - new Date(accommodation.createdAt).getTime()) < THIRTY_DAYS_MS;
const typeLabel = getAccommodationTypeLabel({ type: accommodation.type, t });
const featuredColors = getBadgeStatusColor({ status: 'featured' });
const newColors = getBadgeStatusColor({ status: 'new' });
---

<header class="detail-header">
  <div class="detail-header__badges">
    <span
      class="detail-header__type-badge"
      style="background-color: var(--brand-secondary-foreground); color: var(--primary-foreground);"
    >{typeLabel}</span>
    {accommodation.isFeatured && (
      <span
        class="detail-header__status-badge"
        style={`background-color: ${featuredColors.bg}; color: ${featuredColors.text}; border-color: ${featuredColors.border};`}
      >
        {t('accommodations.detail.badges.featured')}
      </span>
    )}
    {isNew && (
      <span
        class="detail-header__status-badge"
        style={`background-color: ${newColors.bg}; color: ${newColors.text}; border-color: ${newColors.border};`}
      >
        {t('accommodations.detail.badges.new')}
      </span>
    )}
  </div>

  <h1 class="detail-header__name">{accommodation.name}</h1>

  <a href={`/${lang}/destinos/${accommodation.destination.slug}`} class="detail-header__destination">
    {accommodation.destination.name}
  </a>

  {accommodation.averageRating > 0 && (
    <div class="detail-header__rating">
      <RatingStars rating={accommodation.averageRating} />
      <span class="detail-header__reviews-count">
        ({accommodation.reviewsCount} {t('accommodations.detail.reviewsLabel')})
      </span>
    </div>
  )}
</header>

<style>
  .detail-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 8px);
    transition: flex-direction 0.3s ease, gap 0.3s ease;
  }
  .detail-header__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2, 8px);
    align-items: center;
    transition: gap 0.3s ease;
  }
  .detail-header__type-badge {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 14px;
    border-radius: var(--radius-pill);
    background-color: var(--brand-secondary-foreground);
    color: var(--primary-foreground);
    transition: padding 0.3s ease, font-size 0.3s ease;
  }
  .detail-header__status-badge {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 4px 14px;
    border-radius: var(--radius-pill);
    border: 1px solid;
    transition: padding 0.3s ease, font-size 0.3s ease;
  }
  .detail-header__name {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--foreground);
    margin: 0;
    line-height: 1.15;
    transition: font-size 0.3s ease;
  }
  .detail-header__destination {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--primary);
    text-decoration: none;
    transition: font-size 0.3s ease;
  }
  .detail-header__destination:hover {
    text-decoration: underline;
  }
  .detail-header__rating {
    display: flex;
    align-items: center;
    gap: var(--space-2, 8px);
    overflow: hidden;
    max-height: 3em;
    opacity: 1;
    transition:
      max-height 0.3s ease,
      opacity 0.2s ease;
  }
  .detail-header__reviews-count {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--muted-foreground);
  }

  /* =========================================================
   * Compact state: triggered by .wave-header--compact ancestor.
   * Badges + name + destination flow into a single horizontal line.
   * Rating collapses.
   * ========================================================= */
  :global(.wave-header--compact) .detail-header {
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2, 8px);
  }

  :global(.wave-header--compact) .detail-header__badges {
    gap: 4px;
  }

  :global(.wave-header--compact) .detail-header__type-badge,
  :global(.wave-header--compact) .detail-header__status-badge {
    font-size: 0.6rem;
    padding: 2px 10px;
  }

  :global(.wave-header--compact) .detail-header__name {
    font-size: clamp(1rem, 2vw, 1.25rem);
  }

  /* Dot separator before destination in compact mode */
  :global(.wave-header--compact) .detail-header__destination::before {
    content: '\00B7';
    margin-right: 0.35em;
    color: var(--muted-foreground);
    font-weight: 700;
  }

  :global(.wave-header--compact) .detail-header__destination {
    font-size: 0.85rem;
  }

  :global(.wave-header--compact) .detail-header__rating {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .detail-header,
    .detail-header__type-badge,
    .detail-header__status-badge,
    .detail-header__name,
    .detail-header__destination,
    .detail-header__rating {
      transition: none;
    }
  }
</style>
