---
/**
 * @file DetailHeader.astro
 * @description Accommodation detail page header with name, type badge,
 * destination, status pills, rating, favorite button, and bookmark counter.
 *
 * Type pill is delegated to the shared `AccommodationTypeBadge` (single
 * source of truth for type colour/label across the app). Status pills
 * (featured/new) use the generic `Badge` primitive. The compact-mode
 * overrides for the wave header poke at the type badge through CSS custom
 * properties exposed by the badge component.
 *
 * FavoriteButton is a React island hydrated with `client:load` (it is
 * above the fold on detail pages). The bookmark counter is a static
 * non-clickable text element shown when `bookmarkCount` is provided.
 */
import type { AccommodationDetailData } from '@/data/types';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { getBadgeStatusColor } from '@/lib/colors';
import AccommodationTypeBadge from '@/components/shared/ui/AccommodationTypeBadge.astro';
import Badge from '@/components/shared/ui/Badge.astro';
import RatingStars from '@/components/shared/ui/RatingStars.astro';
import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';

interface Props {
  readonly accommodation: AccommodationDetailData;
  readonly lang: string;
  /** Whether the current user is authenticated. Defaults to false. */
  readonly isAuthenticated?: boolean;
  /** UUID of the accommodation — used by FavoriteButton. */
  readonly accommodationId: string;
  /** Pre-hydrated favorite state from a server-side check. */
  readonly initialIsFavorited?: boolean;
  /** Bookmark ID when the entity is already favorited on page load. */
  readonly initialBookmarkId?: string | null;
  /**
   * Pre-fetched public bookmark count.
   * When undefined the counter is not rendered (parent opted out of pre-fetch).
   */
  readonly bookmarkCount?: number;
}

const {
  accommodation,
  lang,
  isAuthenticated = false,
  accommodationId,
  initialIsFavorited,
  initialBookmarkId = null,
  bookmarkCount
} = Astro.props;
const locale = lang as SupportedLocale;
const { t, tPlural } = createTranslations(locale);

const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
const isNew = (Date.now() - new Date(accommodation.createdAt).getTime()) < THIRTY_DAYS_MS;

const featuredColors = getBadgeStatusColor({ status: 'featured' });
const newColors = getBadgeStatusColor({ status: 'new' });
---

<header class="detail-header">
  <div class="detail-header__top-row">
    <div class="detail-header__badges">
      <AccommodationTypeBadge
        type={accommodation.type}
        locale={locale}
        size="sm"
        class="detail-header__type-badge"
      />
      {accommodation.isFeatured && (
        <Badge
          label={t('accommodations.detail.badges.featured')}
          colorScheme={featuredColors}
          size="sm"
          class="detail-header__status-badge"
        />
      )}
      {isNew && (
        <Badge
          label={t('accommodations.detail.badges.new')}
          colorScheme={newColors}
          size="sm"
          class="detail-header__status-badge"
        />
      )}
    </div>

    <FavoriteButton
      client:load
      entityId={accommodationId}
      entityType="ACCOMMODATION"
      initialIsFavorited={initialIsFavorited}
      initialBookmarkId={initialBookmarkId}
      isAuthenticated={isAuthenticated}
      variant="standalone"
      locale={locale}
      class="detail-header__favorite-btn"
    />
  </div>

  <h1 class="detail-header__name">{accommodation.name}</h1>

  <a href={`/${lang}/destinos/${accommodation.destination.slug}`} class="detail-header__destination">
    {accommodation.destination.name}
  </a>

  {accommodation.averageRating > 0 && (
    <div class="detail-header__rating">
      <RatingStars rating={accommodation.averageRating} />
      <span class="detail-header__reviews-count">
        ({accommodation.reviewsCount} {t('accommodations.detail.reviewsLabel')})
      </span>
      {bookmarkCount !== undefined && (
        <span
          class="detail-header__bookmark-count"
          aria-label={bookmarkCount === 0
            ? t('accommodations.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
            : tPlural('accommodations.detail.bookmark_count', bookmarkCount)}
        >
          <span class="detail-header__bookmark-icon" aria-hidden="true">♥</span>
          {bookmarkCount === 0
            ? t('accommodations.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
            : tPlural('accommodations.detail.bookmark_count', bookmarkCount)}
        </span>
      )}
    </div>
  )}

  {accommodation.averageRating === 0 && bookmarkCount !== undefined && (
    <div class="detail-header__rating">
      <span
        class="detail-header__bookmark-count"
        aria-label={bookmarkCount === 0
          ? t('accommodations.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
          : tPlural('accommodations.detail.bookmark_count', bookmarkCount)}
      >
        <span class="detail-header__bookmark-icon" aria-hidden="true">♥</span>
        {bookmarkCount === 0
          ? t('accommodations.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
          : tPlural('accommodations.detail.bookmark_count', bookmarkCount)}
      </span>
    </div>
  )}
</header>

<style>
  .detail-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 8px);
    transition: flex-direction 0.3s ease, gap 0.3s ease;
  }

  /* Top row: badges on the left, favorite button on the right */
  .detail-header__top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2, 8px);
  }

  .detail-header__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2, 8px);
    align-items: center;
    transition: gap 0.3s ease;
  }

  /* Bookmark count pill (non-interactive, info only) */
  .detail-header__bookmark-count {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted-foreground);
    border-left: 1px solid var(--border);
    padding-left: var(--space-2, 8px);
    margin-left: var(--space-1, 4px);
  }

  .detail-header__bookmark-icon {
    font-size: 0.75rem;
    color: var(--destructive);
    line-height: 1;
  }

  /* Status pills (featured / new): the shared Badge primitive owns the
   * colours; we just tighten the typography to match the type badge. */
  :global(.detail-header__status-badge) {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 4px 14px;
    transition: padding 0.3s ease, font-size 0.3s ease;
  }

  .detail-header__name {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--foreground);
    margin: 0;
    line-height: 1.15;
    transition: font-size 0.3s ease;
  }
  .detail-header__destination {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--primary);
    text-decoration: none;
    transition: font-size 0.3s ease;
  }
  .detail-header__destination:hover {
    text-decoration: underline;
  }
  .detail-header__rating {
    display: flex;
    align-items: center;
    gap: var(--space-2, 8px);
    overflow: hidden;
    max-height: 3em;
    opacity: 1;
    transition:
      max-height 0.3s ease,
      opacity 0.2s ease;
  }
  .detail-header__reviews-count {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--muted-foreground);
  }

  /* =========================================================
   * Compact state: triggered by .wave-header--compact ancestor.
   * Badges + name + destination flow into a single horizontal line.
   * Rating collapses.
   * ========================================================= */
  :global(.wave-header--compact) .detail-header {
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2, 8px);
  }

  :global(.wave-header--compact) .detail-header__top-row {
    gap: 4px;
  }

  :global(.wave-header--compact) .detail-header__badges {
    gap: 4px;
  }

  /* Type badge shrinks via the custom properties exposed by
   * AccommodationTypeBadge — no `!important`, no fighting child styles. */
  :global(.wave-header--compact .detail-header__type-badge) {
    --acc-type-font-size: 0.6rem;
    --acc-type-padding: 2px 10px;
  }
  :global(.wave-header--compact .detail-header__status-badge) {
    font-size: 0.6rem;
    padding: 2px 10px;
  }

  :global(.wave-header--compact) .detail-header__name {
    font-size: clamp(1rem, 2vw, 1.25rem);
  }

  /* Dot separator before destination in compact mode */
  :global(.wave-header--compact) .detail-header__destination::before {
    content: '\00B7';
    margin-right: 0.35em;
    color: var(--muted-foreground);
    font-weight: 700;
  }

  :global(.wave-header--compact) .detail-header__destination {
    font-size: 0.85rem;
  }

  :global(.wave-header--compact) .detail-header__rating {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .detail-header,
    :global(.detail-header__status-badge),
    .detail-header__name,
    .detail-header__destination,
    .detail-header__rating {
      transition: none;
    }
    /* Type badge: AccommodationTypeBadge owns its own reduced-motion rule. */
  }
</style>
