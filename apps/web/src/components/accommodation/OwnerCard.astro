---
/**
 * @file OwnerCard.astro
 * @description Owner card with avatar, name, member since, and contact island.
 */
import type { AccommodationOwnerData } from '@/data/types';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { getInitials } from '@/lib/api/transforms';
import GradientButton from '@/components/shared/ui/GradientButton.astro';

interface Props {
  readonly owner: AccommodationOwnerData;
  readonly accommodationId: string;
  readonly userId: string | null;
  readonly lang: string;
}

const { owner, accommodationId, userId, lang } = Astro.props;
const { t } = createTranslations(lang as SupportedLocale);

const initials = getInitials(owner.name);
const memberDate = new Date(owner.createdAt).toLocaleDateString(
  lang === 'pt' ? 'pt-BR' : lang === 'en' ? 'en-US' : 'es-AR',
  { year: 'numeric', month: 'long' }
);
---

<div class="owner-card">
  <div class="owner-card__header">
    {owner.image ? (
      <img src={owner.image} alt={owner.name} class="owner-card__avatar" loading="lazy" />
    ) : (
      <div class="owner-card__avatar-fallback" aria-hidden="true">
        {initials}
      </div>
    )}
    <div class="owner-card__info">
      <span class="owner-card__name">{owner.name}</span>
      <span class="owner-card__member">{t('accommodations.detail.owner.memberSince', undefined, { date: memberDate })}</span>
    </div>
  </div>

  <div class="owner-card__contact" id="contact">
    {userId ? (
      <div class="owner-card__island-placeholder">
        <!-- OwnerContact React island will be rendered here by the page orchestrator -->
        <slot />
      </div>
    ) : (
      <div class="owner-card__register-cta-wrapper">
        <GradientButton
          href={`/${lang}/auth/signin`}
          label={t('accommodations.detail.owner.registerToContact')}
          variant="outline-primary"
          size="sm"
          shape="rounded"
          class="owner-card__register-cta"
        />
      </div>
    )}
  </div>
</div>

<style>
  .owner-card {
    background-color: var(--card);
    border-radius: var(--radius-card, 24px);
    padding: var(--space-5, 20px);
    box-shadow: var(--shadow-card);
  }
  .owner-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-3, 12px);
    margin-bottom: var(--space-4, 16px);
  }
  .owner-card__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .owner-card__avatar-fallback {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: var(--primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.2rem;
    flex-shrink: 0;
  }
  .owner-card__info {
    display: flex;
    flex-direction: column;
  }
  .owner-card__name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--foreground);
  }
  .owner-card__member {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--muted-foreground);
  }
  .owner-card__register-cta-wrapper {
    display: flex;
  }
  .owner-card__register-cta {
    flex: 1;
    justify-content: center;
  }
</style>
