---
/**
 * @file OwnerCard.astro
 * @description Owner card with avatar, name, member since, and contact island.
 */
import type { AccommodationOwnerData } from '@/data/types';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { getInitialsFromName } from '@/lib/avatar-utils';
import { getMediaUrl } from '@repo/media';

interface Props {
  readonly owner: AccommodationOwnerData;
  readonly accommodationId: string;
  readonly userId: string | null;
  readonly lang: string;
}

const { owner, accommodationId: _accommodationId, userId: _userId, lang } = Astro.props;
const { t } = createTranslations(lang as SupportedLocale);

const initials = getInitialsFromName(owner.name);
const memberDate = new Date(owner.createdAt).toLocaleDateString(
  lang === 'pt' ? 'pt-BR' : lang === 'en' ? 'en-US' : 'es-AR',
  { year: 'numeric', month: 'long' }
);
const ownerAvatarUrl = owner.image
  ? getMediaUrl(owner.image, { preset: 'avatar' })
  : null;
---

<div class="owner-card">
  <div class="owner-card__header">
    <div class="owner-card__avatar-wrapper">
      {ownerAvatarUrl && (
        <img
          src={ownerAvatarUrl}
          alt={owner.name}
          class="owner-card__avatar"
          width="56"
          height="56"
          loading="lazy"
          decoding="async"
          data-hide-on-error
        />
      )}
      <div class="owner-card__avatar-fallback" aria-hidden={ownerAvatarUrl ? 'true' : undefined}>
        {initials}
      </div>
    </div>
    <div class="owner-card__info">
      <span class="owner-card__name">{owner.name}</span>
      <span class="owner-card__member">{t('accommodations.detail.owner.memberSince', undefined, { date: memberDate })}</span>
    </div>
  </div>

  <div class="owner-card__contact" id="contact">
    <div class="owner-card__island-placeholder">
      <!-- ContactHost React island will be rendered here by the page orchestrator -->
      <slot />
    </div>
  </div>
</div>

<style>
  .owner-card {
    position: relative;
    background-color: var(--core-card);
    border-radius: var(--radius-card, 24px);
    padding: var(--space-6, 24px) var(--space-5, 20px) var(--space-5, 20px);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: transform 200ms ease-out, box-shadow 200ms ease-out;
  }
  .owner-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--brand-primary) 0%, var(--brand-accent) 100%);
  }
  .owner-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover, var(--shadow-card));
  }
  .owner-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-3, 12px);
    margin-bottom: var(--space-4, 16px);
    padding-bottom: var(--space-4, 16px);
    border-bottom: 1px solid var(--border);
  }
  .owner-card__avatar-wrapper {
    position: relative;
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: 50%;
    box-shadow: 0 0 0 3px var(--core-card), 0 0 0 4px var(--brand-primary-a25);
  }
  .owner-card__avatar {
    position: relative;
    z-index: 1;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    background-color: var(--brand-primary);
  }
  .owner-card__avatar-fallback {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background-color: var(--brand-primary);
    color: var(--primary-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.2rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .owner-card,
    .owner-card:hover {
      transform: none;
      transition: none;
    }
  }
  .owner-card__info {
    display: flex;
    flex-direction: column;
  }
  .owner-card__name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--core-foreground);
  }
  .owner-card__member {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--core-muted-foreground);
  }
  .owner-card__register-cta-wrapper {
    display: flex;
  }
  .owner-card__register-cta {
    flex: 1;
    justify-content: center;
  }
</style>
