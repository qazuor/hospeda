---
/**
 * Search bar for accommodations page. Native HTML form (no JS required).
 * Submits GET request preserving other query params as hidden inputs.
 */
import { SearchIcon } from '@repo/icons';
import { t, type SupportedLocale } from '../../lib/i18n';

interface Props {
    /** Current search query */
    readonly query?: string;
    /** Current locale */
    readonly locale?: string;
    /** Other query params to preserve on submit */
    readonly preserveParams?: Record<string, string>;
}

const { query = '', locale = 'es', preserveParams = {} } = Astro.props;
const loc = locale as SupportedLocale;

const placeholder = t({ locale: loc, namespace: 'accommodations', key: 'search.placeholder' });
const buttonLabel = t({ locale: loc, namespace: 'accommodations', key: 'search.button' });

/** Params to carry forward as hidden inputs (exclude 'q' and 'page') */
const hiddenParams = Object.entries(preserveParams).filter(
    ([key]) => key !== 'q' && key !== 'page'
);
---

<form method="get" action="" class="relative w-full" role="search">
    {/* Preserve existing filter params */}
    {hiddenParams.map(([key, value]) => (
        <input type="hidden" name={key} value={value} />
    ))}

    <div class="relative">
        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4">
            <SearchIcon size={20} className="text-text-tertiary" aria-hidden="true" />
        </div>
        <input
            type="text"
            name="q"
            value={query}
            placeholder={placeholder}
            class="w-full rounded-full border border-border bg-surface py-3 pl-11 pr-24 text-sm text-text placeholder:text-text-tertiary focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-colors"
            aria-label={placeholder}
        />
        <button
            type="submit"
            class="absolute inset-y-1.5 right-1.5 rounded-full bg-primary px-5 text-sm font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary/50"
        >
            {buttonLabel}
        </button>
    </div>
</form>
