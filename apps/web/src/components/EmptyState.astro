---
/**
 * @file EmptyState.astro
 * @description Generic empty state component. Shows an optional icon, a bold
 * title in the heading font, a muted description, and an optional CTA via slot.
 *
 * The action slot is omitted entirely when no slot content is provided, avoiding
 * empty containers in the output.
 *
 * @example
 * ```astro
 * <!-- With CTA slot -->
 * <EmptyState
 *   title="No hay resultados"
 *   description="Intentá con otros filtros o buscá algo diferente."
 * >
 *   <a href="/es/alojamientos/" class="btn">Ver todos los alojamientos</a>
 * </EmptyState>
 *
 * <!-- Without CTA -->
 * <EmptyState
 *   icon={SearchIcon}
 *   title="Sin favoritos"
 *   description="Aún no tenés alojamientos favoritos."
 * />
 * ```
 */

// Astro supports passing any component as a prop via `any` — we use an
// intentional union type that matches Phosphor/icon shapes used across the app.
// biome-ignore lint/suspicious/noExplicitAny: Icon component passed as prop cannot be more specific without coupling to @repo/icons internals
type IconComponent = (props: Record<string, unknown>) => unknown;

interface Props {
    /** Bold heading text displayed below the icon */
    readonly title: string;
    /** Secondary muted description text */
    readonly description: string;
    /**
     * Optional icon component from @repo/icons.
     * Rendered at 48px with aria-hidden.
     */
    readonly icon?: IconComponent;
}

const { title, description, icon: Icon } = Astro.props;

const hasSlot = Astro.slots.has('default');
---

<div class="empty-state" role="status" aria-live="polite">
    {Icon && (
        <div class="empty-state__icon-wrapper" aria-hidden="true">
            <Icon size={48} weight="duotone" aria-hidden="true" />
        </div>
    )}

    <h2 class="empty-state__title">{title}</h2>
    <p class="empty-state__description">{description}</p>

    {hasSlot && (
        <div class="empty-state__action">
            <slot />
        </div>
    )}
</div>

<style>
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        width: 100%;
        max-width: 500px;
        margin-inline: auto;
        padding: var(--space-section-sm, 2.5rem) var(--space-container-x, 1.5rem);
        gap: 1rem;
    }

    .empty-state__icon-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 5rem;
        height: 5rem;
        border-radius: 50%;
        background-color: var(--brand-primary-a08);
        color: var(--brand-primary);
        flex-shrink: 0;
    }

    .empty-state__title {
        font-family: var(--font-heading);
        font-size: var(--text-h3, 1.375rem);
        font-weight: 700;
        color: var(--core-foreground);
        margin: 0;
        line-height: 1.3;
    }

    .empty-state__description {
        font-family: var(--font-sans);
        font-size: var(--text-body, 1rem);
        color: var(--core-muted-foreground);
        margin: 0;
        line-height: 1.6;
    }

    .empty-state__action {
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
</style>
