---
/**
 * @file AuthSection.astro
 * @description Server Island that resolves authentication state at request time.
 *
 * Intended for use with `server:defer` in the site header so auth state is
 * always fresh, even when the surrounding page is pre-rendered (SSG).
 *
 * The middleware populates `Astro.locals.user` for:
 * - Protected routes (/mi-cuenta/*) — always parsed
 * - Auth routes (/auth/*) — always parsed
 * - Server Island requests (/_server-islands/*) — always parsed
 *
 * Renders either:
 * - A `UserNav` dropdown when the user is authenticated
 * - A localized "Iniciar sesion" link when the user is not authenticated
 *
 * @example
 * ```astro
 * <AuthSection server:defer locale={locale} variant="hero">
 *   <span slot="fallback" class="auth-section__skeleton" aria-hidden="true" />
 * </AuthSection>
 * ```
 */

import { UserNav } from '../auth/UserNav.client';
import { createT, type SupportedLocale } from '../../lib/i18n';
import { buildUrl } from '../../lib/urls';

interface Props {
    /** Current locale for localized links (e.g. 'es', 'en', 'pt'). Defaults to 'es'. */
    readonly locale?: string;
    /**
     * Visual variant matching the Navbar's current scroll state.
     * Passed through to UserNav so button colours stay consistent.
     * - "hero": transparent navbar (light text on dark overlay)
     * - "scrolled": opaque navbar (dark text on light background)
     */
    readonly variant?: 'hero' | 'scrolled';
}

const { locale = 'es', variant = 'hero' } = Astro.props;
const typedLocale = locale as SupportedLocale;

const t = createT(typedLocale);
const user = Astro.locals.user;
const isAuthenticated = !!user;
---

{isAuthenticated && user ? (
    <UserNav
        client:load
        user={{
            name: user.name || 'Usuario',
            email: user.email || ''
        }}
        locale={locale}
        variant={variant}
    />
) : (
    <a
        href={buildUrl({ locale: typedLocale, path: 'auth/signin' })}
        id="navbar-signin"
        class:list={[
            'auth-section__signin-link',
            variant === 'scrolled' ? 'auth-section__signin-link--scrolled' : ''
        ]}
    >
        {t('nav.iniciarSesion', 'Iniciar sesion')}
    </a>
)}

<style>
    /*
     * Sign-in link styles mirror the static sign-in button in Navbar.astro.
     * The Navbar scroll-state script targets #navbar-signin so these classes
     * must produce the same visual output as the corresponding static button.
     */

    .auth-section__signin-link {
        display: inline-flex;
        height: 2.5rem;
        align-items: center;
        justify-content: center;
        padding-inline: 1.25rem;
        border-radius: var(--radius-pill);
        font-size: var(--text-body-sm);
        font-family: var(--font-sans);
        font-weight: 500;
        text-decoration: none;
        transition: background-color var(--duration-normal) ease,
            color var(--duration-normal) ease,
            border-color var(--duration-normal) ease;

        /* Hero (transparent) variant — light text on dark overlay */
        border: 1px solid rgba(255 255 255 / 0.35);
        color: #fff;
        background-color: rgba(255 255 255 / 0.12);
    }

    .auth-section__signin-link:hover {
        background-color: rgba(255 255 255 / 0.18);
    }

    .auth-section__signin-link--scrolled {
        border: 1px solid oklch(from var(--core-foreground) l c h / 0.2);
        color: var(--core-foreground);
        background-color: transparent;
    }

    .auth-section__signin-link--scrolled:hover {
        background-color: oklch(from var(--core-foreground) l c h / 0.05);
    }

    .auth-section__signin-link:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }
</style>
