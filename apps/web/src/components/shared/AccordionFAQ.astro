---
/**
 * @file AccordionFAQ.astro
 * @description Accordion component for displaying frequently asked questions.
 * Uses native `<details>`/`<summary>` HTML elements for zero-framework
 * progressive enhancement. A small inline script handles single-open
 * exclusivity when `allowMultiple` is false (default). The chevron icon
 * rotates via the CSS `group-open:` variant — no React hydration required.
 *
 * @example
 * ```astro
 * ---
 * import AccordionFAQ from '@/components/shared/AccordionFAQ.astro';
 * ---
 * <AccordionFAQ
 *   items={[
 *     { question: 'What is the cancellation policy?', answer: 'You can cancel up to 48 hours before check-in.' },
 *     { question: 'Are pets allowed?', answer: 'It depends on each property.' },
 *   ]}
 *   allowMultiple={false}
 * />
 * ```
 */

import { ChevronDownIcon } from '@repo/icons';

/** A single FAQ entry rendered as a disclosure widget */
interface FaqItem {
  /** Question text rendered in the `<summary>` trigger */
  readonly question: string;
  /** Answer text rendered in the expandable body */
  readonly answer: string;
}

/** Props for the AccordionFAQ component */
interface Props {
  /** Array of FAQ items to render */
  readonly items: readonly FaqItem[];
  /**
   * When `false` (default) opening one item automatically closes all siblings.
   * When `true`, any number of items can be open simultaneously.
   */
  readonly allowMultiple?: boolean;
  /**
   * Accessible label for the wrapping `<section>` element.
   * Defaults to "Frequently asked questions".
   */
  readonly ariaLabel?: string;
  /** Additional CSS classes applied to the wrapping `<section>` */
  readonly class?: string;
}

const {
  items,
  allowMultiple = false,
  ariaLabel = 'Frequently asked questions',
  class: className,
} = Astro.props;

/**
 * Unique ID prefix so that multiple accordion instances on the same page
 * do not share id attributes and break ARIA associations.
 */
const uid = Math.random().toString(36).slice(2, 8);
---

<section
  class:list={['space-y-2', className]}
  aria-label={ariaLabel}
  data-accordion
  data-allow-multiple={allowMultiple ? 'true' : 'false'}
>
  {items.map((item, index) => {
    const summaryId = `${uid}-summary-${index}`;
    const contentId = `${uid}-content-${index}`;

    return (
      <details
        id={`${uid}-item-${index}`}
        class="group rounded-lg border border-border transition-colors duration-200 open:border-primary/40"
      >
        {/*
          `list-none` removes the default disclosure triangle in WebKit.
          `cursor-pointer` and `select-none` improve UX.
          `focus-visible` ring provides keyboard accessibility.
        */}
        <summary
          id={summaryId}
          class="flex w-full cursor-pointer select-none list-none items-center justify-between rounded-lg px-4 py-3 transition-colors duration-150 hover:bg-muted focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2"
          aria-controls={contentId}
        >
          <span class="pr-4 font-semibold text-foreground">
            {item.question}
          </span>
          {/*
            `group-open:rotate-180` rotates the chevron 180° when the parent
            <details> has the `open` attribute, driven entirely by CSS.
          */}
          <span
            class="flex-shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-180"
            aria-hidden="true"
          >
            <ChevronDownIcon size="sm" weight="bold" color="currentColor" />
          </span>
        </summary>

        <div
          id={contentId}
          role="region"
          aria-labelledby={summaryId}
          class="px-4 pt-1 pb-4 text-muted-foreground leading-relaxed"
        >
          {item.answer}
        </div>
      </details>
    );
  })}
</section>

<!--
  Inline script: closes sibling <details> elements when one is opened,
  implementing single-open (accordion) behaviour. The script reads the
  `data-allow-multiple` attribute so it is inert when `allowMultiple=true`.
  Event delegation is used so the listener survives Astro View Transitions
  without double-binding (each `astro:page-load` re-scans the DOM).
-->
<script>
  /**
   * Initialises accordion exclusivity for all `[data-accordion]` sections
   * with `data-allow-multiple="false"` found inside `root`.
   *
   * Safe to call multiple times: the `data-accordion-init` flag prevents
   * duplicate listeners from being attached.
   */
  function initAccordions(root: Document | Element = document): void {
    const accordions = root.querySelectorAll<HTMLElement>(
      '[data-accordion][data-allow-multiple="false"]:not([data-accordion-init])',
    );

    for (const accordion of accordions) {
      accordion.dataset.accordionInit = 'true';

      accordion.addEventListener(
        'toggle',
        (event: Event) => {
          const target = event.target as HTMLDetailsElement;
          if (!target.open) return;

          const siblings = accordion.querySelectorAll<HTMLDetailsElement>('details');
          for (const sibling of siblings) {
            if (sibling !== target && sibling.open) {
              sibling.open = false;
            }
          }
        },
        { capture: true },
      );
    }
  }

  // Initial page load
  initAccordions();

  // Re-run after each Astro View Transition navigation
  document.addEventListener('astro:page-load', () => initAccordions());
</script>
