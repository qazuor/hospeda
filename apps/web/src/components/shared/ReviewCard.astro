---
/**
 * @file ReviewCard.astro
 * @description Card component for displaying a guest testimonial/review.
 * Features a decorative quote icon, star rating via StarsDisplay,
 * review text, and reviewer info (name, location, accommodation).
 */
import { QuotesIcon } from "@repo/icons";
import StarsDisplay from "@/components/shared/StarsDisplay.astro";
import type { Review } from "@/data/types";

/**
 * Props for the ReviewCard component.
 * @property review - Review data containing rating, text, and reviewer details
 */
interface Props {
  /** Review data with rating, text, name, location, and accommodation */
  readonly review: Review;
}

const { review } = Astro.props;
---

<blockquote class="relative flex flex-col gap-4 rounded-2xl bg-card p-6 shadow-card transition-all duration-300 hover:shadow-card-hover">
  <QuotesIcon size={32} className="absolute right-4 top-4 text-primary/10" />
  <!-- Stars -->
  <StarsDisplay count={review.rating} />
  <p class="text-sm leading-relaxed text-card-foreground">"{review.text}"</p>
  <div class="mt-auto flex items-center gap-3 border-t border-border pt-4">
    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground">
      {review.name[0]}
    </div>
    <div>
      <p class="text-sm font-semibold text-card-foreground">{review.name}</p>
      <p class="text-xs text-muted-foreground">{review.location} &middot; {review.accommodation}</p>
    </div>
  </div>
</blockquote>
