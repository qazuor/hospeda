---
/**
 * @file EmptyState.astro
 * @description Empty state component shown when no results match filters
 * or a collection is genuinely empty. Two variants: "no-results" and "empty".
 *
 * Optional `tone` prop tints the surface (`muted` default, `warm`, or `brand`).
 *
 * Optional default slot replaces the built-in SVG icon. Use it to inject a
 * Phosphor/`@repo/icons` component for richer visuals.
 *
 * @example
 * ```astro
 * <EmptyState
 *   locale={locale}
 *   variant="empty"
 *   message="No upcoming events"
 *   actionUrl="/events"
 *   actionLabel="View all events"
 *   tone="warm"
 * >
 *   <CalendarIcon size={48} weight="duotone" />
 * </EmptyState>
 * ```
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';

/**
 * A removable chip showing one of the filters currently applied.
 * Tapping the chip navigates to a URL without that filter.
 */
export interface ActiveFilterChip {
	readonly label: string;
	readonly removeUrl: string;
}

/**
 * A secondary recovery action shown below the primary "clear filters"
 * button when the user lands on an empty result set with filters applied.
 */
export interface EmptyStateSuggestion {
	readonly label: string;
	readonly url: string;
}

interface Props {
	readonly locale: SupportedLocale;
	/** "no-results" shows clear-filters link, "empty" shows a link to related content. */
	readonly variant?: 'no-results' | 'empty';
	/** Main message text. Falls back to i18n defaults per variant. */
	readonly message?: string;
	/** Link URL for the action button. */
	readonly actionUrl?: string;
	/** Link label for the action button. */
	readonly actionLabel?: string;
	/**
	 * Currently-applied filters rendered as removable chips above the
	 * primary action. Empty / omitted hides the chip group entirely.
	 */
	readonly activeFilters?: ReadonlyArray<ActiveFilterChip>;
	/**
	 * Secondary recovery links rendered below the primary action.
	 * Useful for "browse popular", "open map view", "see all destinations".
	 */
	readonly suggestions?: ReadonlyArray<EmptyStateSuggestion>;
	/** Visual tone of the empty state surface. Defaults to "muted". */
	readonly tone?: 'muted' | 'warm' | 'brand';
	readonly class?: string;
}

const {
	locale,
	variant = 'no-results',
	message,
	actionUrl,
	actionLabel,
	activeFilters,
	suggestions,
	tone = 'muted',
	class: className,
} = Astro.props;

const t = createT(locale);

const defaultMessages = {
	'no-results': t('ui.emptyState.noResults', 'No se encontraron resultados para los filtros seleccionados.'),
	'empty': t('ui.emptyState.empty', 'No hay contenido disponible en este momento.'),
} as const;

const defaultActions = {
	'no-results': t('ui.emptyState.clearFilters', 'Limpiar filtros'),
	'empty': t('ui.emptyState.explore', 'Explorar'),
} as const;

const resolvedMessage = message ?? defaultMessages[variant];
const resolvedActionLabel = actionLabel ?? defaultActions[variant];

const activeFiltersHeading = t(
	'ui.emptyState.activeFiltersHeading',
	'Filtros aplicados (tocá uno para quitarlo):',
);
const removeFilterAriaPrefix = t('ui.emptyState.removeFilter', 'Quitar filtro');
const suggestionsHeading = t('ui.emptyState.suggestionsHeading', 'O probá:');

const hasActiveFilters = Array.isArray(activeFilters) && activeFilters.length > 0;
const hasSuggestions = Array.isArray(suggestions) && suggestions.length > 0;

/**
 * Detect whether the caller passed a custom icon via the default slot. When
 * present, it replaces the built-in SVG fallback.
 */
const hasIconSlot = Astro.slots.has('default');
---

<div class:list={[
	'empty-state',
	`empty-state--${variant}`,
	`empty-state--tone-${tone}`,
	className,
]}>
	<div class="empty-state__icon" aria-hidden="true">
		{hasIconSlot ? (
			<slot />
		) : (
			<svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
				{variant === 'no-results' ? (
					<>
						<circle cx="28" cy="28" r="18" stroke="var(--core-muted-foreground)" stroke-width="2" opacity="0.3" />
						<line x1="40" y1="40" x2="54" y2="54" stroke="var(--core-muted-foreground)" stroke-width="2" stroke-linecap="round" opacity="0.3" />
					</>
				) : (
					<>
						<rect x="12" y="16" width="40" height="32" rx="8" stroke="var(--core-muted-foreground)" stroke-width="2" opacity="0.3" />
						<line x1="24" y1="30" x2="40" y2="30" stroke="var(--core-muted-foreground)" stroke-width="2" stroke-linecap="round" opacity="0.3" />
						<line x1="24" y1="38" x2="34" y2="38" stroke="var(--core-muted-foreground)" stroke-width="2" stroke-linecap="round" opacity="0.3" />
					</>
				)}
			</svg>
		)}
	</div>

	<p class="empty-state__message">{resolvedMessage}</p>

	{hasActiveFilters && (
		<div class="empty-state__filters" role="group" aria-label={activeFiltersHeading}>
			<p class="empty-state__filters-heading">{activeFiltersHeading}</p>
			<ul class="empty-state__chip-list">
				{activeFilters!.map((filter) => (
					<li>
						<a
							href={filter.removeUrl}
							class="empty-state__chip"
							aria-label={`${removeFilterAriaPrefix}: ${filter.label}`}
						>
							<span>{filter.label}</span>
							<span class="empty-state__chip-x" aria-hidden="true">&times;</span>
						</a>
					</li>
				))}
			</ul>
		</div>
	)}

	{actionUrl && (
		<a href={actionUrl} class="btn-gradient btn-gradient--outline-accent">
			{resolvedActionLabel}
		</a>
	)}

	{hasSuggestions && (
		<div class="empty-state__suggestions">
			<p class="empty-state__suggestions-heading">{suggestionsHeading}</p>
			<ul class="empty-state__suggestion-list">
				{suggestions!.map((s) => (
					<li>
						<a href={s.url} class="empty-state__suggestion-link">{s.label}</a>
					</li>
				))}
			</ul>
		</div>
	)}
</div>

<script>
	/*
	 * Publish a flag on <html> while the EmptyState is mounted so the global
	 * feedback FAB can hide itself and not overlap the action button on mobile.
	 * Cleared on the next Astro page swap; the next page's own script (if any)
	 * re-publishes the flag if it also renders an EmptyState.
	 */
	document.documentElement.dataset.emptyStateVisible = '';
	document.addEventListener(
		'astro:before-swap',
		() => {
			delete document.documentElement.dataset.emptyStateVisible;
		},
		{ once: true }
	);
</script>

<style>
	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: var(--space-12) var(--space-6);
		gap: var(--space-4);
		border-radius: var(--radius-card, 12px);
	}

	/* Tone variants — surface tints layered on top of the section background. */
	.empty-state--tone-muted {
		background-color: transparent;
	}

	.empty-state--tone-warm {
		background-color: var(--brand-accent-a05);
	}

	.empty-state--tone-brand {
		background-color: var(--brand-primary-a08);
	}

	.empty-state__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--brand-accent);
	}

	.empty-state--tone-brand .empty-state__icon {
		color: var(--brand-primary);
	}

	.empty-state__message {
		font-family: var(--font-sans);
		font-size: var(--text-body-lg);
		color: var(--core-muted-foreground);
		max-width: 40ch;
		line-height: 1.6;
		margin: 0;
	}

	/* Active filters: removable chips */
	.empty-state__filters {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		max-width: 60ch;
	}

	.empty-state__filters-heading {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
		margin: 0;
	}

	.empty-state__chip-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
	}

	.empty-state__chip {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.4rem 0.75rem;
		min-height: 36px;
		background-color: var(--brand-accent-a10);
		color: var(--brand-accent);
		border: 1px solid var(--brand-accent-a30);
		border-radius: var(--radius-pill);
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		font-weight: 500;
		text-decoration: none;
		transition: background-color var(--duration-fast) ease,
			border-color var(--duration-fast) ease;
	}

	.empty-state__chip:hover {
		background-color: var(--brand-accent-a20);
		border-color: var(--brand-accent-a50);
	}

	.empty-state__chip-x {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1rem;
		height: 1rem;
		font-size: 1rem;
		line-height: 1;
		font-weight: 700;
	}

	/* Secondary recovery links */
	.empty-state__suggestions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.375rem;
		margin-top: 0.25rem;
	}

	.empty-state__suggestions-heading {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
		margin: 0;
	}

	.empty-state__suggestion-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem 1.25rem;
	}

	.empty-state__suggestion-link {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--brand-primary);
		text-decoration: underline;
		text-underline-offset: 3px;
		transition: color var(--duration-fast) ease;
	}

	.empty-state__suggestion-link:hover {
		color: var(--core-foreground);
	}
</style>
