---
/**
 * @file SortDropdown.astro
 * @description Server-rendered sort dropdown for accommodation listings.
 * Navigates to the same URL with an updated `sortBy` query parameter on change,
 * resetting the page to the first result set.
 */

import { createT, type SupportedLocale } from '../../lib/i18n';

/**
 * Props for the SortDropdown component.
 * @property currentSort - The active sort key, pre-selected in the dropdown.
 * @property locale - BCP-47 locale string used for translations.
 */
interface Props {
    /** Currently active sort value. Defaults to "featured". */
    readonly currentSort?: string;
    /** Locale string for i18n. Defaults to "es". */
    readonly locale?: string;
}

const { currentSort = 'featured', locale = 'es' } = Astro.props;

const t = createT(locale as SupportedLocale);

/** Available sort options built from i18n keys. */
const options = [
    { value: 'featured',   label: t('accommodations.sort.featured') },
    { value: 'price_asc',  label: t('accommodations.sort.price.asc') },
    { value: 'price_desc', label: t('accommodations.sort.price.desc') },
    { value: 'rating',     label: t('accommodations.sort.rating') },
    { value: 'recent',     label: t('accommodations.sort.recent') },
    { value: 'name',       label: t('accommodations.sort.name') },
] as const;
---

<div class="flex items-center gap-2">
    <label
        for="sort-select"
        class="whitespace-nowrap text-sm font-medium text-muted-foreground"
    >
        {t('accommodations.sort.title')}:
    </label>
    <select
        id="sort-select"
        class="rounded-full border border-border bg-card px-4 py-2 text-sm text-foreground transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
    >
        {options.map((opt) => (
            <option value={opt.value} selected={opt.value === currentSort}>
                {opt.label}
            </option>
        ))}
    </select>
</div>

<script>
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
    if (sortSelect) {
        sortSelect.addEventListener('change', () => {
            const url = new URL(window.location.href);
            url.searchParams.set('sortBy', sortSelect.value);
            url.searchParams.delete('page');
            window.location.href = url.toString();
        });
    }
</script>
