---
/**
 * @file ArticleCard.astro
 * @description Standard article card for the 3-column secondary row.
 * Shows category accent bar, image with overlays, category badge, tags,
 * title, excerpt, optional related entity link, author meta row and
 * a "Leer más" CTA link. Replaces VerticalArticleCard and CompactArticleCard.
 */

import type { ArticleCardBaseProps } from '@/data/types';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { formatDate } from '@/lib/format-utils';
import {
    truncateTags,
    truncateExcerpt,
    resolveEntityLink,
    resolveEntityIcon,
    formatReadingTime,
} from '@/lib/article-card-utils';
import Badge from '@/components/shared/Badge.astro';
import { getPostCategoryColor, getPostCategoryLabel, getPostCategoryEmoji } from '@/lib/colors';

interface Props {
    /** Full article card data. */
    readonly data: ArticleCardBaseProps;
    /** Active locale for URL building and translations. */
    readonly locale: SupportedLocale;
    /** Show the "🔥 Trending" overlay badge on the image. */
    readonly isTrending?: boolean;
}

const { data, locale, isTrending = false } = Astro.props;
const { t } = createTranslations(locale);

const articleUrl = buildUrl({ locale, path: `/publicaciones/${data.slug}/` });
const categoryColor = getPostCategoryColor({ category: data.category });
const categoryLabel = getPostCategoryLabel({ category: data.category, t });
const categoryEmoji = getPostCategoryEmoji({ category: data.category });
const hasImage = Boolean(data.featuredImage);

const { visible: visibleTags } = truncateTags({ tags: data.tags ?? [], maxVisible: 2 });
const { text: excerpt } = truncateExcerpt({ text: data.summary, variant: 'standard' });
const { text: readingTime } = formatReadingTime({ minutes: data.readingTimeMinutes, locale });

const entityLink = data.relatedEntity
    ? resolveEntityLink({ entity: data.relatedEntity, locale })
    : null;
const entityIcon = data.relatedEntity
    ? resolveEntityIcon({ type: data.relatedEntity.type }).icon
    : null;

const publishedDate = data.publishedAt
    ? formatDate({
        date: data.publishedAt,
        locale,
        options: { day: 'numeric', month: 'short', year: 'numeric' },
    })
    : '';

/** Muted color scheme for tag chips (secondary/faded style). */
const mutedColorScheme = {
    bg: 'oklch(from var(--core-muted-foreground) l c h / 0.08)',
    text: 'var(--core-muted-foreground)',
    border: 'oklch(from var(--core-muted-foreground) l c h / 0.20)',
};
---

<article class="article-card">
    <!-- Category accent bar -->
    <div
        class="article-card__accent-bar"
        style={`background-color: ${categoryColor.text};`}
        aria-hidden="true"
    ></div>

    <!-- Image -->
    <div class="article-card__image-wrapper">
        <!-- Placeholder always rendered behind the image -->
        <div class="article-card__placeholder" style={`background-color: ${categoryColor.bg};`} aria-hidden="true">
            <span class="article-card__placeholder-emoji">{categoryEmoji}</span>
        </div>
        {hasImage && (
            <img
                src={data.featuredImage}
                alt={data.title}
                loading="lazy"
                class="article-card__img"
                width="400"
                height="225"
                data-hide-on-error
            />
        )}
        {isTrending && (
            <span class="article-card__overlay-badge article-card__overlay-badge--trending" aria-label={t('articles.trending', 'Trending')}>
                🔥 {t('articles.trending', 'Trending')}
            </span>
        )}
        {data.isPromoted && (
            <span class="article-card__overlay-badge article-card__overlay-badge--promoted" aria-label={t('articles.promoted', 'Destacado')}>
                {t('articles.promoted', 'Destacado')}
            </span>
        )}
    </div>

    <!-- Content -->
    <div class="article-card__content">
        <!-- Category badge -->
        <div class="article-card__category">
            <Badge
                label={categoryLabel}
                colorScheme={categoryColor}
                size="sm"
            />
        </div>

        <!-- Tags -->
        {visibleTags.length > 0 && (
            <div class="article-card__tags" aria-label={t('articles.tags', 'Etiquetas')}>
                {visibleTags.map((tag) => (
                    <Badge
                        label={tag}
                        colorScheme={mutedColorScheme}
                        size="sm"
                    />
                ))}
            </div>
        )}

        <!-- Title -->
        <h3 class="article-card__title">{data.title}</h3>

        <!-- Excerpt -->
        <p class="article-card__excerpt">{excerpt}</p>

        <!-- Related entity -->
        {entityLink && entityIcon && (
            <a
                href={entityLink.href}
                class="article-card__entity-link"
                onclick="event.stopPropagation();"
            >
                <span aria-hidden="true">{entityIcon}</span>
                {entityLink.label}
            </a>
        )}

        <!-- Meta row -->
        <div class="article-card__meta">
            {data.authorName && (
                <span class="article-card__author">{data.authorName}</span>
            )}
            {data.authorName && publishedDate && (
                <span class="article-card__meta-sep" aria-hidden="true">&middot;</span>
            )}
            {publishedDate && (
                <time datetime={data.publishedAt} class="article-card__date">
                    {publishedDate}
                </time>
            )}
            {(data.authorName || publishedDate) && (
                <span class="article-card__meta-sep" aria-hidden="true">&middot;</span>
            )}
            <span class="article-card__reading-time">{readingTime}</span>
        </div>

        <!-- CTA link -->
        <a href={articleUrl} class="article-card__cta" aria-label={`${t('articles.readMore', 'Leer más')} — ${data.title}`}>
            {t('articles.readMore', 'Leer más')}
            <span class="article-card__cta-arrow" aria-hidden="true">&rarr;</span>
        </a>
    </div>
</article>

<style>
    .article-card {
        position: relative;
        display: flex;
        flex-direction: column;
        height: 100%;
        border-radius: var(--radius-card);
        background-color: var(--core-card);
        box-shadow: var(--shadow-card);
        overflow: hidden;
        transition:
            box-shadow var(--duration-normal) ease,
            transform var(--duration-normal) ease;
    }

    .article-card:hover {
        box-shadow: var(--shadow-card-hover);
        transform: translateY(-4px);
    }

    .article-card:focus-within {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    /* Accent bar */
    .article-card__accent-bar {
        height: 4px;
        width: 100%;
        flex-shrink: 0;
    }

    /* Image */
    .article-card__image-wrapper {
        position: relative;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        border-radius: 0;
    }

    .article-card__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform var(--duration-normal) ease;
    }

    .article-card:hover .article-card__img {
        transform: scale(1.04);
    }

    /* Placeholder (behind image, visible when image absent or fails) */
    .article-card__placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 0;
    }

    .article-card__placeholder-emoji {
        font-size: 3rem;
        line-height: 1;
        filter: grayscale(0.15);
        transition: transform var(--duration-normal) ease;
    }

    .article-card:hover .article-card__placeholder-emoji {
        transform: scale(1.15);
    }

    .article-card__img {
        position: relative;
        z-index: 1;
    }

    /* Overlay badges */
    .article-card__overlay-badge {
        position: absolute;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        font-weight: 600;
        padding: 0.25rem 0.625rem;
        border-radius: var(--radius-pill);
        line-height: 1;
    }

    .article-card__overlay-badge--trending {
        top: 0.625rem;
        right: 0.625rem;
        background-color: var(--brand-accent);
        color: oklch(1 0 0);
    }

    .article-card__overlay-badge--promoted {
        top: 0.625rem;
        left: 0.625rem;
        background-color: var(--brand-primary);
        color: oklch(1 0 0);
    }

    /* Content */
    .article-card__content {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 1.25rem 1.5rem;
        padding-bottom: 1.75rem;
        gap: 0.75rem;
    }

    /* Category */
    .article-card__category {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
    }

    /* Tags */
    .article-card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
    }

    /* Title */
    .article-card__title {
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 1.125rem; /* 18px */
        color: var(--core-foreground);
        line-height: 1.3;
        margin: 0;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
        transition: color var(--duration-fast) ease;
    }

    .article-card:hover .article-card__title {
        color: var(--brand-primary);
    }

    /* Excerpt */
    .article-card__excerpt {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
    }

    /* Related entity */
    .article-card__entity-link {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        color: var(--brand-primary);
        text-decoration: none;
        font-weight: 500;
        width: fit-content;
        transition: text-decoration var(--duration-fast) ease;
    }

    .article-card__entity-link:hover {
        text-decoration: underline;
    }

    /* Meta row */
    .article-card__meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.375rem;
        margin-top: auto;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        color: var(--core-muted-foreground);
    }

    .article-card__author {
        font-weight: 500;
        color: var(--core-foreground);
    }

    .article-card__meta-sep {
        color: var(--core-muted-foreground);
    }

    .article-card__date,
    .article-card__reading-time {
        white-space: nowrap;
    }

    /* CTA */
    .article-card__cta {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        font-weight: 500;
        color: var(--brand-primary);
        text-decoration: none;
        width: fit-content;
        transition: color var(--duration-fast) ease;
    }

    .article-card__cta:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
        border-radius: 2px;
    }

    .article-card__cta-arrow {
        display: inline-block;
        transition: transform var(--duration-fast) ease;
    }

    .article-card:hover .article-card__cta-arrow {
        transform: translateX(4px);
    }
</style>
