---
/**
 * @file AmenityTag.astro
 * @description Small pill tag displaying an amenity label (e.g. "Wi-Fi", "Pool").
 * Used in accommodation cards to show available features at a glance.
 */

/**
 * Props for the AmenityTag component.
 * @property amenity - Amenity label text to display
 * @property class - Additional CSS classes to merge into the tag container
 */
interface Props {
  /** Amenity label text (e.g. "Wi-Fi", "Pool", "Parking") */
  readonly amenity: string;
  /** Additional CSS classes */
  readonly class?: string;
}

const { amenity, class: className = "" } = Astro.props;
---

<span class:list={["flex items-center gap-1 rounded-full bg-muted px-2 py-0.5 text-xs-alt text-muted-foreground", className]}>
  {amenity}
</span>
