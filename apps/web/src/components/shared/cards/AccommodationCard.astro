---
/**
 * @file AccommodationCard.astro
 * @description Accommodation card matching Figma node 965:102 (ACCOMMODATION CARD V2).
 * Features: image with wave separator, status corner badge, featured badge,
 * favorite + photo count, category pill, location bar, amenities, stars, price + CTA.
 */

import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';
import {
	GalleryIcon,
	LocationIcon,
	StarIcon,
} from '@repo/icons';
import { resolveAmenityIcon } from './accommodation-card-icons';
import AccommodationTypeBadge from '@/components/shared/ui/AccommodationTypeBadge.astro';
import { formatPrice } from '@/lib/format-utils';
import { buildUrl } from '@/lib/urls';
import { createTranslations } from '@/lib/i18n';
import { Image } from 'astro:assets';
import type { AccommodationCardData } from '@/data/types';
import type { SupportedLocale } from '@/lib/i18n';

interface Props {
	readonly data: AccommodationCardData;
	readonly locale: SupportedLocale;
	/**
	 * Whether the current user is authenticated.
	 * Forwarded to FavoriteButton to decide between toggle-favorite or
	 * auth-required popover. Defaults to false (guest user).
	 */
	readonly isAuthenticated?: boolean;
	/**
	 * Optional URL search string (without leading `?`) appended to the detail
	 * link. Used to forward search context (checkIn, checkOut, adults,
	 * children) from the listing into the detail page so the contact form can
	 * pre-fill the message.
	 */
	readonly linkQuery?: string;
	/**
	 * When true, the card image renders with `loading="eager"` and
	 * `fetchpriority="high"` so the browser treats it as an LCP candidate.
	 * Set this on cards in the first visible row of a listing or featured grid.
	 * Defaults to false (lazy loading).
	 */
	readonly eager?: boolean;
}

const { data, locale, isAuthenticated = false, linkQuery, eager = false } = Astro.props;
const { t, tPlural } = createTranslations(locale);

const baseDetailUrl = buildUrl({ locale, path: `/alojamientos/${data.slug}/` });
const detailUrl = linkQuery ? `${baseDetailUrl}?${linkQuery}` : baseDetailUrl;

const formattedPrice = data.price
	? formatPrice({ amount: data.price.amount, currency: data.price.currency, locale })
	: null;

/** Maximum number of amenity icons shown in the card row. */
const MAX_AMENITIES = 4;
const visibleAmenities = (data.amenities ?? []).slice(0, MAX_AMENITIES);
const extraAmenities = Math.max(0, (data.amenities?.length ?? 0) - MAX_AMENITIES);
const fullStars = Math.floor(data.averageRating);
const hasHalfStar = data.averageRating - fullStars >= 0.5;

/** Accommodation is "new" if created less than 30 days ago. */
const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
const isNew = data.createdAt
	? (Date.now() - new Date(data.createdAt).getTime()) < THIRTY_DAYS_MS
	: false;

---

<article class="acc-card">
	<a href={detailUrl} class="acc-card__link" aria-label={data.name}>
		<!-- IMAGE AREA -->
		<div class="acc-card__image-area">
			{data.featuredImage.url && !data.featuredImage.url.includes('placeholder') ? (
				<Image
					src={data.featuredImage.url}
					alt={data.featuredImage.caption ?? data.name}
					width={432}
					height={220}
					format="webp"
					loading={eager ? 'eager' : 'lazy'}
					fetchpriority={eager ? 'high' : undefined}
					decoding="async"
					class="acc-card__img"
					data-fallback="/assets/images/placeholder-accommodation.svg"
					transition:name={`accommodation-${data.slug}`}
				/>
			) : (
				<img
					src={data.featuredImage.url || '/assets/images/placeholder-accommodation.svg'}
					alt={data.featuredImage.caption ?? data.name}
					loading={eager ? 'eager' : 'lazy'}
					fetchpriority={eager ? 'high' : undefined}
					decoding="async"
					class="acc-card__img"
					width="432"
					height="220"
					data-fallback="/assets/images/placeholder-accommodation.svg"
					transition:name={`accommodation-${data.slug}`}
				/>
			)}

			<!-- Status corner (diagonal) - shown for accommodations created in the last 30 days -->
			{isNew && (
				<div
					class="acc-card__status-corner"
					aria-hidden="true"
				>
					<span class="acc-card__status-text">{t('home.accommodations.badge.new', 'Nuevo')}</span>
				</div>
			)}

			<!-- Featured badge -->
			{data.isFeatured && (
				<div class="acc-card__featured-badge featured-badge">
					<StarIcon size={12} weight="fill" aria-hidden="true" />
					<span>{t('home.accommodations.badge.featured', 'Destacado')}</span>
				</div>
			)}

			<!-- Wave separator -->
			<div class="acc-card__wave" aria-hidden="true">
				<svg viewBox="0 0 432 40" preserveAspectRatio="none" fill="var(--core-card, white)">
					<path d="M0 40V22C72 8 144 0 216 6C288 12 360 24 432 22V40H0Z" />
				</svg>
			</div>

			<!-- Top right actions: FavoriteButton island + photo count -->
			<div class="acc-card__actions">
				<FavoriteButton
					client:visible
					entityId={data.id}
					entityType="ACCOMMODATION"
					initialIsFavorited={data.isFavorited}
					initialBookmarkId={data.favoriteBookmarkId ?? null}
					count={data.bookmarkCount}
					variant="standalone"
					showCount={true}
					locale={locale}
					isAuthenticated={isAuthenticated}
				/>
				{(data.photoCount ?? 0) > 0 && (
					<div class="acc-card__photo-count" aria-hidden="true">
						<GalleryIcon size={18} weight="fill" aria-hidden="true" />
						<span>{tPlural('common.photos', data.photoCount ?? 0)}</span>
					</div>
				)}
			</div>
		</div>

		<!-- CONTENT AREA -->
		<div class="acc-card__content">
			<!-- Category + Location row -->
			<div class="acc-card__category-row">
				<AccommodationTypeBadge type={data.type} locale={locale} size="xs" />
				<div class="acc-card__location-bar">
					<LocationIcon size={12} weight="fill" aria-hidden="true" />
					<span>{data.cityName ?? data.location.city}</span>
				</div>
			</div>

			<!-- Name -->
			<h3 class="acc-card__name">{data.name}</h3>

			<!-- Description -->
			<p class="acc-card__description">{data.summary}</p>

			<!-- Amenities row: dynamic loop over actual amenities data -->
			{visibleAmenities.length > 0 && (
				<div class="acc-card__amenities" aria-label={t('home.accommodations.amenities.label', 'Amenidades')}>
					{visibleAmenities.map((amenity) => {
						const IconComponent = resolveAmenityIcon(amenity);
						return (
							<span class="acc-card__amenity-icon" data-tooltip={amenity.label}>
								<IconComponent size={16} weight="regular" aria-hidden="true" />
							</span>
						);
					})}
					{extraAmenities > 0 && (
						<span class="acc-card__amenities-more">+{extraAmenities}</span>
					)}
				</div>
			)}

			<!-- Stars + rating row -->
			{data.averageRating > 0 && (
				<div class="acc-card__stars">
					{Array.from({ length: 5 }).map((_, i) => (
						<span class={i < fullStars ? 'acc-card__star--filled' : 'acc-card__star--empty'}>
							<StarIcon size={14} weight={i < fullStars ? 'fill' : 'regular'} aria-hidden="true" />
						</span>
					))}
					<span class="acc-card__rating-value">{data.averageRating.toFixed(1)}</span>
					{data.reviewsCount > 0 && (
						<span class="acc-card__reviews-count">({data.reviewsCount} {t('common.reviews', 'reseñas')})</span>
					)}
				</div>
			)}

			<!-- Divider -->
			<div class="acc-card__divider"></div>

			<!-- Price + CTA row -->
			<div class="acc-card__price-row">
				{formattedPrice ? (
					<div class="acc-card__price-block">
						<span class="acc-card__price-label">{t('home.accommodations.price.from', 'Desde')}</span>
						<span class="acc-card__price-value">{formattedPrice}</span>
						<span class="acc-card__price-label">{t('home.accommodations.price.perNight', '/noche')}</span>
					</div>
				) : (
					<div class="acc-card__price-block">
						<span class="acc-card__price-value">{t('home.accommodations.price.consult', 'Consultar')}</span>
					</div>
				)}
				<span class="acc-card__cta-btn">
					{t('common.readMore', 'Ver más')} →
				</span>
			</div>
		</div>
	</a>
</article>

<style>
	.acc-card {
		background-color: var(--core-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-md, 12px);
		box-shadow: var(--shadow-card);
		display: flex;
		flex-direction: column;
		height: 100%;
		transition: box-shadow 200ms ease-out;
	}

	.acc-card:hover {
		box-shadow: var(--shadow-card-hover);
	}

	.acc-card__link {
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.acc-card__link:focus-visible {
		outline: 2px solid var(--brand-primary);
		outline-offset: 2px;
		border-radius: var(--radius-md, 12px);
	}

	/* IMAGE AREA */
	.acc-card__image-area {
		position: relative;
		height: clamp(160px, 30vw, 220px);
		overflow: hidden;
		border-radius: var(--radius-md, 12px) var(--radius-md, 12px) 0 0;
		background-color: var(--muted);
	}

	.acc-card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 200ms ease-out;
	}

	.acc-card:hover .acc-card__img {
		transform: scale(1.08);
	}

	/* Status corner badge (diagonal) */
	.acc-card__status-corner {
		position: absolute;
		top: 0;
		left: 0;
		width: 80px;
		height: 80px;
		overflow: hidden;
	}

	.acc-card__status-corner::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 0;
		height: 0;
		/* Status corner uses the "new" badge colors. They are constants so we
		 * bake them directly instead of threading through inline style=
		 * (SPEC-046 GAP-046-09a). */
		border-top: 80px solid var(--hospeda-forest);
		border-right: 80px solid transparent;
	}

	.acc-card__status-text {
		position: absolute;
		top: 16px;
		left: 4px;
		transform: rotate(-45deg);
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 14px;
		line-height: 22.4px;
		color: var(--primary-foreground);
		white-space: nowrap;
	}

	/* Featured badge — right edge matches the actions column above
	 * (12px from card edge) so favorite, photo-count and featured stack
	 * along the same vertical guideline. Look (color/font/padding/icon
	 * gap) comes from the shared `.featured-badge` rule in components.css. */
	.acc-card__featured-badge {
		position: absolute;
		bottom: 48px;
		right: 12px;
	}

	/* Wave separator */
	.acc-card__wave {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 40px;
		pointer-events: none;
	}

	.acc-card__wave svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	/* Actions (favorite + photo count) — right-aligned column. Items have
	 * different widths (40px circle button vs. "N fotos" pill) so flex-end
	 * keeps both flush with the card's right edge, matching the featured
	 * badge below. */
	.acc-card__actions {
		position: absolute;
		top: 12px;
		right: 12px;
		display: flex;
		flex-direction: column;
		gap: 8px;
		align-items: flex-end;
	}

	.acc-card__fav-btn {
		min-width: 44px;
		min-height: 44px;
		border-radius: 9999px;
		background-color: oklch(from var(--core-card) l c h / 0.85);
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--core-foreground);
		transition: color 200ms ease-out;
	}

	.acc-card__fav-btn:hover {
		color: var(--brand-accent);
	}

	.acc-card__fav-btn:focus-visible {
		outline: 2px solid var(--brand-primary);
		outline-offset: 2px;
	}

	/* Photo-count pill: always visible. Bigger + labeled (e.g. "9 fotos")
	 * so the meaning reads at a glance, but keeps the original translucent
	 * surface so it doesn't overpower the photo. */
	.acc-card__photo-count {
		display: flex;
		align-items: center;
		gap: 6px;
		background-color: oklch(from var(--core-foreground) l c h / 0.55);
		padding: 6px 12px;
		border-radius: 9999px;
		color: var(--primary-foreground);
		font-family: var(--font-sans);
		font-weight: 600;
		font-size: 13px;
		line-height: 1.2;
	}

	/* CONTENT AREA */
	.acc-card__content {
		background-color: var(--core-card);
		padding: 0 16px 20px;
		display: flex;
		flex-direction: column;
		gap: 10px;
		flex: 1;
	}

	/* Category + Location row. The category badge is a bounded enum label
	 * (CASA, HOTEL, etc.) so it never needs to shrink — flex-shrink: 0
	 * keeps it intact. The location is the unbounded text (city names
	 * like "Concepción del Uruguay") so it absorbs the remaining width
	 * and ellipsises when it would overflow. min-width: 0 on the row is
	 * required for the inner ellipsis to engage inside a flex layout. */
	.acc-card__category-row {
		display: flex;
		align-items: center;
		gap: 10px;
		min-width: 0;
	}

	.acc-card__category-row > :global(.acc-type-badge) {
		flex-shrink: 0;
	}

	/* Destino: plain inline label, no surface. Reads as supporting text
	 * to the category pill instead of a second competing badge. */
	.acc-card__location-bar {
		display: flex;
		align-items: center;
		gap: 6px;
		min-width: 0;
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 12px;
		line-height: 1.4;
		color: var(--core-muted-foreground);
	}

	.acc-card__location-bar > :global(svg) {
		flex-shrink: 0;
	}

	.acc-card__location-bar > span {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		min-width: 0;
	}

	/* Name */
	.acc-card__name {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1rem, 0.5vw + 0.875rem, 1.25rem);
		line-height: clamp(1.375rem, 0.5vw + 1.25rem, 1.75rem);
		color: var(--core-foreground);
		overflow: hidden;
		text-overflow: ellipsis;
		margin: 0;
	}

	/* Description */
	.acc-card__description {
		font-family: var(--font-sans);
		font-weight: 400;
		font-size: clamp(0.75rem, 0.2vw + 0.625rem, 0.8125rem);
		line-height: 20.8px;
		color: var(--core-muted-foreground);
		overflow: hidden;
		text-overflow: ellipsis;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
	}

	/* Amenities */
	.acc-card__amenities {
		display: flex;
		align-items: center;
		gap: 8px;
		color: var(--core-muted-foreground);
	}

	.acc-card__amenity-icon {
		position: relative;
		display: inline-flex;
		cursor: default;
	}

	.acc-card__amenity-icon::after {
		content: attr(data-tooltip);
		position: absolute;
		bottom: calc(100% + 6px);
		left: 50%;
		transform: translateX(-50%) scale(0.9);
		background-color: var(--core-foreground);
		color: var(--core-background);
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: clamp(0.625rem, 0.15vw + 0.5rem, 0.6875rem);
		line-height: 1.3;
		padding: 4px 8px;
		border-radius: 6px;
		white-space: nowrap;
		pointer-events: none;
		opacity: 0;
		transition: opacity 150ms ease-out, transform 150ms ease-out;
		z-index: 10;
	}

	.acc-card__amenity-icon::before {
		content: '';
		position: absolute;
		bottom: calc(100% + 2px);
		left: 50%;
		transform: translateX(-50%) scale(0.9);
		border: 4px solid transparent;
		border-top-color: var(--core-foreground);
		pointer-events: none;
		opacity: 0;
		transition: opacity 150ms ease-out, transform 150ms ease-out;
		z-index: 10;
	}

	.acc-card__amenity-icon:hover::after,
	.acc-card__amenity-icon:hover::before,
	.acc-card__amenity-icon:focus-visible::after,
	.acc-card__amenity-icon:focus-visible::before,
	.acc-card__amenity-icon:focus::after,
	.acc-card__amenity-icon:focus::before {
		opacity: 1;
		transform: translateX(-50%) scale(1);
	}

	/* Touch devices: hide hover-dependent tooltip, keep icon at full scale */
	@media (hover: none) {
		.acc-card__amenity-icon {
			transform: scale(1);
		}

		.acc-card__amenity-icon::after,
		.acc-card__amenity-icon::before {
			display: none;
		}
	}

	.acc-card__amenities-more {
		font-family: var(--font-sans);
		font-weight: 400;
		font-size: 11px;
		line-height: 17.6px;
		color: var(--core-muted-foreground);
	}

	/* Stars */
	.acc-card__stars {
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.acc-card__star--filled {
		color: var(--rating-star);
		display: inline-flex;
	}

	.acc-card__star--empty {
		color: var(--core-muted-foreground);
		opacity: 0.4;
		display: inline-flex;
	}

	.acc-card__rating-value {
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 13px;
		line-height: 19.2px;
		color: var(--core-foreground);
		margin-left: 4px;
	}

	.acc-card__reviews-count {
		font-family: var(--font-sans);
		font-weight: 400;
		font-size: 12px;
		line-height: 19.2px;
		color: var(--core-muted-foreground);
	}

	/* Divider */
	.acc-card__divider {
		height: 1px;
		background-color: var(--border);
		width: 100%;
	}

	/* Price + CTA row */
	.acc-card__price-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 4px;
	}

	.acc-card__price-block {
		display: flex;
		align-items: baseline;
		gap: 4px;
		white-space: nowrap;
	}

	.acc-card__price-label {
		font-family: var(--font-sans);
		font-weight: 400;
		font-size: 11px;
		line-height: 17.6px;
		color: var(--core-muted-foreground);
	}

	.acc-card__price-value {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: 16px;
		line-height: 24px;
		color: var(--brand-accent);
	}

	.acc-card__cta-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 16px;
		border-radius: 9999px;
		font-family: var(--font-sans);
		font-weight: 500;
		font-size: 12px;
		line-height: 19.2px;
		color: var(--core-foreground);
		background: linear-gradient(135deg, var(--brand-secondary) 0%, var(--core-background) 100%);
		white-space: nowrap;
		transition: opacity 200ms ease-out;
	}

	.acc-card:hover .acc-card__cta-btn {
		opacity: 0.85;
	}

	/*
	 * Mobile density tweaks (kept at the bottom so they override the base
	 * rules above by source order — Astro scoped styles emit the same
	 * specificity for `.acc-card__content` etc., so the later declaration
	 * wins inside a matching media query).
	 *
	 * Tighter content area + 1-line description + hidden reviews count.
	 * Net effect: ~2.4 cards per viewport vs ~1.9 before, without losing
	 * amenities, stars, the numeric rating, or the price block.
	 */
	@media (max-width: 767px) {
		.acc-card__image-area {
			height: 200px;
		}

		.acc-card__content {
			gap: 6px;
			padding-bottom: 12px;
		}

		.acc-card__description {
			-webkit-line-clamp: 3;
		}

		.acc-card__reviews-count {
			display: none;
		}

		/* In mobile the image area shrinks via clamp(160px,…); placing the
		 * featured badge at bottom-right made it collide vertically with the
		 * actions column (favorite + photo count). Top-left is occupied by
		 * the "Nuevo" status corner, top-right by the actions column —
		 * bottom-left, just above the wave, is the only quadrant left clear. */
		.acc-card__featured-badge {
			bottom: 48px;
			left: 12px;
			right: auto;
			top: auto;
		}
	}
</style>
