---
/**
 * @file EventCard.astro
 * @description Card displaying event summary with 16/9 image, category badge,
 * date range, optional venue location, and summary text. Links to the event
 * detail page.
 */

import Badge from '../ui/Badge.astro';
import EventCardImage from './utils/EventCardImage.astro';
import { CalendarDotsIcon, LocationIcon } from '@repo/icons';
import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';
import { getEventCategoryColor } from '@/lib/colors';
import { buildUrl } from '@/lib/urls';
import { formatEventDate } from './utils/formatEventDate';
import type { EventCardData } from '@/data/types';
import type { SupportedLocale } from '@/lib/i18n';

/**
 * Props for the EventCard component.
 *
 * @example
 * ```astro
 * <EventCard data={eventData} locale="es" isAuthenticated={false} />
 * ```
 */
interface Props {
  /** Event data produced by toEventCardProps(). */
  readonly data: EventCardData;
  /** Active locale used to build the detail page URL and format values. */
  readonly locale: SupportedLocale;
  /**
   * Whether the current user is authenticated.
   * Forwarded to FavoriteButton to decide between toggle-favorite or
   * auth-required popover. Defaults to false (guest user).
   */
  readonly isAuthenticated?: boolean;
}

const { data, locale, isAuthenticated = false } = Astro.props;

const categoryColor = getEventCategoryColor({ category: data.category });
const detailUrl = buildUrl({ locale, path: `/eventos/${data.slug}/` });

const dateResult = formatEventDate({ start: data.date.start, end: data.date.end, locale, mode: 'short' });
const startDateLabel = dateResult.mode === 'short' ? dateResult.startLabel : '';
const endDateLabel = dateResult.mode === 'short' ? dateResult.endLabel : null;

const locationCity = data.cityName ?? data.location?.city ?? '';
const locationVenue = data.location?.name ?? '';
const locationLabel =
  locationVenue && locationCity && locationVenue.trim().toLowerCase() !== locationCity.trim().toLowerCase()
    ? `${locationVenue}, ${locationCity}`
    : locationVenue || locationCity;
---

<article class="card event-card">
  <!-- Image area -->
  <div class="card__image event-card__image">
    <a href={detailUrl} tabindex="-1" aria-hidden="true">
      <EventCardImage
        url={data.featuredImage.url}
        alt={data.featuredImage.caption ?? data.name}
        width={400}
        height={225}
        imgClass="event-card__img"
        imgStyle="border-radius: var(--radius-card);"
      />
    </a>
    <!-- FavoriteButton island: top-right over image, OUTSIDE the <a> link (HTML semantics) -->
    <div class="event-card__fav-wrapper">
      <FavoriteButton
        client:load
        entityId={data.id}
        entityType="EVENT"
        initialIsFavorited={data.isFavorited}
        initialBookmarkId={data.favoriteBookmarkId ?? null}
        count={data.bookmarkCount}
        variant="standalone"
        showCount={true}
        locale={locale}
        isAuthenticated={isAuthenticated}
      />
    </div>
  </div>

  <!-- Content area -->
  <div class="card__content">
    <!-- Category badge -->
    <div class="event-card__badge-wrapper">
      <Badge
        label={data.category}
        colorScheme={categoryColor}
        size="sm"
      />
    </div>

    <!-- Name -->
    <h3 class="event-card__name">
      <a href={detailUrl} class="event-card__name-link">
        {data.name}
      </a>
    </h3>

    <!-- Date range -->
    <p class="event-card__meta">
      <CalendarDotsIcon size={14} weight="regular" aria-hidden="true" />
      <span>
        {startDateLabel}
        {endDateLabel && (
          <> &ndash; {endDateLabel}</>
        )}
      </span>
    </p>

    <!-- Location (optional, deduped if venue equals city) -->
    {locationLabel && (
      <p class="event-card__meta event-card__meta--location">
        <LocationIcon size={14} weight="regular" aria-hidden="true" />
        <span>{locationLabel}</span>
      </p>
    )}

    <!-- Summary -->
    <p class="event-card__summary">
      {data.summary}
    </p>
  </div>
</article>

<style>
  .event-card__image {
    aspect-ratio: 16/9;
    position: relative;
  }

  .event-card__img {
    height: 100%;
  }

  /* FavoriteButton positioned top-right over the image, outside the <a> link */
  .event-card__fav-wrapper {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 1;
  }

  .event-card__badge-wrapper {
    margin-bottom: 0.75rem;
  }

  .event-card__name {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--core-foreground);
    margin-bottom: 0.5rem;
    font-size: var(--text-h4);
  }

  .event-card__name-link {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-normal) ease;
  }

  .event-card__name-link:hover {
    color: var(--brand-accent);
  }

  .event-card__meta {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-sans);
    color: var(--core-muted-foreground);
    margin-bottom: 0.5rem;
    font-size: var(--text-body-sm);
  }

  .event-card__meta--location {
    margin-bottom: 0.75rem;
  }

  .event-card__summary {
    font-family: var(--font-sans);
    color: var(--core-muted-foreground);
    font-size: var(--text-body-sm);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
