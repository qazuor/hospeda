---
/**
 * @file EventCardFeatured.astro
 * @description Featured/hero event card for the Bento Grid layout on the homepage.
 *
 * This card occupies the LEFT column spanning 2 rows in a CSS grid. It uses a
 * vertical layout: full-width image on top (~60% of height) with an overlaid
 * category badge and date block, followed by a content area below (~40%) with
 * title, summary, and optional location. A subtle featured accent line sits on
 * the left border of the card.
 *
 * Color schemes are category-aware via getEventCategoryColor(). The date block
 * background reflects the category color instead of always being blue.
 *
 * @example
 * ```astro
 * <EventCardFeatured data={featuredEvent} locale="es" />
 * ```
 */

import { Image } from 'astro:assets';
import {
  LocationIcon,
  ArrowRightIcon,
  BallroomIcon,
  SportsCenterIcon,
  CulturalCenterIcon,
  RestaurantIcon,
  FestivalPlazaIcon,
  WellnessCenterIcon,
  MuseumIcon,
  UsersIcon,
  NatureReserveIcon,
  AmphitheaterIcon,
  WorkshopSpaceIcon,
  BooksAndMagazinesIcon,
  EventIcon,
} from '@repo/icons';
import { buildUrl } from '@/lib/urls';
import { getEventCategoryColor } from '@/lib/colors';
import type { EventCardData } from '@/data/types';
import type { SupportedLocale } from '@/lib/i18n';

/**
 * Props for the EventCardFeatured component.
 *
 * @example
 * ```astro
 * <EventCardFeatured data={eventData} locale="es" />
 * ```
 */
interface Props {
  /** Event data produced by toEventCardProps(). */
  readonly data: EventCardData;
  /** Active locale used to build the detail page URL and format date values. */
  readonly locale: SupportedLocale;
}

const { data, locale } = Astro.props;

const detailUrl = buildUrl({ locale, path: `/eventos/${data.slug}/` });
const categoryColor = getEventCategoryColor({ category: data.category });

/** Locale tag used by Intl formatters. */
const bcp47: Record<SupportedLocale, string> = { es: 'es-AR', en: 'en-US', pt: 'pt-BR' };
const intlLocale = bcp47[locale];

const startDate = new Date(data.date.start);
const endDate = data.date.end ? new Date(data.date.end) : null;

/** Month abbreviation (3 chars, uppercase) from the start date. */
const monthAbbr = startDate
  .toLocaleDateString(intlLocale, { month: 'short' })
  .replace('.', '')
  .toUpperCase()
  .slice(0, 3);

/**
 * Builds the compact date display for the date block overlay.
 * Returns an object with `dateLine` (day/range + month) and an optional `timeLine`.
 */
function buildDateBlock(): { dateLine: string; timeLine: string | null } {
  const startDay = startDate.getDate();
  const startTime = startDate.toLocaleTimeString(intlLocale, {
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  });

  let dateLine: string;

  if (!endDate) {
    dateLine = `${startDay} ${monthAbbr}`;
  } else {
    const endDay = endDate.getDate();
    const endMonthAbbr = endDate
      .toLocaleDateString(intlLocale, { month: 'short' })
      .replace('.', '')
      .toUpperCase()
      .slice(0, 3);

    const sameDay =
      startDate.getDate() === endDate.getDate() &&
      startDate.getMonth() === endDate.getMonth() &&
      startDate.getFullYear() === endDate.getFullYear();

    if (sameDay) {
      dateLine = `${startDay} ${monthAbbr}`;
    } else {
      const sameMonth = startDate.getMonth() === endDate.getMonth();
      if (sameMonth) {
        dateLine = `${startDay}-${endDay} ${monthAbbr}`;
      } else {
        dateLine = `${startDay} ${monthAbbr}-${endDay} ${endMonthAbbr}`;
      }
    }
  }

  /* Determine if we should show a time line. */
  const startTimeStr = startDate.toLocaleTimeString(intlLocale, {
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  });

  let timeLine: string | null = null;

  /* Hide time when both start and end are "00:00". */
  const startIsMidnight = startTimeStr === '00:00';
  if (!startIsMidnight) {
    if (endDate) {
      const endTimeStr = endDate.toLocaleTimeString(intlLocale, {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
      });
      const endIsMidnight = endTimeStr === '00:00';
      if (!endIsMidnight) {
        timeLine = `${startTime} - ${endTimeStr}`;
      } else {
        timeLine = `${startTime}`;
      }
    } else {
      timeLine = `${startTime}`;
    }
  }

  return { dateLine, timeLine };
}

const { dateLine, timeLine } = buildDateBlock();

/**
 * Maps event category to the appropriate icon component name.
 * Returns one of the named imports defined above.
 */
type CategoryIconName =
  | 'BallroomIcon'
  | 'SportsCenterIcon'
  | 'CulturalCenterIcon'
  | 'RestaurantIcon'
  | 'FestivalPlazaIcon'
  | 'WellnessCenterIcon'
  | 'MuseumIcon'
  | 'UsersIcon'
  | 'NatureReserveIcon'
  | 'AmphitheaterIcon'
  | 'WorkshopSpaceIcon'
  | 'BooksAndMagazinesIcon'
  | 'EventIcon';

function getCategoryIconName(category: string): CategoryIconName {
  switch (category.toLowerCase()) {
    case 'music':
    case 'musica':
      return 'BallroomIcon';
    case 'sports':
    case 'deporte':
      return 'SportsCenterIcon';
    case 'cultural':
    case 'culture':
    case 'cultura':
      return 'CulturalCenterIcon';
    case 'gastronomy':
    case 'gastronomia':
      return 'RestaurantIcon';
    case 'festival':
      return 'FestivalPlazaIcon';
    case 'wellness':
    case 'bienestar':
      return 'WellnessCenterIcon';
    case 'art':
    case 'arte':
      return 'MuseumIcon';
    case 'family':
    case 'familia':
      return 'UsersIcon';
    case 'nature':
    case 'naturaleza':
      return 'NatureReserveIcon';
    case 'theater':
    case 'teatro':
      return 'AmphitheaterIcon';
    case 'workshop':
    case 'taller':
      return 'WorkshopSpaceIcon';
    case 'education':
    case 'educacion':
      return 'BooksAndMagazinesIcon';
    default:
      return 'EventIcon';
  }
}

const categoryIconName = getCategoryIconName(data.category);

/** Locale-aware category label map. */
const CATEGORY_LABELS: Record<string, Record<SupportedLocale, string>> = {
  music: { es: 'Música', en: 'Music', pt: 'Música' },
  sports: { es: 'Deportes', en: 'Sports', pt: 'Esportes' },
  cultural: { es: 'Cultural', en: 'Cultural', pt: 'Cultural' },
  culture: { es: 'Cultural', en: 'Cultural', pt: 'Cultural' },
  gastronomy: { es: 'Gastronomía', en: 'Gastronomy', pt: 'Gastronomia' },
  festival: { es: 'Festival', en: 'Festival', pt: 'Festival' },
  wellness: { es: 'Bienestar', en: 'Wellness', pt: 'Bem-estar' },
  art: { es: 'Arte', en: 'Art', pt: 'Arte' },
  family: { es: 'Familia', en: 'Family', pt: 'Família' },
  nature: { es: 'Naturaleza', en: 'Nature', pt: 'Natureza' },
  workshop: { es: 'Taller', en: 'Workshop', pt: 'Oficina' },
  education: { es: 'Educación', en: 'Education', pt: 'Educação' },
  other: { es: 'Evento', en: 'Event', pt: 'Evento' },
};

/**
 * Returns a locale-aware label for the given event category.
 * Falls back to a capitalized version of the raw category string.
 */
function getCategoryLabel(category: string, loc: SupportedLocale): string {
  const labels = CATEGORY_LABELS[category.toLowerCase()];
  if (labels) return labels[loc];
  return category.charAt(0).toUpperCase() + category.slice(1);
}

/**
 * Determines whether the featuredImage prop contains a real image URL.
 * Falls back to the decorative gradient when the value is empty or the
 * SVG placeholder path.
 */
const hasRealImage =
  Boolean(data.featuredImage) &&
  !data.featuredImage.includes('placeholder');

/**
 * Semi-transparent version of the category color used for the badge overlay.
 * We use a slightly more opaque value (0.85) for a glassy but readable look.
 */
const badgeBgSolid = categoryColor.bg.replace('/ 0.15)', '/ 0.85)');
---

<article class="event-card-featured" style={`--category-color: ${categoryColor.text};`}>
  <a href={detailUrl} class="event-card-featured__link" aria-label={data.name}>

    <!-- Featured accent line (left border decoration) -->
    <div class="event-card-featured__accent" aria-hidden="true"></div>

    <!-- Image area -->
    <div class="event-card-featured__image-wrap">
      <!-- Fallback always renders behind; shows through when no real image loads -->
      <div
        class="event-card-featured__image-fallback"
        aria-hidden="true"
        style={`background: linear-gradient(135deg, ${categoryColor.bg}, ${categoryColor.border});`}
      >
        <span class="event-card-featured__fallback-icon">
          {categoryIconName === 'BallroomIcon' && <BallroomIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'SportsCenterIcon' && <SportsCenterIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'CulturalCenterIcon' && <CulturalCenterIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'RestaurantIcon' && <RestaurantIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'FestivalPlazaIcon' && <FestivalPlazaIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'WellnessCenterIcon' && <WellnessCenterIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'MuseumIcon' && <MuseumIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'UsersIcon' && <UsersIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'NatureReserveIcon' && <NatureReserveIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'AmphitheaterIcon' && <AmphitheaterIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'WorkshopSpaceIcon' && <WorkshopSpaceIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'BooksAndMagazinesIcon' && <BooksAndMagazinesIcon size={96} weight="duotone" aria-hidden="true" />}
          {categoryIconName === 'EventIcon' && <EventIcon size={96} weight="duotone" aria-hidden="true" />}
        </span>
      </div>

      <!-- Real image on top; when it loads it covers the fallback -->
      {hasRealImage && (
        <Image
          src={data.featuredImage}
          alt=""
          width={600}
          height={260}
          format="webp"
          loading="lazy"
          class="event-card-featured__image"
          data-hide-on-error
        />
      )}

      <!-- Dark gradient overlay at the bottom of the image for readability -->
      <div class="event-card-featured__image-overlay" aria-hidden="true"></div>

      <!-- Category badge: top-left overlay -->
      <div
        class="event-card-featured__badge"
        aria-hidden="true"
        style={`background-color: ${badgeBgSolid}; color: var(--primary-foreground);`}
      >
        <span class="event-card-featured__badge-icon">
          {categoryIconName === 'BallroomIcon' && <BallroomIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'SportsCenterIcon' && <SportsCenterIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'CulturalCenterIcon' && <CulturalCenterIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'RestaurantIcon' && <RestaurantIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'FestivalPlazaIcon' && <FestivalPlazaIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'WellnessCenterIcon' && <WellnessCenterIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'MuseumIcon' && <MuseumIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'UsersIcon' && <UsersIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'NatureReserveIcon' && <NatureReserveIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'AmphitheaterIcon' && <AmphitheaterIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'WorkshopSpaceIcon' && <WorkshopSpaceIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'BooksAndMagazinesIcon' && <BooksAndMagazinesIcon size={14} weight="fill" aria-hidden="true" />}
          {categoryIconName === 'EventIcon' && <EventIcon size={14} weight="fill" aria-hidden="true" />}
        </span>
        <span class="event-card-featured__badge-label">{getCategoryLabel(data.category, locale)}</span>
      </div>

      <!-- Date block: bottom-right overlay -->
      <div
        class="event-card-featured__date-block"
        aria-hidden="true"
        style={`background-color: ${categoryColor.text};`}
      >
        <span class="event-card-featured__date-line">{dateLine}</span>
        {timeLine && (
          <span class="event-card-featured__time-line">{timeLine}</span>
        )}
      </div>
    </div>

    <!-- Content area -->
    <div class="event-card-featured__content">
      <h3 class="event-card-featured__title">{data.name}</h3>
      <p class="event-card-featured__summary">{data.summary}</p>

      {data.location && (
        <span class="event-card-featured__location">
          <LocationIcon size={13} weight="fill" aria-hidden="true" />
          <span>{data.location.name ? `${data.location.name}, ${data.location.city}` : data.location.city}</span>
        </span>
      )}

      <!-- CTA row -->
      <div class="event-card-featured__cta" aria-hidden="true">
        <ArrowRightIcon size={18} weight="bold" />
      </div>
    </div>

  </a>
</article>

<style>
  /* -------------------------------------------------------------------------
   * Block
   * ---------------------------------------------------------------------- */
  .event-card-featured {
    position: relative;
    background-color: var(--core-card);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition:
      box-shadow var(--duration-normal) ease,
      transform var(--duration-normal) ease;
    display: flex;
    flex-direction: column;
  }

  .event-card-featured:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-3px);
  }

  /* -------------------------------------------------------------------------
   * Featured accent line (left border)
   * ---------------------------------------------------------------------- */
  .event-card-featured__accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background-color: var(--category-color, var(--brand-primary));
    transition: width var(--duration-normal) ease;
    z-index: 2;
  }

  .event-card-featured:hover .event-card-featured__accent {
    width: 6px;
  }

  /* -------------------------------------------------------------------------
   * Link wrapper
   * ---------------------------------------------------------------------- */
  .event-card-featured__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  /* -------------------------------------------------------------------------
   * Image area
   * ---------------------------------------------------------------------- */
  .event-card-featured__image-wrap {
    position: relative;
    flex-shrink: 0;
    height: 260px;
    overflow: hidden;
  }

  /* Fallback gradient sits behind the real image; always rendered */
  .event-card-featured__image-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 0;
  }

  .event-card-featured__image {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 1;
    transition: transform var(--duration-normal) ease;
  }

  .event-card-featured:hover .event-card-featured__image {
    transform: scale(1.03);
  }

  .event-card-featured__fallback-icon {
    opacity: 0.25;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--category-color, var(--brand-primary));
    transform: rotate(-12deg) scale(1.2);
  }

  /* Dark gradient overlay at the bottom of the image */
  .event-card-featured__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      oklch(0.1 0 0 / 0.55) 100%
    );
    pointer-events: none;
  }

  /* -------------------------------------------------------------------------
   * Category badge (top-left over image)
   * ---------------------------------------------------------------------- */
  .event-card-featured__badge {
    position: absolute;
    top: 0.875rem;
    left: 0.875rem;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 1;
  }

  .event-card-featured__badge-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .event-card-featured__badge-label {
    line-height: 1;
  }

  /* -------------------------------------------------------------------------
   * Date block (bottom-right over image)
   * ---------------------------------------------------------------------- */
  .event-card-featured__date-block {
    position: absolute;
    bottom: 0.875rem;
    right: 0.875rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.5rem 0.875rem;
    border-radius: 10px;
    z-index: 1;
    color: var(--primary-foreground);
    min-width: 72px;
    text-align: center;
  }

  .event-card-featured__date-line {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.1;
    white-space: nowrap;
  }

  .event-card-featured__time-line {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    opacity: 0.85;
    white-space: nowrap;
  }

  /* -------------------------------------------------------------------------
   * Content area
   * ---------------------------------------------------------------------- */
  .event-card-featured__content {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 1.25rem 1.5rem 1.25rem 1.75rem; /* extra left padding for accent line */
    gap: 0.5rem;
    min-width: 0;
  }

  .event-card-featured__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: var(--core-foreground);
    line-height: 1.2;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .event-card-featured__summary {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm, 0.875rem);
    color: var(--core-muted-foreground);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .event-card-featured__location {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--brand-primary);
    background-color: oklch(from var(--brand-primary) l c h / 0.1);
    border-radius: var(--radius-pill);
    padding: 0.2rem 0.65rem;
    width: fit-content;
    font-weight: 500;
    text-decoration: none;
  }

  /* -------------------------------------------------------------------------
   * CTA arrow (bottom-right of content)
   * ---------------------------------------------------------------------- */
  .event-card-featured__cta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-top: 0.25rem;
    color: var(--brand-primary);
    transition: transform var(--duration-normal) ease;
  }

  .event-card-featured:hover .event-card-featured__cta {
    transform: translateX(4px);
  }

  /* -------------------------------------------------------------------------
   * Responsive: on mobile this card acts as a regular vertical card
   * ---------------------------------------------------------------------- */
  @media (max-width: 767px) {
    .event-card-featured__link {
      min-height: auto;
    }

    .event-card-featured__image-wrap {
      flex: 0 0 220px;
      min-height: 220px;
    }

    .event-card-featured__content {
      padding: 1rem 1.25rem 1rem 1.5rem;
    }

    .event-card-featured__title {
      font-size: 1.125rem;
    }
  }
</style>
