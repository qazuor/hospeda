---
/**
 * @file RelatedPostCard.astro
 * @description Lightweight post card for use in related content carousels.
 * Zero client-side JS. Pure Astro.
 */

import Badge from '@/components/shared/ui/Badge.astro';
import { getWarmColorScheme } from '@/lib/colors';
import { buildUrl } from '@/lib/urls';
import type { SupportedLocale } from '@/lib/i18n';

interface Props {
  readonly id: string;
  readonly slug: string;
  readonly title: string;
  readonly summary: string;
  readonly featuredImage?: string | null;
  readonly destinationName?: string | null;
  readonly publishedAt?: string | null;
  readonly lang: string;
}

const { slug, title, summary, featuredImage, destinationName, publishedAt, lang } = Astro.props;

const detailUrl = buildUrl({ locale: lang as SupportedLocale, path: `publicaciones/${slug}` });

const formattedDate = publishedAt
  ? new Date(publishedAt).toLocaleDateString(lang === 'pt' ? 'pt-BR' : lang, {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    })
  : null;

const warmColorScheme = getWarmColorScheme();
---

<article class="related-post-card">
  <a href={detailUrl} class="related-post-card__link">
    <div class="related-post-card__image-wrapper">
      {featuredImage ? (
        <img
          src={featuredImage}
          alt=""
          class="related-post-card__img"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="related-post-card__placeholder" aria-hidden="true" />
      )}
    </div>
    <div class="related-post-card__content">
      <h4 class="related-post-card__title">{title}</h4>
      <p class="related-post-card__summary">{summary}</p>
      <div class="related-post-card__meta">
        {destinationName && (
          <Badge
            label={destinationName}
            colorScheme={warmColorScheme}
            size="sm"
          />
        )}
        {formattedDate && (
          <time class="related-post-card__date" datetime={publishedAt!}>
            {formattedDate}
          </time>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .related-post-card {
    background-color: var(--core-card);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: box-shadow var(--duration-normal) ease;
  }
  .related-post-card:hover {
    box-shadow: var(--shadow-card-hover);
  }
  .related-post-card__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .related-post-card__image-wrapper {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-card);
  }
  .related-post-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) ease;
  }
  .related-post-card:hover .related-post-card__img {
    transform: scale(1.05);
  }
  .related-post-card__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--surface-warm) 0%, var(--core-card) 100%);
  }
  .related-post-card__content {
    padding: 1rem;
  }
  .related-post-card__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--core-foreground);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }
  .related-post-card__summary {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--core-muted-foreground);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .related-post-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .related-post-card__date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--core-muted-foreground);
  }
</style>
