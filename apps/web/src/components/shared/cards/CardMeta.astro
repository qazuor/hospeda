---
/**
 * @file CardMeta.astro
 * @description Reusable meta row for cards: displays author, published date and
 * reading time, each segment prefixed with its own icon. Renders nothing when
 * all props are undefined. Safe to use in any card that needs a compact
 * attribution line.
 */

import { CalendarIcon, ClockIcon, UserIcon } from '@repo/icons';
import { formatDate } from '@/lib/format-utils';
import type { SupportedLocale } from '@/lib/i18n';

interface AuthorData {
    /** Author display name. */
    readonly name: string;
    /** Optional URL for an author detail page. */
    readonly href?: string;
    /**
     * Optional avatar image URL. When provided, shown inside the circular
     * badge. Otherwise the badge falls back to a generic user icon.
     */
    readonly avatarUrl?: string;
}

interface Props {
    /** Author data. Omit entirely to hide the author segment. */
    readonly author?: AuthorData;
    /** Published date as ISO string or Date object. */
    readonly date?: string | Date;
    /** Estimated reading time in minutes. Omit to hide the segment. */
    readonly readingTimeMinutes?: number;
    /** Active locale used to format the date. */
    readonly locale: SupportedLocale;
    /** i18n suffix for reading time (e.g. "min de lectura"). */
    readonly readingTimeSuffix?: string;
}

const { author, date, readingTimeMinutes, locale, readingTimeSuffix = 'min' } = Astro.props;

const hasAuthor = Boolean(author?.name);
const hasDate = Boolean(date);
const hasReadingTime = typeof readingTimeMinutes === 'number' && readingTimeMinutes > 0;

const isEmpty = !hasAuthor && !hasDate && !hasReadingTime;

// The avatar URL is rendered raw inside the badge only when it points to a
// real image — placeholder/svg fallbacks fall through to the icon variant so
// every byline still gets a circular badge of the same shape and size.
const authorAvatarUrl = author?.avatarUrl;
const hasAuthorAvatar = Boolean(
    authorAvatarUrl
        && !authorAvatarUrl.includes('placeholder')
        && !authorAvatarUrl.endsWith('.svg')
);

const formattedDate = hasDate
    ? formatDate({
          date: date!,
          locale,
          options: { day: 'numeric', month: 'short', year: 'numeric' },
      })
    : '';
---

{!isEmpty && (
    <div class="card-meta">
        {hasAuthor && (
            author!.href
                ? (
                    <a href={author!.href} class="card-meta__item card-meta__author--link">
                        <span class="card-meta__avatar-badge" aria-hidden="true">
                            {hasAuthorAvatar ? (
                                <img
                                    src={authorAvatarUrl}
                                    alt=""
                                    class="card-meta__avatar-img"
                                    loading="lazy"
                                    width={24}
                                    height={24}
                                    data-hide-on-error
                                />
                            ) : (
                                <UserIcon size={14} weight="fill" />
                            )}
                        </span>
                        <span>{author!.name}</span>
                    </a>
                )
                : (
                    <span class="card-meta__item card-meta__author">
                        <span class="card-meta__avatar-badge" aria-hidden="true">
                            {hasAuthorAvatar ? (
                                <img
                                    src={authorAvatarUrl}
                                    alt=""
                                    class="card-meta__avatar-img"
                                    loading="lazy"
                                    width={24}
                                    height={24}
                                    data-hide-on-error
                                />
                            ) : (
                                <UserIcon size={14} weight="fill" />
                            )}
                        </span>
                        <span>{author!.name}</span>
                    </span>
                )
        )}

        {hasDate && (
            <time
                datetime={typeof date === 'string' ? date : (date as Date).toISOString()}
                class="card-meta__item card-meta__date"
            >
                <CalendarIcon size={14} weight="regular" aria-hidden="true" />
                <span>{formattedDate}</span>
            </time>
        )}

        {hasReadingTime && (
            <span class="card-meta__item card-meta__reading-time">
                <ClockIcon size={14} weight="regular" aria-hidden="true" />
                <span>{readingTimeMinutes} {readingTimeSuffix}</span>
            </span>
        )}
    </div>
)}

<style>
    .card-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.875rem;
        font-family: var(--font-sans);
        font-size: var(--text-meta);
        color: var(--core-muted-foreground);
    }

    .card-meta__item {
        display: inline-flex;
        flex-direction: row;
        align-items: center;
        gap: 0.3rem;
        white-space: nowrap;
        line-height: 1;
    }

    .card-meta__author {
        font-weight: 500;
        color: var(--core-foreground);
    }

    .card-meta__author--link {
        text-decoration: none;
        color: var(--core-foreground);
        font-weight: 500;
        transition: color var(--duration-fast) ease;
    }

    .card-meta__author--link:hover {
        color: var(--brand-primary);
    }

    .card-meta__item :global(svg) {
        display: inline-block;
        vertical-align: middle;
        flex-shrink: 0;
        opacity: 0.7;
    }

    /* Circular author badge: either an avatar image or the fallback user
       icon centered on a tinted background. Same dimensions in both
       variants so the byline never reflows. */
    .card-meta__avatar-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        flex-shrink: 0;
        overflow: hidden;
        background-color: color-mix(
            in oklab,
            var(--core-card, #fff) 60%,
            var(--brand-primary, #2563eb) 40%
        );
        color: #fff;
    }

    .card-meta__avatar-badge :global(svg) {
        opacity: 1;
    }

    .card-meta__avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
</style>
