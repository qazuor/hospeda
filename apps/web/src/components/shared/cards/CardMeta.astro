---
/**
 * @file CardMeta.astro
 * @description Reusable meta row for cards: displays author, published date and
 * reading time, each segment prefixed with its own icon. Renders nothing when
 * all props are undefined. Safe to use in any card that needs a compact
 * attribution line.
 */

import { CalendarIcon, ClockIcon, UserIcon } from '@repo/icons';
import { formatDate } from '@/lib/format-utils';
import type { SupportedLocale } from '@/lib/i18n';

interface AuthorData {
    /** Author display name. */
    readonly name: string;
    /** Optional URL for an author detail page. */
    readonly href?: string;
}

interface Props {
    /** Author data. Omit entirely to hide the author segment. */
    readonly author?: AuthorData;
    /** Published date as ISO string or Date object. */
    readonly date?: string | Date;
    /** Estimated reading time in minutes. Omit to hide the segment. */
    readonly readingTimeMinutes?: number;
    /** Active locale used to format the date. */
    readonly locale: SupportedLocale;
    /** i18n suffix for reading time (e.g. "min de lectura"). */
    readonly readingTimeSuffix?: string;
}

const { author, date, readingTimeMinutes, locale, readingTimeSuffix = 'min' } = Astro.props;

const hasAuthor = Boolean(author?.name);
const hasDate = Boolean(date);
const hasReadingTime = typeof readingTimeMinutes === 'number' && readingTimeMinutes > 0;

const isEmpty = !hasAuthor && !hasDate && !hasReadingTime;

const formattedDate = hasDate
    ? formatDate({
          date: date!,
          locale,
          options: { day: 'numeric', month: 'short', year: 'numeric' },
      })
    : '';
---

{!isEmpty && (
    <div class="card-meta">
        {hasAuthor && (
            author!.href
                ? (
                    <a href={author!.href} class="card-meta__item card-meta__author--link">
                        <UserIcon size={14} weight="regular" aria-hidden="true" />
                        <span>{author!.name}</span>
                    </a>
                )
                : (
                    <span class="card-meta__item card-meta__author">
                        <UserIcon size={14} weight="regular" aria-hidden="true" />
                        <span>{author!.name}</span>
                    </span>
                )
        )}

        {hasDate && (
            <time
                datetime={typeof date === 'string' ? date : (date as Date).toISOString()}
                class="card-meta__item card-meta__date"
            >
                <CalendarIcon size={14} weight="regular" aria-hidden="true" />
                <span>{formattedDate}</span>
            </time>
        )}

        {hasReadingTime && (
            <span class="card-meta__item card-meta__reading-time">
                <ClockIcon size={14} weight="regular" aria-hidden="true" />
                <span>{readingTimeMinutes} {readingTimeSuffix}</span>
            </span>
        )}
    </div>
)}

<style>
    .card-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.875rem;
        font-family: var(--font-sans);
        font-size: var(--text-meta);
        color: var(--core-muted-foreground);
    }

    .card-meta__item {
        display: inline-flex;
        flex-direction: row;
        align-items: center;
        gap: 0.3rem;
        white-space: nowrap;
        line-height: 1;
    }

    .card-meta__author {
        font-weight: 500;
        color: var(--core-foreground);
    }

    .card-meta__author--link {
        text-decoration: none;
        color: var(--core-foreground);
        font-weight: 500;
        transition: color var(--duration-fast) ease;
    }

    .card-meta__author--link:hover {
        color: var(--brand-primary);
    }

    .card-meta__item :global(svg) {
        display: inline-block;
        vertical-align: middle;
        flex-shrink: 0;
        opacity: 0.7;
    }
</style>
