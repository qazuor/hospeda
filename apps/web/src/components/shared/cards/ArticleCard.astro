---
/**
 * @file ArticleCard.astro
 * @description Standard article card. The entire card is a link to the post.
 * Supports category color theming, overlay badges (trending / promoted),
 * a FavoriteButton island, related-entity context chip, and a compact meta row.
 */

import type { ArticleCardBaseProps } from '@/data/types';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import {
    truncateTags,
    truncateExcerpt,
    resolveEntityLink,
    resolveEntityIcon,
} from '@/lib/article-card-utils';
import Badge from '@/components/shared/ui/Badge.astro';
import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';
import {
    getPostCategoryColor,
    getPostCategoryLabel,
    getPostCategoryEmoji,
    getBadgeStatusColor,
    getMutedColorScheme,
} from '@/lib/colors';
import CardImage from './CardImage.astro';
import CardMeta from './CardMeta.astro';
import { getExpiryStatus } from '@/lib/format-expires';

interface Props {
    /** Full article card data. */
    readonly data: ArticleCardBaseProps;
    /** Active locale for URL building and translations. */
    readonly locale: SupportedLocale;
    /** Show the trending overlay badge on the image. */
    readonly isTrending?: boolean;
    /**
     * Whether the current user is authenticated.
     * Forwarded to FavoriteButton to decide between toggle-favorite or
     * auth-required popover. Defaults to false (guest user).
     */
    readonly isAuthenticated?: boolean;
}

const { data, locale, isTrending = false, isAuthenticated = false } = Astro.props;
const { t } = createTranslations(locale);
const newsColors = { bg: 'var(--info, #0ea5e9)', text: '#fff' };

const expiryStatus = getExpiryStatus({ expiresAt: data.expiresAt });
const showExpiryBadge = expiryStatus.status === 'expiring-soon';
const expiryDays = expiryStatus.daysRemaining ?? 0;
const expiryLabel =
    expiryDays === 0
        ? t('blog.card.expiresToday', 'Expira hoy')
        : t('blog.card.expiresIn', `Expira en ${expiryDays} días`).replace('{{count}}', String(expiryDays));

const articleUrl = buildUrl({ locale, path: `/publicaciones/${data.slug}/` });
const categoryColor = getPostCategoryColor({ category: data.category });
const categoryLabel = getPostCategoryLabel({ category: data.category, t });
const categoryEmoji = getPostCategoryEmoji({ category: data.category });
const trendingColors = getBadgeStatusColor({ status: 'trending' });
const promotedColors = getBadgeStatusColor({ status: 'promoted' });
const mutedColorScheme = getMutedColorScheme();

const { visible: visibleTags } = truncateTags({ tags: data.tags ?? [], maxVisible: 2 });
const { text: excerpt } = truncateExcerpt({ text: data.summary, variant: 'standard' });

const entityLink = data.relatedEntity
    ? resolveEntityLink({ entity: data.relatedEntity, locale })
    : null;
const entityIcon = data.relatedEntity
    ? resolveEntityIcon({ type: data.relatedEntity.type }).icon
    : null;

const readingTimeSuffix = t('blog.detail.readingTime', 'min de lectura');
---

<article
    class="article-card"
    data-post-category={data.category}
>
    <a href={articleUrl} class="article-card__link" aria-label={data.title}>
        <CardImage
            src={data.featuredImage?.url ?? ''}
            alt={data.featuredImage?.caption ?? data.title}
            placeholderContent={categoryEmoji}
        >
            <Fragment slot="badges">
                {isTrending && (
                    <span
                        class="article-card__overlay-badge"
                        style={`background-color: ${trendingColors.bg}; color: ${trendingColors.text};`}
                    >
                        🔥 {t('blog.card.trending', 'Trending')}
                    </span>
                )}
                {data.isPromoted && (
                    <span
                        class="article-card__overlay-badge"
                        style={`background-color: ${promotedColors.bg}; color: ${promotedColors.text};`}
                    >
                        {t('blog.card.promoted', 'Destacado')}
                    </span>
                )}
                {data.isNews && (
                    <span
                        class="article-card__overlay-badge"
                        style={`background-color: ${newsColors.bg}; color: ${newsColors.text};`}
                    >
                        {t('blog.card.news', 'Noticia')}
                    </span>
                )}
            </Fragment>
            <Fragment slot="actions">
                {data.id && (
                    <FavoriteButton
                        client:visible
                        entityId={data.id}
                        entityType="POST"
                        initialIsFavorited={data.isFavorited}
                        initialBookmarkId={data.favoriteBookmarkId ?? null}
                        count={data.bookmarkCount}
                        variant="standalone"
                        showCount={true}
                        locale={locale}
                        isAuthenticated={isAuthenticated}
                    />
                )}
            </Fragment>
        </CardImage>

        <div class="article-card__body">
            <div class="article-card__badges">
                <Badge label={categoryLabel} colorScheme={categoryColor} size="sm" />
                {visibleTags.map((tag) => (
                    <Badge label={tag} colorScheme={mutedColorScheme} size="sm" />
                ))}
            </div>

            {showExpiryBadge && (
                <span class="article-card__expiry-badge" aria-label={expiryLabel}>
                    ⏰ {expiryLabel}
                </span>
            )}

            <h3 class="article-card__title">{data.title}</h3>

            <p class="article-card__excerpt">{excerpt}</p>

            <CardMeta
                author={{ name: data.authorName }}
                date={data.publishedAt}
                readingTimeMinutes={data.readingTimeMinutes}
                locale={locale}
                readingTimeSuffix={readingTimeSuffix}
            />

            {entityLink && entityIcon && (
                <div class="article-card__context-chip">
                    <span aria-hidden="true">{entityIcon}</span>
                    <span>
                        {t('blog.card.about', 'Sobre')}:
                        <strong>{entityLink.label}</strong>
                    </span>
                </div>
            )}
        </div>
    </a>
</article>

<style>
    .article-card {
        position: relative;
        display: flex;
        flex-direction: column;
        height: 100%;
        border-radius: var(--radius-card);
        background-color: var(--core-card);
        box-shadow: var(--shadow-card);
        overflow: hidden;
        transition:
            box-shadow var(--duration-normal) ease,
            transform var(--duration-normal) ease;
    }

    .article-card:hover {
        box-shadow: var(--shadow-card-hover);
        transform: translateY(-4px);
    }

    .article-card:focus-within {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    .article-card__link {
        display: flex;
        flex-direction: column;
        height: 100%;
        text-decoration: none;
        color: inherit;
    }

    .article-card__link:focus-visible {
        outline: none;
    }

    .article-card__overlay-badge {
        display: inline-block;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        font-weight: 600;
        padding: 0.25rem 0.625rem;
        border-radius: var(--radius-pill);
        line-height: 1;
        white-space: nowrap;
    }

    .article-card__body {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 1.25rem 1.5rem 1.5rem;
        gap: 0.625rem;
    }

    .article-card__badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
    }

    .article-card__expiry-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        font-weight: 600;
        color: var(--warning, #f59e0b);
        background-color: oklch(from var(--warning, #f59e0b) l c h / 0.12);
        border: 1px solid oklch(from var(--warning, #f59e0b) l c h / 0.35);
        border-radius: var(--radius-pill);
        padding: 0.2rem 0.5rem;
        line-height: 1;
        white-space: nowrap;
    }

    .article-card__title {
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 1.125rem;
        color: var(--core-foreground);
        line-height: 1.3;
        margin: 0;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
        transition: color var(--duration-fast) ease;
    }

    .article-card:hover .article-card__title {
        color: var(--card-accent, var(--brand-primary));
    }

    .article-card__excerpt {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
    }

    .article-card__context-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        color: var(--core-muted-foreground);
        margin-top: auto;
        padding-top: 0.25rem;
    }

    .article-card__context-chip strong {
        color: var(--core-foreground);
        font-weight: 500;
    }

    .article-card :global(.card-image__img) {
        transition: transform var(--duration-normal) ease;
    }

    .article-card:hover :global(.card-image__img) {
        transform: scale(1.04);
    }

    .article-card:hover :global(.card-image__placeholder-content) {
        transform: scale(1.15);
    }
</style>
