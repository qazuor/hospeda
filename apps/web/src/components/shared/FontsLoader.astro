---
/**
 * @file FontsLoader.astro
 * @description Loads Google Fonts (Geologica, Roboto, Caveat) without
 * render-blocking the page.
 *
 * The pattern: a `<link rel="preload" as="style">` warms the browser's
 * resource cache, a `<link rel="stylesheet" media="print">` then loads
 * the same CSS without blocking render, and a small nonce-scoped inline
 * script swaps the `media` attribute to `"all"` once the stylesheet has
 * loaded. A `<noscript>` fallback ships an unconditional stylesheet for
 * users without JavaScript.
 *
 * Used by BaseLayout, AuthLayout, and ErrorLayout — a single source of
 * truth for the font load contract. SPEC-047: replaces the previous
 * `onload="this.media='all'"` inline event handler that was blocked by
 * the strict CSP.
 *
 * Usage:
 * ```astro
 * <FontsLoader cspNonce={cspNonce} />
 * ```
 */

interface Props {
	readonly cspNonce: string;
}

const { cspNonce } = Astro.props;

const FONTS_HREF =
	'https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Geologica:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap';
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" as="style" href={FONTS_HREF} />
<link rel="stylesheet" href={FONTS_HREF} media="print" data-fonts-stylesheet />
<noscript>
	<link rel="stylesheet" href={FONTS_HREF} />
</noscript>
<script is:inline nonce={cspNonce}>
	(function () {
		var link = document.querySelector('link[data-fonts-stylesheet]');
		if (!link) return;
		var apply = function () {
			link.media = 'all';
		};
		if (link.sheet) apply();
		else link.addEventListener('load', apply, { once: true });
	})();
</script>
