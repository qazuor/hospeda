---
/**
 * @file StarsDisplay.astro
 * @description Visual star rating display rendering filled and unfilled star icons.
 * Used in review cards and testimonial sections to represent guest ratings.
 */
import { StarIcon } from "@repo/icons";

/**
 * Props for the StarsDisplay component.
 * @property count - Number of filled stars to render
 * @property max - Total number of stars to display (filled + unfilled)
 * @property size - Icon size variant: "sm" renders 16px stars, "md" renders 20px stars
 */
interface Props {
  /** Number of filled stars (1-5 typically) */
  readonly count: number;
  /** Maximum number of stars to render */
  readonly max?: number;
  /** Star icon size variant */
  readonly size?: "sm" | "md";
}

const { count, max = 5, size = "sm" } = Astro.props;

/** Pixel size for star icons based on the size variant */
const iconSize = size === "sm" ? 16 : 20;
---

<div class="flex gap-0.5">
  {Array.from({ length: max }).map((_, i) => (
    <StarIcon
      size={iconSize}
      weight={i < count ? "fill" : "duotone"}
      className={i < count ? "text-accent" : "text-muted"}
    />
  ))}
</div>
