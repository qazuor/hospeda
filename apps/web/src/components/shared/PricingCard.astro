---
/**
 * @file PricingCard.astro
 * @description Pricing plan card component for subscription tiers.
 * Displays plan name, price, feature list, and a CTA button.
 * Highlighted plans receive visual emphasis with a gradient CTA and "Popular" badge.
 * Uses semantic design tokens for consistent theming across light/dark modes.
 */

import { CheckIcon } from '@repo/icons';
import Badge from './Badge.astro';
import GradientButton from './GradientButton.astro';

/**
 * Plan CTA configuration.
 */
interface PlanCta {
    /** Button label text */
    readonly label: string;
    /** Navigation URL */
    readonly href: string;
}

/**
 * Plan data shape passed to the card.
 */
interface Plan {
    /** Display name for the pricing tier */
    readonly name: string;
    /** Numeric price value (e.g. 2990) */
    readonly price: number;
    /** Currency code displayed before the price (e.g. "ARS") */
    readonly currency?: string;
    /** Billing period label (e.g. "/mes") */
    readonly period?: string;
    /** List of feature strings included in this plan */
    readonly features: readonly string[];
    /** Call-to-action link for the plan */
    readonly cta: PlanCta;
}

/**
 * Props for the PricingCard component.
 */
interface Props {
    /** Plan data to render */
    readonly plan: Plan;
    /**
     * Whether this card should be visually highlighted as the featured/popular plan.
     * Highlighted cards receive a ring, shadow elevation, scale transform,
     * a "Popular" badge, and a gradient CTA button instead of an outline button.
     */
    readonly highlighted?: boolean;
    /** Optional label override for the badge shown on highlighted cards */
    readonly highlightLabel?: string;
    /** Additional CSS classes merged into the card root element */
    readonly class?: string;
}

const {
    plan,
    highlighted = false,
    highlightLabel = 'Popular',
    class: className,
} = Astro.props;

const currency = plan.currency ?? 'ARS';
const period = plan.period ?? '/mes';
---

<div
    class:list={[
        'relative flex flex-col rounded-xl border border-border bg-card p-6 shadow-sm transition-all hover:shadow-md',
        highlighted && 'ring-2 ring-primary shadow-xl scale-105 z-10',
        className,
    ]}
>
    {/* Popular badge anchored above the card top center */}
    {highlighted && (
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
            <Badge variant="featured">
                {highlightLabel}
            </Badge>
        </div>
    )}

    {/* Plan name */}
    <div class="mb-6">
        <h3 class="text-2xl font-bold text-foreground">
            {plan.name}
        </h3>
    </div>

    {/* Price block */}
    <div class="mb-6">
        <div class="flex items-baseline gap-1">
            <span class="text-sm font-medium text-muted-foreground">
                {currency}
            </span>
            <span class="text-4xl font-bold text-foreground">
                {plan.price.toLocaleString('es-AR')}
            </span>
            <span class="text-sm text-muted-foreground">
                {period}
            </span>
        </div>
    </div>

    {/* Feature list */}
    <ul class="mb-8 flex-1 space-y-3">
        {plan.features.map((feature) => (
            <li class="flex items-start gap-3">
                <CheckIcon
                    size={20}
                    weight="bold"
                    className="mt-0.5 shrink-0 text-primary"
                    aria-hidden="true"
                />
                <span class="text-foreground text-sm leading-relaxed">
                    {feature}
                </span>
            </li>
        ))}
    </ul>

    {/* CTA */}
    <div>
        {highlighted ? (
            <GradientButton
                href={plan.cta.href}
                label={plan.cta.label}
                class="w-full justify-center"
            />
        ) : (
            <a
                href={plan.cta.href}
                class="inline-flex h-10 w-full items-center justify-center rounded-full border border-border bg-transparent px-8 text-sm font-medium text-foreground transition-colors hover:bg-primary/5 hover:border-primary hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            >
                {plan.cta.label}
            </a>
        )}
    </div>
</div>
