---
/**
 * @file FeatureItem.astro
 * @description Horizontal feature item with a circular icon badge on the left
 * and a title + description stack on the right. Designed for feature lists
 * inside sections.
 *
 * Supports two visual variants:
 * - 'light' (default): transparent accent icon circle, dark text. For light backgrounds.
 * - 'dark': solid accent icon circle with white icon, white title, muted white description.
 *   Use when placed on dark/surface-dark section backgrounds.
 */

import { resolveIcon } from '@repo/icons';

interface Props {
  /**
   * Icon name string resolved via @repo/icons resolveIcon helper.
   * Example: 'wifi', 'pool', 'parking'.
   */
  readonly icon: string;
  /** Feature title rendered in the heading font. */
  readonly title: string;
  /** Supporting description text. */
  readonly description: string;
  /**
   * Visual variant controlling colors.
   * - 'light' (default): transparent accent background, dark text.
   * - 'dark': solid accent background, white icon + text.
   */
  readonly variant?: 'light' | 'dark';
}

const { icon, title, description, variant = 'light' } = Astro.props;

const IconComponent = resolveIcon({ iconName: icon });

const isDark = variant === 'dark';
const iconColor = isDark ? 'var(--accent-foreground)' : 'var(--brand-accent)';

const iconCircleStyle = isDark
  ? 'background-color: var(--brand-accent);'
  : 'background-color: oklch(from var(--brand-accent) l c h / 0.10);';
---

<div class:list={['feature-item', { 'feature-item--dark': isDark }]}>
  {/* Icon circle */}
  <div
    class="feature-item__icon"
    style={iconCircleStyle}
    aria-hidden="true"
  >
    {IconComponent ? (
      <IconComponent size={24} color={iconColor} weight={isDark ? 'fill' : 'duotone'} aria-hidden="true" />
    ) : (
      <span class="feature-item__icon-fallback" aria-hidden="true">
        {icon.slice(0, 2).toUpperCase()}
      </span>
    )}
  </div>

  {/* Text */}
  <div class="feature-item__text">
    <h4 class="feature-item__title">
      {title}
    </h4>
    <p class="feature-item__description">
      {description}
    </p>
  </div>
</div>

<style>
  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .feature-item__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.75rem;
    height: 3.75rem;
    border-radius: 9999px;
  }

  .feature-item__icon-fallback {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-body-sm);
    color: var(--brand-accent);
  }

  .feature-item--dark .feature-item__icon-fallback {
    color: white;
  }

  .feature-item__text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .feature-item__title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-h4);
    color: var(--core-foreground);
  }

  .feature-item--dark .feature-item__title {
    color: white;
  }

  .feature-item__description {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    color: var(--core-muted-foreground);
  }

  .feature-item--dark .feature-item__description {
    color: oklch(1 0 0 / 0.7);
  }
</style>
