---
/**
 * @file MobileMenuIsland.astro
 * @description Server Island wrapper that resolves auth state and renders MobileMenu.
 *
 * Uses `server:defer` so the auth session is always fresh, even on SSG pages.
 * Passes the authenticated user data (or null) as props to the React island.
 */

import { getImage } from 'astro:assets';
import { MobileMenu } from './MobileMenu.client';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

interface Props {
    /** Current locale for i18n. */
    readonly locale: SupportedLocale;
    /** Navigation items for the menu. */
    readonly navItems: readonly { label: string; href: string }[];
    /** Current page path for locale switcher URLs. */
    readonly currentPath: string;
    /** Resolved logo image URL. */
    readonly logoSrc: string;
    /** Home URL for the logo link. */
    readonly homeHref: string;
}

const { locale, navItems, currentPath, logoSrc, homeHref } = Astro.props;
const { t } = createTranslations(locale);

const serverUser = Astro.locals.user;

/** Pre-optimized avatar image URL for MobileMenu (64px @ 2x for retina). */
let optimizedUserImage: string | undefined;
if (serverUser && 'image' in serverUser && typeof serverUser.image === 'string' && serverUser.image) {
    const raw = serverUser.image;
    if (!raw.includes('placeholder') && !raw.endsWith('.svg')) {
        try {
            const optimized = await getImage({ src: raw, width: 64, format: 'webp' });
            optimizedUserImage = optimized.src;
        } catch {
            optimizedUserImage = raw;
        }
    } else {
        optimizedUserImage = raw;
    }
}

const user = serverUser
    ? { name: serverUser.name || 'Usuario', email: serverUser.email || '', image: optimizedUserImage }
    : null;

---

<MobileMenu
    client:media="(max-width: 1024px)"
    locale={locale}
    navItems={navItems}
    currentPath={currentPath}
    logoSrc={logoSrc}
    homeHref={homeHref}
    user={user}
    ctaLabel={t("nav.ownerCta")}
    ctaHref={buildUrl({ locale, path: "/suscriptores/" })}
/>
