---
/**
 * @file ListingPageHeader.astro
 * @description Reusable header area for listing pages with decorative tagline,
 * bold title, and optional subtitle.
 * Matches Figma design: italic Caveat tagline above bold Geologica heading.
 *
 * BETA-22: the natural-language results summary ("Mostrando N de M ...")
 * used to render here as a count element, inside the sticky WaveHeader band,
 * detached from the filters/results it describes. It now renders in
 * `ListingLayout` instead, at the top of the content column — see the
 * results-summary props documented on `ListingLayout.astro`. This component
 * intentionally has no results-count prop anymore; do not re-add one here.
 */

import type { SupportedLocale } from '@/lib/i18n';

interface Props {
	readonly locale: SupportedLocale;
	/** Decorative tagline rendered in Caveat font (e.g., "Encontra tu lugar ideal"). */
	readonly tagline?: string;
	/** Main page title (e.g., "Alojamientos"). */
	readonly title: string;
	/** Optional subtitle below the title. */
	readonly subtitle?: string;
	readonly class?: string;
}

const { tagline, title, subtitle, class: className } = Astro.props;
---

<div class:list={['listing-page-header', className]}>
	<div class="listing-page-header__text">
		{tagline && (
			<p class="listing-page-header__tagline wh-compact-hide">{tagline}</p>
		)}
		<h1 class="listing-page-header__title wh-compact-title">{title}</h1>
		{subtitle && (
			<p class="listing-page-header__subtitle wh-compact-hide">{subtitle}</p>
		)}
	</div>
</div>

<style>
	.listing-page-header__tagline {
		font-family: var(--font-decorative);
		font-weight: 700;
		font-size: clamp(1.1rem, 2.5vw, 1.4rem);
		color: var(--brand-accent-strong);
		margin: 0 0 var(--space-1);
		overflow: hidden;
		max-height: 2.5em;
		opacity: 1;
		transition:
			max-height 0.3s ease,
			opacity 0.2s ease,
			margin 0.3s ease;
	}

	.listing-page-header__title {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		color: var(--core-foreground);
		margin: 0;
		line-height: 1.2;
		transition: font-size 0.3s ease;
	}

	.listing-page-header__subtitle {
		font-family: var(--font-sans);
		font-size: var(--text-body);
		color: var(--core-muted-foreground);
		margin: var(--space-2) 0 0;
		overflow: hidden;
		max-height: 3em;
		opacity: 1;
		transition:
			max-height 0.3s ease,
			opacity 0.2s ease,
			margin 0.3s ease;
	}

	@media (prefers-reduced-motion: reduce) {
		.listing-page-header__tagline,
		.listing-page-header__title,
		.listing-page-header__subtitle {
			transition: none;
		}
	}
</style>
