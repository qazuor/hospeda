---
/**
 * @file PostCardLight.astro
 * @description Lightweight post card for use in related content carousels.
 * Zero client-side JS. Pure Astro.
 */

interface Props {
  readonly id: string;
  readonly slug: string;
  readonly title: string;
  readonly summary: string;
  readonly featuredImage?: string | null;
  readonly destinationName?: string | null;
  readonly publishedAt?: string | null;
  readonly lang: string;
}

const { slug, title, summary, featuredImage, destinationName, publishedAt, lang } = Astro.props;

const formattedDate = publishedAt
  ? new Date(publishedAt).toLocaleDateString(lang === 'pt' ? 'pt-BR' : lang, {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    })
  : null;
---

<article class="post-card-light">
  <a href={`/${lang}/publicaciones/${slug}`} class="post-card-light__link">
    <div class="post-card-light__image-wrapper">
      {featuredImage ? (
        <img
          src={featuredImage}
          alt={title}
          class="post-card-light__img"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="post-card-light__placeholder" aria-hidden="true" />
      )}
    </div>
    <div class="post-card-light__content">
      <h4 class="post-card-light__title">{title}</h4>
      <p class="post-card-light__summary">{summary}</p>
      <div class="post-card-light__meta">
        {destinationName && (
          <span class="post-card-light__chip">{destinationName}</span>
        )}
        {formattedDate && (
          <time class="post-card-light__date" datetime={publishedAt!}>
            {formattedDate}
          </time>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .post-card-light {
    background-color: var(--card);
    border-radius: var(--radius-card, 24px);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: box-shadow var(--duration-normal, 0.4s) ease;
  }
  .post-card-light:hover {
    box-shadow: var(--shadow-card-hover);
  }
  .post-card-light__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .post-card-light__image-wrapper {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-organic-sm, 0px 75px);
  }
  .post-card-light__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal, 0.4s) ease;
  }
  .post-card-light:hover .post-card-light__img {
    transform: scale(1.05);
  }
  .post-card-light__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--surface-warm) 0%, var(--card) 100%);
  }
  .post-card-light__content {
    padding: var(--space-4, 16px);
  }
  .post-card-light__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--foreground);
    margin: 0 0 var(--space-2, 8px);
    line-height: 1.3;
  }
  .post-card-light__summary {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--muted-foreground);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-card-light__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2, 8px);
    margin-top: var(--space-3, 12px);
  }
  .post-card-light__chip {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    background-color: var(--surface-warm);
    color: var(--accent);
    padding: 2px 10px;
    border-radius: var(--radius-pill);
    font-weight: 500;
  }
  .post-card-light__date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }
</style>
