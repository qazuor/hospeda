---
/**
 * @file CategoryBadge.astro
 * @description Pill-shaped badge displaying a category label with customizable colors.
 * Used across accommodation cards, event cards, and article cards
 * to indicate content type or classification.
 */

/**
 * Props for the CategoryBadge component.
 * @property category - Category label text (e.g. "Hotel", "Cultural", "Gastronomia")
 * @property colorClass - Tailwind color classes for background and text (defaults to primary theme)
 * @property class - Additional CSS classes to merge into the badge container
 */
interface Props {
  /** Category label text to display */
  readonly category: string;
  /** Tailwind color classes for background and text */
  readonly colorClass?: string;
  /** Additional CSS classes */
  readonly class?: string;
}

const {
  category,
  colorClass = "bg-primary text-primary-foreground",
  class: className = "",
} = Astro.props;
---

<span class:list={["rounded-full px-2.5 py-1 text-2xs font-semibold uppercase tracking-wide", colorClass, className]}>
  {category}
</span>
