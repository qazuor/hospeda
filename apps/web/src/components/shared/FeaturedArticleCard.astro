---
/**
 * @file FeaturedArticleCard.astro
 * @description Large featured article card for the magazine-style blog layout.
 * Spans 7 columns in the grid with a tall hero image, bookmark ribbon,
 * paper fold decoration, category badge, and reading time indicator.
 * Composes shared components: PaperFold, CategoryBadge.
 */
import { ClockIcon, ArrowRightIcon, BookmarkIcon } from "@repo/icons";
import { createT } from "@/lib/i18n";
import type { BlogPostCardData } from "@/lib/api/transforms";
import PaperFold from "@/components/shared/PaperFold.astro";
import CategoryBadge from "@/components/shared/CategoryBadge.astro";

/**
 * Props for the FeaturedArticleCard component.
 * @property article - Blog post data from the API transform layer
 * @property locale - Current locale for i18n translation lookups
 */
interface Props {
  /** Blog post data from the API transform layer */
  readonly article: BlogPostCardData;
  /** Current locale for translations */
  readonly locale?: string;
}

const { article, locale = "es" } = Astro.props;
const t = createT(locale);
---

<a href={`/${locale}/publicaciones/${article.slug}/`} class="group relative lg:col-span-7 card-3d-featured">
  <div class="relative overflow-hidden rounded-2xl bg-card shadow-brutal-lg transition-all duration-500 ease-out group-hover:shadow-brutal-lg-hover group-hover:-translate-x-1.5 group-hover:-translate-y-1.5 group-hover:card-3d-featured-tilt">
    <!-- Paper fold -->
    <PaperFold size="md" />

    <!-- Bookmark -->
    <div class="absolute right-6 top-0 z-10 flex h-16 w-10 items-end justify-center bg-accent pb-2 shadow-md" aria-hidden="true">
      <BookmarkIcon size={20} className="text-accent-foreground" />
    </div>

    <!-- Image -->
    <div class="relative h-72 overflow-hidden md:h-80 lg:h-96">
      <img src={article.featuredImage} alt={article.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" transition:name={`entity-${article.slug}`} />
      <div class="absolute inset-0 bg-gradient-to-t from-foreground/60 via-transparent to-transparent"></div>
      <div class="absolute bottom-4 left-4 flex items-center gap-2">
        <CategoryBadge category={article.category} colorClass="bg-card/95 text-foreground backdrop-blur-sm" class="px-3 py-1.5 text-xs font-semibold" />
      </div>
    </div>

    <!-- Content -->
    <div class="p-6 md:p-8">
      <div class="mb-3 font-mono text-xs uppercase tracking-wider text-muted-foreground">{article.publishedAt}</div>
      <h3 class="mb-3 text-2xl font-bold leading-tight text-card-foreground md:text-3xl">{article.title}</h3>
      <p class="mb-6 text-muted-foreground leading-relaxed">{article.summary}</p>
      <div class="flex items-center justify-between border-t border-border pt-4">
        <span class="flex items-center gap-1.5 text-sm text-muted-foreground">
          <ClockIcon size={16} />
          {article.readingTimeMinutes} min
        </span>
        <span class="flex items-center gap-2 font-semibold text-primary transition-colors group-hover:text-accent">
          {t('home.latestPosts.readArticle', 'Leer articulo')}
          <ArrowRightIcon size={18} className="transition-transform group-hover:translate-x-1" />
        </span>
      </div>
    </div>
  </div>
</a>
