---
/**
 * @file FeaturedArticleCard.astro
 * @description Full-width horizontal featured article card.
 * Image left (~55%), content right (~45%). Has category accent bar at the top,
 * promoted/trending overlays on the image, author avatar row, and a CTA link.
 * Used as the top row of the LatestArticlesSection layout.
 */

import type { ArticleCardBaseProps } from '@/data/types';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { formatDate } from '@/lib/format-utils';
import {
    truncateTags,
    truncateExcerpt,
    resolveEntityLink,
    resolveEntityIcon,
    formatReadingTime,
} from '@/lib/article-card-utils';
import Badge from '@/components/shared/Badge.astro';
import { getPostCategoryColor, getPostCategoryLabel, getPostCategoryEmoji } from '@/lib/colors';

interface Props {
    /** Full article card data. */
    readonly data: ArticleCardBaseProps;
    /** Active locale for URL building and translations. */
    readonly locale: SupportedLocale;
    /** Show the "🔥 Trending" overlay badge on the image. */
    readonly isTrending?: boolean;
}

const { data, locale, isTrending = false } = Astro.props;
const { t } = createTranslations(locale);

const articleUrl = buildUrl({ locale, path: `/publicaciones/${data.slug}/` });
const categoryColor = getPostCategoryColor({ category: data.category });
const categoryLabel = getPostCategoryLabel({ category: data.category, t });
const categoryEmoji = getPostCategoryEmoji({ category: data.category });
const hasImage = Boolean(data.featuredImage);

const { visible: visibleTags } = truncateTags({ tags: data.tags ?? [], maxVisible: 3 });
const { text: excerpt } = truncateExcerpt({ text: data.summary, variant: 'featured' });
const { text: readingTime } = formatReadingTime({ minutes: data.readingTimeMinutes, locale });

const entityLink = data.relatedEntity
    ? resolveEntityLink({ entity: data.relatedEntity, locale })
    : null;
const entityIcon = data.relatedEntity
    ? resolveEntityIcon({ type: data.relatedEntity.type }).icon
    : null;

const publishedDate = data.publishedAt
    ? formatDate({
        date: data.publishedAt,
        locale,
        options: { day: 'numeric', month: 'short', year: 'numeric' },
    })
    : '';

/** Muted color scheme for secondary tag chips. */
const mutedColorScheme = {
    bg: 'oklch(from var(--core-muted-foreground) l c h / 0.08)',
    text: 'var(--core-muted-foreground)',
    border: 'oklch(from var(--core-muted-foreground) l c h / 0.20)',
};
---

<article class="featured-card">
    <!-- Category accent bar -->
    <div
        class="featured-card__accent-bar"
        style={`background-color: ${categoryColor.text};`}
        aria-hidden="true"
    ></div>

    <!-- Inner link grid: image | content -->
    <a href={articleUrl} class="featured-card__link" aria-label={data.title}>
        <!-- Image area -->
        <div class="featured-card__image-wrapper">
            <!-- Placeholder always rendered behind the image -->
            <div class="featured-card__placeholder" style={`background-color: ${categoryColor.bg};`} aria-hidden="true">
                <span class="featured-card__placeholder-emoji">{categoryEmoji}</span>
            </div>
            {hasImage && (
                <img
                    src={data.featuredImage}
                    alt={data.title}
                    loading="lazy"
                    class="featured-card__img"
                    width="800"
                    height="500"
                    data-hide-on-error
                />
            )}
            {isTrending && (
                <span
                    class="featured-card__overlay-badge featured-card__overlay-badge--trending"
                    aria-label={t('articles.trending', 'Trending')}
                >
                    🔥 {t('articles.trending', 'Trending')}
                </span>
            )}
            {data.isPromoted && (
                <span
                    class="featured-card__overlay-badge featured-card__overlay-badge--promoted"
                    aria-label={t('articles.promoted', 'Destacado')}
                >
                    {t('articles.promoted', 'Destacado')}
                </span>
            )}
        </div>

        <!-- Content area -->
        <div class="featured-card__content">
            <!-- Category badge -->
            <div class="featured-card__category">
                <Badge
                    label={categoryLabel}
                    colorScheme={categoryColor}
                    size="md"
                />
            </div>

            <!-- Tags -->
            {visibleTags.length > 0 && (
                <div class="featured-card__tags" aria-label={t('articles.tags', 'Etiquetas')}>
                    {visibleTags.map((tag) => (
                        <Badge
                            label={tag}
                            colorScheme={mutedColorScheme}
                            size="sm"
                        />
                    ))}
                </div>
            )}

            <!-- Title -->
            <h3 class="featured-card__title">{data.title}</h3>

            <!-- Excerpt -->
            <p class="featured-card__excerpt">{excerpt}</p>

            <!-- Related entity -->
            {entityLink && entityIcon && (
                <a
                    href={entityLink.href}
                    class="featured-card__entity-link"
                    onclick="event.stopPropagation();"
                >
                    <span aria-hidden="true">{entityIcon}</span>
                    {entityLink.label}
                </a>
            )}

            <!-- Author row -->
            <div class="featured-card__author-row">
                {data.authorName && (
                    data.authorAvatar ? (
                        <img
                            src={data.authorAvatar}
                            alt={data.authorName}
                            class="featured-card__avatar"
                            loading="lazy"
                            width="32"
                            height="32"
                        />
                    ) : (
                        <span
                            class="featured-card__avatar featured-card__avatar--placeholder"
                            aria-hidden="true"
                        >
                            {data.authorName.charAt(0)}
                        </span>
                    )
                )}
                {data.authorName && (
                    <span class="featured-card__author-name">{data.authorName}</span>
                )}
                {data.authorName && publishedDate && (
                    <span class="featured-card__meta-sep" aria-hidden="true">&middot;</span>
                )}
                {publishedDate && (
                    <time datetime={data.publishedAt} class="featured-card__date">
                        {publishedDate}
                    </time>
                )}
                {(data.authorName || publishedDate) && (
                    <span class="featured-card__meta-sep" aria-hidden="true">&middot;</span>
                )}
                <span class="featured-card__reading-time">{readingTime}</span>
            </div>

            <!-- CTA -->
            <span class="featured-card__cta" aria-hidden="true">
                {t('articles.readFull', 'Leer artículo completo')}
                <span class="featured-card__cta-arrow">→</span>
            </span>
        </div>
    </a>
</article>

<style>
    .featured-card {
        border-radius: var(--radius-card);
        background-color: var(--core-card);
        box-shadow: var(--shadow-card);
        overflow: hidden;
        transition: box-shadow var(--duration-normal) ease;
    }

    .featured-card:hover {
        box-shadow: var(--shadow-card-hover);
    }

    .featured-card:focus-within {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    /* Accent bar */
    .featured-card__accent-bar {
        height: 4px;
        width: 100%;
    }

    /* Link grid */
    .featured-card__link {
        display: grid;
        grid-template-columns: 55% 45%;
        text-decoration: none;
        color: inherit;
        min-height: 380px;
    }

    .featured-card__link:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    /* Image */
    .featured-card__image-wrapper {
        position: relative;
        overflow: hidden;
    }

    .featured-card__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform var(--duration-normal) ease;
    }

    .featured-card:hover .featured-card__img {
        transform: scale(1.04);
    }

    /* Placeholder (behind image, visible when image absent or fails) */
    .featured-card__placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 0;
    }

    .featured-card__placeholder-emoji {
        font-size: 4.5rem;
        line-height: 1;
        filter: grayscale(0.15);
        transition: transform var(--duration-normal) ease;
    }

    .featured-card:hover .featured-card__placeholder-emoji {
        transform: scale(1.15);
    }

    .featured-card__img {
        position: relative;
        z-index: 1;
    }

    /* Overlay badges */
    .featured-card__overlay-badge {
        position: absolute;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        font-weight: 600;
        padding: 0.3rem 0.75rem;
        border-radius: var(--radius-pill);
        line-height: 1;
    }

    .featured-card__overlay-badge--trending {
        top: 0.75rem;
        right: 0.75rem;
        background-color: var(--brand-accent);
        color: oklch(1 0 0);
    }

    .featured-card__overlay-badge--promoted {
        top: 0.75rem;
        left: 0.75rem;
        background-color: var(--brand-primary);
        color: oklch(1 0 0);
    }

    /* Content */
    .featured-card__content {
        display: flex;
        flex-direction: column;
        padding: 2rem;
        gap: 0.75rem;
    }

    /* Category */
    .featured-card__category {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
    }

    /* Tags */
    .featured-card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
    }

    /* Title */
    .featured-card__title {
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 1.625rem; /* 26px */
        color: var(--core-foreground);
        line-height: 1.3;
        margin: 0;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 3;
        overflow: hidden;
        transition: color var(--duration-fast) ease;
    }

    .featured-card:hover .featured-card__title {
        color: var(--brand-primary);
    }

    /* Excerpt */
    .featured-card__excerpt {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 3;
        overflow: hidden;
    }

    /* Related entity */
    .featured-card__entity-link {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        color: var(--brand-primary);
        text-decoration: none;
        font-weight: 500;
        width: fit-content;
        transition: text-decoration var(--duration-fast) ease;
    }

    .featured-card__entity-link:hover {
        text-decoration: underline;
    }

    /* Author row */
    .featured-card__author-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: auto;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        color: var(--core-muted-foreground);
    }

    .featured-card__avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .featured-card__avatar--placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--brand-primary);
        color: oklch(1 0 0);
        font-weight: 600;
        font-size: var(--text-body-sm);
        font-family: var(--font-sans);
    }

    .featured-card__author-name {
        font-weight: 500;
        color: var(--core-foreground);
    }

    .featured-card__meta-sep {
        color: var(--core-muted-foreground);
    }

    .featured-card__date,
    .featured-card__reading-time {
        white-space: nowrap;
    }

    /* CTA */
    .featured-card__cta {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        font-weight: 500;
        color: var(--brand-primary);
    }

    .featured-card__cta-arrow {
        display: inline-block;
        transition: transform var(--duration-fast) ease;
    }

    .featured-card:hover .featured-card__cta-arrow {
        transform: translateX(4px);
    }

    /* Responsive: single column on mobile */
    @media (max-width: 767px) {
        .featured-card__link {
            grid-template-columns: 1fr;
            min-height: unset;
        }

        .featured-card__image-wrapper {
            aspect-ratio: 16 / 9;
        }

        .featured-card__title {
            font-size: 1.375rem; /* 22px */
        }
    }
</style>
