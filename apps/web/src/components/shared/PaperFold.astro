---
/**
 * @file PaperFold.astro
 * @description Decorative paper fold corner effect positioned at the bottom-right of a card.
 * Creates a subtle 3D "page fold" illusion using rotated gradient layers.
 * Used in article cards (FeaturedArticleCard, SecondaryArticleCard) for visual richness.
 */

/**
 * Props for the PaperFold component.
 * @property size - Fold size variant: "sm" for smaller cards, "md" for featured cards
 */
interface Props {
  /** Fold size variant controlling outer/inner dimensions */
  readonly size?: "sm" | "md";
}

const { size = "md" } = Astro.props;

/** Outer container dimensions based on size variant */
const outerSize = size === "sm" ? "h-8 w-8" : "h-10 w-10";
/** Inner rotated element dimensions based on size variant */
const innerSize = size === "sm" ? "h-10 w-10" : "h-12 w-12";
---

<div class:list={["absolute -bottom-1 -right-1 z-20 overflow-hidden", outerSize]} aria-hidden="true">
  <div class:list={["absolute bottom-1 right-1 origin-bottom-right rotate-45 bg-gradient-to-br from-muted via-muted to-muted-foreground/20 shadow-inner", innerSize]}></div>
</div>
