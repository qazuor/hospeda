---
/**
 * @file WaveDivider.astro
 * @description SVG-based decorative wave divider for section transitions.
 * Renders a full-width SVG wave shape that can be positioned absolutely
 * at the top/bottom of a section or rendered inline within the document flow.
 * Uses custom SVG paths for unique wave shapes per section.
 */

/**
 * Props for the WaveDivider component.
 * @property path - SVG path data string defining the wave shape (d attribute)
 * @property fillClass - Tailwind fill class for the SVG path color
 * @property position - Positioning mode: "top"/"bottom" use absolute positioning, "inline" flows normally
 * @property height - SVG viewBox height value (controls wave amplitude)
 * @property marginClass - Additional margin classes for fine-tuning position
 */
interface Props {
  /** SVG path data string defining the wave shape */
  readonly path: string;
  /** Tailwind fill class for the wave color */
  readonly fillClass?: string;
  /** Positioning mode: absolute (top/bottom) or inline (document flow) */
  readonly position?: "top" | "bottom" | "inline";
  /** SVG viewBox height controlling wave amplitude */
  readonly height?: string;
  /** Additional margin utility classes */
  readonly marginClass?: string;
}

const {
  path,
  fillClass = "fill-background",
  position = "bottom",
  height = "60",
  marginClass = "",
} = Astro.props;

/** CSS positioning classes mapped to each position variant */
const positionClasses: Record<string, string> = {
  top: "absolute left-0 right-0 top-0 z-20",
  bottom: "absolute bottom-0 left-0 right-0",
  inline: "",
};
const positionClass = positionClasses[position] ?? "";
---

<div class:list={[positionClass, marginClass]}>
  <svg
    viewBox={`0 0 1440 ${height}`}
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path d={path} class={fillClass} />
  </svg>
</div>
