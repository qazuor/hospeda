---
/**
 * @file MobileMenuIsland.astro
 * @description Thin wrapper that mounts the mobile navigation React island.
 *
 * Historically this was a `server:defer` Server Island so it could resolve
 * `Astro.locals.user` fresh on every render. That made the mobile menu a
 * SEPARATE browserâ†’server request on EVERY page view (server:defer islands
 * are their own `/_server-islands/*` fetch), which fired an extra
 * `get-session` call site-wide and flooded the API's `auth` rate-limit
 * bucket. Fixed by dropping `server:defer` here â€” the menu now renders
 * inline with the page (still SSR'd, just not deferred) â€” and resolving
 * auth state CLIENT-SIDE in `MobileMenu.client.tsx`, via the same shared
 * `authMeSnapshot` cache `UserMenu.client.tsx` already uses. `initialUser` /
 * `initialRole` are SSR HINTS (correct on pages whose middleware parsed the
 * session; `null` elsewhere) passed straight through from `Header.astro` â€”
 * the client cache/fetch refines them after hydration, exactly like
 * `UserMenu`.
 */

import { MobileMenu } from './MobileMenu.client';
import type { AuthMeUser } from '@/lib/auth-cache';
import type { SupportedLocale } from '@/lib/i18n';

interface Props {
    /** Current locale for i18n. */
    readonly locale: SupportedLocale;
    /** Navigation items for the menu. */
    readonly navItems: readonly { label: string; href: string }[];
    /** Current page path for locale switcher URLs. */
    readonly currentPath: string;
    /** Resolved logo image URL. */
    readonly logoSrc: string;
    /** Home URL for the logo link. */
    readonly homeHref: string;
    /**
     * SSR auth hint (`Astro.locals.user`, mapped to `AuthMeUser`). `null`
     * for guests AND for pages whose middleware did not parse the session â€”
     * `MobileMenu.client.tsx` reconciles it against the shared client cache.
     */
    readonly initialUser: AuthMeUser | null;
    /** SSR role hint (`Astro.locals.user?.role`), for the host-mode CTA on first paint. */
    readonly initialRole: string | null;
    /**
     * Admin panel base URL for the session-zone admin-panel link and the
     * host-mode CTA. `undefined` (env var not configured) hides both.
     */
    readonly adminPanelUrl: string | undefined;
}

const { locale, navItems, currentPath, logoSrc, homeHref, initialUser, initialRole, adminPanelUrl } =
    Astro.props;
---

<!--
  client:load (not client:idle): this island resolves auth state client-side
  and is the sole gate for the mobile menu's logged-in/host affordances. On
  Cloudflare-cached pages (e.g. home) `Astro.locals.user` is always null, so a
  signed-in user's correct state only appears after hydration â€” client:idle
  would leave them looking logged-out until the browser goes idle. Matches
  UserMenu's client:load so the "wrong state" window is the same for both.
-->
<MobileMenu
    client:load
    locale={locale}
    navItems={navItems}
    currentPath={currentPath}
    logoSrc={logoSrc}
    homeHref={homeHref}
    initialUser={initialUser}
    initialRole={initialRole}
    adminPanelUrl={adminPanelUrl}
/>
