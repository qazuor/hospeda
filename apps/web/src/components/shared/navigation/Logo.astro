---
/**
 * @file Logo.astro
 * @description Site logo component. Renders the Hospeda brand logo as an
 * image wrapped in an anchor tag linking to the homepage.
 *
 * Both variants currently share the same source asset; `variant=light` is
 * kept for API compatibility with existing callers and so a separate light
 * asset can be wired in later without changing call sites.
 *
 * Size mappings:
 * - `sm` → 2rem   (32px)
 * - `md` → 2.5rem (40px)
 * - `lg` → 3.5rem (56px)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import logoSrc from '@/assets/images/logo.webp';

interface Props {
	/** Controls which logo asset is rendered. Use `light` on dark backgrounds. */
	readonly variant?: 'light' | 'dark';
	/** Controls the rendered height of the logo image. */
	readonly size?: 'sm' | 'md' | 'lg';
	/** Optional additional CSS classes applied to the wrapping `<a>` element. */
	readonly class?: string;
	/** Locale for i18n. Defaults to 'es'. */
	readonly locale?: SupportedLocale;
}

const {
	size = 'md',
	class: className,
	locale = 'es',
} = Astro.props;

const { t } = createTranslations(locale);
---

<a
	href="/"
	aria-label={t('nav.goHome', 'Hospeda - Go to home')}
	class:list={['logo', className]}
>
	<img
		src={logoSrc.src}
		width={logoSrc.width}
		height={logoSrc.height}
		alt="Hospeda"
		class:list={['logo__image', `logo__image--${size}`]}
		loading="eager"
		decoding="async"
	/>
</a>

<style>
	.logo {
		display: inline-flex;
		align-items: center;
		border-radius: var(--radius-sm);
	}

	.logo:focus-visible {
		outline: 2px solid var(--ring);
		outline-offset: 2px;
	}

	.logo__image {
		width: auto;
		object-fit: contain;
	}

	/*
	 * Size modifier classes — replace inline `style="height: Xrem;"` per
	 * SPEC-046 GAP-046-09a so the logo does not emit `style-src-attr`-
	 * violating attributes during SSR. The three values mirror the
	 * `size: 'sm' | 'md' | 'lg'` prop enum 1:1.
	 */
	.logo__image--sm {
		height: 2rem;
	}

	.logo__image--md {
		height: 2.5rem;
	}

	.logo__image--lg {
		height: 3.5rem;
	}
</style>
