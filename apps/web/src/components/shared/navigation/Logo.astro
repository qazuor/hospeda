---
/**
 * @file Logo.astro
 * @description Site logo component. Renders the Hospeda brand logo as an
 * image wrapped in an anchor tag linking to the homepage.
 *
 * Both variants currently share the same source asset; `variant=light` is
 * kept for API compatibility with existing callers and so a separate light
 * asset can be wired in later without changing call sites.
 *
 * Size mappings:
 * - `sm` → 2rem   (32px)
 * - `md` → 2.5rem (40px)
 * - `lg` → 3.5rem (56px)
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import logoSrc from '@/assets/images/logo.webp';

interface Props {
	/** Controls which logo asset is rendered. Use `light` on dark backgrounds. */
	readonly variant?: 'light' | 'dark';
	/** Controls the rendered height of the logo image. */
	readonly size?: 'sm' | 'md' | 'lg';
	/** Optional additional CSS classes applied to the wrapping `<a>` element. */
	readonly class?: string;
	/** Locale for i18n. Defaults to 'es'. */
	readonly locale?: SupportedLocale;
}

const {
	size = 'md',
	class: className,
	locale = 'es',
} = Astro.props;

const { t } = createTranslations(locale);

/** Map size tokens to CSS height values. */
const sizeValues: Record<NonNullable<Props['size']>, string> = {
	sm: '2rem',
	md: '2.5rem',
	lg: '3.5rem',
} as const;

const heightValue = sizeValues[size];
---

<a
	href="/"
	aria-label={t('nav.goHome', 'Hospeda - Go to home')}
	class:list={['logo', className]}
>
	<img
		src={logoSrc.src}
		width={logoSrc.width}
		height={logoSrc.height}
		alt="Hospeda"
		class="logo__image"
		style={`height: ${heightValue};`}
		loading="eager"
		decoding="async"
	/>
</a>

<style>
	.logo {
		display: inline-flex;
		align-items: center;
		border-radius: var(--radius-sm);
	}

	.logo:focus-visible {
		outline: 2px solid var(--ring);
		outline-offset: 2px;
	}

	.logo__image {
		width: auto;
		object-fit: contain;
	}
</style>
