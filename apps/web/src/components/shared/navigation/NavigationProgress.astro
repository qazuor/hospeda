---
/**
 * @file NavigationProgress.astro
 * @description Global navigation loading feedback during page transitions.
 *
 * Two layers, both driven by Astro View Transitions (ClientRouter) lifecycle
 * events:
 *   1. A slim top progress bar that appears instantly when a navigation starts
 *      (`astro:before-preparation`, the document-fetch phase) and completes on
 *      `astro:after-swap`.
 *   2. A threshold-gated full-screen overlay with a centered spinner, shown only
 *      when the navigation takes longer than `THRESHOLD_MS` (e.g. an SSR page
 *      with a cold cache). The threshold prevents a flash on fast navigations.
 *   3. `cursor: progress` on <html> for the whole navigation (desktop pointer
 *      affordance).
 *
 * Why re-query the bar on every event: the element lives in the swapped <body>
 * (no `transition:persist`), so ClientRouter recreates it on each navigation.
 * The hoisted module script runs once and is NOT re-executed across swaps, so a
 * reference cached at module load would point at a detached node after the first
 * SPA navigation — leaving the bar dead from the second navigation onward.
 * `getBar()` reads the live node every time instead.
 *
 * The overlay coordinates with `PaginationLoading` (which shows its own
 * immediate overlay) via the shared `[data-nav-overlay]` marker so the two
 * never stack.
 *
 * Bar is decorative (`aria-hidden`); the overlay is a `role="status"` live
 * region labelled with `common.loading`.
 */

import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';

interface Props {
    readonly locale: SupportedLocale;
}

const { locale } = Astro.props;
const { t } = createTranslations(locale);
const loadingLabel = t('common.loading', 'Cargando...');
---

<div
    id="nav-progress"
    class="nav-progress"
    data-loading-label={loadingLabel}
    aria-hidden="true"
></div>

<script>
    import { createNavigationProgress } from './nav-progress';

    // Runs once per full load; the hoisted module script is not re-executed
    // across ClientRouter swaps, so the document/window listeners persist.
    createNavigationProgress().attach();
</script>

<style>
    .nav-progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 0;
        height: 4px;
        opacity: 0;
        background-color: var(--brand-accent);
        z-index: var(--z-modal);
        transition:
            width var(--duration-fast) ease-out,
            opacity 0.25s ease-out;
        pointer-events: none;
    }

    /* Active state: opacity appears instantly (no fade-in), only width animates. */
    .nav-progress.is-active {
        opacity: 1;
        transition: width var(--duration-fast) ease-out;
    }

    @media (prefers-reduced-motion: reduce) {
        .nav-progress,
        .nav-progress.is-active {
            transition: none;
        }
    }
</style>

<style is:global>
    /*
     * Overlay is created imperatively and appended to <body>, so it carries no
     * scoped `data-astro-cid` — its styles must be global. Namespaced under
     * `.nav-overlay` to avoid collisions. Visual mirrors PaginationLoading for
     * consistency. Sits just below the top bar (`--z-modal` - 1) so the bar
     * stays visible above it, and above the sticky header.
     */
    .nav-overlay {
        position: fixed;
        inset: 0;
        z-index: calc(var(--z-modal) - 1);
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--core-background-a70);
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
        animation: nav-overlay-fade 0.2s ease-out;
    }

    .nav-overlay__ring {
        box-sizing: border-box;
        width: 44px;
        height: 44px;
        border: 3px solid var(--brand-primary-a25);
        border-top-color: var(--brand-primary);
        border-radius: var(--radius-pill, 9999px);
        animation: nav-overlay-spin 0.7s linear infinite;
    }

    @keyframes nav-overlay-spin {
        to {
            transform: rotate(360deg);
        }
    }

    @keyframes nav-overlay-fade {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .nav-overlay {
            animation: none;
        }

        .nav-overlay__ring {
            animation: none;
        }
    }
</style>
