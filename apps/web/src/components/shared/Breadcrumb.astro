---
import { getHomeUrl } from '@/utils/urls';
import { useTranslations } from '@/utils/i18n';
import { getLangFromUrl } from '@/utils/i18n';

interface BreadcrumbItem {
    label: string;
    href?: string;
}

interface Props {
    items: BreadcrumbItem[];
    colorScheme?: 'teal' | 'purple' | 'emerald' | 'orange';
}

const { items, colorScheme = 'teal' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const colorClasses: Record<string, { link: string; linkHover: string }> = {
    teal: {
        link: 'text-teal-600 dark:text-teal-400',
        linkHover: 'hover:text-teal-700 dark:hover:text-teal-300',
    },
    purple: {
        link: 'text-purple-600 dark:text-purple-400',
        linkHover: 'hover:text-purple-700 dark:hover:text-purple-300',
    },
    emerald: {
        link: 'text-emerald-600 dark:text-emerald-400',
        linkHover: 'hover:text-emerald-700 dark:hover:text-emerald-300',
    },
    orange: {
        link: 'text-orange-600 dark:text-orange-400',
        linkHover: 'hover:text-orange-700 dark:hover:text-orange-300',
    },
};

const colors = colorClasses[colorScheme] ?? colorClasses.teal;
---

<nav class='bg-gray-50 dark:bg-gray-800 py-4 border-b border-gray-200 dark:border-gray-700' aria-label='Breadcrumb'>
    <div class='container mx-auto px-4'>
        <ol class='flex items-center space-x-2 text-sm'>
            <li>
                <a href={getHomeUrl()} class={`${colors.link} ${colors.linkHover}`}>
                    {t('nav.breadcrumb.home')}
                </a>
            </li>
            {items.map((item, index) => (
                <>
                    <li class='text-gray-500 dark:text-gray-400' aria-hidden='true'>/</li>
                    <li>
                        {item.href && index < items.length - 1 ? (
                            <a href={item.href} class={`${colors.link} ${colors.linkHover}`}>
                                {item.label}
                            </a>
                        ) : (
                            <span class='text-gray-900 dark:text-white font-medium' aria-current={index === items.length - 1 ? 'page' : undefined}>
                                {item.label}
                            </span>
                        )}
                    </li>
                </>
            ))}
        </ol>
    </div>
</nav>
