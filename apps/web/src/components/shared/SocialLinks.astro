---
/**
 * @file SocialLinks.astro
 * @description Social media icon links rendered as a flex row.
 *
 * Uses official brand-mark silhouettes from `@repo/icons` (Simple Icons set
 * via `createBrandIcon`). Color is driven by `currentColor` so consumers can
 * theme via CSS; the `light` variant flips text to white for dark surfaces.
 */

import {
  FacebookIcon,
  InstagramIcon,
  WhatsappIcon,
  XIcon,
  YoutubeIcon,
} from '@repo/icons';

interface Props {
  /** Controls icon color: 'light' renders white icons, 'dark' inherits foreground. */
  readonly variant?: 'light' | 'dark';
}

const { variant = 'dark' } = Astro.props;

const links = [
  {
    href: 'https://www.facebook.com/hospeda.com.ar',
    label: 'Seguinos en Facebook',
    Icon: FacebookIcon,
  },
  {
    href: 'https://www.instagram.com/hospeda.com.ar',
    label: 'Seguinos en Instagram',
    Icon: InstagramIcon,
  },
  {
    href: 'https://x.com/hospeda.com.ar',
    label: 'Seguinos en X',
    Icon: XIcon,
  },
  {
    href: 'https://www.youtube.com/@hospeda.com.ar',
    label: 'Seguinos en YouTube',
    Icon: YoutubeIcon,
  },
  {
    href: 'https://wa.me/543442453797',
    label: 'Contactanos por WhatsApp',
    Icon: WhatsappIcon,
  },
] as const;
---

<div class:list={['social-links', `social-links--${variant}`]}>
  {
    links.map(({ href, label, Icon }) => (
      <a
        href={href}
        aria-label={label}
        target="_blank"
        rel="noopener noreferrer"
        class="social-links__item"
      >
        <Icon size={24} aria-hidden="true" />
      </a>
    ))
  }
</div>

<style>
  .social-links {
    display: flex;
    flex-direction: row;
    gap: 16px;
    padding-block: 16px;
  }

  .social-links--light {
    color: white;
  }

  .social-links--dark {
    color: var(--core-foreground);
  }

  .social-links__item {
    display: inline-flex;
    /* User-agent stylesheets paint <a> blue (`-webkit-link`); inherit so the
     * brand-icon SVGs pick up the parent `--light` / `--dark` color instead. */
    color: inherit;
    transition: opacity var(--duration-normal) ease;
  }

  .social-links__item:hover {
    opacity: 0.75;
  }
</style>
