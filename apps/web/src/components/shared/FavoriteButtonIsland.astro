---
/**
 * Server Island wrapper for FavoriteButton.
 *
 * Uses `server:defer` so authentication state is resolved at request time,
 * even on pre-rendered (SSG) pages. This ensures the button reflects the
 * correct initial favorited and authenticated state without client-side
 * session fetches on first paint.
 */
import { FavoriteButton } from './FavoriteButton.client';

interface Props {
    readonly entityId: string;
    readonly entityType: 'accommodation' | 'destination' | 'event';
    readonly entityName?: string;
    readonly initialFavorited?: boolean;
    readonly locale?: 'es' | 'en' | 'pt';
    readonly className?: string;
}

const { entityId, entityType, entityName, initialFavorited, locale, className } = Astro.props;
const isAuthenticated = !!Astro.locals.user;
---

<FavoriteButton
    server:defer
    entityId={entityId}
    entityType={entityType}
    entityName={entityName}
    initialFavorited={initialFavorited}
    locale={locale}
    className={className}
    isAuthenticated={isAuthenticated}
/>
