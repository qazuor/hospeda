---
/**
 * @file Badge.astro
 * @description Pill-shaped badge component. Renders as an `<a>` element when
 * `href` is provided, otherwise as a `<span>`. The color scheme is applied via
 * an inline style using tokenized CSS values from `@/lib/colors`, and the
 * class list / style object are computed through pure helpers in
 * `./badge.utils` so the React twin (`Badge.tsx`) produces identical output.
 *
 * Variants:
 * - `default`: uses `colorScheme` for per-type bg / text / border.
 * - `filled-dark`: uniform dark pill for homepage filter rows.
 * - `outline`: transparent bg, colored border and text.
 * - `dot`: neutral bg with a colored leading dot indicator.
 *
 * Sizes (`xs`, `sm`, `md`) control padding, font-size, icon size and, for
 * clickable badges only, a minimum tap-target height.
 *
 * Icon support: when `icon` is provided it is resolved via
 * `resolveIcon({ iconName })` from `@repo/icons`. If the name is unknown the
 * icon is silently omitted (and a dev-mode warning is emitted via
 * `webLogger.warn`).
 */

import { resolveIcon } from '@repo/icons/resolver';
import { webLogger } from '@/lib/logger';
import type { BadgeColorScheme, BadgeSize, BadgeVariant } from './badge.types';
import {
    buildBadgeClassName,
    buildBadgeInlineStyle,
    getBadgeIconSize
} from './badge.utils';

/**
 * Re-export `BadgeColorScheme` from `./badge.types` so existing consumers that
 * do `import type { BadgeColorScheme } from '@/components/shared/ui/Badge.astro'`
 * continue to work after the type was moved to the shared types module.
 */
export type { BadgeColorScheme } from './badge.types';

interface Props {
    /** Text label displayed inside the badge. */
    readonly label: string;
    /** Optional href. When provided the badge renders as an `<a>` element. */
    readonly href?: string;
    /** Color scheme object controlling badge appearance (ignored for `filled-dark`/`dot`). */
    readonly colorScheme: BadgeColorScheme;
    /** Size variant. Defaults to `'sm'`. */
    readonly size?: BadgeSize;
    /** Visual variant. Defaults to `'default'`. */
    readonly variant?: BadgeVariant;
    /** Optional icon name resolved via `@repo/icons`. */
    readonly icon?: string;
    /** Optional aria-label applied to the root element. */
    readonly ariaLabel?: string;
    /** Optional extra class forwarded to the root element's class list. */
    readonly class?: string;
}

const {
    label,
    href,
    colorScheme,
    size = 'sm',
    variant = 'default',
    icon,
    ariaLabel,
    class: extraClass
} = Astro.props;

const hasHref = Boolean(href);
const classes = buildBadgeClassName({
    variant,
    size,
    hasHref,
    extraClassName: extraClass
});
const inlineStyle = buildBadgeInlineStyle({ variant, colorScheme, size, hasHref });

const IconComponent = icon ? resolveIcon({ iconName: icon }) : undefined;
if (icon && !IconComponent && import.meta.env.DEV) {
    webLogger.warn(
        `Badge: icon "${icon}" could not be resolved via @repo/icons`
    );
}
const iconPixelSize = getBadgeIconSize({ size });
---

{href ? (
    <a href={href} class={classes} style={inlineStyle} aria-label={ariaLabel}>
        {variant === 'dot' && (
            <span class="badge__dot" aria-hidden="true" style={`background-color: ${colorScheme.text};`}></span>
        )}
        {IconComponent && (
            <IconComponent size={iconPixelSize} weight="regular" aria-hidden="true" />
        )}
        <span>{label}</span>
    </a>
) : (
    <span class={classes} style={inlineStyle} aria-label={ariaLabel}>
        {variant === 'dot' && (
            <span class="badge__dot" aria-hidden="true" style={`background-color: ${colorScheme.text};`}></span>
        )}
        {IconComponent && (
            <IconComponent size={iconPixelSize} weight="regular" aria-hidden="true" />
        )}
        <span>{label}</span>
    </span>
)}

<style>
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        border-radius: var(--radius-pill);
        font-family: var(--font-sans);
        font-weight: 600;
        white-space: nowrap;
        text-decoration: none;
    }

    /* Interactive affordance: only anchors get tap-target height + hover lift */
    a.badge {
        min-height: 44px;
        cursor: pointer;
        transition:
            transform 150ms ease,
            filter 150ms ease,
            background-color 150ms ease;
    }

    span.badge {
        min-height: auto;
    }

    a.badge--size-xs {
        min-height: 24px;
    }

    a.badge:hover,
    .badge--interactive:hover {
        transform: translateY(-1px);
        filter: brightness(0.96);
    }

    .badge--interactive {
        cursor: pointer;
    }

    .badge__dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .badge--variant-filled-dark {
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .badge:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }

    @media (prefers-reduced-motion: reduce) {
        a.badge,
        a.badge:hover {
            transform: none;
            filter: none;
            transition: none;
        }
    }
</style>
