---
/**
 * @file GradientButton.astro
 * @description Unified CTA component with real linear-gradient backgrounds,
 * pill shape (default), outline variants that fill on hover, and three sizes.
 *
 * Props:
 * - label: required text
 * - variant: accent | primary | outline-accent | outline-primary
 * - size: sm | md | lg (default md)
 * - shape: pill | rounded (default pill — use 'rounded' for form submits / pricing cards)
 * - icon: pass "true" to render a trailing ArrowRightIcon
 * - as: 'a' | 'button'
 * - href, type, name, id, data, aria, class
 *
 * Slots:
 * - leading: rendered before the label (e.g. icon)
 * - trailing: rendered after the label (alternative to `icon` prop)
 */

import { ArrowRightIcon } from '@repo/icons';

interface Props {
  readonly label: string;
  readonly href?: string;
  readonly as?: 'a' | 'button';
  readonly variant?: 'primary' | 'accent' | 'outline-primary' | 'outline-accent';
  readonly size?: 'sm' | 'md' | 'lg';
  readonly shape?: 'pill' | 'rounded';
  readonly icon?: string;
  readonly class?: string;
  readonly id?: string;
  readonly type?: 'button' | 'submit' | 'reset';
  readonly name?: string;
  readonly data?: Record<string, string | number>;
  /**
   * Arbitrary `aria-*` attributes as a plain record.
   * Keys are used without the `aria-` prefix; it is added automatically.
   * Boolean values are stringified to `'true'` or `'false'` because HTML
   * ARIA boolean attributes are enumerated strings, not real booleans.
   *
   * **Collision rule**: if `'label'` is included here it is silently dropped —
   * the button label is visible text rendered via the `label` prop.
   *
   * @example { busy: isLoading }
   */
  readonly aria?: Record<string, string | boolean>;
}

const {
  label,
  href,
  as: element = 'a',
  variant = 'accent',
  size = 'md',
  shape = 'pill',
  icon,
  class: extraClass,
  id,
  type = 'button',
  name,
  data,
  aria,
} = Astro.props;

const classes = [
  'btn-gradient',
  `btn-gradient--${variant}`,
  `btn-gradient--${size}`,
  shape === 'rounded' ? 'btn-gradient--shape-rounded' : '',
  extraClass ?? '',
]
  .filter(Boolean)
  .join(' ');

const dataAttrs: Record<string, string | number> = {};
if (data) {
  for (const [key, value] of Object.entries(data)) {
    dataAttrs[`data-${key}`] = value;
  }
}

// Build aria-* attrs. The 'label' key is dropped — label prop renders visible text.
const ariaAttrs: Record<string, string> = {};
if (aria) {
  for (const [key, value] of Object.entries(aria)) {
    if (key === 'label') continue;
    ariaAttrs[`aria-${key}`] = String(value);
  }
}

const hasLeadingSlot = Astro.slots.has('leading');
const hasTrailingSlot = Astro.slots.has('trailing');
---

{element === 'a' ? (
  <a href={href} id={id} class={classes} {...dataAttrs} {...ariaAttrs}>
    {hasLeadingSlot && (
      <span class="gradient-btn__icon gradient-btn__icon--leading" aria-hidden="true">
        <slot name="leading" />
      </span>
    )}
    <span class="gradient-btn__label">{label}</span>
    {hasTrailingSlot ? (
      <span class="gradient-btn__icon gradient-btn__icon--trailing" aria-hidden="true">
        <slot name="trailing" />
      </span>
    ) : icon && (
      <span class="gradient-btn__icon gradient-btn__icon--trailing" aria-hidden="true">
        <ArrowRightIcon size={18} weight="bold" color="currentColor" />
      </span>
    )}
  </a>
) : (
  <button
    type={type}
    name={name}
    id={id}
    class={classes}
    {...dataAttrs}
    {...ariaAttrs}
  >
    {hasLeadingSlot && (
      <span class="gradient-btn__icon gradient-btn__icon--leading" aria-hidden="true">
        <slot name="leading" />
      </span>
    )}
    <span class="gradient-btn__label">{label}</span>
    {hasTrailingSlot ? (
      <span class="gradient-btn__icon gradient-btn__icon--trailing" aria-hidden="true">
        <slot name="trailing" />
      </span>
    ) : icon && (
      <span class="gradient-btn__icon gradient-btn__icon--trailing" aria-hidden="true">
        <ArrowRightIcon size={18} weight="bold" color="currentColor" />
      </span>
    )}
  </button>
)}
