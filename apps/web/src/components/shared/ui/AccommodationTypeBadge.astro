---
/**
 * @file AccommodationTypeBadge.astro
 * @description Single source of truth for the accommodation-type pill used
 * across listing cards, detail headers, and any other UI surface that needs
 * to communicate accommodation type.
 *
 * The DECORATIVE variant (no `href`, rendered as a `<span>`) ships with a
 * small leading icon (resolved via `getAccommodationTypeIcon`) followed by an
 * i18n label (`getAccommodationTypeLabel`), on the brand-primary surface.
 *
 * The INTERACTIVE variant (`href` provided, rendered as an `<a>`) is the
 * accommodation quick-filter chip used above the /alojamientos/ listing and
 * the homepage featured-accommodations row. Per BETA-113 (visual
 * unification of every quick-filter chip row across the app — see
 * `dest-attractions-filter__badge` in destinos/index.astro and
 * `tag-chips__chip` in TagChips.astro for the other two surfaces that share
 * this canonical look), this variant uses the canonical neutral-rest /
 * brand-accent-hover treatment (instead of the solid brand-primary pill) at
 * the SAME size/font as the other two surfaces (`--text-body-sm` / `6px
 * 16px`, overriding the decorative variant's own `--acc-type-font-size` /
 * `--acc-type-padding` tokens), and keeps its own per-type leading icon
 * (owner decision: every quick-filter chip gets an icon — "icono en
 * todos"). Only the interactive anchor variant changed; the decorative span
 * variant (cards, detail headers) is untouched.
 *
 * The component exposes `--acc-type-padding` and `--acc-type-font-size` CSS
 * custom properties so ancestor scopes (e.g. the wave-header compact mode)
 * can override the size without `!important`.
 */
import { getAccommodationTypeLabel } from '@/lib/colors';
import { getAccommodationTypeIcon } from '@/lib/accommodation-type-icons';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';

interface Props {
    /** Accommodation type from the API (case-insensitive, e.g. `"HOTEL"`). */
    readonly type: string;
    /** Active locale for the i18n label. */
    readonly locale: SupportedLocale;
    /** Pill density. `xs` matches listing-card density, `sm` the detail header. */
    readonly size?: 'xs' | 'sm';
    /** When provided the badge renders as an `<a>` (tap target + hover lift). */
    readonly href?: string;
    /** Optional extra class forwarded to the root element (for ancestor-driven overrides). */
    readonly class?: string;
}

const { type, locale, size = 'sm', href, class: extraClass } = Astro.props;
const { t } = createTranslations(locale);

const normalizedType = type.toLowerCase();
const label = getAccommodationTypeLabel({ type, t });
const Icon = getAccommodationTypeIcon({ type: normalizedType });

const classList = [
    'acc-type-badge',
    `acc-type-badge--size-${size}`,
    href ? 'acc-type-badge--interactive' : null,
    extraClass
];

const iconSize = size === 'xs' ? 14 : 16;
---

{href ? (
    <a class:list={classList} href={href}>
        <Icon size={14} weight="regular" aria-hidden="true" />
        <span class="acc-type-badge__label">{label}</span>
    </a>
) : (
    <span class:list={classList}>
        <Icon size={iconSize} weight="bold" aria-hidden="true" />
        <span class="acc-type-badge__label">{label}</span>
    </span>
)}

<style>
    .acc-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
        background-color: var(--brand-primary-dark);
        color: var(--primary-foreground, #fff);
        border: none;
        border-radius: var(--radius-pill, 9999px);
        font-family: var(--font-sans);
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
        box-shadow:
            0 1px 2px oklch(0 0 0 / 0.08),
            0 2px 6px oklch(0 0 0 / 0.06);
        padding: var(--acc-type-padding);
        font-size: var(--acc-type-font-size);
        letter-spacing: var(--acc-type-letter-spacing, 0.05em);
        transition:
            padding 0.3s ease,
            font-size 0.3s ease,
            box-shadow 0.3s ease,
            background-color 0.2s ease;
    }
    .acc-type-badge--size-xs {
        --acc-type-padding: 4px 10px;
        --acc-type-font-size: 0.625rem;
        --acc-type-letter-spacing: 0.04em;
        line-height: 1.4;
    }
    .acc-type-badge--size-sm {
        --acc-type-padding: 4px 14px;
        --acc-type-font-size: 0.7rem;
    }

    .acc-type-badge__label {
        line-height: 1;
    }

    /* Interactive (anchor) variant: tap target, hover/focus affordance.
     * `display: inline-flex` + `min-height` only when actionable, so the
     * decorative span variant keeps hugging its content.
     *
     * BETA-113 canonical quick-filter chip: neutral --core-card surface at
     * rest (like the `dest-attractions-filter__badge` and `tag-chips__chip`
     * treatments on the other two listing surfaces), solid --brand-accent on
     * hover. Overrides the decorative base rule's uppercase/bold/box-shadow
     * treatment since a "chip" reads differently from a static type label. */
    a.acc-type-badge {
        background-color: var(--core-card);
        color: var(--core-foreground);
        border: 1px solid var(--border, var(--brand-primary-a25));
        text-transform: none;
        font-weight: 500;
        letter-spacing: normal;
        box-shadow: none;
        /* Canonical quick-filter chip size — matches tag-chips__chip and
         * dest-attractions-filter__badge exactly. Overrides the decorative
         * variant's --acc-type-font-size / --acc-type-padding (0.7rem / 4px
         * 14px for size=sm), which stay in effect for the decorative span. */
        font-size: var(--text-body-sm);
        padding: 6px 16px;
        text-decoration: none;
        cursor: pointer;
        min-height: 32px;
        transition:
            transform 200ms ease-out,
            background-color var(--duration-normal, 0.4s) ease,
            color var(--duration-normal, 0.4s) ease,
            border-color var(--duration-normal, 0.4s) ease,
            padding 0.3s ease,
            font-size 0.3s ease;
    }
    a.acc-type-badge:hover {
        transform: translateY(-1px);
        background-color: var(--brand-accent);
        color: var(--accent-foreground, #fff);
        border-color: var(--brand-accent);
    }
    a.acc-type-badge:focus-visible {
        outline: 2px solid var(--brand-accent);
        outline-offset: 2px;
    }
    @media (prefers-reduced-motion: reduce) {
        .acc-type-badge,
        a.acc-type-badge,
        a.acc-type-badge:hover {
            transition: none;
            transform: none;
        }
    }
</style>
