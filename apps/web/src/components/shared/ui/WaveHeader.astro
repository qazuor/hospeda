---
/**
 * @file WaveHeader.astro
 * @description Reusable sticky page header with a solid "band puro" surface and
 * smooth compact mode on scroll. Used by ListingLayout and DetailLayout.
 *
 * IMPORTANT: This component wraps the ENTIRE page content (header + body)
 * so that the sticky bar has a tall-enough parent to stick for the full scroll.
 * Pass page body content via the default slot.
 *
 * Architecture:
 *   <WaveHeader>
 *     <breadcrumbs slot="breadcrumbs" />
 *     <header slot="content" />
 *     <body-content />  ← default slot
 *   </WaveHeader>
 *
 * Surface technique (HOS-84): a flat band filled with --surface-header. No SVG
 * wave. In compact mode the band gains a theme-aware bottom edge shadow so it
 * reads as a distinct sticky surface over the scrolling content below.
 */

interface Props {
  /**
   * Semantic padding-top preset for the expanded header.
   * `listing` = 3rem, `detail` = 2rem. Drives the data-wave-padding map in
   * css-var-themes.css instead of inline `style="--wave-header-padding-top"`
   * (SPEC-046 GAP-046-09a).
   */
  readonly paddingTop?: 'listing' | 'detail';
  /** Extra CSS classes on the root element. */
  readonly class?: string;
}

const { paddingTop = 'listing', class: className } = Astro.props;
---

<div
  class:list={['wave-header', className]}
  data-wave-padding={paddingTop}
  data-wave-header
>
  {/* Sticky band: sticks below navbar for the full page scroll */}
  <div class="wave-header__bar">
    <div class="wave-header__breadcrumbs">
      <div class="wave-header__container">
        <slot name="breadcrumbs" />
      </div>
    </div>

    <div class="wave-header__content">
      <div class="wave-header__container">
        <slot name="content" />
      </div>
    </div>
  </div>

  {/* Page body: default slot. Being inside .wave-header gives the sticky bar
      a tall parent so it can stick for the entire page scroll. */}
  <slot />
</div>

<script>
  /**
   * WaveHeader behavior wiring (HOS-84). The decision logic lives in the pure,
   * unit-tested `waveHeaderState.ts` module; this script only owns the DOM side:
   * reading `window.scrollY`, feeding the state machine, and toggling classes.
   *
   * Three-state model on DETAIL surfaces (data-wave-padding="detail"):
   *   expanded → compact → hidden, with scroll-up revealing back to compact.
   * LISTING surfaces render a STATIC band — no scroll machine is attached at all.
   *
   * `overflow-anchor: none` (see <style>) + the position hysteresis in the pure
   * module are the anti-trembling fix; the direction-delta dead-zone is the
   * anti-jitter guard for the new hide/reveal layer. Only toggles CSS classes —
   * all motion stays in CSS transitions. Compatible with Astro View Transitions.
   */
  import {
    DEFAULT_WAVE_HEADER_CONFIG,
    nextWaveHeaderState,
    type WaveHeaderState
  } from './waveHeaderState.ts';

  function initWaveHeaders(): void {
    const headers = document.querySelectorAll<HTMLElement>('[data-wave-header]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    for (const header of headers) {
      const bar = header.querySelector<HTMLElement>('.wave-header__bar');
      if (!bar) continue;

      // Static band on listing surfaces: no scroll state machine. The header
      // stays expanded. The mobile fullscreen map manages its own locked
      // compact class directly (see mapa.astro), so it is not driven here.
      if (header.dataset.wavePadding !== 'detail') continue;

      if (header.dataset.waveInitialized === 'true') continue;
      header.dataset.waveInitialized = 'true';

      let state: WaveHeaderState = 'expanded';
      let accumulator = 0;
      let prevScrollY = window.scrollY;

      const apply = (next: WaveHeaderState): void => {
        if (next === state) return;
        state = next;
        // `hidden` is `compact` styling PLUS a translate-out; keep --compact on
        // in both so the slide-out animates from the compact band, not the tall
        // expanded one.
        header.classList.toggle('wave-header--compact', next === 'compact' || next === 'hidden');
        header.classList.toggle('wave-header--hidden', next === 'hidden');
      };

      let ticking = false;
      const evaluate = (): void => {
        ticking = false;
        const scrollY = window.scrollY;
        const delta = scrollY - prevScrollY;
        prevScrollY = scrollY;
        const result = nextWaveHeaderState({
          scrollY,
          delta,
          accumulator,
          currentState: state,
          config: DEFAULT_WAVE_HEADER_CONFIG,
          // Respect a lock applied after init (e.g. the mobile map view).
          lockedCompact: header.dataset.lockedCompact === 'true',
          reducedMotion
        });
        accumulator = result.accumulator;
        apply(result.state);
      };

      const onScroll = (): void => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(evaluate);
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      // Set the initial state (handles navigating in already scrolled down).
      evaluate();

      document.addEventListener('astro:before-swap', () => {
        window.removeEventListener('scroll', onScroll);
        window.removeEventListener('resize', onScroll);
        header.dataset.waveInitialized = '';
      }, { once: true });
    }
  }

  initWaveHeaders();
  document.addEventListener('astro:after-swap', initWaveHeaders);
</script>

<style>
  /* Disable the browser's scroll anchoring on pages that use the wave header.
   *
   * This is the root-cause fix for the header trembling when scrolling back UP
   * toward the top. Expanding the bar grows the breadcrumbs (~80px) ABOVE the
   * current scroll position; with anchoring ON, the browser compensates by
   * nudging scrollY by that same ~80px to keep the visible content from
   * jumping — but that nudge crosses the compact trigger, which re-compacts,
   * which shrinks the bar again: a feedback loop. Measured directly: requesting
   * scrollY=4 bounced to ~63 with anchoring on, and stayed at 4 with it off.
   * The compact toggle itself never moves the scroll once anchoring is off.
   *
   * Scoped via `:has` so every other page keeps anchoring. `html` is the scroll
   * container in this app (the `overflow-x: clip` on html/body does not create
   * one), and `body` is covered too as a belt-and-suspenders. */
  :global(html:has(.wave-header)),
  :global(html:has(.wave-header) body) {
    overflow-anchor: none;
  }

  /* =========================================================
   * Expanded (default) state — "band puro"
   * ========================================================= */
  .wave-header {
    position: relative;
  }

  .wave-header__bar {
    position: sticky;
    /* Pin flush against the navbar — the var is published by Header.astro
       (publishNavbarHeight). 80px is a safe fallback before JS hydrates. */
    top: var(--navbar-height, 80px);
    z-index: calc(var(--z-nav, 50) - 1);
    transition: transform 0.3s ease;
  }

  /* Hidden state: on a sustained scroll-down the whole band slides up behind
     the navbar (opaque, higher z-index), freeing reading height. Scroll-up
     reveals it back to compact (never straight to expanded) — the state machine
     in waveHeaderState.ts owns that decision. */
  .wave-header--hidden .wave-header__bar {
    transform: translateY(-100%);
  }

  .wave-header__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-container-x);
  }

  .wave-header__breadcrumbs {
    padding-top: var(--wave-header-padding-top, 3rem);
    padding-bottom: 0.75rem;
    overflow: hidden;
    max-height: 80px;
    background-color: var(--surface-header);
    /* NOTE: no `opacity` transition. The bar wrapper has no background of its
       own, so fading the breadcrumbs would expose the page behind it during
       the compact transition. `overflow: hidden` + `max-height: 0` already
       hide the content cleanly. */
    transition:
      max-height 0.3s ease,
      padding 0.3s ease;
  }

  .wave-header__content {
    padding-bottom: 1.5rem;
    background-color: var(--surface-header);
    transition:
      padding 0.3s ease,
      box-shadow 0.3s ease;
  }

  /* =========================================================
   * Compact (scrolled) state — all CSS transitions, no JS
   * ========================================================= */
  .wave-header--compact .wave-header__breadcrumbs {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    pointer-events: none;
  }

  .wave-header--compact .wave-header__content {
    padding-top: 1.7rem;
    padding-bottom: 1.1rem;
    position: relative;
    z-index: 2;
    /* Theme-aware bottom edge: separates the sticky band from the content
       scrolling underneath it. Derived from the page foreground so it reads in
       both light and dark (replaces the old wave-SVG drop-shadow). */
    box-shadow: 0 6px 12px -6px oklch(from var(--core-foreground) l c h / 0.18);
  }

  /* =========================================================
   * Shared compact-mode contract (HOS-84 T-007 / OQ-4)
   * ---------------------------------------------------------
   * The compact BEHAVIOR is defined ONCE here. Each entity header opts in
   * per element by applying these utility classes in its own markup, and so
   * chooses WHAT collapses — the per-page override "escape hatch". The
   * elements keep their own `transition` declarations in their base (non-
   * compact) rules so these value changes animate. Genuinely header-specific
   * bits (e.g. a badge that shrinks via its own custom props, a page that
   * also hides a summary paragraph) stay as small local overrides in that
   * header, keyed off the same `.wave-header--compact` ancestor.
   * ========================================================= */

  /* Collapse a vertical stack into one wrapping row. Apply to the header's
     main content container (the column that holds title + meta). */
  :global(.wave-header.wave-header--compact) :global(.wh-compact-row) {
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2, 8px);
  }

  /* Shrink the H1 to the compact title size. Apply to the header's <h1>. */
  :global(.wave-header.wave-header--compact) :global(.wh-compact-title) {
    font-size: clamp(1rem, 2vw, 1.25rem);
  }

  /* Shrink a badge / status pill. Apply to type/category/status badges that
     size themselves directly (not via their own custom props). */
  :global(.wave-header.wave-header--compact) :global(.wh-compact-badge) {
    font-size: 0.6rem;
    padding: 2px 10px;
  }

  /* Fully collapse a secondary element out of the compact row (rating, meta,
     summary, attractions, pricing…). Apply to whatever each page drops.
     The element MUST declare its own max-height/opacity transition in its
     base rule for this to animate. */
  :global(.wave-header.wave-header--compact) :global(.wh-compact-hide) {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Demote a secondary inline text (location / destination) and prefix it
     with a dot separator once it sits inline in the compact row. */
  :global(.wave-header.wave-header--compact) :global(.wh-compact-demote) {
    font-size: 0.85rem;
  }
  :global(.wave-header.wave-header--compact) :global(.wh-compact-demote)::before {
    content: '\00B7';
    margin-right: 0.35em;
    color: var(--core-muted-foreground);
    font-weight: 700;
  }

  /* =========================================================
   * Reduced motion
   * ========================================================= */
  @media (prefers-reduced-motion: reduce) {
    .wave-header__bar,
    .wave-header__breadcrumbs,
    .wave-header__content {
      transition: none;
    }
  }
</style>
