---
/**
 * @file WaveHeader.astro
 * @description Reusable sticky wave header with smooth compact mode on scroll.
 * Used by ListingLayout and DetailLayout.
 *
 * IMPORTANT: This component wraps the ENTIRE page content (header + body)
 * so that the sticky bar has a tall-enough parent to stick for the full scroll.
 * Pass page body content via the default slot.
 *
 * Architecture:
 *   <WaveHeader>
 *     <breadcrumbs slot="breadcrumbs" />
 *     <header slot="content" />
 *     <body-content />  ← default slot
 *   </WaveHeader>
 *
 * Wave technique: SVG filled with --surface-warm hangs below the bar via
 * absolute positioning, creating a wavy overhang. Content scrolls behind it.
 */

interface Props {
  /**
   * Semantic padding-top preset for the expanded header.
   * `listing` = 3rem, `detail` = 2rem. Drives the data-wave-padding map in
   * css-var-themes.css instead of inline `style="--wave-header-padding-top"`
   * (SPEC-046 GAP-046-09a).
   */
  readonly paddingTop?: 'listing' | 'detail';
  /** Extra CSS classes on the root element. */
  readonly class?: string;
}

const { paddingTop = 'listing', class: className } = Astro.props;
---

<div
  class:list={['wave-header', className]}
  data-wave-padding={paddingTop}
  data-wave-header
>
  {/* Sentinel: sits at the top of the wrapper in normal flow.
      When it scrolls out of view (past the navbar), compact mode activates. */}
  <div class="wave-header__sentinel" data-wave-sentinel></div>

  {/* Sticky bar: sticks below navbar for the full page scroll */}
  <div class="wave-header__bar">
    <div class="wave-header__breadcrumbs">
      <div class="wave-header__container">
        <slot name="breadcrumbs" />
      </div>
    </div>

    <div class="wave-header__content">
      <div class="wave-header__container">
        <slot name="content" />
      </div>
    </div>

    {/* Wave hangs below the bar via absolute positioning.
        SVG fills the TOP with warm color, bottom is transparent.
        Content scrolls behind the wave overhang. */}
    <div class="wave-header__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,64 C288,120 576,0 864,64 C1152,128 1440,32 1440,32 L1440,0 L0,0 Z" fill="var(--surface-warm, #fdf6f0)" />
      </svg>
    </div>
  </div>

  {/* Page body: default slot. Being inside .wave-header gives the sticky bar
      a tall parent so it can stick for the entire page scroll. */}
  <slot />
</div>

<script>
  /**
   * WaveHeader compact-mode toggle, driven by scroll position with HYSTERESIS.
   *
   * The header expands only near the very top of the page and compacts once
   * you have scrolled clearly past it, with a wide dead zone between the two
   * thresholds. That dead zone is the whole point: collapsing/expanding the
   * sticky bar near the top shifts the scroll position by a few dozen px
   * (the breadcrumbs grow/shrink on-screen and the sticky bar re-lays-out
   * right at its pinning boundary). The previous `IntersectionObserver` used a
   * single crossing line, so that scroll shift re-crossed the line and toggled
   * the header straight back — it trembled when scrolling UP into the top
   * (measured: expanding bounced scrollY from ~10 back to ~55, re-compacting).
   * Two thresholds wider apart than that bounce absorb it.
   *
   * Still only toggles a CSS class — all visual changes remain CSS
   * transitions. Compatible with Astro View Transitions.
   */
  function initWaveHeaders(): void {
    const headers = document.querySelectorAll<HTMLElement>('[data-wave-header]');

    // Scroll offsets (px) for the two trigger lines. The gap (COMPACT_AT minus
    // EXPAND_AT) must exceed the scroll bounce that toggling near the top
    // induces (~45px measured; ~80px worst case if the breadcrumbs are tall).
    const EXPAND_AT = 8;
    const COMPACT_AT = 96;

    for (const header of headers) {
      const sentinel = header.querySelector<HTMLElement>('[data-wave-sentinel]');
      const bar = header.querySelector<HTMLElement>('.wave-header__bar');
      if (!sentinel || !bar) continue;

      if (header.dataset.waveInitialized === 'true') continue;
      header.dataset.waveInitialized = 'true';

      let compact = false;
      const setCompact = (next: boolean): void => {
        if (next === compact) return;
        compact = next;
        header.classList.toggle('wave-header--compact', next);
      };

      // Opt-in lock: a page can keep the wave header permanently compact by
      // setting `data-locked-compact="true"` on the root .wave-header element.
      // Used by the mobile fullscreen map view so the bar doesn't expand back
      // out when the auto-scroll lands at the top of the map.
      if (header.dataset.lockedCompact === 'true') {
        setCompact(true);
        continue;
      }

      let ticking = false;
      const evaluate = (): void => {
        ticking = false;
        // Respect a lock applied after init (e.g. the mobile map view sets it
        // on astro:page-load). Don't fight a deliberate lock.
        if (header.dataset.lockedCompact === 'true') {
          setCompact(true);
          return;
        }
        const y = window.scrollY;
        if (!compact && y >= COMPACT_AT) {
          setCompact(true);
        } else if (compact && y <= EXPAND_AT) {
          setCompact(false);
        }
      };

      const onScroll = (): void => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(evaluate);
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      // Set the initial state (handles navigating in already scrolled down).
      evaluate();

      document.addEventListener('astro:before-swap', () => {
        window.removeEventListener('scroll', onScroll);
        window.removeEventListener('resize', onScroll);
        header.dataset.waveInitialized = '';
      }, { once: true });
    }
  }

  initWaveHeaders();
  document.addEventListener('astro:after-swap', initWaveHeaders);
</script>

<style>
  /* Disable the browser's scroll anchoring on pages that use the wave header.
   *
   * This is the root-cause fix for the header trembling when scrolling back UP
   * toward the top. Expanding the bar grows the breadcrumbs (~80px) ABOVE the
   * current scroll position; with anchoring ON, the browser compensates by
   * nudging scrollY by that same ~80px to keep the visible content from
   * jumping — but that nudge crosses the compact trigger, which re-compacts,
   * which shrinks the bar again: a feedback loop. Measured directly: requesting
   * scrollY=4 bounced to ~63 with anchoring on, and stayed at 4 with it off.
   * The compact toggle itself never moves the scroll once anchoring is off.
   *
   * Scoped via `:has` so every other page keeps anchoring. `html` is the scroll
   * container in this app (the `overflow-x: clip` on html/body does not create
   * one), and `body` is covered too as a belt-and-suspenders. */
  :global(html:has(.wave-header)),
  :global(html:has(.wave-header) body) {
    overflow-anchor: none;
  }

  /* =========================================================
   * Expanded (default) state
   * ========================================================= */
  .wave-header {
    position: relative;
  }

  .wave-header__sentinel {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 20px;
    pointer-events: none;
  }

  .wave-header__bar {
    position: sticky;
    /* Pin flush against the navbar — the var is published by Header.astro
       (publishNavbarHeight). 80px is a safe fallback before JS hydrates. */
    top: var(--navbar-height, 80px);
    z-index: calc(var(--z-nav, 50) - 1);
    /* No background here: breadcrumbs + content have their own warm bg.
       This lets the wave SVG sit on a transparent background so the
       wavy edge reveals the page bg below. */
  }

  .wave-header__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-container-x);
  }

  .wave-header__breadcrumbs {
    padding-top: var(--wave-header-padding-top, 3rem);
    padding-bottom: 0.75rem;
    overflow: hidden;
    max-height: 80px;
    background-color: var(--surface-warm);
    /* NOTE: no `opacity` transition. The bar wrapper has no background of its
       own, so fading the breadcrumbs would expose the page behind it during
       the compact transition. `overflow: hidden` + `max-height: 0` already
       hide the content cleanly. */
    transition:
      max-height 0.3s ease,
      padding 0.3s ease;
  }

  .wave-header__content {
    padding-bottom: 1.5rem;
    background-color: var(--surface-warm);
    transition: padding 0.3s ease;
  }

  /* Wave: in flow but with negative margin so content overlaps behind it.
     SVG fills top with warm color, bottom is transparent.
     This creates a seamless warm-to-content transition with no white gap. */
  .wave-header__wave {
    line-height: 0;
    position: relative;
    pointer-events: none;
    transition: margin-bottom 0.3s ease;
  }

  .wave-header__wave svg {
    width: 100%;
    height: 80px;
    display: block;
    transition: height 0.3s ease;
  }

  /* =========================================================
   * Compact (scrolled) state — all CSS transitions, no JS
   * ========================================================= */
  .wave-header--compact .wave-header__breadcrumbs {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    pointer-events: none;
  }

  .wave-header--compact .wave-header__content {
    padding-top: 1.7rem;
    padding-bottom: 0;
    position: relative;
    z-index: 2;
  }

  .wave-header--compact .wave-header__wave {
    z-index: 1;
    margin-bottom: -48px;
  }

  .wave-header--compact .wave-header__wave svg {
    height: 48px;
    margin-top: -10px;
    filter: drop-shadow(0px 15px 5px #fff);
  }

  /* =========================================================
   * Reduced motion
   * ========================================================= */
  @media (prefers-reduced-motion: reduce) {
    .wave-header__breadcrumbs,
    .wave-header__content,
    .wave-header__wave,
    .wave-header__wave svg {
      transition: none;
    }
  }
</style>
