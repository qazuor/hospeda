---
/**
 * @file LanguageSwitcher.astro
 * @description Compact language switcher rendered as "ES | EN | PT".
 *
 * The active locale is displayed as a non-interactive highlighted label.
 * Inactive locales are anchor links that swap the URL's locale prefix while
 * preserving the rest of the path and trailing slash, allowing seamless
 * navigation between the same page in different languages.
 *
 * This is a pure Astro component - no client-side JavaScript is needed.
 */

import type { SupportedLocale } from '@/lib/i18n';
import { SUPPORTED_LOCALES } from '@/lib/i18n';

interface Props {
    /** Current active locale shown in the UI. */
    readonly locale: SupportedLocale;
    /** Additional CSS classes forwarded to the root <nav> element. */
    readonly class?: string;
}

const { locale: currentLocale, class: className } = Astro.props;

const currentPath = Astro.url.pathname;

/** Human-readable uppercase label for each locale code. */
const LOCALE_LABELS: Readonly<Record<SupportedLocale, string>> = {
    es: 'ES',
    en: 'EN',
    pt: 'PT',
} as const;

/**
 * Builds a URL that targets the given locale while keeping the rest of the
 * pathname intact. Handles the case where the path may or may not start with
 * a known locale segment.
 *
 * @param params - Object with the target locale.
 * @returns Absolute pathname string (e.g., "/en/alojamientos/").
 */
function buildLocaleUrl({ targetLocale }: { readonly targetLocale: SupportedLocale }): string {
    const segments = currentPath.split('/').filter(Boolean);

    if (segments.length > 0 && SUPPORTED_LOCALES.includes(segments[0] as SupportedLocale)) {
        segments[0] = targetLocale;
    } else {
        segments.unshift(targetLocale);
    }

    return `/${segments.join('/')}/`;
}
---

<nav
    aria-label="Language switcher"
    class:list={['inline-flex items-center gap-0.5 text-xs', className]}
>
    {SUPPORTED_LOCALES.map((loc, index) => {
        const isActive = loc === currentLocale;
        const label = LOCALE_LABELS[loc];

        return (
            <span class="inline-flex items-center">
                {isActive ? (
                    <span
                        class="px-1 font-bold text-primary"
                        aria-current="true"
                        aria-label={`Current language: ${label}`}
                    >
                        {label}
                    </span>
                ) : (
                    <a
                        href={buildLocaleUrl({ targetLocale: loc })}
                        hreflang={loc}
                        class="px-1 text-muted-foreground transition-colors duration-200 hover:text-foreground"
                        aria-label={`Switch to ${label}`}
                    >
                        {label}
                    </a>
                )}
                {index < SUPPORTED_LOCALES.length - 1 && (
                    <span class="text-muted-foreground/50 select-none" aria-hidden="true">|</span>
                )}
            </span>
        );
    })}
</nav>
