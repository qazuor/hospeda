---
/**
 * @file AccommodationCard.astro
 * @description Card component for displaying a single accommodation listing.
 * Features an image with overlay badges (type, location, rating, price),
 * a title with detail link, summary text, and amenity tags.
 * Composes shared components: CategoryBadge, LocationBadge, RatingBadge, AmenityTag.
 */
import { ArrowRightIcon } from "@repo/icons";
import { createT } from "@/lib/i18n";
import type { SupportedLocale } from "@/lib/i18n";
import type { AccommodationCardData } from "@/lib/api/transforms";
import { formatPrice } from "@/lib/format-utils";
import CategoryBadge from "@/components/shared/CategoryBadge.astro";
import LocationBadge from "@/components/shared/LocationBadge.astro";
import RatingBadge from "@/components/shared/RatingBadge.astro";
import AmenityTag from "@/components/shared/AmenityTag.astro";

/**
 * Props for the AccommodationCard component.
 * @property card - Accommodation data from the API transform layer
 * @property locale - Current locale for i18n translation lookups
 */
interface Props {
  /** Accommodation data from the API transform layer */
  readonly card: AccommodationCardData;
  /** Current locale for translations */
  readonly locale?: SupportedLocale;
}

const { card, locale = "es" } = Astro.props;
const t = createT(locale);

/** Formatted price string with currency symbol, or null if no price available */
const priceDisplay = card.price
  ? formatPrice({ amount: card.price.amount, currency: card.price.currency, locale })
  : null;
---

<article class="group overflow-hidden rounded-2xl bg-card shadow-card transition-all duration-300 hover:shadow-card-hover hover:-translate-y-1">
  <!-- Image -->
  <div class="relative h-48 overflow-hidden">
    <img src={card.featuredImage} alt={card.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" transition:name={`entity-${card.slug}`} />
    <div class="absolute inset-0 bg-gradient-to-t from-foreground/60 via-transparent to-transparent"></div>

    <!-- Badges -->
    <div class="absolute left-3 top-3 flex flex-wrap gap-1.5">
      <CategoryBadge category={card.type} />
      <LocationBadge location={card.location.city} />
    </div>

    <!-- Rating -->
    <RatingBadge rating={card.averageRating} reviewsCount={card.reviewsCount} noReviewsLabel={t('home.featuredAccommodations.noReviews', 'Sin reviews')} />

    <!-- Price -->
    <div class="absolute bottom-3 left-3 rounded-full bg-card/90 px-3 py-1.5 backdrop-blur-sm">
      {priceDisplay ? (
        <>
          <span class="text-sm font-bold text-foreground">{priceDisplay}</span>
          <span class="text-xs text-muted-foreground"> {t('home.featuredAccommodations.perNight', '/ noche')}</span>
        </>
      ) : (
        <span class="text-sm font-semibold text-primary">{t('home.featuredAccommodations.inquire', 'Consultar')}</span>
      )}
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col gap-2 p-4">
    <div class="flex items-center justify-between gap-2">
      <h3 class="text-sm font-semibold text-card-foreground leading-snug truncate">{card.name}</h3>
      <a href={`/${locale}/alojamientos/${card.slug}/`} class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-primary transition-colors hover:bg-primary hover:text-primary-foreground" aria-label={`${t('home.featuredAccommodations.viewDetail', 'Ver detalle de')} ${card.name}`}>
        <ArrowRightIcon size={16} />
      </a>
    </div>
    <p class="text-xs text-muted-foreground line-clamp-2 leading-relaxed">{card.summary}</p>

    <!-- Amenity tags -->
    <div class="flex flex-wrap gap-1">
      {(card.amenities ?? []).map((amenity) => (
        <AmenityTag amenity={amenity.label} />
      ))}
    </div>
  </div>
</article>
