---
import type { Stat } from "@/data/types";

interface Props {
  stat: Stat;
}

const { stat } = Astro.props;
const Icon = stat.icon;
---

<div class="flex flex-col items-center gap-2 rounded-xl bg-card p-4 shadow-sm text-center">
  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10" aria-hidden="true">
    <Icon size={20} weight="duotone" className="text-primary" />
  </div>
  <div>
    <p class="text-xl font-bold text-foreground md:text-2xl">{stat.value}</p>
    <p class="text-xs font-medium text-foreground">{stat.label}</p>
    <p class="text-2xs text-muted-foreground leading-tight">{stat.description}</p>
  </div>
</div>
