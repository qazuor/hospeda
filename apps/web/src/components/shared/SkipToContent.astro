---
/**
 * @file SkipToContent.astro
 * @description Accessibility skip link that allows keyboard users to bypass
 * repeated navigation and jump directly to the main content area.
 *
 * Rendered as visually hidden text that becomes visible on keyboard focus,
 * targeting the `#main-content` landmark. Must be the first focusable element
 * in the DOM — place it as the very first child of `<body>`.
 */
---

<a
	href="#main-content"
	class="skip-to-content"
>
	<span class="sr-only-text">Saltar al contenido</span>
</a>

<style>
	.skip-to-content {
		position: absolute;
		left: -9999px;
		top: auto;
		width: 1px;
		height: 1px;
		overflow: hidden;
		z-index: 999;

		/* Visible styles (applied on focus) */
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1rem;
		background-color: var(--core-background);
		color: var(--core-foreground);
		font-family: var(--font-sans, sans-serif);
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		border: 2px solid var(--brand-primary);
		border-radius: 0.375rem;
		white-space: nowrap;
	}

	.skip-to-content:focus,
	.skip-to-content:focus-visible {
		position: fixed;
		left: 1rem;
		top: 1rem;
		width: auto;
		height: auto;
		overflow: visible;
		outline: 2px solid var(--ring);
		outline-offset: 2px;
	}

	.sr-only-text {
		/* Text is always visible when the link itself is focused */
		display: inline;
	}
</style>
