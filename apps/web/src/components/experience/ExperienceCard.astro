---
/**
 * @file ExperienceCard.astro
 * @description Card component for an experience listing (SPEC-240 T-024).
 * Mirrors the GastronomyCard pattern: featured image, type badge, price tag,
 * rating stars + review count, destination name, and a "new" corner badge.
 *
 * Hydration: none — fully static Astro component.
 */

import { StarIcon, LocationIcon } from '@repo/icons';
import { buildUrl } from '@/lib/urls';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import type { ExperienceCardData } from '@/data/types';
import ExperiencePriceTag from './ExperiencePriceTag.astro';

interface Props {
    readonly data: ExperienceCardData;
    readonly locale: SupportedLocale;
    /**
     * When true the card image renders with `loading="eager"` and
     * `fetchpriority="high"` — set this on cards in the first visible row
     * so the browser treats them as LCP candidates. Defaults to false.
     */
    readonly eager?: boolean;
}

const { data, locale, eager = false } = Astro.props;
const { t } = createTranslations(locale);

const detailUrl = buildUrl({ locale, path: `experiencias/${data.slug}/` });

/** Type label from i18n (e.g. 'KAYAK_RENTAL' → 'Alquiler de kayak'). */
const typeLabel = t(`experience.type.${data.type}`, data.type);

const fullStars = Math.floor(data.averageRating);

/** "Nuevo" badge: created less than 30 days ago. */
const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
const isNew = data.createdAt
    ? Date.now() - new Date(data.createdAt).getTime() < THIRTY_DAYS_MS
    : false;

const featuredLabel = t('experience.card.featured', 'Destacada');
---

<article class="exp-card">
    <a href={detailUrl} class="exp-card__link" aria-label={data.name}>
        <!-- IMAGE AREA -->
        <div class="exp-card__image-area">
            <img
                src={data.featuredImage.url || '/assets/images/placeholder-experience.svg'}
                alt={data.featuredImage.caption ?? data.name}
                width="432"
                height="220"
                loading={eager ? 'eager' : 'lazy'}
                fetchpriority={eager ? 'high' : undefined}
                decoding="async"
                class="exp-card__img"
                data-fallback="/assets/images/placeholder-experience.svg"
                transition:name={`experience-${data.slug}`}
            />

            <!-- NEW corner badge -->
            {isNew && (
                <div class="exp-card__status-corner" aria-hidden="true">
                    <span class="exp-card__status-text">
                        {t('home.accommodations.badge.new', 'Nuevo')}
                    </span>
                </div>
            )}

            <!-- Featured badge -->
            {data.isFeatured && (
                <div class="exp-card__featured-badge featured-badge">
                    <StarIcon size={12} weight="fill" aria-hidden="true" />
                    <span>{featuredLabel}</span>
                </div>
            )}

            <!-- Wave separator -->
            <div class="exp-card__wave" aria-hidden="true">
                <svg
                    viewBox="0 0 432 40"
                    preserveAspectRatio="none"
                    fill="var(--core-card, white)"
                >
                    <path d="M0 40V22C72 8 144 0 216 6C288 12 360 24 432 22V40H0Z" />
                </svg>
            </div>
        </div>

        <!-- CONTENT AREA -->
        <div class="exp-card__content">
            <!-- Type + Location row -->
            <div class="exp-card__category-row">
                <span class="exp-card__type-badge">{typeLabel}</span>
                <div class="exp-card__location-bar">
                    <LocationIcon size={12} weight="fill" aria-hidden="true" />
                    <span>{data.destinationName}</span>
                </div>
            </div>

            <!-- Name -->
            <h3 class="exp-card__name">{data.name}</h3>

            <!-- Summary -->
            <p class="exp-card__description">{data.summary}</p>

            <!-- Stars + rating -->
            {data.averageRating > 0 && (
                <div class="exp-card__stars">
                    {Array.from({ length: 5 }).map((_, i) => (
                        <span
                            class={
                                i < fullStars
                                    ? 'exp-card__star--filled'
                                    : 'exp-card__star--empty'
                            }
                        >
                            <StarIcon
                                size={14}
                                weight={i < fullStars ? 'fill' : 'regular'}
                                aria-hidden="true"
                            />
                        </span>
                    ))}
                    <span class="exp-card__rating-value">
                        {data.averageRating.toFixed(1)}
                    </span>
                    {data.reviewsCount > 0 && (
                        <span class="exp-card__reviews-count">
                            ({data.reviewsCount} {t('common.reviews', 'reseñas')})
                        </span>
                    )}
                </div>
            )}

            <!-- Divider -->
            <div class="exp-card__divider" aria-hidden="true"></div>

            <!-- Price + CTA row -->
            <div class="exp-card__price-row">
                <ExperiencePriceTag
                    priceFrom={data.priceFrom}
                    priceUnit={data.priceUnit}
                    isPriceOnRequest={data.isPriceOnRequest}
                    locale={locale}
                />
                <span class="exp-card__cta-btn">
                    {t('common.readMore', 'Ver más')} →
                </span>
            </div>
        </div>
    </a>
</article>

<style>
    .exp-card {
        background-color: var(--core-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md, 12px);
        box-shadow: var(--shadow-card);
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: box-shadow 200ms ease-out;
    }

    .exp-card:hover {
        box-shadow: var(--shadow-card-hover);
    }

    .exp-card__link {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .exp-card__link:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
        border-radius: var(--radius-md, 12px);
    }

    /* IMAGE AREA */
    .exp-card__image-area {
        position: relative;
        height: clamp(160px, 30vw, 220px);
        overflow: hidden;
        border-radius: var(--radius-md, 12px) var(--radius-md, 12px) 0 0;
        background-color: var(--muted);
    }

    .exp-card__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 200ms ease-out;
    }

    .exp-card:hover .exp-card__img {
        transform: scale(1.08);
    }

    /* Status corner (Nuevo) */
    .exp-card__status-corner {
        position: absolute;
        top: 0;
        left: 0;
        width: 80px;
        height: 80px;
        overflow: hidden;
    }

    .exp-card__status-corner::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 0;
        height: 0;
        border-top: 80px solid var(--hospeda-forest);
        border-right: 80px solid transparent;
    }

    .exp-card__status-text {
        position: absolute;
        top: 16px;
        left: 4px;
        transform: rotate(-45deg);
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 14px;
        line-height: 22.4px;
        color: var(--primary-foreground);
        white-space: nowrap;
    }

    /* Featured badge */
    .exp-card__featured-badge {
        position: absolute;
        bottom: 48px;
        right: 12px;
    }

    /* Wave separator */
    .exp-card__wave {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40px;
        pointer-events: none;
    }

    .exp-card__wave svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    /* CONTENT AREA */
    .exp-card__content {
        background-color: var(--core-card);
        padding: 0 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }

    /* Category + location row */
    .exp-card__category-row {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .exp-card__type-badge {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        padding: 2px 10px;
        border-radius: var(--radius-pill, 9999px);
        background-color: var(--brand-primary-a12);
        color: var(--brand-primary);
        font-family: var(--font-sans);
        font-size: 11px;
        font-weight: 600;
        line-height: 1.4;
        white-space: nowrap;
        border: 1px solid var(--brand-primary-a25);
    }

    .exp-card__location-bar {
        display: flex;
        align-items: center;
        gap: 6px;
        min-width: 0;
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 12px;
        line-height: 1.4;
        color: var(--core-muted-foreground);
    }

    .exp-card__location-bar > :global(svg) {
        flex-shrink: 0;
    }

    .exp-card__location-bar > span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
    }

    /* Name */
    .exp-card__name {
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: clamp(1rem, 0.5vw + 0.875rem, 1.25rem);
        line-height: clamp(1.375rem, 0.5vw + 1.25rem, 1.75rem);
        color: var(--core-foreground);
        overflow: hidden;
        text-overflow: ellipsis;
        margin: 0;
    }

    /* Summary */
    .exp-card__description {
        font-family: var(--font-sans);
        font-weight: 400;
        font-size: clamp(0.75rem, 0.2vw + 0.625rem, 0.8125rem);
        line-height: 20.8px;
        color: var(--core-muted-foreground);
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        margin: 0;
    }

    /* Stars */
    .exp-card__stars {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .exp-card__star--filled {
        color: var(--rating-star);
        display: inline-flex;
    }

    .exp-card__star--empty {
        color: var(--core-muted-foreground);
        opacity: 0.4;
        display: inline-flex;
    }

    .exp-card__rating-value {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 13px;
        line-height: 19.2px;
        color: var(--core-foreground);
        margin-left: 4px;
    }

    .exp-card__reviews-count {
        font-family: var(--font-sans);
        font-weight: 400;
        font-size: 12px;
        line-height: 19.2px;
        color: var(--core-muted-foreground);
    }

    /* Divider */
    .exp-card__divider {
        height: 1px;
        background-color: var(--border);
        width: 100%;
    }

    /* Price + CTA row */
    .exp-card__price-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 4px;
    }

    .exp-card__cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 9999px;
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 12px;
        line-height: 19.2px;
        color: var(--core-foreground);
        background: linear-gradient(
            135deg,
            var(--brand-secondary) 0%,
            var(--core-background) 100%
        );
        white-space: nowrap;
        transition: opacity 200ms ease-out;
    }

    .exp-card:hover .exp-card__cta-btn {
        opacity: 0.85;
    }

    /* Mobile adjustments */
    @media (max-width: 767px) {
        .exp-card__image-area {
            height: 200px;
        }

        .exp-card__content {
            gap: 6px;
            padding-bottom: 12px;
        }

        .exp-card__description {
            -webkit-line-clamp: 3;
        }

        .exp-card__reviews-count {
            display: none;
        }

        .exp-card__featured-badge {
            bottom: 48px;
            left: 12px;
            right: auto;
            top: auto;
        }
    }
</style>
