---
/**
 * @file ExperienceContactCTA.astro
 * @description Contact CTA block for an experience listing (SPEC-240 T-027).
 *
 * Renders a WhatsApp deep link CTA when the experience has a phone number
 * stored under `contactInfo.whatsapp`. The deep link format is:
 *   https://wa.me/<phone>?text=<encoded-message>
 *
 * IMPORTANT: The public ExperiencePublicSchema only exposes `contactInfo.whatsapp`
 * (phone / email are withheld from the public tier per the SPEC-240 privacy model).
 * No booking widget — contact only (spec decision #4).
 *
 * Hydration: none — fully static Astro component.
 */

import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import type { ExperienceContactInfo } from '@/data/types';

interface Props {
    readonly contactInfo: ExperienceContactInfo | null;
    readonly experienceName: string;
    readonly locale: SupportedLocale;
}

const { contactInfo, experienceName, locale } = Astro.props;
const { t } = createTranslations(locale);

if (!contactInfo?.whatsapp) {
    // Nothing to render when no WhatsApp contact is available
    return;
}

/**
 * Sanitize the phone number: strip non-digit characters except leading '+'.
 * WhatsApp wa.me links expect E.164-like format without spaces or dashes.
 */
const phone = contactInfo.whatsapp.startsWith('+')
    ? '+' + contactInfo.whatsapp.slice(1).replace(/\D/g, '')
    : contactInfo.whatsapp.replace(/\D/g, '');

const messageTemplate = t(
    'experience.detail.whatsapp',
    'Hola, me interesa obtener más información sobre {{name}}'
).replace('{{name}}', experienceName);

const waUrl = `https://wa.me/${phone}?text=${encodeURIComponent(messageTemplate)}`;

const ctaLabel = t('experience.detail.whatsapp', 'Consultar por WhatsApp');
---

<section class="exp-contact-cta">
    <h3 class="exp-contact-cta__title">{t('experience.detail.contact', 'Contacto')}</h3>
    <a
        href={waUrl}
        class="exp-contact-cta__whatsapp-btn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={ctaLabel}
    >
        <!-- WhatsApp icon (inline SVG — minimal, no external dependency) -->
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            width="20"
            height="20"
            aria-hidden="true"
        >
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
        </svg>
        <span>{ctaLabel}</span>
    </a>
</section>

<style>
    .exp-contact-cta {
        display: flex;
        flex-direction: column;
        gap: var(--space-4, 16px);
        padding: var(--space-5, 20px);
        background-color: var(--surface-warm);
        border-radius: var(--radius-card, 24px);
        border: 1px solid var(--border);
    }

    .exp-contact-cta__title {
        font-family: var(--font-heading);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--core-foreground);
        margin: 0;
    }

    .exp-contact-cta__whatsapp-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 24px;
        border-radius: var(--radius-button, 8px);
        background-color: #25d366;
        color: white;
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: opacity 200ms ease-out;
        width: fit-content;
    }

    .exp-contact-cta__whatsapp-btn:hover {
        opacity: 0.85;
    }

    .exp-contact-cta__whatsapp-btn:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }
</style>
