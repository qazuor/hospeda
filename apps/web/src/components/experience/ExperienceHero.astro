---
/**
 * @file ExperienceHero.astro
 * @description Detail page hero for an experience listing (SPEC-240 T-027).
 * Shows name, type badge, pricing info (ExperiencePriceTag), average rating,
 * and a featured star. The FavoriteButton island lives in a right-side column
 * (mirrors EventDetailHeader / GastronomyDetailHeader pattern).
 *
 * Layout (HOS-84): a vertical stack — a back-button row on top, then a 2-column
 * `.exp-hero__body` row where `.exp-hero__main` holds badges + name + location +
 * pricing + rating and `.exp-hero__fav` anchors the favorite button on the right.
 *
 * Compact behavior comes from the shared `.wh-compact-*` utility classes
 * (contract defined once in WaveHeader.astro): `wh-compact-row` collapses the
 * main stack to one line, `wh-compact-title` shrinks the H1, `wh-compact-hide`
 * drops the back-button row + pricing + rating, `wh-compact-demote` inlines the
 * location, `wh-compact-badge` shrinks the type/new badges. Only the badges gap
 * remains as a genuinely local override below.
 *
 * DIVERGENCES from the accommodation reference (`DetailHeader.astro`): the
 * `.exp-hero__body` row does NOT set `align-items: center` in compact mode.
 * There is no price-badge — pricing lives in the separate `ExperiencePriceTag`
 * sub-component, collapsed here via `.exp-hero__pricing`. The FavoriteButton
 * also passes `count`/`showCount={true}` — kept unchanged.
 */

import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';
import { StarIcon, LocationIcon } from '@repo/icons';
import type { ExperienceDetailData } from '@/data/types';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import ExperiencePriceTag from './ExperiencePriceTag.astro';
import HeaderBackButton from '@/components/shared/ui/HeaderBackButton.astro';

interface Props {
    readonly experience: ExperienceDetailData;
    readonly locale: SupportedLocale;
    /** Whether the current user is authenticated (forwarded to FavoriteButton). */
    readonly isAuthenticated?: boolean;
    /** SSR-resolved initial favorite state for the current user. */
    readonly initialIsFavorited?: boolean;
    /** SSR-resolved bookmark id for toggling off without a re-check. */
    readonly initialBookmarkId?: string | null;
    /** Total bookmark count from the public API. */
    readonly bookmarkCount?: number;
}

const {
    experience,
    locale,
    isAuthenticated = false,
    initialIsFavorited,
    initialBookmarkId = null,
    bookmarkCount,
} = Astro.props;
const { t, tPlural } = createTranslations(locale);

const typeLabel = t(`experience.type.${experience.type}`, experience.type);

const fullStars = Math.floor(experience.averageRating);

const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;
const isNew = experience.createdAt
    ? Date.now() - new Date(experience.createdAt).getTime() < THIRTY_DAYS_MS
    : false;
---

<header class="exp-hero">
    <div class="exp-hero__back-row wh-compact-hide">
        <HeaderBackButton href={`/${locale}/experiencias/`} locale={locale} />
    </div>

    <div class="exp-hero__body">
        <!-- Main column: badges, title, location, pricing, rating -->
        <div class="exp-hero__main wh-compact-row">
            <div class="exp-hero__badges">
                <span class="exp-hero__type-badge wh-compact-badge">{typeLabel}</span>
                {experience.isFeatured && (
                    <span class="featured-badge">
                        <StarIcon size={12} weight="fill" aria-hidden="true" />
                        <span>{t('experience.card.featured', 'Destacada')}</span>
                    </span>
                )}
                {isNew && (
                    <span class="exp-hero__new-badge wh-compact-badge">
                        {t('home.accommodations.badge.new', 'Nuevo')}
                    </span>
                )}
            </div>

            <h1 class="exp-hero__name wh-compact-title">{experience.name}</h1>

            {experience.destinationName && (
                <div class="exp-hero__location wh-compact-demote">
                    <LocationIcon size={16} weight="fill" aria-hidden="true" />
                    <span>{experience.destinationName}</span>
                </div>
            )}

            <!-- Pricing -->
            <div class="exp-hero__pricing wh-compact-hide">
                <ExperiencePriceTag
                    priceFrom={experience.priceFrom}
                    priceUnit={experience.priceUnit}
                    isPriceOnRequest={experience.isPriceOnRequest}
                    locale={locale}
                />
            </div>

            {experience.averageRating > 0 && (
                <div class="exp-hero__rating wh-compact-hide">
                    <div class="exp-hero__stars" aria-hidden="true">
                        {Array.from({ length: 5 }).map((_, i) => (
                            <span
                                class={
                                    i < fullStars
                                        ? 'exp-hero__star--filled'
                                        : 'exp-hero__star--empty'
                                }
                            >
                                <StarIcon
                                    size={16}
                                    weight={i < fullStars ? 'fill' : 'regular'}
                                    aria-hidden="true"
                                />
                            </span>
                        ))}
                    </div>
                    <span class="exp-hero__rating-value">
                        {experience.averageRating.toFixed(1)}
                    </span>
                    {experience.reviewsCount > 0 && (
                        <span class="exp-hero__reviews-count">
                            · {tPlural('review.list.totalReviews', experience.reviewsCount, { count: experience.reviewsCount })}
                        </span>
                    )}
                </div>
            )}
        </div>

        <!-- Favorite column -->
        <div class="exp-hero__fav">
            <FavoriteButton
                client:load
                entityId={experience.id}
                entityType="EXPERIENCE"
                initialIsFavorited={initialIsFavorited}
                initialBookmarkId={initialBookmarkId}
                count={bookmarkCount}
                variant="standalone"
                showCount={true}
                locale={locale}
                isAuthenticated={isAuthenticated}
            />
        </div>
    </div>
</header>

<style>
    /* Vertical stack: back-button row on top, then the body row. */
    .exp-hero {
        display: flex;
        flex-direction: column;
        gap: var(--space-2, 8px);
    }

    /* Back-button row — collapses out via `wh-compact-hide` in compact mode, so
       it needs its own max-height/opacity transition to animate. */
    .exp-hero__back-row {
        overflow: hidden;
        max-height: 3em;
        opacity: 1;
        transition:
            max-height 0.3s ease,
            opacity 0.2s ease;
    }

    /* Body: main column (flex:1) + fav column (shrink:0) */
    .exp-hero__body {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        gap: 16px;
    }

    .exp-hero__main {
        display: flex;
        flex-direction: column;
        gap: var(--space-3, 12px);
        flex: 1;
        min-width: 0;
        transition: gap 0.3s ease;
    }

    .exp-hero__fav {
        flex-shrink: 0;
        padding-top: 4px;
    }

    .exp-hero__badges {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
    }

    .exp-hero__type-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 14px;
        border-radius: var(--radius-pill, 9999px);
        background-color: var(--brand-primary-a12);
        color: var(--brand-primary-link);
        border: 1px solid var(--brand-primary-a25);
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 600;
        line-height: 1.4;
        transition: padding 0.3s ease, font-size 0.3s ease;
    }

    .exp-hero__new-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 14px;
        border-radius: var(--radius-pill, 9999px);
        background-color: var(--hospeda-forest);
        /* SPEC-308: white ink on the saturated green badge (primary-foreground
           flips to dark in dark mode and fails AA on green). */
        color: white;
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 600;
        line-height: 1.4;
        transition: padding 0.3s ease, font-size 0.3s ease;
    }

    .exp-hero__name {
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: clamp(1.75rem, 2vw + 1rem, 2.5rem);
        line-height: 1.2;
        color: var(--core-foreground);
        margin: 0;
        transition: font-size 0.3s ease;
    }

    .exp-hero__location {
        display: flex;
        align-items: center;
        gap: 6px;
        color: var(--core-muted-foreground);
        font-family: var(--font-sans);
        font-size: 0.95rem;
        transition: font-size 0.3s ease;
    }

    .exp-hero__pricing {
        display: flex;
        align-items: center;
        overflow: hidden;
        max-height: 3em;
        opacity: 1;
        transition: max-height 0.3s ease, opacity 0.3s ease;
    }

    .exp-hero__rating {
        display: flex;
        align-items: center;
        gap: 8px;
        overflow: hidden;
        max-height: 3em;
        opacity: 1;
        transition: max-height 0.3s ease, opacity 0.3s ease;
    }

    .exp-hero__stars {
        display: flex;
        align-items: center;
        gap: 2px;
    }

    .exp-hero__star--filled {
        color: var(--rating-star);
        display: inline-flex;
    }

    .exp-hero__star--empty {
        color: var(--core-muted-foreground);
        opacity: 0.4;
        display: inline-flex;
    }

    .exp-hero__rating-value {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--core-foreground);
    }

    .exp-hero__reviews-count {
        font-family: var(--font-sans);
        font-size: 0.9rem;
        color: var(--core-muted-foreground);
    }

    /* =========================================================
     * Compact state — only the genuinely experience-specific override
     * (badges gap) remains here; the row collapse, title shrink, location
     * demote, pricing/rating/back hide, and badge shrink all come from the
     * shared `.wh-compact-*` utilities applied in the markup (contract in
     * WaveHeader.astro). DIVERGENCES from the accommodation reference: no
     * outer `align-items: center` override on `.exp-hero__body`, and no
     * price-badge (pricing lives in `ExperiencePriceTag`, collapsed via
     * `.exp-hero__pricing`).
     * ========================================================= */
    :global(.wave-header--compact) .exp-hero__badges {
        gap: 4px;
    }

    @media (prefers-reduced-motion: reduce) {
        .exp-hero__back-row,
        .exp-hero__main,
        .exp-hero__type-badge,
        .exp-hero__new-badge,
        .exp-hero__name,
        .exp-hero__location,
        .exp-hero__pricing,
        .exp-hero__rating {
            transition: none;
        }
    }
</style>
