---
/**
 * Server Island wrapper for NewsletterCTA.
 * Used with `server:defer` so auth state is resolved at request time,
 * even on pre-rendered (SSG) pages.
 */
import { NewsletterCTA } from './NewsletterCTA.client';

interface Props {
  readonly locale?: 'es' | 'en';
  readonly isSubscribed?: boolean;
  readonly className?: string;
}

const { locale, isSubscribed, className } = Astro.props;
const isAuthenticated = !!Astro.locals.user;
---

<NewsletterCTA
  client:idle
  locale={locale}
  isAuthenticated={isAuthenticated}
  isSubscribed={isSubscribed}
  className={className}
/>
