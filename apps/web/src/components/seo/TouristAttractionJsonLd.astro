---
/**
 * @file TouristAttractionJsonLd.astro
 * @description TouristAttraction JSON-LD component for experiences and attractions.
 * Generates schema.org TouristAttraction structured data.
 *
 * SPEC-268 F2/F3: new component for experience and attraction detail pages.
 */

import JsonLd from './JsonLd.astro';

interface Props {
	readonly name: string;
	readonly description: string;
	readonly url: string;
	readonly image?: string;
	readonly telephone?: string;
}

const {
	name,
	description,
	url,
	image,
	telephone,
} = Astro.props;

const structuredData: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'TouristAttraction',
	name,
	description,
	url,
};

if (image) {
	structuredData.image = image;
}

if (telephone) {
	structuredData.telephone = telephone;
}
---

<JsonLd data={structuredData} />
