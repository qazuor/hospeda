---
/**
 * @file ArticleJsonLd.astro
 * @description Article JSON-LD component for blog posts.
 * Generates schema.org Article (or subtype) structured data.
 *
 * SPEC-157 REQ-7: fixed publisher URL TLD (was hospeda.com, corrected to
 * hospeda.com.ar via getSiteUrl()) and added `articleType` prop so callers
 * can emit BlogPosting, NewsArticle, etc. instead of the generic Article type.
 */

import JsonLd from './JsonLd.astro';
import { getSiteUrl } from '@/lib/env';

/** Article author interface */
export interface ArticleAuthor {
	/** Author name */
	readonly name: string;
	/** Author profile URL */
	readonly url?: string;
}

/** Props interface for ArticleJsonLd component. */
interface Props {
	/** Article headline/title */
	readonly headline: string;
	/** Article description */
	readonly description: string;
	/** URL of the article page */
	readonly url: string;
	/** Image URL for the article */
	readonly image?: string;
	/** Publication date in ISO 8601 format */
	readonly datePublished: string;
	/** Last modification date in ISO 8601 format */
	readonly dateModified?: string;
	/** Article author information */
	readonly author: ArticleAuthor;
	/**
	 * Schema.org Article subtype.
	 * Defaults to 'Article'. Use 'BlogPosting', 'NewsArticle', etc.
	 * when the entity matches a more specific type.
	 */
	readonly articleType?: string;
}

const {
	headline,
	description,
	url,
	image,
	datePublished,
	dateModified,
	author,
	articleType = 'Article',
} = Astro.props;

const siteUrl = getSiteUrl().replace(/\/$/, '');

const structuredData: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': articleType,
	headline,
	description,
	url,
	datePublished,
	author: {
		'@type': 'Person',
		name: author.name,
		...(author.url && { url: author.url }),
	},
	publisher: {
		'@type': 'Organization',
		name: 'Hospeda',
		url: siteUrl,
	},
};

if (image) {
	structuredData.image = image;
}

if (dateModified) {
	structuredData.dateModified = dateModified;
}
---

<JsonLd data={structuredData} />
