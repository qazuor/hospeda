---
/**
 * @file SEOHead.astro
 * @description SEO Head component for Hospeda web2 application.
 * Renders essential meta tags, Open Graph tags, Twitter Card tags, and hreflang links.
 */

import { getSiteUrl } from '@/lib/env';
import { SUPPORTED_LOCALES, type SupportedLocale } from '@/lib/i18n';
import { BRAND_NAME, TITLE_SEPARATOR, TWITTER_SITE_HANDLE } from '@/lib/constants';
import { buildOgImagePath } from '@/lib/og-template';

export interface Props {
    /** Page title (will be suffixed with " | Hospeda" unless it already IS the brand name) */
    title: string;
    /** Meta description for the page */
    description: string;
    /** Canonical URL of the page */
    canonical: string;
    /** Open Graph and Twitter Card image URL */
    image?: string;
    /** Whether to add noindex robots meta tag */
    noindex?: boolean;
    /** Page locale for Open Graph and hreflang tags */
    locale?: SupportedLocale;
    /** Open Graph type */
    type?: 'website' | 'article';
    /** ISO date emitted as `article:published_time` (only when type === 'article'). */
    articlePublishedTime?: string;
    /** ISO date emitted as `article:modified_time` (only when type === 'article'). */
    articleModifiedTime?: string;
    /**
     * OG card type badge (PHOTO mode). When set, the auto-generated `/api/og`
     * URL renders the photo card with this label (e.g. Alojamiento/Destino/
     * Evento/Guía). Ignored when an explicit `image` is provided.
     */
    ogType?: string;
    /**
     * Featured image URL for the OG PHOTO card. Passed to `/api/og?image=...`.
     * Switches the generated card to photo mode. Ignored when an explicit
     * `image` (final OG image URL) is provided.
     */
    ogImage?: string;
    /** Subtitle line for the OG PHOTO card (e.g. locality/region). */
    ogSubtitle?: string;
    /** Rating value for the OG PHOTO card (e.g. "4.8"). */
    ogRating?: string;
    /** Caveat tagline for the OG BRAND card. */
    ogTagline?: string;
}

const {
    title,
    description,
    canonical,
    image,
    noindex = false,
    locale = 'es',
    type = 'website',
    articlePublishedTime,
    articleModifiedTime,
    ogType,
    ogImage,
    ogSubtitle,
    ogRating,
    ogTagline,
} = Astro.props;

const fullTitle = title === BRAND_NAME ? BRAND_NAME : `${title}${TITLE_SEPARATOR}${BRAND_NAME}`;

const generateAlternateUrl = (targetLocale: string): string => {
    const url = new URL(canonical);
    const pathParts = url.pathname.split('/').filter(Boolean);

    if (pathParts.length > 0 && SUPPORTED_LOCALES.includes(pathParts[0] as (typeof SUPPORTED_LOCALES)[number])) {
        pathParts[0] = targetLocale;
    } else {
        pathParts.unshift(targetLocale);
    }

    url.pathname = `/${pathParts.join('/')}/`;
    return url.href;
};

const esUrl = generateAlternateUrl('es');
const enUrl = generateAlternateUrl('en');
const ptUrl = generateAlternateUrl('pt');

const OG_LOCALE_MAP = { es: 'es_AR', en: 'en_US', pt: 'pt_BR' } as const;
const ogLocale = OG_LOCALE_MAP[locale];
// og:locale:alternate for the other two locales so OG consumers (Facebook etc.)
// know the page has translations. hreflang already covers this for Google.
const ogLocaleAlternates = (Object.keys(OG_LOCALE_MAP) as SupportedLocale[])
    .filter((l) => l !== locale)
    .map((l) => OG_LOCALE_MAP[l]);

// Default OG image via dynamic generation endpoint — ensures every page has a social preview.
// SPEC-157 REQ-8: coerce to an absolute URL. Social scrapers ignore relative
// paths, so a page passing e.g. "/og-image.png" would emit an invalid og:image.
// new URL(image, siteBase) resolves relative paths and passes absolute ones through.
//
// Precedence: an explicit `image` (a final OG image URL) wins. Otherwise we
// assemble the `/api/og?...` URL from the OG-card props. `ogImage`+`ogType`
// produce a PHOTO card (entity detail pages); `ogTagline` alone produces a
// BRAND card (home/listings). Passing nothing still yields a valid brand card,
// keeping every page backward-compatible.
const siteBase = getSiteUrl();
const generatedOgPath = buildOgImagePath({
    title,
    description,
    type: ogType,
    image: ogImage,
    subtitle: ogSubtitle,
    rating: ogRating,
    tagline: ogTagline,
});
const ogImageUrl = new URL(image ?? generatedOgPath, siteBase).href;
---

<!-- Title and meta description -->
<title>{fullTitle}</title>
<meta name="description" content={description} />

<!-- Canonical URL -->
<link rel="canonical" href={canonical} />

<!-- Robots meta tag (only when noindex is true) -->
{noindex && <meta name="robots" content="noindex,follow" />}

<!-- Open Graph tags -->
<meta property="og:type" content={type} />
{type === 'article' && articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime} />
)}
{type === 'article' && articleModifiedTime && (
    <meta property="article:modified_time" content={articleModifiedTime} />
)}
<meta property="og:url" content={canonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:locale" content={ogLocale} />
{ogLocaleAlternates.map((altLocale) => (
    <meta property="og:locale:alternate" content={altLocale} />
))}
<meta property="og:site_name" content="Hospeda" />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={fullTitle} />

<!-- Twitter Card tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={TWITTER_SITE_HANDLE} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={fullTitle} />

<!-- Hreflang tags for i18n -->
<link rel="alternate" hreflang="es" href={esUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="pt" href={ptUrl} />
<link rel="alternate" hreflang="x-default" href={esUrl} />
