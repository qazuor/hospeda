---
/**
 * @file PlaceJsonLd.astro
 * @description TouristDestination JSON-LD component for destination pages.
 * Generates schema.org TouristDestination structured data.
 *
 * SPEC-157 REQ-7: extended to accept geo coordinates so detail pages no longer
 * need inline JSON-LD blocks.
 */

import JsonLd from './JsonLd.astro';

/** Address interface for destination structured data. */
export interface PlaceAddress {
	/** City or locality name */
	readonly addressLocality: string;
	/** State or region name */
	readonly addressRegion?: string;
	/** Country code (ISO 3166-1 alpha-2) */
	readonly addressCountry: string;
}

/** GeoCoordinates interface for destination structured data. */
export interface PlaceGeo {
	/** Latitude as a decimal number */
	readonly latitude: number;
	/** Longitude as a decimal number */
	readonly longitude: number;
}

/** Props interface for PlaceJsonLd component. */
interface Props {
	/** Name of the destination */
	readonly name: string;
	/** Description of the destination */
	readonly description: string;
	/** Canonical URL of the destination page */
	readonly url: string;
	/** Hero image URL for the destination */
	readonly image?: string;
	/** Address information for the destination */
	readonly address?: PlaceAddress;
	/** GPS coordinates for GeoCoordinates structured data */
	readonly geo?: PlaceGeo;
	/**
	 * Canonical external entity URLs for disambiguation (schema.org `sameAs`),
	 * e.g. the Wikipedia/Wikidata page of the destination. When present and
	 * non-empty, emitted as `sameAs` on the TouristDestination.
	 */
	readonly sameAs?: ReadonlyArray<string>;
}

const { name, description, url, image, address, geo, sameAs } = Astro.props;

const structuredData: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'TouristDestination',
	name,
	description,
	url,
};

if (image) {
	structuredData.image = image;
}

if (address) {
	structuredData.address = {
		'@type': 'PostalAddress',
		addressLocality: address.addressLocality,
		addressCountry: address.addressCountry,
		...(address.addressRegion && { addressRegion: address.addressRegion }),
	};
}

if (geo) {
	structuredData.geo = {
		'@type': 'GeoCoordinates',
		latitude: geo.latitude,
		longitude: geo.longitude,
	};
}

if (sameAs && sameAs.length > 0) {
	structuredData.sameAs = [...sameAs];
}
---

<JsonLd data={structuredData} />
