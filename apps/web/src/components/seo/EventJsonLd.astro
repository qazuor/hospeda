---
/**
 * @file EventJsonLd.astro
 * @description Event JSON-LD component for events.
 * Generates schema.org Event structured data.
 *
 * SPEC-095: callers building the venue address MUST derive locality/region/
 * country from the event's `eventLocation.cityDestination` projection — this
 * component does not read the legacy `location.city`. Use
 * `parseCityPathToAddress({ cityName, cityPath })` from
 * `@/lib/seo/address-from-city` and pass the `formatted` address string to
 * the `location.address` prop.
 *
 * SPEC-157 REQ-7: extended to accept eventStatus and offers so detail pages
 * no longer need inline JSON-LD blocks.
 */

import JsonLd from './JsonLd.astro';
import { toJsonLdEventDate } from '@/lib/seo/event-json-ld-date';

/** Event location interface */
export interface EventLocation {
	/** Name of the location/venue */
	readonly name: string;
	/** Street address of the location */
	readonly address: string;
	/** City or locality (used for addressLocality in PostalAddress) */
	readonly addressLocality?: string;
}

/** Event offer interface (schema.org Offer) */
export interface EventOffer {
	/** schema.org type: 'Offer' or 'AggregateOffer' */
	readonly type: 'Offer' | 'AggregateOffer';
	/** Currency code (ISO 4217) */
	readonly priceCurrency: string;
	/** Single price (used in Offer) */
	readonly price?: number;
	/** Lowest price (used in AggregateOffer) */
	readonly lowPrice?: number;
	/** Highest price (used in AggregateOffer) */
	readonly highPrice?: number;
}

/** Props interface for EventJsonLd component. */
interface Props {
	/** Name of the event */
	readonly name: string;
	/** Description of the event */
	readonly description: string;
	/** Start date and time in ISO 8601 format */
	readonly startDate: string;
	/** End date and time in ISO 8601 format */
	readonly endDate?: string;
	/**
	 * Date precision (HOS-280). `'MONTH'` events only have a known month/year
	 * (the day is a storage placeholder, always the 1st) — `startDate`/
	 * `endDate` are truncated to `YYYY-MM` so the structured data never
	 * claims a specific day it doesn't actually have. schema.org's `Date`
	 * type accepts a bare `YYYY-MM` value. Defaults to `'EXACT'` (today's
	 * behavior: full ISO date-time strings, unchanged).
	 */
	readonly precision?: 'EXACT' | 'MONTH';
	/** URL of the event page */
	readonly url: string;
	/** Image URL for the event */
	readonly image?: string;
	/** Event location information */
	readonly location: EventLocation;
	/** Event organizer name */
	readonly organizer?: string;
	/**
	 * schema.org EventStatus URL.
	 * E.g. 'https://schema.org/EventScheduled', 'https://schema.org/EventCancelled'.
	 * When provided, emitted as-is as the `eventStatus` field.
	 */
	readonly eventStatus?: string;
	/** Offer or AggregateOffer data for ticketed events */
	readonly offers?: EventOffer;
}

const {
	name,
	description,
	startDate,
	endDate,
	precision = 'EXACT',
	url,
	image,
	location,
	organizer,
	eventStatus,
	offers,
} = Astro.props;

const jsonLdStartDate = toJsonLdEventDate({ isoDate: startDate, precision });
const jsonLdEndDate = endDate ? toJsonLdEventDate({ isoDate: endDate, precision }) : endDate;

const structuredData: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name,
	description,
	startDate: jsonLdStartDate,
	url,
	location: {
		'@type': 'Place',
		name: location.name,
		address: {
			'@type': 'PostalAddress',
			streetAddress: location.address,
			...(location.addressLocality && { addressLocality: location.addressLocality }),
		},
	},
};

if (jsonLdEndDate) {
	structuredData.endDate = jsonLdEndDate;
}

if (image) {
	structuredData.image = image;
}

if (organizer) {
	structuredData.organizer = {
		'@type': 'Organization',
		name: organizer,
	};
}

if (eventStatus) {
	structuredData.eventStatus = eventStatus;
}

if (offers) {
	const offerBlock: Record<string, unknown> = {
		'@type': offers.type,
		priceCurrency: offers.priceCurrency,
	};
	if (offers.price !== undefined) {
		offerBlock.price = offers.price;
	}
	if (offers.lowPrice !== undefined) {
		offerBlock.lowPrice = offers.lowPrice;
	}
	if (offers.highPrice !== undefined) {
		offerBlock.highPrice = offers.highPrice;
	}
	structuredData.offers = offerBlock;
}
---

<JsonLd data={structuredData} />
