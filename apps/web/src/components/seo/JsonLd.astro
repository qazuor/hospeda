---
/**
 * @file JsonLd.astro
 * @description Generic JSON-LD wrapper component.
 * Renders structured data in JSON-LD format for search engines.
 */

/**
 * Props interface for JsonLd component.
 */
interface Props {
  /** Structured data object to be serialized as JSON-LD */
  readonly data: Record<string, unknown>;
}

const { data } = Astro.props;

// Escape HTML-unsafe chars to prevent XSS injection via JSON-LD:
//   < → \u003c prevents </script> injection
//   > → \u003e prevents SGML comment tricks
//   & → \u0026 prevents HTML entity confusion
const jsonLdContent = JSON.stringify(data, null, 0)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026');
---

<script type="application/ld+json" set:html={jsonLdContent} />
