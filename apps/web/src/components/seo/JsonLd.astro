---
/**
 * @file JsonLd.astro
 * @description Generic JSON-LD wrapper component.
 * Renders structured data in JSON-LD format for search engines.
 */

/**
 * Props interface for JsonLd component.
 */
interface Props {
  /** Structured data object to be serialized as JSON-LD */
  readonly data: Record<string, unknown>;
}

const { data } = Astro.props;

// Escape < as \u003c to prevent </script> injection (stored XSS via JSON-LD)
const jsonLdContent = JSON.stringify(data, null, 0).replace(/</g, '\\u003c');
---

<script type="application/ld+json" set:html={jsonLdContent} />
