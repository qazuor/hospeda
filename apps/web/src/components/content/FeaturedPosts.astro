---
/**
 * Server Island: Featured blog posts section for the homepage.
 * Fetches featured posts from the API and renders them as cards.
 * Used with server:defer for dynamic content on a static shell.
 */
import BlogPostCard from '../blog/BlogPostCard.astro';
import EmptyState from '../ui/EmptyState.astro';
import { postsApi } from '../../lib/api/endpoints';
import { extractFeaturedImageUrl } from '../../lib/media';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const result = await postsApi.list({ pageSize: 6, sortBy: 'createdAt', sortOrder: 'desc' });
const posts = result.ok ? result.data.items : [];

const postCards = posts.map((post) => {
  const p = post as Record<string, unknown>;
  return {
    slug: String(p.slug || ''),
    title: String(p.title || ''),
    summary: String(p.summary || p.content || ''),
    featuredImage: extractFeaturedImageUrl(p, '/images/placeholder-post.svg'),
    category: String(p.category || ''),
    publishedAt: String(p.publishedAt || ''),
    readingTimeMinutes: Number(p.readingTimeMinutes || 0),
    authorName: String(p.authorName || ''),
    isFeatured: Boolean(p.isFeatured),
  };
});
---

{postCards.length > 0 ? (
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {postCards.map((post) => (
        <BlogPostCard
          post={post}
          locale={locale}
        />
    ))}
  </div>
) : (
  <EmptyState
    title="No hay publicaciones destacadas"
    message="Próximamente agregaremos publicaciones."
  />
)}
