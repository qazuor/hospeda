---
/**
 * Platform statistics section with panoramic river photo background
 * and glassmorphism stat cards. Animated counters on viewport entry.
 * Progressive enhancement: solid semi-transparent bg on browsers without backdrop-filter.
 */
import SectionWrapper from '../ui/SectionWrapper.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import { CounterAnimation } from './CounterAnimation.client.tsx';
import { t, type SupportedLocale } from '../../lib/i18n';

interface StatItem {
  value: number;
  suffix?: string;
  prefix?: string;
  label: string;
}

interface Props {
  /** URL for the section background image */
  backgroundImage?: string;
  /** Array of stat items to display; defaults to hardcoded platform stats */
  stats?: StatItem[];
  /** Locale for translations */
  locale?: SupportedLocale;
}

const { backgroundImage, stats, locale = 'es' } = Astro.props;

/** Default platform statistics */
const defaultStats: StatItem[] = [
  { value: 500, suffix: '+', label: t({ locale, namespace: 'home', key: 'statistics.accommodations', fallback: 'Alojamientos' }) },
  { value: 50, suffix: '+', label: t({ locale, namespace: 'home', key: 'statistics.destinations', fallback: 'Destinos' }) },
  { value: 1000, suffix: '+', label: t({ locale, namespace: 'home', key: 'statistics.reviews', fallback: 'Resenas' }) },
  { value: 10, suffix: '+', label: t({ locale, namespace: 'home', key: 'statistics.experience', fallback: 'Anos de experiencia' }) },
];

const displayStats = stats ?? defaultStats;
---

<SectionWrapper variant="image" backgroundImage={backgroundImage} class={!backgroundImage ? 'bg-primary-900' : ''}>
  <SectionHeader
    title={t({ locale, namespace: 'home', key: 'statistics.title', fallback: 'Numeros que hablan por si solos' })}
    accentSubtitle={t({ locale, namespace: 'home', key: 'statistics.accentSubtitle', fallback: 'Nuestra plataforma' })}
    align="center"
    class="text-white [&_h2]:text-white [&_p]:text-white/80"
  />
  <div class="grid grid-cols-2 gap-6 md:grid-cols-4 md:gap-8">
    {displayStats.map((stat) => (
      <div class="glassmorphism-card rounded-2xl border border-white/20 p-6 text-center backdrop-blur-md sm:p-8">
        <CounterAnimation
          client:visible
          targetValue={stat.value}
          suffix={stat.suffix}
          prefix={stat.prefix}
          label={stat.label}
          locale={locale}
          class="[&_.counter-number]:font-serif [&_.counter-number]:text-4xl [&_.counter-number]:font-bold [&_.counter-number]:text-white sm:[&_.counter-number]:text-5xl"
        />
      </div>
    ))}
  </div>
</SectionWrapper>

<style>
  /*
   * Glassmorphism with progressive enhancement.
   * This section always renders on a dark background (photo or primary-900),
   * so white-alpha and black-alpha values are intentional in both themes.
   */

  /* Glassmorphism with progressive enhancement */
  .glassmorphism-card {
    background-color: rgb(255 255 255 / 0.08);
  }

  @supports (backdrop-filter: blur(1px)) {
    .glassmorphism-card {
      backdrop-filter: blur(12px);
      background-color: rgb(255 255 255 / 0.1);
    }
  }

  /* Mobile fallback: no blur, more opaque */
  @media (max-width: 639px) {
    .glassmorphism-card {
      backdrop-filter: none;
      background-color: rgb(0 0 0 / 0.4);
    }
  }
</style>
