---
/**
 * Server Island: Featured/upcoming events section for the homepage.
 * Fetches upcoming events from the API and renders them as cards.
 * Used with server:defer for dynamic content on a static shell.
 */
import EventCard from '../event/EventCard.astro';
import EmptyState from '../ui/EmptyState.astro';
import { eventsApi } from '../../lib/api/endpoints';
import { toEventCardProps } from '../../lib/api/transforms';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const result = await eventsApi.list({ pageSize: 4, sortBy: 'startDate', sortOrder: 'asc' });
const events = result.ok ? result.data.items : [];

const eventCards = events.map((evt) =>
  toEventCardProps({ item: evt as Record<string, unknown> })
);
---

{eventCards.length > 0 ? (
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    {eventCards.map((event) => (
        <EventCard
          event={event}
          locale={locale}
        />
    ))}
  </div>
) : (
  <EmptyState
    title="No hay eventos próximos"
    message="No hay eventos programados por el momento."
  />
)}
