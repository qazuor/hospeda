---
/**
 * Full-viewport hero section shell with carousel background,
 * gradient overlay, static text content, search bar island, and wave divider.
 */
import { HeroCarousel } from './HeroCarousel.client';
import { HeroSearchBar } from '../search/HeroSearchBar.client';
import WaveDivider from '../ui/WaveDivider.astro';

export interface HeroSectionProps {
  slides: Array<{ src: string; alt: string }>;
  accentSubtitle: string;
  headline: string;
  subheadline: string;
  searchLabels: {
    typePlaceholder: string;
    destinationPlaceholder: string;
    checkInPlaceholder: string;
    checkOutPlaceholder: string;
    ctaLabel: string;
    loadingText: string;
    searchAriaLabel: string;
  };
  carouselLabels: {
    carouselAriaLabel: string;
    slideNavLegend: string;
    dotAriaLabel: string;
    liveRegionText: string;
  };
  locale: 'es' | 'en' | 'pt';
  apiBaseUrl: string;
  firstSectionFill?: string;
}

interface Props extends HeroSectionProps {}

const {
  slides,
  accentSubtitle,
  headline,
  subheadline,
  searchLabels,
  carouselLabels,
  locale,
  apiBaseUrl,
  firstSectionFill = '#FFFFFF',
} = Astro.props;

const baseAccommodationsPath = `/${locale}/alojamientos`;
---

<section class="relative min-h-[max(100vh,600px)] overflow-hidden bg-gray-900">
  <!-- Carousel background (React island) -->
  <HeroCarousel client:load slides={slides} labels={carouselLabels} />

  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/30 to-black/70" aria-hidden="true"></div>

  <!-- Overlay text content (static Astro markup) -->
  <div class="relative z-20 flex min-h-[max(100vh,600px)] flex-col items-center justify-center px-4 text-center">
    <p class="mb-4 font-accent text-[length:var(--fs-accent-subtitle)] text-white">
      {accentSubtitle}
    </p>
    <h1 class="mb-4 font-serif text-[length:var(--fs-display-hero)] font-bold text-white">
      {headline}
    </h1>
    <p class="mx-auto mb-8 max-w-2xl text-base text-white/80 sm:text-lg">
      {subheadline}
    </p>

    <!-- Search bar (React island) -->
    <div class="w-full max-w-4xl">
      <HeroSearchBar
        client:load
        locale={locale}
        apiBaseUrl={apiBaseUrl}
        labels={searchLabels}
        baseAccommodationsPath={baseAccommodationsPath}
      />
    </div>
  </div>

  <!-- Wave divider at bottom -->
  <WaveDivider
    fill={firstSectionFill}
    class="absolute bottom-0 left-0 w-full z-30"
  />
</section>
