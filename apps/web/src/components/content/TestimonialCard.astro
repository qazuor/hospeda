---
/**
 * Testimonial card displaying a quote with author information, optional avatar,
 * star rating, and location. Features quote mark decoration, italic text,
 * hover lift effect, and accessible semantic markup.
 */
interface Props {
  quote: string;
  author: string;
  image?: string;
  /** @deprecated Use `location` instead. Kept for backward compatibility. */
  role?: string;
  /** Location label displayed below author name (takes priority over `role`) */
  location?: string;
  /** Star rating from 1 to 5 */
  rating?: number;
  class?: string;
}

const { quote, author, image, role, location, rating, class: className } = Astro.props;

/** Location takes priority over role for display */
const displaySubtitle = location ?? role;

/** Clamp rating between 1 and 5 */
const safeRating = rating ? Math.min(5, Math.max(1, Math.round(rating))) : undefined;

/** Extract up to 2 initials from a full name for the avatar fallback. */
const initials = author
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase() ?? '')
  .join('');
---

<article class:list={['overflow-hidden rounded-xl border border-border bg-surface p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl', className]}>
  <!-- Quote mark decoration -->
  <div class="mb-4 text-5xl leading-none text-primary/20" aria-hidden="true">
    &ldquo;
  </div>

  <!-- Quote content -->
  <blockquote class="mb-6">
    <p class="italic text-text">
      {quote}
    </p>
  </blockquote>

  <!-- Author section -->
  <footer>
    <cite class="not-italic">
      <div class="flex items-center gap-3">
        <span
          class="relative flex h-20 w-20 shrink-0 items-center justify-center rounded-full bg-primary/15 text-2xl font-semibold text-primary ring-2 ring-white dark:ring-gray-700"
          aria-hidden="true"
        >
          {initials}
          {image && (
            <img
              src={image}
              alt={`${author} avatar`}
              class="absolute inset-0 h-full w-full rounded-full object-cover"
              loading="lazy"
              width="80"
              height="80"
            />
          )}
        </span>
        <div>
          <div class="text-lg font-semibold text-text">
            {author}
          </div>
          {safeRating && (
            <div class="mt-0.5 flex items-center gap-0.5" aria-label={`${safeRating} de 5 estrellas`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <span class={i < safeRating ? 'text-star' : 'text-star-empty'} aria-hidden="true">
                  {i < safeRating ? '★' : '☆'}
                </span>
              ))}
            </div>
          )}
          {displaySubtitle && (
            <div class="text-sm text-text-tertiary">
              {displaySubtitle}
            </div>
          )}
        </div>
      </div>
    </cite>
  </footer>
</article>
