---
/**
 * Section wrapper for featured content with title, optional subtitle,
 * and optional "View all" link.
 * Content is provided via the default slot (typically a grid of entity cards).
 * The title can be overridden via the named "title" slot for custom styling.
 */
import Container from '../ui/Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import { t, type SupportedLocale } from '../../lib/i18n';

interface Props {
  title: string;
  subtitle?: string;
  viewAllHref?: string;
  viewAllLabel?: string;
  locale?: string;
  class?: string;
}

const { title, subtitle, viewAllHref, viewAllLabel, locale = 'es', class: className } = Astro.props;
const safeLocale = (locale as SupportedLocale) ?? 'es';
const resolvedViewAllLabel = viewAllLabel || t({ locale: safeLocale, namespace: 'common', key: 'viewAll' });
const hasTitleSlot = Astro.slots.has('title');
---

<section class:list={['py-12 sm:py-16 lg:py-24', className]}>
  <Container>
    <!-- Section header -->
    <div class="mb-8 flex items-end justify-between">
      <div>
        {hasTitleSlot ? (
          <slot name="title" />
        ) : (
          <SectionTitle>{title}</SectionTitle>
        )}
        {subtitle && (
          <p class="mt-2 max-w-2xl text-base text-text-secondary">{subtitle}</p>
        )}
      </div>
      {viewAllHref && (
        <a
          href={viewAllHref}
          class="text-sm font-medium text-primary transition-colors hover:text-primary-dark"
        >
          {resolvedViewAllLabel} &rarr;
        </a>
      )}
    </div>

    <!-- Content slot -->
    <slot />
  </Container>
</section>
