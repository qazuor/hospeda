---
/**
 * Server Island: Featured destinations as a bento grid layout.
 * Fetches featured destinations from the API.
 * Featured destinations get large cells (span 2 cols, 2 rows on desktop).
 * Used with server:defer for dynamic content on a static shell.
 */
import DestinationCard from '../destination/DestinationCard.astro';
import EmptyState from '../ui/EmptyState.astro';
import { destinationsApi } from '../../lib/api/endpoints';
import { extractFeaturedImageUrl } from '../../lib/media';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const result = await destinationsApi.list({ isFeatured: true, pageSize: 5, destinationType: 'CITY' });
const destinations = result.ok ? result.data.items : [];

const destinationCards = destinations.map((dest) => {
  const d = dest as Record<string, unknown>;
  return {
    slug: String(d.slug || ''),
    name: String(d.name || ''),
    summary: String(d.summary || d.description || ''),
    featuredImage: extractFeaturedImageUrl(d, '/images/placeholder-destination.svg'),
    accommodationsCount: Number(d.accommodationsCount || 0),
    isFeatured: Boolean(d.isFeatured),
    path: String(d.path || d.slug || ''),
  };
});

const featuredCard = destinationCards.find((d) => d.isFeatured);
const regularCards = destinationCards.filter((d) => d !== featuredCard);
---

{destinationCards.length > 0 ? (
  <div class="bento-grid grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {/* Featured destination: large cell */}
    {featuredCard && (
      <div class="sm:col-span-2 sm:row-span-2">
        <DestinationCard
          destination={featuredCard}
          locale={locale}
          class="h-full [&_img]:h-64 sm:[&_img]:h-full"
        />
      </div>
    )}
    {/* Regular destinations: smaller cells */}
    {regularCards.map((destination) => (
      <DestinationCard
        destination={destination}
        locale={locale}
      />
    ))}
    {/* If no featured, show all in regular grid */}
    {!featuredCard && destinationCards.map((destination) => (
      <DestinationCard
        destination={destination}
        locale={locale}
      />
    ))}
  </div>
) : (
  <EmptyState
    title="No hay destinos destacados"
    message="Proximamente agregaremos destinos destacados."
  />
)}
