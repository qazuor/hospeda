---
/**
 * Owner registration call-to-action section.
 * Split layout: left side - decorative illustration, right side - text + CTA.
 * Teal-to-amber gradient background with terracotta CTA button.
 * Mobile: stacked (illustration above, text below).
 */
import SectionWrapper from '../ui/SectionWrapper.astro';
import Button from '../ui/Button.astro';
import { t, type SupportedLocale } from '../../lib/i18n';

interface Props {
  locale?: SupportedLocale;
}

const { locale = 'es' } = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-surface-warm to-accent/30">
  <div class="mx-auto max-w-site px-4 py-16 sm:px-6 sm:py-20 lg:py-24">
    <div class="flex flex-col items-center gap-12 lg:flex-row lg:gap-16">
      <!-- Left: Decorative illustration -->
      <div class="flex-shrink-0 lg:w-2/5" aria-hidden="true">
        <div class="mx-auto flex h-64 w-64 items-center justify-center rounded-full bg-primary/10 sm:h-80 sm:w-80">
          <!-- Welcoming host illustration (SVG) -->
          <svg class="h-40 w-40 text-primary sm:h-48 sm:w-48" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <!-- House -->
            <path d="M60,140 L60,90 L100,60 L140,90 L140,140 Z" />
            <path d="M60,90 L100,60 L140,90" />
            <!-- Door -->
            <rect x="88" y="110" width="24" height="30" rx="2" />
            <!-- Window -->
            <rect x="68" y="100" width="14" height="14" rx="1" />
            <rect x="118" y="100" width="14" height="14" rx="1" />
            <!-- Heart -->
            <path d="M93,80 C93,75 87,70 87,75 C87,80 93,88 93,88 C93,88 99,80 99,75 C99,70 93,75 93,80 Z" fill="currentColor" opacity="0.3" />
            <!-- Welcome mat -->
            <path d="M82,140 L118,140" stroke-dasharray="4 2" />
            <!-- Trees -->
            <path d="M30,140 L40,100 L50,140" />
            <path d="M35,120 L40,105 L45,120" />
            <path d="M150,140 L160,105 L170,140" />
            <path d="M155,125 L160,110 L165,125" />
          </svg>
        </div>
      </div>

      <!-- Right: Text content + CTA -->
      <div class="flex-1 text-center lg:text-left">
        <p class="mb-2 inline-block -rotate-2 font-accent text-lg text-secondary">
          {t({ locale, namespace: 'home', key: 'ownerCta.accentSubtitle', fallback: 'Para propietarios' })}
        </p>
        <h2 class="mb-4 font-serif text-3xl font-bold text-text md:text-4xl lg:text-5xl" style="font-variation-settings: var(--fraunces-section);">
          {t({ locale, namespace: 'home', key: 'ownerCta.title', fallback: 'Publica tu alojamiento en Hospeda' })}
        </h2>
        <p class="mb-8 text-lg text-text-secondary">
          {t({ locale, namespace: 'home', key: 'ownerCta.description', fallback: 'Llega a miles de viajeros que buscan alojamientos en el Litoral argentino. Simple, rapido y efectivo.' })}
        </p>
        <Button variant="primary-warm" href={`/${locale}/propietarios/`} class="bg-terracotta hover:bg-terracotta-dark text-white">
          {t({ locale, namespace: 'home', key: 'ownerCta.button', fallback: 'Comenzar ahora' })}
        </Button>
      </div>
    </div>
  </div>
</section>
