---
/**
 * Server Island: Featured accommodations section for the homepage.
 * Fetches featured accommodations from the API and renders them as cards.
 * Used with server:defer for dynamic content on a static shell.
 */
import AccommodationCard from '../accommodation/AccommodationCard.astro';
import EmptyState from '../ui/EmptyState.astro';
import { accommodationsApi } from '../../lib/api/endpoints';
import { extractFeaturedImageUrl } from '../../lib/media';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const result = await accommodationsApi.list({ isFeatured: true, pageSize: 6 });
const accommodations = result.ok ? result.data.items : [];

const accommodationCards = accommodations.map((acc) => {
  const a = acc as Record<string, unknown>;
  return {
    slug: String(a.slug || ''),
    name: String(a.name || ''),
    summary: String(a.summary || a.description || ''),
    type: String(a.type || a.accommodationType || ''),
    featuredImage: extractFeaturedImageUrl(a, '/images/placeholder-accommodation.svg'),
    averageRating: Number(a.averageRating || 0),
    reviewsCount: Number(a.reviewsCount || 0),
    location: (a.location as { city: string; state: string }) || { city: '', state: '' },
    isFeatured: Boolean(a.isFeatured),
  };
});
---

{accommodationCards.length > 0 ? (
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {accommodationCards.map((accommodation) => (
        <AccommodationCard
          accommodation={accommodation}
          locale={locale}
        />
    ))}
  </div>
) : (
  <EmptyState
    title="No hay alojamientos destacados"
    message="Próximamente agregaremos alojamientos destacados."
  />
)}
