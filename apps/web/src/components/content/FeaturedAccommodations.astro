---
/**
 * Server Island: Featured accommodations section for the homepage.
 * Fetches featured accommodations from the API and renders them as cards.
 * Used with server:defer for dynamic content on a static shell.
 */
import { accommodationsApi } from "../../lib/api/endpoints";
import { toAccommodationCardProps } from "../../lib/api/transforms";
import { t, type SupportedLocale } from "../../lib/i18n";
import AccommodationCardFeatured from "../accommodation/AccommodationCardFeatured.astro";
import EmptyState from "../ui/EmptyState.astro";

interface Props {
    locale?: SupportedLocale;
}

const { locale = "es" } = Astro.props;

const result = await accommodationsApi.list({
    isFeatured: true,
    pageSize: 12,
    includeAmenities: true,
    includeFeatures: true,
});
const accommodations = result.ok ? result.data.items : [];

const accommodationCards = accommodations.map((acc) =>
    toAccommodationCardProps({ item: acc as Record<string, unknown> })
);
---

{
    accommodationCards.length > 0 ? (
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {accommodationCards.map((accommodation) => (
                <AccommodationCardFeatured accommodation={accommodation} showFavorite={true} locale={locale} />
            ))}
        </div>
    ) : (
        <EmptyState
            title={t({
                locale,
                namespace: "accommodations",
                key: "featured.emptyTitle",
                fallback: "No hay alojamientos destacados",
            })}
            message={t({
                locale,
                namespace: "accommodations",
                key: "featured.emptyMessage",
                fallback: "Proximamente agregaremos alojamientos destacados.",
            })}
        />
    )
}
