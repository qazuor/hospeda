---
/**
 * @file FeaturedAccommodationsSection.astro
 * @description Homepage featured accommodations section. Displays a left-aligned
 * section header with a "Ver todos" action pill, a row of clickable
 * `AccommodationTypeBadge` chips (each with an icon, all sharing the
 * brand-primary surface) and a responsive grid of AccommodationCard
 * components that scales from 1 column on mobile to 4 columns on desktop
 * (4×2 layout, 8 cards).
 * Background uses `var(--core-background)` per the section alternation rule.
 */

import { AccommodationTypeEnum } from '@repo/schemas';
import { AccommodationIcon } from '@repo/icons';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { accommodationsApi, toAccommodationCardProps } from '@/lib/api';
import type { AccommodationCardData } from '@/lib/api/transforms';
import SectionHeader from '@/components/shared/layout/SectionHeader.astro';
import AccommodationTypeBadge from '@/components/shared/ui/AccommodationTypeBadge.astro';
import ScrollableNav from '@/components/shared/ui/ScrollableNav.astro';
import AccommodationCard from '@/components/shared/cards/AccommodationCard.astro';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import GradientButton from '@/components/shared/ui/GradientButton.astro';
import { webLogger } from '@/lib/logger';
import { revealStagger } from '@/lib/reveal-stagger';

interface Props {
  /** Active locale used to resolve translations and build internal URLs. */
  readonly locale: SupportedLocale;
}

const { locale } = Astro.props;

const { t } = createTranslations(locale);

/** All accommodation types from the canonical enum in @repo/schemas.
 * `type` keeps the enum value (underscore form) for the badge's icon + i18n
 * label resolution; `slug` is the hyphenated URL form for the route href
 * (e.g. APART_HOTEL → type "APART_HOTEL", slug "apart-hotel"). Keeping them
 * separate is required: the icon/label maps are keyed by the enum value, only
 * the route segment uses hyphens. (Bug B10 fix)
 */
const ACCOMMODATION_TYPES = Object.values(AccommodationTypeEnum).map((v) => {
  const enumValue = String(v);
  return { type: enumValue, slug: enumValue.toLowerCase().replace(/_/g, '-') };
});

// Fetch from API - empty array if unavailable
let items: AccommodationCardData[] = [];
try {
  const result = await accommodationsApi.list({ isFeatured: true, pageSize: 8, includeAmenities: true, includeFeatures: true, sortBy: 'averageRating', sortOrder: 'desc' });
  if (result.ok) {
    items = result.data.items.map((raw) => toAccommodationCardProps({ item: raw as Record<string, unknown>, locale }));
  }
} catch (err) {
  webLogger.error('API fetch failed', { endpoint: 'accommodations', error: err instanceof Error ? err.message : err });
}

const seeAllLabel = t('home.featuredAccommodations.seeAllAction', 'Ver todos los alojamientos');
const seeAllHref = buildUrl({ locale, path: '/alojamientos/' });

---

<section class="section accommodations">
  <div class="section__container">

    <!-- Section header: action moved below the grid (see __see-all-mobile). -->
    <SectionHeader
      tagline={t('home.featuredAccommodations.accentSubtitle')}
      title={t('home.featuredAccommodations.title')}
      subtitle={t('home.featuredAccommodations.description')}
      alignment="left"
    />

    <!-- Accommodation type filter badges: per-type colour identity,
         clickable links to the filtered listing. -->
    <ScrollableNav
      ariaLabel={t('home.featuredAccommodations.typesLabel', 'Filtrar por tipo')}
      innerClass="accommodations__types"
    >
      {ACCOMMODATION_TYPES.map(({ type, slug }) => (
        <AccommodationTypeBadge
          type={type}
          locale={locale}
          size="sm"
          href={buildUrl({ locale, path: `/alojamientos/tipo/${slug}/` })}
        />
      ))}
    </ScrollableNav>

    <!-- Cards grid: scales 1→2→3→4 columns by viewport (4×2 on desktop, 8 cards). -->
    {items.length === 0 ? (
      <EmptyState
        locale={locale}
        variant="empty"
        message={t('home.featuredAccommodations.emptyState')}
        actionUrl={seeAllHref}
        actionLabel={t('home.featuredAccommodations.emptyAction')}
        tone="warm"
      >
        <AccommodationIcon size={48} weight="duotone" />
      </EmptyState>
    ) : (
      <>
        <div class="grid-cards accommodations__grid">
          {items.map((accommodation, i) => (
            <div data-reveal="up" class="accommodations__card-wrapper" {...revealStagger({ index: i })}>
              {/* First row on desktop (4 cols at ≥1280px) gets eager loading
                  so the browser prioritises the LCP images above the fold. */}
              <AccommodationCard data={accommodation} locale={locale} eager={i < 4} />
            </div>
          ))}
        </div>

        <!-- "See all" CTA below the grid. The SectionHeader no longer
             carries an action button (every viewport scrolls past the
             grid and lands on this CTA instead). -->
        <div class="accommodations__see-all">
          <GradientButton
            href={seeAllHref}
            label={seeAllLabel}
            variant="outline-primary"
            size="sm"
            icon="true"
          />
        </div>
      </>
    )}

  </div>
</section>

<style>
  .accommodations {
    background-color: var(--core-background);
  }
  .accommodations__card-wrapper {
    height: 100%;
  }
  /* The default --space-section-header-mb (50px) is sized for sections
   * where the header is followed directly by the grid. Here the chip row
   * sits between, so the 50px gap leaves a visible empty band between
   * the subtitle and the chips. Compact it so the chips read as a
   * continuation of the header block. */
  .accommodations :global(.section-header) {
    margin-bottom: 1.1rem;
  }
  /* Type pills row spacing only — overflow + fade + arrows come from
   * ScrollableNav (see apps/web/src/components/shared/ui/ScrollableNav.astro).
   *
   * `:global()` is required because the <nav> that carries this class is
   * rendered by ScrollableNav.astro, which has its own scoped style block.
   * A locally-scoped `.accommodations__types` selector would compile to
   * `.accommodations__types[data-astro-cid-XXX]` and never match the child
   * component's element. */
  :global(.accommodations__types) {
    justify-content: center;
    gap: 0.5rem;
    /* Match the gap between the SectionHeader's action and the chip row
     * above so the rhythm header → chips → grid feels even. (Previously
     * the gap below the chips was much larger via clamp(2.5rem, 5vw,
     * 3.5rem) — a workaround for cards' `data-reveal="up"` overshoot,
     * which we accept now in exchange for a tighter visual flow.) */
    margin-bottom: 1.1rem;
  }

  /* Mobile: the chip row uses overflow-x: auto (set by ScrollableNav) to
   * scroll horizontally, but with `justify-content: center` flex centers
   * its content when it doesn't fit — pushing the first chips off-screen
   * to the LEFT, where scrollLeft can't reach them (its minimum is 0).
   * Force flex-start on mobile so the first chip lands at the left edge
   * and the user can swipe through every type from the beginning. */
  @media (max-width: 767px) {
    :global(.accommodations__types) {
      justify-content: flex-start;
    }
  }

  .accommodations__see-all {
    display: flex;
    justify-content: center;
    margin-top: var(--space-card-gap, 2rem);
  }
</style>
