---
/**
 * @file ListPropertySection.astro
 * @description Homepage CTA section encouraging property owners to list their accommodation.
 * Features a gradient card with illustration, quick stats, and registration CTA button.
 */
import { ArrowRightIcon, StarIcon, UsersIcon, TrendingUpIcon } from "@repo/icons";
import BackgroundPattern from "@/components/shared/BackgroundPattern.astro";
import DecorativeElement from "@/components/shared/DecorativeElement.astro";
import { createT } from "@/lib/i18n";

/**
 * Props for the ListPropertySection component.
 * @property locale - Current locale for i18n translations and link generation
 */
interface Props {
  /** Current locale for translations */
  readonly locale?: string;
}

const { locale = 'es' } = Astro.props;
const t = createT(locale);
---

<section class="relative py-10 md:py-14 overflow-hidden">
  <BackgroundPattern pattern="/images/patterns/pattern-topo.svg" size="300px 300px" opacity="opacity-40" />

  <DecorativeElement src="/images/decoratives/deco-kayak.svg" position="top-2 left-4 md:left-12" size="w-24 md:w-36" opacity="opacity-30" rotate="-rotate-6" />
  <DecorativeElement src="/images/decoratives/deco-multi-pins.svg" position="top-1/2 -translate-y-1/2 right-4 md:right-12" size="w-20 md:w-28" opacity="opacity-35" hidden="hidden lg:block" />
  <DecorativeElement src="/images/decoratives/deco-flecha-doble.svg" position="bottom-4 left-1/4" size="w-28 md:w-40" opacity="opacity-30" />

  <div class="relative mx-auto max-w-5xl px-4 md:px-8">
    <div class="scroll-reveal relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary/95 to-primary p-8 md:p-10">
      <!-- Decorative circles -->
      <div class="absolute -right-16 -top-16 h-48 w-48 rounded-full bg-primary-foreground/5" aria-hidden="true"></div>
      <div class="absolute -bottom-10 -left-10 h-32 w-32 rounded-full bg-primary-foreground/5" aria-hidden="true"></div>

      <div class="relative flex flex-col items-center gap-8 lg:flex-row lg:justify-between">
        <!-- Illustration -->
        <div class="hidden lg:block shrink-0">
          <img src="/images/illustrations/ilustracion-publica-alojamiento.svg" alt={t('home.ownerCta.cta', 'Quiero publicar')} class="h-56 w-56 object-contain xl:h-64 xl:w-64" />
        </div>

        <!-- Content -->
        <div class="text-center lg:text-left flex-1">
          <p class="mb-2 text-xs font-medium uppercase tracking-widest text-primary-foreground/60">{t('home.ownerCta.tagline', 'Para anfitriones')}</p>
          <h3 class="font-serif text-2xl font-bold text-primary-foreground md:text-3xl text-balance">{t('home.ownerCta.title', 'Comparti tu espacio con viajeros de todo el pais')}</h3>
          <p class="mt-3 max-w-lg text-sm text-primary-foreground/80 leading-relaxed">
            {t('home.ownerCta.description', 'Mas de 50 anfitriones ya confian en nosotros. Publicar es gratis, sin comisiones ocultas, y te ayudamos a llegar a miles de turistas cada mes.')}
          </p>

          <!-- Quick stats -->
          <div class="mt-5 flex flex-wrap justify-center gap-4 lg:justify-start">
            <div class="flex items-center gap-1.5 text-xs text-primary-foreground/70">
              <UsersIcon size={14} />
              <span>{t('home.ownerCta.visitors', '+10.000 visitantes/mes')}</span>
            </div>
            <div class="flex items-center gap-1.5 text-xs text-primary-foreground/70">
              <StarIcon size={14} />
              <span>{t('home.ownerCta.free', 'Publicacion gratuita')}</span>
            </div>
            <div class="flex items-center gap-1.5 text-xs text-primary-foreground/70">
              <TrendingUpIcon size={14} />
              <span>{t('home.ownerCta.directBookings', 'Reservas directas')}</span>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="flex shrink-0 flex-col items-center gap-2">
          <a
            href={`/${locale}/registrar-alojamiento`}
            class="inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3.5 text-sm font-semibold text-accent-foreground shadow-lg transition-all hover:bg-accent/90 hover:shadow-xl hover:-translate-y-0.5"
          >
            {t('home.ownerCta.cta', 'Quiero publicar')}
            <ArrowRightIcon size={16} />
          </a>
          <a
            href={`/${locale}/como-funciona`}
            class="text-xs text-primary-foreground/60 underline-offset-2 hover:underline hover:text-primary-foreground/80 transition-colors"
          >
            {t('home.ownerCta.howItWorks', 'Como funciona?')}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
