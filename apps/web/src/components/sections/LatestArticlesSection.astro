---
/**
 * @file LatestArticlesSection.astro
 * @description Homepage latest articles section.
 * Layout: 1 FeaturedArticleCard full-width on top, then 3 equal ArticleCards in a row.
 * Staggered scroll-reveal on each card. Links to full posts listing page.
 */

import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import SectionHeader from '@/components/shared/SectionHeader.astro';
import FeaturedArticleCard from '@/components/shared/FeaturedArticleCard.astro';
import ArticleCard from '@/components/shared/ArticleCard.astro';
import { postsApi, toPostCardProps } from '@/lib/api';
import type { BlogPostCardData } from '@/lib/api/transforms';
import { webLogger } from '@/lib/logger';

interface Props {
    /** Active locale used to resolve translations and URLs. */
    readonly locale: SupportedLocale;
}

const { locale } = Astro.props;
const { t } = createTranslations(locale);

// Fetch 4 posts: 1 featured + 3 secondary
let posts: BlogPostCardData[] = [];
try {
    const result = await postsApi.list({ sortBy: 'publishedAt', sortOrder: 'desc', pageSize: 4 });
    if (result.ok) {
        posts = result.data.items.map((raw) => toPostCardProps({ item: raw as Record<string, unknown> }));
    }
} catch (err) {
    webLogger.error('API fetch failed', {
        endpoint: 'posts',
        error: err instanceof Error ? err.message : err,
    });
}

const [featured, ...secondaryPosts] = posts;
const secondary = secondaryPosts.slice(0, 3);
const isSparse = posts.length < 2;
---

<section class:list={['section', { 'latest-articles--sparse': isSparse }]} aria-label={t('home.latestPosts.title', 'Últimas publicaciones')}>
    <div class="section__container">

        <SectionHeader
            tagline={t('home.latestPosts.tagline', 'Informate, Inspirate, Conoce')}
            title={t('home.latestPosts.title', 'Últimos artículos')}
            subtitle={t('home.latestPosts.subtitle', 'Historias, guías y secretos del litoral entrerriano para inspirar tu próxima aventura.')}
        />

        {posts.length === 0 ? (
            <div class="section__empty-state">
                <p class="section__empty-text">{t('home.latestPosts.emptyState')}</p>
            </div>
        ) : (
            <div class="articles__layout">
                <!-- Featured card: full-width top row -->
                {featured && (
                    <div class="articles__featured-row" data-reveal="up" style="transition-delay: 0ms">
                        <FeaturedArticleCard data={featured} locale={locale} isTrending={true} />
                    </div>
                )}

                <!-- Secondary cards: adaptive columns based on count -->
                {secondary.length > 0 && (
                    <div class:list={['articles__secondary-row', `articles__secondary-row--${secondary.length}col`]}>
                        {secondary.map((post, i) => (
                            <div
                                class="articles__secondary-item"
                                data-reveal="up"
                                style={`transition-delay: ${(i + 1) * 100}ms`}
                            >
                                <ArticleCard data={post} locale={locale} />
                            </div>
                        ))}
                    </div>
                )}
            </div>
        )}

        <!-- CTA button -->
        <div class="posts__cta">
            <a href={buildUrl({ locale, path: 'publicaciones' })} class="posts__cta-btn">
                {t('home.latestPosts.viewAll', 'Ver todos los artículos →')}
            </a>
        </div>

    </div>
</section>

<style>
    /* Main layout container */
    .articles__layout {
        display: flex;
        flex-direction: column;
        gap: var(--space-card-gap);
    }

    /* Featured row: always full width */
    .articles__featured-row {
        width: 100%;
    }

    /* Secondary row: adaptive columns based on item count */
    .articles__secondary-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-card-gap);
    }

    .articles__secondary-item {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    @media (min-width: 640px) {
        .articles__secondary-row--2col {
            grid-template-columns: repeat(2, 1fr);
        }
        .articles__secondary-row--3col {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .articles__secondary-row--3col {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    /* Sparse section: fewer articles, reduce vertical padding */
    .latest-articles--sparse {
        padding-block: var(--space-section-sm);
    }

    /* Empty state styles are in components.css (.section__empty-state, .section__empty-text) */

    /* CTA */
    .posts__cta {
        display: flex;
        justify-content: center;
        margin-top: 3rem;
    }

    .posts__cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 12px 28px;
        border-radius: var(--radius-pill);
        background-color: var(--brand-secondary-foreground);
        color: var(--core-background);
        font-family: var(--font-sans);
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition:
            background-color var(--duration-normal) ease,
            transform var(--duration-normal) ease;
    }

    .posts__cta-btn:hover {
        background-color: var(--brand-primary);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px oklch(from var(--brand-primary) l c h / 0.25);
    }

    .posts__cta-btn:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }
</style>
