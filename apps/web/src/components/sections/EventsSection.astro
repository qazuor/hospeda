---
/**
 * @file EventsSection.astro
 * @description Homepage section displaying upcoming events in a bento grid layout.
 * Fetches featured events from the API and renders alternating card orientations.
 */
import BackgroundPattern from "@/components/shared/BackgroundPattern.astro";
import DecorativeElement from "@/components/shared/DecorativeElement.astro";
import Illustration from "@/components/shared/Illustration.astro";
import SectionHeader from "@/components/shared/SectionHeader.astro";
import GradientButton from "@/components/shared/GradientButton.astro";
import EventCard from "@/components/shared/EventCard.astro";
import { eventsApi } from "@/lib/api/endpoints";
import { toEventCardProps } from "@/lib/api/transforms";
import { createT } from "@/lib/i18n";

/**
 * Props for the EventsSection component.
 * @property locale - Current locale for i18n translations and link generation
 */
interface Props {
  /** Current locale for translations */
  readonly locale?: string;
}

const { locale = 'es' } = Astro.props;
const t = createT(locale);

const result = await eventsApi.list({ isFeatured: true, pageSize: 4 });
const cards = result.ok
  ? result.data.items.map((item) => toEventCardProps({ item: item as unknown as Record<string, unknown> }))
  : [];
---

<section id="events" class="wave-bottom-c relative z-[6] py-16 pb-20 md:py-24 md:pb-24 overflow-hidden">
  <BackgroundPattern pattern="/images/patterns/pattern-diagonal.svg" size="40px 40px" />

  <DecorativeElement src="/images/decoratives/deco-olas.svg" position="top-8 left-0" size="w-1/3" opacity="opacity-40" hidden="" />
  <DecorativeElement src="/images/decoratives/deco-multi-pins.svg" position="top-1/3 left-4 md:left-12" size="w-24 md:w-32" opacity="opacity-35" hidden="hidden lg:block" />
  <DecorativeElement src="/images/decoratives/deco-brujula.svg" position="bottom-24 right-8 md:right-16" size="w-16 md:w-24" opacity="opacity-35" />
  <DecorativeElement src="/images/decoratives/deco-avion.svg" position="bottom-12 left-1/4" size="w-20 md:w-28" opacity="opacity-30" />
  <Illustration src="/images/illustrations/ilustracion-eventos.svg" position="-right-4 bottom-4 md:right-4 md:bottom-16 lg:right-12" size="h-28 w-28 md:h-44 md:w-44 lg:h-56 lg:w-56" />

  <div class="relative mx-auto max-w-7xl px-4 md:px-8">
    <SectionHeader
      tagline={t('home.upcomingEvents.tagline', 'Agenda')}
      title={t('home.upcomingEvents.title', 'Proximos eventos')}
      subtitle={t('home.upcomingEvents.subtitle', 'No te pierdas las fiestas, festivales y competencias que hacen unica a nuestra region.')}
    />

    <!-- Bento Grid -->
    <div class="scroll-reveal grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {cards.map((card, i) => (
        <EventCard card={card} reversed={i === 1 || i === 3} locale={locale} />
      ))}
    </div>

    <!-- Footer CTA -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border pt-6 sm:flex-row">
      <p class="text-muted-foreground">{t('home.upcomingEvents.footerText', 'Explora mas eventos esperandote en el litoral')}</p>
      <GradientButton href={`/${locale}/eventos/`} label={t('home.upcomingEvents.viewAll', 'Ver todos los eventos')} />
    </div>
  </div>
</section>
