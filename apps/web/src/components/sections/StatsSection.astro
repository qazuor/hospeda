---
/**
 * @file StatsSection.astro
 * @description Homepage section displaying platform statistics in a compact grid.
 * Renders 6 StatCard components with icons, values, and descriptions.
 */
import BackgroundPattern from "@/components/shared/BackgroundPattern.astro";
import DecorativeElement from "@/components/shared/DecorativeElement.astro";
import SectionHeader from "@/components/shared/SectionHeader.astro";
import StatCard from "@/components/shared/StatCard.astro";
import { STATS } from "@/data/stats";
import { createT } from "@/lib/i18n";

/**
 * Props for the StatsSection component.
 * @property locale - Current locale for i18n translations
 */
interface Props {
  /** Current locale for translations */
  readonly locale?: string;
}

const { locale = 'es' } = Astro.props;
const t = createT(locale);
---

<section id="stats" class="relative z-[1] py-12 md:py-16 bg-muted/30 overflow-hidden">
  <BackgroundPattern pattern="/images/patterns/pattern-dots.svg" size="60px 60px" opacity="opacity-60" />

  <DecorativeElement src="/images/decoratives/deco-brujula.svg" position="top-4 left-4 md:left-12" size="w-16 md:w-20" opacity="opacity-50" />
  <DecorativeElement src="/images/decoratives/deco-flecha-doble.svg" position="top-6 left-1/2 -translate-x-1/2" size="w-32 md:w-48" opacity="opacity-50" hidden="" />
  <DecorativeElement src="/images/decoratives/deco-multi-pins.svg" position="top-1/2 -translate-y-1/2 right-2 md:right-8" size="w-20 md:w-28" opacity="opacity-45" hidden="hidden lg:block" />
  <DecorativeElement src="/images/decoratives/deco-olas.svg" position="bottom-0 left-0" size="w-full" opacity="opacity-40" hidden="" />

  <div class="relative mx-auto max-w-5xl px-4 md:px-8">
    <SectionHeader
      title={t('home.statistics.title', 'Entre Rios en numeros')}
      subtitle={t('home.statistics.subtitle', 'La comunidad de turismo mas grande de la provincia')}
    />

    <div class="scroll-reveal grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-6">
      {STATS.map((stat) => (
        <StatCard stat={stat} />
      ))}
    </div>
  </div>
</section>
