---
/**
 * @file PostsSection.astro
 * @description Homepage section displaying latest blog posts in a magazine-style layout.
 * Features one large FeaturedArticleCard and secondary horizontal cards,
 * with a decorative wave divider and background patterns.
 */
import BackgroundPattern from "@/components/shared/BackgroundPattern.astro";
import DecorativeElement from "@/components/shared/DecorativeElement.astro";
import Illustration from "@/components/shared/Illustration.astro";
import SectionHeader from "@/components/shared/SectionHeader.astro";
import GradientButton from "@/components/shared/GradientButton.astro";
import FeaturedArticleCard from "@/components/shared/FeaturedArticleCard.astro";
import SecondaryArticleCard from "@/components/shared/SecondaryArticleCard.astro";
import { postsApi } from "@/lib/api/endpoints";
import { toPostCardProps } from "@/lib/api/transforms";
import { createT } from "@/lib/i18n";

/**
 * Props for the PostsSection component.
 * @property locale - Current locale for i18n translations and link generation
 */
interface Props {
  /** Current locale for translations */
  readonly locale?: string;
}

const { locale = 'es' } = Astro.props;
const t = createT(locale);

const result = await postsApi.list({ isFeatured: true, pageSize: 3 });
const cards = result.ok
  ? result.data.items.map((item) => toPostCardProps({ item: item as unknown as Record<string, unknown> }))
  : [];

const featuredCard = cards[0] ?? null;
const secondaryCards = cards.slice(1);
---

<section id="posts" class="wave-bottom-d relative z-[4] bg-muted py-16 pb-20 md:py-24 md:pb-24 overflow-hidden">
  <BackgroundPattern pattern="/images/patterns/pattern-waves.svg" size="200px 50px" />

  <DecorativeElement src="/images/decoratives/deco-brujula.svg" position="top-24 left-4 md:left-12" size="w-16 md:w-24" opacity="opacity-35" />
  <DecorativeElement src="/images/decoratives/deco-avion.svg" position="top-1/3 right-4 md:right-12" size="w-20 md:w-28" opacity="opacity-40" rotate="rotate-12" hidden="hidden lg:block" />
  <DecorativeElement src="/images/decoratives/deco-multi-pins.svg" position="bottom-16 left-8 md:left-20" size="w-24 md:w-32" opacity="opacity-35" />
  <DecorativeElement src="/images/decoratives/deco-olas.svg" position="bottom-0 right-0" size="w-1/2" opacity="opacity-30" hidden="" />

  <div class="relative mx-auto max-w-7xl px-4 md:px-8">
    <Illustration src="/images/illustrations/ilustracion-notas.svg" position="-right-4 top-40 md:right-4 md:top-20 lg:right-8 lg:top-16" size="h-24 w-24 md:h-36 md:w-36 lg:h-48 lg:w-48" />

    <SectionHeader
      tagline={t('home.latestPosts.tagline', 'Inspirate')}
      taglineColor="text-hospeda-forest"
      title={t('home.latestPosts.title', 'Notas y guias de viaje')}
      subtitle={t('home.latestPosts.subtitle', 'Historias, guias y secretos del litoral entrerriano para inspirar tu proxima aventura.')}
      align="left"
      maxSubtitleWidth="max-w-xl"
    />

    <!-- Magazine Layout -->
    <div class="scroll-reveal grid gap-8 lg:grid-cols-12 lg:gap-10">
      {featuredCard && <FeaturedArticleCard article={featuredCard} locale={locale} />}

      <!-- Secondary Articles -->
      <div class="flex flex-col gap-6 lg:col-span-5">
        {secondaryCards.map((card) => (
          <SecondaryArticleCard article={card} locale={locale} />
        ))}

        <!-- View all -->
        <div class="mt-4 text-center">
          <GradientButton href={`/${locale}/notas/`} label={t('home.latestPosts.viewAll', 'Ver todas las notas')} />
        </div>
      </div>
    </div>
  </div>
</section>
