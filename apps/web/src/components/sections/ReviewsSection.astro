---
/**
 * @file ReviewsSection.astro
 * @description Homepage section displaying guest testimonials in a 3-column card grid.
 * Uses static review data from the data layer with decorative background elements.
 */
import BackgroundPattern from "@/components/shared/BackgroundPattern.astro";
import DecorativeElement from "@/components/shared/DecorativeElement.astro";
import Illustration from "@/components/shared/Illustration.astro";
import SectionHeader from "@/components/shared/SectionHeader.astro";
import ReviewCard from "@/components/shared/ReviewCard.astro";
import { REVIEWS } from "@/data/reviews";
import { createT } from "@/lib/i18n";

/**
 * Props for the ReviewsSection component.
 * @property locale - Current locale for i18n translations
 */
interface Props {
  /** Current locale for translations */
  readonly locale?: string;
}

const { locale = 'es' } = Astro.props;
const t = createT(locale);
---

<section class="relative z-[2] py-16 md:py-24 overflow-hidden">
  <BackgroundPattern pattern="/images/patterns/pattern-crosses.svg" size="30px 30px" opacity="opacity-70" />

  <DecorativeElement src="/images/decoratives/deco-rio-uruguay.svg" position="right-0 top-0" size="h-full w-48 md:w-64" opacity="opacity-35" hidden="" objectContain objectPosition="object-right" />
  <DecorativeElement src="/images/decoratives/deco-brujula.svg" position="top-8 left-8 md:left-16" size="w-14 md:w-20" opacity="opacity-40" />
  <DecorativeElement src="/images/decoratives/deco-kayak.svg" position="bottom-8 left-1/4" size="w-28 md:w-40" opacity="opacity-35" hidden="hidden lg:block" />
  <DecorativeElement src="/images/decoratives/deco-ruta-punteada.svg" position="bottom-4 right-1/4" size="w-32 md:w-44" opacity="opacity-40" />
  <Illustration src="/images/illustrations/ilustracion-reviews.svg" position="-left-6 top-1/2 md:left-4 lg:left-12" size="h-24 w-24 md:h-40 md:w-40 lg:h-52 lg:w-52" />

  <div class="relative mx-auto max-w-7xl px-4 md:px-8">
    <SectionHeader
      tagline={t('home.testimonials.tagline', 'Testimonios')}
      title={t('home.testimonials.title', 'Lo que dicen nuestros viajeros')}
    />

    <div class="scroll-reveal grid gap-6 md:grid-cols-3">
      {REVIEWS.map((review) => (
        <ReviewCard review={review} />
      ))}
    </div>
  </div>
</section>
