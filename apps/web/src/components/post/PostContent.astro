---
/**
 * @file PostContent.astro
 * @description Renders the sanitized HTML body of a blog post with editorial typography.
 * Applies prose styles for headings, paragraphs, images, figures, blockquotes, and
 * responsive iframes (YouTube embed support).
 *
 * The `id` attributes on headings are set by the sanitizer so TOC anchor links work.
 */

interface Props {
	/** Sanitized HTML string — must have already been processed by sanitizeHtml(). */
	readonly safeContentHtml: string;
	/** Optional lead summary shown above the content body. */
	readonly summary?: string;
}

const { safeContentHtml, summary } = Astro.props;
---

<div class="post-content">
	{summary && <p class="post-content__summary">{summary}</p>}
	<div class="prose" set:html={safeContentHtml} />
</div>

<style>
	.post-content {
		width: 100%;
	}

	.post-content__summary {
		font-family: var(--font-sans);
		font-size: 1.15rem;
		line-height: 1.7;
		color: var(--core-muted-foreground);
		border-left: 3px solid var(--brand-primary);
		padding-left: 1rem;
		margin-bottom: var(--space-6, 1.5rem);
		font-style: italic;
	}

	/* =========================================================
	 * Prose block — editorial typography
	 * Uses :global() because prose content comes from set:html.
	 * ========================================================= */

	.prose {
		font-family: var(--font-sans);
		font-size: 1.05rem;
		line-height: 1.85;
		color: var(--core-foreground);
	}

	.prose :global(h2) {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: 1.5rem;
		color: var(--core-foreground);
		margin-top: 2.5rem;
		margin-bottom: 0.75rem;
		line-height: 1.25;
		/* Extra clearance so sticky TOC/nav don't hide the heading on jump */
		scroll-margin-top: calc(var(--navbar-height, 80px) + 130px);
	}

	.prose :global(h3) {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 1.2rem;
		color: var(--core-foreground);
		margin-top: 2rem;
		margin-bottom: 0.5rem;
		line-height: 1.3;
		scroll-margin-top: calc(var(--navbar-height, 80px) + 130px);
	}

	.prose :global(p) {
		margin-bottom: 1.25rem;
	}

	.prose :global(p:last-child) {
		margin-bottom: 0;
	}

	.prose :global(a) {
		color: var(--brand-primary);
		text-decoration: underline;
		text-underline-offset: 2px;
		transition: color 0.2s ease;
	}

	.prose :global(a:hover) {
		color: var(--brand-accent);
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1.25rem;
		padding-left: 1.5rem;
	}

	.prose :global(li) {
		margin-bottom: 0.4rem;
	}

	.prose :global(blockquote) {
		border-left: 4px solid var(--brand-accent);
		margin: 1.75rem 0;
		padding: 0.75rem 1.25rem;
		background-color: var(--brand-accent-a05);
		border-radius: 0 var(--radius-md) var(--radius-md) 0;
		font-style: italic;
		color: var(--core-muted-foreground);
	}

	.prose :global(blockquote p) {
		margin-bottom: 0;
	}

	.prose :global(img) {
		width: 100%;
		height: auto;
		border-radius: var(--radius-card);
		margin: 1.75rem 0;
		display: block;
	}

	.prose :global(figure) {
		margin: 1.75rem 0;
	}

	.prose :global(figure img) {
		margin: 0 0 0.5rem;
	}

	.prose :global(figcaption) {
		font-family: var(--font-sans);
		font-size: 0.85rem;
		color: var(--core-muted-foreground);
		text-align: center;
		line-height: 1.4;
	}

	/* Responsive YouTube embed (16:9) */
	.prose :global(iframe) {
		width: 100%;
		aspect-ratio: 16 / 9;
		border: none;
		border-radius: var(--radius-card);
		margin: 1.75rem 0;
		display: block;
	}

	.prose :global(pre) {
		background-color: var(--surface-warm);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 1rem 1.25rem;
		overflow-x: auto;
		margin-bottom: 1.25rem;
		font-size: 0.9rem;
	}

	.prose :global(code) {
		font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
		font-size: 0.875em;
		background-color: var(--surface-warm);
		border: 1px solid var(--border);
		border-radius: 4px;
		padding: 0.15em 0.4em;
	}

	.prose :global(pre code) {
		background: none;
		border: none;
		padding: 0;
		font-size: inherit;
	}

	.prose :global(hr) {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2rem 0;
	}

	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: 1.25rem;
		font-size: 0.95rem;
	}

	.prose :global(th),
	.prose :global(td) {
		border: 1px solid var(--border);
		padding: 0.6rem 0.9rem;
		text-align: left;
	}

	.prose :global(th) {
		font-family: var(--font-heading);
		font-weight: 600;
		background-color: var(--surface-warm);
	}
</style>
