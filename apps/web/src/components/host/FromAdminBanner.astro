---
/**
 * @file FromAdminBanner.astro
 * @description Contextual banner shown on top of `/{lang}/publicar/` when the
 * user arrived from the admin app (i.e. `?from=admin` is present). Lets
 * tourists who hit the admin wall understand why they were rerouted and how
 * the funnel will get them what they were looking for (host access).
 *
 * 100% server-side rendered: no island, no hydration cost. The visibility
 * decision is made on the parent page based on `Astro.url.searchParams`.
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';

interface Props {
    readonly locale: SupportedLocale;
}

const { locale } = Astro.props;
const { t } = createTranslations(locale);
---

<aside
    class="from-admin-banner"
    role="status"
    aria-live="polite"
    data-testid="from-admin-banner"
>
    <div class="from-admin-banner__container">
        <span class="from-admin-banner__icon" aria-hidden="true">ℹ️</span>
        <div class="from-admin-banner__copy">
            <p class="from-admin-banner__title">
                {t('host.fromAdminBanner.title', 'Detectamos que intentaste acceder al panel de administración.')}
            </p>
            <p class="from-admin-banner__message">
                {t('host.fromAdminBanner.message', 'Para gestionar tus alojamientos primero necesitás publicar uno. Completá los datos básicos y obtenés acceso automático.')}
            </p>
        </div>
    </div>
</aside>

<style>
    .from-admin-banner {
        background-color: var(--surface-warm);
        border-left: 4px solid var(--brand-accent);
        border-radius: var(--radius-card);
        padding: var(--space-4) var(--space-5);
        margin: 0 auto var(--space-6);
        max-width: var(--container-max);
        box-shadow: var(--shadow-card);
    }

    .from-admin-banner__container {
        display: flex;
        align-items: flex-start;
        gap: var(--space-3);
        max-width: 920px;
        margin: 0 auto;
    }

    .from-admin-banner__icon {
        font-size: var(--text-body-lg);
        line-height: 1.4;
        flex-shrink: 0;
    }

    .from-admin-banner__copy {
        display: flex;
        flex-direction: column;
        gap: var(--space-1, 0.25rem);
    }

    .from-admin-banner__title {
        font-family: var(--font-heading);
        font-weight: 600;
        font-size: var(--text-body);
        color: var(--core-foreground);
        margin: 0;
        line-height: 1.4;
    }

    .from-admin-banner__message {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
        margin: 0;
        line-height: 1.6;
    }

    @media (max-width: 480px) {
        .from-admin-banner {
            margin-left: var(--space-container-x);
            margin-right: var(--space-container-x);
            padding: var(--space-3) var(--space-4);
        }
    }
</style>
