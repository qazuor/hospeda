---
/**
 * @file PricingCardsGrid.astro
 * @description Renders a grid of subscription plan cards (name, description,
 * price, entitlements, CTA). Shared between the owner pricing page
 * (/suscriptores/planes/) and the tourist pricing page (/suscriptores/turistas/).
 *
 * The two pricing pages target completely different audiences with separate
 * URLs (intentional, for SEO and conversion-focused copy), but the visual
 * presentation of the plan cards themselves is identical. Keeping that UI in
 * one component prevents drift between the pages and makes future visual
 * tweaks land in both places at once.
 */

import { StarIcon } from '@repo/icons';
import { PlanPurchaseButton } from '@/components/billing/PlanPurchaseButton.client';
import EmptyState from '@/components/shared/feedback/EmptyState.astro';
import { getEntitlementName, getPlanDescription, getPlanName } from '@/lib/billing-i18n';
import type { EntitlementKey } from '@/lib/billing-i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';

/**
 * Minimal plan shape required by this component. Decoupled from PlanDefinition
 * so the component works with both the static @repo/billing config and the
 * runtime endpoint response (PublicPlanData from @/lib/billing/fetch-plans).
 * The `limits` field from PlanDefinition is intentionally excluded because this
 * component does not render limits — only entitlements are shown as feature bullets.
 */
export interface PricingPlan {
	readonly slug: string;
	readonly name: string;
	readonly description: string;
	readonly monthlyPriceArs: number;
	readonly annualPriceArs: number | null;
	readonly hasTrial: boolean;
	readonly trialDays: number;
	readonly sortOrder: number;
	readonly isActive: boolean;
	/** Entitlement keys (string values matching EntitlementKey). */
	readonly entitlements: readonly string[];
}

interface Props {
	readonly locale: SupportedLocale;
	readonly plans: ReadonlyArray<PricingPlan>;
	readonly highlightedSlug: string;
	readonly intlLocale: string;
	/** Section heading text (rendered sr-only as h2 for accessibility). */
	readonly sectionHeading: string;
	/** Aria label for the section. */
	readonly sectionAriaLabel?: string;
	/** Message rendered inside EmptyState when `plans` is empty. */
	readonly emptyMessage: string;
	readonly emptyActionUrl: string;
	readonly emptyActionLabel: string;
	/** CTA button text on each card. */
	readonly ctaText: string;
}

const {
	locale,
	plans,
	highlightedSlug,
	intlLocale,
	sectionHeading,
	emptyMessage,
	emptyActionUrl,
	emptyActionLabel,
	ctaText,
} = Astro.props;

const { t } = createTranslations(locale);
const hasPlans = plans.length > 0;

// Annual toggle: only render the UI when at least one plan in the grid has
// an annual price configured. If every plan is monthly-only, the toggle is
// a no-op surface that just adds clutter.
const hasAnyAnnualPrice = plans.some(
	(plan) => plan.annualPriceArs !== null && plan.annualPriceArs > 0
);

const recommendedLabel = t('pricing.recommended', 'Recomendado');
const featuresLabel = t('pricing.features.label', 'Incluye');
const trialFallback = t('pricing.trial', '{days} días gratis');
const includesEverythingTemplate = t(
	'pricing.includesEverything',
	'Todo lo del plan {plan}, más:'
);
const inheritedSummaryTemplate = t(
	'pricing.inheritedSummary',
	'+{count} funciones del plan {plan}'
);
const toggleMonthlyLabel = t('pricing.toggle.monthly', 'Mensual');
const toggleAnnualLabel = t('pricing.toggle.annual', 'Anual');
const toggleAriaLabel = t(
	'pricing.toggle.ariaLabel',
	'Elegí la frecuencia de facturación'
);
const annualSavingTemplate = t('pricing.toggle.annualSaving', 'Ahorrá {percent}%');
const periodMonthLabel = t('pricing.period.month', '/mes');
const periodYearLabel = t('pricing.period.year', '/año');
const monthlyOnlyLabel = t('pricing.monthlyOnly', 'Solo plan mensual');

/**
 * Compute the per-plan annual saving percentage. Returns null when the
 * plan has no annual price (saving label gets hidden) or when the
 * annual price is greater than 12 monthly cycles (saving would be
 * negative — bad config, hide the label).
 */
function computeAnnualSavingPercent(plan: PricingPlan): number | null {
	if (plan.annualPriceArs === null || plan.annualPriceArs <= 0) return null;
	if (plan.monthlyPriceArs <= 0) return null;
	const yearAtMonthly = plan.monthlyPriceArs * 12;
	if (plan.annualPriceArs >= yearAtMonthly) return null;
	const saving = (yearAtMonthly - plan.annualPriceArs) / yearAtMonthly;
	return Math.round(saving * 100);
}

/**
 * Compute the entitlements that this plan adds on top of the previous tier.
 * The first plan in the grid lists every entitlement; subsequent plans show
 * only what they introduce, with a leading "everything in <previous>" line.
 * This keeps cards visually balanced (no card with 18 bullets next to a card
 * with 4) without losing information — users can still see the upgrade story.
 */
function computeAddedEntitlements(input: {
	plan: PricingPlan;
	previous: PricingPlan | undefined;
}): ReadonlyArray<string> {
	const { plan, previous } = input;
	if (!previous) return plan.entitlements;
	const previousSet = new Set<string>(previous.entitlements as ReadonlyArray<string>);
	const added = plan.entitlements.filter((e) => !previousSet.has(e as string));
	// Defensive fallback: if the upper plan introduces nothing on top of the
	// previous one (config error), show its full list instead of an empty bullets.
	return added.length > 0 ? added : plan.entitlements;
}

/**
 * Format ARS cents to a locale-aware currency string. Mirrors the helper that
 * was previously inlined in each pricing page; keeping it here so both pages
 * share the same formatting logic.
 */
function formatPriceArs(cents: number): string {
	const pesos = cents / 100;
	try {
		return new Intl.NumberFormat(intlLocale, {
			style: 'currency',
			currency: 'ARS',
			maximumFractionDigits: 0,
			minimumFractionDigits: 0,
		}).format(pesos);
	} catch {
		return `$${pesos.toLocaleString('es-AR')}`;
	}
}
---

<div class="pricing-cards__container" data-billing="monthly">
	<h2 class="sr-only">{sectionHeading}</h2>

	{hasPlans && hasAnyAnnualPrice && (
		<div class="pricing-toggle" role="radiogroup" aria-label={toggleAriaLabel}>
			<button
				type="button"
				class="pricing-toggle__option pricing-toggle__option--active"
				data-pricing-toggle="monthly"
				role="radio"
				aria-checked="true"
			>
				{toggleMonthlyLabel}
			</button>
			<button
				type="button"
				class="pricing-toggle__option"
				data-pricing-toggle="annual"
				role="radio"
				aria-checked="false"
			>
				{toggleAnnualLabel}
			</button>
		</div>
	)}

	{!hasPlans ? (
		<EmptyState
			locale={locale}
			variant="empty"
			message={emptyMessage}
			actionUrl={emptyActionUrl}
			actionLabel={emptyActionLabel}
		/>
	) : (
		<div class="pricing-cards__grid">
			{plans.map((plan, i) => {
				const isHighlighted = plan.slug === highlightedSlug;
				const monthlyFormatted =
					plan.monthlyPriceArs === 0
						? t('pricing.free', 'Gratis')
						: formatPriceArs(plan.monthlyPriceArs);
				const hasAnnualPrice =
					plan.annualPriceArs !== null && plan.annualPriceArs > 0;
				const annualFormatted = hasAnnualPrice
					? formatPriceArs(plan.annualPriceArs as number)
					: '';
				const savingPercent = computeAnnualSavingPercent(plan);
				const savingLabel =
					savingPercent !== null
						? annualSavingTemplate.replace('{percent}', String(savingPercent))
						: '';
				const previousPlan = i > 0 ? plans[i - 1] : undefined;
				const visibleEntitlements = computeAddedEntitlements({ plan, previous: previousPlan });
				const showsIncremental = i > 0 && visibleEntitlements !== plan.entitlements;
				const includesEverythingLabel = previousPlan
					? includesEverythingTemplate.replace('{plan}', getPlanName({ plan: previousPlan, t }))
					: '';
				const inheritedSummaryLabel = previousPlan
					? inheritedSummaryTemplate
							.replace('{count}', String(previousPlan.entitlements.length))
							.replace('{plan}', getPlanName({ plan: previousPlan, t }))
					: '';

				return (
					<div
						class:list={['pricing-card', { 'pricing-card--highlighted': isHighlighted }]}
						data-reveal="up"
						data-recommended-label={isHighlighted ? recommendedLabel : null}
						data-stagger-index={Math.min(i, 6)} data-stagger-step="100"
					>
						<h3 class="pricing-card__name">{getPlanName({ plan, t })}</h3>
						<p class="pricing-card__desc">{getPlanDescription({ plan, t })}</p>
						<div class="pricing-card__price">
							{/*
								Render both prices in the markup and let CSS toggle visibility
								based on the ancestor's data-billing attribute. Avoids shipping
								an island for the price display; the React PlanPurchaseButton
								below reads the same data attribute when forming the checkout
								payload.
							*/}
							<span class="pricing-card__amount pricing-card__amount--monthly">
								{monthlyFormatted}
							</span>
							{plan.monthlyPriceArs > 0 && (
								<span class="pricing-card__period pricing-card__period--monthly">
									{periodMonthLabel}
								</span>
							)}
							{hasAnnualPrice ? (
								<>
									<span class="pricing-card__amount pricing-card__amount--annual">
										{annualFormatted}
									</span>
									<span class="pricing-card__period pricing-card__period--annual">
										{periodYearLabel}
									</span>
									{savingLabel && (
										<span class="pricing-card__saving pricing-card__saving--annual">
											{savingLabel}
										</span>
									)}
								</>
							) : (
								<span class="pricing-card__amount pricing-card__amount--annual pricing-card__monthly-only">
									{monthlyOnlyLabel}
								</span>
							)}
						</div>
						{plan.hasTrial && plan.trialDays > 0 && (
							<p class="pricing-card__trial pricing-card__trial--monthly">
								{trialFallback.replace('{days}', String(plan.trialDays))}
							</p>
						)}
						{visibleEntitlements.length > 0 && (
							<ul class="pricing-card__features" aria-label={featuresLabel}>
								{showsIncremental && (
									<li class="pricing-card__feature pricing-card__feature--carryover">
										<svg
											class="pricing-card__feature-icon"
											xmlns="http://www.w3.org/2000/svg"
											width="18"
											height="18"
											viewBox="0 0 24 24"
											fill="none"
											aria-hidden="true"
										>
											<path
												d="M12 5v14M5 12h14"
												stroke="currentColor"
												stroke-width="2.5"
												stroke-linecap="round"
											/>
										</svg>
										<strong>{includesEverythingLabel}</strong>
									</li>
								)}
								{visibleEntitlements.map((entitlementKey) => (
									<li class="pricing-card__feature">
										<svg
											class="pricing-card__feature-icon"
											xmlns="http://www.w3.org/2000/svg"
											width="18"
											height="18"
											viewBox="0 0 24 24"
											fill="none"
											aria-hidden="true"
										>
											<path
												d="M5 12.5l4.5 4.5L19 7"
												stroke="currentColor"
												stroke-width="2.5"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										</svg>
										<span>{getEntitlementName({ key: entitlementKey as EntitlementKey, t })}</span>
									</li>
								))}
							</ul>
						)}
						{showsIncremental && inheritedSummaryLabel && (
							<p class="pricing-card__inherited">
								<span class="pricing-card__inherited-icon" aria-hidden="true">
									<StarIcon size="xs" weight="fill" color="currentColor" />
								</span>
								<span>{inheritedSummaryLabel}</span>
							</p>
						)}
						<div class="pricing-card__btn-wrapper">
							<PlanPurchaseButton
								client:load
								planSlug={plan.slug}
								monthlyPrice={plan.monthlyPriceArs}
								annualPrice={plan.annualPriceArs ?? null}
								currency="ARS"
								ctaText={ctaText}
								locale={locale}
							/>
						</div>
					</div>
				);
			})}
		</div>
	)}
</div>

<style>
	.pricing-cards__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.pricing-cards__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-card-gap);
		align-items: stretch;
		max-width: 1140px;
		margin: 0 auto;
		/* Headroom so the highlighted card's "Recomendado" badge, which sits
		   above the card's top edge, is never clipped (no scale anymore). */
		padding-top: var(--space-4);
	}

	.pricing-card {
		background-color: var(--core-card);
		border-radius: var(--radius-card);
		padding: var(--space-8);
		box-shadow: var(--shadow-card);
		border: 2px solid transparent;
		display: flex;
		flex-direction: column;
		transition:
			transform var(--duration-normal) ease,
			box-shadow var(--duration-normal) ease,
			border-color var(--duration-normal) ease;
	}

	.pricing-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-card-hover);
	}

	.pricing-card--highlighted {
		border-color: var(--brand-accent);
		background-color: var(--surface-warm);
		position: relative;
	}

	.pricing-card--highlighted:hover {
		transform: translateY(-4px);
	}

	.pricing-card--highlighted::before {
		content: attr(data-recommended-label);
		position: absolute;
		top: calc(var(--space-3) * -1);
		left: 50%;
		transform: translateX(-50%);
		background-color: var(--brand-accent);
		color: var(--accent-foreground);
		font-family: var(--font-sans);
		font-weight: 600;
		font-size: var(--text-caption);
		padding: var(--space-1) var(--space-3);
		border-radius: var(--radius-pill);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.pricing-card__name {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: var(--text-xl);
		color: var(--core-foreground);
		margin: 0 0 var(--space-2);
	}

	.pricing-card__desc {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
		margin: 0 0 var(--space-4);
	}

	.pricing-card__price {
		margin-bottom: var(--space-4);
	}

	.pricing-card__amount {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		color: var(--core-foreground);
	}

	.pricing-card__period {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
		margin-left: var(--space-1);
	}

	.pricing-card__trial {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--brand-accent);
		font-weight: 600;
		margin: 0 0 var(--space-4);
	}

	.pricing-card__features {
		list-style: none;
		padding: 0;
		margin: 0 0 var(--space-4);
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	/* Summary block (OQ-2): on incremental cards, restate the inherited tier
	   compactly so higher-tier cards do not read as "empty" next to the full
	   base card. A dashed outline keeps it legible on both the plain card and
	   the warm-tinted highlighted card. It sits right after the feature list;
	   the CTA wrapper's `margin-top: auto` absorbs the remaining space below. */
	.pricing-card__inherited {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		margin: 0 0 var(--space-4);
		padding: var(--space-3);
		border: 1px dashed var(--core-foreground-a15);
		border-radius: var(--radius-card);
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
	}

	.pricing-card__inherited-icon {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
		color: var(--brand-accent);
	}

	.pricing-card__feature {
		display: flex;
		align-items: flex-start;
		gap: var(--space-2);
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		color: var(--core-foreground);
		line-height: 1.5;
	}

	.pricing-card__feature--carryover {
		padding-bottom: var(--space-2);
		border-bottom: 1px dashed var(--core-foreground-a15);
		margin-bottom: var(--space-1);
	}

	.pricing-card__feature--carryover strong {
		font-weight: 600;
	}

	.pricing-card__feature--carryover .pricing-card__feature-icon {
		color: var(--brand-accent);
	}

	.pricing-card__feature-icon {
		flex-shrink: 0;
		color: var(--success);
		margin-top: 2px;
	}

	.pricing-card__btn-wrapper {
		display: flex;
		justify-content: center;
		margin-top: auto;
	}

	@media (max-width: 768px) {
		.pricing-cards__grid {
			grid-template-columns: 1fr;
			max-width: 400px;
			margin: 0 auto;
		}
		.pricing-card--highlighted {
			transform: none;
		}
		.pricing-card--highlighted:hover {
			transform: translateY(-4px);
		}
	}

	/* ─── Toggle UI ────────────────────────────────────────────────── */
	.pricing-toggle {
		display: inline-flex;
		gap: 0;
		margin: 0 auto var(--space-6);
		background-color: var(--surface-warm);
		border-radius: var(--radius-pill);
		padding: var(--space-1);
		position: relative;
		justify-self: center;
		align-self: center;
	}
	.pricing-cards__container .pricing-toggle {
		margin-left: auto;
		margin-right: auto;
		display: flex;
		max-width: max-content;
	}
	.pricing-toggle__option {
		font-family: var(--font-sans);
		font-size: var(--text-body-sm);
		font-weight: 600;
		color: var(--core-muted-foreground);
		background-color: transparent;
		border: none;
		padding: var(--space-2) var(--space-4);
		border-radius: var(--radius-pill);
		cursor: pointer;
		transition: background-color var(--duration-normal) ease,
			color var(--duration-normal) ease;
	}
	.pricing-toggle__option:hover {
		color: var(--core-foreground);
	}
	.pricing-toggle__option--active {
		background-color: var(--core-card);
		color: var(--brand-accent);
		box-shadow: var(--shadow-card);
	}
	.pricing-toggle__option:focus-visible {
		outline: 2px solid var(--brand-accent);
		outline-offset: 2px;
	}

	/* ─── Dual price visibility ──────────────────────────────────────
	   The grid container carries `data-billing="monthly"|"annual"`. The
	   toggle script (below) flips it on user interaction. Cards render
	   both monthly and annual price spans; CSS hides the inactive set.
	   This keeps the toggle as zero-cost SSG markup — the React island
	   below (PlanPurchaseButton) reads the same attribute on click to
	   send the right `billingInterval` to /start-paid.
	 */
	.pricing-card__amount--annual,
	.pricing-card__period--annual,
	.pricing-card__saving--annual {
		display: none;
	}
	[data-billing='annual'] .pricing-card__amount--monthly,
	[data-billing='annual'] .pricing-card__period--monthly,
	[data-billing='annual'] .pricing-card__trial--monthly {
		display: none;
	}
	[data-billing='annual'] .pricing-card__amount--annual,
	[data-billing='annual'] .pricing-card__period--annual {
		display: inline;
	}
	[data-billing='annual'] .pricing-card__saving--annual {
		display: block;
	}
	.pricing-card__saving {
		/* `display` is owned exclusively by the --annual toggle rules above:
		   hidden in monthly, shown (block) only under [data-billing='annual'].
		   Do NOT set `display` here or it overrides the monthly-hide rule. */
		font-family: var(--font-sans);
		font-size: var(--text-caption);
		font-weight: 600;
		color: var(--success, var(--brand-accent));
		margin-top: var(--space-1);
	}
	.pricing-card__monthly-only {
		font-size: var(--text-body-sm);
		color: var(--core-muted-foreground);
		font-style: italic;
		font-weight: 400;
	}
</style>

<style is:global>
	/* ─── Promo-applied card visuals ─────────────────────────────────────
	   These classes/nodes are injected at runtime by the PlanPurchaseButton
	   island (when a user applies a valid promo code) on the surrounding
	   `.pricing-card`. They live OUTSIDE Astro's scoped CSS, so the rules
	   must be global. Every change is reverted by the island on remove.
	 */
	.pricing-card__amount--struck {
		text-decoration: line-through;
		opacity: 0.55;
		font-weight: 400;
		margin-right: var(--space-2, 0.5rem);
	}
	.pricing-card__amount--promo {
		color: var(--success, var(--brand-accent));
		font-weight: 800;
	}
	.pricing-card__promo-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		margin-top: var(--space-2, 0.5rem);
		padding: 0.2em 0.65em;
		border-radius: 999px;
		background: color-mix(in srgb, var(--success, var(--brand-accent)) 14%, transparent);
		color: var(--success, var(--brand-accent));
		font-family: var(--font-sans);
		font-size: var(--text-caption);
		font-weight: 700;
		line-height: 1.3;
		animation: promo-badge-in 280ms ease-out both;
	}
	.pricing-card__promo-badge::before {
		content: '';
		width: 0.5em;
		height: 0.5em;
		border-radius: 50%;
		background: currentColor;
		flex: none;
	}
	.pricing-card__trial--promo {
		color: var(--success, var(--brand-accent));
		font-weight: 700;
	}
	.pricing-card__price--promo-active {
		animation: promo-price-pulse 650ms ease-out 1;
		border-radius: var(--radius-md, 0.5rem);
	}
	@keyframes promo-price-pulse {
		0% {
			box-shadow: 0 0 0 0 color-mix(in srgb, var(--success, var(--brand-accent)) 55%, transparent);
		}
		70% {
			box-shadow: 0 0 0 12px color-mix(in srgb, var(--success, var(--brand-accent)) 0%, transparent);
		}
		100% {
			box-shadow: 0 0 0 0 transparent;
		}
	}
	@keyframes promo-badge-in {
		from {
			opacity: 0;
			transform: translateY(4px) scale(0.96);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.pricing-card__price--promo-active,
		.pricing-card__promo-badge {
			animation: none;
		}
	}
</style>

<script>
	/**
	 * Vanilla JS toggle for monthly / annual billing interval. Lives outside
	 * any React island so the grid stays SSG-friendly (no hydration cost).
	 * Updates the closest `.pricing-cards__container` data-billing attribute;
	 * CSS handles all visual changes for the cards, and the React
	 * PlanPurchaseButton island observes the attribute via MutationObserver
	 * to keep the displayed checkout price + the /start-paid payload in
	 * sync. Pattern documented inline in PlanPurchaseButton.client.tsx.
	 */
	function initPricingToggle(container: HTMLElement): void {
		const options = container.querySelectorAll<HTMLButtonElement>(
			'[data-pricing-toggle]'
		);
		if (options.length === 0) return;
		const setActive = (interval: 'monthly' | 'annual'): void => {
			container.setAttribute('data-billing', interval);
			for (const opt of options) {
				const isActive = opt.dataset.pricingToggle === interval;
				opt.classList.toggle('pricing-toggle__option--active', isActive);
				opt.setAttribute('aria-checked', String(isActive));
			}
		};
		for (const opt of options) {
			opt.addEventListener('click', () => {
				const interval = opt.dataset.pricingToggle === 'annual' ? 'annual' : 'monthly';
				setActive(interval);
			});
		}
	}

	document.querySelectorAll<HTMLElement>('.pricing-cards__container[data-billing]').forEach(
		(container) => initPricingToggle(container)
	);
</script>
