---
/**
 * @file TagChips.astro
 * @description Horizontal scrollable row of chip-styled anchor links for quick
 * category / type filtering on listing pages. Renders a semantically correct
 * <nav> with an accessible label and a horizontally scrollable chip list.
 *
 * BETA-113 (icon parity follow-up): each chip supports an OPTIONAL leading
 * icon — a resolved `@repo/icons` component reference (not a JSX element),
 * the same dynamic-component-rendering pattern already used by
 * `AccommodationTypeBadge.astro` and the destinos attraction filter
 * (`const Icon = getAttractionIcon(...); <Icon .../>`). Callers resolve their
 * own per-category/type icon component and pass it in `chips[].icon`; this
 * component only renders it, it does not resolve any mapping itself.
 *
 * Rendering: Static (no client JavaScript).
 */
import type { ComponentType } from 'react';
import type { IconProps } from '@repo/icons';

interface ChipItem {
    /** Visible label rendered inside the chip. */
    readonly label: string;
    /** Target URL for the chip anchor. */
    readonly href: string;
    /** When true, the chip renders in the active/selected state. */
    readonly active?: boolean;
    /** Optional leading icon component (already resolved by the caller). */
    readonly icon?: ComponentType<IconProps>;
}

interface Props {
    /** Array of chips to render. */
    readonly chips: ReadonlyArray<ChipItem>;
    /** Accessible label for the surrounding <nav> element. */
    readonly ariaLabel: string;
}

const { chips, ariaLabel } = Astro.props;
---

<nav class="tag-chips" aria-label={ariaLabel}>
    <div class="tag-chips__fade-wrapper">
        <ul class="tag-chips__list" role="list">
            {chips.map(({ label, href, active, icon: Icon }) => (
                <li class="tag-chips__item">
                    <a
                        href={href}
                        class:list={['tag-chips__chip', { 'tag-chips__chip--active': active }]}
                        aria-current={active ? 'true' : undefined}
                    >
                        {Icon && (
                            <span class="tag-chips__chip-icon" aria-hidden="true">
                                <Icon size={14} weight="regular" />
                            </span>
                        )}
                        {label}
                    </a>
                </li>
            ))}
        </ul>
    </div>
</nav>

<style>
    /* ========================================================
       Tag Chips — scrollable row of category/type filter links
       ======================================================== */
    .tag-chips {
        width: 100%;
        overflow: hidden;
        /* Breathing room between the category chip row and the results grid
           below it — without this the chips sit flush against the first cards
           (BETA-120). Pairs with the ~8px padding-block on the list for a
           balanced gap. */
        margin-bottom: var(--space-6, 24px);
    }

    .tag-chips__fade-wrapper {
        position: relative;
        width: 100%;
    }

    .tag-chips__list {
        display: flex;
        flex-direction: row;
        flex-wrap: nowrap;
        gap: var(--space-3, 12px);
        padding-block: var(--space-2, 8px);
        padding-inline: 2px;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        list-style: none;
        /* Edge-fade widths, driven by the scroll-state script below. Default is
           0 (no fade) on both sides so the FIRST chip is never dimmed at rest
           (BETA-30: "Cultura" looked faded under a fixed left fade). The script
           raises a side to 48px only when there is off-screen content to scroll
           toward on that side. */
        --tag-chips-fade-start: 0px;
        --tag-chips-fade-end: 0px;
        mask-image: linear-gradient(
            to right,
            transparent 0,
            black var(--tag-chips-fade-start),
            black calc(100% - var(--tag-chips-fade-end)),
            transparent 100%
        );
        -webkit-mask-image: linear-gradient(
            to right,
            transparent 0,
            black var(--tag-chips-fade-start),
            black calc(100% - var(--tag-chips-fade-end)),
            transparent 100%
        );
    }

    .tag-chips__list::-webkit-scrollbar {
        display: none;
    }

    .tag-chips__chip {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        white-space: nowrap;
        padding: 6px 16px;
        border-radius: var(--radius-pill, 9999px);
        border: 1px solid var(--border, var(--brand-primary-a25));
        background-color: var(--core-card);
        color: var(--core-foreground);
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        font-weight: 500;
        line-height: 1.4;
        text-decoration: none;
        transition:
            background-color var(--duration-normal) ease,
            color var(--duration-normal) ease,
            border-color var(--duration-normal) ease,
            box-shadow var(--duration-normal) ease;
        cursor: pointer;
        /* Prevent chip from being squished */
        flex-shrink: 0;
    }

    .tag-chips__chip:hover {
        background-color: var(--brand-accent);
        color: var(--accent-foreground, #fff);
        border-color: var(--brand-accent);
        box-shadow: 0 2px 8px var(--brand-accent-a30);
    }

    /* Active/selected chip — matches the temporal quick-filter chips so both
       rows of filters read as the same control. */
    .tag-chips__chip--active {
        background-color: var(--brand-accent);
        color: var(--accent-foreground, #fff);
        border-color: var(--brand-accent);
    }

    .tag-chips__chip:focus-visible {
        outline: 2px solid var(--brand-accent);
        outline-offset: 2px;
    }

    /* Optional leading icon (BETA-113 icon parity) — same 14px size and
       vertical centering as the destinos attraction-filter chip icon, so
       every quick-filter chip surface reads consistently when an icon is
       present. */
    .tag-chips__chip-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
</style>

<script>
    /**
     * Toggle the left/right edge fade per scroll position so the fade only
     * appears on a side that has off-screen chips (BETA-30). At rest (scrollLeft
     * 0) the left fade stays off, keeping the first chip ("Cultura") crisp.
     * Runs on every page load incl. View Transitions; idempotent per list.
     */
    const FADE = '48px';
    const NONE = '0px';

    function initTagChipsFades(): void {
        const lists = document.querySelectorAll<HTMLElement>('.tag-chips__list');
        for (const list of lists) {
            if (list.dataset.fadeInit === 'true') continue;
            list.dataset.fadeInit = 'true';

            const update = (): void => {
                const maxScroll = list.scrollWidth - list.clientWidth;
                const scrollable = maxScroll > 1;
                const atStart = list.scrollLeft <= 1;
                const atEnd = list.scrollLeft >= maxScroll - 1;
                list.style.setProperty(
                    '--tag-chips-fade-start',
                    scrollable && !atStart ? FADE : NONE
                );
                list.style.setProperty(
                    '--tag-chips-fade-end',
                    scrollable && !atEnd ? FADE : NONE
                );
            };

            list.addEventListener('scroll', update, { passive: true });
            if (typeof ResizeObserver !== 'undefined') {
                new ResizeObserver(update).observe(list);
            }
            update();
        }
    }

    document.addEventListener('astro:page-load', initTagChipsFades);
</script>
