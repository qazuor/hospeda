---
/**
 * @file EventDetailHeader.astro
 * @description Event detail page header with a history-aware back button,
 * category badge, title, date/location meta, status badges (past/cancelled),
 * bookmark counter, and favorite button.
 *
 * Layout (HOS-84): a vertical stack — a back-button row on top, then a
 * 2-column `.event-header__body` row where `.event-header__main` holds
 * badges + title + meta and `.event-header__favorite` anchors the heart
 * button on the right. The favorite stays right-aligned regardless of
 * viewport or compact mode.
 *
 * Compact behavior comes from the shared `.wh-compact-*` utility classes
 * (contract defined once in WaveHeader.astro): `wh-compact-row` collapses the
 * main stack to one line, `wh-compact-title` shrinks the H1, `wh-compact-badge`
 * shrinks the category/status pills, `wh-compact-hide` drops the back-button
 * row + meta. Only the genuinely event-specific body cross-axis alignment and
 * badges-gap overrides remain local below.
 */

import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';
import HeaderBackButton from '@/components/shared/ui/HeaderBackButton.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { getEventCategoryColor, getBadgeStatusColor } from '@/lib/colors';
import { formatEventDetailDateRange } from '@/lib/format-utils';
import { CalendarDotsIcon, LocationIcon } from '@repo/icons';

interface Props {
    readonly eventId: string;
    readonly name: string;
    readonly category: string;
    readonly startDate: string | Date;
    readonly endDate?: string | Date | null;
    /** Date precision (HOS-280). Defaults to `'EXACT'`. */
    readonly precision?: 'EXACT' | 'MONTH';
    readonly locationCity?: string | null;
    readonly locationName?: string | null;
    readonly isPast: boolean;
    readonly isCancelled: boolean;
    readonly bookmarkCount?: number;
    readonly locale: SupportedLocale;
    readonly isAuthenticated: boolean;
    readonly initialIsFavorited?: boolean;
    readonly initialBookmarkId?: string | null;
}

const {
    eventId,
    name,
    category,
    startDate,
    endDate,
    precision = 'EXACT',
    locationCity,
    locationName,
    isPast,
    isCancelled,
    bookmarkCount,
    locale,
    isAuthenticated,
    initialIsFavorited,
    initialBookmarkId = null,
} = Astro.props;

const { t, tPlural } = createTranslations(locale);

const dateRange = formatEventDetailDateRange({ startDate, endDate, precision, locale });

const categoryColors = getEventCategoryColor({ category: category.toLowerCase() });
const pastColors = getBadgeStatusColor({ status: 'past' });
const cancelledColors = getBadgeStatusColor({ status: 'cancelled' });

const locationLabel =
    locationName &&
    locationCity &&
    locationName.trim().toLowerCase() !== locationCity.trim().toLowerCase()
        ? `${locationName}, ${locationCity}`
        : locationName || locationCity || null;

const categoryStyle = `background-color: ${categoryColors.bg}; color: ${categoryColors.text}; border: 1px solid ${categoryColors.border};`;
const pastStyle = `background-color: ${pastColors.bg}; color: ${pastColors.text};`;
const cancelledStyle = `background-color: ${cancelledColors.bg}; color: ${cancelledColors.text};`;
---

<header class="event-header">
    <div class="event-header__back-row wh-compact-hide">
        <HeaderBackButton href={`/${locale}/eventos/`} locale={locale} />
    </div>

    <div class="event-header__body">
        <div class="event-header__main wh-compact-row">
            <div class="event-header__badges">
                <span class="event-header__category-badge wh-compact-badge" style={categoryStyle}>
                    {t(`events.categories.${category.toLowerCase()}`, category)}
                </span>
                {isPast && (
                    <span class="event-header__status-pill wh-compact-badge" style={pastStyle}>
                        {t('event.detail.pastEvent', 'Evento Finalizado')}
                    </span>
                )}
                {isCancelled && (
                    <span class="event-header__status-pill wh-compact-badge" style={cancelledStyle}>
                        {t('event.detail.cancelled', 'Cancelado')}
                    </span>
                )}
                {precision === 'MONTH' && (
                    <span class="event-header__estimated-badge wh-compact-badge">
                        {t('events.detail.monthOnlyBadge', 'Fecha estimada · programación a confirmar')}
                    </span>
                )}
            </div>

            <h1 class="event-header__title wh-compact-title">{name}</h1>

            <div class="event-header__meta wh-compact-hide">
                {startDate && (
                    <span class="event-header__meta-item">
                        <CalendarDotsIcon size={15} aria-hidden="true" />
                        {dateRange.precision === 'EXACT' ? (
                            <>
                                {dateRange.startLabel}
                                {dateRange.endLabel && (
                                    <span class="event-header__meta-separator" aria-hidden="true">–</span>
                                )}
                                {dateRange.endLabel}
                            </>
                        ) : (
                            dateRange.label
                        )}
                    </span>
                )}
                {locationLabel && (
                    <span class="event-header__meta-item">
                        <LocationIcon size={15} aria-hidden="true" />
                        {locationLabel}
                    </span>
                )}
                {bookmarkCount !== undefined && (
                    <span
                        class="event-header__bookmark-count"
                        aria-label={bookmarkCount === 0
                            ? t('event.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
                            : tPlural('event.detail.bookmark_count', bookmarkCount)}
                    >
                        <span class="event-header__bookmark-icon" aria-hidden="true">♥</span>
                        {bookmarkCount === 0
                            ? t('event.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
                            : tPlural('event.detail.bookmark_count', bookmarkCount)}
                    </span>
                )}
            </div>
        </div>

        <div class="event-header__favorite">
            <FavoriteButton
                client:load
                entityId={eventId}
                entityType="EVENT"
                initialIsFavorited={initialIsFavorited}
                initialBookmarkId={initialBookmarkId}
                isAuthenticated={isAuthenticated}
                variant="standalone"
                locale={locale}
            />
        </div>
    </div>
</header>

<style>
    /* Vertical stack: back-button row on top, then the body row. */
    .event-header {
        display: flex;
        flex-direction: column;
        gap: var(--space-2, 8px);
    }

    /* Back-button row — collapses out via `wh-compact-hide` in compact mode, so
       it needs its own max-height/opacity transition to animate. */
    .event-header__back-row {
        overflow: hidden;
        max-height: 3em;
        opacity: 1;
        transition:
            max-height 0.3s ease,
            opacity 0.2s ease;
    }

    /* Body: main content stretches, favorite stays right. */
    .event-header__body {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        gap: var(--space-3, 12px);
    }

    .event-header__main {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2, 8px);
        transition: gap 0.3s ease;
    }

    .event-header__favorite {
        flex-shrink: 0;
        margin-left: auto;
    }

    .event-header__badges {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2, 8px);
        align-items: center;
        transition: gap 0.3s ease;
    }

    .event-header__category-badge {
        display: inline-flex;
        align-items: center;
        border-radius: var(--radius-pill, 9999px);
        font-family: var(--font-sans);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 4px 14px;
        line-height: 1.4;
        white-space: nowrap;
        transition: padding 0.3s ease, font-size 0.3s ease;
    }

    .event-header__status-pill {
        display: inline-flex;
        align-items: center;
        border-radius: var(--radius-pill, 9999px);
        font-family: var(--font-sans);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 4px 14px;
        line-height: 1.4;
        white-space: nowrap;
        transition: padding 0.3s ease, font-size 0.3s ease;
    }

    /* Estimated-date badge (HOS-280): a plain-language pill (not uppercase, not
       color-coded to a status) that flags MONTH-precision events — the text
       itself carries the meaning, so it reads correctly without relying on
       color alone. Reuses the `--muted` / `--core-muted-foreground` pair,
       matching the neutral "past" status scheme in getBadgeStatusColor(). */
    .event-header__estimated-badge {
        display: inline-flex;
        align-items: center;
        border-radius: var(--radius-pill, 9999px);
        font-family: var(--font-sans);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        padding: 4px 14px;
        line-height: 1.4;
        background-color: var(--muted);
        color: var(--core-muted-foreground);
        transition: padding 0.3s ease, font-size 0.3s ease;
    }

    .event-header__title {
        font-family: var(--font-heading);
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        font-weight: 700;
        color: var(--core-foreground);
        margin: 0;
        line-height: 1.15;
        transition: font-size 0.3s ease;
    }

    .event-header__meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: var(--space-3, 12px);
        overflow: hidden;
        max-height: 12em;
        opacity: 1;
        transition:
            max-height 0.3s ease,
            opacity 0.2s ease;
    }

    .event-header__meta-item {
        display: inline-flex;
        align-items: center;
        gap: 0.3em;
        font-family: var(--font-sans);
        font-size: var(--text-body-sm, 0.875rem);
        color: var(--core-muted-foreground);
    }

    .event-header__meta-separator {
        margin: 0 0.2em;
    }

    .event-header__bookmark-count {
        display: inline-flex;
        align-items: center;
        gap: 0.3em;
        font-family: var(--font-sans);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--core-muted-foreground);
        border-left: 1px solid var(--border);
        padding-left: var(--space-2, 8px);
        margin-left: var(--space-1, 4px);
    }

    .event-header__bookmark-icon {
        font-size: 0.75rem;
        color: var(--destructive);
        line-height: 1;
    }

    /* =========================================================
     * Compact state — only genuinely event-specific overrides remain here;
     * the row collapse, title shrink, badge shrink, meta/back hide all come
     * from the shared `.wh-compact-*` utilities applied in the markup
     * (contract in WaveHeader.astro).
     * ========================================================= */
    :global(.wave-header--compact) .event-header__body {
        align-items: center;
    }

    :global(.wave-header--compact) .event-header__badges {
        gap: 4px;
    }

    @media (prefers-reduced-motion: reduce) {
        .event-header__back-row,
        .event-header__main,
        .event-header__badges,
        .event-header__category-badge,
        .event-header__status-pill,
        .event-header__estimated-badge,
        .event-header__title,
        .event-header__meta {
            transition: none;
        }
    }
</style>
