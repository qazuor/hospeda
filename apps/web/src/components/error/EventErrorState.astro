---
/**
 * Error state component for event pages.
 * Wraps GenericErrorState with event-specific icon and default messages.
 */
import { EventIcon } from '@repo/icons';
import GenericErrorState from './GenericErrorState.astro';

interface Props {
  /** Current locale */
  locale?: 'es' | 'en' | 'pt';
  /** URL to retry (defaults to event listing) */
  retryHref?: string;
  /** Additional CSS classes */
  class?: string;
}

const { locale = 'es', retryHref, class: className } = Astro.props;

const messages: Record<string, { title: string; message: string }> = {
  es: {
    title: 'Error al cargar eventos',
    message: 'No pudimos obtener la información de eventos. Verificá tu conexión e intentá de nuevo.',
  },
  en: {
    title: 'Error loading events',
    message: 'We could not load event information. Check your connection and try again.',
  },
  pt: {
    title: 'Erro ao carregar eventos',
    message: 'Não foi possível obter as informações de eventos. Verifique sua conexão e tente novamente.',
  },
};

const t = messages[locale] ?? messages.es;
---

<GenericErrorState
  title={t.title}
  message={t.message}
  retryHref={retryHref ?? `/${locale}/eventos/`}
  homeHref={`/${locale}/`}
  locale={locale}
  class={className}
>
  <div slot="icon" class="flex h-16 w-16 items-center justify-center rounded-full bg-accent-dark/10 text-accent-dark">
    <EventIcon size={32} weight="duotone" aria-hidden="true" />
  </div>
</GenericErrorState>
