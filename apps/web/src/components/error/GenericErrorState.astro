---
/**
 * Generic error state component for displaying when data fetching fails.
 * Provides a consistent error UI with icon, title, message, retry, and home link.
 * Used as a base for entity-specific error components.
 *
 * @example
 * ```astro
 * <GenericErrorState
 *   title="Error loading data"
 *   message="Something went wrong. Please try again."
 *   retryHref="/es/alojamientos/"
 *   homeHref="/es/"
 *   locale="es"
 * />
 * ```
 */
import { AlertTriangleIcon } from '@repo/icons';
import Button from '../ui/Button.astro';

interface Props {
  /** Error heading text */
  title: string;
  /** Descriptive error message */
  message: string;
  /** URL to retry the failed request (usually the current page) */
  retryHref?: string;
  /** URL for the home/back link */
  homeHref?: string;
  /** Current locale */
  locale?: 'es' | 'en' | 'pt';
  /** Additional CSS classes */
  class?: string;
}

const {
  title,
  message,
  retryHref,
  homeHref,
  locale = 'es',
  class: className,
} = Astro.props;

/**
 * Localized labels for action buttons.
 */
const labels: Record<string, { retry: string; home: string }> = {
  es: { retry: 'Reintentar', home: 'Volver al inicio' },
  en: { retry: 'Try again', home: 'Go to home' },
  pt: { retry: 'Tentar novamente', home: 'Voltar ao início' },
};

const t = labels[locale] ?? labels.es;
---

<div class:list={['flex flex-col items-center justify-center px-6 py-16 text-center', className]} role="alert">
  {/* Icon slot for entity-specific icons */}
  <div class="mb-6">
    <slot name="icon">
      {/* Default: generic error icon */}
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-error/10 text-error">
        <AlertTriangleIcon size={32} weight="duotone" aria-hidden="true" />
      </div>
    </slot>
  </div>

  {/* Title */}
  <h2 class="mb-3 text-xl font-semibold text-text">
    {title}
  </h2>

  {/* Message */}
  <p class="mb-8 max-w-md text-base text-text-secondary">
    {message}
  </p>

  {/* Actions */}
  <div class="flex flex-col items-center gap-3 sm:flex-row">
    {retryHref && (
      <Button href={retryHref} variant="primary" size="md">
        {t.retry}
      </Button>
    )}
    {homeHref && (
      <a href={homeHref} class="text-sm font-medium text-text-secondary transition-colors hover:text-primary">
        {t.home}
      </a>
    )}
  </div>
</div>
