---
/**
 * BeachUmbrellaIllustration - Beach umbrella in sand with towel and water horizon.
 * Line-art illustration using currentColor for light/dark mode compatibility.
 */
export interface BeachUmbrellaIllustrationProps {
  /** Additional CSS classes to apply to the SVG element */
  class?: string;
}

interface Props extends BeachUmbrellaIllustrationProps {}

const { class: className } = Astro.props;
---

<svg
  class:list={['illustration', className]}
  viewBox="0 0 150 150"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Sky / water horizon -->
  <path d="M0,70 L150,70" stroke-width="1.5" opacity="0.4" />

  <!-- Water -->
  <path d="M0,72 Q25,68 50,72 Q75,76 100,72 Q125,68 150,72" stroke-width="1.5" />
  <path d="M0,80 Q30,76 60,80 Q90,84 120,80 Q135,78 150,80" stroke-width="1" opacity="0.7" />
  <path d="M0,88 Q35,84 70,88 Q100,91 130,88 Q140,87 150,88" stroke-width="1" opacity="0.5" />

  <!-- Water light reflections -->
  <path d="M10,75 Q20,73 30,75" stroke-width="1" opacity="0.4" />
  <path d="M110,74 Q120,72 130,74" stroke-width="1" opacity="0.4" />
  <path d="M60,82 Q70,80 80,82" stroke-width="1" opacity="0.3" />

  <!-- Sand -->
  <path d="M0,95 Q75,90 150,95 L150,150 L0,150 Z"
        fill="currentColor" opacity="0.06" stroke="none" />
  <path d="M0,95 Q75,90 150,95" stroke-width="2" />

  <!-- Sand texture dots -->
  <circle cx="15" cy="105" r="1" fill="currentColor" opacity="0.3" />
  <circle cx="30" cy="112" r="1" fill="currentColor" opacity="0.3" />
  <circle cx="110" cy="108" r="1" fill="currentColor" opacity="0.3" />
  <circle cx="125" cy="120" r="1" fill="currentColor" opacity="0.3" />
  <circle cx="140" cy="105" r="1" fill="currentColor" opacity="0.3" />
  <circle cx="20" cy="130" r="1" fill="currentColor" opacity="0.2" />
  <circle cx="45" cy="122" r="1" fill="currentColor" opacity="0.2" />

  <!-- Towel on sand -->
  <path d="M25,112 Q40,108 65,110 Q75,111 80,116 Q65,120 40,118 Q28,116 25,112 Z"
        stroke-width="1.5" fill="currentColor" opacity="0.08" />
  <!-- Towel stripes -->
  <path d="M32,111 Q35,116 34,117" stroke-width="1" opacity="0.4" />
  <path d="M42,109 Q45,115 43,118" stroke-width="1" opacity="0.4" />
  <path d="M52,109 Q55,115 53,119" stroke-width="1" opacity="0.4" />
  <path d="M62,110 Q64,115 63,119" stroke-width="1" opacity="0.4" />
  <!-- Towel fringe -->
  <path d="M25,112 Q24,110 23,108" stroke-width="1" opacity="0.5" />
  <path d="M30,111 Q29,109 28,107" stroke-width="1" opacity="0.5" />

  <!-- Umbrella pole -->
  <line x1="75" y1="140" x2="75" y2="45" stroke-width="3" />
  <!-- Pole goes into sand -->
  <line x1="75" y1="130" x2="75" y2="140" stroke-width="3" opacity="0.6" />

  <!-- Umbrella canopy - full arc shape -->
  <!-- Main canopy silhouette -->
  <path d="M30,72 Q45,45 75,40 Q105,35 120,72"
        stroke-width="0" fill="currentColor" opacity="0.08" />
  <path d="M30,72 Q45,45 75,40 Q105,35 120,72" stroke-width="2.5" />

  <!-- Umbrella ribs -->
  <line x1="75" y1="45" x2="30" y2="72" stroke-width="1.5" opacity="0.6" />
  <line x1="75" y1="45" x2="45" y2="60" stroke-width="1.5" opacity="0.6" />
  <line x1="75" y1="45" x2="60" y2="52" stroke-width="1.5" opacity="0.6" />
  <line x1="75" y1="45" x2="90" y2="52" stroke-width="1.5" opacity="0.6" />
  <line x1="75" y1="45" x2="105" y2="60" stroke-width="1.5" opacity="0.6" />
  <line x1="75" y1="45" x2="120" y2="72" stroke-width="1.5" opacity="0.6" />

  <!-- Umbrella scalloped edge -->
  <path d="M30,72 Q36,78 43,72 Q49,78 56,72 Q62,78 69,72 Q75,78 81,72 Q87,78 94,72 Q100,78 107,72 Q113,78 120,72"
        stroke-width="2" />

  <!-- Umbrella tip top -->
  <circle cx="75" cy="40" r="3" fill="currentColor" opacity="0.3" stroke-width="2" />

  <!-- Sunglasses on towel -->
  <path d="M50,113 Q53,111 56,113 Q56,116 53,116 Q50,116 50,113 Z" stroke-width="1" />
  <path d="M56,113 L60,113" stroke-width="1" />
  <path d="M60,113 Q63,111 66,113 Q66,116 63,116 Q60,116 60,113 Z" stroke-width="1" />
  <!-- Glasses arms -->
  <line x1="50" y1="113" x2="47" y2="114" stroke-width="1" />
  <line x1="66" y1="113" x2="69" y2="114" stroke-width="1" />

  <!-- Seagull silhouettes in sky -->
  <path d="M15,55 Q18,52 21,55" stroke-width="1.5" />
  <path d="M25,48 Q28,45 31,48" stroke-width="1.5" />
  <path d="M110,50 Q113,47 116,50" stroke-width="1.5" />
  <path d="M130,42 Q132,39 135,42" stroke-width="1.5" />
</svg>
