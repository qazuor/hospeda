---
/**
 * KayakIllustration - Kayak with paddler on calm waters.
 * Line-art illustration using currentColor for light/dark mode compatibility.
 */
export interface KayakIllustrationProps {
  /** Additional CSS classes to apply to the SVG element */
  class?: string;
}

interface Props extends KayakIllustrationProps {}

const { class: className } = Astro.props;
---

<svg
  class:list={['illustration', className]}
  viewBox="0 0 200 120"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Water ripples behind kayak -->
  <path d="M0,85 Q20,80 40,85 Q60,90 80,85" stroke-width="1.5" opacity="0.6" />
  <path d="M0,93 Q25,88 50,93 Q70,97 90,93" stroke-width="1" opacity="0.5" />

  <!-- Main water surface -->
  <path d="M0,88 Q50,83 100,88 Q150,93 200,88" stroke-width="1.5" />
  <path d="M0,96 Q50,91 100,96 Q150,101 200,96" stroke-width="1" opacity="0.7" />
  <path d="M0,104 Q50,100 100,104 Q150,108 200,104" stroke-width="1" opacity="0.5" />

  <!-- Kayak hull -->
  <path d="M30,82 Q60,72 100,70 Q140,68 165,76 Q175,80 172,84 Q140,90 100,88 Q60,86 30,82 Z"
        stroke-width="2.5" />
  <!-- Kayak deck line -->
  <path d="M32,82 Q60,78 100,76 Q140,74 165,78" stroke-width="1" opacity="0.6" />
  <!-- Kayak cockpit -->
  <ellipse cx="100" cy="76" rx="22" ry="8" stroke-width="2" />
  <!-- Cockpit rim highlight -->
  <path d="M80,74 Q100,70 120,74" stroke-width="1" opacity="0.5" />

  <!-- Bow and stern decorative lines -->
  <path d="M30,82 Q28,80 32,78" stroke-width="1.5" />
  <path d="M165,76 Q168,74 170,76" stroke-width="1.5" />

  <!-- Paddler - torso -->
  <line x1="100" y1="68" x2="100" y2="55" stroke-width="3" />
  <!-- Paddler - head -->
  <circle cx="100" cy="49" r="7" stroke-width="2" />
  <!-- Helmet -->
  <path d="M93,48 Q100,40 107,48" stroke-width="2" fill="currentColor" opacity="0.15" />
  <!-- Life vest suggestion -->
  <path d="M95,55 Q92,60 93,65 Q100,67 107,65 Q108,60 105,55" stroke-width="1.5" fill="currentColor" opacity="0.1" />

  <!-- Paddle -->
  <!-- Left paddle blade -->
  <path d="M60,52 Q52,46 48,50 Q46,55 52,58 Q58,60 64,56 Z" stroke-width="1.5" fill="currentColor" opacity="0.15" />
  <!-- Paddle shaft left -->
  <line x1="64" y1="55" x2="95" y2="62" stroke-width="2.5" />
  <!-- Paddle shaft right -->
  <line x1="105" y1="62" x2="136" y2="55" stroke-width="2.5" />
  <!-- Right paddle blade (raised, dripping) -->
  <path d="M136,52 Q142,44 148,46 Q154,50 150,56 Q144,60 138,57 Z" stroke-width="1.5" fill="currentColor" opacity="0.15" />
  <!-- Water drips from right paddle -->
  <line x1="142" y1="58" x2="141" y2="64" stroke-width="1" opacity="0.6" />
  <line x1="146" y1="57" x2="145" y2="63" stroke-width="1" opacity="0.6" />

  <!-- Arms -->
  <path d="M96,58 Q80,60 64,55" stroke-width="2" />
  <path d="M104,58 Q120,60 136,55" stroke-width="2" />

  <!-- Wake / water displacement -->
  <path d="M28,83 Q15,87 5,85" stroke-width="1.5" opacity="0.7" />
  <path d="M28,85 Q12,90 2,89" stroke-width="1" opacity="0.5" />
  <!-- Forward ripples -->
  <path d="M168,78 Q180,80 192,78" stroke-width="1" opacity="0.5" />
  <path d="M170,82 Q183,84 195,82" stroke-width="1" opacity="0.4" />

  <!-- Distant water reflections -->
  <path d="M10,100 Q30,97 50,100" stroke-width="1" opacity="0.4" />
  <path d="M140,99 Q160,96 180,99" stroke-width="1" opacity="0.4" />
  <path d="M160,106 Q175,103 190,106" stroke-width="1" opacity="0.3" />
</svg>
