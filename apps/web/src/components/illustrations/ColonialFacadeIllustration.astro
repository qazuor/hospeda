---
/**
 * ColonialFacadeIllustration
 *
 * Colonial building facade with arched doorway, tall windows,
 * ornamental cornice, and tiled roof hints.
 * Uses currentColor for light/dark mode compatibility.
 */
export interface ColonialFacadeIllustrationProps {
  class?: string;
}
interface Props extends ColonialFacadeIllustrationProps {}
const { class: className } = Astro.props;
---
<svg
  class:list={['illustration', className]}
  viewBox="0 0 160 180"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Ground line -->
  <line x1="8" y1="170" x2="152" y2="170" />

  <!-- Main facade rectangle -->
  <rect x="16" y="52" width="128" height="118" />

  <!-- Tiled roof (overlapping arcs suggesting tiles) -->
  <path d="M 16,52 L 8,52 L 8,30 L 152,30 L 152,52" />
  <!-- Roof ridge -->
  <line x1="8" y1="30" x2="152" y2="30" />
  <!-- Tile hints - curved lines on roof area -->
  <path d="M 16,30 Q 24,38 32,30" />
  <path d="M 32,30 Q 40,38 48,30" />
  <path d="M 48,30 Q 56,38 64,30" />
  <path d="M 64,30 Q 72,38 80,30" />
  <path d="M 80,30 Q 88,38 96,30" />
  <path d="M 96,30 Q 104,38 112,30" />
  <path d="M 112,30 Q 120,38 128,30" />
  <path d="M 128,30 Q 136,38 144,30" />
  <!-- Chimney -->
  <rect x="60" y="16" width="12" height="16" />
  <rect x="58" y="13" width="16" height="4" />
  <!-- Smoke wisps -->
  <path d="M 64,13 Q 62,8 66,4 Q 70,0 68,4" stroke-width="1.5" />
  <path d="M 70,13 Q 74,7 72,3" stroke-width="1.5" />

  <!-- Ornamental cornice -->
  <line x1="14" y1="56" x2="146" y2="56" />
  <line x1="14" y1="60" x2="146" y2="60" />
  <!-- Dentil decoration on cornice -->
  <rect x="20" y="56" width="4" height="4" />
  <rect x="30" y="56" width="4" height="4" />
  <rect x="40" y="56" width="4" height="4" />
  <rect x="50" y="56" width="4" height="4" />
  <rect x="60" y="56" width="4" height="4" />
  <rect x="70" y="56" width="4" height="4" />
  <rect x="80" y="56" width="4" height="4" />
  <rect x="90" y="56" width="4" height="4" />
  <rect x="100" y="56" width="4" height="4" />
  <rect x="110" y="56" width="4" height="4" />
  <rect x="120" y="56" width="4" height="4" />
  <rect x="130" y="56" width="4" height="4" />

  <!-- Left tall window with arch -->
  <rect x="26" y="76" width="34" height="52" rx="1" />
  <path d="M 26,76 Q 43,62 60,76" />
  <!-- Window sill -->
  <line x1="24" y1="128" x2="62" y2="128" />
  <!-- Window muntins -->
  <line x1="43" y1="76" x2="43" y2="128" />
  <line x1="26" y1="100" x2="60" y2="100" />
  <!-- Window frame decoration -->
  <rect x="24" y="74" width="38" height="56" rx="1" stroke-width="1" />

  <!-- Right tall window with arch -->
  <rect x="100" y="76" width="34" height="52" rx="1" />
  <path d="M 100,76 Q 117,62 134,76" />
  <!-- Window sill -->
  <line x1="98" y1="128" x2="136" y2="128" />
  <!-- Window muntins -->
  <line x1="117" y1="76" x2="117" y2="128" />
  <line x1="100" y1="100" x2="134" y2="100" />
  <!-- Window frame decoration -->
  <rect x="98" y="74" width="38" height="56" rx="1" stroke-width="1" />

  <!-- Central arched doorway -->
  <path d="M 58,170 L 58,130 Q 80,112 102,130 L 102,170" />
  <!-- Door arch decorative keystone -->
  <path d="M 74,116 L 80,110 L 86,116" stroke-width="1.5" />
  <!-- Door panels -->
  <line x1="80" y1="130" x2="80" y2="170" />
  <rect x="60" y="140" width="18" height="20" rx="1" />
  <rect x="82" y="140" width="18" height="20" rx="1" />
  <!-- Door knocker/knob -->
  <circle cx="77" cy="155" r="2" />
  <circle cx="83" cy="155" r="2" />

  <!-- Transom window above door -->
  <path d="M 58,130 Q 80,118 102,130" />
  <!-- Transom fan lights -->
  <line x1="80" y1="118" x2="80" y2="130" />
  <line x1="70" y1="120" x2="80" y2="130" />
  <line x1="90" y1="120" x2="80" y2="130" />

  <!-- Pilasters flanking door -->
  <line x1="54" y1="60" x2="54" y2="170" />
  <line x1="106" y1="60" x2="106" y2="170" />

  <!-- Base/plinth molding -->
  <line x1="14" y1="162" x2="146" y2="162" />
  <line x1="14" y1="166" x2="146" y2="166" />

  <!-- Small balcony railing above door -->
  <line x1="54" y1="76" x2="106" y2="76" />
  <line x1="56" y1="70" x2="56" y2="76" />
  <line x1="63" y1="70" x2="63" y2="76" />
  <line x1="70" y1="70" x2="70" y2="76" />
  <line x1="80" y1="70" x2="80" y2="76" />
  <line x1="90" y1="70" x2="90" y2="76" />
  <line x1="97" y1="70" x2="97" y2="76" />
  <line x1="104" y1="70" x2="104" y2="76" />
  <line x1="54" y1="70" x2="106" y2="70" />
</svg>
