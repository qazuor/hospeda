---
/**
 * CarnivalHeaddressIllustration
 *
 * Elaborate carnival headdress with feathered crown,
 * ornate and flowing decorative elements.
 * Uses currentColor for light/dark mode compatibility.
 */
export interface CarnivalHeaddressIllustrationProps {
  class?: string;
}
interface Props extends CarnivalHeaddressIllustrationProps {}
const { class: className } = Astro.props;
---
<svg
  class:list={['illustration', className]}
  viewBox="0 0 160 180"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Base headband / crown band -->
  <path d="M 36,142 Q 80,148 124,142 Q 128,136 124,130 Q 80,136 36,130 Q 32,136 36,142 Z" />

  <!-- Jewels on headband -->
  <circle cx="60" cy="136" r="4" />
  <circle cx="80" cy="137" r="5" />
  <circle cx="100" cy="136" r="4" />
  <!-- Small gems -->
  <circle cx="48" cy="134" r="2" />
  <circle cx="112" cy="134" r="2" />

  <!-- Central tall feather (main plume) -->
  <path d="M 80,130 Q 74,100 70,70 Q 74,50 80,20 Q 86,50 90,70 Q 86,100 80,130" />
  <!-- Central feather spine -->
  <line x1="80" y1="130" x2="80" y2="20" />
  <!-- Central feather barbs -->
  <path d="M 80,40 Q 70,36 62,38" stroke-width="1.5" />
  <path d="M 80,40 Q 90,36 98,38" stroke-width="1.5" />
  <path d="M 80,52 Q 68,46 58,48" stroke-width="1.5" />
  <path d="M 80,52 Q 92,46 102,48" stroke-width="1.5" />
  <path d="M 80,64 Q 66,58 55,60" stroke-width="1.5" />
  <path d="M 80,64 Q 94,58 105,60" stroke-width="1.5" />
  <path d="M 80,76 Q 68,72 60,74" stroke-width="1.5" />
  <path d="M 80,76 Q 92,72 100,74" stroke-width="1.5" />

  <!-- Left large feather -->
  <path d="M 76,128 Q 60,104 44,80 Q 34,60 28,34 Q 42,54 56,72 Q 66,96 76,128" />
  <line x1="76" y1="128" x2="28" y2="34" />
  <!-- Left feather barbs -->
  <path d="M 48,72 Q 42,62 36,58" stroke-width="1.5" />
  <path d="M 58,90 Q 52,82 44,80" stroke-width="1.5" />
  <path d="M 42,54 Q 36,46 32,42" stroke-width="1.5" />

  <!-- Right large feather -->
  <path d="M 84,128 Q 100,104 116,80 Q 126,60 132,34 Q 118,54 104,72 Q 94,96 84,128" />
  <line x1="84" y1="128" x2="132" y2="34" />
  <!-- Right feather barbs -->
  <path d="M 112,72 Q 118,62 124,58" stroke-width="1.5" />
  <path d="M 102,90 Q 108,82 116,80" stroke-width="1.5" />
  <path d="M 118,54 Q 124,46 128,42" stroke-width="1.5" />

  <!-- Flanking medium feathers (left) -->
  <path d="M 72,128 Q 52,112 38,90 Q 28,72 22,52 Q 36,68 50,86 Q 62,108 72,128" />
  <line x1="72" y1="128" x2="22" y2="52" />
  <path d="M 88,128 Q 108,112 122,90 Q 132,72 138,52 Q 124,68 110,86 Q 98,108 88,128" />
  <line x1="88" y1="128" x2="138" y2="52" />

  <!-- Outer sweeping feathers -->
  <path d="M 68,130 Q 42,118 22,100 Q 10,86 8,66 Q 22,80 38,96 Q 56,116 68,130" />
  <path d="M 92,130 Q 118,118 138,100 Q 150,86 152,66 Q 138,80 122,96 Q 104,116 92,130" />

  <!-- Curved ornamental side pieces -->
  <path d="M 36,132 Q 20,126 12,118 Q 8,110 12,104 Q 20,108 28,116 Q 34,124 36,132" stroke-width="1.5" />
  <path d="M 124,132 Q 140,126 148,118 Q 152,110 148,104 Q 140,108 132,116 Q 126,124 124,132" stroke-width="1.5" />

  <!-- Decorative stars/sparkles among feathers -->
  <path d="M 60,56 L 62,52 L 64,56 L 68,54 L 64,58 L 66,62 L 62,60 L 58,62 L 60,58 L 56,54 Z" stroke-width="1" />
  <path d="M 100,56 L 102,52 L 104,56 L 108,54 L 104,58 L 106,62 L 102,60 L 98,62 L 100,58 L 96,54 Z" stroke-width="1" />
  <circle cx="80" cy="16" r="3" stroke-width="1.5" />

  <!-- Sequin dots suggestion -->
  <circle cx="52" cy="104" r="1.5" />
  <circle cx="108" cy="104" r="1.5" />
  <circle cx="40" cy="88" r="1.5" />
  <circle cx="120" cy="88" r="1.5" />

  <!-- Hanging tassels from headband -->
  <line x1="42" y1="142" x2="40" y2="158" />
  <circle cx="40" cy="160" r="2" />
  <line x1="118" y1="142" x2="120" y2="158" />
  <circle cx="120" cy="160" r="2" />
  <line x1="56" y1="144" x2="54" y2="162" />
  <circle cx="54" cy="164" r="2" />
  <line x1="104" y1="144" x2="106" y2="162" />
  <circle cx="106" cy="164" r="2" />
</svg>
