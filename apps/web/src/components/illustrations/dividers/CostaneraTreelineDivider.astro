---
/**
 * Inline SVG divider with a willow treeline silhouette.
 * Depicts 4 drooping willow tree shapes along the bottom edge,
 * evoking the riverside costanera landscape of the Litoral region.
 * Positioned absolute at the bottom of a parent section.
 * Uses CSS variable for fill color to support dark mode theming.
 */
export interface CostaneraTreelineDividerProps {
  /** Fill color for light mode (dark mode uses CSS variable override) */
  fill?: string;
  class?: string;
}

interface Props extends CostaneraTreelineDividerProps {}

const { fill = 'currentColor', class: className } = Astro.props;
---

<svg
  class:list={['wave-divider h-16 sm:h-[100px]', className]}
  width="100%"
  viewBox="0 0 1440 100"
  preserveAspectRatio="none"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!--
    Willow treeline silhouette.
    Each tree: trunk rises from ground line, crown fans out with drooping branches.
    Ground baseline runs at y=100. Trees are distributed across the width.
  -->
  <path
    d="
      M0,100
      L0,85

      C30,60 10,30 60,10
      C50,28 40,46 55,55
      C65,30 80,12 110,8
      C100,25 90,45 108,58
      C115,35 130,18 155,15
      C145,30 140,52 158,62
      C165,42 178,26 195,25
      C188,38 182,56 198,65
      L200,100

      C240,90 260,82 280,78

      C300,50 285,20 330,5
      C320,22 310,44 328,54
      C335,28 352,10 378,8
      C368,26 358,48 376,60
      C384,36 400,18 425,16
      C415,32 410,54 428,64
      C436,42 450,28 470,26
      C462,40 456,58 474,68
      L480,100

      C560,88 600,80 640,76

      C660,48 645,18 695,3
      C684,20 674,44 692,54
      C700,26 718,8 745,6
      C734,24 724,48 742,60
      C750,34 768,16 793,14
      C782,30 778,52 796,62
      C804,40 820,24 842,22
      C834,38 828,56 846,68
      L850,100

      C940,88 980,80 1020,76

      C1040,46 1025,14 1080,2
      C1068,20 1058,46 1076,56
      C1084,28 1103,10 1130,7
      C1118,26 1108,50 1127,62
      C1135,36 1154,18 1180,15
      C1168,32 1164,54 1182,65
      C1190,42 1206,26 1228,24
      C1220,40 1214,58 1232,70
      L1240,100

      C1300,90 1340,84 1370,80
      C1390,60 1378,32 1410,18
      C1402,34 1396,54 1412,64
      C1420,44 1432,28 1440,26
      L1440,100
      Z
    "
    fill={fill}
    class="wave-divider-path"
  />
</svg>
