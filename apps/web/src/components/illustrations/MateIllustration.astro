---
/**
 * MateIllustration - Mate gourd with bombilla and thermos.
 * Line-art illustration using currentColor for light/dark mode compatibility.
 */
export interface MateIllustrationProps {
  /** Additional CSS classes to apply to the SVG element */
  class?: string;
}

interface Props extends MateIllustrationProps {}

const { class: className } = Astro.props;
---

<svg
  class:list={['illustration', className]}
  viewBox="0 0 120 150"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- ===== MATE GOURD (left) ===== -->

  <!-- Gourd body - rounded pear shape -->
  <path d="M22,140 Q10,138 8,122 Q6,106 12,94 Q18,82 28,80 Q38,78 44,82 Q50,86 52,94 Q54,106 52,122 Q50,138 38,140 Z"
        stroke-width="2.5" fill="currentColor" opacity="0.07" />
  <!-- Gourd body shading line -->
  <path d="M14,100 Q12,112 14,124 Q16,134 22,138" stroke-width="1" opacity="0.3" />

  <!-- Gourd neck -->
  <path d="M24,80 Q28,72 30,68 Q32,72 36,80" stroke-width="2" />

  <!-- Gourd rim / top opening -->
  <ellipse cx="30" cy="68" rx="7" ry="3" stroke-width="2" />
  <!-- Rim inner -->
  <ellipse cx="30" cy="68" rx="5" ry="2" stroke-width="1" opacity="0.5" />

  <!-- Yerba mate inside (textured fill suggestion) -->
  <path d="M25,74 Q28,76 30,74 Q32,72 35,74" stroke-width="1" opacity="0.4" />
  <path d="M24,78 Q27,80 30,78 Q33,76 36,78" stroke-width="1" opacity="0.3" />

  <!-- Decorative lines on gourd body -->
  <path d="M20,90 Q22,88 24,90 Q26,92 28,90" stroke-width="1" opacity="0.35" />
  <path d="M32,88 Q34,86 36,88 Q38,90 40,88" stroke-width="1" opacity="0.35" />
  <path d="M18,104 Q21,101 24,104" stroke-width="1" opacity="0.3" />
  <path d="M36,102 Q39,99 42,102" stroke-width="1" opacity="0.3" />

  <!-- Bottom ring/base -->
  <ellipse cx="30" cy="138" rx="12" ry="3" stroke-width="1.5" fill="currentColor" opacity="0.1" />

  <!-- ===== BOMBILLA (metal straw) ===== -->

  <!-- Bombilla shaft -->
  <line x1="30" y1="65" x2="22" y2="100" stroke-width="2.5" />
  <!-- Bombilla curved part -->
  <path d="M22,100 Q20,108 22,114" stroke-width="2.5" />
  <!-- Filter bulb at bottom -->
  <ellipse cx="22" cy="116" rx="4" ry="6" stroke-width="2" fill="currentColor" opacity="0.1" />
  <!-- Filter holes (dots) -->
  <circle cx="20" cy="114" r="0.8" fill="currentColor" />
  <circle cx="23" cy="115" r="0.8" fill="currentColor" />
  <circle cx="21" cy="118" r="0.8" fill="currentColor" />
  <circle cx="24" cy="117" r="0.8" fill="currentColor" />

  <!-- Bombilla top mouthpiece -->
  <path d="M28,65 Q30,62 32,65" stroke-width="1.5" />
  <line x1="30" y1="62" x2="30" y2="57" stroke-width="2" />
  <ellipse cx="30" cy="56" rx="3" ry="1.5" stroke-width="1.5" />

  <!-- Steam wisps from mate -->
  <path d="M26,60 Q24,55 26,50 Q28,45 26,40" stroke-width="1" opacity="0.5" stroke-dasharray="2,2" />
  <path d="M32,58 Q34,53 32,48 Q30,43 32,38" stroke-width="1" opacity="0.4" stroke-dasharray="2,2" />

  <!-- ===== THERMOS (right) ===== -->

  <!-- Thermos body -->
  <rect x="72" y="60" width="34" height="75" rx="8" stroke-width="2.5" fill="currentColor" opacity="0.07" />
  <!-- Thermos body shading -->
  <path d="M76,65 L76,130" stroke-width="1" opacity="0.2" />

  <!-- Thermos top cap -->
  <rect x="74" y="52" width="30" height="12" rx="5" stroke-width="2" fill="currentColor" opacity="0.1" />
  <!-- Cap grip lines -->
  <line x1="80" y1="54" x2="80" y2="62" stroke-width="1" opacity="0.4" />
  <line x1="84" y1="54" x2="84" y2="62" stroke-width="1" opacity="0.4" />
  <line x1="88" y1="54" x2="88" y2="62" stroke-width="1" opacity="0.4" />
  <line x1="92" y1="54" x2="92" y2="62" stroke-width="1" opacity="0.4" />
  <!-- Cap top -->
  <path d="M79,52 Q89,48 99,52" stroke-width="1.5" />

  <!-- Thermos bottom cap -->
  <rect x="74" y="132" width="30" height="6" rx="3" stroke-width="2" fill="currentColor" opacity="0.1" />

  <!-- Thermos brand band (decorative stripe) -->
  <rect x="72" y="88" width="34" height="8" rx="0" stroke-width="0" fill="currentColor" opacity="0.08" />
  <line x1="72" y1="88" x2="106" y2="88" stroke-width="1" opacity="0.5" />
  <line x1="72" y1="96" x2="106" y2="96" stroke-width="1" opacity="0.5" />

  <!-- Thermos handle suggestion -->
  <path d="M106,75 Q116,75 116,82 Q116,89 106,89" stroke-width="1.5" />

  <!-- Thermos shine highlight -->
  <path d="M78,66 Q80,64 82,66" stroke-width="1" opacity="0.4" />
  <path d="M78,70 Q81,68 83,70" stroke-width="1" opacity="0.3" />

  <!-- Surface / table line -->
  <path d="M0,142 L120,142" stroke-width="1.5" opacity="0.5" />
</svg>
