---
/**
 * BnbGardenIcon - Line-art illustration of a cozy house with garden elements.
 * Used to represent the "Bed & Breakfast" accommodation category.
 * Part of the category icons illustration system (T-013).
 */
export interface BnbGardenIconProps {
  /** Additional CSS classes for sizing or color customization */
  class?: string;
  /** Icon size in pixels (applied to both width and height) */
  size?: number;
}

interface Props extends BnbGardenIconProps {}

const { class: className, size = 48 } = Astro.props;
---

<svg
  class:list={['category-icon', className]}
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Ground / garden base -->
  <line x1="2" y1="43" x2="46" y2="43" />

  <!-- House walls -->
  <rect x="12" y="24" width="24" height="19" />

  <!-- Gabled roof -->
  <polyline points="9,24 24,10 39,24" />
  <line x1="9" y1="24" x2="39" y2="24" />

  <!-- Chimney -->
  <rect x="28" y="12" width="4" height="8" />
  <!-- Smoke curl -->
  <path d="M28,12 Q25,9 27,6 Q29,3 28,1" stroke-dasharray="1.5 1.5" />

  <!-- Front door (arched top) -->
  <path d="M20,43 L20,32 Q24,28 28,32 L28,43" />
  <!-- Door knocker -->
  <circle cx="25.5" cy="37" r="1" />

  <!-- Left window -->
  <rect x="13" y="26" width="6" height="5" />
  <line x1="16" y1="26" x2="16" y2="31" />
  <line x1="13" y1="28.5" x2="19" y2="28.5" />
  <!-- Window flower box -->
  <rect x="13" y="31" width="6" height="2" rx="0.5" />
  <!-- Flowers in box -->
  <line x1="15" y1="31" x2="15" y2="29.5" />
  <circle cx="15" cy="29.5" r="1" />
  <line x1="17" y1="31" x2="17" y2="29" />
  <circle cx="17" cy="29" r="1" />
  <line x1="19" y1="31" x2="19" y2="29.5" />
  <circle cx="19" cy="29.5" r="1" />

  <!-- Right window -->
  <rect x="29" y="26" width="6" height="5" />
  <line x1="32" y1="26" x2="32" y2="31" />
  <line x1="29" y1="28.5" x2="35" y2="28.5" />
  <!-- Window flower box -->
  <rect x="29" y="31" width="6" height="2" rx="0.5" />
  <!-- Flowers in box -->
  <line x1="31" y1="31" x2="31" y2="29.5" />
  <circle cx="31" cy="29.5" r="1" />
  <line x1="33" y1="31" x2="33" y2="29" />
  <circle cx="33" cy="29" r="1" />
  <line x1="35" y1="31" x2="35" y2="29.5" />
  <circle cx="35" cy="29.5" r="1" />

  <!-- Garden path (stone pavers) -->
  <ellipse cx="24" cy="45" rx="2.5" ry="1" />
  <ellipse cx="24" cy="47" rx="2" ry="0.8" />

  <!-- Left garden bush -->
  <path d="M4,43 Q4,37 8,37 Q12,37 12,43" />
  <path d="M5,41 Q5,36 8,36 Q10,36 11,38" />

  <!-- Right garden bush -->
  <path d="M36,43 Q36,37 40,37 Q44,37 44,43" />
  <path d="M37,41 Q37,36 40,36 Q42,36 43,38" />

  <!-- Small flowers in garden left -->
  <line x1="6" y1="43" x2="6" y2="40" />
  <circle cx="6" cy="39.5" r="1.2" />

  <!-- Small flowers in garden right -->
  <line x1="42" y1="43" x2="42" y2="40" />
  <circle cx="42" cy="39.5" r="1.2" />

  <!-- Fence left -->
  <line x1="2" y1="43" x2="12" y2="43" />
  <line x1="3" y1="40" x2="3" y2="43" />
  <line x1="5.5" y1="40" x2="5.5" y2="43" />
  <line x1="8" y1="40" x2="8" y2="43" />
  <line x1="10.5" y1="40" x2="10.5" y2="43" />

  <!-- Fence right -->
  <line x1="36" y1="43" x2="46" y2="43" />
  <line x1="37.5" y1="40" x2="37.5" y2="43" />
  <line x1="40" y1="40" x2="40" y2="43" />
  <line x1="42.5" y1="40" x2="42.5" y2="43" />
  <line x1="45" y1="40" x2="45" y2="43" />
</svg>
