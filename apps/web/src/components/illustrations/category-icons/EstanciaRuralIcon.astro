---
/**
 * EstanciaRuralIcon - Line-art illustration of a rural estancia with a corral fence.
 * Used to represent the "Estancia Rural" accommodation category.
 * Part of the category icons illustration system (T-013).
 */
export interface EstanciaRuralIconProps {
  /** Additional CSS classes for sizing or color customization */
  class?: string;
  /** Icon size in pixels (applied to both width and height) */
  size?: number;
}

interface Props extends EstanciaRuralIconProps {}

const { class: className, size = 48 } = Astro.props;
---

<svg
  class:list={['category-icon', className]}
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Ground line -->
  <line x1="2" y1="42" x2="46" y2="42" />

  <!-- === Main house === -->
  <!-- Walls -->
  <rect x="14" y="24" width="20" height="18" />

  <!-- Low-pitched hip roof -->
  <polyline points="12,24 24,14 36,24" />
  <line x1="12" y1="24" x2="36" y2="24" />

  <!-- Roof tile lines (horizontal) -->
  <line x1="15" y1="20" x2="33" y2="20" />
  <line x1="13" y1="22.5" x2="35" y2="22.5" />

  <!-- Chimney -->
  <rect x="29" y="15" width="3" height="6" />

  <!-- Door (arched) -->
  <path d="M20,42 L20,33 Q24,29.5 28,33 L28,42" />

  <!-- Left window -->
  <rect x="15" y="26" width="4" height="4" />
  <line x1="17" y1="26" x2="17" y2="30" />

  <!-- Right window -->
  <rect x="29" y="26" width="4" height="4" />
  <line x1="31" y1="26" x2="31" y2="30" />

  <!-- === Corral fence (U-shape around right side) === -->
  <!-- Left fence post + rail going right -->
  <line x1="36" y1="30" x2="46" y2="30" />
  <line x1="36" y1="36" x2="46" y2="36" />
  <!-- Fence posts along top rail -->
  <line x1="38" y1="28" x2="38" y2="38" />
  <line x1="41" y1="28" x2="41" y2="38" />
  <line x1="44" y1="28" x2="44" y2="38" />
  <!-- Right vertical post -->
  <line x1="46" y1="28" x2="46" y2="42" />
  <!-- Bottom connecting rail to ground -->
  <line x1="36" y1="38" x2="46" y2="38" />

  <!-- === Left alamo / eucalyptus tree === -->
  <!-- Tall narrow trunk -->
  <line x1="7" y1="42" x2="7" y2="10" />
  <!-- Narrow oval canopy -->
  <ellipse cx="7" cy="12" rx="3" ry="6" />
  <!-- Foliage texture lines -->
  <line x1="5" y1="12" x2="9" y2="12" />
  <line x1="5" y1="9" x2="9" y2="9" />
  <line x1="5.5" y1="15" x2="8.5" y2="15" />

  <!-- === Rolling hills in background === -->
  <path d="M2,34 Q8,28 14,34" />
  <path d="M34,32 Q40,25 46,32" />

  <!-- Weather vane on roof peak -->
  <line x1="24" y1="14" x2="24" y2="10" />
  <!-- Arrow -->
  <polyline points="24,10 27,11.5 24,13 21,11.5 24,10" />
  <!-- Cardinal point N -->
  <line x1="24" y1="8" x2="24" y2="6" />
</svg>
