---
/**
 * HotelColonialIcon - Line-art illustration of a colonial building with arches.
 * Used to represent the "Hotel" accommodation category.
 * Part of the category icons illustration system (T-013).
 */
export interface HotelColonialIconProps {
  /** Additional CSS classes for sizing or color customization */
  class?: string;
  /** Icon size in pixels (applied to both width and height) */
  size?: number;
}

interface Props extends HotelColonialIconProps {}

const { class: className, size = 48 } = Astro.props;
---

<svg
  class:list={['category-icon', className]}
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Ground line -->
  <line x1="4" y1="42" x2="44" y2="42" />

  <!-- Main building body -->
  <rect x="8" y="18" width="32" height="24" />

  <!-- Roof / pediment -->
  <polyline points="5,18 24,6 43,18" />

  <!-- Roof ridge cap -->
  <line x1="5" y1="18" x2="43" y2="18" />

  <!-- Central door (tall arch) -->
  <path d="M20,42 L20,30 Q24,25 28,30 L28,42" />

  <!-- Left arch window -->
  <path d="M10,36 L10,28 Q13.5,23.5 17,28 L17,36" />

  <!-- Right arch window -->
  <path d="M31,36 L31,28 Q34.5,23.5 38,28 L38,36" />

  <!-- Keystone accents on arches (small triangles at apex) -->
  <line x1="13.5" y1="24" x2="13.5" y2="26" />
  <line x1="24" y1="25" x2="24" y2="27.5" />
  <line x1="34.5" y1="24" x2="34.5" y2="26" />

  <!-- Cornice line between roof and arches -->
  <line x1="8" y1="24" x2="40" y2="24" />

  <!-- Chimney left -->
  <rect x="11" y="8" width="3" height="6" />

  <!-- Chimney right -->
  <rect x="34" y="8" width="3" height="6" />

  <!-- Flag pole at peak -->
  <line x1="24" y1="6" x2="24" y2="3" />
  <polyline points="24,3 28,4.5 24,6" />
</svg>
