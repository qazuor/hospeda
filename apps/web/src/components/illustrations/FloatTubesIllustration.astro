---
/**
 * FloatTubesIllustration - Float tubes (inflatable rings) on river water.
 * Line-art illustration using currentColor for light/dark mode compatibility.
 */
export interface FloatTubesIllustrationProps {
  /** Additional CSS classes to apply to the SVG element */
  class?: string;
}

interface Props extends FloatTubesIllustrationProps {}

const { class: className } = Astro.props;
---

<svg
  class:list={['illustration', className]}
  viewBox="0 0 180 120"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Distant bank silhouette -->
  <path d="M0,28 Q45,22 90,25 Q135,22 180,28" stroke-width="1.5" opacity="0.4" />
  <!-- Distant vegetation -->
  <path d="M10,28 Q14,20 18,28" stroke-width="1" opacity="0.35" />
  <path d="M28,26 Q32,18 36,26" stroke-width="1" opacity="0.35" />
  <path d="M55,24 Q58,17 62,24" stroke-width="1" opacity="0.35" />
  <path d="M115,23 Q119,16 123,23" stroke-width="1" opacity="0.35" />
  <path d="M140,25 Q143,18 147,25" stroke-width="1" opacity="0.35" />
  <path d="M162,27 Q165,21 168,27" stroke-width="1" opacity="0.35" />

  <!-- Water surface -->
  <path d="M0,32 Q45,28 90,32 Q135,36 180,32" stroke-width="1.5" />

  <!-- Water fill -->
  <rect x="0" y="32" width="180" height="88" fill="currentColor" opacity="0.04" stroke="none" />

  <!-- Background water ripples -->
  <path d="M0,42 Q30,38 60,42 Q90,46 120,42 Q150,38 180,42" stroke-width="1" opacity="0.5" />
  <path d="M0,54 Q35,50 70,54 Q105,58 140,54 Q160,52 180,54" stroke-width="1" opacity="0.4" />
  <path d="M0,68 Q40,64 80,68 Q110,71 140,68 Q160,66 180,68" stroke-width="1" opacity="0.35" />
  <path d="M0,84 Q45,80 90,84 Q125,87 155,84 Q167,83 180,84" stroke-width="1" opacity="0.3" />
  <path d="M0,98 Q50,94 100,98 Q130,101 160,98 Q170,97 180,98" stroke-width="1" opacity="0.25" />

  <!-- ===== FLOAT TUBE 1 - left, slightly tilted ===== -->
  <!-- Outer ring -->
  <ellipse cx="42" cy="72" rx="28" ry="18" stroke-width="2.5" fill="currentColor" opacity="0.06" />
  <!-- Inner hole -->
  <ellipse cx="42" cy="72" rx="14" ry="9" stroke-width="2" />
  <!-- Inner hole fill (darker, water visible) -->
  <ellipse cx="42" cy="72" rx="13" ry="8" fill="currentColor" opacity="0.04" stroke="none" />
  <!-- Tube segments (valve bumps) -->
  <path d="M14,72 Q14,68 16,68" stroke-width="1.5" />
  <path d="M70,72 Q70,68 68,68" stroke-width="1.5" />
  <!-- Tube grip handles -->
  <path d="M30,58 Q32,54 38,56" stroke-width="1.5" />
  <path d="M46,56 Q52,54 54,58" stroke-width="1.5" />
  <!-- Arm of person in tube -->
  <path d="M28,70 Q22,66 18,62" stroke-width="2" />
  <path d="M56,70 Q62,66 66,62" stroke-width="2" />
  <!-- Hands gripping -->
  <path d="M17,62 Q16,60 18,59 Q20,60 20,62" stroke-width="1.5" />
  <path d="M66,62 Q65,60 67,59 Q69,60 68,62" stroke-width="1.5" />
  <!-- Person head -->
  <circle cx="42" cy="56" r="8" stroke-width="2" fill="currentColor" opacity="0.08" />
  <!-- Hat or sunglasses -->
  <path d="M34,54 Q42,49 50,54" stroke-width="1.5" fill="currentColor" opacity="0.1" />
  <!-- Smile -->
  <path d="M39,57 Q42,60 45,57" stroke-width="1" />
  <!-- Legs dangling in water (shown faintly) -->
  <path d="M38,80 Q36,88 34,94" stroke-width="1.5" opacity="0.4" />
  <path d="M46,80 Q48,88 50,94" stroke-width="1.5" opacity="0.4" />
  <!-- Water shadow around tube -->
  <ellipse cx="42" cy="80" rx="30" ry="6" stroke-width="1" opacity="0.3" fill="currentColor" opacity="0.04" />

  <!-- ===== FLOAT TUBE 2 - center, more frontal ===== -->
  <!-- Outer ring -->
  <ellipse cx="100" cy="65" rx="24" ry="16" stroke-width="2.5" fill="currentColor" opacity="0.06" />
  <!-- Inner hole -->
  <ellipse cx="100" cy="65" rx="12" ry="7" stroke-width="2" />
  <!-- Tube surface detail (stripe) -->
  <path d="M76,68 Q100,72 124,68" stroke-width="1" opacity="0.35" />
  <path d="M78,63 Q100,60 122,63" stroke-width="1" opacity="0.3" />
  <!-- Person's head from tube -->
  <circle cx="100" cy="51" r="8" stroke-width="2" fill="currentColor" opacity="0.08" />
  <!-- Sunglasses (cool look) -->
  <path d="M94,50 Q96,48 98,50 Q98,53 96,53 Q94,53 94,50 Z" stroke-width="1" />
  <path d="M98,50 L102,50" stroke-width="1" />
  <path d="M102,50 Q104,48 106,50 Q106,53 104,53 Q102,53 102,50 Z" stroke-width="1" />
  <line x1="94" y1="50" x2="91" y2="51" stroke-width="1" />
  <line x1="106" y1="50" x2="109" y2="51" stroke-width="1" />
  <!-- Shoulder / arms resting on tube edge -->
  <path d="M88,58 Q86,62 84,66" stroke-width="2" />
  <path d="M112,58 Q114,62 116,66" stroke-width="2" />
  <!-- Hands trailing in water -->
  <path d="M83,66 Q80,70 78,73" stroke-width="1.5" opacity="0.6" />
  <path d="M117,66 Q120,70 122,73" stroke-width="1.5" opacity="0.6" />
  <!-- Water circle around tube -->
  <ellipse cx="100" cy="73" rx="26" ry="5" stroke-width="1" opacity="0.35" />

  <!-- ===== FLOAT TUBE 3 - right, partial/background ===== -->
  <!-- Outer ring (slightly behind, smaller) -->
  <ellipse cx="152" cy="75" rx="22" ry="14" stroke-width="2" fill="currentColor" opacity="0.05" />
  <!-- Inner hole -->
  <ellipse cx="152" cy="75" rx="11" ry="6" stroke-width="1.5" />
  <!-- Person head (partially behind tube 2) -->
  <circle cx="152" cy="63" r="7" stroke-width="2" fill="currentColor" opacity="0.08" />
  <!-- Simple face -->
  <circle cx="149" cy="62" r="1" fill="currentColor" opacity="0.4" />
  <circle cx="155" cy="62" r="1" fill="currentColor" opacity="0.4" />
  <path d="M149,65 Q152,67 155,65" stroke-width="1" />
  <!-- Arm gesturing / waving -->
  <path d="M160,70 Q168,62 170,56" stroke-width="2" />
  <path d="M168,57 Q171,54 170,58" stroke-width="1.5" />
  <!-- Other arm in water -->
  <path d="M144,70 Q138,72 134,76" stroke-width="1.5" opacity="0.6" />
  <!-- Water ripples from tubes interacting -->
  <path d="M125,72 Q138,68 152,72" stroke-width="1" opacity="0.35" />

  <!-- General splashes and play -->
  <path d="M62,52 Q65,48 68,52" stroke-width="1" opacity="0.5" />
  <path d="M118,48 Q121,44 124,48" stroke-width="1" opacity="0.5" />
  <!-- Droplet dots -->
  <circle cx="70" cy="49" r="1" fill="currentColor" opacity="0.4" />
  <circle cx="110" cy="46" r="1" fill="currentColor" opacity="0.4" />
  <circle cx="165" cy="55" r="1" fill="currentColor" opacity="0.4" />
</svg>
