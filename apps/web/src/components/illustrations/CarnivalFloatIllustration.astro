---
/**
 * CarnivalFloatIllustration
 *
 * Carnival float (carroza) - decorated platform on wheels
 * with feathers, stars and festive ornaments.
 * Uses currentColor for light/dark mode compatibility.
 */
export interface CarnivalFloatIllustrationProps {
  class?: string;
}
interface Props extends CarnivalFloatIllustrationProps {}
const { class: className } = Astro.props;
---
<svg
  class:list={['illustration', className]}
  viewBox="0 0 240 150"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Ground line -->
  <line x1="6" y1="132" x2="234" y2="132" />

  <!-- === WHEELS === -->
  <!-- Front wheel -->
  <circle cx="52" cy="122" r="20" />
  <!-- Front wheel spokes -->
  <line x1="52" y1="102" x2="52" y2="142" />
  <line x1="32" y1="122" x2="72" y2="122" />
  <line x1="38" y1="108" x2="66" y2="136" />
  <line x1="66" y1="108" x2="38" y2="136" />
  <!-- Front wheel hub -->
  <circle cx="52" cy="122" r="4" />
  <!-- Front wheel decorative outer ring -->
  <circle cx="52" cy="122" r="17" stroke-width="1" />

  <!-- Rear wheel -->
  <circle cx="188" cy="122" r="20" />
  <!-- Rear wheel spokes -->
  <line x1="188" y1="102" x2="188" y2="142" />
  <line x1="168" y1="122" x2="208" y2="122" />
  <line x1="174" y1="108" x2="202" y2="136" />
  <line x1="202" y1="108" x2="174" y2="136" />
  <!-- Rear wheel hub -->
  <circle cx="188" cy="122" r="4" />
  <!-- Rear wheel decorative outer ring -->
  <circle cx="188" cy="122" r="17" stroke-width="1" />

  <!-- === FLOAT CHASSIS / PLATFORM BASE === -->
  <!-- Main platform deck -->
  <rect x="30" y="94" width="180" height="14" rx="2" />
  <!-- Decorative panel below platform -->
  <rect x="36" y="108" width="168" height="10" rx="2" />

  <!-- Decorative diamond pattern on side panel -->
  <path d="M 46,113 L 56,108 L 66,113 L 56,118 Z" stroke-width="1" />
  <path d="M 76,113 L 86,108 L 96,113 L 86,118 Z" stroke-width="1" />
  <path d="M 106,113 L 116,108 L 126,113 L 116,118 Z" stroke-width="1" />
  <path d="M 136,113 L 146,108 L 156,113 L 146,118 Z" stroke-width="1" />
  <path d="M 166,113 L 176,108 L 186,113 L 176,118 Z" stroke-width="1" />

  <!-- === FLOAT STRUCTURE / TOWER === -->
  <!-- Central tower column left -->
  <line x1="96" y1="94" x2="96" y2="40" />
  <!-- Central tower column right -->
  <line x1="144" y1="94" x2="144" y2="40" />
  <!-- Tower cross beams -->
  <line x1="96" y1="70" x2="144" y2="70" />
  <line x1="96" y1="56" x2="144" y2="56" />
  <!-- Tower top arch -->
  <path d="M 96,40 Q 120,22 144,40" />
  <!-- Tower top platform -->
  <rect x="88" y="36" width="64" height="8" rx="1" />

  <!-- Lateral side wings of float structure -->
  <line x1="36" y1="94" x2="36" y2="64" />
  <line x1="60" y1="94" x2="60" y2="64" />
  <line x1="36" y1="64" x2="60" y2="64" />
  <path d="M 36,64 Q 48,52 60,64" />

  <line x1="180" y1="94" x2="180" y2="64" />
  <line x1="204" y1="94" x2="204" y2="64" />
  <line x1="180" y1="64" x2="204" y2="64" />
  <path d="M 180,64 Q 192,52 204,64" />

  <!-- === FEATHER DECORATIONS === -->
  <!-- Large center feathers from top arch -->
  <!-- Central feather -->
  <path d="M 120,36 Q 114,18 110,8 Q 116,16 120,14 Q 124,16 130,8 Q 126,18 120,36" />
  <line x1="120" y1="36" x2="120" y2="8" />

  <!-- Flanking feathers on top -->
  <path d="M 108,38 Q 100,22 96,12 Q 102,20 106,18 Q 108,20 112,12 Q 108,24 108,38" />
  <line x1="108" y1="38" x2="108" y2="14" />
  <path d="M 132,38 Q 140,22 144,12 Q 138,20 134,18 Q 132,20 128,12 Q 132,24 132,38" />
  <line x1="132" y1="38" x2="132" y2="14" />

  <!-- Outer tall feathers on center tower -->
  <path d="M 100,42 Q 88,30 84,16 Q 90,26 96,24 Q 98,28 100,42" />
  <path d="M 140,42 Q 152,30 156,16 Q 150,26 144,24 Q 142,28 140,42" />

  <!-- Side wing feathers (left) -->
  <path d="M 42,62 Q 36,46 32,34 Q 38,44 44,42 Q 48,46 42,62" />
  <path d="M 52,62 Q 52,46 54,34 Q 56,44 58,42 Q 60,46 52,62" />

  <!-- Side wing feathers (right) -->
  <path d="M 186,62 Q 180,46 176,34 Q 182,44 188,42 Q 192,46 186,62" />
  <path d="M 196,62 Q 196,46 198,34 Q 200,44 202,42 Q 204,46 196,62" />

  <!-- === STARS / SPARKLES DECORATION === -->
  <!-- Large star center -->
  <path d="M 120,62 L 122,56 L 128,60 L 122,64 L 124,70 L 120,66 L 116,70 L 118,64 L 112,60 L 118,56 Z" stroke-width="1.5" />

  <!-- Small stars scattered on float -->
  <path d="M 70,76 L 71.5,72 L 76,74 L 71.5,76 L 73,80 L 70,78 L 67,80 L 68.5,76 L 64,74 L 68.5,72 Z" stroke-width="1" />
  <path d="M 170,76 L 171.5,72 L 176,74 L 171.5,76 L 173,80 L 170,78 L 167,80 L 168.5,76 L 164,74 L 168.5,72 Z" stroke-width="1" />

  <!-- Star sparkles in sky -->
  <path d="M 24,36 L 25,32 L 26,36 L 30,37 L 26,38 L 25,42 L 24,38 L 20,37 Z" stroke-width="1" />
  <path d="M 212,28 L 213,24 L 214,28 L 218,29 L 214,30 L 213,34 L 212,30 L 208,29 Z" stroke-width="1" />
  <path d="M 14,56 L 15,53 L 16,56 L 19,56.5 L 16,57 L 15,60 L 14,57 L 11,56.5 Z" stroke-width="1" />
  <path d="M 222,52 L 223,49 L 224,52 L 227,52.5 L 224,53 L 223,56 L 222,53 L 219,52.5 Z" stroke-width="1" />

  <!-- Confetti / circular decorations -->
  <circle cx="76" cy="90" r="3" stroke-width="1.5" />
  <circle cx="164" cy="90" r="3" stroke-width="1.5" />
  <circle cx="120" cy="78" r="2.5" stroke-width="1.5" />

  <!-- Streamers/ribbons hanging from platform -->
  <path d="M 50" y1="108" x2="46" d="M 50,108 Q 48,116 52,124 Q 48,128 50,132" stroke-width="1" />
  <path d="M 80,108 Q 82,116 78,124 Q 80,128 78,132" stroke-width="1" />
  <path d="M 160,108 Q 158,116 162,124 Q 160,128 162,132" stroke-width="1" />
  <path d="M 190,108 Q 192,116 188,124 Q 190,128 188,132" stroke-width="1" />

  <!-- Float front decorative face/mask motif -->
  <!-- Stylized sun face on front -->
  <circle cx="44" cy="78" r="8" stroke-width="1.5" />
  <path d="M 40,76 Q 42,78 40,80" stroke-width="1" />
  <path d="M 44,74 L 44,72" stroke-width="1.5" />
  <path d="M 44,82 L 44,84" stroke-width="1.5" />
  <path d="M 38,78 L 36,78" stroke-width="1.5" />
  <path d="M 50,78 L 52,78" stroke-width="1.5" />
  <path d="M 39,73 L 38,72" stroke-width="1.5" />
  <path d="M 49,73 L 50,72" stroke-width="1.5" />
  <path d="M 39,83 L 38,84" stroke-width="1.5" />
  <path d="M 49,83 L 50,84" stroke-width="1.5" />
</svg>
