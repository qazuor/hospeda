---
/**
 * ComparsaDancerIllustration
 *
 * Carnival dancer in dynamic motion with flowing costume.
 * Shows a figure mid-dance with outstretched arms and skirt in motion.
 * Uses currentColor for light/dark mode compatibility.
 */
export interface ComparsaDancerIllustrationProps {
  class?: string;
}
interface Props extends ComparsaDancerIllustrationProps {}
const { class: className } = Astro.props;
---
<svg
  class:list={['illustration', className]}
  viewBox="0 0 150 200"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Head -->
  <circle cx="76" cy="28" r="14" />

  <!-- Hair up in bun with decoration -->
  <path d="M 66,20 Q 70,10 76,8 Q 82,10 86,20" stroke-width="1.5" />
  <circle cx="76" cy="8" r="4" />
  <!-- Hair accessories / floral pin -->
  <path d="M 72,6 Q 76,2 80,6 Q 76,8 72,6 Z" stroke-width="1" />

  <!-- Facial features (simple) -->
  <path d="M 71,30 Q 73,32 76,31 Q 79,32 81,30" stroke-width="1.5" />
  <circle cx="72" cy="26" r="1.5" />
  <circle cx="80" cy="26" r="1.5" />

  <!-- Earrings -->
  <circle cx="62" cy="30" r="2" />
  <line x1="62" y1="32" x2="62" y2="37" />
  <circle cx="62" cy="38" r="2.5" />

  <!-- Neck -->
  <line x1="72" y1="42" x2="70" y2="52" />
  <line x1="80" y1="42" x2="82" y2="52" />

  <!-- Necklace -->
  <path d="M 68,50 Q 76,56 84,50" stroke-width="1.5" />
  <circle cx="76" cy="56" r="2" />

  <!-- Torso / fitted bodice -->
  <path d="M 62,52 Q 58,60 60,72 Q 64,80 76,82 Q 88,80 92,72 Q 94,60 90,52 Q 84,48 76,48 Q 68,48 62,52 Z" />
  <!-- Bodice decorative lines -->
  <path d="M 68,54 Q 72,58 76,56 Q 80,58 84,54" stroke-width="1" />
  <path d="M 66,64 Q 70,68 76,66 Q 82,68 86,64" stroke-width="1" />

  <!-- Right arm raised and extended with flow -->
  <path d="M 90,56 Q 102,48 116,38 Q 122,34 128,36" stroke-width="2" />
  <!-- Right hand with fanned fingers -->
  <path d="M 128,36 Q 132,32 134,28" stroke-width="1.5" />
  <path d="M 128,36 Q 134,34 138,32" stroke-width="1.5" />
  <path d="M 128,36 Q 134,38 136,36" stroke-width="1.5" />
  <!-- Wrist bracelet -->
  <ellipse cx="122" cy="39" rx="4" ry="3" stroke-width="1.5" />

  <!-- Left arm extended downward/sideward (dance pose) -->
  <path d="M 62,56 Q 48,62 34,74 Q 28,80 24,86" stroke-width="2" />
  <!-- Left hand -->
  <path d="M 24,86 Q 18,88 16,92" stroke-width="1.5" />
  <path d="M 24,86 Q 20,92 18,96" stroke-width="1.5" />
  <path d="M 24,86 Q 26,92 24,96" stroke-width="1.5" />
  <!-- Wrist bracelet -->
  <ellipse cx="30" cy="81" rx="4" ry="3" stroke-width="1.5" />

  <!-- Flowing skirt - multi-layered with motion -->
  <!-- Skirt waistband -->
  <path d="M 58,80 Q 76,84 94,80" />

  <!-- Skirt first layer (flared outward, motion to right) -->
  <path d="M 58,80 Q 40,100 30,120 Q 28,134 36,140 Q 52,144 68,136 Q 74,120 76,106 Q 78,120 82,136 Q 92,148 110,142 Q 118,136 114,120 Q 106,100 94,80" />

  <!-- Skirt inner layers / ruffles -->
  <path d="M 60,86 Q 44,104 36,122 Q 34,130 40,134" stroke-width="1" />
  <path d="M 92,86 Q 108,104 114,122 Q 116,130 110,134" stroke-width="1" />

  <!-- Skirt ruffle tier 1 -->
  <path d="M 44,106 Q 52,100 62,104 Q 72,100 80,104 Q 88,100 98,106" stroke-width="1.5" />

  <!-- Skirt ruffle tier 2 -->
  <path d="M 34,124 Q 46,118 58,122 Q 68,118 76,122 Q 84,118 94,122 Q 106,118 116,124" stroke-width="1.5" />

  <!-- Skirt hem decoration dots -->
  <circle cx="38" cy="136" r="1.5" />
  <circle cx="50" cy="140" r="1.5" />
  <circle cx="62" cy="142" r="1.5" />
  <circle cx="74" cy="143" r="1.5" />
  <circle cx="86" cy="142" r="1.5" />
  <circle cx="98" cy="140" r="1.5" />
  <circle cx="110" cy="136" r="1.5" />

  <!-- Left leg raised (dancing step) -->
  <path d="M 65,136 Q 60,152 52,162 Q 48,170 46,178" />
  <!-- Left foot with heel -->
  <path d="M 46,178 Q 42,182 36,180 Q 34,178 38,176" />
  <line x1="46" y1="178" x2="50" y2="182" />

  <!-- Right leg (standing/planted) -->
  <path d="M 82,138 Q 86,154 88,168 Q 88,176 88,186" />
  <!-- Right foot -->
  <path d="M 88,186 Q 92,192 100,190 Q 104,188 102,184" />
  <line x1="88" y1="186" x2="84" y2="190" />

  <!-- Flowing fabric trails from arms (scarves) -->
  <path d="M 116,38 Q 124,30 130,20 Q 134,14 138,10" stroke-width="1" stroke-dasharray="3,2" />
  <path d="M 118,42 Q 128,36 136,28" stroke-width="1" stroke-dasharray="3,2" />

  <!-- Sparkles/sequins around costume -->
  <path d="M 50,72 L 52,70 L 54,72 L 52,74 Z" stroke-width="1" />
  <path d="M 96,68 L 98,66 L 100,68 L 98,70 Z" stroke-width="1" />
  <path d="M 32,98 L 34,96 L 36,98 L 34,100 Z" stroke-width="1" />
  <path d="M 118,98 L 120,96 L 122,98 L 120,100 Z" stroke-width="1" />
</svg>
