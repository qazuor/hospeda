---
/**
 * ArtGalleryIllustration
 *
 * Art gallery interior with picture frames on wall,
 * a small figure viewing art, and a gallery arch.
 * Uses currentColor for light/dark mode compatibility.
 */
export interface ArtGalleryIllustrationProps {
  class?: string;
}
interface Props extends ArtGalleryIllustrationProps {}
const { class: className } = Astro.props;
---
<svg
  class:list={['illustration', className]}
  viewBox="0 0 200 150"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Floor line -->
  <line x1="10" y1="128" x2="190" y2="128" />

  <!-- Back wall -->
  <line x1="20" y1="20" x2="180" y2="20" />
  <!-- Wall side lines (perspective) -->
  <line x1="10" y1="128" x2="20" y2="20" />
  <line x1="190" y1="128" x2="180" y2="20" />

  <!-- Gallery arch opening (center back wall) -->
  <path d="M 82,128 L 82,72 Q 100,54 118,72 L 118,128" />

  <!-- Arch decorative molding -->
  <path d="M 78,74 Q 100,52 122,74" stroke-width="1.5" />
  <path d="M 80,76 Q 100,56 120,76" stroke-width="1" />

  <!-- Through arch: hint of another room -->
  <line x1="88" y1="128" x2="88" y2="80" />
  <line x1="112" y1="128" x2="112" y2="80" />
  <path d="M 88,80 Q 100,68 112,80" stroke-width="1" />

  <!-- Picture rail molding on wall -->
  <line x1="20" y1="38" x2="180" y2="38" />

  <!-- Left large painting frame -->
  <rect x="24" y="44" width="44" height="56" rx="1" />
  <!-- Inner frame -->
  <rect x="28" y="48" width="36" height="48" rx="1" stroke-width="1" />
  <!-- Abstract painting content - landscape hint -->
  <path d="M 30,82 Q 38,70 46,75 Q 54,68 62,78" stroke-width="1.5" />
  <path d="M 30,88 Q 38,84 46,86 Q 54,84 62,88" stroke-width="1" />
  <!-- Sun/circle in painting -->
  <circle cx="54" cy="56" r="5" stroke-width="1.5" />

  <!-- Hanging wire for left painting -->
  <line x1="46" y1="38" x2="46" y2="44" />

  <!-- Center painting (above arch) -->
  <rect x="74" y="24" width="52" height="30" rx="1" />
  <rect x="78" y="27" width="44" height="24" rx="1" stroke-width="1" />
  <!-- Abstract geometric in center painting -->
  <polygon points="100,30 110,44 90,44" stroke-width="1.5" />
  <circle cx="100" cy="37" r="4" stroke-width="1" />

  <!-- Hanging wire for center painting -->
  <line x1="100" y1="20" x2="100" y2="24" />

  <!-- Right large painting frame -->
  <rect x="132" y="44" width="44" height="56" rx="1" />
  <!-- Inner frame -->
  <rect x="136" y="48" width="36" height="48" rx="1" stroke-width="1" />
  <!-- Portrait content hint - face oval -->
  <ellipse cx="154" cy="64" rx="10" ry="13" stroke-width="1.5" />
  <!-- Body hint below portrait -->
  <path d="M 144,80 Q 154,76 164,80 L 168,96 L 140,96 Z" stroke-width="1" />

  <!-- Hanging wire for right painting -->
  <line x1="154" y1="38" x2="154" y2="44" />

  <!-- Small figure viewing left painting -->
  <!-- Head -->
  <circle cx="76" cy="100" r="5" />
  <!-- Body -->
  <line x1="76" y1="105" x2="76" y2="120" />
  <!-- Arms - one raised toward painting -->
  <line x1="76" y1="110" x2="82" y2="106" />
  <line x1="76" y1="110" x2="70" y2="114" />
  <!-- Legs -->
  <line x1="76" y1="120" x2="72" y2="128" />
  <line x1="76" y1="120" x2="80" y2="128" />

  <!-- Floor perspective lines -->
  <line x1="20" y1="128" x2="100" y2="138" stroke-width="1" stroke-dasharray="4,3" />
  <line x1="180" y1="128" x2="100" y2="138" stroke-width="1" stroke-dasharray="4,3" />

  <!-- Spotlight circles on paintings (ceiling lights effect) -->
  <circle cx="46" cy="44" r="3" stroke-width="1" />
  <circle cx="154" cy="44" r="3" stroke-width="1" />

  <!-- Bench/pedestal for sculpture (right side) -->
  <rect x="158" y="112" width="22" height="16" rx="1" />
  <!-- Small sculpture on pedestal - abstract form -->
  <path d="M 165,112 Q 162,104 169,100 Q 176,104 173,112" stroke-width="1.5" />

  <!-- Museum label placards below paintings -->
  <rect x="36" y="102" width="20" height="6" rx="1" stroke-width="1" />
  <rect x="142" y="102" width="20" height="6" rx="1" stroke-width="1" />
</svg>
