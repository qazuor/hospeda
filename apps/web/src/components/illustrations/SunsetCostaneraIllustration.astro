---
/**
 * SunsetCostaneraIllustration - Sunset over the costanera with bench and tree.
 * Line-art illustration using currentColor for light/dark mode compatibility.
 */
export interface SunsetCostaneraIllustrationProps {
  /** Additional CSS classes to apply to the SVG element */
  class?: string;
}

interface Props extends SunsetCostaneraIllustrationProps {}

const { class: className } = Astro.props;
---

<svg
  class:list={['illustration', className]}
  viewBox="0 0 200 150"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Sun (large circle, partially below horizon) -->
  <circle cx="100" cy="85" r="28" stroke-width="2" fill="currentColor" opacity="0.08" />
  <!-- Sun inner glow ring -->
  <circle cx="100" cy="85" r="22" stroke-width="1" opacity="0.15" />

  <!-- Sun rays -->
  <line x1="100" y1="52" x2="100" y2="45" stroke-width="1.5" opacity="0.6" />
  <line x1="120" y1="57" x2="125" y2="51" stroke-width="1.5" opacity="0.6" />
  <line x1="134" y1="70" x2="141" y2="65" stroke-width="1.5" opacity="0.6" />
  <line x1="80" y1="57" x2="75" y2="51" stroke-width="1.5" opacity="0.6" />
  <line x1="66" y1="70" x2="59" y2="65" stroke-width="1.5" opacity="0.6" />
  <line x1="62" y1="88" x2="55" y2="88" stroke-width="1.5" opacity="0.5" />
  <line x1="138" y1="88" x2="145" y2="88" stroke-width="1.5" opacity="0.5" />

  <!-- Horizon / water surface -->
  <path d="M0,96 L200,96" stroke-width="2" />

  <!-- Water reflections of sun -->
  <path d="M82,100 Q100,97 118,100" stroke-width="2" opacity="0.7" />
  <path d="M86,106 Q100,103 114,106" stroke-width="1.5" opacity="0.6" />
  <path d="M90,112 Q100,109 110,112" stroke-width="1.5" opacity="0.5" />
  <path d="M93,118 Q100,116 107,118" stroke-width="1" opacity="0.4" />

  <!-- Wider water ripples -->
  <path d="M20,102 Q50,99 80,102" stroke-width="1" opacity="0.4" />
  <path d="M120,102 Q150,99 180,102" stroke-width="1" opacity="0.4" />
  <path d="M5,110 Q40,107 70,110" stroke-width="1" opacity="0.3" />
  <path d="M130,110 Q160,107 195,110" stroke-width="1" opacity="0.3" />

  <!-- Costanera walkway / path -->
  <rect x="0" y="112" width="200" height="38" fill="currentColor" opacity="0.05" stroke="none" />
  <path d="M0,112 L200,112" stroke-width="2" />
  <path d="M0,130 L200,130" stroke-width="1" stroke-dasharray="8,6" opacity="0.4" />

  <!-- Bench - left side -->
  <!-- Bench seat -->
  <rect x="28" y="116" width="32" height="4" rx="1" stroke-width="1.5" fill="currentColor" opacity="0.1" />
  <!-- Bench back -->
  <rect x="28" y="109" width="32" height="3" rx="1" stroke-width="1.5" />
  <!-- Bench back support bars -->
  <line x1="38" y1="112" x2="38" y2="120" stroke-width="1.5" />
  <line x1="50" y1="112" x2="50" y2="120" stroke-width="1.5" />
  <!-- Bench legs -->
  <line x1="30" y1="120" x2="29" y2="128" stroke-width="1.5" />
  <line x1="58" y1="120" x2="59" y2="128" stroke-width="1.5" />
  <!-- Bench center leg -->
  <line x1="44" y1="120" x2="44" y2="128" stroke-width="1.5" />

  <!-- Tree - right side -->
  <!-- Trunk -->
  <path d="M148,128 L148,112 Q148,108 150,105" stroke-width="3" />
  <!-- Main branch left -->
  <path d="M148,110 Q140,104 135,98" stroke-width="2" />
  <!-- Main branch right -->
  <path d="M149,108 Q157,102 162,96" stroke-width="2" />
  <!-- Sub-branches left -->
  <path d="M140,105 Q134,100 130,96" stroke-width="1.5" />
  <path d="M137,101 Q133,95 131,90" stroke-width="1.5" />
  <!-- Sub-branches right -->
  <path d="M156,104 Q161,98 165,93" stroke-width="1.5" />
  <path d="M161,98 Q165,93 168,88" stroke-width="1.5" />
  <!-- Top crown branches -->
  <path d="M150,105 Q147,99 145,93" stroke-width="1.5" />
  <path d="M151,104 Q155,98 157,92" stroke-width="1.5" />
  <!-- Foliage cluster dots (suggested) -->
  <circle cx="132" cy="93" r="4" fill="currentColor" opacity="0.12" stroke-width="1" />
  <circle cx="138" cy="88" r="5" fill="currentColor" opacity="0.12" stroke-width="1" />
  <circle cx="146" cy="90" r="6" fill="currentColor" opacity="0.12" stroke-width="1" />
  <circle cx="155" cy="89" r="5" fill="currentColor" opacity="0.12" stroke-width="1" />
  <circle cx="163" cy="91" r="4" fill="currentColor" opacity="0.12" stroke-width="1" />
  <circle cx="167" cy="86" r="3" fill="currentColor" opacity="0.12" stroke-width="1" />

  <!-- Lamp post -->
  <line x1="90" y1="128" x2="90" y2="105" stroke-width="2" />
  <path d="M90,105 Q92,100 97,100" stroke-width="1.5" />
  <circle cx="98" cy="100" r="3" fill="currentColor" opacity="0.3" stroke-width="1.5" />

  <!-- Distant silhouette of city / trees on horizon -->
  <path d="M0,96 Q10,92 18,96 Q22,88 28,94 Q34,90 40,96 Q50,93 55,96" stroke-width="1" opacity="0.3" />
  <path d="M155,96 Q162,91 168,96 Q172,89 178,96 Q183,92 190,96 Q195,93 200,96" stroke-width="1" opacity="0.3" />
</svg>
