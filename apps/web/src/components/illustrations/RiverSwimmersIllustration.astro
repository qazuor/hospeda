---
/**
 * RiverSwimmersIllustration - Simplified swimmers in river with gentle ripples.
 * Line-art illustration using currentColor for light/dark mode compatibility.
 */
export interface RiverSwimmersIllustrationProps {
  /** Additional CSS classes to apply to the SVG element */
  class?: string;
}

interface Props extends RiverSwimmersIllustrationProps {}

const { class: className } = Astro.props;
---

<svg
  class:list={['illustration', className]}
  viewBox="0 0 200 120"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Distant bank / shore line -->
  <path d="M0,38 Q50,32 100,35 Q150,32 200,38" stroke-width="1.5" opacity="0.5" />
  <!-- Distant trees/vegetation silhouette -->
  <path d="M5,38 Q8,30 12,38" stroke-width="1" opacity="0.4" fill="currentColor" opacity="0.1" />
  <path d="M18,36 Q22,26 27,36" stroke-width="1" opacity="0.4" />
  <path d="M30,35 Q33,28 36,35" stroke-width="1" opacity="0.4" />
  <path d="M140,35 Q144,27 148,35" stroke-width="1" opacity="0.4" />
  <path d="M155,34 Q158,25 162,34" stroke-width="1" opacity="0.4" />
  <path d="M170,36 Q174,29 178,36" stroke-width="1" opacity="0.4" />
  <path d="M185,38 Q188,31 192,38" stroke-width="1" opacity="0.4" />

  <!-- Water surface -->
  <path d="M0,42 Q25,38 50,42 Q75,46 100,42 Q125,38 150,42 Q175,46 200,42" stroke-width="1.5" />

  <!-- Water fill area -->
  <rect x="0" y="42" width="200" height="78" fill="currentColor" opacity="0.04" stroke="none" />

  <!-- General water ripples -->
  <path d="M0,52 Q25,48 50,52 Q75,56 100,52 Q125,48 150,52 Q175,56 200,52" stroke-width="1" opacity="0.6" />
  <path d="M0,62 Q30,58 60,62 Q90,66 120,62 Q150,58 180,62 Q190,63 200,62" stroke-width="1" opacity="0.5" />
  <path d="M0,74 Q35,70 70,74 Q100,77 130,74 Q160,70 200,74" stroke-width="1" opacity="0.4" />
  <path d="M0,86 Q40,82 80,86 Q110,89 140,86 Q165,83 200,86" stroke-width="1" opacity="0.3" />
  <path d="M0,98 Q45,94 90,98 Q120,101 150,98 Q170,96 200,98" stroke-width="1" opacity="0.3" />

  <!-- ===== SWIMMER 1 - front crawl (left) ===== -->
  <!-- Head above water -->
  <circle cx="42" cy="57" r="7" stroke-width="2" fill="currentColor" opacity="0.08" />
  <!-- Swimming cap suggestion -->
  <path d="M36,55 Q42,50 48,55" stroke-width="1.5" fill="currentColor" opacity="0.1" />
  <!-- Goggle band -->
  <path d="M36,57 Q38,56 42,56 Q46,56 48,57" stroke-width="1" />
  <!-- Body below waterline (shown faint) -->
  <path d="M42,64 Q55,66 65,62" stroke-width="2" opacity="0.5" />
  <!-- Arm reaching forward -->
  <path d="M42,60 Q50,54 60,52" stroke-width="2.5" />
  <!-- Arm in water behind -->
  <path d="M36,62 Q28,64 20,68" stroke-width="2" opacity="0.6" />
  <!-- Kick splash behind -->
  <path d="M38,66 Q30,70 25,72" stroke-width="1.5" opacity="0.5" />
  <!-- Small splash -->
  <path d="M58,52 Q60,48 62,50" stroke-width="1" opacity="0.6" />
  <path d="M55,50 Q56,46 59,48" stroke-width="1" opacity="0.5" />

  <!-- ===== SWIMMER 2 - backstroke (center) ===== -->
  <!-- Head -->
  <circle cx="100" cy="54" r="7" stroke-width="2" fill="currentColor" opacity="0.08" />
  <!-- Face up expression (backstroke) -->
  <path d="M96,52 Q98,50 100,50 Q102,50 104,52" stroke-width="1" opacity="0.4" />
  <!-- Chest / shoulders above water -->
  <path d="M92,62 Q100,60 108,62" stroke-width="2.5" />
  <!-- Right arm raised back -->
  <path d="M107,61 Q115,52 120,50" stroke-width="2.5" />
  <path d="M119,50 Q122,48 122,52" stroke-width="1.5" />
  <!-- Left arm in water behind -->
  <path d="M93,62 Q83,60 78,62" stroke-width="2" opacity="0.6" />
  <!-- Body in water -->
  <path d="M100,61 Q100,72 98,78" stroke-width="2" opacity="0.4" />
  <!-- Leg kick splash -->
  <path d="M98,78 Q94,82 90,84" stroke-width="1.5" opacity="0.4" />
  <path d="M100,78 Q104,82 108,84" stroke-width="1.5" opacity="0.4" />
  <!-- Water displaced around arm entry -->
  <path d="M118,52 Q122,55 123,58" stroke-width="1" opacity="0.5" />

  <!-- ===== SWIMMER 3 - treading water (right) ===== -->
  <!-- Head and shoulders above water, relaxed position -->
  <circle cx="162" cy="55" r="7" stroke-width="2" fill="currentColor" opacity="0.08" />
  <!-- Smiling face suggestion -->
  <path d="M158,56 Q160,58 162,58 Q164,58 166,56" stroke-width="1" opacity="0.4" />
  <!-- Eye dots -->
  <circle cx="160" cy="54" r="1" fill="currentColor" opacity="0.4" />
  <circle cx="164" cy="54" r="1" fill="currentColor" opacity="0.4" />
  <!-- Shoulders -->
  <path d="M154,65 Q162,62 170,65" stroke-width="2.5" />
  <!-- Arms out to sides treading -->
  <path d="M154,65 Q145,68 140,72" stroke-width="2" />
  <path d="M170,65 Q179,68 184,72" stroke-width="2" />
  <!-- Hands flat (treading) -->
  <path d="M138,72 Q140,70 142,72" stroke-width="1.5" />
  <path d="M182,72 Q184,70 186,72" stroke-width="1.5" />
  <!-- Water ripple around body -->
  <path d="M148,66 Q162,63 176,66" stroke-width="1" opacity="0.5" />
  <path d="M146,70 Q162,67 178,70" stroke-width="1" opacity="0.4" />

  <!-- Small splashes and bubbles in water -->
  <path d="M70,60 Q72,57 74,60" stroke-width="1" opacity="0.4" />
  <path d="M128,58 Q130,55 132,58" stroke-width="1" opacity="0.4" />
  <circle cx="80" cy="68" r="1.5" stroke-width="1" opacity="0.3" />
  <circle cx="125" cy="65" r="1.5" stroke-width="1" opacity="0.3" />
  <circle cx="50" cy="75" r="1" stroke-width="1" opacity="0.3" />
  <circle cx="145" cy="76" r="1" stroke-width="1" opacity="0.3" />
</svg>
