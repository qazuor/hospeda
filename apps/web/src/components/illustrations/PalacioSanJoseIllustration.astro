---
/**
 * PalacioSanJoseIllustration
 *
 * Iconic Palacio San Jose building silhouette.
 * Neoclassical facade with columns, central dome/pediment, symmetrical wings.
 * Uses currentColor for light/dark mode compatibility.
 */
export interface PalacioSanJoseIllustrationProps {
  class?: string;
}
interface Props extends PalacioSanJoseIllustrationProps {}
const { class: className } = Astro.props;
---
<svg
  class:list={['illustration', className]}
  viewBox="0 0 240 150"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Ground baseline -->
  <line x1="10" y1="140" x2="230" y2="140" />

  <!-- Left wing - base rectangle -->
  <rect x="12" y="90" width="52" height="50" />
  <!-- Left wing - roof pediment -->
  <polyline points="12,90 38,72 64,90" />
  <!-- Left wing - windows row -->
  <rect x="20" y="100" width="12" height="16" rx="1" />
  <rect x="44" y="100" width="12" height="16" rx="1" />
  <!-- Left wing - columns -->
  <line x1="24" y1="90" x2="24" y2="140" />
  <line x1="34" y1="90" x2="34" y2="140" />
  <line x1="44" y1="90" x2="44" y2="140" />
  <line x1="54" y1="90" x2="54" y2="140" />

  <!-- Right wing - base rectangle -->
  <rect x="176" y="90" width="52" height="50" />
  <!-- Right wing - roof pediment -->
  <polyline points="176,90 202,72 228,90" />
  <!-- Right wing - windows row -->
  <rect x="184" y="100" width="12" height="16" rx="1" />
  <rect x="208" y="100" width="12" height="16" rx="1" />
  <!-- Right wing - columns -->
  <line x1="186" y1="90" x2="186" y2="140" />
  <line x1="196" y1="90" x2="196" y2="140" />
  <line x1="206" y1="90" x2="206" y2="140" />
  <line x1="216" y1="90" x2="216" y2="140" />

  <!-- Central body - wider and taller -->
  <rect x="64" y="70" width="112" height="70" />

  <!-- Central pediment / triangular gable -->
  <polyline points="64,70 120,42 176,70" />

  <!-- Central dome above pediment -->
  <path d="M 104,42 Q 120,20 136,42" />
  <!-- Dome lantern -->
  <rect x="115" y="14" width="10" height="8" rx="1" />
  <line x1="120" y1="14" x2="120" y2="8" />
  <!-- Flagpole on dome -->
  <line x1="120" y1="8" x2="120" y2="2" />
  <polyline points="120,2 130,5 120,8" fill="currentColor" stroke="none" />

  <!-- Central entrance arch -->
  <path d="M 104,140 L 104,108 Q 120,94 136,108 L 136,140" />

  <!-- Central columns (6 columns) -->
  <line x1="76" y1="70" x2="76" y2="140" />
  <line x1="89" y1="70" x2="89" y2="140" />
  <line x1="102" y1="70" x2="102" y2="140" />
  <line x1="138" y1="70" x2="138" y2="140" />
  <line x1="151" y1="70" x2="151" y2="140" />
  <line x1="164" y1="70" x2="164" y2="140" />

  <!-- Column capitals (horizontal lines at top) -->
  <line x1="72" y1="72" x2="80" y2="72" />
  <line x1="85" y1="72" x2="93" y2="72" />
  <line x1="98" y1="72" x2="106" y2="72" />
  <line x1="134" y1="72" x2="142" y2="72" />
  <line x1="147" y1="72" x2="155" y2="72" />
  <line x1="160" y1="72" x2="168" y2="72" />

  <!-- Central upper windows -->
  <rect x="72" y="80" width="16" height="18" rx="1" />
  <path d="M 72,80 Q 80,74 88,80" />
  <rect x="152" y="80" width="16" height="18" rx="1" />
  <path d="M 152,80 Q 160,74 168,80" />

  <!-- Entablature / horizontal cornice lines -->
  <line x1="64" y1="75" x2="176" y2="75" />
  <line x1="12" y1="93" x2="228" y2="93" />

  <!-- Steps at base -->
  <line x1="80" y1="143" x2="160" y2="143" />
  <line x1="70" y1="146" x2="170" y2="146" />
</svg>
