---
/**
 * Auth section rendered as a Server Island.
 * Used with `server:defer` in Header so that auth state is always
 * resolved at request time, even on pre-rendered (SSG) pages.
 *
 * The middleware populates `Astro.locals.user` by validating the
 * session cookie against the Better Auth API. This component reads
 * that value and renders either the UserNav dropdown or a sign-in link.
 */
import { UserNav } from './UserNav.client';

interface Props {
  /** Current locale for localized links and labels */
  readonly locale?: string;
}

const { locale = 'es' } = Astro.props;

const user = Astro.locals.user;
const isAuthenticated = !!user;
---

{isAuthenticated && user ? (
  <UserNav
    client:load
    user={{
      name: user.name || 'User',
      email: user.email || '',
    }}
    locale={locale as 'es' | 'en' | 'pt'}
  />
) : (
  <a
    href={`/${locale}/auth/signin/`}
    class="text-sm font-medium text-primary transition-colors hover:text-primary-dark"
  >
    Iniciar Sesion
  </a>
)}
