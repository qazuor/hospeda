---
/**
 * AuthSection - Server Island that resolves authentication state at request time.
 *
 * Used with `server:defer` in the Navbar so that auth state is always fresh,
 * even when the surrounding page is pre-rendered (SSG).
 *
 * The middleware populates `Astro.locals.user` for:
 * - Protected routes (/mi-cuenta/*) - always parsed
 * - Auth routes (/auth/*) - always parsed
 * - Server Island requests (/_server-islands/*) - always parsed
 *
 * This component is rendered as a Server Island, so it receives a fresh session
 * on every request regardless of whether the parent page is SSG or SSR.
 *
 * Renders either:
 * - A UserNav dropdown when the user is authenticated
 * - A "Iniciar sesion" link when the user is not authenticated
 */
import { UserNav } from './UserNav.client';
import { createT, type SupportedLocale } from '../../lib/i18n';
import { buildUrl } from '../../lib/urls';

interface Props {
    /** Current locale for localized links (e.g. "es", "en", "pt") */
    readonly locale?: string;
    /**
     * Visual variant matching the Navbar's current scroll state.
     * Passed through to UserNav so colours stay consistent.
     */
    readonly variant?: 'hero' | 'scrolled';
}

const { locale = 'es', variant = 'hero' } = Astro.props;
const typedLocale = locale as SupportedLocale;

const t = createT(typedLocale);
const user = Astro.locals.user;
const isAuthenticated = !!user;

// Sign-in link classes mirror the static button in Navbar.astro exactly.
// The Navbar scroll-state script targets #navbar-signin by id, so we replicate
// that id here so the same JS logic applies when the user is NOT authenticated.
const signinClasses =
    variant === 'scrolled'
        ? 'inline-flex h-10 items-center justify-center rounded-full px-5 text-sm font-medium transition-colors border border-foreground/20 text-foreground hover:bg-foreground/5'
        : 'inline-flex h-10 items-center justify-center rounded-full px-5 text-sm font-medium transition-colors border border-hero-border text-hero-text bg-hero-surface hover:bg-hero-surface';
---

{isAuthenticated && user ? (
  <UserNav
    client:load
    user={{
      name: user.name || 'Usuario',
      email: user.email || '',
    }}
    locale={locale}
    variant={variant}
  />
) : (
  <a
    href={buildUrl({ locale: typedLocale, path: 'auth/signin' })}
    id="navbar-signin"
    class={signinClasses}
  >
    {t('nav.iniciarSesion', 'Iniciar sesion')}
  </a>
)}
