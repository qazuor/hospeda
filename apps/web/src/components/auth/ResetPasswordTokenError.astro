---
/**
 * @file ResetPasswordTokenError.astro
 * @description Error state rendered when the reset-password page is loaded
 * with a token that the API check endpoint reported as `expired` or `invalid`
 * (SPEC-118).
 *
 * Renders a title, an explanation, and a CTA to request a new reset link. No
 * password input is shown — that would let users type a password they will
 * never get to actually set.
 *
 * The `invalid` variant covers three real-world cases that Better Auth cannot
 * tell apart post-consumption (already used, tampered, or never existed); see
 * SPEC-118 Phase 0 decision.
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createT } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';

interface Props {
    readonly locale: SupportedLocale;
    readonly reason: 'expired' | 'invalid';
}

const { locale, reason } = Astro.props;

const t = createT(locale);

const titleKey = `auth-ui.pages.resetPassword.tokenError.${reason}.title`;
const descriptionKey = `auth-ui.pages.resetPassword.tokenError.${reason}.description`;
const ctaLabel = t(
    'auth-ui.pages.resetPassword.tokenError.requestNewLinkCta',
    'Solicitar nuevo enlace'
);

const fallbacks = {
    expired: {
        title: 'Este enlace expiró',
        description:
            'Los enlaces de restablecimiento tienen una vigencia limitada por seguridad. Solicitá uno nuevo y volvé a intentarlo.'
    },
    invalid: {
        title: 'Este enlace ya no es válido',
        description:
            'Es posible que ya lo hayas usado o que haya sido modificado. Solicitá uno nuevo para continuar.'
    }
} as const;

const title = t(titleKey, fallbacks[reason].title);
const description = t(descriptionKey, fallbacks[reason].description);

const forgotPasswordUrl = buildUrl({ locale, path: 'auth/forgot-password' });
---

<section
    class="token-error"
    data-testid="reset-password-token-error"
    data-reason={reason}
    aria-live="polite"
>
    <div class="token-error__icon" aria-hidden="true">
        <svg
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            focusable="false"
        >
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
        </svg>
    </div>
    <h2 class="token-error__title">{title}</h2>
    <p class="token-error__description">{description}</p>
    <a class="token-error__cta" href={forgotPasswordUrl}>
        {ctaLabel}
    </a>
</section>

<style>
    .token-error {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.75rem;
        padding: 1.5rem 0;
    }

    .token-error__icon {
        color: var(--destructive, oklch(0.6 0.18 28));
        margin-bottom: 0.25rem;
    }

    .token-error__title {
        font-size: var(--text-h3);
        font-weight: 600;
        font-family: var(--font-heading);
        color: var(--core-foreground);
        margin: 0;
    }

    .token-error__description {
        color: var(--core-muted-foreground);
        font-size: var(--text-body-sm);
        font-family: var(--font-sans);
        margin: 0;
        max-width: 22rem;
    }

    .token-error__cta {
        display: inline-block;
        margin-top: 0.5rem;
        padding: 0.625rem 1.5rem;
        border: none;
        border-radius: var(--radius-button);
        font-size: var(--text-body);
        font-weight: 600;
        font-family: var(--font-sans);
        color: var(--primary-foreground, #fff);
        background-color: var(--brand-primary);
        text-decoration: none;
        transition: filter var(--duration-fast) ease;
    }

    .token-error__cta:hover {
        filter: brightness(1.1);
    }

    .token-error__cta:focus-visible {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
    }
</style>
