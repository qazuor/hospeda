---
/**
 * DecorativeCorner - Subtle line-art SVG illustration for section corners.
 * Renders a small decorative motif (leaf branch or wave curl) positioned
 * absolutely in any of the four corners of a relatively-positioned parent.
 *
 * The parent element must have `position: relative` (or `overflow: hidden`)
 * for the absolute positioning to work correctly.
 *
 * @example
 * ```astro
 * <div class="relative">
 *   <DecorativeCorner motif="leaf" position="top-left" />
 *   <DecorativeCorner motif="wave" position="bottom-right" />
 * </div>
 * ```
 */
export interface DecorativeCornerProps {
  /** Visual motif: 'leaf' renders a small branch with leaves, 'wave' renders a flowing curl */
  motif: 'leaf' | 'wave';
  /** Which corner to place the decoration in */
  position: 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';
  /** Additional CSS classes (e.g. for color or opacity customization) */
  class?: string;
}

interface Props extends DecorativeCornerProps {}

const { motif, position, class: className } = Astro.props;

/**
 * CSS transform values to rotate and/or flip the base SVG (drawn for top-left)
 * so it naturally fits each corner without needing separate paths.
 *
 * Base drawing origin is top-left.
 * - top-right:    flip horizontally   → scaleX(-1)
 * - bottom-left:  flip vertically     → scaleY(-1)
 * - bottom-right: rotate 180°         → rotate(180deg) or scale(-1,-1)
 */
const transformMap: Record<DecorativeCornerProps['position'], string> = {
  'top-left': 'none',
  'top-right': 'scaleX(-1)',
  'bottom-left': 'scaleY(-1)',
  'bottom-right': 'scale(-1, -1)',
};

/**
 * Inset positioning styles — place the SVG flush against the target corner.
 * The transform origin is always the corner anchor point.
 */
const positionStyleMap: Record<DecorativeCornerProps['position'], string> = {
  'top-left': 'top: 0; left: 0; transform-origin: top left;',
  'top-right': 'top: 0; right: 0; transform-origin: top right;',
  'bottom-left': 'bottom: 0; left: 0; transform-origin: bottom left;',
  'bottom-right': 'bottom: 0; right: 0; transform-origin: bottom right;',
};

const transform = transformMap[position];
const positionStyle = positionStyleMap[position];

const inlineStyle = [
  'position: absolute;',
  positionStyle,
  transform !== 'none' ? `transform: ${transform};` : '',
  'pointer-events: none;',
].filter(Boolean).join(' ');
---

<svg
  class:list={['decorative-corner', `decorative-corner--${motif}`, `decorative-corner--${position}`, className]}
  style={inlineStyle}
  width="40"
  height="40"
  viewBox="0 0 40 40"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  {motif === 'leaf' && (
    <>
      {/* Main stem curving from corner outward */}
      <path d="M2,38 Q6,28 14,18" />

      {/* Secondary stem branching right */}
      <path d="M8,30 Q14,26 18,20" />

      {/* Leaf 1 - on main stem, lower */}
      <path d="M6,34 Q3,28 9,27 Q10,32 6,34 Z" />

      {/* Leaf 2 - on main stem, upper */}
      <path d="M11,24 Q8,18 15,18 Q14,24 11,24 Z" />

      {/* Leaf 3 - on branch */}
      <path d="M14,28 Q12,22 18,22 Q17,27 14,28 Z" />

      {/* Small bud at tip of main stem */}
      <circle cx="14" cy="18" r="1.2" />

      {/* Tiny leaf near corner anchor */}
      <path d="M3,38 Q1,35 4,34 Q5,37 3,38 Z" />
    </>
  )}

  {motif === 'wave' && (
    <>
      {/* Main sweeping wave curl originating from corner */}
      <path d="M2,38 Q4,30 12,28 Q20,26 22,18 Q24,10 18,6" />

      {/* Secondary smaller curl underneath */}
      <path d="M4,40 Q8,34 16,32 Q22,30 24,24" />

      {/* Wave crest spiral at top */}
      <path d="M18,6 Q22,2 26,6 Q22,10 18,10 Q16,8 18,6" />

      {/* Small foam dots along the wave */}
      <circle cx="10" cy="30" r="0.8" fill="currentColor" stroke="none" />
      <circle cx="16" cy="26" r="0.8" fill="currentColor" stroke="none" />
      <circle cx="20" cy="20" r="0.8" fill="currentColor" stroke="none" />

      {/* Trailing wisp near corner */}
      <path d="M2,36 Q5,33 8,35" />
    </>
  )}
</svg>
