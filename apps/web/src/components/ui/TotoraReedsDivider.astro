---
/**
 * Inline SVG divider with a totora reed grass silhouette.
 * Depicts vertical reed stalks of varying heights with oval cattail tops,
 * evoking the wetland vegetation typical of the Litoral region.
 * Positioned absolute at the bottom of a parent section.
 * Uses CSS variable for fill color to support dark mode theming.
 */
export interface TotoraReedsDividerProps {
  /** Fill color for light mode (dark mode uses CSS variable override) */
  fill?: string;
  class?: string;
}

interface Props extends TotoraReedsDividerProps {}

const { fill = 'currentColor', class: className } = Astro.props;
---

<svg
  class:list={['wave-divider h-12 sm:h-[80px]', className]}
  width="100%"
  viewBox="0 0 1440 80"
  preserveAspectRatio="none"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!--
    Reed stalks: thin vertical rectangles rising from the ground baseline.
    Cattail tops: small ellipses near the top of taller stalks.
    A wavy ground fill closes the bottom.
    Stalks are grouped in clusters across the full width.
  -->

  <!-- Ground fill with gentle undulation -->
  <path
    d="M0,68 C120,62 240,70 360,65 C480,60 600,68 720,64 C840,60 960,68 1080,63 C1200,58 1320,66 1440,62 L1440,80 L0,80 Z"
    fill={fill}
    class="wave-divider-path"
  />

  <!-- Cluster 1: left edge (x 0-180) -->
  <!-- Stalk tall -->
  <rect x="18" y="28" width="4" height="40" fill={fill} class="wave-divider-path" />
  <ellipse cx="20" cy="24" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <!-- Stalk medium -->
  <rect x="40" y="38" width="3" height="30" fill={fill} class="wave-divider-path" />
  <ellipse cx="41.5" cy="34" rx="4" ry="7" fill={fill} class="wave-divider-path" />
  <!-- Stalk short -->
  <rect x="60" y="48" width="3" height="20" fill={fill} class="wave-divider-path" />
  <!-- Stalk tall -->
  <rect x="80" y="24" width="4" height="44" fill={fill} class="wave-divider-path" />
  <ellipse cx="82" cy="20" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <!-- Stalk medium-tall -->
  <rect x="102" y="32" width="3" height="36" fill={fill} class="wave-divider-path" />
  <ellipse cx="103.5" cy="28" rx="4" ry="8" fill={fill} class="wave-divider-path" />
  <!-- Stalk short -->
  <rect x="120" y="50" width="3" height="18" fill={fill} class="wave-divider-path" />
  <!-- Stalk medium -->
  <rect x="140" y="40" width="4" height="28" fill={fill} class="wave-divider-path" />
  <ellipse cx="142" cy="36" rx="4" ry="7" fill={fill} class="wave-divider-path" />
  <!-- Stalk tall -->
  <rect x="162" y="20" width="4" height="48" fill={fill} class="wave-divider-path" />
  <ellipse cx="164" cy="16" rx="5" ry="10" fill={fill} class="wave-divider-path" />

  <!-- Cluster 2: left-center (x 260-440) -->
  <rect x="268" y="30" width="4" height="38" fill={fill} class="wave-divider-path" />
  <ellipse cx="270" cy="26" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <rect x="290" y="44" width="3" height="24" fill={fill} class="wave-divider-path" />
  <rect x="310" y="22" width="4" height="46" fill={fill} class="wave-divider-path" />
  <ellipse cx="312" cy="18" rx="5" ry="10" fill={fill} class="wave-divider-path" />
  <rect x="334" y="36" width="3" height="32" fill={fill} class="wave-divider-path" />
  <ellipse cx="335.5" cy="32" rx="4" ry="7" fill={fill} class="wave-divider-path" />
  <rect x="355" y="50" width="3" height="18" fill={fill} class="wave-divider-path" />
  <rect x="374" y="26" width="4" height="42" fill={fill} class="wave-divider-path" />
  <ellipse cx="376" cy="22" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <rect x="398" y="40" width="3" height="28" fill={fill} class="wave-divider-path" />
  <rect x="418" y="32" width="4" height="36" fill={fill} class="wave-divider-path" />
  <ellipse cx="420" cy="28" rx="4" ry="8" fill={fill} class="wave-divider-path" />

  <!-- Cluster 3: center (x 580-760) -->
  <rect x="588" y="24" width="4" height="44" fill={fill} class="wave-divider-path" />
  <ellipse cx="590" cy="20" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <rect x="610" y="42" width="3" height="26" fill={fill} class="wave-divider-path" />
  <rect x="630" y="30" width="4" height="38" fill={fill} class="wave-divider-path" />
  <ellipse cx="632" cy="26" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <rect x="654" y="48" width="3" height="20" fill={fill} class="wave-divider-path" />
  <rect x="672" y="18" width="4" height="50" fill={fill} class="wave-divider-path" />
  <ellipse cx="674" cy="14" rx="5" ry="10" fill={fill} class="wave-divider-path" />
  <rect x="696" y="34" width="3" height="34" fill={fill} class="wave-divider-path" />
  <ellipse cx="697.5" cy="30" rx="4" ry="7" fill={fill} class="wave-divider-path" />
  <rect x="716" y="44" width="3" height="24" fill={fill} class="wave-divider-path" />
  <rect x="736" y="28" width="4" height="40" fill={fill} class="wave-divider-path" />
  <ellipse cx="738" cy="24" rx="5" ry="9" fill={fill} class="wave-divider-path" />

  <!-- Cluster 4: right-center (x 900-1080) -->
  <rect x="908" y="32" width="4" height="36" fill={fill} class="wave-divider-path" />
  <ellipse cx="910" cy="28" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <rect x="930" y="46" width="3" height="22" fill={fill} class="wave-divider-path" />
  <rect x="950" y="22" width="4" height="46" fill={fill} class="wave-divider-path" />
  <ellipse cx="952" cy="18" rx="5" ry="10" fill={fill} class="wave-divider-path" />
  <rect x="974" y="38" width="3" height="30" fill={fill} class="wave-divider-path" />
  <ellipse cx="975.5" cy="34" rx="4" ry="7" fill={fill} class="wave-divider-path" />
  <rect x="994" y="50" width="3" height="18" fill={fill} class="wave-divider-path" />
  <rect x="1014" y="26" width="4" height="42" fill={fill} class="wave-divider-path" />
  <ellipse cx="1016" cy="22" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <rect x="1038" y="36" width="3" height="32" fill={fill} class="wave-divider-path" />
  <rect x="1058" y="28" width="4" height="40" fill={fill} class="wave-divider-path" />
  <ellipse cx="1060" cy="24" rx="4" ry="8" fill={fill} class="wave-divider-path" />

  <!-- Cluster 5: right edge (x 1260-1440) -->
  <rect x="1268" y="30" width="4" height="38" fill={fill} class="wave-divider-path" />
  <ellipse cx="1270" cy="26" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <rect x="1290" y="46" width="3" height="22" fill={fill} class="wave-divider-path" />
  <rect x="1310" y="20" width="4" height="48" fill={fill} class="wave-divider-path" />
  <ellipse cx="1312" cy="16" rx="5" ry="10" fill={fill} class="wave-divider-path" />
  <rect x="1334" y="38" width="3" height="30" fill={fill} class="wave-divider-path" />
  <ellipse cx="1335.5" cy="34" rx="4" ry="7" fill={fill} class="wave-divider-path" />
  <rect x="1355" y="50" width="3" height="18" fill={fill} class="wave-divider-path" />
  <rect x="1374" y="28" width="4" height="40" fill={fill} class="wave-divider-path" />
  <ellipse cx="1376" cy="24" rx="5" ry="9" fill={fill} class="wave-divider-path" />
  <rect x="1398" y="40" width="3" height="28" fill={fill} class="wave-divider-path" />
  <rect x="1418" y="32" width="4" height="36" fill={fill} class="wave-divider-path" />
  <ellipse cx="1420" cy="28" rx="4" ry="8" fill={fill} class="wave-divider-path" />
</svg>
