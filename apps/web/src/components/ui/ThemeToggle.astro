---
/**
 * ThemeToggle - Accessible light/dark mode toggle button.
 *
 * Reads the current theme from the `data-theme` attribute on `<html>`,
 * toggles between "light" and "dark", and persists the choice to
 * localStorage under the key "theme" (matching the FOUC prevention
 * script in BaseLayout.astro).
 *
 * No external dependencies. Uses inline SVG icons only.
 */

interface Props {
  /** Additional CSS classes for the button wrapper. */
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  title="Toggle dark mode"
  class:list={[
    "theme-toggle",
    "inline-flex items-center justify-center",
    "w-9 h-9 rounded-lg",
    "theme-toggle-btn border border-hero-border",
    "bg-hero-surface text-hero-text",
    "hover:bg-hero-surface transition-colors duration-200",
    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2",
    "cursor-pointer",
    className,
  ]}
>
  <!-- Sun icon: shown in dark mode (click to go light) -->
  <svg
    class="theme-toggle__sun hidden h-4 w-4"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>

  <!-- Moon icon: shown in light mode (click to go dark) -->
  <svg
    class="theme-toggle__moon h-4 w-4"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  /**
   * Synchronizes the toggle button icon with the current theme.
   * Called on initial load and after every toggle.
   */
  function syncIcon(isDark: boolean): void {
    const sun = document.querySelector<SVGElement>(".theme-toggle__sun");
    const moon = document.querySelector<SVGElement>(".theme-toggle__moon");
    if (!sun || !moon) return;

    if (isDark) {
      sun.classList.remove("hidden");
      moon.classList.add("hidden");
    } else {
      sun.classList.add("hidden");
      moon.classList.remove("hidden");
    }
  }

  /**
   * Applies a theme by setting the data-theme attribute on <html>
   * and persisting the choice to localStorage.
   */
  function applyTheme(theme: "light" | "dark"): void {
    const root = document.documentElement;
    if (theme === "dark") {
      root.setAttribute("data-theme", "dark");
    } else {
      root.removeAttribute("data-theme");
    }
    localStorage.setItem("theme", theme);
    syncIcon(theme === "dark");
  }

  function initToggle(): void {
    const button = document.getElementById("theme-toggle");
    if (!button) return;

    // Sync icon with the theme already applied by FOUC prevention script.
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    syncIcon(isDark);

    button.addEventListener("click", () => {
      const currentlyDark =
        document.documentElement.getAttribute("data-theme") === "dark";
      applyTheme(currentlyDark ? "light" : "dark");
    });
  }

  // Run on first load and after view transitions (if enabled).
  initToggle();
  document.addEventListener("astro:page-load", initToggle);
</script>
