---
/**
 * Reusable star rating display component with partial fill support.
 * Renders 5 SVG stars with clip-path for fractional ratings.
 * Hides completely when rating is 0 or undefined.
 */
import { t, type SupportedLocale } from '../../lib/i18n';

interface Props {
  /** Rating value from 0 to 5. Component hidden when 0. */
  rating: number;
  /** Number of reviews to display next to stars. */
  reviewsCount?: number;
  /** Visual size of stars. */
  size?: 'sm' | 'md' | 'lg';
  /** Locale for accessible labels. */
  locale?: SupportedLocale;
  /** Additional CSS classes. */
  class?: string;
}

const { rating: rawRating, reviewsCount, size = 'sm', locale = 'es', class: className } = Astro.props;

/** Coerce rating to a safe number (API may return strings or null) */
const rating = Number(rawRating) || 0;

const sizeMap = {
  sm: 14,
  md: 18,
  lg: 22,
} as const;

const starSize = sizeMap[size];
const gapClass = size === 'lg' ? 'gap-1' : 'gap-0.5';

/** Simple counter for unique SVG clip-path IDs (no crypto overhead) */
let _starRatingCounter = globalThis.__starRatingCounter ?? 0;
globalThis.__starRatingCounter = ++_starRatingCounter;
const uid = `sr-${_starRatingCounter}`;

/** Build localized aria-label */
const ratingLabel = t({
  locale,
  namespace: 'destinations',
  key: 'featured.card.ratingLabel',
  params: { rating: rating.toFixed(1) },
  fallback: `Rating: ${rating.toFixed(1)} out of 5`,
});
const reviewsSuffix = reviewsCount != null ? `, ${reviewsCount} reviews` : '';
const ariaLabel = `${ratingLabel}${reviewsSuffix}`;
---

{rating > 0 && (
  <div
    class:list={['inline-flex items-center', gapClass, className]}
    role="img"
    aria-label={ariaLabel}
  >
    <div class:list={['flex items-center', gapClass]}>
      {Array.from({ length: 5 }, (_, i) => {
        const fillPercent = Math.min(1, Math.max(0, rating - i)) * 100;
        return (
          <svg
            width={starSize}
            height={starSize}
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            class="shrink-0"
          >
            <defs>
              <clipPath id={`${uid}-${i}`}>
                <rect x="0" y="0" width={`${fillPercent}%`} height="100%" />
              </clipPath>
            </defs>
            {/* Empty star (background) */}
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
              fill="var(--color-border)"
            />
            {/* Filled star (clipped to rating percentage) */}
            <path
              d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
              fill="var(--color-warning)"
              clip-path={`url(#${uid}-${i})`}
            />
          </svg>
        );
      })}
    </div>
    {reviewsCount != null && reviewsCount > 0 && (
      <span class="text-xs text-text-secondary">({reviewsCount})</span>
    )}
  </div>
)}
