---
import Button from './Button.astro';

/**
 * Empty state component for displaying when no content is available.
 * Shows an illustration, title, message, and optional call-to-action.
 */
interface Props {
  title: string;
  message: string;
  cta?: {
    label: string;
    href: string;
  };
  class?: string;
}

const { title, message, cta, class: className } = Astro.props;
---

<div class:list={['flex flex-col items-center justify-center px-6 py-12 text-center max-w-md mx-auto', className]}>
  <!-- SVG Illustration -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-24 h-24 mb-6 text-text-secondary"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
      d="M9.172 7.828a4 4 0 015.656 0l3.172 3.172a4 4 0 010 5.656l-3.172 3.172a4 4 0 01-5.656 0l-3.172-3.172a4 4 0 010-5.656l3.172-3.172z"
    />
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
      d="M12 9v6m0 0v.01"
    />
  </svg>

  <!-- Title -->
  <h3 class="text-xl font-semibold text-text mb-3">
    {title}
  </h3>

  <!-- Message -->
  <p class="text-base text-text-secondary mb-6">
    {message}
  </p>

  <!-- Optional CTA -->
  {cta && (
    <Button href={cta.href} variant="primary" size="md">
      {cta.label}
    </Button>
  )}
</div>
