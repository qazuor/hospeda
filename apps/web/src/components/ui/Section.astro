---
/**
 * Semantic page section with optional title and subtitle.
 * Provides consistent vertical spacing between content sections.
 */
interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
  id?: string;
}

const { title, subtitle, class: className, id } = Astro.props;
---

<section id={id} class:list={['py-24', className]}>
  {(title || subtitle) && (
    <div class="mb-8 text-center">
      {title && <h2 class="text-3xl font-bold md:text-4xl">{title}</h2>}
      {subtitle && (
        <p class="mx-auto mt-3 max-w-2xl text-text-secondary">{subtitle}</p>
      )}
    </div>
  )}
  <slot />
</section>
