---
/**
 * Scroll-triggered reveal wrapper using IntersectionObserver.
 * Wraps content with initial hidden state that transitions to visible
 * when the element enters the viewport. Supports stagger delay via index prop.
 * Respects prefers-reduced-motion by starting elements in visible state.
 * The observer script is loaded globally via BaseLayout.
 */
export interface ScrollRevealProps {
  /** Stagger index for delay calculation (0-based) */
  index?: number;
  /** Custom CSS class to append */
  class?: string;
  /** HTML tag to render (defaults to div) */
  as?: 'div' | 'article' | 'section' | 'li';
}

interface Props extends ScrollRevealProps {}

const { index = 0, class: className, as: Tag = 'div' } = Astro.props;

const staggerDelay = index * 75;
---

<Tag
  class:list={['scroll-reveal', className]}
  style={staggerDelay > 0 ? `--stagger-delay: ${staggerDelay}ms` : undefined}
  data-scroll-reveal
>
  <slot />
</Tag>
