---
/**
 * Standard section heading pattern with optional accent subtitle,
 * icon badge, description, and view-all link.
 */
export interface SectionHeaderProps {
  title: string;
  accentSubtitle?: string;
  icon?: {
    component: unknown;
    bgColor: string;
  };
  description?: string;
  viewAllHref?: string;
  viewAllLabel?: string;
  align?: 'left' | 'center';
  class?: string;
}

interface Props extends SectionHeaderProps {}

const {
  title,
  accentSubtitle,
  icon,
  description,
  viewAllHref,
  viewAllLabel,
  align = 'center',
  class: className,
} = Astro.props;

const alignClass = align === 'center' ? 'text-center' : 'text-left';
const IconComponent = icon?.component as any;
---

<div class:list={['mb-12 scroll-reveal', alignClass, className]} data-scroll-reveal>
  {icon && (
    <div
      class:list={['mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl', icon.bgColor, align === 'center' && 'mx-auto']}
      aria-hidden="true"
    >
      <IconComponent size={24} className="text-white" />
    </div>
  )}
  {accentSubtitle && (
    <p class="mb-2 inline-block -rotate-2 font-accent text-[length:var(--fs-accent-subtitle)] text-accent-warm">
      {accentSubtitle}
    </p>
  )}
  <h2 class="mb-2 font-serif text-[length:var(--fs-display-section)] font-bold text-text">
    {title}
  </h2>
  {description && (
    <p class:list={['mt-3 text-lg text-text-secondary max-w-[600px]', align === 'center' && 'mx-auto']}>
      {description}
    </p>
  )}
  {viewAllHref && viewAllLabel && (
    <a
      href={viewAllHref}
      class="mt-6 inline-block rounded-lg border-2 border-primary px-6 py-2 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
    >
      {viewAllLabel}
    </a>
  )}
</div>
