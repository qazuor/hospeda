---
/**
 * Responsive max-width container with horizontal padding.
 * Centers content and constrains width based on size prop.
 */
interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const { size = 'lg', class: className } = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-6xl',
  xl: 'max-w-7xl',
};
---

<div class:list={['mx-auto px-4 sm:px-6 lg:px-8', sizeClasses[size], className]}>
  <slot />
</div>
