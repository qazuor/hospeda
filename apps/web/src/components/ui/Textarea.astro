---
/**
 * Multi-line text input component with label and error state.
 * Configurable number of rows for different content sizes.
 */
interface Props {
  name: string;
  label?: string;
  placeholder?: string;
  value?: string;
  error?: string;
  required?: boolean;
  disabled?: boolean;
  rows?: number;
  id?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  name,
  label,
  placeholder,
  value,
  error,
  required = false,
  disabled = false,
  rows = 4,
  id,
  class: className,
  ...rest
} = Astro.props;

const textareaId = id || `textarea-${name}`;
const errorId = `${textareaId}-error`;

const baseClasses = 'w-full px-3 py-2 text-base rounded-md border transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:bg-surface/50 resize-vertical';

const stateClasses = error
  ? 'border-red-500 dark:border-red-400 focus:border-red-500 dark:focus:border-red-400 focus:ring-red-500 dark:focus:ring-red-400'
  : 'border-border bg-surface text-text hover:border-border/80';

const classes = [baseClasses, stateClasses, className].filter(Boolean).join(' ');
---

<div class="w-full">
  {label && (
    <label for={textareaId} class="block text-sm font-medium text-text mb-1.5">
      {label}
      {required && <span class="text-red-500 dark:text-red-400 ml-1" aria-label="required">*</span>}
    </label>
  )}
  <textarea
    name={name}
    id={textareaId}
    placeholder={placeholder}
    required={required || undefined}
    disabled={disabled}
    rows={rows}
    aria-invalid={error ? 'true' : undefined}
    aria-describedby={error ? errorId : undefined}
    class={classes}
    {...rest}
  >{value}</textarea>
  {error && (
    <p id={errorId} class="mt-1.5 text-sm text-red-500 dark:text-red-400" role="alert">
      {error}
    </p>
  )}
</div>
