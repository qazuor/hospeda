---
/**
 * Skeleton loading component with shimmer animation.
 * Displays placeholder shapes during content loading.
 * Supports text, card, and image layout types.
 */
interface Props {
  type?: 'card' | 'text' | 'image';
  count?: number;
  class?: string;
}

const { type = 'text', count = 1, class: className } = Astro.props;

const baseClasses = 'bg-border/50 animate-shimmer';

const typeClasses: Record<string, string> = {
  text: 'h-4 rounded w-full',
  card: 'rounded-lg aspect-[4/3]',
  image: 'rounded-lg aspect-square',
};

const classes = [baseClasses, typeClasses[type], className].filter(Boolean).join(' ');
---

<div role="status" aria-hidden="true">
  <span class="sr-only">Loading...</span>

  {type === 'text' && count > 1 ? (
    <div class="space-y-3">
      {Array.from({ length: count }, (_, i) => (
        <div
          key={i}
          class={classes}
          style={i === count - 1 ? 'width: 75%' : undefined}
        />
      ))}
    </div>
  ) : type === 'card' ? (
    <div class={classes}>
      <div class="p-4 h-full flex flex-col justify-end space-y-2">
        <div class="h-3 bg-surface rounded w-3/4" />
        <div class="h-3 bg-surface rounded w-1/2" />
      </div>
    </div>
  ) : (
    <div class={classes} />
  )}
</div>
