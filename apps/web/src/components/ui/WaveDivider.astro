---
/**
 * Inline SVG wave divider for smooth section transitions.
 * Positioned absolute at the bottom of a parent section.
 * Uses CSS variable for fill color to support dark mode theming.
 */
export interface WaveDividerProps {
  /** Fill color for light mode (dark mode uses CSS variable override) */
  fill?: string;
  class?: string;
}

interface Props extends WaveDividerProps {}

const { fill = '#FFFFFF', class: className } = Astro.props;
---

<svg
  class:list={['wave-divider h-10 sm:h-[60px]', className]}
  width="100%"
  viewBox="0 0 1440 60"
  preserveAspectRatio="none"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M0,0 C240,60 480,60 720,30 C960,0 1200,0 1440,30 L1440,60 L0,60 Z"
    fill={fill}
    class="wave-divider-path"
  />
</svg>
