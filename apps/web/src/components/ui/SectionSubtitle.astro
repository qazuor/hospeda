---
/**
 * Reusable section subtitle component with Caveat handwritten font,
 * optional rotation, and warm accent color.
 */
export interface SectionSubtitleProps {
  /** HTML tag to render (default: p) */
  as?: 'p' | 'span' | 'div';
  /** CSS font-size value (default: var(--fs-accent-subtitle)) */
  size?: string;
  /** CSS color value (default: inherits accent-warm via class) */
  color?: string;
  /** Apply slight rotation for hand-drawn feel (default: true) */
  rotated?: boolean;
  /** Additional CSS classes */
  class?: string;
}

interface Props extends SectionSubtitleProps {}

const {
  as: Tag = 'p',
  size = 'var(--fs-accent-subtitle)',
  color,
  rotated = true,
  class: className,
} = Astro.props;

const inlineStyle = [
  `font-size: ${size}`,
  color ? `color: ${color}` : '',
].filter(Boolean).join('; ');
---

<Tag
  class:list={[
    'font-accent',
    !color && 'text-accent-warm',
    rotated && '-rotate-2',
    className,
  ]}
  style={inlineStyle}
>
  <slot />
</Tag>
