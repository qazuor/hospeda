---
/**
 * Form label component with optional required indicator.
 * Links to input element via 'for' attribute.
 */
interface Props {
  for?: string;
  required?: boolean;
  class?: string;
}

const {
  for: htmlFor,
  required = false,
  class: className,
} = Astro.props;

const baseClasses = 'text-sm font-medium text-text';
---

<label for={htmlFor} class:list={[baseClasses, className]}>
  <slot />
  {required && <span class="text-red-500 dark:text-red-400 ml-0.5" aria-label="required">*</span>}
</label>
