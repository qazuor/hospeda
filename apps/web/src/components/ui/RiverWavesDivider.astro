---
/**
 * Animated SVG wave divider with 5 colored layers representing river water.
 * Back layers use deep teal/blue (deep river water), progressing to lighter
 * shades, with the front layer matching the next section's background color.
 * Each wave layer animates its path independently using SVG SMIL animation.
 * Supports light/dark mode via CSS variable overrides.
 */
export interface RiverWavesDividerProps {
  /** Fill color for the front wave layer (should match the next section background) */
  fill?: string;
  class?: string;
}

interface Props extends RiverWavesDividerProps {}

const { fill = 'currentColor', class: className } = Astro.props;
---

<div class:list={['river-waves-divider', className]}>
  <svg
    class="relative block h-32 w-full sm:h-40 md:h-48"
    viewBox="0 0 1200 120"
    preserveAspectRatio="none"
    aria-hidden="true"
    focusable="false"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Layer 1: Deep river water.. darkest, slowest (18s) -->
    <path
      d="M0,120 L0,0 C150,80 300,30 450,60 C600,90 750,40 900,70 C1050,100 1150,50 1200,0 L1200,120 Z"
      class="wave-layer-1"
      fill-opacity="0.9"
    >
      <animate
        attributeName="d"
        dur="18s"
        repeatCount="indefinite"
        values="
          M0,120 L0,0 C150,90 300,20 450,70 C600,100 750,30 900,80 C1050,110 1150,40 1200,0 L1200,120 Z;
          M0,120 L0,40 C150,20 300,90 450,50 C600,30 750,100 900,60 C1050,40 1150,110 1200,40 L1200,120 Z;
          M0,120 L0,20 C150,100 300,40 450,80 C600,50 750,110 900,70 C1050,30 1150,90 1200,20 L1200,120 Z;
          M0,120 L0,0 C150,90 300,20 450,70 C600,100 750,30 900,80 C1050,110 1150,40 1200,0 L1200,120 Z
        "
      />
    </path>

    <!-- Layer 2: Mid-depth river (15s) -->
    <path
      d="M0,120 L0,20 C200,70 400,30 600,60 C800,90 1000,40 1200,20 L1200,120 Z"
      class="wave-layer-2"
      fill-opacity="0.85"
    >
      <animate
        attributeName="d"
        dur="15s"
        repeatCount="indefinite"
        values="
          M0,120 L0,20 C200,80 400,20 600,70 C800,100 1000,30 1200,20 L1200,120 Z;
          M0,120 L0,60 C200,30 400,80 600,40 C800,20 1000,90 1200,60 L1200,120 Z;
          M0,120 L0,40 C200,90 400,35 600,75 C800,50 1000,100 1200,40 L1200,120 Z;
          M0,120 L0,20 C200,80 400,20 600,70 C800,100 1000,30 1200,20 L1200,120 Z
        "
      />
    </path>

    <!-- Layer 3: Main current.. brand teal (12s) -->
    <path
      d="M0,120 L0,35 C120,75 240,45 360,65 C480,85 600,50 720,70 C840,90 960,55 1080,75 C1150,85 1180,65 1200,35 L1200,120 Z"
      class="wave-layer-3"
      fill-opacity="0.8"
    >
      <animate
        attributeName="d"
        dur="12s"
        repeatCount="indefinite"
        values="
          M0,120 L0,35 C120,85 240,35 360,75 C480,95 600,40 720,80 C840,100 960,45 1080,85 C1150,95 1180,55 1200,35 L1200,120 Z;
          M0,120 L0,70 C120,40 240,85 360,50 C480,35 600,90 720,55 C840,40 960,95 1080,60 C1150,45 1180,100 1200,70 L1200,120 Z;
          M0,120 L0,50 C120,90 240,50 360,80 C480,60 600,100 720,70 C840,50 960,110 1080,75 C1150,60 1180,100 1200,50 L1200,120 Z;
          M0,120 L0,35 C120,85 240,35 360,75 C480,95 600,40 720,80 C840,100 960,45 1080,85 C1150,95 1180,55 1200,35 L1200,120 Z
        "
      />
    </path>

    <!-- Layer 4: Shallow water with sunlight (10s) -->
    <path
      d="M0,120 L0,50 C150,85 300,55 450,75 C600,95 750,60 900,80 C1050,100 1150,70 1200,50 L1200,120 Z"
      class="wave-layer-4"
      fill-opacity="0.75"
    >
      <animate
        attributeName="d"
        dur="10s"
        repeatCount="indefinite"
        values="
          M0,120 L0,50 C150,95 300,45 450,85 C600,105 750,50 900,90 C1050,110 1150,60 1200,50 L1200,120 Z;
          M0,120 L0,85 C150,55 300,95 450,65 C600,50 750,100 900,70 C1050,55 1150,105 1200,85 L1200,120 Z;
          M0,120 L0,65 C150,100 300,60 450,90 C600,70 750,110 900,80 C1050,65 1150,115 1200,65 L1200,120 Z;
          M0,120 L0,50 C150,95 300,45 450,85 C600,105 750,50 900,90 C1050,110 1150,60 1200,50 L1200,120 Z
        "
      />
    </path>

    <!-- Layer 5: Shore/surface.. blends into next section (8s) -->
    <path
      d="M0,120 L0,60 C120,90 240,65 360,80 C480,95 600,70 720,85 C840,100 960,75 1080,90 C1150,100 1180,80 1200,60 L1200,120 Z"
      fill={fill}
      fill-opacity="1"
      class="wave-layer-5"
    >
      <animate
        attributeName="d"
        dur="8s"
        repeatCount="indefinite"
        values="
          M0,120 L0,60 C120,100 240,55 360,90 C480,105 600,60 720,95 C840,110 960,65 1080,100 C1150,110 1180,70 1200,60 L1200,120 Z;
          M0,120 L0,90 C120,60 240,100 360,70 C480,55 600,105 720,75 C840,60 960,110 1080,80 C1150,65 1180,105 1200,90 L1200,120 Z;
          M0,120 L0,75 C120,105 240,70 360,95 C480,80 600,115 720,90 C840,75 960,120 1080,95 C1150,80 1180,115 1200,75 L1200,120 Z;
          M0,120 L0,60 C120,100 240,55 360,90 C480,105 600,60 720,95 C840,110 960,65 1080,100 C1150,110 1180,70 1200,60 L1200,120 Z
        "
      />
    </path>
  </svg>
</div>

<style>
  .river-waves-divider {
    overflow: hidden;
    line-height: 0;
    pointer-events: none;
  }

  /* River color palette: deep water to shore */
  .wave-layer-1 { fill: var(--color-primary-900); }  /* #042526 - deep riverbed */
  .wave-layer-2 { fill: var(--color-primary-700); }  /* #084A4D - mid-depth */
  .wave-layer-3 { fill: var(--color-primary-500); }  /* #0D7377 - main current */
  .wave-layer-4 { fill: var(--color-primary-300); }  /* #6FC4C7 - sunlit shallows */
  /* Layer 5 uses the fill prop directly (next section color) */

  /* Dark mode: shift colors for night river feel */
  [data-theme="dark"] .wave-layer-1 { fill: var(--color-primary-950); }
  [data-theme="dark"] .wave-layer-2 { fill: var(--color-primary-900); }
  [data-theme="dark"] .wave-layer-3 { fill: var(--color-primary-800); }
  [data-theme="dark"] .wave-layer-4 { fill: var(--color-primary-700); }
  [data-theme="dark"] .wave-layer-5 { fill: var(--color-bg) !important; }
</style>
