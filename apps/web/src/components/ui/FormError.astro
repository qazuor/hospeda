---
/**
 * Form error message component.
 * Conditionally renders error message with accessibility attributes.
 */
interface Props {
  message?: string;
  id?: string;
  class?: string;
}

const {
  message,
  id,
  class: className,
} = Astro.props;

const baseClasses = 'text-sm text-red-500 dark:text-red-400';
---

{message && (
  <p
    id={id}
    class:list={[baseClasses, className]}
    role="alert"
    aria-live="polite"
  >
    {message}
  </p>
)}
