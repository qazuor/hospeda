---
/**
 * Skeleton fallback for the accommodations grid (Server Island).
 * Renders 8 placeholder cards with pulse animation.
 */
---

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
  {Array.from({ length: 8 }).map(() => (
    <div class="animate-pulse rounded-2xl bg-card shadow-sm overflow-hidden">
      <div class="aspect-[4/3] bg-muted" />
      <div class="p-4 space-y-3">
        <div class="h-4 w-3/4 rounded bg-muted" />
        <div class="h-3 w-1/2 rounded bg-muted" />
        <div class="flex gap-2">
          <div class="h-6 w-16 rounded-full bg-muted" />
          <div class="h-6 w-16 rounded-full bg-muted" />
        </div>
        <div class="flex items-center justify-between pt-2 border-t border-border">
          <div class="h-5 w-24 rounded bg-muted" />
          <div class="h-8 w-20 rounded-lg bg-muted" />
        </div>
      </div>
    </div>
  ))}
</div>
