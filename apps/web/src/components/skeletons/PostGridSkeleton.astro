---
/**
 * Skeleton fallback for the blog posts magazine layout (Server Island).
 * Renders 1 featured card + 2 secondary cards with pulse animation.
 */
---

<div class="grid gap-8 lg:grid-cols-12 lg:gap-10">
  <!-- Featured article skeleton -->
  <div class="animate-pulse lg:col-span-7 rounded-2xl bg-card shadow-sm overflow-hidden">
    <div class="aspect-video bg-muted" />
    <div class="p-6 space-y-3">
      <div class="h-5 w-24 rounded-full bg-muted" />
      <div class="h-6 w-3/4 rounded bg-muted" />
      <div class="space-y-2">
        <div class="h-3 w-full rounded bg-muted" />
        <div class="h-3 w-5/6 rounded bg-muted" />
      </div>
      <div class="h-3 w-1/4 rounded bg-muted" />
    </div>
  </div>

  <!-- Secondary articles skeleton -->
  <div class="flex flex-col gap-6 lg:col-span-5">
    {Array.from({ length: 2 }).map(() => (
      <div class="animate-pulse flex gap-4 rounded-2xl bg-card shadow-sm p-3">
        <div class="h-24 w-24 flex-shrink-0 rounded-xl bg-muted" />
        <div class="flex-1 space-y-2 py-1">
          <div class="h-3 w-16 rounded-full bg-muted" />
          <div class="h-4 w-3/4 rounded bg-muted" />
          <div class="h-3 w-1/2 rounded bg-muted" />
        </div>
      </div>
    ))}
  </div>
</div>
