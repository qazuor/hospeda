---
/**
 * Skeleton fallback for the destinations grid (Server Island).
 * Renders 3 placeholder cards with pulse animation.
 */
---

<div class="grid gap-6 md:grid-cols-3">
  {Array.from({ length: 3 }).map(() => (
    <div class="animate-pulse rounded-2xl bg-card shadow-sm overflow-hidden">
      <div class="aspect-[3/4] bg-muted" />
      <div class="p-4 space-y-2">
        <div class="h-5 w-2/3 rounded bg-muted" />
        <div class="h-3 w-1/3 rounded bg-muted" />
      </div>
    </div>
  ))}
</div>
