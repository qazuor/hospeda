---
/**
 * @file EventCardHorizontalSkeleton.astro
 * @description Skeleton loading placeholder for EventCardHorizontal.
 *
 * Mirrors the horizontal layout:
 * - Left photo strip (150px wide)
 * - Date block column (category-colored in real card, neutral border here)
 * - Content area with category badge, title lines, summary lines, location pill
 * - Right circular CTA button
 *
 * Uses the same pulse animation tokens as EventGridSkeleton.astro.
 */
---

<div class="skeleton-h">
  <!-- Left photo strip -->
  <div class="skeleton-h__photo skeleton-pulse"></div>

  <!-- Date block -->
  <div class="skeleton-h__date-block skeleton-pulse">
    <div class="skeleton-h__month-bar"></div>
    <div class="skeleton-h__date-lines">
      <div class="skeleton-h__date-line skeleton-pulse"></div>
      <div class="skeleton-h__time-line skeleton-pulse"></div>
    </div>
  </div>

  <!-- Content -->
  <div class="skeleton-h__content">
    <div class="skeleton-h__badge skeleton-pulse"></div>
    <div class="skeleton-h__title skeleton-pulse"></div>
    <div class="skeleton-h__title-short skeleton-pulse"></div>
    <div class="skeleton-h__summary skeleton-pulse"></div>
    <div class="skeleton-h__location skeleton-pulse"></div>
  </div>

  <!-- CTA circle -->
  <div class="skeleton-h__cta skeleton-pulse"></div>
</div>

<style>
  @keyframes skeleton-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  .skeleton-pulse {
    animation: skeleton-pulse 1.8s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .skeleton-pulse {
      animation: none;
      opacity: 0.6;
    }
  }

  .skeleton-h {
    display: flex;
    align-items: stretch;
    min-height: 160px;
    background-color: var(--core-card);
    border-radius: var(--radius-card);
    border: 1px solid var(--brand-primary-a15);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  /* Photo strip */
  .skeleton-h__photo {
    flex-shrink: 0;
    width: 150px;
    background-color: var(--border);
  }

  /* Date block */
  .skeleton-h__date-block {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    min-width: 120px;
    background-color: var(--border);
    border-radius: 0 12px 12px 0;
    padding: 0.75rem 1rem 0.75rem 0;
    /* Override pulse on the container — children pulse individually */
    animation: none;
    opacity: 1;
  }

  .skeleton-h__month-bar {
    flex-shrink: 0;
    width: 1.25rem;
    height: 60%;
    background-color: var(--border-lm05);
    border-radius: var(--radius-sm);
    margin-left: -0.125rem;
  }

  .skeleton-h__date-lines {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .skeleton-h__date-line {
    height: 0.875rem;
    width: 80%;
    background-color: var(--border-lm05);
    border-radius: var(--radius-sm);
  }

  .skeleton-h__time-line {
    height: 0.7rem;
    width: 55%;
    background-color: var(--border-lm05);
    border-radius: var(--radius-sm);
  }

  /* Content */
  .skeleton-h__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1rem 1.25rem;
    gap: 0.375rem;
    min-width: 0;
  }

  .skeleton-h__badge {
    background-color: var(--border);
    border-radius: var(--radius-pill);
    height: 1.25rem;
    width: 5rem;
  }

  .skeleton-h__title {
    background-color: var(--border);
    border-radius: var(--radius-sm);
    height: 1.125rem;
    width: 75%;
  }

  .skeleton-h__title-short {
    background-color: var(--border);
    border-radius: var(--radius-sm);
    height: 1.125rem;
    width: 50%;
  }

  .skeleton-h__summary {
    background-color: var(--border);
    border-radius: var(--radius-sm);
    height: 0.875rem;
    width: 90%;
  }

  .skeleton-h__location {
    background-color: var(--border);
    border-radius: var(--radius-pill);
    height: 1.25rem;
    width: 6.5rem;
    margin-top: 0.125rem;
  }

  /* Circular CTA */
  .skeleton-h__cta {
    flex-shrink: 0;
    align-self: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--border);
    margin-right: 1.25rem;
  }

  /* Match responsive breakpoint of real card */
  @media (max-width: 480px) {
    .skeleton-h__photo {
      width: 100px;
    }

    .skeleton-h__date-block {
      min-width: 95px;
    }

    .skeleton-h__cta {
      margin-right: 0.75rem;
    }
  }
</style>
