---
/**
 * Skeleton fallback for the events bento grid (Server Island).
 * Renders 4 placeholder cards with pulse animation.
 */
---

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
  {Array.from({ length: 4 }).map((_, i) => (
    <div class={`animate-pulse rounded-2xl bg-card shadow-sm overflow-hidden ${i === 0 || i === 2 ? 'sm:row-span-2' : ''}`}>
      <div class="aspect-[3/4] bg-muted" />
      <div class="p-4 space-y-2">
        <div class="h-5 w-24 rounded-full bg-muted" />
        <div class="h-4 w-3/4 rounded bg-muted" />
        <div class="h-3 w-1/2 rounded bg-muted" />
      </div>
    </div>
  ))}
</div>
