---
/**
 * @file EventGridSkeleton.astro
 * @description Skeleton fallback for the events bento grid (Server Island).
 * Renders 4 placeholder cards with pulse animation using web2 design tokens.
 * Cards at index 0 and 2 span 2 rows on sm+ for a bento layout.
 */
---

<div class="skeleton-grid skeleton-grid--events">
  {Array.from({ length: 4 }).map((_, i) => (
    <div class:list={['skeleton-card skeleton-card--event', { 'skeleton-card--tall': i === 0 || i === 2 }]}>
      <div class="skeleton-image skeleton-image--3-4 skeleton-pulse" />
      <div class="skeleton-content">
        <div class="skeleton-badge skeleton-pulse" />
        <div class="skeleton-line skeleton-line--title skeleton-pulse" />
        <div class="skeleton-line skeleton-line--meta skeleton-pulse" />
      </div>
    </div>
  ))}
</div>

<style>
  @keyframes skeleton-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  .skeleton-pulse {
    animation: skeleton-pulse 1.8s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .skeleton-pulse {
      animation: none;
      opacity: 0.6;
    }
  }

  .skeleton-grid--events {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: var(--space-card-gap);
  }

  @media (min-width: 640px) {
    .skeleton-grid--events {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .skeleton-card--tall {
      grid-row: span 2;
    }
  }

  @media (min-width: 1280px) {
    .skeleton-grid--events {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .skeleton-card--event {
    background-color: var(--core-card);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .skeleton-image {
    background-color: var(--border);
    width: 100%;
    border-radius: var(--radius-organic);
  }

  .skeleton-image--3-4 {
    aspect-ratio: 3 / 4;
  }

  .skeleton-content {
    padding: var(--space-card-content);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skeleton-badge {
    background-color: var(--border);
    border-radius: var(--radius-pill);
    height: 1.25rem;
    width: 6rem;
    align-self: flex-start;
  }

  .skeleton-line {
    background-color: var(--border);
    border-radius: var(--radius-sm);
  }

  .skeleton-line--title {
    width: 75%;
    height: 1rem;
  }

  .skeleton-line--meta {
    width: 50%;
    height: 0.75rem;
  }
</style>
