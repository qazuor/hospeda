---
/**
 * Preview card for blog post listings.
 * Displays featured image, per-category colored badge, title, author,
 * reading time, date, summary, and optional tag pills.
 * Data-source agnostic - receives typed props, not DB entities.
 */
import Badge from '../ui/Badge.astro';
import type { BlogPostCardData } from '../../lib/api/transforms';

interface Props {
  post: BlogPostCardData;
  variant?: 'default' | 'featured';
  locale?: string;
}

const { post, variant = 'default', locale = 'es' } = Astro.props;
const detailUrl = `/${locale}/publicaciones/${post.slug}/`;

/** Format date for display */
const publishedDate = new Date(post.publishedAt).toLocaleDateString(locale === 'es' ? 'es-AR' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

/** Category labels for display */
const categoryLabels: Record<string, string> = {
  GUIDE: 'Guía',
  NEWS: 'Noticias',
  TIPS: 'Consejos',
  REVIEW: 'Reseña',
  STORY: 'Historia',
  DESTINATION: 'Destino',
  CULTURE: 'Cultura',
  FOOD: 'Gastronomía',
  EVENTS: 'Eventos',
  CARNIVAL: 'Carnaval',
  NATURE: 'Naturaleza',
  BEACH: 'Playa',
  GASTRONOMY: 'Gastronomía',
};
const categoryLabel = categoryLabels[post.category] ?? post.category;

/** Per-category color mapping for badge backgrounds */
const categoryColorMap: Record<string, string> = {
  CARNIVAL: 'bg-pink-500',
  TIPS: 'bg-green-500',
  GASTRONOMY: 'bg-orange-500',
  FOOD: 'bg-orange-500',
  NATURE: 'bg-green-500',
  BEACH: 'bg-teal-500',
  CULTURE: 'bg-purple-500',
};
const categoryColorClass = categoryColorMap[post.category] ?? 'bg-primary';

/** Variant-specific classes */
const imageAspectClass = variant === 'featured' ? 'aspect-[16/9]' : 'aspect-[4/3]';
const titleClass = variant === 'featured' ? 'text-2xl' : 'text-lg';
const summaryClampClass = variant === 'featured' ? 'line-clamp-3' : 'line-clamp-2';

/** Tag pills (max 3) */
const displayTags = (post.tags ?? []).slice(0, 3);
---

<article class="group overflow-hidden rounded-xl border border-border bg-surface shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
  <!-- Image container -->
  <a href={detailUrl} class:list={['relative block overflow-hidden', imageAspectClass]}>
    <img
      src={post.featuredImage}
      alt={post.title}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
      transition:name={`entity-${post.slug}`}
    />
    <!-- Category badge -->
    <div class="absolute left-3 top-3">
      <Badge label={categoryLabel} variant="category" colorClass={categoryColorClass} />
    </div>
  </a>

  <!-- Content -->
  <div class="p-4">
    <h3 class:list={['font-semibold line-clamp-2', titleClass]} title={post.title}>
      <a href={detailUrl} class="text-text no-underline hover:text-primary">
        {post.title}
      </a>
    </h3>

    <!-- Metadata: Author and reading time -->
    <div class="mt-1.5 flex items-center gap-2 text-sm text-text-tertiary">
      <span>By {post.authorName}</span>
      <span aria-hidden="true">&middot;</span>
      <span>{post.readingTimeMinutes} min read</span>
    </div>

    <!-- Published date -->
    <time datetime={post.publishedAt} class="mt-1 block text-sm text-text-tertiary">
      {publishedDate}
    </time>

    <!-- Summary -->
    <p class:list={['mt-2 text-sm text-text-secondary', summaryClampClass]}>
      {post.summary}
    </p>

    <!-- Tag pills -->
    {displayTags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {displayTags.map((tag) => (
          <Badge label={tag} variant="tag" />
        ))}
      </div>
    )}
  </div>
</article>
