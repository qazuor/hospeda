---
/**
 * @file DestinationAttractionsGrid.astro
 * @description Grid of destination attractions. Sorted by displayWeight desc,
 * then alphabetically. Renders nothing when the attractions array is empty.
 * Each card shows an icon, attraction name, and optional 2-line description.
 */
import { LocationIcon } from '@repo/icons';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';

/** A single attraction belonging to a destination. */
export interface AttractionItem {
	readonly id: string;
	readonly name: string;
	readonly slug?: string;
	readonly description?: string;
	readonly icon?: string;
	readonly isFeatured?: boolean;
	readonly displayWeight?: number;
}

interface Props {
	readonly attractions: ReadonlyArray<AttractionItem>;
	readonly locale: SupportedLocale;
	/** Maximum number of attraction cards to display. Defaults to 8. */
	readonly maxItems?: number;
}

const { attractions, locale, maxItems = 8 } = Astro.props;
const { t } = createTranslations(locale);

if (!attractions || attractions.length === 0) return;

const sorted = [...attractions]
	.sort((a, b) => {
		const wA = a.displayWeight ?? 0;
		const wB = b.displayWeight ?? 0;
		if (wB !== wA) return wB - wA;
		return a.name.localeCompare(b.name);
	})
	.slice(0, maxItems);
---

<section class="attractions-grid" aria-labelledby="attractions-title">
	<h2 class="attractions-grid__title" id="attractions-title">
		{t('destination.detail.attractions.title', 'Qué hacer acá')}
	</h2>

	<div class="attractions-grid__grid">
		{sorted.map((attraction) => (
			<div class="attractions-grid__card">
				<span class="attractions-grid__icon" aria-hidden="true">
					<LocationIcon size={28} weight="fill" aria-hidden="true" />
				</span>
				<h3 class="attractions-grid__name">{attraction.name}</h3>
				{attraction.description && (
					<p class="attractions-grid__description">{attraction.description}</p>
				)}
			</div>
		))}
	</div>
</section>

<style>
	.attractions-grid {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.attractions-grid__title {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--core-foreground);
		margin: 0;
	}

	.attractions-grid__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	@media (min-width: 640px) {
		.attractions-grid__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1024px) {
		.attractions-grid__grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	.attractions-grid__card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.25rem;
		background-color: var(--core-card);
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		transition: box-shadow var(--duration-fast) ease;
	}

	.attractions-grid__card:hover {
		box-shadow: var(--shadow-card-hover);
	}

	.attractions-grid__icon {
		display: inline-flex;
		color: var(--brand-primary);
	}

	.attractions-grid__name {
		font-family: var(--font-heading);
		font-size: 1rem;
		font-weight: 600;
		color: var(--core-foreground);
		margin: 0;
	}

	.attractions-grid__description {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		color: var(--core-muted-foreground);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
