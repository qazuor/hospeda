---
/**
 * Preview card for destination listings.
 * Displays featured image, name, accommodations count, and summary.
 * Data-source agnostic - receives typed props, not DB entities.
 */
import { FavoriteIcon } from '@repo/icons';

interface DestinationCardData {
  slug: string;
  name: string;
  summary: string;
  featuredImage: string;
  accommodationsCount: number;
  isFeatured: boolean;
  path?: string;
}

interface Props {
  destination: DestinationCardData;
  /** Whether to show the favorite/bookmark button on the card */
  showFavorite?: boolean;
  locale?: string;
}

const { destination, showFavorite = false, locale = 'es' } = Astro.props;

// Use hierarchical path if available, otherwise fallback to slug
const detailPath = destination.path ?? destination.slug;
const detailUrl = `/${locale}/destinos/${detailPath}/`;
---

<article class="group relative overflow-hidden rounded-lg bg-surface shadow-md transition-shadow hover:shadow-lg">
  <!-- Image -->
  <a href={detailUrl} class="relative block aspect-[16/9] overflow-hidden">
    <img
      src={destination.featuredImage}
      alt={destination.name}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
      transition:name={`entity-${destination.slug}`}
    />
    {destination.isFeatured && (
      <div class="absolute right-3 top-3">
        <span class="rounded-full bg-warning/90 px-2.5 py-0.5 text-xs font-medium text-text backdrop-blur-sm">
          Destacado
        </span>
      </div>
    )}
  </a>

  <!-- Favorite button -->
  {showFavorite && (
    <div class="absolute right-3 bottom-3 z-10">
      <button
        type="button"
        class="rounded-full bg-surface/80 p-1.5 shadow-sm backdrop-blur-sm transition-colors hover:bg-surface"
        aria-label={`Agregar ${destination.name} a favoritos`}
      >
        <FavoriteIcon size={20} className="text-text-secondary" aria-hidden="true" />
      </button>
    </div>
  )}

  <!-- Content -->
  <div class="p-4">
    <h3 class="text-lg font-semibold">
      <a href={detailUrl} class="text-text no-underline hover:text-primary">
        {destination.name}
      </a>
    </h3>

    <p class="mt-1 text-sm text-text-tertiary">
      {destination.accommodationsCount} {destination.accommodationsCount === 1 ? 'alojamiento' : 'alojamientos'}
    </p>

    <p class="mt-2 line-clamp-2 text-sm text-text-secondary">
      {destination.summary}
    </p>
  </div>
</article>
