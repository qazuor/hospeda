---
/**
 * @file DestinationPOISection.astro
 * @description Points-of-interest (POI) section for the destination detail
 * page (HOS-113 Phase 4, extended HOS-138, HOS-146). Renders the
 * destination's PRIMARY POIs as a **list / grid** — NOT map pins; the
 * multi-marker map lives separately in `DestinationPOIMap.client.tsx`
 * (HOS-146), rendered as enrichment alongside this SSR grid, which stays the
 * indexable content source (SSR-first principle, apps/web/CLAUDE.md). Built
 * fresh — this does NOT resurrect the dead `DestinationAttractionsGrid.astro`,
 * though its displayWeight-then-alphabetical sort + card shape informed this
 * one.
 *
 * HOS-146: the API payload now carries BOTH `PRIMARY` (city-core) and
 * `NEARBY` (far-out, median 9-55km away) POIs. This grid explicitly filters
 * to `relation !== 'NEARBY'` so it keeps showing exactly what it showed
 * before HOS-146 shipped NEARBY — zero visual regression. NEARBY POIs only
 * ever appear on the map, behind the "ver alrededores" toggle.
 *
 * Each card shows: a type-derived icon, the display name (HOS-138 resolves
 * admin-editable multilang `nameI18n` content, degrading to a humanized slug
 * when absent — the legacy `destinations.poiNames.<slug>` i18n keys were
 * removed in HOS-138, see `poi-labels.ts`), a translated type label
 * (`destinations.poiTypeLabels.<TYPE>`), and an optional 2-line description
 * (same multilang-first/legacy-fallback order via `descriptionI18n` /
 * `description`). Ordered featured-first, then by `displayWeight`
 * descending, then by display name (§8). Renders nothing when the
 * destination has no PRIMARY POIs, mirroring how the attractions grid guards
 * against an empty array.
 */
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { translatePoiCategoryLabel, translatePoiName } from '@/lib/poi-labels';
import { getPointOfInterestTypeIcon } from '@/lib/poi-type-icons';
import type { I18nTextLike } from '@/lib/resolve-i18n-text';
import { resolveI18nText } from '@/lib/resolve-i18n-text';
import { getPoiCategoryColorScheme, getPoiCategoryIcon } from '@repo/icons';

/** A single point of interest belonging to a destination. */
export interface DestinationPOIItem {
	readonly id: string;
	readonly slug: string;
	readonly type: string;
	readonly description?: string | null;
	readonly isFeatured?: boolean;
	readonly displayWeight?: number;
	/**
	 * Admin-editable multilang name content (HOS-138); null for POIs not yet
	 * migrated. `I18nTextLike` (not the stricter `I18nText`) because the
	 * source payload allows null `en`/`pt` for Spanish-sourced imports — same
	 * shape `poi-labels.ts`'s `translatePoiName` already accepts.
	 */
	readonly nameI18n?: I18nTextLike | null;
	/** Admin-editable multilang description content (HOS-138); null for POIs not yet migrated. */
	readonly descriptionI18n?: I18nTextLike | null;
	/**
	 * PRIMARY (city-core) vs NEARBY (far-out) — HOS-146. Only PRIMARY POIs
	 * render in this grid; `undefined` is treated as PRIMARY (back-compat
	 * with callers that predate HOS-146).
	 */
	readonly relation?: 'PRIMARY' | 'NEARBY';
	/** Unused by the grid; present so the page can share one transform shape with DestinationPOIMap (HOS-146). */
	readonly lat?: number | null;
	/** Unused by the grid; present so the page can share one transform shape with DestinationPOIMap (HOS-146). */
	readonly long?: number | null;
	/**
	 * The POI's primary category (HOS-182); `null`/absent when it has none
	 * (expected, known-dirty data — HOS-177). `slug` drives the card icon +
	 * icon color and `nameI18n` the badge label, both falling back to the
	 * legacy `type`-based mapping when absent.
	 */
	readonly primaryCategory?: {
		readonly slug: string;
		readonly nameI18n?: I18nTextLike | null;
	} | null;
	/**
	 * The POI's full category set (HOS-147) — every category slug, not just the
	 * primary. Emitted as the card's `data-poi-categories` attribute so the
	 * client-side thematic filter island (`DestinationPOIFilter.client.tsx`)
	 * can show/hide this card by intersecting it with the active selection.
	 */
	readonly categories?: ReadonlyArray<{ readonly slug: string }>;
}

interface Props {
	readonly pointsOfInterest: ReadonlyArray<DestinationPOIItem>;
	readonly locale: SupportedLocale;
}

const { pointsOfInterest, locale } = Astro.props;
const { t } = createTranslations(locale);

if (!pointsOfInterest || pointsOfInterest.length === 0) return;

// HOS-146: the payload now carries NEARBY POIs too (map-only) — filter them
// out here so the grid keeps showing exactly what it showed pre-HOS-146.
const primaryOnly = pointsOfInterest.filter((poi) => poi.relation !== 'NEARBY');

if (primaryOnly.length === 0) return;

const sorted = [...primaryOnly]
	.map((poi) => ({
		...poi,
		displayName: translatePoiName({ slug: poi.slug, nameI18n: poi.nameI18n, locale }),
		resolvedDescription: resolveI18nText(poi.descriptionI18n, locale) || poi.description
	}))
	.sort((a, b) => {
		// Featured first.
		const featuredDelta = (a.isFeatured ? 0 : 1) - (b.isFeatured ? 0 : 1);
		if (featuredDelta !== 0) return featuredDelta;
		// Then by displayWeight descending.
		const wA = a.displayWeight ?? 0;
		const wB = b.displayWeight ?? 0;
		if (wB !== wA) return wB - wA;
		// Then alphabetically by the resolved display name.
		return a.displayName.localeCompare(b.displayName);
	});

// HOS-181: cap the visible grid at the 12 most important POIs. Every card still
// ships in the same grid (SSR / crawlable, per apps/web/CLAUDE.md SSR-first) —
// a sibling native <details> reveals the rest via CSS. This is a purely visual
// cut, never a server-side truncation, so no PRIMARY POI leaves crawler reach.
const POI_VISIBLE_LIMIT = 12;
const hasOverflow = sorted.length > POI_VISIBLE_LIMIT;
const overflowCount = Math.max(0, sorted.length - POI_VISIBLE_LIMIT);
---

<section class="poi-section" aria-labelledby="poi-section-title">
	<h2 class="poi-section__title" id="poi-section-title">
		{t('destinations.detailPage.pointsOfInterestTitle', 'Puntos de interés')}
	</h2>

	<div class="poi-section__grid">
		{sorted.map((poi) => {
			const categorySlug = poi.primaryCategory?.slug;
			const Icon = categorySlug
				? getPoiCategoryIcon({ slug: categorySlug })
				: getPointOfInterestTypeIcon({ type: poi.type });
			// HOS-182: an uncategorized POI must look exactly as it did before —
			// never resolve the color scheme for a nullish slug (its `services`
			// bucket carries real meaning it would falsely apply here).
			const iconColor = categorySlug
				? getPoiCategoryColorScheme({ slug: categorySlug }).fill
				: 'var(--brand-primary)';
			const typeLabel = translatePoiCategoryLabel({
				t,
				type: poi.type,
				primaryCategory: poi.primaryCategory,
				locale
			});
			// HOS-147: emit every category slug so the client-side thematic
			// filter island can match this card against the active selection.
			const categorySlugs = (poi.categories ?? []).map((c) => c.slug).join(',');
			return (
				<div class="poi-section__card" data-poi-card data-poi-categories={categorySlugs}>
					<span class="poi-section__icon" aria-hidden="true">
						<Icon size={28} weight="fill" color={iconColor} aria-hidden="true" />
					</span>
					<h3 class="poi-section__name">{poi.displayName}</h3>
					<span class="poi-section__type-badge">{typeLabel}</span>
					{poi.resolvedDescription && (
						<p class="poi-section__description">{poi.resolvedDescription}</p>
					)}
				</div>
			);
		})}
	</div>

	<p class="poi-section__empty" data-poi-empty hidden>
		{t(
			'destinations.detailPage.pointsOfInterestEmptyFiltered',
			'No hay puntos de interés para las categorías seleccionadas.'
		)}
	</p>

	{
		hasOverflow && (
			<details class="poi-section__more">
				<summary class="poi-section__more-toggle">
					<span class="poi-section__more-label-closed">
						{t('ui.filter.showMore', 'Ver más')}
					</span>
					<span class="poi-section__more-label-open">
						{t('ui.filter.showLess', 'Ver menos')}
					</span>
					<span class="poi-section__more-count">{overflowCount}</span>
				</summary>
			</details>
		)
	}
</section>

<style>
	.poi-section {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.poi-section__title {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--core-foreground);
		margin: 0;
	}

	.poi-section__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	@media (min-width: 640px) {
		.poi-section__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1024px) {
		.poi-section__grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	.poi-section__card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 0.85rem;
		background-color: var(--core-card);
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		transition: box-shadow var(--duration-fast) ease;
	}

	/* HOS-147: the thematic filter island hides non-matching cards by setting
	   the `hidden` attribute; the card's own `display: flex` would otherwise
	   defeat the UA `[hidden] { display: none }` rule (author-normal beats
	   UA-normal regardless of specificity), so re-assert it explicitly. */
	.poi-section__card[hidden] {
		display: none;
	}

	.poi-section__card:hover {
		box-shadow: var(--shadow-card-hover);
	}

	.poi-section__icon {
		display: inline-flex;
		color: var(--brand-primary);
	}

	.poi-section__name {
		font-family: var(--font-heading);
		font-size: 1rem;
		font-weight: 600;
		color: var(--core-foreground);
		margin: 0;
	}

	.poi-section__type-badge {
		align-self: flex-start;
		font-family: var(--font-sans);
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--brand-primary);
		background-color: var(--surface-warm);
		border-radius: var(--radius-pill);
		padding: 0.25rem 0.75rem;
	}

	.poi-section__description {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		color: var(--core-muted-foreground);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.poi-section__empty {
		font-family: var(--font-sans);
		font-size: 0.9375rem;
		color: var(--core-muted-foreground);
		margin: 0;
		padding: 1rem 0;
	}

	/* HOS-181: visual-only cut. When the disclosure is closed, hide every card
	 * past the 12th. All cards stay in the DOM (SSR-first, crawlable) — this
	 * never removes content from the served HTML. `nth-child(n + 13)` pairs with
	 * POI_VISIBLE_LIMIT = 12; when there is no overflow the <details> is absent,
	 * `:has()` does not match, and all cards show. */
	.poi-section:has(.poi-section__more:not([open])) .poi-section__card:nth-child(n + 13) {
		display: none;
	}

	/* HOS-147 × HOS-181: while a thematic category filter is active (the island
	 * sets `data-poi-filtered` on the section), the filter IS the narrowing
	 * mechanism — the 12-card overflow cut must not also hide a filtered-in card
	 * just because it sits past the 12th DOM position, and the "Ver más" control
	 * is redundant. So hide the toggle and re-show every MATCHING card past the
	 * 12th. `[hidden]` (non-matching) cards stay hidden via the rule below —
	 * hence the `:not([hidden])`. Higher specificity than the HOS-181 cut. */
	.poi-section[data-poi-filtered] .poi-section__more {
		display: none;
	}

	.poi-section[data-poi-filtered]:has(.poi-section__more:not([open]))
		.poi-section__card:nth-child(n + 13):not([hidden]) {
		display: flex;
	}

	/* Native <details> used purely as a stateful toggle — the cards live in the
	 * sibling grid and are hidden/shown by the `:has()` rule above. Mirrors the
	 * attractions-filter disclosure on the destinations listing. */
	.poi-section__more {
		align-self: flex-start;
	}

	.poi-section__more-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background-color: transparent;
		color: var(--core-muted-foreground);
		border: 1px dashed var(--core-muted-foreground);
		border-radius: var(--radius-pill);
		padding: 0.375rem 0.875rem;
		font-family: var(--font-sans);
		font-size: 0.875rem;
		font-weight: 600;
		cursor: pointer;
		list-style: none;
		user-select: none;
	}

	.poi-section__more-toggle::-webkit-details-marker {
		display: none;
	}

	.poi-section__more-toggle:hover,
	.poi-section__more[open] .poi-section__more-toggle {
		color: var(--core-foreground);
		border-color: var(--core-foreground);
	}

	/* Two-state label: closed = "Ver más", open = "Ver menos". Both ship through
	 * i18n so translators never touch CSS ::after content swaps. */
	.poi-section__more:not([open]) .poi-section__more-label-open {
		display: none;
	}

	.poi-section__more[open] .poi-section__more-label-closed {
		display: none;
	}

	/* The count matters only while the tail is hidden ("Ver más (59)"); once
	 * expanded the cards convey it and the count becomes noise. */
	.poi-section__more[open] .poi-section__more-count {
		display: none;
	}

	.poi-section__more-count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.25rem;
		height: 1.125rem;
		padding: 0 0.3125rem;
		border-radius: var(--radius-pill);
		background-color: var(--surface-warm);
		color: var(--brand-primary);
		font-size: 0.75rem;
		font-weight: 700;
	}
</style>
