---
/**
 * @file DestinationFaqPlaceholder.astro
 * @description "Coming soon" placeholder for the destination FAQ section.
 *
 * Renders a dashed-border container with an icon and localised copy to
 * communicate that FAQ content is being prepared. Marked with an aria-label
 * so screen readers understand the pending state.
 */
import { FaqsIcon } from '@repo/icons';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';

interface Props {
	readonly locale: SupportedLocale;
}

const { locale } = Astro.props;
const { t } = createTranslations(locale);
---

<section
	class="dest-faq-placeholder"
	aria-label={t('destination.detail.faq.ariaLabel', 'Preguntas frecuentes — próximamente')}
	aria-labelledby="dest-faq-title"
>
	<h2 class="dest-faq-placeholder__title" id="dest-faq-title">
		{t('destination.detail.faq.title', 'Preguntas frecuentes')}
	</h2>

	<div class="dest-faq-placeholder__container">
		<span class="dest-faq-placeholder__icon" aria-hidden="true">
			<FaqsIcon size={48} weight="regular" aria-hidden="true" />
		</span>
		<p class="dest-faq-placeholder__body">
			{t(
				'destination.detail.faq.placeholder',
				'Estamos preparando respuestas a las preguntas más frecuentes sobre este destino.'
			)}
		</p>
	</div>
</section>

<style>
	.dest-faq-placeholder {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.dest-faq-placeholder__title {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--core-foreground);
		margin: 0;
	}

	.dest-faq-placeholder__container {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		padding: 2rem 1.5rem;
		border: 2px dashed var(--border);
		border-radius: var(--radius-card);
		text-align: center;
	}

	.dest-faq-placeholder__icon {
		display: inline-flex;
		color: var(--core-muted-foreground);
		opacity: 0.5;
	}

	.dest-faq-placeholder__body {
		font-family: var(--font-sans);
		font-size: 0.95rem;
		color: var(--core-muted-foreground);
		max-width: 44ch;
		margin: 0;
		line-height: 1.6;
	}
</style>
