---
/**
 * @file DestinationDetailHeader.astro
 * @description Destination detail page header with a history-aware back
 * button, name, attraction badges, bookmark counter, and favorite button.
 *
 * Layout (HOS-84): a vertical stack — a back-button row on top, then a
 * 2-column `.dest-header__body` row where `.dest-header__main` holds the
 * name + attractions + meta and `.dest-header__favorite` anchors the heart
 * button on the right. The favorite stays right-aligned regardless of
 * viewport or compact mode.
 *
 * Compact behavior comes from the shared `.wh-compact-*` utility classes
 * (contract defined once in WaveHeader.astro): `wh-compact-row` collapses the
 * main stack to one line, `wh-compact-title` shrinks the H1, `wh-compact-hide`
 * drops the back-button row + attractions + meta. There are no status badges
 * on this header, so `wh-compact-badge` is not used. Only the genuinely
 * destination-specific body cross-axis alignment override remains local
 * below.
 */
import { FavoriteIcon } from '@repo/icons';
import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';
import HeaderBackButton from '@/components/shared/ui/HeaderBackButton.astro';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';

/** Minimal attraction shape rendered as a header badge. */
export interface HeaderAttraction {
	readonly id: string;
	readonly name: string;
	readonly slug?: string;
	readonly displayWeight?: number;
}

interface Props {
	readonly destinationId: string;
	readonly name: string;
	readonly locale: SupportedLocale;
	readonly isAuthenticated?: boolean;
	readonly initialIsFavorited?: boolean;
	readonly initialBookmarkId?: string | null;
	readonly bookmarkCount?: number;
	/** Optional attractions, rendered as badges below the name. */
	readonly attractions?: ReadonlyArray<HeaderAttraction>;
	/** Maximum number of attractions to render as badges. Defaults to 6. */
	readonly maxAttractions?: number;
}

const {
	destinationId,
	name,
	locale,
	isAuthenticated = false,
	initialIsFavorited,
	initialBookmarkId = null,
	bookmarkCount,
	attractions = [],
	maxAttractions = 6
} = Astro.props;
const { t, tPlural } = createTranslations(locale);

// Attractions: highest displayWeight first, then alphabetical, capped to maxAttractions.
const sortedAttractions = [...attractions]
	.sort((a, b) => {
		const wA = a.displayWeight ?? 0;
		const wB = b.displayWeight ?? 0;
		if (wB !== wA) return wB - wA;
		return a.name.localeCompare(b.name);
	})
	.slice(0, maxAttractions);
const remainingAttractions = Math.max(0, attractions.length - sortedAttractions.length);
---

<header class="dest-header">
	<div class="dest-header__back-row wh-compact-hide">
		<HeaderBackButton href={`/${locale}/destinos/`} locale={locale} />
	</div>

	<div class="dest-header__body">
		<div class="dest-header__main wh-compact-row">
			<h1 class="dest-header__name wh-compact-title">{name}</h1>

			{sortedAttractions.length > 0 && (
				<ul class="dest-header__attractions wh-compact-hide" aria-label={t('destinations.detail.attractions.title', 'Qué hacer acá')}>
					{sortedAttractions.map((a) => (
						<li class="dest-header__attraction-badge">{a.name}</li>
					))}
					{remainingAttractions > 0 && (
						<li class="dest-header__attraction-badge dest-header__attraction-badge--more">
							+{remainingAttractions}
						</li>
					)}
				</ul>
			)}

			{bookmarkCount !== undefined && (
				<div class="dest-header__meta wh-compact-hide">
					<span
						class="dest-header__bookmark-count"
						aria-label={bookmarkCount === 0
							? t('destinations.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
							: tPlural('destinations.detail.bookmark_count', bookmarkCount)}
					>
						<FavoriteIcon size={14} weight="fill" aria-hidden="true" />
						{bookmarkCount === 0
							? t('destinations.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
							: tPlural('destinations.detail.bookmark_count', bookmarkCount)}
					</span>
				</div>
			)}
		</div>

		<div class="dest-header__favorite">
			<FavoriteButton
				client:load
				entityId={destinationId}
				entityType="DESTINATION"
				initialIsFavorited={initialIsFavorited}
				initialBookmarkId={initialBookmarkId}
				isAuthenticated={isAuthenticated}
				variant="standalone"
				locale={locale}
			/>
		</div>
	</div>
</header>

<style>
	/* Vertical stack: back-button row on top, then the body row. */
	.dest-header {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	/* Back-button row — collapses out via `wh-compact-hide` in compact mode, so
	   it needs its own max-height/opacity transition to animate. */
	.dest-header__back-row {
		overflow: hidden;
		max-height: 3em;
		opacity: 1;
		transition:
			max-height 0.3s ease,
			opacity 0.2s ease;
	}

	/* Body: main content stretches, favorite stays right. */
	.dest-header__body {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		gap: 0.75rem;
	}

	.dest-header__main {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		transition: gap 0.3s ease;
	}

	.dest-header__favorite {
		flex-shrink: 0;
		margin-left: auto;
	}

	.dest-header__attractions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
		transition: max-height 0.3s ease, opacity 0.2s ease;
	}

	.dest-header__attraction-badge {
		display: inline-flex;
		align-items: center;
		border: 1px solid var(--brand-primary-a25);
		border-radius: var(--radius-pill);
		background-color: var(--brand-primary-a10);
		color: var(--brand-primary);
		font-family: var(--font-sans);
		font-size: 0.75rem;
		font-weight: 600;
		padding: 3px 10px;
		line-height: 1.4;
		white-space: nowrap;
		transition: padding 0.3s ease, font-size 0.3s ease;
	}

	.dest-header__attraction-badge--more {
		background-color: var(--core-card);
		color: var(--core-muted-foreground);
		border-color: var(--border);
	}

	.dest-header__name {
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		font-weight: 700;
		color: var(--core-foreground);
		margin: 0;
		line-height: 1.15;
		transition: font-size 0.3s ease;
	}

	.dest-header__meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		overflow: hidden;
		max-height: 3em;
		opacity: 1;
		transition:
			max-height 0.3s ease,
			opacity 0.2s ease;
	}

	.dest-header__bookmark-count {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--core-muted-foreground);
	}

	.dest-header__bookmark-count :global(svg) {
		color: var(--rating-star);
	}

	/* =========================================================
	 * Compact state — only the genuinely destination-specific body
	 * cross-axis alignment override remains here; the row collapse, title
	 * shrink, and attractions/meta/back hide all come from the shared
	 * `.wh-compact-*` utilities applied in the markup (contract in
	 * WaveHeader.astro).
	 * ========================================================= */
	:global(.wave-header--compact) .dest-header__body {
		align-items: center;
	}

	@media (prefers-reduced-motion: reduce) {
		.dest-header__back-row,
		.dest-header__main,
		.dest-header__attractions,
		.dest-header__attraction-badge,
		.dest-header__name,
		.dest-header__meta {
			transition: none;
		}
	}
</style>
