---
/**
 * @file DestinationDetailHeader.astro
 * @description Destination detail page header with name, attraction badges,
 * bookmark counter, and favorite button. Designed to live inside a
 * WaveHeader so it can collapse to a single row when the wave goes
 * compact on scroll (mirroring the accommodation DetailHeader pattern).
 *
 * Layout: 2-column flex at all times — `.dest-header__main` on the left
 * (name + attractions + meta) and `.dest-header__favorite` on the right.
 *
 * Compact mode: when the page-header is wrapped by a `.wave-header--compact`
 * ancestor (toggled by WaveHeader's IntersectionObserver), the inner main
 * flow collapses to a single wrapped row, fonts shrink, and the bookmark
 * meta + attractions are hidden so only the name remains visible.
 */
import { FavoriteIcon } from '@repo/icons';
import { FavoriteButton } from '@/components/shared/favorite/FavoriteButton.client';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';

/** Minimal attraction shape rendered as a header badge. */
export interface HeaderAttraction {
	readonly id: string;
	readonly name: string;
	readonly slug?: string;
	readonly displayWeight?: number;
}

interface Props {
	readonly destinationId: string;
	readonly name: string;
	readonly locale: SupportedLocale;
	readonly isAuthenticated?: boolean;
	readonly initialIsFavorited?: boolean;
	readonly initialBookmarkId?: string | null;
	readonly bookmarkCount?: number;
	/** Optional attractions, rendered as badges below the name. */
	readonly attractions?: ReadonlyArray<HeaderAttraction>;
	/** Maximum number of attractions to render as badges. Defaults to 6. */
	readonly maxAttractions?: number;
}

const {
	destinationId,
	name,
	locale,
	isAuthenticated = false,
	initialIsFavorited,
	initialBookmarkId = null,
	bookmarkCount,
	attractions = [],
	maxAttractions = 6
} = Astro.props;
const { t, tPlural } = createTranslations(locale);

// Attractions: highest displayWeight first, then alphabetical, capped to maxAttractions.
const sortedAttractions = [...attractions]
	.sort((a, b) => {
		const wA = a.displayWeight ?? 0;
		const wB = b.displayWeight ?? 0;
		if (wB !== wA) return wB - wA;
		return a.name.localeCompare(b.name);
	})
	.slice(0, maxAttractions);
const remainingAttractions = Math.max(0, attractions.length - sortedAttractions.length);
---

<header class="dest-header">
	<div class="dest-header__main">
		<h1 class="dest-header__name">{name}</h1>

		{sortedAttractions.length > 0 && (
			<ul class="dest-header__attractions" aria-label={t('destinations.detail.attractions.title', 'Qué hacer acá')}>
				{sortedAttractions.map((a) => (
					<li class="dest-header__attraction-badge">{a.name}</li>
				))}
				{remainingAttractions > 0 && (
					<li class="dest-header__attraction-badge dest-header__attraction-badge--more">
						+{remainingAttractions}
					</li>
				)}
			</ul>
		)}

		{bookmarkCount !== undefined && (
			<div class="dest-header__meta">
				<span
					class="dest-header__bookmark-count"
					aria-label={bookmarkCount === 0
						? t('destinations.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
						: tPlural('destinations.detail.bookmark_count', bookmarkCount)}
				>
					<FavoriteIcon size={14} weight="fill" aria-hidden="true" />
					{bookmarkCount === 0
						? t('destinations.detail.bookmark_count_zero', 'Sé el primero en guardarlo')
						: tPlural('destinations.detail.bookmark_count', bookmarkCount)}
				</span>
			</div>
		)}
	</div>

	<div class="dest-header__favorite">
		<FavoriteButton
			client:load
			entityId={destinationId}
			entityType="DESTINATION"
			initialIsFavorited={initialIsFavorited}
			initialBookmarkId={initialBookmarkId}
			isAuthenticated={isAuthenticated}
			variant="standalone"
			locale={locale}
		/>
	</div>
</header>

<style>
	.dest-header {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		gap: 0.75rem;
	}

	.dest-header__main {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		transition: flex-direction 0.3s ease, gap 0.3s ease;
	}

	.dest-header__favorite {
		flex-shrink: 0;
		margin-left: auto;
	}

	.dest-header__attractions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
		transition: max-height 0.3s ease, opacity 0.2s ease;
	}

	.dest-header__attraction-badge {
		display: inline-flex;
		align-items: center;
		border: 1px solid var(--brand-primary-a25);
		border-radius: var(--radius-pill);
		background-color: var(--brand-primary-a10);
		color: var(--brand-primary);
		font-family: var(--font-sans);
		font-size: 0.75rem;
		font-weight: 600;
		padding: 3px 10px;
		line-height: 1.4;
		white-space: nowrap;
		transition: padding 0.3s ease, font-size 0.3s ease;
	}

	.dest-header__attraction-badge--more {
		background-color: var(--core-card);
		color: var(--core-muted-foreground);
		border-color: var(--border);
	}

	.dest-header__name {
		font-family: var(--font-heading);
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		font-weight: 700;
		color: var(--core-foreground);
		margin: 0;
		line-height: 1.15;
		transition: font-size 0.3s ease;
	}

	.dest-header__meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		overflow: hidden;
		max-height: 3em;
		opacity: 1;
		transition:
			max-height 0.3s ease,
			opacity 0.2s ease;
	}

	.dest-header__bookmark-count {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--core-muted-foreground);
	}

	.dest-header__bookmark-count :global(svg) {
		color: var(--rating-star);
	}

	/* =========================================================
	 * Compact state — collapses everything in __main to one row.
	 * Only the type-badge and the name remain readable; meta hides.
	 * ========================================================= */
	:global(.wave-header--compact) .dest-header {
		align-items: center;
	}

	:global(.wave-header--compact) .dest-header__main {
		flex-direction: row;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	:global(.wave-header--compact) .dest-header__attractions {
		max-height: 0;
		opacity: 0;
		pointer-events: none;
		overflow: hidden;
	}

	:global(.wave-header--compact) .dest-header__name {
		font-size: clamp(1rem, 2vw, 1.25rem);
	}

	:global(.wave-header--compact) .dest-header__meta {
		max-height: 0;
		opacity: 0;
		pointer-events: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.dest-header__main,
		.dest-header__attractions,
		.dest-header__attraction-badge,
		.dest-header__name,
		.dest-header__meta {
			transition: none;
		}
	}
</style>
