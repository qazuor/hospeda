---
/**
 * Desktop hover/focus preview card for destination cards.
 * Shows expanded info: summary, gallery thumbnails, rating dimensions, and CTA.
 * Triggered via vanilla JS mouseenter/mouseleave and focusin/focusout.
 * Only rendered on desktop (lg+), hidden on mobile/tablet.
 */
import { t, type SupportedLocale } from '../../lib/i18n';

interface PreviewData {
  slug: string;
  name: string;
  summary: string;
  path?: string;
  gallery?: ReadonlyArray<{ readonly url: string; readonly caption?: string }>;
  ratingDimensions?: Readonly<Record<string, number>>;
}

interface Props {
  destinations: ReadonlyArray<PreviewData>;
  locale?: SupportedLocale;
  class?: string;
}

const { destinations, locale = 'es', class: className } = Astro.props;

const galleryLabel = t({ locale, namespace: 'destinations', key: 'featured.preview.gallery', fallback: 'Gallery' });
const ratingsLabel = t({ locale, namespace: 'destinations', key: 'featured.preview.topRatings', fallback: 'Top ratings' });
const ctaLabel = t({ locale, namespace: 'destinations', key: 'featured.preview.viewAccommodations', fallback: 'View accommodations' });

/** Rating dimension display names from i18n */
const DIMENSION_KEYS = ['landscape', 'gastronomy', 'safety', 'nightlife', 'culture', 'nature', 'beaches', 'activities'] as const;
const labels: Readonly<Record<string, string>> = Object.fromEntries(
  DIMENSION_KEYS.map((key) => [
    key,
    t({ locale, namespace: 'destinations', key: `featured.preview.dimensions.${key}`, fallback: key }),
  ])
);
---

{/* Hidden preview panels - one per destination, positioned via JS */}
<div class:list={['destination-previews hidden lg:block', className]} inert>
  {destinations.map((dest) => {
    const detailUrl = `/${locale}/destinos/${dest.path ?? dest.slug}/`;
    const galleryImages = (dest.gallery ?? []).slice(0, 3);
    const topRatings = Object.entries(dest.ratingDimensions ?? {})
      .filter(([, val]) => val > 0)
      .sort(([, a], [, b]) => b - a)
      .slice(0, 4);

    return (
      <div
        class="destination-preview pointer-events-none absolute z-50 w-72 rounded-xl border border-border bg-surface p-4 opacity-0 shadow-xl transition-all duration-200"
        data-preview-for={dest.slug}
      >
        {/* Summary */}
        <p class="text-sm text-text-secondary line-clamp-3">{dest.summary}</p>

        {/* Gallery thumbnails */}
        {galleryImages.length > 0 && (
          <div class="mt-3">
            <p class="mb-1.5 text-xs font-medium text-text-secondary">{galleryLabel}</p>
            <div class="flex gap-1.5">
              {galleryImages.map((img) => (
                <img
                  src={img.url}
                  alt={img.caption ?? dest.name}
                  class="h-16 w-20 rounded-md object-cover"
                  loading="lazy"
                  width="80"
                  height="64"
                />
              ))}
            </div>
          </div>
        )}

        {/* Rating dimensions */}
        {topRatings.length > 0 && (
          <div class="mt-3">
            <p class="mb-1.5 text-xs font-medium text-text-secondary">{ratingsLabel}</p>
            <div class="space-y-1">
              {topRatings.map(([key, val]) => (
                <div class="flex items-center justify-between text-xs">
                  <span class="text-text">{labels[key] ?? key}</span>
                  <div class="flex items-center gap-1.5">
                    <div
                      class="h-1.5 w-16 overflow-hidden rounded-full bg-border"
                      role="meter"
                      aria-valuenow={val}
                      aria-valuemin={0}
                      aria-valuemax={5}
                      aria-label={labels[key] ?? key}
                    >
                      <div
                        class="h-full rounded-full bg-primary"
                        style={`width: ${(val / 5) * 100}%`}
                      />
                    </div>
                    <span class="w-6 text-right font-medium text-text-secondary">{val.toFixed(1)}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* CTA button */}
        <a
          href={detailUrl}
          class="mt-3 block w-full rounded-lg bg-primary px-3 py-2 text-center text-sm font-medium text-white transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {ctaLabel}
        </a>
      </div>
    );
  })}
</div>

<script>
  import { calculatePreviewPosition } from './destination-preview.utils';

  /** Track cleanup functions to avoid listener accumulation on page navigation */
  let previewCleanup: (() => void) | null = null;

  function initDestinationPreviews(): void {
    /* Clean up previous listeners before re-initializing */
    if (previewCleanup) {
      previewCleanup();
      previewCleanup = null;
    }

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const cards = document.querySelectorAll('[data-destination-slug]');
    const previewContainer = document.querySelector('.destination-previews');

    if (!previewContainer || cards.length === 0) return;

    /* Use matchMedia for responsive check (handles orientation changes) */
    const desktopQuery = window.matchMedia('(min-width: 1024px)');
    if (!desktopQuery.matches) return;

    let hoverTimeout: ReturnType<typeof setTimeout> | null = null;
    let activePreview: HTMLElement | null = null;
    const abortController = new AbortController();
    const { signal } = abortController;

    function showPreview(card: HTMLElement): void {
      const slug = card.getAttribute('data-destination-slug');
      if (!slug) return;

      const preview = previewContainer!.querySelector(`[data-preview-for="${slug}"]`) as HTMLElement | null;
      if (!preview) return;

      /* Remove inert so the preview panel is accessible */
      previewContainer!.removeAttribute('inert');

      /* Batch all DOM reads first, then writes (avoid layout thrashing) */
      const rect = card.getBoundingClientRect();
      const previewWidth = preview.offsetWidth || 288;
      /* Use actual rendered height for accurate overflow check */
      const previewHeight = preview.offsetHeight || 320;

      /* Compute position using extracted utility */
      const { left, top } = calculatePreviewPosition({
        triggerRect: { top: rect.top, bottom: rect.bottom, left: rect.left },
        previewWidth,
        previewHeight,
        viewportWidth: window.innerWidth,
        viewportHeight: window.innerHeight
      });

      /* Single DOM write */
      preview.style.cssText = `position: fixed; left: ${left}px; top: ${top}px;`;

      /* Show with transition */
      preview.classList.remove('opacity-0', 'pointer-events-none');
      preview.classList.add('opacity-100', 'pointer-events-auto');
      if (!prefersReducedMotion) {
        preview.style.transform = 'translateY(0)';
      }
      activePreview = preview;
    }

    function hidePreview(): void {
      if (hoverTimeout) {
        clearTimeout(hoverTimeout);
        hoverTimeout = null;
      }
      if (activePreview) {
        activePreview.classList.remove('opacity-100', 'pointer-events-auto');
        activePreview.classList.add('opacity-0', 'pointer-events-none');
        activePreview = null;
      }
      /* Restore inert when no preview is visible */
      previewContainer?.setAttribute('inert', '');
    }

    for (const card of cards) {
      const el = card as HTMLElement;

      el.addEventListener('mouseenter', () => {
        hidePreview();
        hoverTimeout = setTimeout(() => showPreview(el), 300);
      }, { signal });

      el.addEventListener('mouseleave', () => {
        hidePreview();
      }, { signal });

      el.addEventListener('focusin', () => {
        hidePreview();
        hoverTimeout = setTimeout(() => showPreview(el), 300);
      }, { signal });

      el.addEventListener('focusout', () => {
        hidePreview();
      }, { signal });
    }

    /* Hide on scroll to prevent misaligned previews */
    window.addEventListener('scroll', hidePreview, { passive: true, signal });

    /* Escape key closes active preview */
    document.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape') {
        hidePreview();
      }
    }, { signal });

    /* Store cleanup function */
    previewCleanup = () => {
      hidePreview();
      abortController.abort();
    };
  }

  initDestinationPreviews();
  document.addEventListener('astro:page-load', initDestinationPreviews);
  document.addEventListener('astro:before-swap', () => {
    if (previewCleanup) {
      previewCleanup();
      previewCleanup = null;
    }
  });
</script>
