---
/**
 * @file DestinationPreview.astro
 * @description Desktop-only hover/focus preview panel for destination cards.
 * Displays an expanded info card (summary, gallery thumbnails, top rating
 * dimensions, and a CTA link) triggered by mouseenter/focusin events on
 * cards with a `data-destination-slug` attribute.
 *
 * Implementation details:
 * - Hidden panels (one per destination) are rendered server-side and positioned
 *   via `position: fixed` at runtime to avoid layout shifts.
 * - The container uses `inert` to hide all panels from AT until one is shown.
 * - Visibility transitions use class swaps (opacity-0 <-> opacity-100).
 * - Respects `prefers-reduced-motion`.
 * - Only active on desktop (min-width: 1024px).
 * - Cleanup runs on astro:before-swap to prevent listener accumulation.
 */

import { createT, type SupportedLocale } from '../../lib/i18n';

/** A single destination's data needed to render a preview panel. */
interface PreviewData {
    /** Unique slug identifying this destination. Must match the card's data-destination-slug. */
    slug: string;
    /** Display name of the destination. */
    name: string;
    /** Short description shown in the preview body. */
    summary: string;
    /** Optional URL path segment (falls back to slug). */
    path?: string;
    /** Optional gallery images — up to 3 are shown as thumbnails. */
    gallery?: ReadonlyArray<{ readonly url: string; readonly caption?: string }>;
    /** Optional rating dimensions object keyed by dimension name with 0–5 values. */
    ratingDimensions?: Readonly<Record<string, number>>;
}

interface Props {
    /** Array of destination data to pre-render preview panels for. */
    destinations: ReadonlyArray<PreviewData>;
    /** Current locale. Defaults to "es". */
    locale?: SupportedLocale;
    /** Additional CSS classes for the container. */
    class?: string;
}

const { destinations, locale = 'es', class: className } = Astro.props;

const t = createT(locale);

const galleryLabel = t('destinations.featured.preview.gallery',              'Galería');
const ratingsLabel = t('destinations.featured.preview.topRatings',           'Valoraciones');
const ctaLabel     = t('destinations.featured.preview.viewAccommodations',   'Ver alojamientos');

/** Rating dimension label keys — ordered by relevance. */
const DIMENSION_KEYS = [
    'landscape', 'gastronomy', 'safety', 'nightlife',
    'culture', 'nature', 'beaches', 'activities'
] as const;

/** Resolved dimension display names for the current locale. */
const labels: Readonly<Record<string, string>> = Object.fromEntries(
    DIMENSION_KEYS.map((key) => [
        key,
        t(`destinations.featured.preview.dimensions.${key}`, key)
    ])
);
---

<!--
    Container is `inert` by default: all panels are hidden from keyboard and AT.
    The JS below removes/restores `inert` when a panel becomes active.
-->
<div
    class:list={['destination-previews hidden lg:block', className]}
    inert
>
    {destinations.map((dest) => {
        const detailUrl     = `/${locale}/destinos/${dest.path ?? dest.slug}/`;
        const galleryImages = (dest.gallery ?? []).slice(0, 3);
        const topRatings    = Object.entries(dest.ratingDimensions ?? {})
            .filter(([, val]) => val > 0)
            .sort(([, a], [, b]) => b - a)
            .slice(0, 4);

        return (
            <div
                class="destination-preview pointer-events-none absolute z-50 w-72 rounded-xl border border-border bg-surface p-4 opacity-0 shadow-xl transition-all duration-200"
                data-preview-for={dest.slug}
            >
                <!-- Summary text -->
                <p class="text-sm text-text-secondary line-clamp-3">{dest.summary}</p>

                <!-- Gallery thumbnails -->
                {galleryImages.length > 0 && (
                    <div class="mt-3">
                        <p class="mb-1.5 text-xs font-medium text-text-secondary">{galleryLabel}</p>
                        <div class="flex gap-1.5">
                            {galleryImages.map((img) => (
                                <img
                                    src={img.url}
                                    alt={img.caption ?? dest.name}
                                    class="h-16 w-20 rounded-md object-cover"
                                    loading="lazy"
                                    width="80"
                                    height="64"
                                />
                            ))}
                        </div>
                    </div>
                )}

                <!-- Top rating dimensions -->
                {topRatings.length > 0 && (
                    <div class="mt-3">
                        <p class="mb-1.5 text-xs font-medium text-text-secondary">{ratingsLabel}</p>
                        <div class="space-y-1">
                            {topRatings.map(([key, val]) => (
                                <div class="flex items-center justify-between text-xs">
                                    <span class="text-text">{labels[key] ?? key}</span>
                                    <div class="flex items-center gap-1.5">
                                        <div
                                            class="h-1.5 w-16 overflow-hidden rounded-full bg-border"
                                            role="meter"
                                            aria-valuenow={val}
                                            aria-valuemin={0}
                                            aria-valuemax={5}
                                            aria-label={labels[key] ?? key}
                                        >
                                            <div
                                                class="h-full rounded-full bg-primary"
                                                style={`width: ${(val / 5) * 100}%`}
                                            />
                                        </div>
                                        <span class="w-6 text-right font-medium text-text-secondary">
                                            {val.toFixed(1)}
                                        </span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                <!-- CTA button -->
                <a
                    href={detailUrl}
                    class="mt-3 block w-full rounded-lg bg-primary px-3 py-2 text-center text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                >
                    {ctaLabel}
                </a>
            </div>
        );
    })}
</div>

<script>
    import { calculatePreviewPosition } from './destination-preview.utils';

    /** Cleanup function from the current initialization cycle. */
    let previewCleanup: (() => void) | null = null;

    /**
     * Attach hover/focus preview behavior to all destination cards on the page.
     * Cleans up any listeners from a previous initialization first.
     */
    function initDestinationPreviews(): void {
        if (previewCleanup) {
            previewCleanup();
            previewCleanup = null;
        }

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const cards                = document.querySelectorAll('[data-destination-slug]');
        const previewContainer     = document.querySelector('.destination-previews');

        if (!previewContainer || cards.length === 0) return;

        /* Only active on desktop (lg breakpoint) */
        const desktopQuery = window.matchMedia('(min-width: 1024px)');
        if (!desktopQuery.matches) return;

        let hoverTimeout: ReturnType<typeof setTimeout> | null = null;
        let activePreview: HTMLElement | null = null;
        const abortController = new AbortController();
        const { signal }      = abortController;

        /** Position and show the preview panel for the given card. */
        function showPreview(card: HTMLElement): void {
            const slug = card.getAttribute('data-destination-slug');
            if (!slug) return;

            const preview = previewContainer!.querySelector(
                `[data-preview-for="${slug}"]`
            ) as HTMLElement | null;
            if (!preview) return;

            /* Make the container accessible while a preview is visible */
            previewContainer!.removeAttribute('inert');

            /* Read layout metrics before mutating the DOM (avoid layout thrashing) */
            const rect          = card.getBoundingClientRect();
            const previewWidth  = preview.offsetWidth  || 288;
            const previewHeight = preview.offsetHeight || 320;

            const { left, top } = calculatePreviewPosition({
                triggerRect:   { top: rect.top, bottom: rect.bottom, left: rect.left },
                previewWidth,
                previewHeight,
                viewportWidth:  window.innerWidth,
                viewportHeight: window.innerHeight
            });

            /* Single DOM write */
            preview.style.cssText = `position: fixed; left: ${left}px; top: ${top}px;`;

            preview.classList.remove('opacity-0', 'pointer-events-none');
            preview.classList.add('opacity-100', 'pointer-events-auto');
            if (!prefersReducedMotion) {
                preview.style.transform = 'translateY(0)';
            }
            activePreview = preview;
        }

        /** Hide the currently active preview panel. */
        function hidePreview(): void {
            if (hoverTimeout) {
                clearTimeout(hoverTimeout);
                hoverTimeout = null;
            }
            if (activePreview) {
                activePreview.classList.remove('opacity-100', 'pointer-events-auto');
                activePreview.classList.add('opacity-0', 'pointer-events-none');
                activePreview = null;
            }
            /* Restore inert when no preview is visible */
            previewContainer?.setAttribute('inert', '');
        }

        for (const card of cards) {
            const el = card as HTMLElement;

            /* Show after 300 ms delay to avoid flicker on quick cursor passes */
            el.addEventListener('mouseenter', () => {
                hidePreview();
                hoverTimeout = setTimeout(() => showPreview(el), 300);
            }, { signal });

            el.addEventListener('mouseleave', () => {
                hidePreview();
            }, { signal });

            el.addEventListener('focusin', () => {
                hidePreview();
                hoverTimeout = setTimeout(() => showPreview(el), 300);
            }, { signal });

            el.addEventListener('focusout', () => {
                hidePreview();
            }, { signal });
        }

        /* Hide on scroll to prevent misaligned previews after the page moves */
        window.addEventListener('scroll', hidePreview, { passive: true, signal });

        /* Escape key closes the active preview */
        document.addEventListener('keydown', (e) => {
            if ((e as KeyboardEvent).key === 'Escape') {
                hidePreview();
            }
        }, { signal });

        /* Store the cleanup function for the next initialization or before-swap */
        previewCleanup = () => {
            hidePreview();
            abortController.abort();
        };
    }

    initDestinationPreviews();

    /* Re-initialize after view transitions */
    document.addEventListener('astro:page-load', initDestinationPreviews);

    /* Clean up before the old DOM is swapped out */
    document.addEventListener('astro:before-swap', () => {
        if (previewCleanup) {
            previewCleanup();
            previewCleanup = null;
        }
    });
</script>
