---
/**
 * @file DestinationClimateCard.astro
 * @description Sidebar card showing seasonal climate data (SSR) and the live
 * weather island (client:idle). Renders climate info from destination data;
 * if climate is null, renders only the weather island.
 */
import { DropIcon, ThermometerIcon } from '@repo/icons';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';
import { DestinationWeatherIsland } from './DestinationWeatherIsland.client';

interface SeasonData {
    readonly avgTempMinC?: number;
    readonly avgTempMaxC?: number;
    readonly rainfallMm?: number;
}

interface ClimateInput {
    readonly bestSeason?: string;
    readonly bestMonths?: {
        readonly from?: string;
        readonly to?: string;
    };
    readonly seasons?: {
        readonly spring?: SeasonData;
        readonly summer?: SeasonData;
        readonly autumn?: SeasonData;
        readonly winter?: SeasonData;
    };
    readonly note?: Record<string, string>;
}

interface Props {
    readonly locale: SupportedLocale;
    readonly destinationId: string;
    readonly apiUrl: string;
    readonly climate: ClimateInput | null;
}

const { locale, destinationId, apiUrl, climate } = Astro.props;
const { t } = createTranslations(locale);

type SeasonKey = 'spring' | 'summer' | 'autumn' | 'winter';
const seasonKeys: ReadonlyArray<SeasonKey> = ['spring', 'summer', 'autumn', 'winter'];

const presentSeasons: ReadonlyArray<{ key: SeasonKey; data: SeasonData }> =
    climate?.seasons
        ? seasonKeys.flatMap((key) => {
              const data = climate.seasons?.[key];
              return data ? [{ key, data }] : [];
          })
        : [];

const note = climate?.note
    ? (climate.note[locale] ?? climate.note['es'] ?? null)
    : null;

const bestMonthsLabel =
    climate?.bestMonths?.from && climate?.bestMonths?.to
        ? `${t(`destinations.climate.months.${climate.bestMonths.from}`, climate.bestMonths.from)} – ${t(`destinations.climate.months.${climate.bestMonths.to}`, climate.bestMonths.to)}`
        : null;
---

<section
    class="dest-climate-card"
    aria-labelledby="dest-climate-card-title"
>
    <h2 class="dest-climate-card__title" id="dest-climate-card-title">
        {t('destinations.climate.title', 'Clima')}
    </h2>

    {climate && (
        <div class="dest-climate-card__static">
            {climate.bestSeason && (
                <p class="dest-climate-card__best-season">
                    <span class="dest-climate-card__label">
                        {t('destinations.climate.bestSeason', 'Mejor época para visitar')}:
                    </span>
                    {' '}
                    <strong>{t(`destinations.climate.seasons.${climate.bestSeason}`, climate.bestSeason)}</strong>
                </p>
            )}

            {bestMonthsLabel && (
                <p class="dest-climate-card__best-months">
                    <span class="dest-climate-card__label">
                        {t('destinations.climate.bestMonths', 'Meses recomendados')}:
                    </span>
                    {' '}
                    {bestMonthsLabel}
                </p>
            )}

            {presentSeasons.length > 0 && (
                <details class="dest-climate-card__collapse">
                    <summary class="dest-climate-card__collapse-summary">
                        {t('destinations.climate.seasonsTitle', 'Clima por estación')}
                    </summary>
                    <div class="dest-climate-card__seasons">
                    {presentSeasons.map(({ key, data }) => (
                        <div class="dest-climate-card__season">
                            <h3 class="dest-climate-card__season-name">
                                {t(`destinations.climate.seasons.${key}`, key)}
                            </h3>
                            <div class="dest-climate-card__season-stats">
                                {(data.avgTempMinC !== undefined || data.avgTempMaxC !== undefined) && (
                                    <span class="dest-climate-card__stat">
                                        <ThermometerIcon size={14} weight="regular" aria-hidden="true" />
                                        <span class="sr-only">
                                            {t('destinations.climate.fields.minTemp', 'Mín.')}
                                            {' / '}
                                            {t('destinations.climate.fields.maxTemp', 'Máx.')}
                                        </span>
                                        {data.avgTempMinC !== undefined ? Math.round(data.avgTempMinC) : '—'}°
                                        {' / '}
                                        {data.avgTempMaxC !== undefined ? Math.round(data.avgTempMaxC) : '—'}{t('destinations.climate.units.celsius', '°C')}
                                    </span>
                                )}
                                {data.rainfallMm !== undefined && (
                                    <span class="dest-climate-card__stat">
                                        <DropIcon size={14} weight="regular" aria-hidden="true" />
                                        <span class="sr-only">
                                            {t('destinations.climate.fields.rainfall', 'Precipitaciones')}
                                        </span>
                                        {Math.round(data.rainfallMm)}{t('destinations.climate.units.mm', 'mm')}
                                    </span>
                                )}
                            </div>
                        </div>
                    ))}
                    </div>
                </details>
            )}

            {note && (
                <p class="dest-climate-card__note">{note}</p>
            )}

            <p class="dest-climate-card__approximate">
                {t('destinations.climate.approximate', 'Valores aproximados')}
            </p>
        </div>
    )}

    <!-- Live weather island: fetches current + 16-day forecast client-side -->
    <DestinationWeatherIsland
        client:idle
        locale={locale}
        destinationId={destinationId}
        apiUrl={apiUrl}
    />
</section>

<style>
    .dest-climate-card {
        display: flex;
        flex-direction: column;
        gap: var(--space-4, 1rem);
        padding: var(--space-5, 1.25rem);
        background-color: var(--core-card);
        border: 1px solid var(--border, var(--core-foreground-a15));
        border-radius: var(--radius-card, 24px);
    }

    .dest-climate-card__title {
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--core-foreground);
        margin: 0;
    }

    .dest-climate-card__static {
        display: flex;
        flex-direction: column;
        gap: var(--space-3, 0.75rem);
    }

    .dest-climate-card__best-season,
    .dest-climate-card__best-months {
        margin: 0;
        font-family: var(--font-sans);
        font-size: 0.9rem;
        color: var(--core-foreground);
    }

    .dest-climate-card__label {
        color: var(--core-muted-foreground);
    }

    /* Collapsible "seasons" disclosure keeps the card compact by default. */
    .dest-climate-card__collapse-summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-2, 0.5rem);
        cursor: pointer;
        list-style: none;
        font-family: var(--font-sans);
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--core-foreground);
    }

    .dest-climate-card__collapse-summary::-webkit-details-marker {
        display: none;
    }

    .dest-climate-card__collapse-summary::after {
        content: "";
        flex-shrink: 0;
        width: 0.45rem;
        height: 0.45rem;
        border-right: 2px solid var(--core-muted-foreground);
        border-bottom: 2px solid var(--core-muted-foreground);
        transform: rotate(45deg);
        transition: transform var(--duration-normal, 0.3s) ease;
    }

    .dest-climate-card__collapse[open] .dest-climate-card__collapse-summary::after {
        transform: rotate(-135deg);
    }

    .dest-climate-card__seasons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-2, 0.5rem);
        margin-top: var(--space-2, 0.5rem);
    }

    .dest-climate-card__season {
        display: flex;
        flex-direction: column;
        gap: var(--space-1, 0.25rem);
        min-width: 0;
        padding: var(--space-2, 0.5rem) var(--space-3, 0.75rem);
        background-color: var(--core-background);
        border-radius: var(--radius-md, 10px);
        border: 1px solid var(--border, var(--core-foreground-a15));
    }

    .dest-climate-card__season-name {
        font-family: var(--font-heading);
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--brand-primary);
        margin: 0;
        text-transform: capitalize;
    }

    .dest-climate-card__season-stats {
        display: flex;
        flex-direction: column;
        gap: var(--space-1, 0.25rem);
        min-width: 0;
    }

    .dest-climate-card__stat {
        display: inline-flex;
        align-items: center;
        gap: var(--space-1, 0.25rem);
        white-space: nowrap;
        font-family: var(--font-sans);
        font-size: 0.8125rem;
        color: var(--core-foreground);
    }

    .dest-climate-card__note {
        margin: 0;
        font-family: var(--font-sans);
        font-size: 0.875rem;
        font-style: italic;
        color: var(--core-muted-foreground);
        line-height: 1.5;
    }

    .dest-climate-card__approximate {
        margin: 0;
        font-family: var(--font-sans);
        font-size: 0.75rem;
        color: var(--core-muted-foreground);
        opacity: 0.7;
    }
</style>
