---
/**
 * @file DestinationClimatePlaceholder.astro
 * @description "Coming soon" placeholder for the climate / best-season section.
 *
 * Visually consistent with DestinationFaqPlaceholder: dashed border,
 * muted icon, localised copy. Will be replaced by live weather-API data
 * in a future iteration.
 */
import { SunIcon } from '@repo/icons';
import { createTranslations } from '@/lib/i18n';
import type { SupportedLocale } from '@/lib/i18n';

interface Props {
	readonly locale: SupportedLocale;
}

const { locale } = Astro.props;
const { t } = createTranslations(locale);
---

<section
	class="dest-climate-placeholder"
	aria-label={t('destination.detail.climate.ariaLabel', 'Clima y mejor época — próximamente')}
	aria-labelledby="dest-climate-title"
>
	<h2 class="dest-climate-placeholder__title" id="dest-climate-title">
		{t('destination.detail.climate.title', 'Clima y mejor época')}
	</h2>

	<div class="dest-climate-placeholder__container">
		<span class="dest-climate-placeholder__icon" aria-hidden="true">
			<SunIcon size={48} weight="regular" aria-hidden="true" />
		</span>
		<p class="dest-climate-placeholder__body">
			{t(
				'destination.detail.climate.placeholder',
				'Próximamente vas a poder ver información sobre el clima y la mejor época para visitar este destino.'
			)}
		</p>
	</div>
</section>

<style>
	.dest-climate-placeholder {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.dest-climate-placeholder__title {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--core-foreground);
		margin: 0;
	}

	.dest-climate-placeholder__container {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		padding: 2rem 1.5rem;
		border: 2px dashed var(--border);
		border-radius: var(--radius-card);
		text-align: center;
	}

	.dest-climate-placeholder__icon {
		display: inline-flex;
		color: var(--brand-accent);
		opacity: 0.6;
	}

	.dest-climate-placeholder__body {
		font-family: var(--font-sans);
		font-size: 0.95rem;
		color: var(--core-muted-foreground);
		max-width: 48ch;
		margin: 0;
		line-height: 1.6;
	}
</style>
