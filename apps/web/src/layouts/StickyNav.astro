---
/**
 * Sticky navigation bar that appears when the main header scrolls out of view.
 * Starts hidden (opacity 0, translated up), transitions in when data-visible="true".
 * Only rendered on hero pages. Mirrors the main header style in a compact form.
 */
import Container from '../components/ui/Container.astro';
import AuthSection from '../components/auth/AuthSection.astro';
import { ThemeToggle } from '../components/ui/ThemeToggle.client';
import { MobileMenuWrapper } from '../components/ui/MobileMenuWrapper.client';
import { StickyNavController } from '../components/ui/StickyNavController.client';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const navLabels: Record<string, Record<string, string>> = {
  accommodations: { es: 'Alojamientos', en: 'Accommodations', pt: 'Hospedagens' },
  destinations: { es: 'Destinos', en: 'Destinations', pt: 'Destinos' },
  events: { es: 'Eventos', en: 'Events', pt: 'Eventos' },
  blog: { es: 'Blog', en: 'Blog', pt: 'Blog' },
};

const ownerCtaLabel: Record<string, string> = {
  es: 'Publica tu alojamiento',
  en: 'List your property',
  pt: 'Publique seu alojamento',
};

const ownerCtaHref = `/${locale}/propietarios/`;

const navLinks = [
  { label: navLabels.accommodations[locale] ?? navLabels.accommodations.es, href: `/${locale}/alojamientos/` },
  { label: navLabels.destinations[locale] ?? navLabels.destinations.es, href: `/${locale}/destinos/` },
  { label: navLabels.events[locale] ?? navLabels.events.es, href: `/${locale}/eventos/` },
  { label: navLabels.blog[locale] ?? navLabels.blog.es, href: `/${locale}/publicaciones/` },
];

function isLinkActive(href: string): boolean {
  return Astro.url.pathname.startsWith(href);
}
---

<!-- Controller island (renders nothing, manages visibility) -->
<StickyNavController client:load />

<div
  data-sticky-nav
  data-visible="false"
  class="sticky-nav fixed top-0 left-0 z-50 w-full bg-gray-900/95 shadow-lg backdrop-blur-md"
  style="padding-top: env(safe-area-inset-top, 0px);"
>
  <Container size="xl">
    <div class="flex h-14 items-center justify-between">
      <!-- Logo -->
      <a
        href={`/${locale}/`}
        class="flex items-center gap-2 no-underline transition-opacity duration-300 hover:opacity-80"
      >
        <img
          src="/logo.webp"
          alt="Hospeda"
          class="h-8 w-auto"
          width="32"
          height="32"
          loading="lazy"
        />
        <span class="font-serif text-xl font-bold tracking-tight text-white">
          Hospeda
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav role="navigation" aria-label="Sticky navigation" class="hidden items-center md:flex">
        {navLinks.map((link, index) => {
          const isActive = isLinkActive(link.href);
          return (
            <>
              <a
                href={link.href}
                class:list={[
                  'px-3 py-1 text-xs font-bold uppercase tracking-widest no-underline transition-colors duration-300',
                  isActive
                    ? 'text-white'
                    : 'text-white/70 hover:text-white',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {link.label}
              </a>
              {index < navLinks.length - 1 && (
                <span class="text-white/20 select-none" aria-hidden="true">/</span>
              )}
            </>
          );
        })}

        <span class="mx-2 h-4 w-px bg-white/20" aria-hidden="true" />

        <a
          href={ownerCtaHref}
          class:list={[
            'rounded-full border border-white/30 px-3 py-1 text-[11px] font-bold uppercase tracking-widest no-underline transition-all duration-300',
            isLinkActive(ownerCtaHref)
              ? 'bg-secondary border-secondary text-white'
              : 'text-white hover:border-white/60 hover:bg-white/10',
          ]}
          aria-current={isLinkActive(ownerCtaHref) ? 'page' : undefined}
        >
          {ownerCtaLabel[locale] ?? ownerCtaLabel.es}
        </a>
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-1">
        <div class="sticky-theme-toggle">
          <ThemeToggle client:idle />
        </div>

        <span class="mx-1 hidden h-4 w-px bg-white/20 sm:block" aria-hidden="true" />

        <div class="sticky-auth-section hidden sm:block">
          <AuthSection server:defer locale={locale}>
            <div slot="fallback" class="h-7 w-16 animate-pulse rounded-full bg-white/5" aria-hidden="true" />
          </AuthSection>
        </div>

        <MobileMenuWrapper
          client:media="(max-width: 768px)"
          navItems={[...navLinks, { label: ownerCtaLabel[locale] ?? ownerCtaLabel.es, href: ownerCtaHref }]}
          locale={locale as 'es' | 'en' | 'pt'}
        />
      </div>
    </div>
  </Container>
</div>

<style>
  .sticky-nav {
    opacity: 0;
    transform: translateY(-100%);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .sticky-nav[data-visible='true'] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Theme toggle */
  .sticky-theme-toggle :global(button) {
    color: rgba(255, 255, 255, 0.6);
    border-radius: 9999px;
    padding: 0.375rem;
    transition: all 0.3s ease;
  }

  .sticky-theme-toggle :global(button:hover) {
    color: white;
  }

  /* Auth: signin link as outlined pill */
  .sticky-auth-section :global(a) {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 700;
    color: white;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  .sticky-auth-section :global(a:hover) {
    border-color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.08);
  }

  /* Auth: UserNav trigger */
  .sticky-auth-section :global(button) {
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 9999px;
    padding: 0.1875rem 0.5rem 0.1875rem 0.1875rem;
    transition: all 0.3s ease;
    background: transparent;
  }

  .sticky-auth-section :global(button:hover) {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.08);
  }

  .sticky-auth-section :global(button div) {
    border: none;
  }

  .sticky-auth-section :global(button span) {
    color: white;
    font-weight: 700;
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
  }

  .sticky-auth-section :global(button svg) {
    color: rgba(255, 255, 255, 0.6);
  }
</style>
