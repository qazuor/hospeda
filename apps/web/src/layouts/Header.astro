---
import { NAV_LINKS } from "@/data/navigation";
import { createT, type SupportedLocale } from "@/lib/i18n";
import { buildUrl } from "@/lib/urls";
import AuthSection from "../components/auth/AuthSection.astro";
import LanguageSwitcher from "../components/shared/LanguageSwitcher.astro";
import ThemeToggle from "../components/ui/ThemeToggle.astro";
import { ListIcon, CloseIcon } from "@repo/icons";

interface Props {
  locale?: string;
  isHomepage?: boolean;
}

const { locale = 'es', isHomepage = false } = Astro.props;
const typedLocale = locale as SupportedLocale;
const t = createT(typedLocale);

/** Resolve nav link href: anchor for homepage, full path for other pages */
function getNavHref(link: typeof NAV_LINKS[number]): string {
  return isHomepage ? link.anchor : buildUrl({ locale: typedLocale, path: link.path });
}

const NAV_STAGGER_MS = 100;
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent"
  aria-label={t('nav.principal', 'Navegacion principal')}
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 md:px-8">
    <!-- Logo -->
    <a href={buildUrl({ locale: typedLocale })} class="flex items-center gap-2">
      <img
        src="/images/logo.webp"
        alt="Hospeda logo"
        class="h-10 w-10 md:h-12 md:w-12"
      />
      <span
        id="navbar-logo-text"
        class="font-serif text-2xl font-bold tracking-tight transition-colors duration-300 md:text-3xl text-hero-text"
      >
        Hospeda
      </span>
    </a>

    <!-- Desktop links with separators -->
    <div class="hidden items-center md:flex">
      {NAV_LINKS.map((link, index) => (
        <div class="flex items-center">
          <a
            href={getNavHref(link)}
            class="nav-link px-4 text-sm font-medium tracking-wide uppercase transition-colors duration-300 hover:text-accent text-hero-text"
          >
            {t(link.labelKey, link.label)}
          </a>
          {index < NAV_LINKS.length - 1 && (
            <span class="nav-separator h-4 w-px transition-colors duration-300 bg-hero-border" aria-hidden="true" />
          )}
        </div>
      ))}
    </div>

    <!-- Desktop CTA -->
    <div class="hidden items-center gap-3 md:flex">
      <LanguageSwitcher locale={typedLocale} />
      <ThemeToggle />
      <a
        href={buildUrl({ locale: typedLocale, path: 'propietarios' })}
        class="inline-flex h-10 items-center justify-center rounded-full bg-accent px-6 text-sm font-medium text-accent-foreground hover:bg-accent/90 transition-colors"
      >
        {t('nav.ownerCta', 'Publica tu alojamiento')}
      </a>
      <AuthSection server:defer locale={locale} variant="hero">
        <!-- Fallback rendered while the Server Island resolves -->
        <span
          slot="fallback"
          class="inline-flex h-10 items-center justify-center rounded-full px-5 text-sm font-medium border border-hero-border text-hero-text bg-hero-surface"
          aria-hidden="true"
        >
          {t('nav.iniciarSesion', 'Iniciar sesion')}
        </span>
      </AuthSection>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden transition-colors z-50 relative text-hero-text"
      aria-label={t('nav.abrirMenu', 'Abrir menu')}
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-label-open={t('nav.abrirMenu', 'Abrir menu')}
      data-label-close={t('nav.cerrarMenu', 'Cerrar menu')}
    >
      <span id="menu-icon-open">
        <ListIcon size={24} aria-hidden="true" />
      </span>
      <span id="menu-icon-close" class="hidden">
        <CloseIcon size={24} aria-hidden="true" />
      </span>
    </button>
  </div>

  <!-- Mobile menu - Full screen -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 bg-card transition-all duration-500 md:hidden opacity-0 pointer-events-none"
    role="dialog"
    aria-modal="true"
    aria-label={t('nav.principal', 'Navegacion principal')}
  >
    <div class="flex h-full flex-col items-center justify-center gap-6 px-8">
      <div class="mb-6">
        <img src="/images/logo.webp" alt="Hospeda logo" class="h-20 w-20" />
      </div>

      {NAV_LINKS.map((link, index) => (
        <div class="flex flex-col items-center">
          <a
            href={getNavHref(link)}
            class="mobile-nav-link text-2xl font-medium text-foreground transition-all duration-500 hover:text-accent translate-y-4 opacity-0"
            style={`transition-delay: ${index * NAV_STAGGER_MS}ms`}
          >
            {t(link.labelKey, link.label)}
          </a>
          {index < NAV_LINKS.length - 1 && (
            <span class="mt-6 h-px w-16 bg-foreground/10" />
          )}
        </div>
      ))}

      <div
        class="mobile-nav-link mt-6 flex flex-col gap-3 w-full max-w-xs transition-all duration-500 translate-y-4 opacity-0"
        style={`transition-delay: ${NAV_LINKS.length * NAV_STAGGER_MS}ms`}
      >
        <LanguageSwitcher locale={typedLocale} class="justify-center" />
        <a
          href={buildUrl({ locale: typedLocale, path: 'propietarios' })}
          class="inline-flex h-14 items-center justify-center rounded-full bg-accent text-accent-foreground hover:bg-accent/90 text-lg font-medium"
        >
          {t('nav.ownerCta', 'Publica tu alojamiento')}
        </a>
        <!-- Auth section in mobile menu uses the "scrolled" variant since the
             mobile overlay always has a light background (bg-card). -->
        <AuthSection server:defer locale={locale} variant="scrolled">
          <span
            slot="fallback"
            class="inline-flex h-14 items-center justify-center rounded-full border border-foreground/20 text-foreground text-lg font-medium"
            aria-hidden="true"
          >
            {t('nav.iniciarSesion', 'Iniciar sesion')}
          </span>
        </AuthSection>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar")!;
  const logoText = document.getElementById("navbar-logo-text")!;
  const navLinks = document.querySelectorAll(".nav-link");
  const navSeparators = document.querySelectorAll(".nav-separator");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const menuIconOpen = document.getElementById("menu-icon-open")!;
  const menuIconClose = document.getElementById("menu-icon-close")!;
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");
  const themeToggleBtn = document.querySelector(".theme-toggle-btn");

  let isMenuOpen = false;

  function handleScroll() {
    const scrolled = window.scrollY > 50;

    // The static sign-in link (#navbar-signin) may be absent when the user is
    // authenticated (UserNav island is rendered instead). Always query fresh.
    const signinBtn = document.getElementById("navbar-signin");

    if (scrolled) {
      navbar.classList.add("bg-card/95", "backdrop-blur-md", "shadow-nav");
      navbar.classList.remove("bg-transparent");
      logoText.classList.add("text-foreground");
      logoText.classList.remove("text-hero-text");
      navLinks.forEach((l) => { l.classList.add("text-foreground"); l.classList.remove("text-hero-text"); });
      navSeparators.forEach((s) => { s.classList.add("bg-foreground/20"); s.classList.remove("bg-hero-border"); });
      if (signinBtn) {
        signinBtn.classList.add("border-foreground/20", "text-foreground", "hover:bg-foreground/5");
        signinBtn.classList.remove("border-hero-border", "text-hero-text", "bg-hero-surface", "hover:bg-hero-surface");
      }
      if (themeToggleBtn) {
        themeToggleBtn.classList.add("border-border", "bg-card", "text-foreground", "hover:bg-muted");
        themeToggleBtn.classList.remove("border-hero-border", "bg-hero-surface", "text-hero-text", "hover:bg-hero-surface");
      }
      if (!isMenuOpen) {
        mobileMenuBtn.classList.add("text-foreground");
        mobileMenuBtn.classList.remove("text-hero-text");
      }
    } else {
      navbar.classList.remove("bg-card/95", "backdrop-blur-md", "shadow-nav");
      navbar.classList.add("bg-transparent");
      logoText.classList.remove("text-foreground");
      logoText.classList.add("text-hero-text");
      navLinks.forEach((l) => { l.classList.remove("text-foreground"); l.classList.add("text-hero-text"); });
      navSeparators.forEach((s) => { s.classList.remove("bg-foreground/20"); s.classList.add("bg-hero-border"); });
      if (signinBtn) {
        signinBtn.classList.remove("border-foreground/20", "text-foreground", "hover:bg-foreground/5");
        signinBtn.classList.add("border-hero-border", "text-hero-text", "bg-hero-surface", "hover:bg-hero-surface");
      }
      if (themeToggleBtn) {
        themeToggleBtn.classList.remove("border-border", "bg-card", "text-foreground", "hover:bg-muted");
        themeToggleBtn.classList.add("border-hero-border", "bg-hero-surface", "text-hero-text", "hover:bg-hero-surface");
      }
      if (!isMenuOpen) {
        mobileMenuBtn.classList.remove("text-foreground");
        mobileMenuBtn.classList.add("text-hero-text");
      }
    }

    // Dispatch a custom event so the UserNav island (if rendered) can
    // adapt its button styles to the current scroll state.
    navbar.dispatchEvent(new CustomEvent("navbar:scroll", { detail: { scrolled } }));
  }

  window.addEventListener("scroll", handleScroll, { passive: true });
  handleScroll();

  mobileMenuBtn.addEventListener("click", () => {
    isMenuOpen = !isMenuOpen;
    if (isMenuOpen) {
      mobileMenu.classList.remove("opacity-0", "pointer-events-none");
      mobileMenu.classList.add("opacity-100", "pointer-events-auto");
      menuIconOpen.classList.add("hidden");
      menuIconClose.classList.remove("hidden");
      mobileMenuBtn.classList.add("text-foreground");
      mobileMenuBtn.classList.remove("text-hero-text");
      document.body.style.overflow = "hidden";
      mobileNavLinks.forEach((link) => {
        link.classList.remove("translate-y-4", "opacity-0");
        link.classList.add("translate-y-0", "opacity-100");
      });
    } else {
      mobileMenu.classList.add("opacity-0", "pointer-events-none");
      mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
      menuIconClose.classList.add("hidden");
      menuIconOpen.classList.remove("hidden");
      document.body.style.overflow = "";
      handleScroll();
      mobileNavLinks.forEach((link) => {
        link.classList.add("translate-y-4", "opacity-0");
        link.classList.remove("translate-y-0", "opacity-100");
      });
    }
    mobileMenuBtn.setAttribute("aria-expanded", String(isMenuOpen));
    mobileMenuBtn.setAttribute("aria-label", isMenuOpen ? mobileMenuBtn.dataset.labelClose! : mobileMenuBtn.dataset.labelOpen!);
  });

  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) mobileMenuBtn.click();
    });
  });
</script>
