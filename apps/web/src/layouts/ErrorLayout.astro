---
/**
 * @file ErrorLayout.astro
 * @description Crash-resistant layout for 404 and 500 error pages.
 * Standalone HTML shell with minimal header (logo only) and no heavy JS.
 * Does NOT extend BaseLayout to avoid complex component trees that could fail.
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import Logo from '@/components/shared/Logo.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

interface Props {
	readonly locale: SupportedLocale;
	readonly title?: string;
	readonly description?: string;
}

const {
	locale,
	title = 'Error',
	description = 'Ha ocurrido un error',
} = Astro.props;

const { t } = createTranslations(locale);
const cspNonce = Astro.locals.cspNonce ?? '';
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

		<!-- Google Fonts (non-blocking) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Geologica:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Geologica:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Geologica:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap"
				rel="stylesheet"
			/>
		</noscript>

		<!-- Theme FOUC prevention -->
		<script is:inline nonce={cspNonce}>
			(function() {
				var t = localStorage.getItem('theme');
				if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
					document.documentElement.setAttribute('data-theme', 'dark');
				}
			})();
		</script>

		<ClientRouter />

		<SEOHead
			title={title}
			description={description}
			locale={locale}
			canonical={canonical}
			noindex={true}
		/>
	</head>
	<body>
		<!-- Simplified header: logo only -->
		<header class="error-header">
			<div class="error-header__container">
				<Logo locale={locale} size="md" />
			</div>
		</header>

		<!-- Decorative wave separator -->
		<div class="error-wave" aria-hidden="true">
			<svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
				<path d="M0,64 C288,120 576,0 864,64 C1152,128 1440,32 1440,32 L1440,0 L0,0 Z" fill="var(--surface-warm, #fdf6f0)" />
			</svg>
		</div>

		<!-- Error content -->
		<main id="main-content" class="error-content">
			<slot />
		</main>

		<!-- Minimal footer -->
		<footer class="error-footer">
			<div class="error-footer__container">
				<p class="error-footer__copyright">
					&copy; {new Date().getFullYear()} Hospeda. {t('footer.allRightsReserved', 'Todos los derechos reservados')}.
				</p>
			</div>
		</footer>
	</body>
</html>

<style>
	.error-header {
		position: sticky;
		top: 0;
		z-index: 100;
		background-color: var(--background);
		border-bottom: 1px solid var(--border);
		padding: var(--space-4) 0;
	}

	.error-header__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-6);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.error-wave {
		margin-top: -1px;
		line-height: 0;
	}

	.error-wave svg {
		width: 100%;
		height: 80px;
		display: block;
	}

	.error-content {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: var(--space-12) var(--space-6);
		min-height: 50vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	.error-footer {
		border-top: 1px solid var(--border);
		padding: var(--space-6) 0;
		margin-top: auto;
	}

	.error-footer__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-6);
		text-align: center;
	}

	.error-footer__copyright {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--muted-foreground);
		margin: 0;
	}
</style>
