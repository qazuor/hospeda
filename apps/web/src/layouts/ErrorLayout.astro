---
/**
 * @file ErrorLayout.astro
 * @description Crash-resistant layout for 404 and 500 error pages.
 * Standalone HTML shell with minimal header (logo only) and no heavy JS.
 * Does NOT extend BaseLayout to avoid complex component trees that could fail.
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { BRAND_THEME_COLOR } from '@/lib/constants';
import Logo from '@/components/shared/navigation/Logo.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import FontsLoader from '@/components/shared/FontsLoader.astro';
import ThemeFoucScript from '@/components/shared/ThemeFoucScript.astro';
import { ToastViewport } from '@/components/ui/ToastViewport.client';
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

interface Props {
	readonly locale: SupportedLocale;
	readonly title?: string;
	readonly description?: string;
	/** Adds noindex robots meta tag. Defaults to true for all error pages. */
	readonly noindex?: boolean;
}

const {
	locale,
	title = 'Error',
	description = 'Ha ocurrido un error',
	noindex = true,
} = Astro.props;

const { t } = createTranslations(locale);
const cspNonce = Astro.locals.cspNonce ?? '';
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;

const isAuthenticatedHint = Astro.locals.user ? 'true' : 'false';
---

<!doctype html>
<html lang={locale} data-user-authenticated={isAuthenticatedHint}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<!-- SPEC-157 REQ-18: browser UI chrome matches the brand blue. -->
		<meta name="theme-color" content={BRAND_THEME_COLOR} />

		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Google Fonts (non-blocking) -->
		<FontsLoader cspNonce={cspNonce} />

		<ThemeFoucScript cspNonce={cspNonce} />

		<ClientRouter />

		<SEOHead
			title={title}
			description={description}
			locale={locale}
			canonical={canonical}
			noindex={noindex}
		/>

		<style is:inline nonce={cspNonce}>
			/* ErrorLayout: body — flex column so the footer sits at the bottom
			   while the main fills the remaining viewport height. Same shape as
			   AuthLayout so status pages render identically across both. */
			body { min-height: 100vh; display: flex; flex-direction: column; background-color: var(--background); }

			/* ErrorLayout: header */
			.error-header { position: sticky; top: 0; z-index: 100; background-color: var(--background); padding: 1rem 0; }
			.error-header__container { max-width: var(--container-max, 1350px); margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: center; }

			/* ErrorLayout: content area. Fills the space between header and
			   footer; StatusPage owns its own vertical padding so we align to
			   the top for a consistent content position across pages. */
			.error-content { flex: 1; max-width: var(--container-max, 1350px); width: 100%; margin: 0 auto; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; }

			/* ErrorLayout: footer */
			.error-footer { border-top: 1px solid var(--border); padding: 1.5rem 0; margin-top: auto; }
			.error-footer__container { max-width: var(--container-max, 1350px); margin: 0 auto; padding: 0 1.5rem; text-align: center; }
			.error-footer__copyright { font-family: var(--font-sans); font-size: 0.875rem; color: var(--core-muted-foreground); margin: 0; }
		</style>
	</head>
	<body>
		<!-- Simplified header: logo only -->
		<header class="error-header">
			<div class="error-header__container">
				<Logo locale={locale} size="md" />
			</div>
		</header>

		<!-- Error content -->
		<main id="main-content" class="error-content">
			<slot />
		</main>

		<!-- Minimal footer -->
		<footer class="error-footer">
			<div class="error-footer__container">
				<p class="error-footer__copyright">
					&copy; {new Date().getFullYear()} Hospeda. {t('footer.allRightsReserved', 'Todos los derechos reservados')}.
				</p>
			</div>
		</footer>

		<ToastViewport client:idle locale={locale} />
	</body>
</html>

