---
/**
 * @file ErrorLayout.astro
 * @description Crash-resistant layout for 404 and 500 error pages.
 * Standalone HTML shell with minimal header (logo only) and no heavy JS.
 * Does NOT extend BaseLayout to avoid complex component trees that could fail.
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import Logo from '@/components/shared/Logo.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

interface Props {
	readonly locale: SupportedLocale;
	readonly title?: string;
	readonly description?: string;
	/** Adds noindex robots meta tag. Defaults to true for all error pages. */
	readonly noindex?: boolean;
}

const {
	locale,
	title = 'Error',
	description = 'Ha ocurrido un error',
	noindex = true,
} = Astro.props;

const { t } = createTranslations(locale);
const cspNonce = Astro.locals.cspNonce ?? '';
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

		<!-- Google Fonts (non-blocking) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Geologica:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Geologica:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Geologica:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap"
				rel="stylesheet"
			/>
		</noscript>

		<!-- Theme FOUC prevention -->
		<script is:inline nonce={cspNonce}>
			(function() {
				var t = localStorage.getItem('theme');
				if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
					document.documentElement.setAttribute('data-theme', 'dark');
				}
			})();
		</script>

		<ClientRouter />

		<SEOHead
			title={title}
			description={description}
			locale={locale}
			canonical={canonical}
			noindex={noindex}
		/>

		<style is:inline>
			/* ErrorLayout: header */
			.error-header { position: sticky; top: 0; z-index: 100; background-color: var(--background); border-bottom: 1px solid var(--border); padding: 1rem 0; }
			.error-header__container { max-width: var(--container-max, 1350px); margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: center; }

			/* ErrorLayout: wave */
			.error-wave { margin-top: -1px; line-height: 0; }
			.error-wave svg { width: 100%; height: 80px; display: block; }

			/* ErrorLayout: content area */
			.error-content { max-width: var(--container-max, 1350px); margin: 0 auto; padding: 4rem 1.5rem; min-height: 50vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }

			/* ErrorLayout: footer */
			.error-footer { border-top: 1px solid var(--border); padding: 1.5rem 0; margin-top: auto; }
			.error-footer__container { max-width: var(--container-max, 1350px); margin: 0 auto; padding: 0 1.5rem; text-align: center; }
			.error-footer__copyright { font-family: var(--font-sans); font-size: 0.875rem; color: var(--muted-foreground); margin: 0; }

			/* 500 page styles */
			.err500-illustration { margin-bottom: 0.5rem; }
			.err500-code { font-family: var(--font-heading); font-size: clamp(3rem, 10vw, 5rem); font-weight: 800; color: var(--muted-foreground); opacity: 0.1; line-height: 1; margin-top: -1rem; letter-spacing: 0.08em; }
			.err500-title { font-family: var(--font-heading); font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 600; color: var(--foreground); line-height: 1.3; margin: 0.5rem 0 0; }
			.err500-message { font-family: var(--font-sans); font-size: 1.125rem; color: var(--foreground); line-height: 1.6; margin: 0.75rem 0 0; max-width: 40ch; }
			.err500-subtitle { font-family: var(--font-sans); font-size: 1rem; color: var(--muted-foreground); line-height: 1.6; margin: 0.25rem 0 0; max-width: 44ch; }
			.err500-actions { display: flex; align-items: center; gap: 0.75rem; margin-top: 1.5rem; flex-wrap: wrap; justify-content: center; }
			.err500-home-link { display: inline-block; font-family: var(--font-sans); font-size: 0.875rem; color: var(--muted-foreground); text-decoration: none; margin-top: 1rem; transition: color 0.2s ease; }
			.err500-home-link:hover { color: var(--primary); text-decoration: underline; }
			.err500-dev { width: 100%; max-width: 480px; margin-top: 2rem; text-align: left; }
			.err500-dev__summary { font-family: var(--font-sans); font-size: 0.875rem; color: var(--muted-foreground); cursor: pointer; user-select: none; padding: 0.5rem; border-radius: var(--radius-button, 8px); }
			.err500-dev__summary:hover { background-color: oklch(from var(--destructive, #ef4444) l c h / 0.06); }
			.err500-dev__content { margin-top: 0.5rem; padding: 0.75rem 1rem; background-color: oklch(from var(--destructive, #ef4444) l c h / 0.05); border: 1px solid oklch(from var(--destructive, #ef4444) l c h / 0.12); border-radius: var(--radius-button, 8px); font-family: monospace; font-size: 0.75rem; color: var(--muted-foreground); }
			.err500-dev__content p { margin: 0 0 0.25rem; }
			.err500-dev__content strong { color: var(--foreground); }
			.err500-dev__hint { margin-top: 0.75rem !important; font-style: italic; opacity: 0.7; }

			/* 404 page styles */
			.error-page { display: flex; align-items: center; justify-content: center; min-height: 60vh; padding: 2rem 1.5rem; }
			.error-page__container { display: flex; flex-direction: column; align-items: center; text-align: center; max-width: 520px; gap: 24px; }
			.error-page__illustration { margin-bottom: 8px; }
			.error-page__title { font-family: var(--font-heading); font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: var(--foreground); line-height: 1.2; }
			.error-page__message { font-family: var(--font-sans); font-size: 1.125rem; color: var(--muted-foreground); line-height: 1.6; }
			.error-page__actions { display: flex; gap: 16px; margin-top: 8px; flex-wrap: wrap; justify-content: center; }
			.error-page__btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; border-radius: var(--radius-button, 8px); font-family: var(--font-sans); font-size: 1rem; font-weight: 600; text-decoration: none; cursor: pointer; border: none; transition: all 0.3s ease; }
			.error-page__btn--primary { background-color: var(--accent); color: var(--accent-foreground, #fff); }
			.error-page__btn--primary:hover { opacity: 0.9; transform: translateY(-1px); }
			.error-page__btn--secondary { background-color: var(--muted); color: var(--foreground); }
			.error-page__btn--secondary:hover { background-color: var(--border); }

			@media (max-width: 480px) {
				.err500-actions { flex-direction: column; width: 100%; }
				.err500-actions .btn-gradient { width: 100%; }
				.error-page__actions { flex-direction: column; }
				.error-page__btn { width: 100%; justify-content: center; }
			}
		</style>
	</head>
	<body>
		<!-- Simplified header: logo only -->
		<header class="error-header">
			<div class="error-header__container">
				<Logo locale={locale} size="md" />
			</div>
		</header>

		<!-- Decorative wave separator -->
		<div class="error-wave" aria-hidden="true">
			<svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
				<path d="M0,64 C288,120 576,0 864,64 C1152,128 1440,32 1440,32 L1440,0 L0,0 Z" fill="var(--surface-warm, #fdf6f0)" />
			</svg>
		</div>

		<!-- Error content -->
		<main id="main-content" class="error-content">
			<slot />
		</main>

		<!-- Minimal footer -->
		<footer class="error-footer">
			<div class="error-footer__container">
				<p class="error-footer__copyright">
					&copy; {new Date().getFullYear()} Hospeda. {t('footer.allRightsReserved', 'Todos los derechos reservados')}.
				</p>
			</div>
		</footer>
	</body>
</html>

