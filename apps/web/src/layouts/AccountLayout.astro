---
/**
 * @file AccountLayout.astro
 * @description Two-panel layout for account pages with persistent sidebar navigation.
 * Wraps BaseLayout. Auth is handled by existing middleware.
 *
 * Used by: mi-cuenta dashboard, edit profile, favorites, reviews, subscription, preferences.
 */

import { getSiteUrl } from '@/lib/env';
import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import BaseLayout from './BaseLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import {
	UserIcon,
	HomeIcon,
	FavoriteIcon,
	StarIcon,
	ChatIcon,
	CreditCardIcon,
	SettingsIcon,
	NewsletterIcon,
	BuildingIcon,
	DashboardIcon,
} from '@repo/icons';
import type { ComponentType } from 'react';
import type { IconProps } from '@repo/icons';

interface Props {
	readonly locale: SupportedLocale;
	readonly title?: string;
	readonly description?: string;
	readonly activeSection?: string;
}

const {
	locale,
	title,
	description,
	activeSection = 'mi-cuenta',
} = Astro.props;

const { t } = createTranslations(locale);
const siteBase = getSiteUrl();
const canonicalUrl = new URL(Astro.url.pathname, siteBase).href;

const resolvedTitle = title ?? t('account.title', 'Mi cuenta');
const resolvedDescription = description ?? t('account.description', 'Gestioná tu cuenta en Hospeda');

interface NavLink {
	readonly section: string;
	readonly label: string;
	readonly path: string;
	readonly Icon: ComponentType<IconProps>;
}

interface NavGroup {
	readonly id: string;
	readonly label: string;
	readonly items: ReadonlyArray<NavLink>;
}

/**
 * Role-based predicate for the "Mis propiedades" sidebar entry. Mirrors the
 * UserMenu (top-right dropdown) predicate `permissions.includes('accommodation.create')`
 * by approximating it as "role has admin-panel access". Five roles get this
 * permission today via the role-permission seed in `apps/api/src/lib/...`:
 *
 *   - HOST: regular property owner managing their own listings.
 *   - ADMIN / SUPER_ADMIN: platform staff.
 *   - CLIENT_MANAGER: agency/business account.
 *   - EDITOR: content moderator with editorial rights.
 *
 * A plain USER (e.g., a tourist who only browses + saves favorites) does NOT
 * see this link, matching the UserMenu behavior. See SPEC-143 Finding #12.
 */
const ROLES_WITH_ACCOMMODATIONS_NAV = new Set([
	'HOST',
	'ADMIN',
	'SUPER_ADMIN',
	'CLIENT_MANAGER',
	'EDITOR',
]);

const userRole = Astro.locals.user?.role ?? null;
const showPropertiesNav = userRole !== null && ROLES_WITH_ACCOMMODATIONS_NAV.has(userRole);

/**
 * Sidebar nav is grouped so users can scan it as two short lists instead
 * of one long one. The grouping is visual only — selection logic still
 * matches by `section` against the `activeSection` prop.
 */
const navGroups: ReadonlyArray<NavGroup> = [
	{
		id: 'profile',
		label: t('account.nav.groupProfile', 'Mi perfil'),
		items: [
			{ section: 'mi-cuenta', label: t('account.nav.dashboard', 'Mi cuenta'), path: 'mi-cuenta', Icon: HomeIcon },
			{ section: 'editar', label: t('account.nav.editProfile', 'Editar perfil'), path: 'mi-cuenta/editar', Icon: UserIcon },
		],
	},
	{
		id: 'activity',
		label: t('account.nav.groupActivity', 'Actividad'),
		items: [
			...(showPropertiesNav
				? [{ section: 'propiedades', label: t('account.nav.properties', 'Mis propiedades'), path: 'mi-cuenta/propiedades', Icon: BuildingIcon }]
				: []),
			{ section: 'favoritos', label: t('account.nav.favorites', 'Favoritos'), path: 'mi-cuenta/favoritos', Icon: FavoriteIcon },
			{ section: 'resenas', label: t('account.nav.reviews', 'Mis reseñas'), path: 'mi-cuenta/resenas', Icon: StarIcon },
			{ section: 'messages', label: t('conversations.inbox.guestInboxTitle', 'Mis consultas'), path: 'mi-cuenta/consultas', Icon: ChatIcon },
		],
	},
	...(showPropertiesNav
		? [
				{
					id: 'host',
					label: t('account.nav.groupHost', 'Anfitrión'),
					items: [
						{
							section: 'host-dashboard',
							label: t('account.nav.hostDashboard', 'Panel del anfitrión'),
							path: 'mi-cuenta/host-dashboard',
							Icon: DashboardIcon
						},
						{
							section: 'owner-messages',
							label: t('conversations.inbox.ownerInboxTitle', 'Mensajes de huéspedes'),
							path: 'mi-cuenta/consultas-propietario',
							Icon: ChatIcon
						},
					],
				} as NavGroup,
		  ]
		: []),
	{
		id: 'config',
		label: t('account.nav.groupConfig', 'Configuración'),
		items: [
			{ section: 'suscripcion', label: t('account.nav.subscription', 'Suscripción'), path: 'mi-cuenta/suscripcion', Icon: CreditCardIcon },
			{ section: 'preferencias', label: t('account.nav.preferences', 'Preferencias'), path: 'mi-cuenta/preferencias', Icon: SettingsIcon },
			{ section: 'newsletter', label: t('account.nav.newsletter', 'Boletín de novedades'), path: 'mi-cuenta/newsletter', Icon: NewsletterIcon },
		],
	},
];
---

<BaseLayout locale={locale} title={resolvedTitle} description={resolvedDescription}>
	<SEOHead
		slot="head"
		title={resolvedTitle}
		description={resolvedDescription}
		locale={locale}
		canonical={canonicalUrl}
		noindex={true}
	/>

	<div class="account-page">
		<div class="account-page__container">
			<!-- Mobile toggle -->
			<button
				class="account-page__toggle"
				aria-expanded="false"
				aria-controls="account-nav"
				type="button"
			>
				<span class="account-page__toggle-label">{t('account.menu', 'Menú de cuenta')}</span>
				<span class="account-page__toggle-icon" aria-hidden="true">▾</span>
			</button>

			<!-- Sidebar navigation -->
			<aside id="account-nav" class="account-page__sidebar" aria-label="Account navigation">
				<nav class="account-nav">
					{navGroups.map((group) => (
						<div class="account-nav__group">
							<p class="account-nav__group-label">{group.label}</p>
							<ul class="account-nav__list">
								{group.items.map(({ section, label, path, Icon }) => (
									<li class="account-nav__item">
										<a
											href={buildUrl({ locale, path })}
											class:list={[
												'account-nav__link',
												{ 'account-nav__link--active': section === activeSection },
											]}
											aria-current={section === activeSection ? 'page' : undefined}
										>
											<span class="account-nav__icon" aria-hidden="true">
												<Icon size={18} weight="regular" aria-hidden="true" />
											</span>
											<span class="account-nav__label">{label}</span>
										</a>
									</li>
								))}
							</ul>
						</div>
					))}
				</nav>
			</aside>

			<!-- Content area -->
			<div class="account-page__content">
				<slot />
			</div>
		</div>
	</div>
</BaseLayout>

<script>
	function initAccountToggle(): void {
		const toggle = document.querySelector<HTMLButtonElement>('.account-page__toggle');
		const nav = document.getElementById('account-nav');
		if (!toggle || !nav) return;

		toggle.addEventListener('click', () => {
			const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!isExpanded));
			nav.classList.toggle('account-page__sidebar--open');
		});
	}

	document.addEventListener('astro:page-load', initAccountToggle);
</script>

<style>
	.account-page {
		padding: var(--space-section-sm) 0;
		background-color: var(--core-background);
	}

	.account-page__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: var(--space-8);
		align-items: start;
	}

	/* Mobile toggle */
	.account-page__toggle {
		display: none;
		width: 100%;
		padding: var(--space-3) var(--space-4);
		background-color: var(--core-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-button);
		font-family: var(--font-sans);
		font-size: var(--text-body);
		font-weight: 500;
		color: var(--core-foreground);
		cursor: pointer;
		justify-content: space-between;
		align-items: center;
	}

	.account-page__toggle-icon {
		transition: transform var(--duration-fast) ease;
	}

	.account-page__toggle[aria-expanded="true"] .account-page__toggle-icon {
		transform: rotate(180deg);
	}

	/* Sidebar shell — card-like wrapper around the grouped nav */
	.account-page__sidebar {
		position: sticky;
		top: 110px;
		background-color: var(--core-card);
		border: 1px solid var(--core-foreground-a08);
		border-radius: var(--radius-card);
		padding: var(--space-3);
		box-shadow: 0 1px 2px var(--core-foreground-a05);
	}

	.account-nav {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.account-nav__group {
		display: flex;
		flex-direction: column;
	}

	.account-nav__group:not(:first-child) {
		margin-top: var(--space-3);
		padding-top: var(--space-3);
		border-top: 1px solid var(--core-foreground-a05);
	}

	.account-nav__group-label {
		margin: 0 0 var(--space-1);
		padding: 0 var(--space-3);
		font-family: var(--font-sans);
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--core-muted-foreground);
	}

	.account-nav__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.account-nav__link {
		position: relative;
		display: flex;
		align-items: center;
		gap: var(--space-3);
		padding: 0.5rem var(--space-3);
		font-family: var(--font-sans);
		font-size: 0.9375rem;
		color: var(--core-foreground);
		text-decoration: none;
		border-radius: var(--radius-button);
		transition: background-color var(--duration-fast) ease,
					color var(--duration-fast) ease;
	}

	.account-nav__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		color: var(--core-muted-foreground);
		transition: color var(--duration-fast) ease;
		flex-shrink: 0;
	}

	.account-nav__label {
		flex: 1;
		font-weight: 500;
	}

	.account-nav__link:hover {
		background-color: var(--brand-primary-a05);
	}

	.account-nav__link:hover .account-nav__icon {
		color: var(--brand-primary);
	}

	.account-nav__link:focus-visible {
		outline: 2px solid var(--brand-primary);
		outline-offset: 2px;
	}

	.account-nav__link--active {
		background-color: var(--brand-accent-a12);
		color: var(--brand-accent);
	}

	.account-nav__link--active .account-nav__icon {
		color: var(--brand-accent);
	}

	.account-nav__link--active .account-nav__label {
		font-weight: 600;
	}

	.account-nav__link--active::before {
		content: '';
		position: absolute;
		left: -3px;
		top: 50%;
		transform: translateY(-50%);
		width: 3px;
		height: 60%;
		background-color: var(--brand-accent);
		border-radius: 0 var(--radius-pill) var(--radius-pill) 0;
	}

	/* Content */
	.account-page__content {
		min-width: 0;
	}

	/* Mobile */
	@media (max-width: 768px) {
		.account-page__container {
			grid-template-columns: 1fr;
			gap: var(--space-4);
		}

		.account-page__toggle {
			display: flex;
			grid-column: 1;
		}

		.account-page__sidebar {
			position: static;
			display: none;
		}

		.account-page__sidebar--open {
			display: block;
			margin-bottom: var(--space-4);
		}
	}
</style>
