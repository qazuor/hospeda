---
import "@/styles/global.css";
import { ToastContainer } from "@/components/ui/Toast.client";
import { FeedbackFAB } from "@repo/feedback";
import { getApiUrl } from "@/lib/env";
import Header from "./Header.astro";
import Footer from "./Footer.astro";

interface Props {
  title?: string;
  description?: string;
  locale?: string;
  isHero?: boolean;
  /** Whether to show the header (default true). Auth pages may use a simplified header. */
  showHeader?: boolean;
  /** Whether this is the homepage (affects nav link behavior). */
  isHomepage?: boolean;
}

const {
  title = "Hospeda",
  description = "Descubri los mejores alojamientos turisticos en Entre Rios",
  locale = "es",
  isHero = false,
  showHeader = true,
  isHomepage = false,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#3b7fa3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111b28" media="(prefers-color-scheme: dark)" />

    <!-- Default meta (overridden by SEOHead slot if present) -->
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link
      rel="icon"
      type="image/png"
      href="/icon-light-32x32.png"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/png"
      href="/icon-dark-32x32.png"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="apple-touch-icon" href="/apple-icon.png" />

    <!-- Skip to content link -->
    <style>
      .skip-to-content {
        position: absolute;
        left: -9999px;
        z-index: 9999;
        padding: 0.5rem 1rem;
        background: var(--accent);
        color: var(--accent-foreground);
        border-radius: 0.25rem;
      }
      .skip-to-content:focus {
        position: fixed;
        top: 1rem;
        left: 1rem;
      }
    </style>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- FOUC prevention for dark mode -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>

    <!-- SEO slot (overrides default title/description) -->
    <slot name="head" />
  </head>
  <body class="font-sans antialiased">
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    {showHeader && <Header locale={locale} isHomepage={isHomepage} />}
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={locale} />

    <ToastContainer client:load locale={locale as 'es' | 'en' | 'pt'} />

    <!-- Feedback FAB: low-priority island, deferred until browser is idle -->
    <!-- FeedbackIslandWrapper is available for wrapping interactive islands -->
    <FeedbackFAB
      client:idle
      apiUrl={getApiUrl()}
      appSource="web"
    />

    <!-- Scroll reveal observer (is:inline to run after DOM is parsed) -->
    <script is:inline>
      (function () {
        var SELECTOR = ".scroll-reveal, .scroll-reveal-left, .scroll-reveal-right";

        var prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        function revealElement(el) {
          el.classList.add("revealed");
        }

        if (prefersReducedMotion) {
          document.querySelectorAll(SELECTOR).forEach(revealElement);
          new MutationObserver(function (mutations) {
            for (var i = 0; i < mutations.length; i++) {
              for (var j = 0; j < mutations[i].addedNodes.length; j++) {
                var node = mutations[i].addedNodes[j];
                if (node.nodeType === 1) {
                  if (node.matches && node.matches(SELECTOR)) revealElement(node);
                  node.querySelectorAll && node.querySelectorAll(SELECTOR).forEach(revealElement);
                }
              }
            }
          }).observe(document.body, { childList: true, subtree: true });
          return;
        }

        var io = new IntersectionObserver(
          function (entries) {
            for (var i = 0; i < entries.length; i++) {
              if (entries[i].isIntersecting) {
                revealElement(entries[i].target);
                io.unobserve(entries[i].target);
              }
            }
          },
          { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
        );

        document.querySelectorAll(SELECTOR).forEach(function (el) {
          io.observe(el);
        });

        /* Watch for Server Island content arriving after initial load */
        new MutationObserver(function (mutations) {
          for (var i = 0; i < mutations.length; i++) {
            for (var j = 0; j < mutations[i].addedNodes.length; j++) {
              var node = mutations[i].addedNodes[j];
              if (node.nodeType === 1) {
                if (node.matches && node.matches(SELECTOR)) io.observe(node);
                if (node.querySelectorAll) {
                  node.querySelectorAll(SELECTOR).forEach(function (el) {
                    io.observe(el);
                  });
                }
              }
            }
          }
        }).observe(document.body, { childList: true, subtree: true });
      })();
    </script>
  </body>
</html>
