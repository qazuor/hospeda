---
/**
 * @file BaseLayout.astro
 * @description Full HTML shell for all pages. Handles font loading, FOUC prevention,
 * global styles, view transitions (ClientRouter), and page initialization.
 *
 * Renders: SkipToContent > Header > main#main-content > Footer > ScrollToTop
 *
 * Usage:
 * ```astro
 * <BaseLayout locale={locale} title="Page Title" description="Page description">
 *   <slot />
 * </BaseLayout>
 * ```
 */

import type { SupportedLocale } from '@/lib/i18n';
import { buildUrl } from '@/lib/urls';
import { getApiUrl, getDeployVersion, isFeedbackEnabled } from '@/lib/env';
import { ClientRouter } from 'astro:transitions';
import Header from './Header.astro';
import Footer from './Footer.astro';
import SkipToContent from '@/components/shared/navigation/SkipToContent.astro';
import ScrollToTop from '@/components/shared/navigation/ScrollToTop.astro';
import NavigationProgress from '@/components/shared/navigation/NavigationProgress.astro';
import FontsLoader from '@/components/shared/FontsLoader.astro';
import ThemeFoucScript from '@/components/shared/ThemeFoucScript.astro';
import { CookieConsentBanner } from '@/components/legal/CookieConsentBanner.client';
import PostHogScript from '@/components/analytics/PostHogScript.astro';
import { ToastViewport } from '@/components/ui/ToastViewport.client';
import { GuestPreferenceNudge } from '@/components/shared/preferences/GuestPreferenceNudge.client';
import { AuthedPreferenceSync } from '@/components/shared/preferences/AuthedPreferenceSync.client';
import { FeedbackFABClient } from '@/components/feedback/FeedbackFAB.client';
import { PaginationLoading } from '@/components/shared/feedback/PaginationLoading.client';
import '@/styles/global.css';
// Static stylesheet for the @repo/feedback widget. Imported here so Astro/Vite
// tracks it as a page-level CSS asset and preserves it across view transitions
// (a runtime-injected style tag would be dropped when Astro swaps the head).
import '@repo/feedback/styles.css';
// App-level overrides: map @repo/feedback tokens onto the Hospeda brand palette
// and lift the FAB above the ScrollToTop button. Loaded after the package CSS
// so the override selectors win without needing higher specificity.
import '@/styles/feedback-overrides.css';

interface Props {
	readonly locale: SupportedLocale;
	readonly title?: string;
	readonly description?: string;
}

const {
	locale,
	title = 'Hospeda',
	description = 'Descubrí alojamientos en el Litoral Entrerriano',
} = Astro.props;

const cspNonce = Astro.locals.cspNonce ?? '';
const cookiesPolicyUrl = buildUrl({ locale, path: 'legal/cookies' });

const feedbackEnabled = isFeedbackEnabled();
const apiUrl = getApiUrl();
const deployVersion = getDeployVersion();

/**
 * Hint for client islands (UserMenu, GuestPreferenceNudge) about whether the
 * visitor is authenticated. Only reliable on routes where middleware parses
 * the session (protected, auth, optional-session). On SSG / public routes
 * `Astro.locals.user` is null, so `UserMenu` does its own /auth/me fetch
 * after hydration and updates this attribute as needed.
 */
const isAuthenticatedHint = Astro.locals.user ? 'true' : 'false';
---

<!doctype html>
<html lang={locale} data-user-authenticated={isAuthenticatedHint}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />

		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Google Fonts: Geologica, Roboto, Caveat (non-blocking with preload + swap) -->
		<FontsLoader cspNonce={cspNonce} />

		<ThemeFoucScript cspNonce={cspNonce} />

		<!-- FOUC prevention: hide text until fonts load.
			 Guard with fonts.status check so client-side View Transition
			 navigations (where fonts are already cached) never hide the body. -->
		<script is:inline nonce={cspNonce}>
			if (document.fonts.status !== 'loaded') {
				document.documentElement.classList.add('fonts-loading');
			}
			document.fonts.ready.then(function() {
				document.documentElement.classList.remove('fonts-loading');
			});
		</script>
		<style is:inline nonce={cspNonce}>
			.fonts-loading body {
				opacity: 0;
			}
			body {
				transition: opacity 0.2s ease;
			}
		</style>

		<ClientRouter />

		{feedbackEnabled && (
			<script is:inline nonce={cspNonce}>{`
				/* Feedback nav-history bootstrap (Opción A).
				   Captures navigation BEFORE the FAB island hydrates with
				   client:idle, persists to sessionStorage so the FAB picks
				   it up on hydration and across full-page reloads. */
				(function () {
					if (window.__hospedaFeedbackBootstrapped) return;
					window.__hospedaFeedbackBootstrapped = true;
					var SS_KEY = '__hospeda_feedback_nav__';
					var MAX = 10;
					function read() {
						try {
							var raw = sessionStorage.getItem(SS_KEY);
							var parsed = raw ? JSON.parse(raw) : [];
							return Array.isArray(parsed) ? parsed : [];
						} catch (e) { return []; }
					}
					function write(nav) {
						try { sessionStorage.setItem(SS_KEY, JSON.stringify(nav)); } catch (e) {}
					}
					function push(url) {
						if (!url) return;
						var nav = read();
						if (nav[nav.length - 1] === url) return;
						nav.push(url);
						if (nav.length > MAX) nav = nav.slice(-MAX);
						write(nav);
					}
					function current() {
						try { return location.pathname + location.search; }
						catch (e) { return ''; }
					}
					push(current());
					var origPush = history.pushState;
					var origReplace = history.replaceState;
					history.pushState = function () {
						var r = origPush.apply(this, arguments);
						push(current());
						return r;
					};
					history.replaceState = function () {
						var r = origReplace.apply(this, arguments);
						push(current());
						return r;
					};
					window.addEventListener('popstate', function () { push(current()); });
					document.addEventListener('astro:after-swap', function () { push(current()); });
				})();
			`}</script>
		)}

		<!--
		  PostHog analytics snippet (SPEC-140).
		  Inline so window.posthog is stubbed before any island hydrates and
		  calls trackEvent(). Renders nothing in dev mode or when the project
		  key is unset (e.g. locally-built previews without the secret).
		-->
		<PostHogScript cspNonce={cspNonce} />

		<!-- Named slot for page-specific head content (SEOHead, JSON-LD, etc.) -->
		<slot name="head" />

		<!--
		  Fallback: when JavaScript is disabled, the IntersectionObserver that
		  reveals [data-reveal] elements never runs, so the entire page below
		  the hero would stay invisible. Force-reveal everything for no-JS users
		  and SEO crawlers that don't execute scripts.
		-->
		<noscript>
			<style>
				[data-reveal] {
					opacity: 1 !important;
					transform: none !important;
				}
			</style>
		</noscript>

		<!--
		  Cloudflare Web Analytics (manual snippet).
		  We use the manual setup (NOT the auto-inject) so this <script> tag
		  receives the per-request CSP nonce via our middleware-driven walker
		  (SPEC-046 T-002). `strict-dynamic` in script-src then propagates
		  trust to the loaded beacon.min.js. The beacon POSTs Core Web Vitals
		  telemetry to https://cloudflareinsights.com — that host must be
		  present in `connect-src` (added in buildCspHeader, SPEC-046 follow-up).
		-->
		<script
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon='{"token": "2dbd11c61c6a461f9b75acf4a0877a83"}'
		></script>
	</head>
	<body>
		<NavigationProgress />
		<SkipToContent />
		<Header locale={locale} />

		<main id="main-content">
			<slot />
		</main>

		<Footer locale={locale} />
		<ScrollToTop locale={locale} />
		<CookieConsentBanner
			client:idle
			transition:persist="cookie-consent-banner"
			locale={locale}
			cookiesPolicyUrl={cookiesPolicyUrl}
		/>

		<ToastViewport client:idle />
		<GuestPreferenceNudge client:idle />
		<AuthedPreferenceSync client:idle />
		<PaginationLoading client:idle />

		{feedbackEnabled && (
			<FeedbackFABClient
				client:idle
				transition:persist="feedback-fab"
				apiUrl={apiUrl}
				deployVersion={deployVersion}
				userId={Astro.locals.user?.id}
				userEmail={Astro.locals.user?.email}
				userName={Astro.locals.user?.name}
			/>
		)}

		<!-- Page initialization script -->
		<script>
			import { initScrollReveal } from '@/lib/scroll-reveal';
			import { initImageFallback } from '@/scripts/image-fallback';
			import { initStopPropagation } from '@/scripts/dom-helpers';

			// Initialize delegated handlers once (module-level dedup)
			initImageFallback();
			initStopPropagation();

			function initParallax(): void {
				if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

				const elements = document.querySelectorAll<HTMLElement>('[data-parallax-speed]');
				if (elements.length === 0) return;

				const observer = new IntersectionObserver((entries) => {
					for (const entry of entries) {
						const el = entry.target as HTMLElement;
						if (entry.isIntersecting) {
							el.dataset.parallaxActive = 'true';
						} else {
							delete el.dataset.parallaxActive;
						}
					}
				}, { rootMargin: '100px' });

				elements.forEach((el) => observer.observe(el));

				let ticking = false;
				window.addEventListener('scroll', () => {
					if (ticking) return;
					ticking = true;
					requestAnimationFrame(() => {
						for (const el of elements) {
							if (el.dataset.parallaxActive !== 'true') continue;
							const speed = parseFloat(el.dataset.parallaxSpeed || '0.1');
							const rect = el.getBoundingClientRect();
							const offset = (rect.top + rect.height / 2 - window.innerHeight / 2) * speed;
							el.style.transform = `translateY(${offset}px)`;
						}
						ticking = false;
					});
				}, { passive: true });
			}

			async function initPage(): Promise<void> {
				initScrollReveal();
				initParallax();
				// Lazy-load GLightbox only when elements with [data-glightbox] exist on the page
				if (document.querySelector('[data-glightbox]')) {
					const [{ default: GLightbox }] = await Promise.all([
						import('glightbox'),
						import('glightbox/dist/css/glightbox.min.css'),
					]);
					GLightbox({
						selector: '[data-glightbox]',
						touchNavigation: true,
						loop: true,
					});
				}
			}

			// Runs on initial page load AND after every client-side navigation
			document.addEventListener('astro:page-load', initPage);

			/*
			 * After paginating to /page/N/ inside a listing, the browser keeps
			 * the previous scroll position by default, which on mobile leaves
			 * the user 500-700px above the first card (header + breadcrumbs +
			 * wave header + type badges + view toggle all stacked on top).
			 * Auto-scroll to the results grid so the new page lands on cards.
			 *
			 * `astro:after-swap` runs after the DOM swap but before the browser
			 * paints, so the scroll appears instant. Page 1 (no /page/ segment)
			 * is intentionally NOT auto-scrolled because users arriving via
			 * direct link or header should see the page header first.
			 */
			document.addEventListener('astro:after-swap', () => {
				if (!location.pathname.includes('/page/')) return;
				const target = document.querySelector<HTMLElement>('.listing-content, .acc-grid');
				if (!target) return;
				const navbarHeight = parseInt(
					getComputedStyle(document.documentElement).getPropertyValue('--navbar-height') || '80',
					10
				);
				const offset = target.getBoundingClientRect().top + window.scrollY - navbarHeight - 16;
				window.scrollTo({ top: Math.max(0, offset), behavior: 'instant' });
			});
		</script>
	</body>
</html>
