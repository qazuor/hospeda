---
/**
 * Global site footer with categorized navigation links and copyright.
 * Provides organized access to main site sections, information, and legal pages.
 */
import Container from '../components/ui/Container.astro';
import { NewsletterCTA } from '../components/newsletter/NewsletterCTA.client';
import { InstagramIcon, FacebookIcon, WhatsappIcon } from '@repo/icons';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

// Get authenticated user from middleware
const authenticatedUser = Astro.locals.user;
const isAuthenticated = !!authenticatedUser;

// Newsletter section titles
const newsletterTitle = locale === 'es' ? 'Suscribite a nuestro newsletter' : 'Subscribe to our newsletter';

const linkGroups = [
  {
    title: 'Explorar',
    links: [
      { label: 'Alojamientos', href: `/${locale}/alojamientos/` },
      { label: 'Destinos', href: `/${locale}/destinos/` },
      { label: 'Eventos', href: `/${locale}/eventos/` },
      { label: 'Blog', href: `/${locale}/publicaciones/` },
    ],
  },
  {
    title: 'Informacion',
    links: [
      { label: 'Quienes somos', href: `/${locale}/quienes-somos/` },
      { label: 'Beneficios', href: `/${locale}/beneficios/` },
      { label: 'Contacto', href: `/${locale}/contacto/` },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Terminos y condiciones', href: `/${locale}/terminos-condiciones/` },
      { label: 'Privacidad', href: `/${locale}/privacidad/` },
      { label: 'Sitemap', href: `/${locale}/sitemap/` },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer role="contentinfo" class="border-t border-border bg-surface">
  <Container size="xl">
    <div class="py-12 md:py-16">
      <!-- Newsletter Section -->
      <div class="mb-12">
        <h2 class="mb-6 text-2xl font-bold text-text">{newsletterTitle}</h2>
        <NewsletterCTA
          client:idle
          locale={locale}
          isAuthenticated={isAuthenticated}
        />
      </div>

      <!-- Link columns -->
      <div class="grid grid-cols-2 gap-8 md:grid-cols-3 lg:grid-cols-4">
        <!-- Brand column -->
        <div class="col-span-2 md:col-span-1">
          <a href={`/${locale}/`} class="font-serif text-xl font-bold text-primary no-underline">
            Hospeda
          </a>
          <p class="mt-3 text-sm text-text-tertiary">
            Descubre alojamientos en el Litoral argentino.
          </p>
        </div>

        <!-- Link groups -->
        {linkGroups.map((group) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-text">
              {group.title}
            </h3>
            <ul class="mt-4 space-y-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-text-tertiary transition-colors hover:text-primary"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Social Media Links -->
      <div class="mt-12 border-t border-border pt-8">
        <div class="flex justify-center gap-6 mb-8">
          <!-- Instagram -->
          <a
            href="https://instagram.com/hospeda"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-tertiary transition-colors hover:text-primary"
            aria-label="Instagram"
          >
            <InstagramIcon size={24} aria-hidden="true" />
          </a>

          <!-- Facebook -->
          <a
            href="https://facebook.com/hospeda"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-tertiary transition-colors hover:text-primary"
            aria-label="Facebook"
          >
            <FacebookIcon size={24} aria-hidden="true" />
          </a>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/5493442000000"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-tertiary transition-colors hover:text-primary"
            aria-label="WhatsApp"
          >
            <WhatsappIcon size={24} aria-hidden="true" />
          </a>
        </div>
      </div>

      <!-- Copyright -->
      <div class="border-t border-border pt-8">
        <p class="text-center text-sm text-text-tertiary">
          &copy; {currentYear} Hospeda. Todos los derechos reservados.
        </p>
      </div>
    </div>
  </Container>
</footer>
