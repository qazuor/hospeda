---
/**
 * @file Footer.astro
 * @description Site footer with 4-zone vertical layout:
 * - ZONE 1: Brand block (logo + description + social) plus 3-column nav
 *           grid (Explorar / Para vos / Hospeda). Heights are balanced
 *           by keeping the newsletter form out of the brand column.
 * - ZONE 1.5: Full-width newsletter strip.
 * - ZONE 2: Trust signals strip + accepted payment methods row.
 * - ZONE 3: Bottom bar with contact info, inline legal links, copyright.
 *
 * Mobile (<768px): nav columns collapse into <details> accordions, brand
 * block stacks above the nav, trust signals wrap into a 2x2 grid.
 *
 * Stats are pulled at request time from `/api/v1/public/stats` (cached 1h
 * server-side). On fetch failure the section degrades gracefully to round
 * fallback numbers so the footer never renders broken values.
 *
 * Rendering: Static HTML (no client JavaScript beyond the cookie-consent
 * reopen handler).
 */

import { Image } from "astro:assets";
import GradientButton from "@/components/shared/ui/GradientButton.astro";
import SocialLinks from "@/components/shared/SocialLinks.astro";
import { statsApi } from "@/lib/api/endpoints";
import type { SupportedLocale } from "@/lib/i18n";
import { createTranslations } from "@/lib/i18n";
import { buildUrl } from "@/lib/urls";
import logoSrc from "@/assets/images/logo.webp";

interface Props {
    readonly locale: SupportedLocale;
}

const { locale } = Astro.props;
const { t } = createTranslations(locale);

const currentYear = new Date().getFullYear();

/** Round a count down to the nearest "marketing-friendly" tier so the
 *  footer reads as `+50` / `+100` / `+1.000` rather than the precise
 *  database number. Keeps the value honest while reinforcing scale. */
function roundDown(n: number): number {
    if (n >= 10000) return Math.floor(n / 1000) * 1000;
    if (n >= 1000) return Math.floor(n / 100) * 100;
    if (n >= 100) return Math.floor(n / 50) * 50;
    if (n >= 10) return Math.floor(n / 10) * 10;
    return n;
}

/** Fallbacks used if the stats endpoint is unreachable. Round numbers
 *  picked to look plausible without lying about scale. */
const STATS_FALLBACK = {
    accommodations: 100,
    destinations: 20,
    averageRating: 4.5,
} as const;

let statsAccommodations = STATS_FALLBACK.accommodations;
let statsAverageRating = STATS_FALLBACK.averageRating;

try {
    const result = await statsApi.getPlatformStats();
    if (result.success && result.data) {
        statsAccommodations = roundDown(result.data.accommodations) || STATS_FALLBACK.accommodations;
        statsAverageRating = result.data.averageRating > 0
            ? result.data.averageRating
            : STATS_FALLBACK.averageRating;
    }
} catch {
    // Silently fall through to defaults. Footer must never break the page.
}

const formattedCount = new Intl.NumberFormat(locale === "es" ? "es-AR" : locale).format(statsAccommodations);
const formattedRating = statsAverageRating.toFixed(1).replace(".", ",");

/** EXPLORAR column — top-level sections + search */
const exploreLinks = [
    { label: t("footer.accommodations"), href: buildUrl({ locale, path: "/alojamientos/" }) },
    { label: t("footer.destinations"), href: buildUrl({ locale, path: "/destinos/" }) },
    { label: t("footer.events"), href: buildUrl({ locale, path: "/eventos/" }) },
    { label: t("footer.publications"), href: buildUrl({ locale, path: "/publicaciones/" }) },
    { label: t("footer.search", "Buscar"), href: buildUrl({ locale, path: "/busqueda/" }) },
] as const;

/** PARA VOS column — owner + tourist value props */
const forYouLinks = [
    { label: t("footer.listProperty"), href: buildUrl({ locale, path: "/suscriptores/propietarios/" }) },
    { label: t("footer.ownerPlans"), href: buildUrl({ locale, path: "/suscriptores/planes/" }) },
    { label: t("footer.touristPlans"), href: buildUrl({ locale, path: "/suscriptores/turistas/" }) },
    { label: t("footer.benefits"), href: buildUrl({ locale, path: "/beneficios/" }) },
] as const;

/** HOSPEDA column — corporate */
const companyLinks = [
    { label: t("footer.aboutUs"), href: buildUrl({ locale, path: "/nosotros/" }) },
    { label: t("footer.faq", "Preguntas frecuentes"), href: buildUrl({ locale, path: "/preguntas-frecuentes/" }) },
    { label: t("footer.contact"), href: buildUrl({ locale, path: "/contacto/" }) },
] as const;

/** Legal links — collapsed into a single inline row in the bottom bar. */
const legalLinks = [
    { label: t("footer.terms"), href: buildUrl({ locale, path: "/legal/terminos/" }) },
    { label: t("footer.privacy"), href: buildUrl({ locale, path: "/legal/privacidad/" }) },
    { label: t("footer.cookies"), href: buildUrl({ locale, path: "/legal/cookies/" }) },
] as const;

const cookiePreferencesLabel = t("cookieConsent.footer.preferencesLink", "Preferencias de cookies");
const trustLabel = t("footer.trustSignals.label", "Por qué elegirnos");
const paymentsLabel = t("footer.payments.label", "Métodos de pago");
const accommodationsCountLabel = t("footer.trustSignals.accommodationsCount", "+{{count}} alojamientos").replace("{{count}}", formattedCount);

/** Payment method logos served from the simpleicons CDN. Single-color
 *  brand marks are returned as SVG and tinted via the `?color=` query.
 *  Naranja X is intentionally omitted (no slug available upstream). */
const paymentMethods = [
    { slug: "mercadopago", label: "Mercado Pago" },
    { slug: "visa", label: "Visa" },
    { slug: "mastercard", label: "Mastercard" },
    { slug: "americanexpress", label: "American Express" },
] as const;
const averageRatingLabel = t("footer.trustSignals.averageRating", "{{rating}} de promedio").replace("{{rating}}", formattedRating);
const localSupportLabel = t("footer.trustSignals.localSupport", "Soporte local en español");
const securePaymentsLabel = t("footer.trustSignals.securePayments", "Pagos seguros");
const noCommissionsLabel = t("footer.trustSignals.noCommissions", "Sin comisiones ocultas");
---

<footer class="footer">
    <!-- Wave decoration overlapping the section above -->
    <div class="footer__wave" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path
                d="M0,48 C180,72 360,16 540,32 C720,48 900,80 1080,56 C1260,32 1380,40 1440,48 L1440,80 L0,80 Z"
                fill="var(--footer-bg)"
            ></path>
        </svg>
    </div>

    <!-- ZONE 1: Brand + nav -->
    <section class="footer__main">
        <div class="footer__container footer__main-grid">
            <!-- Brand block: logo, description, social, inline newsletter -->
            <div class="footer__brand">
                <a
                    href={buildUrl({ locale, path: "/" })}
                    class="footer__logo"
                    aria-label="Hospeda"
                >
                    <Image
                        src={logoSrc}
                        alt=""
                        width={48}
                        height={52}
                        class="footer__logo-icon"
                        loading="lazy"
                    />
                    <span class="footer__logo-wordmark">Hospeda</span>
                </a>

                <p class="footer__brand-desc">
                    {t("footer.shortDescription")}
                </p>

                <div class="footer__brand-social">
                    <SocialLinks variant="light" />
                </div>
            </div>

            <!-- 3-column navigation -->
            <nav class="footer__nav" aria-label={t("footer.navigation", "Footer navigation")}>
                <details class="footer__nav-col" open>
                    <summary class="footer__nav-heading">{t("footer.exploreTitle")}</summary>
                    <ul class="footer__nav-list">
                        {
                            exploreLinks.map(({ label, href }) => (
                                <li>
                                    <a href={href} class="footer__nav-link">
                                        {label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </details>

                <details class="footer__nav-col" open>
                    <summary class="footer__nav-heading">{t("footer.forYouTitle", "Para vos")}</summary>
                    <ul class="footer__nav-list">
                        {
                            forYouLinks.map(({ label, href }) => (
                                <li>
                                    <a href={href} class="footer__nav-link">
                                        {label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </details>

                <details class="footer__nav-col" open>
                    <summary class="footer__nav-heading">{t("footer.hospedaTitle")}</summary>
                    <ul class="footer__nav-list">
                        {
                            companyLinks.map(({ label, href }) => (
                                <li>
                                    <a href={href} class="footer__nav-link">
                                        {label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </details>
            </nav>
        </div>
    </section>

    <!-- ZONE 1.5: Newsletter strip -->
    <section class="footer__newsletter-zone" aria-label={t("footer.newsletterShortTitle", "Recibí novedades")}>
        <div class="footer__container footer__newsletter-inner">
            <div class="footer__newsletter-text">
                <h3 class="footer__newsletter-title">
                    {t("footer.newsletterShortTitle", "Recibí novedades")}
                </h3>
                <p class="footer__newsletter-desc">
                    {t("footer.newsletterShortDescription", "Novedades y ofertas en tu correo.")}
                </p>
            </div>
            <form
                class="footer__newsletter"
                data-prevent-submit
            >
                <label for="newsletter-email" class="sr-only">
                    {t("footer.newsletterPlaceholder")}
                </label>
                <input
                    id="newsletter-email"
                    type="email"
                    name="email"
                    autocomplete="email"
                    class="footer__newsletter-input"
                    placeholder={t("footer.newsletterPlaceholder")}
                    aria-label={t("footer.newsletterPlaceholder")}
                />
                <GradientButton
                    as="button"
                    label={t("footer.subscribeShort", "Suscribirme")}
                    variant="accent"
                    size="sm"
                    class="footer__newsletter-btn"
                />
            </form>
        </div>
    </section>

    <!-- ZONE 2: Trust signals + payments -->
    <section class="footer__trust" aria-label={trustLabel}>
        <div class="footer__container footer__trust-inner">
            <ul class="footer__trust-list">
                <li class="footer__trust-item">
                    <svg class="footer__trust-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M3 11l9-7 9 7v9a2 2 0 0 1-2 2h-4v-7h-6v7H5a2 2 0 0 1-2-2v-9z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="footer__trust-text">
                        <strong class="footer__trust-strong">{accommodationsCountLabel}</strong>
                        <span class="footer__trust-meta">{averageRatingLabel}</span>
                    </span>
                </li>
                <li class="footer__trust-item">
                    <svg class="footer__trust-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="footer__trust-text">
                        <strong class="footer__trust-strong">{localSupportLabel}</strong>
                    </span>
                </li>
                <li class="footer__trust-item">
                    <svg class="footer__trust-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 2L4 6v6c0 5 3.5 9.4 8 10 4.5-.6 8-5 8-10V6l-8-4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="footer__trust-text">
                        <strong class="footer__trust-strong">{securePaymentsLabel}</strong>
                    </span>
                </li>
                <li class="footer__trust-item">
                    <svg class="footer__trust-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.6"/>
                        <circle cx="16" cy="16" r="2.5" stroke="currentColor" stroke-width="1.6"/>
                        <path d="M19 5L5 19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    </svg>
                    <span class="footer__trust-text">
                        <strong class="footer__trust-strong">{noCommissionsLabel}</strong>
                    </span>
                </li>
            </ul>

            <ul class="footer__payments-list" aria-label={paymentsLabel}>
                {
                    paymentMethods.map(({ slug, label }) => (
                        <li>
                            <img
                                class="footer__payment"
                                src={`https://cdn.simpleicons.org/${slug}/ffffff`}
                                alt={label}
                                loading="lazy"
                                width="48"
                                height="24"
                            />
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <!-- ZONE 3: Bottom bar -->
    <section class="footer__bottom">
        <div class="footer__container footer__bottom-inner">
            <div class="footer__bottom-contact">
                <a class="footer__contact-link" href={`mailto:${t("footer.contactEmail")}`}>
                    <svg class="footer__contact-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/>
                        <path d="M3 7l9 6 9-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    </svg>
                    <span>{t("footer.contactEmail")}</span>
                </a>
                <a class="footer__contact-link" href={`tel:${t("footer.contactPhone").replace(/\s+/g, "")}`}>
                    <svg class="footer__contact-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M22 16.92V20a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2H7.2a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>{t("footer.contactPhone")}</span>
                </a>
            </div>

            <ul class="footer__legal" aria-label={t("footer.legal", "Legal")}>
                {
                    legalLinks.map(({ label, href }) => (
                        <li>
                            <a href={href} class="footer__legal-link">
                                {label}
                            </a>
                        </li>
                    ))
                }
                <li>
                    <button
                        type="button"
                        class="footer__legal-link footer__cookie-btn"
                        data-cookie-consent-reopen
                        aria-label={cookiePreferencesLabel}
                    >
                        {cookiePreferencesLabel}
                    </button>
                </li>
            </ul>

            <p class="footer__copyright">
                &copy; {currentYear} Hospeda. {t("footer.bottom.rights", "Todos los derechos reservados")}.
            </p>
        </div>
    </section>
</footer>

<script>
    /** Footer client-side wiring. Replaces inline event handlers, which are blocked by CSP. */
    document.addEventListener("astro:page-load", () => {
        const btn = document.querySelector("[data-cookie-consent-reopen]");
        if (btn) {
            btn.addEventListener("click", () => {
                window.dispatchEvent(new CustomEvent("cookie-consent:reopen"));
            });
        }
        // Newsletter forms opt out of native submission via [data-prevent-submit].
        for (const form of document.querySelectorAll<HTMLFormElement>(
            "form[data-prevent-submit]"
        )) {
            form.addEventListener("submit", (event) => {
                event.preventDefault();
            });
        }
    });
</script>

<style>
    /* ════════════════════════════════════════════════════════════════════
       Footer — base
       ════════════════════════════════════════════════════════════════════ */
    .footer {
        position: relative;
        background-color: var(--footer-bg);
        color: var(--footer-fg);
    }

    .footer__container {
        max-width: var(--container-max);
        margin-inline: auto;
        padding-inline: var(--space-container-x);
    }

    /* ════════════════════════════════════════════════════════════════════
       Wave decoration — smoother, double-curve transition into the footer
       ════════════════════════════════════════════════════════════════════ */
    .footer__wave {
        position: absolute;
        top: clamp(-3rem, -4vw, -4.5rem);
        left: 0;
        width: 100%;
        height: 4rem;
        pointer-events: none;
    }

    .footer__wave svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    /* ════════════════════════════════════════════════════════════════════
       ZONE 1: Brand + nav
       ════════════════════════════════════════════════════════════════════ */
    .footer__main {
        padding-block: clamp(2.5rem, 5vw, 4rem);
    }

    .footer__main-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: clamp(2rem, 4vw, 3.5rem);
    }

    /* Brand block — vertical stack on all sizes */
    .footer__brand {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .footer__logo {
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        text-decoration: none;
        color: var(--footer-fg);
        width: fit-content;
    }

    .footer__logo-icon {
        width: 2.5rem;
        height: auto;
        object-fit: contain;
    }

    .footer__logo-wordmark {
        font-family: var(--font-decorative);
        font-size: clamp(2rem, 1.5rem + 1.5vw, 2.5rem);
        font-weight: 700;
        line-height: 1;
        color: var(--footer-fg);
    }

    .footer__brand-desc {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        line-height: 1.6;
        color: var(--footer-fg-muted);
        max-width: 30ch;
        margin: 0;
    }

    .footer__brand-social {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* ════════════════════════════════════════════════════════════════════
       ZONE 1.5: Newsletter strip — full-width row, sits between nav & trust
       ════════════════════════════════════════════════════════════════════ */
    .footer__newsletter-zone {
        border-top: 1px solid var(--footer-border);
        padding-block: clamp(1.5rem, 3vw, 2rem);
    }

    .footer__newsletter-inner {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .footer__newsletter-text {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .footer__newsletter-title {
        font-family: var(--font-heading);
        font-size: var(--text-h4);
        font-weight: 600;
        line-height: 1.2;
        color: var(--footer-fg);
        margin: 0;
    }

    .footer__newsletter-desc {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        line-height: 1.5;
        color: var(--footer-fg-muted);
        margin: 0;
    }

    .footer__newsletter {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .footer__newsletter-input {
        flex: 1;
        min-width: 0;
        background-color: oklch(from var(--footer-fg) l c h / 0.08);
        border: 1px solid var(--footer-border);
        border-radius: var(--radius-button);
        padding: 0.625rem 0.875rem;
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        color: var(--footer-fg);
        outline: none;
        transition: border-color var(--duration-normal) ease,
            background-color var(--duration-normal) ease;
    }

    .footer__newsletter-input::placeholder {
        color: var(--footer-fg-muted);
    }

    .footer__newsletter-input:focus {
        border-color: oklch(from var(--footer-fg) l c h / 0.5);
        background-color: oklch(from var(--footer-fg) l c h / 0.12);
    }

    .footer__newsletter-btn {
        align-self: flex-start;
        white-space: nowrap;
    }

    /* ════════════════════════════════════════════════════════════════════
       Nav columns
       ════════════════════════════════════════════════════════════════════ */
    .footer__nav {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
    }

    .footer__nav-col {
        border-bottom: 1px solid var(--footer-border);
        padding-block: 0.5rem;
    }

    .footer__nav-heading {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--font-heading);
        font-size: var(--text-h4);
        font-weight: 500;
        line-height: 1.2;
        color: var(--footer-fg);
        padding-block: 0.25rem;
    }

    .footer__nav-heading::-webkit-details-marker,
    .footer__nav-heading::marker {
        display: none;
    }

    .footer__nav-heading::after {
        content: "+";
        font-size: 1.25rem;
        font-weight: 400;
        color: var(--footer-fg-muted);
        transition: transform var(--duration-normal) ease;
    }

    .footer__nav-col[open] .footer__nav-heading::after {
        transform: rotate(45deg);
    }

    .footer__nav-list {
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
        list-style: none;
        padding: 0.75rem 0 0.5rem 0;
        margin: 0;
    }

    .footer__nav-link {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        line-height: 1.4;
        color: var(--footer-fg-muted);
        text-decoration: none;
        transition: color var(--duration-normal) ease;
    }

    .footer__nav-link:hover,
    .footer__nav-link:focus-visible {
        color: var(--footer-fg);
    }

    /* ════════════════════════════════════════════════════════════════════
       ZONE 2: Trust signals + payments
       ════════════════════════════════════════════════════════════════════ */
    .footer__trust {
        border-top: 1px solid var(--footer-border);
        border-bottom: 1px solid var(--footer-border);
        padding-block: 1.25rem;
    }

    .footer__trust-inner {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .footer__trust-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer__trust-item {
        display: flex;
        align-items: center;
        gap: 0.625rem;
    }

    .footer__trust-icon {
        flex-shrink: 0;
        width: 1.5rem;
        height: 1.5rem;
        color: var(--brand-accent);
    }

    .footer__trust-text {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        line-height: 1.3;
        min-width: 0;
    }

    .footer__trust-strong {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        font-weight: 600;
        color: var(--footer-fg);
    }

    .footer__trust-meta {
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        color: var(--footer-fg-muted);
    }

    /* Payments row — logo-only, served from cdn.simpleicons.org */
    .footer__payments-list {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 1.25rem;
        list-style: none;
        padding: 0;
        margin: 0;
        flex-shrink: 0;
    }

    .footer__payment {
        height: 1.5rem;
        width: auto;
        display: block;
        flex-shrink: 0;
        opacity: 0.7;
        transition: opacity var(--duration-normal) ease;
    }

    .footer__payments-list li:hover .footer__payment {
        opacity: 1;
    }

