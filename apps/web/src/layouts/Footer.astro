---
/**
 * @file Footer.astro
 * @description Site footer with 5-column navigation layout on desktop.
 * Layout:
 * - Wave SVG decoration overlapping the previous section
 * - TOP ROW (flex): LEFT_BLOCK (logo + description + social) + RIGHT_BLOCK (newsletter card + 5-col nav grid)
 * - BOTTOM BAR: contact info left, copyright right
 * - Mobile (<768px): nav columns collapse into <details><summary> accordion
 *
 * Columns: Explorar | Categorías | Destinos | Propietarios & Turistas | Hospeda
 *
 * Rendering: Static (no client JavaScript).
 */

import { Image } from "astro:assets";
import GradientButton from "@/components/shared/ui/GradientButton.astro";
import SocialLinks from "@/components/shared/SocialLinks.astro";
import type { SupportedLocale } from "@/lib/i18n";
import { createTranslations } from "@/lib/i18n";
import { buildUrl } from "@/lib/urls";
import logoSrc from "@/assets/images/logo.webp";

interface Props {
    readonly locale: SupportedLocale;
}

const { locale } = Astro.props;
const { t } = createTranslations(locale);

const currentYear = new Date().getFullYear();

/** EXPLORAR column — top-level sections + search */
const exploreLinks = [
    { label: t("footer.accommodations"), href: buildUrl({ locale, path: "/alojamientos/" }) },
    { label: t("footer.destinations"), href: buildUrl({ locale, path: "/destinos/" }) },
    { label: t("footer.events"), href: buildUrl({ locale, path: "/eventos/" }) },
    { label: t("footer.publications"), href: buildUrl({ locale, path: "/publicaciones/" }) },
    { label: t("footer.search", "Buscar"), href: buildUrl({ locale, path: "/busqueda/" }) },
] as const;

/** CATEGORÍAS column — curated accommodation types and event categories */
const categoryLinks = [
    { label: t("footer.categoryCabins", "Cabañas"), href: buildUrl({ locale, path: "/alojamientos/tipo/cabin/" }) },
    { label: t("footer.categoryHotels", "Hoteles"), href: buildUrl({ locale, path: "/alojamientos/tipo/hotel/" }) },
    { label: t("footer.categoryHouses", "Casas"), href: buildUrl({ locale, path: "/alojamientos/tipo/house/" }) },
    { label: t("footer.categoryMusic", "Música"), href: buildUrl({ locale, path: "/eventos/categoria/music/" }) },
    { label: t("footer.categoryCulture", "Cultura"), href: buildUrl({ locale, path: "/eventos/categoria/culture/" }) },
    { label: t("footer.categoryGastronomy", "Gastronomía"), href: buildUrl({ locale, path: "/eventos/categoria/gastronomy/" }) },
    { label: t("footer.categoryNature", "Naturaleza"), href: buildUrl({ locale, path: "/eventos/categoria/nature/" }) },
] as const;

/** DESTINOS column */
const destinationLinks = [
    { label: t("footer.destinationCdu"), href: buildUrl({ locale, path: "/destinos/concepcion-del-uruguay/" }) },
    { label: t("footer.destinationColon"), href: buildUrl({ locale, path: "/destinos/colon/" }) },
    { label: t("footer.destinationGualeguaychu"), href: buildUrl({ locale, path: "/destinos/gualeguaychu/" }) },
    { label: t("footer.destinationSanJose"), href: buildUrl({ locale, path: "/destinos/san-jose/" }) },
] as const;

/** PROPIETARIOS & TURISTAS column */
const subscriberLinks = [
    { label: t("footer.listProperty"), href: buildUrl({ locale, path: "/suscriptores/propietarios/" }) },
    { label: t("footer.ownerPlans"), href: buildUrl({ locale, path: "/suscriptores/planes/" }) },
    { label: t("footer.touristPlans"), href: buildUrl({ locale, path: "/suscriptores/turistas/" }) },
    { label: t("footer.benefits"), href: buildUrl({ locale, path: "/beneficios/" }) },
] as const;

/** HOSPEDA column */
const companyLinks = [
    { label: t("footer.aboutUs"), href: buildUrl({ locale, path: "/nosotros/" }) },
    { label: t("footer.contact"), href: buildUrl({ locale, path: "/contacto/" }) },
    { label: t("footer.terms"), href: buildUrl({ locale, path: "/legal/terminos/" }) },
    { label: t("footer.privacy"), href: buildUrl({ locale, path: "/legal/privacidad/" }) },
    { label: t("footer.cookies"), href: buildUrl({ locale, path: "/legal/cookies/" }) },
] as const;

const cookiePreferencesLabel = t("cookieConsent.footer.preferencesLink", "Preferencias de cookies");
---

<footer class="footer">
    <!-- Wave decoration: overlaps the section above -->
    <div class="footer__wave" aria-hidden="true">
        <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="var(--footer-bg)"
            ></path>
        </svg>
    </div>

    <!-- Top row: left block + right block -->
    <div class="footer__top">
        <div class="footer__container">
            <!-- LEFT BLOCK: logo + description + social -->
            <div class="footer__left">
                <div class="footer__logo">
                    <Image
                        src={logoSrc}
                        alt="Hospeda logo"
                        width={58}
                        height={63}
                        class="footer__logo-icon"
                        loading="lazy"
                    />
                    <span class="footer__logo-wordmark">Hospeda</span>
                </div>

                <p class="footer__description">
                    {t("footer.shortDescription")}
                </p>

                <SocialLinks variant="light" />
            </div>

            <!-- RIGHT BLOCK: newsletter card + nav grid -->
            <div class="footer__right">
                <!-- Newsletter card -->
                <div class="footer__newsletter">
                    <div class="footer__newsletter-text">
                        <h3 class="footer__newsletter-title">{t("footer.newsletterTitle")}</h3>
                        <p class="footer__newsletter-desc">{t("footer.newsletterDescription")}</p>
                    </div>
                    <div class="footer__newsletter-form">
                        <label for="newsletter-email" class="sr-only">
                            {t("footer.newsletterPlaceholder")}
                        </label>
                        <input
                            id="newsletter-email"
                            type="email"
                            name="email"
                            autocomplete="email"
                            class="footer__newsletter-input"
                            placeholder={t("footer.newsletterPlaceholder")}
                            aria-label={t("footer.newsletterPlaceholder")}
                        />
                        <GradientButton
                            as="button"
                            label={t("footer.subscribe")}
                            variant="accent"
                            size="sm"
                            class="footer__newsletter-btn"
                        />

                    </div>
                </div>

                <!-- Navigation columns: 5 columns on desktop, accordion on mobile -->
                <nav class="footer__nav" aria-label={t("footer.navigation", "Footer navigation")}>
                    <!-- Column 1: Explorar -->
                    <details class="footer__nav-col footer__nav-col--accordion" open>
                        <summary class="footer__nav-heading footer__nav-summary">
                            {t("footer.exploreTitle")}
                        </summary>
                        <ul class="footer__nav-list">
                            {
                                exploreLinks.map(({ label, href }) => (
                                    <li>
                                        <a href={href} class="footer__nav-link">
                                            {label}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </details>

                    <!-- Column 2: Categorías -->
                    <details class="footer__nav-col footer__nav-col--accordion" open>
                        <summary class="footer__nav-heading footer__nav-summary">
                            {t("footer.categoriesTitle", "Categorías")}
                        </summary>
                        <ul class="footer__nav-list">
                            {
                                categoryLinks.map(({ label, href }) => (
                                    <li>
                                        <a href={href} class="footer__nav-link">
                                            {label}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </details>

                    <!-- Column 3: Destinos -->
                    <details class="footer__nav-col footer__nav-col--accordion" open>
                        <summary class="footer__nav-heading footer__nav-summary">
                            {t("footer.destinationsTitle")}
                        </summary>
                        <ul class="footer__nav-list">
                            {
                                destinationLinks.map(({ label, href }) => (
                                    <li>
                                        <a href={href} class="footer__nav-link">
                                            {label}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </details>

                    <!-- Column 4: Propietarios & Turistas -->
                    <details class="footer__nav-col footer__nav-col--accordion" open>
                        <summary class="footer__nav-heading footer__nav-summary">
                            {t("footer.subscribersTitle", "Propietarios & Turistas")}
                        </summary>
                        <ul class="footer__nav-list">
                            {
                                subscriberLinks.map(({ label, href }) => (
                                    <li>
                                        <a href={href} class="footer__nav-link">
                                            {label}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </details>

                    <!-- Column 5: Hospeda -->
                    <details class="footer__nav-col footer__nav-col--accordion" open>
                        <summary class="footer__nav-heading footer__nav-summary">
                            {t("footer.hospedaTitle")}
                        </summary>
                        <ul class="footer__nav-list">
                            {
                                companyLinks.map(({ label, href }) => (
                                    <li>
                                        <a href={href} class="footer__nav-link">
                                            {label}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </details>
                </nav>
            </div>
        </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
        <div class="footer__container footer__bottom-inner">
            <p class="footer__bottom-contact">
                {t("footer.contactEmail")}&nbsp;&nbsp;|&nbsp;&nbsp;{t("footer.contactPhone")}
            </p>
            <div class="footer__bottom-right">
                <button
                    type="button"
                    class="footer__cookie-btn"
                    data-cookie-consent-reopen
                    aria-label={cookiePreferencesLabel}
                >
                    {cookiePreferencesLabel}
                </button>
                <p class="footer__bottom-copy">
                    &copy; {currentYear} Hospeda. {t("footer.rights")}
                </p>
            </div>
        </div>
    </div>
</footer>

<script>
    /** Dispatch the reopen event when any footer cookie-preferences button is clicked. */
    document.addEventListener('astro:page-load', () => {
        const btn = document.querySelector('[data-cookie-consent-reopen]');
        if (btn) {
            btn.addEventListener('click', () => {
                window.dispatchEvent(new CustomEvent('cookie-consent:reopen'));
            });
        }
    });
</script>

<style>
    /* ========================================================
       Footer — base
       ======================================================== */
    .footer {
        position: relative;
        background-color: var(--footer-bg);
        color: var(--footer-fg);
    }

    /* ========================================================
       Wave decoration
       ======================================================== */
    .footer__wave {
        position: absolute;
        top: clamp(-40px, -5vw, -59px);
        left: 0;
        width: 100%;
        height: 60px;
        pointer-events: none;
    }

    .footer__wave svg {
        width: 100%;
        height: 100%;
    }

    /* ========================================================
       Shared container
       ======================================================== */
    .footer__container {
        max-width: var(--container-max);
        margin-inline: auto;
        padding-inline: var(--space-container-x);
    }

    /* ========================================================
       Top row
       ======================================================== */
    .footer__top {
        padding-top: 96px;
    }

    .footer__top .footer__container {
        display: flex;
        flex-direction: column;
        gap: 48px;
        padding-top: 48px;
        padding-bottom: 48px;
    }

    /* ========================================================
       Left block
       ======================================================== */
    .footer__left {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
        flex-shrink: 0;
    }

    /* Logo: icon + wordmark (horizontal per Figma) */
    .footer__logo {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-inline: 10px;
    }

    .footer__logo-icon {
        width: 58px;
        height: 63px;
        object-fit: contain;
    }

    .footer__logo-wordmark {
        font-family: var(--font-decorative);
        font-size: 48px;
        font-weight: 700;
        color: var(--footer-fg);
        line-height: 1;
    }

    /* Description */
    .footer__description {
        font-family: var(--font-sans);
        font-size: var(--text-body);
        color: var(--footer-fg-muted);
        text-align: center;
        max-width: 205px;
        line-height: 1.5;
    }

    /* ========================================================
       Right block
       ======================================================== */
    .footer__right {
        display: flex;
        flex-direction: column;
        gap: 20px;
        flex: 1;
    }

    /* ========================================================
       Newsletter card
       ======================================================== */
    .footer__newsletter {
        display: flex;
        flex-direction: column;
        gap: 16px;
        background-color: var(--footer-newsletter-bg);
        border: 1px solid var(--footer-newsletter-border);
        border-radius: 24px;
        padding: 16px 12px;
    }

    .footer__newsletter-text {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .footer__newsletter-title {
        font-family: var(--font-heading);
        font-size: 24px;
        font-weight: 700;
        color: var(--footer-newsletter-fg);
        line-height: 1.2;
    }

    .footer__newsletter-desc {
        font-family: var(--font-sans);
        font-size: var(--text-body);
        color: var(--footer-newsletter-fg);
        line-height: 1.5;
    }

    .footer__newsletter-form {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .footer__newsletter-input {
        background-color: var(--core-background, #f5f5f5);
        border: 1px solid var(--border, #e0e0e0);
        border-radius: 12px;
        padding: 15px 16px;
        font-family: var(--font-sans);
        font-size: var(--text-body);
        color: var(--core-foreground);
        outline: none;
        width: 100%;
    }

    @media (min-width: 768px) {
        .footer__newsletter-input {
            width: clamp(200px, 30vw, 260px);
        }
    }

    .footer__newsletter-input:focus {
        border-color: var(--footer-newsletter-fg);
    }

    .footer__newsletter-btn {
        border-radius: var(--radius-pill, 9999px);
        align-self: flex-start;
        white-space: nowrap;
    }

    /* ========================================================
       Navigation grid
       ======================================================== */
    .footer__nav {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        column-gap: 24px;
        row-gap: 32px;
        padding-left: 0;
    }

    /* Accordion: <details> used as the column container on mobile */
    .footer__nav-col--accordion {
        border-bottom: 1px solid var(--footer-border);
        padding-bottom: 8px;
    }

    /* Summary acts as the column heading on mobile */
    .footer__nav-summary {
        cursor: pointer;
        list-style: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 0;
    }

    /* Remove default marker */
    .footer__nav-summary::-webkit-details-marker,
    .footer__nav-summary::marker {
        display: none;
    }

    /* Chevron indicator via ::after */
    .footer__nav-summary::after {
        content: "▾";
        font-size: 0.75rem;
        color: var(--footer-fg-muted);
        transition: transform var(--duration-normal) ease;
        flex-shrink: 0;
    }

    .footer__nav-col--accordion[open] .footer__nav-summary::after {
        transform: rotate(180deg);
    }

    .footer__nav-heading {
        font-family: var(--font-heading);
        font-size: clamp(1rem, 2vw, 1.25rem);
        font-weight: 700;
        color: var(--footer-link);
        margin-bottom: 0;
        line-height: 1.2;
    }

    .footer__nav-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        list-style: none;
        padding-top: 8px;
    }

    .footer__nav-link {
        font-family: var(--font-sans);
        font-size: var(--text-body);
        color: var(--footer-fg-muted);
        text-decoration: none;
        transition: color var(--duration-normal) ease;
        line-height: 1.4;
    }

    .footer__nav-link:hover {
        color: var(--footer-fg);
    }

    /* ========================================================
       Bottom bar
       ======================================================== */
    .footer__bottom {
        border-top: 1px solid var(--footer-border);
    }

    .footer__bottom-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: clamp(0.5rem, 2vw, 1rem);
        padding-block: 16px;
    }

    .footer__bottom-contact,
    .footer__bottom-copy {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        color: var(--footer-fg-muted);
        text-align: center;
    }

    /* Cookie preferences reopen button */
    .footer__bottom-right {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .footer__cookie-btn {
        font-family: var(--font-sans);
        font-size: var(--text-body-sm);
        color: var(--footer-fg-muted);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color var(--duration-normal) ease;
    }

    .footer__cookie-btn:hover {
        color: var(--footer-fg);
    }

    /* ========================================================
       Responsive: tablet (768px+)
       ======================================================== */
    @media (min-width: 768px) {
        .footer__top .footer__container {
            flex-direction: row;
            align-items: flex-start;
            gap: 64px;
        }

        .footer__newsletter {
            flex-direction: row;
            align-items: flex-start;
            gap: 32px;
        }

        .footer__newsletter-text {
            flex: 1;
            min-width: 0;
        }

        .footer__newsletter-form {
            flex-direction: row;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
        }

        .footer__bottom-inner {
            flex-direction: row;
            justify-content: space-between;
        }

        .footer__bottom-contact,
        .footer__bottom-copy {
            text-align: left;
        }

        .footer__bottom-right {
            flex-direction: row;
            align-items: center;
            gap: 16px;
        }
    }

    /* ========================================================
       Responsive: tablet (768px+) — accordion collapses into static columns
       ======================================================== */
    @media (min-width: 768px) {
        /* Reset accordion behaviour on tablet+ */
        .footer__nav-col--accordion {
            border-bottom: none;
            padding-bottom: 0;
        }

        .footer__nav-summary {
            cursor: default;
            pointer-events: none;
            padding: 0;
        }

        .footer__nav-summary::after {
            display: none;
        }

        /* Always show list content on tablet+ */
        .footer__nav-col--accordion:not([open]) .footer__nav-list {
            display: flex;
        }

        .footer__nav-heading {
            margin-bottom: 12px;
        }

        .footer__nav-list {
            padding-top: 0;
        }

        .footer__nav {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    /* ========================================================
       Responsive: desktop (1024px+) — full 5-column layout
       ======================================================== */
    @media (min-width: 1024px) {
        .footer__top .footer__container {
            gap: 64px;
        }

        .footer__newsletter {
            gap: 48px;
            padding: 16px 24px;
        }

        .footer__nav {
            grid-template-columns: repeat(5, 1fr);
            column-gap: 32px;
            row-gap: 19px;
            padding-left: 48px;
        }
    }
</style>
