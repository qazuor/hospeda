---
import { LocationIcon, EmailIcon, PhoneIcon, InstagramIcon, FacebookIcon, YoutubeIcon, CheckCircleIcon } from "@repo/icons";
import WaveDivider from "@/components/shared/WaveDivider.astro";
import { FOOTER_LINKS } from "@/data/navigation";
import { createT, type SupportedLocale } from "@/lib/i18n";
import { buildUrl } from "@/lib/urls";

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;
const typedLocale = locale as SupportedLocale;
const t = createT(typedLocale);

const columnTitles: Record<string, string> = {
  Explore: t('footer.columns.explorar', 'Explorar'),
  Destinations: t('footer.columns.destinos', 'Destinos'),
  Owners: t('footer.columns.propietarios', 'Propietarios'),
  Hospeda: t('footer.columns.hospeda', 'Hospeda'),
};
---

<footer class="bg-foreground text-card">
  <!-- Top wave -->
  <WaveDivider path="M0,30 C480,60 960,0 1440,30 L1440,0 L0,0 Z" fillClass="fill-background" position="inline" />

  <div class="mx-auto max-w-7xl px-4 pb-8 pt-4 md:px-8 md:pt-8">
    <!-- Newsletter -->
    <div class="mb-10 rounded-2xl bg-card/5 p-6 md:p-8">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div class="max-w-md">
          <h3 class="font-serif text-xl font-semibold text-card">{t('footer.newsletter.title', 'Recibi novedades de Entre Rios')}</h3>
          <p class="mt-1 text-sm text-card/60">{t('footer.newsletter.subtitle', 'Eventos, ofertas de alojamientos y notas de interes en tu correo.')}</p>
        </div>
        <form class="flex w-full max-w-sm flex-col gap-2 sm:flex-row" id="newsletter-form" aria-label={t('footer.newsletter.title', 'Recibi novedades de Entre Rios')}>
          <label for="newsletter-email" class="sr-only">{t('footer.newsletter.placeholder', 'Tu correo electronico')}</label>
          <input
            type="email"
            id="newsletter-email"
            name="email"
            placeholder={t('footer.newsletter.placeholder', 'Tu correo electronico')}
            class="h-10 flex-1 rounded-full bg-card/10 px-4 text-sm text-card placeholder:text-card/40 focus:outline-none focus:ring-2 focus:ring-accent"
            required
          />
          <button
            type="submit"
            class="h-10 shrink-0 rounded-full bg-accent px-5 text-sm font-medium text-accent-foreground transition-colors hover:bg-accent/90"
          >
            {t('footer.newsletter.submit', 'Suscribirme')}
          </button>
        </form>
        <div id="newsletter-success" class="hidden items-center gap-2 text-sm text-accent">
          <CheckCircleIcon size={16} />
          <span>{t('footer.newsletter.success', 'Gracias por suscribirte!')}</span>
        </div>
      </div>
    </div>

    <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-5">
      <!-- Brand -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-2">
          <LocationIcon size={20} className="text-accent" />
          <span class="font-serif text-2xl font-bold">Hospeda</span>
        </div>
        <p class="text-sm leading-relaxed text-card/70">{t('footer.brand', 'Tu portal de turismo para la costa del Rio Uruguay en Entre Rios, Argentina.')}</p>
        <div class="flex gap-3">
          <a href="#" class="text-card/60 transition-colors hover:text-accent" aria-label="Instagram">
            <InstagramIcon size={20} />
          </a>
          <a href="#" class="text-card/60 transition-colors hover:text-accent" aria-label="Facebook">
            <FacebookIcon size={20} />
          </a>
          <a href="#" class="text-card/60 transition-colors hover:text-accent" aria-label="Youtube">
            <YoutubeIcon size={20} />
          </a>
        </div>
      </div>

      <!-- Links -->
      {Object.entries(FOOTER_LINKS).map(([columnKey, items]) => (
        <div>
          <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-card/50">{columnTitles[columnKey] ?? columnKey}</h4>
          <ul class="flex flex-col gap-2.5">
            {items.map((item) => (
              <li>
                <a
                  href={item.path ? buildUrl({ locale: typedLocale, path: item.path }) : '#'}
                  class="text-sm text-card/70 transition-colors hover:text-accent"
                >
                  {t(item.labelKey, item.label)}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Contact + copyright -->
    <div class="mt-10 flex flex-col gap-4 border-t border-card/10 pt-8 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-wrap gap-6 text-sm text-card/60">
        <span class="flex items-center gap-1.5">
          <EmailIcon size={16} /> info@hospeda.com.ar
        </span>
        <span class="flex items-center gap-1.5">
          <PhoneIcon size={16} /> +54 345 123-4567
        </span>
      </div>
      <p class="text-xs text-card/40">{t('footer.copyright', '2026 Hospeda. Todos los derechos reservados.')}</p>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById("newsletter-form") as HTMLFormElement;
  const successMsg = document.getElementById("newsletter-success")!;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    form.classList.add("hidden");
    successMsg.classList.remove("hidden");
    successMsg.classList.add("flex");
  });
</script>
