---
/**
 * Global site footer with categorized navigation links and copyright.
 * Provides organized access to main site sections, information, and legal pages.
 */
import Container from '../components/ui/Container.astro';
import NewsletterCTAIsland from '../components/newsletter/NewsletterCTAIsland.astro';
import { InstagramIcon, FacebookIcon, WhatsappIcon } from '@repo/icons';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

// Localized labels
const t = (labels: Record<string, string>) => labels[locale] ?? labels.es;

const newsletterTitle = t({
  es: 'Suscribite a nuestro newsletter',
  en: 'Subscribe to our newsletter',
  pt: 'Assine nossa newsletter',
});

const linkGroups = [
  {
    title: t({ es: 'Explorar', en: 'Explore', pt: 'Explorar' }),
    links: [
      { label: t({ es: 'Alojamientos', en: 'Accommodations', pt: 'Hospedagens' }), href: `/${locale}/alojamientos/` },
      { label: t({ es: 'Destinos', en: 'Destinations', pt: 'Destinos' }), href: `/${locale}/destinos/` },
      { label: t({ es: 'Eventos', en: 'Events', pt: 'Eventos' }), href: `/${locale}/eventos/` },
      { label: 'Blog', href: `/${locale}/publicaciones/` },
    ],
  },
  {
    title: t({ es: 'Propietarios', en: 'Property Owners', pt: 'Proprietarios' }),
    links: [
      { label: t({ es: 'Publica tu alojamiento', en: 'List your property', pt: 'Publique seu alojamento' }), href: `/${locale}/propietarios/` },
      { label: t({ es: 'Planes para propietarios', en: 'Owner plans', pt: 'Planos para proprietarios' }), href: `/${locale}/precios/propietarios/` },
      { label: t({ es: 'Planes para turistas', en: 'Tourist plans', pt: 'Planos para turistas' }), href: `/${locale}/precios/turistas/` },
    ],
  },
  {
    title: t({ es: 'Informacion', en: 'Information', pt: 'Informacoes' }),
    links: [
      { label: t({ es: 'Quienes somos', en: 'About Us', pt: 'Quem Somos' }), href: `/${locale}/quienes-somos/` },
      { label: t({ es: 'Beneficios', en: 'Benefits', pt: 'Beneficios' }), href: `/${locale}/beneficios/` },
      { label: t({ es: 'Contacto', en: 'Contact', pt: 'Contato' }), href: `/${locale}/contacto/` },
    ],
  },
  {
    title: t({ es: 'Legal', en: 'Legal', pt: 'Legal' }),
    links: [
      { label: t({ es: 'Terminos y condiciones', en: 'Terms and Conditions', pt: 'Termos e Condicoes' }), href: `/${locale}/terminos-condiciones/` },
      { label: t({ es: 'Privacidad', en: 'Privacy', pt: 'Privacidade' }), href: `/${locale}/privacidad/` },
      { label: 'Sitemap', href: `/${locale}/sitemap/` },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer role="contentinfo" class="border-t border-border bg-surface">
  <Container size="xl">
    <div class="py-12 md:py-16">
      <!-- Newsletter Section -->
      <div class="mb-12">
        <h2 class="mb-6 text-2xl font-bold text-text">{newsletterTitle}</h2>
        <NewsletterCTAIsland
          server:defer
          locale={locale}
        >
          <div slot="fallback" class="h-12 w-full max-w-md animate-pulse rounded-lg bg-gray-200" />
        </NewsletterCTAIsland>
      </div>

      <!-- Link columns -->
      <div class="grid grid-cols-2 gap-8 md:grid-cols-3 lg:grid-cols-5">
        <!-- Brand column -->
        <div class="col-span-2 md:col-span-1">
          <a href={`/${locale}/`} class="font-serif text-xl font-bold text-primary no-underline">
            Hospeda
          </a>
          <p class="mt-3 text-sm text-text-tertiary">
            {t({ es: 'Descubre alojamientos en el Litoral argentino.', en: 'Discover accommodations in the Argentine Litoral.', pt: 'Descubra hospedagens no Litoral argentino.' })}
          </p>
        </div>

        <!-- Link groups -->
        {linkGroups.map((group) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-text">
              {group.title}
            </h3>
            <ul class="mt-4 space-y-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-text-tertiary transition-colors hover:text-primary"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Social Media Links -->
      <div class="mt-12 border-t border-border pt-8">
        <div class="flex justify-center gap-6 mb-8">
          <!-- Instagram -->
          <a
            href="https://instagram.com/hospeda"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-tertiary transition-colors hover:text-primary"
            aria-label="Instagram"
          >
            <InstagramIcon size={24} aria-hidden="true" />
          </a>

          <!-- Facebook -->
          <a
            href="https://facebook.com/hospeda"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-tertiary transition-colors hover:text-primary"
            aria-label="Facebook"
          >
            <FacebookIcon size={24} aria-hidden="true" />
          </a>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/5493442000000"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-tertiary transition-colors hover:text-primary"
            aria-label="WhatsApp"
          >
            <WhatsappIcon size={24} aria-hidden="true" />
          </a>
        </div>
      </div>

      <!-- Copyright -->
      <div class="border-t border-border pt-8">
        <p class="text-center text-sm text-text-tertiary">
          &copy; {currentYear} Hospeda. {t({ es: 'Todos los derechos reservados.', en: 'All rights reserved.', pt: 'Todos os direitos reservados.' })}
        </p>
      </div>
    </div>
  </Container>
</footer>
