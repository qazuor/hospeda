---
/**
 * @file ListingLayout.astro
 * @description Layout for entity listing pages with optional filter sidebar,
 * content grid, and pagination. Wraps BaseLayout.
 *
 * Used by: accommodations, events, posts listings, destination sub-pages.
 */

import { getSiteUrl } from '@/lib/env';
import type { SupportedLocale } from '@/lib/i18n';
import BaseLayout from './BaseLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import WaveHeader from '@/components/shared/ui/WaveHeader.astro';

interface Props {
	readonly locale: SupportedLocale;
	readonly title?: string;
	readonly description?: string;
	readonly canonicalPath?: string;
	readonly showFilters?: boolean;
	readonly filterPosition?: 'left' | 'top';
	/**
	 * When true, emits a `noindex` robots meta tag (via SEOHead, which renders
	 * `noindex,follow` — the page stays out of the index but links are still
	 * followed). Used by facet/filter sub-pages that should not be indexed.
	 * Defaults to false. Mirrors DefaultLayout.
	 */
	readonly noindex?: boolean;
}

const {
	locale,
	title,
	description,
	canonicalPath = Astro.url.pathname,
	showFilters = false,
	filterPosition = 'left',
	noindex = false,
} = Astro.props;

const siteBase = getSiteUrl();
const canonicalUrl = new URL(canonicalPath, siteBase).href;

const resolvedTitle = title ?? 'Hospeda';
const resolvedDescription = description ?? 'Descubrí alojamientos en el Litoral Entrerriano';

const hasLeftFilters = showFilters && filterPosition === 'left';
const hasTopFilters = showFilters && filterPosition === 'top';
---

<BaseLayout locale={locale} title={resolvedTitle} description={resolvedDescription}>
	<SEOHead
		slot="head"
		title={resolvedTitle}
		description={resolvedDescription}
		locale={locale}
		canonical={canonicalUrl}
		noindex={noindex}
	/>
	<slot name="head-extra" slot="head" />

	<!-- WaveHeader wraps everything so sticky bar has full-page-height parent -->
	<WaveHeader paddingTop="listing">
		<slot name="breadcrumbs" slot="breadcrumbs" />
		<div slot="content" data-listing-swap="header">
			<slot name="page-header" />
		</div>

		<!-- Main content area (default slot of WaveHeader) -->
		<div class="listing-body">
		<div class="listing-body__container">
			{/* Top filters (events use this) */}
			{hasTopFilters && (
				<div class="listing-filters-top">
					<slot name="filters" />
				</div>
			)}

			<div class:list={[
				'listing-body__grid',
				{ 'listing-body__grid--with-sidebar': hasLeftFilters },
			]}>
				{/* Left sidebar filters */}
				{hasLeftFilters && (
					<aside class="listing-sidebar" aria-label="Filtros">
						<slot name="filters" />
					</aside>
				)}

				{/* Content area — marked as a same-path swap target so filter
				 * toggles re-fetch and re-render only this region, leaving the
				 * wave header, navbar and FilterSidebar untouched. See the
				 * inline script below. */}
				<div class="listing-content" data-listing-swap="content">
					<slot />

					<div class="listing-pagination">
						<slot name="pagination" />
					</div>
				</div>
			</div>
		</div>
	</div>
	</WaveHeader>
</BaseLayout>

<style>
	.listing-body {
		padding: var(--space-section-sm) 0;
	}

	.listing-body__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	/* Top filters layout (full-width above content) */
	.listing-filters-top {
		margin-bottom: var(--space-6);
	}

	/* Grid layout: sidebar + content */
	.listing-body__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-card-gap);
	}

	.listing-body__grid--with-sidebar {
		grid-template-columns: 250px 1fr;
	}

	/* Sidebar offset = real navbar height (--navbar-height, published by Header.astro)
	   + the compact wave header band (~105px: content padding + title + wave overhang). */
	.listing-sidebar {
		position: sticky;
		top: calc(var(--navbar-height, 80px) + 105px);
		align-self: start;
	}

	/* Content area */
	.listing-content {
		min-width: 0; /* Prevent grid blowout */
		/* Keep the grid row at least viewport-tall so the sticky sidebar
		 * always has enough containing-block height to remain at its
		 * sticky top position. Without this, a restrictive filter (e.g.
		 * empty result set) collapses the row below the sidebar's height,
		 * which forces the sticky algorithm to push the sidebar up — the
		 * "sidebar moved" papercut the partial-swap script was supposed
		 * to avoid. */
		min-height: calc(100vh - var(--navbar-height, 80px));
		/* Used by the partial-swap script's `scrollIntoView` to land the
		 * user just below the sticky navbar instead of under it. */
		scroll-margin-top: calc(var(--navbar-height, 80px) + 24px);
	}

	/* Pagination */
	.listing-pagination {
		margin-top: var(--space-8);
	}

	/* Mobile: collapse sidebar to zero, single column content. */
	@media (max-width: 768px) {
		.listing-body__grid--with-sidebar {
			grid-template-columns: 1fr;
		}

		/*
		 * Do NOT use `display: none` here. FilterSidebar renders its mobile UI
		 * (floating trigger button + drawer dialog, both `position: fixed`) as
		 * descendants of this <aside>. `display: none` would propagate to those
		 * fixed descendants and silently kill the mobile filter UX. Collapsing
		 * to zero size keeps the fixed-positioned children visible because they
		 * escape the parent's layout box.
		 */
		.listing-sidebar {
			position: static;
			width: 0;
			height: 0;
			margin: 0;
			padding: 0;
			overflow: visible;
		}
	}
</style>

<script is:inline>
	/**
	 * Same-path partial swap for listing pages.
	 *
	 * When a filter toggle navigates from `/alojamientos?type=hotel` to
	 * `/alojamientos?type=apartment` (same pathname, different query),
	 * ClientRouter's default behaviour is to swap the entire document.
	 * That works, but it re-renders the wave header, re-hydrates every
	 * island in the sidebar, runs the View Transition snapshot over the
	 * whole viewport, and resets sidebar scroll positions. Visually it
	 * looks like the page reloads even though only the grid changed.
	 *
	 * This handler intercepts `astro:before-preparation`, detects the
	 * "same pathname, different query" case, cancels ClientRouter's
	 * default flow, fetches the target URL with a plain `fetch()`, and
	 * splices ONLY the regions tagged `data-listing-swap` from the
	 * response into the live document. Everything else — wave header,
	 * navbar, FilterSidebar's React tree, scroll positions — stays as
	 * the user left it. Astro islands inside the spliced regions
	 * re-hydrate automatically via their `<astro-island>` custom-element
	 * `connectedCallback` once the new markup lands in the DOM.
	 *
	 * Cross-path navigations (menu links, list → detail, between listing
	 * pages, pagination URLs that change the path segment) keep the
	 * default ClientRouter flow untouched.
	 *
	 * DOM splicing uses `adoptNode` + `replaceChildren` instead of
	 * `innerHTML` so the swap doesn't trip the codebase's XSS guard
	 * (same-origin SSR response, so the content is trusted, but using
	 * proper DOM APIs is the cheaper habit either way).
	 */
	(function () {
		var currentAbort = null;
		var root = document.documentElement;

		function spliceSwapRegions(newDoc) {
			var currentTargets = document.querySelectorAll('[data-listing-swap]');
			currentTargets.forEach(function (currentEl) {
				var key = currentEl.getAttribute('data-listing-swap');
				var newEl = newDoc.querySelector('[data-listing-swap="' + key + '"]');
				if (!newEl) return;
				var adoptedChildren = [];
				while (newEl.firstChild) {
					adoptedChildren.push(document.adoptNode(newEl.firstChild));
				}
				currentEl.replaceChildren.apply(currentEl, adoptedChildren);
			});
		}

		async function performPartialSwap(targetUrl, needsPushState, signal) {
			var response = await fetch(targetUrl, {
				headers: { Accept: 'text/html' },
				credentials: 'same-origin',
				signal: signal
			});
			if (!response.ok) throw new Error('http ' + response.status);
			var html = await response.text();
			var newDoc = new DOMParser().parseFromString(html, 'text/html');

			// Kick off the "return to the top of the results" scroll BEFORE
			// the splice runs, not after.
			//
			// Why pre-splice: when a restrictive filter shrinks the grid,
			// the sidebar's sticky containing block (the grid row) shrinks
			// too. If the user was scrolled past the new container's bottom,
			// the post-splice sticky rules push the sidebar out of view —
			// which is the "the sidebar jumped" effect the previous
			// iteration was trying to avoid. By starting the smooth scroll
			// while the OLD (longer) grid is still in place, the user
			// travels entirely within the old sticky range; the sidebar
			// stays glued to its sticky top throughout. The splice happens
			// in parallel, so by the time the scroll lands the user at the
			// top of the new content, the new (shorter) layout is already
			// applied — and the user is also inside the NEW sticky range,
			// so the sidebar still doesn't move.
			//
			// The result is one continuous motion: cards scroll up under a
			// stationary sidebar, then morph into the filtered set, with
			// no perceived shift on any other element.
			var contentRegion = document.querySelector('[data-listing-swap="content"]');
			if (contentRegion) {
				var rect = contentRegion.getBoundingClientRect();
				if (rect.top < 0) {
					contentRegion.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			}

			spliceSwapRegions(newDoc);

			if (newDoc.title) document.title = newDoc.title;
			if (needsPushState) window.history.pushState({}, '', targetUrl);

			// Tell anything that initialises on a navigation (FilterSidebar
			// clears its "loading" flag here, for instance) that we are done.
			document.dispatchEvent(new Event('astro:after-swap'));
			document.dispatchEvent(new Event('astro:page-load'));

			// FilterSidebar's debounce hook sets this dataset flag right
			// before it calls navigate(). With ClientRouter bypassed the
			// flag would otherwise linger; clear it ourselves.
			delete root.dataset.filtersLoading;
		}

		function handleListingNav(targetUrl, needsPushState) {
			if (currentAbort) currentAbort.abort();
			currentAbort = new AbortController();
			var signal = currentAbort.signal;

			performPartialSwap(targetUrl, needsPushState, signal).catch(function (err) {
				if (err && err.name === 'AbortError') return;
				// Anything else is unrecoverable from our side — fall back to
				// a full navigation so the user still ends up on the right URL.
				window.location.href = targetUrl;
			});
		}

		// FilterSidebar's debounced nav dispatches this custom event before
		// falling back to `astro:transitions/client navigate()`. We claim
		// ownership of the navigation by calling `preventDefault()` and run
		// our partial swap instead of letting ClientRouter swap the whole
		// document. (Astro 5's `astro:before-preparation` event does not
		// actually honour `preventDefault()` from user handlers, so the
		// custom-event handshake is the only reliable way to intercept.)
		window.addEventListener('hospeda:listing-nav', function (event) {
			var detail = event && event.detail;
			if (!detail || typeof detail.url !== 'string') return;
			var nextUrl;
			try {
				nextUrl = new URL(detail.url, window.location.origin);
			} catch (_err) {
				return;
			}
			if (nextUrl.pathname !== window.location.pathname) return;
			if (nextUrl.origin !== window.location.origin) return;

			event.preventDefault();
			handleListingNav(nextUrl.href, window.location.href !== nextUrl.href);
		});

		// Browser back/forward (popstate) intentionally falls through to
		// `<ClientRouter />`'s default handling. ClientRouter listens on
		// window first and competing with it for the popstate event is
		// brittle; the marginal cost is that back/forward across filter
		// states briefly re-renders the wave header, same as before. If
		// that becomes a papercut we can revisit with a capture-phase
		// stopImmediatePropagation trick.
	})();
</script>
