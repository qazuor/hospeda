---
/**
 * @file AuthLayout.astro
 * @description Focused layout for authentication pages (signin, signup, forgot-password, etc.).
 * Standalone HTML shell with minimal header (logo only), centered card content,
 * and a minimal copyright footer.
 */

import type { SupportedLocale } from '@/lib/i18n';
import { createTranslations } from '@/lib/i18n';
import { BRAND_THEME_COLOR, BRAND_THEME_COLOR_DARK } from '@/lib/constants';
import Logo from '@/components/shared/navigation/Logo.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import FontsLoader from '@/components/shared/FontsLoader.astro';
import ThemeFoucScript from '@/components/shared/ThemeFoucScript.astro';
import { ToastViewport } from '@/components/ui/ToastViewport.client';
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

interface Props {
	readonly locale: SupportedLocale;
	readonly title?: string;
	readonly description?: string;
	/**
	 * When true the slot is rendered directly inside .auth-content,
	 * skipping the centered .auth-card wrapper. Use for pages that bring
	 * their own full layout (status pages, etc.) and want to manage their
	 * own card-or-not styling.
	 */
	readonly bareSlot?: boolean;
}

const {
	locale,
	title = 'Hospeda',
	description = 'Ingresá a tu cuenta',
	bareSlot = false,
} = Astro.props;

const { t } = createTranslations(locale);

const cspNonce = Astro.locals.cspNonce ?? '';
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;

const isAuthenticatedHint = Astro.locals.user ? 'true' : 'false';
---

<!doctype html>
<html lang={locale} data-user-authenticated={isAuthenticatedHint}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<!-- SPEC-157 REQ-18: browser UI chrome matches the brand blue, with a
		     dark-mode variant gated by prefers-color-scheme. -->
		<meta name="theme-color" content={BRAND_THEME_COLOR} />
		<meta
			name="theme-color"
			content={BRAND_THEME_COLOR_DARK}
			media="(prefers-color-scheme: dark)"
		/>

		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Google Fonts (non-blocking) -->
		<FontsLoader cspNonce={cspNonce} />

		<ThemeFoucScript cspNonce={cspNonce} />

		<ClientRouter />

		<SEOHead
			title={title}
			description={description}
			locale={locale}
			canonical={canonical}
			noindex={true}
		/>
	</head>
	<body class="auth-body">
		<!-- Minimal header: logo only, centered -->
		<header class="auth-header">
			<div class="auth-header__container">
				<Logo locale={locale} size="md" />
			</div>
		</header>

		<!-- Centered auth card -->
		<main id="main-content" class="auth-content" data-bare-slot={bareSlot ? 'true' : 'false'}>
			<slot name="decoratives" />
			{bareSlot ? (
				<slot />
			) : (
				<div class="auth-card">
					<slot />
				</div>
			)}
		</main>

		<!-- Minimal copyright footer -->
		<footer class="auth-footer">
			<div class="auth-footer__container">
				<p class="auth-footer__copyright">
					&copy; {new Date().getFullYear()} Hospeda. {t('footer.allRightsReserved', 'Todos los derechos reservados')}.
				</p>
			</div>
		</footer>

		<ToastViewport client:idle locale={locale} />
	</body>
</html>

<style>
	.auth-body {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		background-color: var(--background);
	}

	.auth-header {
		padding: var(--space-4) 0;
		background-color: var(--background);
	}

	.auth-header__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-6);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.auth-content {
		position: relative;
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding-inline: var(--space-6);
		overflow: hidden;
	}

	/* Status-style pages (verify-email-sent, etc.) own their own vertical
	   padding via the StatusPage component. Aligning the slot to the top
	   keeps content position consistent across pages with different
	   content heights. */
	.auth-content[data-bare-slot='true'] {
		align-items: flex-start;
		justify-content: center;
		padding-inline: 0;
	}

	.auth-card {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 480px;
		background-color: var(--core-card);
		border-radius: var(--radius-card);
		box-shadow: var(--shadow-card);
		padding: var(--space-8);
	}

	@media (max-width: 640px) {
		.auth-card {
			box-shadow: none;
			background-color: transparent;
			padding: var(--space-4);
		}
	}

	/* Minimal copyright footer — same shape as ErrorLayout for visual parity. */
	.auth-footer {
		padding: 1.5rem 0;
		margin-top: auto;
	}

	.auth-footer__container {
		max-width: var(--container-max, 1350px);
		margin: 0 auto;
		padding: 0 1.5rem;
		text-align: center;
	}

	.auth-footer__copyright {
		font-family: var(--font-sans);
		font-size: 0.875rem;
		color: var(--core-muted-foreground);
		margin: 0;
	}
</style>
