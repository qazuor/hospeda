---
/**
 * @file DetailLayout.astro
 * @description Two-column layout for entity detail pages with optional
 * breadcrumbs and contextual sidebar. Wraps BaseLayout.
 *
 * Used by: accommodation detail, destination detail, event detail, post detail, attraction detail.
 */

import type { SupportedLocale } from '@/lib/i18n';
import BaseLayout from './BaseLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';

interface Props {
	readonly locale: SupportedLocale;
	readonly title?: string;
	readonly description?: string;
	readonly canonicalPath?: string;
	readonly showBreadcrumbs?: boolean;
	readonly showSidebar?: boolean;
}

const {
	locale,
	title,
	description,
	canonicalPath = Astro.url.pathname,
	showBreadcrumbs = true,
	showSidebar = true,
} = Astro.props;

const siteBase = import.meta.env.SITE ?? Astro.url.origin;
const canonicalUrl = new URL(canonicalPath, siteBase).href;

const resolvedTitle = title ?? 'Hospeda';
const resolvedDescription = description ?? 'Descubrí alojamientos en el Litoral Entrerriano';
---

<BaseLayout locale={locale} title={resolvedTitle} description={resolvedDescription}>
	<SEOHead
		slot="head"
		title={resolvedTitle}
		description={resolvedDescription}
		locale={locale}
		canonical={canonicalUrl}
	/>
	<slot name="head-extra" slot="head" />

	<!-- Header area on warm background: breadcrumbs + title/meta -->
	<div class="detail-header">
		<div class="detail-header__container">
			{showBreadcrumbs && (
				<div class="detail-header__breadcrumbs">
					<slot name="breadcrumbs" />
				</div>
			)}
			<div class="detail-header__content">
				<slot name="page-header" />
			</div>
		</div>
	</div>

	<!-- Decorative wave separator -->
	<div class="detail-wave" aria-hidden="true">
		<svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
			<path d="M0,64 C288,120 576,0 864,64 C1152,128 1440,32 1440,32 L1440,0 L0,0 Z" fill="var(--surface-warm, #fdf6f0)" />
		</svg>
	</div>

	<div class="detail-page">
		<div class="detail-page__container">
			<div class:list={[
				'detail-page__body',
				{ 'detail-page__body--full': !showSidebar },
			]}>
				<article class="detail-page__main">
					<slot />
				</article>

				{showSidebar && (
					<aside class="detail-page__sidebar">
						<slot name="sidebar" />
					</aside>
				)}
			</div>
		</div>
	</div>
</BaseLayout>

<style>
	.detail-header {
		background-color: var(--surface-warm);
		padding: 2rem 0 1.5rem;
	}

	.detail-header__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.detail-header__breadcrumbs {
		margin-bottom: 1rem;
	}

	.detail-header__content {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.detail-wave {
		margin-top: -1px;
		line-height: 0;
	}

	.detail-wave svg {
		width: 100%;
		height: 80px;
		display: block;
	}

	.detail-page {
		padding: 1.5rem 0 var(--space-section-sm);
	}

	.detail-page__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.detail-page__body {
		display: grid;
		grid-template-columns: 1fr 360px;
		gap: var(--space-card-gap);
		align-items: start;
	}

	.detail-page__body--full {
		grid-template-columns: 1fr;
	}

	.detail-page__main {
		min-width: 0; /* Prevent grid blowout */
	}

	.detail-page__sidebar {
		position: sticky;
		top: 130px;
		align-self: start;
	}

	@media (max-width: 1024px) {
		.detail-page__body {
			grid-template-columns: 1fr;
		}

		.detail-page__sidebar {
			position: static;
			order: 2;
		}

		.detail-page__main {
			order: 1;
		}
	}
</style>
