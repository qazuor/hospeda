---
/**
 * @file DetailLayout.astro
 * @description Two-column layout for entity detail pages with optional
 * breadcrumbs and contextual sidebar. Wraps BaseLayout.
 *
 * Used by: accommodation detail, destination detail, event detail, post detail, attraction detail.
 */

import { getSiteUrl } from '@/lib/env';
import type { SupportedLocale } from '@/lib/i18n';
import BaseLayout from './BaseLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import WaveHeader from '@/components/shared/ui/WaveHeader.astro';

interface Props {
	readonly locale: SupportedLocale;
	readonly title?: string;
	readonly description?: string;
	readonly canonicalPath?: string;
	readonly showBreadcrumbs?: boolean;
	readonly showSidebar?: boolean;
	/**
	 * Entity featured image URL. Forwarded to SEOHead as `ogImage`, which makes
	 * the generated `/api/og` card render in PHOTO mode (full-bleed image +
	 * type badge + rating). Omit it (or pass a placeholder) for a brand card.
	 */
	readonly ogImage?: string;
	/** OG photo-card type badge (Alojamiento/Destino/Evento/Guía). */
	readonly ogType?: string;
	/** OG photo-card subtitle line (locality/region). */
	readonly ogSubtitle?: string;
	/** OG photo-card rating value (e.g. "4.8"). */
	readonly ogRating?: string;
	/**
	 * Open Graph object type. Article detail pages (blog posts) pass 'article';
	 * everything else falls back to the SEOHead default ('website').
	 */
	readonly ogMetaType?: 'website' | 'article';
	/** ISO published date — forwarded as article:published_time for articles. */
	readonly articlePublishedTime?: string;
	/** ISO modified date — forwarded as article:modified_time for articles. */
	readonly articleModifiedTime?: string;
}

const {
	locale,
	title,
	description,
	canonicalPath = Astro.url.pathname,
	showBreadcrumbs = true,
	showSidebar = true,
	ogImage,
	ogType,
	ogSubtitle,
	ogRating,
	ogMetaType,
	articlePublishedTime,
	articleModifiedTime,
} = Astro.props;

const siteBase = getSiteUrl();
const canonicalUrl = new URL(canonicalPath, siteBase).href;

const resolvedTitle = title ?? 'Hospeda';
const resolvedDescription = description ?? 'Descubrí alojamientos en el Litoral Entrerriano';
---

<BaseLayout locale={locale} title={resolvedTitle} description={resolvedDescription}>
	<SEOHead
		slot="head"
		title={resolvedTitle}
		description={resolvedDescription}
		locale={locale}
		canonical={canonicalUrl}
		ogImage={ogImage}
		ogType={ogType}
		ogSubtitle={ogSubtitle}
		ogRating={ogRating}
		type={ogMetaType}
		articlePublishedTime={articlePublishedTime}
		articleModifiedTime={articleModifiedTime}
	/>
	<slot name="head-extra" slot="head" />

	<!-- WaveHeader wraps everything so sticky bar has full-page-height parent -->
	<WaveHeader paddingTop="detail">
		{showBreadcrumbs && (
			<slot name="breadcrumbs" slot="breadcrumbs" />
		)}
		<slot name="page-header" slot="content" />

		<!-- Page body (default slot of WaveHeader) -->
		<div class="detail-page">
			<div class="detail-page__container">
				<div class:list={[
					'detail-page__body',
					{ 'detail-page__body--full': !showSidebar },
				]}>
					<article class="detail-page__main">
						<slot />
					</article>

					{showSidebar && (
						<aside class="detail-page__sidebar">
							<slot name="sidebar" />
						</aside>
					)}
				</div>
			</div>
		</div>
	</WaveHeader>
</BaseLayout>

<style>
	.detail-page {
		padding: 1.5rem 0 var(--space-section-sm);
	}

	.detail-page__container {
		max-width: var(--container-max);
		margin: 0 auto;
		padding: 0 var(--space-container-x);
	}

	.detail-page__body {
		display: grid;
		grid-template-columns: 1fr 360px;
		gap: var(--space-card-gap);
		align-items: start;
	}

	.detail-page__body--full {
		grid-template-columns: 1fr;
	}

	.detail-page__main {
		min-width: 0; /* Prevent grid blowout */
	}

	/* Sidebar offset = real navbar height (--navbar-height, published by Header.astro)
	   + the compact wave header band (~105px: content padding + title + wave overhang).
	   max-height + overflow-y: auto make the sidebar independently scrollable when
	   its content is taller than the visible viewport area below the sticky top
	   offset. Without this, the bottom portion of a tall sidebar was unreachable
	   because position:sticky + align-self:start sizes the sticky container to
	   exactly the sidebar's intrinsic height, leaving no scroll anchor. */
	.detail-page__sidebar {
		position: sticky;
		top: calc(var(--navbar-height, 80px) + 105px);
		align-self: start;
		max-height: calc(100vh - var(--navbar-height, 80px) - 105px);
		overflow-y: auto;
	}

	@media (max-width: 1024px) {
		.detail-page__body {
			grid-template-columns: 1fr;
		}

		.detail-page__sidebar {
			position: static;
			order: 2;
			/* Stacked full-width on mobile: drop the desktop sticky-scroll cap so
			   the sidebar grows to its natural height instead of scrolling internally. */
			max-height: none;
			overflow-y: visible;
		}

		.detail-page__main {
			order: 1;
		}
	}
</style>
