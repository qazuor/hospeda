{
    "name": "hospeda-web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "ASTRO_DEV_BACKGROUND=0 astro dev --port 4321",
        "build": "astro build",
        "build:analyze": "ANALYZE=1 astro build",
        "preview": "astro preview",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage --passWithNoTests",
        "verify:csp": "node scripts/verify-csp-over-the-wire.mjs",
        "test:visual:install": "playwright install chromium --with-deps",
        "test:visual:baseline": "playwright test --config=playwright-visual.config.ts --update-snapshots",
        "test:visual": "playwright test --config=playwright-visual.config.ts",
        "lint": "biome check . && pnpm check-tokens && pnpm check:relative-colors",
        "format": "biome format --write .",
        "typecheck": "astro sync && astro check && tsc --noEmit --project ./tsconfig.json",
        "check-tokens": "node scripts/check-css-tokens.cjs",
        "check:relative-colors": "node scripts/check-css-relative-colors.cjs",
        "lighthouse": "lhci autorun --config=./lighthouserc.json",
        "a11y:sweep": "tsx scripts/a11y-sweep/sweep.ts",
        "a11y:diagnose": "A11Y_DETAIL=1 tsx scripts/a11y-sweep/sweep.ts",
        "clean": "rm -rf node_modules dist .astro"
    },
    "dependencies": {
        "@astrojs/node": "^11.0.2",
        "@astrojs/react": "^6.0.1",
        "@astrojs/rss": "^4.0.18",
        "@astrojs/sitemap": "^3.7.3",
        "@repo/billing": "workspace:*",
        "@repo/config": "workspace:*",
        "@repo/design-tokens": "workspace:*",
        "@repo/feedback": "workspace:*",
        "@repo/i18n": "workspace:*",
        "@repo/icons": "workspace:*",
        "@repo/logger": "workspace:*",
        "@repo/media": "workspace:*",
        "@repo/schemas": "workspace:*",
        "@repo/utils": "workspace:*",
        "@sentry/astro": "^10.62.0",
        "@tiptap/react": "^3",
        "@tiptap/starter-kit": "^3",
        "@vercel/og": "^0.11.1",
        "astro": "^7.0.3",
        "better-auth": "^1.6.23",
        "clsx": "^2.1.1",
        "dompurify": "^3.4.11",
        "driver.js": "1.6.0",
        "embla-carousel-autoplay": "^8.6.0",
        "embla-carousel-react": "^8.6.0",
        "glightbox": "^3.3.0",
        "leaflet": "^1.9.4",
        "marked": "^18.0.5",
        "parse5": "^8.0.1",
        "react": "19.2.4",
        "react-day-picker": "10.0.1",
        "react-dom": "19.2.4",
        "react-leaflet": "^5.0.0",
        "react-leaflet-cluster": "^4.1.3",
        "recharts": "^2.15.4",
        "sanitize-html": "^2.17.5",
        "sharp": "^0.35.2",
        "tiptap-markdown": "^0.9.0"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.4",
        "@axe-core/playwright": "^4.10.2",
        "@lhci/cli": "0.15.1",
        "@playwright/test": "^1.61.1",
        "@repo/typescript-config": "workspace:*",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/dompurify": "^3.2.0",
        "@types/leaflet": "^1.9.12",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/sanitize-html": "^2.16.1",
        "@vitejs/plugin-react": "^4",
        "@vitest/coverage-v8": "^3.2.4",
        "identity-obj-proxy": "^3.0.0",
        "jsdom": "^26.0.0",
        "rollup-plugin-visualizer": "^7.0.1",
        "typescript": "6.0.3",
        "vitest": "^3.1.3"
    }
}
