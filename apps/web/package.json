{
    "name": "hospeda-web",
    "type": "module",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "build:preview": "astro build --config astro.config.preview.mjs",
        "preview": "pnpm build:preview && astro preview --config astro.config.preview.mjs",
        "astro": "astro",
        "analyze": "astro build --verbose",
        "gen:translations-keys": "pnpm tsx scripts/generate-translation-keys.ts",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "lint": "biome check .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit --project ./tsconfig.json",
        "clean": "rm -rf node_modules dist"
    },
    "dependencies": {
        "@astrojs/node": "^9.4.2",
        "@astrojs/react": "^4.4.2",
        "@astrojs/sitemap": "^3.4.2",
        "@astrojs/tailwind": "^5.1.0",
        "@astrojs/vercel": "^8.1.4",
        "@clerk/astro": "^2.11.2",
        "@clerk/clerk-react": "^5.42.0",
        "@nanostores/react": "^1.0.0",
        "@qazuor/qzpay-core": "^1.1.0",
        "@qazuor/qzpay-react": "^1.1.0",
        "@repo/auth-ui": "workspace:*",
        "@repo/billing": "workspace:*",
        "@repo/config": "workspace:*",
        "@repo/db": "workspace:*",
        "@repo/i18n": "workspace:*",
        "@repo/icons": "workspace:*",
        "@repo/logger": "workspace:*",
        "@repo/schemas": "workspace:*",
        "@repo/service-core": "workspace:*",
        "@repo/utils": "workspace:*",
        "@reunmedia/astro-normalize-trailing-slash": "^0.1.1",
        "@tailwindcss/forms": "^0.5.10",
        "@tailwindcss/typography": "^0.5.16",
        "astro": "^5.12.9",
        "astro-devtool-breakpoints": "^0.3.0",
        "astro-lighthouse": "^0.1.3",
        "astro-og": "^0.3.0",
        "astro-typed-links": "^1.1.4",
        "better-auth": "^1.4.18",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.1",
        "nanostores": "^0.9.5",
        "pg": "^8.15.6",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "zod": "^4.0.8"
    },
    "devDependencies": {
        "@repo/tailwind-config": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@sentry/astro": "^10.38.0",
        "@tailwindcss/vite": "^4.1.12",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.2.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/pg": "^8.15.1",
        "@types/react": "^19.1.10",
        "@types/react-dom": "^19.1.7",
        "@vitest/coverage-v8": "^3.2.4",
        "astro-font-picker": "^0.2.2",
        "jsdom": "^26.0.0",
        "lightningcss": "^1.28.1",
        "tailwindcss": "^4.1.12",
        "vitest": "^3.1.3"
    }
}
