{
    "name": "hospeda-web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "astro dev --port 4321",
        "build": "astro build",
        "preview": "astro preview",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:visual:install": "playwright install chromium --with-deps",
        "test:visual:baseline": "playwright test --config=playwright-visual.config.ts --update-snapshots",
        "test:visual": "playwright test --config=playwright-visual.config.ts",
        "lint": "biome check . && pnpm check-tokens",
        "format": "biome format --write .",
        "typecheck": "astro sync && tsc --noEmit --project ./tsconfig.json",
        "check-tokens": "node scripts/check-css-tokens.cjs",
        "lighthouse": "lhci autorun --config=./lighthouserc.json",
        "clean": "rm -rf node_modules dist .astro"
    },
    "dependencies": {
        "@astrojs/node": "^10.1.1",
        "@astrojs/react": "^5.0.5",
        "@astrojs/rss": "^4.0.18",
        "@astrojs/sitemap": "^3.7.2",
        "@repo/billing": "workspace:*",
        "@repo/config": "workspace:*",
        "@repo/design-tokens": "workspace:*",
        "@repo/feedback": "workspace:*",
        "@repo/i18n": "workspace:*",
        "@repo/icons": "workspace:*",
        "@repo/logger": "workspace:*",
        "@repo/media": "workspace:*",
        "@repo/schemas": "workspace:*",
        "@repo/utils": "workspace:*",
        "@sentry/astro": "^10.53.1",
        "@vercel/og": "^0.11.1",
        "astro": "^6.3.3",
        "better-auth": "^1.4.18",
        "clsx": "^2.1.1",
        "embla-carousel-autoplay": "^8.6.0",
        "embla-carousel-react": "^8.6.0",
        "glightbox": "^3.3.0",
        "leaflet": "^1.9.4",
        "marked": "^18.0.4",
        "parse5": "^7.3.0",
        "react": "19.2.4",
        "react-day-picker": "9.13.2",
        "react-dom": "19.2.4",
        "react-leaflet": "^4.2.1",
        "react-leaflet-cluster": "^2.1.0",
        "sanitize-html": "^2.17.0",
        "sharp": "^0.34.5"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@repo/typescript-config": "workspace:*",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/leaflet": "^1.9.12",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/sanitize-html": "^2.16.0",
        "@vitejs/plugin-react": "^4",
        "@vitest/coverage-v8": "^3.2.4",
        "identity-obj-proxy": "^3.0.0",
        "jsdom": "^26.0.0",
        "typescript": "5.9.3",
        "vitest": "^3.1.3"
    }
}
