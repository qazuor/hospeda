# Hospeda Web - Environment Variables
# Copy to .env.local and fill in values

# --- Server-side (not exposed to browser) -------------------------------------------

# API server URL (Hono backend)
HOSPEDA_API_URL=http://localhost:3001

# Public site URL (this Astro app)
HOSPEDA_SITE_URL=http://localhost:4321

# Better Auth configuration
HOSPEDA_BETTER_AUTH_SECRET=change-me-to-a-random-secret
HOSPEDA_BETTER_AUTH_URL=http://localhost:3001/api/auth

# --- Client-side (PUBLIC_ prefix - exposed to browser) ------------------------------

# API URL accessible from the browser
PUBLIC_API_URL=http://localhost:3001

# Site URL accessible from the browser
PUBLIC_SITE_URL=http://localhost:4321

# Sentry DSN (optional - leave empty to disable error tracking)
PUBLIC_SENTRY_DSN=
