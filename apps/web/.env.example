# ================================================
# Hospeda Web App - Environment Variables
# ================================================
# Copy this file to .env.local and fill in the values.

# Runtime
#
# IMPORTANT: NODE_ENV is platform-managed by Vercel. Do NOT set it in the
# Vercel project Settings (the platform rejects it). The line below is for
# reference only — uncomment in `.env.local` only if you need to override
# the local default while running outside the Vercel CLI.
# NODE_ENV=development

# Core URLs (required - set one of each pair)
# Monorepo dev (HOSPEDA_*) or production deployment (PUBLIC_*)
HOSPEDA_API_URL=http://localhost:3001
HOSPEDA_SITE_URL=http://localhost:4321
# PUBLIC_API_URL=https://api.hospeda.com.ar
# PUBLIC_SITE_URL=https://hospeda.com.ar

# Authentication (optional - only if auth features are needed)
# HOSPEDA_BETTER_AUTH_URL=http://localhost:3001/api/auth

# ISR Revalidation (optional - Vercel only, 32+ chars, must match API)
# HOSPEDA_REVALIDATION_SECRET=

# Monitoring (optional)
# PUBLIC_SENTRY_DSN=
# PUBLIC_SENTRY_RELEASE=
# PUBLIC_SENTRY_ENVIRONMENT=staging   # or "production" — REQUIRED to separate
                                       # staging/prod in Sentry; without it, both
                                       # Astro builds emit MODE=production and
                                       # events collide in the same bucket.
# SENTRY_AUTH_TOKEN=
# Note: org and project slugs are hardcoded (`qazuor`/`hospeda-web`)
# in astro.config.mjs — no SENTRY_ORG/SENTRY_PROJECT needed.
#
# TUNNEL (SPEC-181 follow-up): in prod/staging set the first-party tunnel path so
# ad-blockers (uBlock `||sentry.io^$3p`) cannot intercept error reporting. The
# Cloudflare Worker in infra/cloudflare/sentry-tunnel/ must be deployed first;
# setting this auto-drops https://*.sentry.io from the CSP (same deploy). PostHog
# uses a DIFFERENT path (/api/relay) and a DIFFERENT Worker — do not mix them.
# Leave unset to report directly to Sentry (default).
# PUBLIC_SENTRY_TUNNEL=/api/event

# Analytics — PostHog Cloud (optional, SPEC-140 + SPEC-181 first-party proxy)
# Public by design — both vars ship in the browser bundle. Per-env values
# (staging vs prod) come from Coolify, one project key each. Leave unset
# locally to keep dev quiet (no events, no cookies, no network). The KEY
# starts with `phc_`. Keys live in 1Password under "Hospeda / PostHog project keys".
#
# HOST: in prod/staging set the first-party reverse proxy (SPEC-181) so ad-blockers
# cannot intercept analytics. The Cloudflare Worker in infra/cloudflare/posthog-proxy/
# must be deployed first, and the CSP in middleware-helpers.ts must drop the external
# PostHog hosts in the SAME deploy (see the Worker README). Falls back to
# https://us.i.posthog.com when unset.
# PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PUBLIC_POSTHOG_HOST=https://hospeda.com.ar/api/relay

# Feature Flags (optional)
# PUBLIC_ENABLE_LOGGING=false
# PUBLIC_VERSION=0.1.0

# Feedback FAB (optional)
# Set to 'true' in preview/production to show the feedback floating action button.
# Defaults to 'false' (FAB hidden) so local dev stays quiet.
# PUBLIC_FEEDBACK_ENABLED=true

# Newsletter WhatsApp channel CTA (optional, SPEC-101)
# Mirror of HOSPEDA_NEWSLETTER_WA_CHANNEL_URL (server-side, used by the
# welcome email). When set, the WhatsAppCTA web component renders a join
# CTA; when unset, the block is hidden.
# PUBLIC_HOSPEDA_WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/0029Va6S3oPxxxxxxxxxxxx
