# =============================================================================
# apps/web — Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in the required values.
#
#   cp .env.example .env.local
#
# Variable prefixes:
#   PUBLIC_*   — exposed to the browser by Astro (safe for client bundles)
#   HOSPEDA_*  — server-side only; never included in client bundles
#
# Required vars are uncommented with placeholder values.
# Optional vars are commented out; uncomment and adjust as needed.
# Secret vars show a placeholder like "https://xxxx@sentry.io/xxxx".
# =============================================================================

# =============================================================================
# Runtime
# =============================================================================

# Node.js execution environment — controls Astro optimisations and SSR mode.
# Allowed: development | test | production
NODE_ENV=development

# =============================================================================
# Public — Browser-Exposed Variables (PUBLIC_*)
# =============================================================================

# API base URL accessible from the browser.
# Used for client-side fetch calls to the Hono API server.
PUBLIC_API_URL=http://localhost:3001

# Web app base URL accessible from the browser.
# Used for canonical links, Open Graph tags, and share URLs.
PUBLIC_SITE_URL=http://localhost:4321

# Sentry DSN for client-side error tracking in the web app.
# Obtain from https://sentry.io — leave unset to disable Sentry on the client.
# PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# Sentry release identifier for the web app (e.g. Git SHA or package version).
# PUBLIC_SENTRY_RELEASE=1.0.0

# Application version string exposed to the browser for feedback auto-collection.
# PUBLIC_VERSION=1.0.0

# =============================================================================
# Server-Side Variables (HOSPEDA_*)
# =============================================================================

# API base URL used by Astro SSR for server-side fetch calls.
# Should match PUBLIC_API_URL in most environments.
HOSPEDA_API_URL=http://localhost:3001

# Web app base URL used by Astro SSR for self-referencing links.
# Should match PUBLIC_SITE_URL in most environments.
HOSPEDA_SITE_URL=http://localhost:4321

# Better Auth endpoint URL used by Astro SSR for server-side auth checks.
HOSPEDA_BETTER_AUTH_URL=http://localhost:3001/api/auth
