# ===========================================
# Hospeda Web - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# In deployment (Vercel), set these in the project settings dashboard.
# Variables marked [REQUIRED] must be set before starting.

# --- API Connection [REQUIRED] ---
# Must be set for both server-side data fetching and client-side requests.
PUBLIC_API_URL=http://localhost:3001

# --- Site URL [REQUIRED] ---
# Used for canonical URLs, Open Graph meta tags, and sitemap generation.
PUBLIC_SITE_URL=http://localhost:4321

# --- Environment ---
NODE_ENV=development

# --- Sentry Error Tracking (optional) ---
# PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# --- Monorepo Alternatives ---
# When running from the monorepo root with `pnpm dev`, these variables are
# read from the root .env.local and automatically mapped to the PUBLIC_* names
# above. You only need PUBLIC_* variables when deploying to Vercel directly.
# HOSPEDA_API_URL=http://localhost:3001
# HOSPEDA_SITE_URL=http://localhost:4321
