# ================================================
# Hospeda Web App - Environment Variables
# ================================================
# Copy this file to .env.local and fill in the values.

# Runtime
#
# IMPORTANT: NODE_ENV is platform-managed by Vercel. Do NOT set it in the
# Vercel project Settings (the platform rejects it). The line below is for
# reference only — uncomment in `.env.local` only if you need to override
# the local default while running outside the Vercel CLI.
# NODE_ENV=development

# Core URLs (required - set one of each pair)
# Monorepo dev (HOSPEDA_*) or production deployment (PUBLIC_*)
HOSPEDA_API_URL=http://localhost:3001
HOSPEDA_SITE_URL=http://localhost:4321
# PUBLIC_API_URL=https://api.hospeda.com.ar
# PUBLIC_SITE_URL=https://hospeda.com.ar

# Authentication (optional - only if auth features are needed)
# HOSPEDA_BETTER_AUTH_URL=http://localhost:3001/api/auth

# ISR Revalidation (optional - Vercel only, 32+ chars, must match API)
# HOSPEDA_REVALIDATION_SECRET=

# Monitoring (optional)
# PUBLIC_SENTRY_DSN=
# PUBLIC_SENTRY_RELEASE=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# Feature Flags (optional)
# PUBLIC_ENABLE_LOGGING=false
# PUBLIC_VERSION=0.1.0

# Feedback FAB (optional)
# Set to 'true' in preview/production to show the feedback floating action button.
# Defaults to 'false' (FAB hidden) so local dev stays quiet.
# PUBLIC_FEEDBACK_ENABLED=true

# Newsletter WhatsApp channel CTA (optional, SPEC-101)
# Mirror of HOSPEDA_NEWSLETTER_WA_CHANNEL_URL (server-side, used by the
# welcome email). When set, the WhatsAppCTA web component renders a join
# CTA; when unset, the block is hidden.
# PUBLIC_HOSPEDA_WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/0029Va6S3oPxxxxxxxxxxxx
