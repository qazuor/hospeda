# =============================================================================
# apps/web — Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in the required values.
#
#   cp .env.example .env.local
#
# Required vars are uncommented with placeholder values.
# Optional vars are commented out; uncomment and adjust as needed.
# =============================================================================

# =============================================================================
# Runtime
# =============================================================================

# Node.js execution environment.
# Allowed: development | test | production
NODE_ENV=development

# =============================================================================
# Core URLs (required)
# =============================================================================

# API base URL — used for server-side data fetching.
# Use HOSPEDA_API_URL in monorepo dev; PUBLIC_API_URL in production deployments.
HOSPEDA_API_URL=http://localhost:3001
# PUBLIC_API_URL=https://api.hospeda.ar

# Web site base URL.
HOSPEDA_SITE_URL=http://localhost:4321
# PUBLIC_SITE_URL=https://hospeda.ar

# =============================================================================
# Authentication (required)
# =============================================================================

# Better Auth endpoint URL — must point at the /api/auth mount of the API server.
HOSPEDA_BETTER_AUTH_URL=http://localhost:3001/api/auth

# =============================================================================
# ISR Revalidation (optional)
# =============================================================================

# ISR Revalidation secret (must match API)
# Generate with: openssl rand -hex 32 — must be at least 32 characters.
HOSPEDA_REVALIDATION_SECRET=

# =============================================================================
# Monitoring — Sentry (optional)
# =============================================================================

# Sentry DSN for client-side error tracking.
# PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# Sentry release identifier.
# PUBLIC_SENTRY_RELEASE=1.0.0

# Sentry source maps upload (build time only — never commit real values)
# SENTRY_AUTH_TOKEN=           # Sentry → Settings → Account → API → Auth Tokens
# SENTRY_ORG=                  # Your Sentry organization slug
# SENTRY_PROJECT=              # Your Sentry project slug for the web app

# =============================================================================
# Feature Flags (optional)
# =============================================================================

# Enable verbose client-side logging (development only).
# PUBLIC_ENABLE_LOGGING=false

# Application version string injected at build time.
# PUBLIC_VERSION=1.0.0
