---
/**
 * Dynamic Page Example with getStaticPaths
 *
 * This page demonstrates:
 * - Dynamic routes with parameters
 * - getStaticPaths for SSG
 * - Service integration
 * - Error handling
 * - Related content
 * - SEO for dynamic pages
 *
 * File location: src/pages/alojamientos/[slug].astro
 */

import type { GetStaticPaths } from 'astro';
import { AccommodationService, DestinationService } from '@repo/service-core';
import MainLayout from '../layouts/MainLayout.astro';
import { Image } from 'astro:assets';
import { Icon } from '@repo/icons';

/**
 * getStaticPaths runs at BUILD TIME
 * Generates one static page for each accommodation
 */
export const getStaticPaths = (async () => {
  const service = new AccommodationService();

  // Fetch all accommodations
  const result = await service.findAll({ limit: 1000 });

  if (!result.success) {
    console.error('Failed to fetch accommodations:', result.error);
    return [];
  }

  // Generate one path per accommodation
  return result.data.items.map(accommodation => ({
    // URL parameter
    params: { slug: accommodation.slug },
    // Props passed to page component
    props: {
      accommodation,
      destination: accommodation.destination
    }
  }));
}) satisfies GetStaticPaths;

// Props from getStaticPaths
const { accommodation, destination } = Astro.props;

// Get URL param (for reference)
const { slug } = Astro.params;

// Fetch related accommodations at build time
const relatedService = new AccommodationService();
const relatedResult = await relatedService.findAll({
  filters: { destinationId: destination.id },
  limit: 3
});

const relatedAccommodations = relatedResult.success
  ? relatedResult.data.items.filter(acc => acc.id !== accommodation.id).slice(0, 3)
  : [];

// SEO metadata
const title = `${accommodation.name} - ${destination.name}`;
const description = accommodation.description.slice(0, 160);
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL}/alojamientos/${slug}`;
const imageUrl = accommodation.images[0]?.url || '/default-og.jpg';

// Structured data for search engines
const accommodationSchema = {
  "@context": "https://schema.org",
  "@type": "Hotel",
  "name": accommodation.name,
  "description": accommodation.description,
  "url": canonicalUrl,
  "image": accommodation.images.map(img => img.url),
  "address": {
    "@type": "PostalAddress",
    "streetAddress": accommodation.address,
    "addressLocality": destination.name,
    "addressRegion": "Entre Ríos",
    "addressCountry": "AR"
  },
  "priceRange": `$${accommodation.pricePerNight}`,
  "starRating": {
    "@type": "Rating",
    "ratingValue": accommodation.stars
  }
};
---

<MainLayout title={title} description={description} image={imageUrl}>
  <!-- SEO Head -->
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="hotel" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(accommodationSchema)} />
  </Fragment>

  <!-- Main Content -->
  <article class="accommodation-detail">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/">Inicio</a>
      <span>/</span>
      <a href="/alojamientos">Alojamientos</a>
      <span>/</span>
      <a href={`/destinos/${destination.slug}`}>{destination.name}</a>
      <span>/</span>
      <span>{accommodation.name}</span>
    </nav>

    <!-- Header -->
    <header class="header">
      <div class="container">
        <h1>{accommodation.name}</h1>
        <div class="meta">
          <div class="rating">
            {Array.from({ length: accommodation.stars }).map(() => (
              <Icon name="star" size={20} />
            ))}
          </div>
          <div class="location">
            <Icon name="map-pin" size={20} />
            <span>{destination.name}, Entre Ríos</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Image Gallery -->
    <section class="gallery">
      <div class="main-image">
        <Image
          src={accommodation.images[0]?.url || '/placeholder.jpg'}
          alt={`${accommodation.name} - Vista principal`}
          width={1200}
          height={600}
          format="webp"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="thumbnail-grid">
        {accommodation.images.slice(1, 5).map((image, i) => (
          <Image
            src={image.url}
            alt={`${accommodation.name} - Foto ${i + 2}`}
            width={300}
            height={200}
            format="webp"
            loading="lazy"
          />
        ))}
      </div>
    </section>

    <!-- Info Section -->
    <section class="info">
      <div class="container">
        <div class="main-content">
          <!-- Description -->
          <div class="description">
            <h2>Descripción</h2>
            <p>{accommodation.description}</p>
          </div>

          <!-- Amenities -->
          <div class="amenities">
            <h2>Servicios</h2>
            <ul class="amenities-list">
              {accommodation.amenities.map(amenity => (
                <li>
                  <Icon name="check" size={20} />
                  <span>{amenity.name}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Location -->
          <div class="location-section">
            <h2>Ubicación</h2>
            <p class="address">{accommodation.address}</p>
            <p class="city">{destination.name}, Entre Ríos, Argentina</p>

            <!-- Map placeholder (would be React island in real implementation) -->
            <div class="map-placeholder">
              <p>🗺️ Mapa interactivo aquí (React island)</p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="sidebar">
          <!-- Price Card -->
          <div class="price-card">
            <div class="price">
              <span class="amount">${accommodation.pricePerNight}</span>
              <span class="period">por noche</span>
            </div>

            <button class="btn-book">
              Reservar ahora
            </button>

            <p class="availability">
              ✓ Disponible para las fechas seleccionadas
            </p>
          </div>

          <!-- Contact Card -->
          <div class="contact-card">
            <h3>Contacto</h3>
            <p class="phone">
              <Icon name="phone" size={20} />
              <span>{accommodation.phone || '(03442) 123-456'}</span>
            </p>
            <p class="email">
              <Icon name="mail" size={20} />
              <span>{accommodation.email || 'info@hospeda.com.ar'}</span>
            </p>
          </div>
        </aside>
      </div>
    </section>

    <!-- Related Accommodations -->
    {relatedAccommodations.length > 0 && (
      <section class="related">
        <div class="container">
          <h2>Otros alojamientos en {destination.name}</h2>

          <div class="related-grid">
            {relatedAccommodations.map(related => (
              <a href={`/alojamientos/${related.slug}`} class="related-card">
                <img
                  src={related.images[0]?.url || '/placeholder.jpg'}
                  alt={related.name}
                  width="400"
                  height="300"
                  loading="lazy"
                />
                <div class="card-content">
                  <h3>{related.name}</h3>
                  <p class="price">${related.pricePerNight} / noche</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</MainLayout>

<style>
  /* Breadcrumb */
  .breadcrumb {
    @apply max-w-7xl mx-auto px-4 py-4 text-sm text-gray-600;
    @apply flex items-center gap-2;
  }

  .breadcrumb a {
    @apply hover:text-primary transition-colors;
  }

  /* Header */
  .header {
    @apply bg-white border-b border-gray-200;
  }

  .header .container {
    @apply max-w-7xl mx-auto px-4 py-6;
  }

  .header h1 {
    @apply text-4xl font-bold mb-4;
  }

  .header .meta {
    @apply flex items-center gap-6;
  }

  .rating {
    @apply flex items-center text-yellow-500;
  }

  .location {
    @apply flex items-center gap-2 text-gray-600;
  }

  /* Gallery */
  .gallery {
    @apply max-w-7xl mx-auto px-4 py-8;
  }

  .main-image {
    @apply mb-4 rounded-lg overflow-hidden;
  }

  .main-image img {
    @apply w-full object-cover;
  }

  .thumbnail-grid {
    @apply grid grid-cols-4 gap-4;
  }

  .thumbnail-grid img {
    @apply rounded-lg cursor-pointer hover:opacity-80 transition-opacity;
  }

  /* Info Section */
  .info .container {
    @apply max-w-7xl mx-auto px-4 py-12;
    @apply grid grid-cols-1 lg:grid-cols-3 gap-8;
  }

  .main-content {
    @apply lg:col-span-2 space-y-8;
  }

  .description h2,
  .amenities h2,
  .location-section h2 {
    @apply text-2xl font-bold mb-4;
  }

  .description p {
    @apply text-gray-700 leading-relaxed;
  }

  .amenities-list {
    @apply grid grid-cols-1 md:grid-cols-2 gap-3;
  }

  .amenities-list li {
    @apply flex items-center gap-2 text-gray-700;
  }

  .map-placeholder {
    @apply mt-4 h-64 bg-gray-100 rounded-lg;
    @apply flex items-center justify-center text-gray-500;
  }

  /* Sidebar */
  .sidebar {
    @apply space-y-6;
  }

  .price-card,
  .contact-card {
    @apply bg-white rounded-lg shadow-md p-6 border border-gray-200;
  }

  .price-card .price {
    @apply mb-4 pb-4 border-b border-gray-200;
  }

  .price .amount {
    @apply text-3xl font-bold text-primary;
  }

  .price .period {
    @apply ml-2 text-gray-600;
  }

  .btn-book {
    @apply w-full py-3 bg-primary text-white rounded-lg font-semibold;
    @apply hover:bg-primary-dark transition-colors;
  }

  .availability {
    @apply mt-4 text-sm text-green-600;
  }

  .contact-card h3 {
    @apply text-lg font-semibold mb-4;
  }

  .contact-card p {
    @apply flex items-center gap-2 mb-2 text-gray-700;
  }

  /* Related */
  .related {
    @apply py-12 bg-gray-50;
  }

  .related .container {
    @apply max-w-7xl mx-auto px-4;
  }

  .related h2 {
    @apply text-2xl font-bold mb-8;
  }

  .related-grid {
    @apply grid grid-cols-1 md:grid-cols-3 gap-6;
  }

  .related-card {
    @apply block bg-white rounded-lg overflow-hidden shadow-md;
    @apply hover:shadow-xl transition-shadow;
  }

  .related-card img {
    @apply w-full h-48 object-cover;
  }

  .related-card .card-content {
    @apply p-4;
  }

  .related-card h3 {
    @apply font-semibold mb-2;
  }

  .related-card .price {
    @apply text-primary font-medium;
  }
</style>
