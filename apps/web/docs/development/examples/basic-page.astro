---
/**
 * Basic Static Page Example
 *
 * This page demonstrates:
 * - Static Site Generation (SSG)
 * - Build-time data fetching
 * - SEO optimization
 * - Component composition
 * - Styling with Tailwind CSS
 *
 * File location: src/pages/about.astro
 */

// Imports
import MainLayout from '../layouts/MainLayout.astro';
import { Icon } from '@repo/icons';

// This code runs at BUILD TIME (once, in Node.js)
// Perfect for content that doesn't change frequently

// Fetch data at build time
const teamMembers = [
  {
    id: 1,
    name: 'Juan Pérez',
    role: 'Founder & CEO',
    bio: 'Tourism expert with 15+ years experience',
    image: '/team/juan.jpg'
  },
  {
    id: 2,
    name: 'María González',
    role: 'Operations Manager',
    bio: 'Specialist in accommodation management',
    image: '/team/maria.jpg'
  },
  {
    id: 3,
    name: 'Carlos López',
    role: 'Technology Lead',
    bio: 'Full-stack developer passionate about tourism tech',
    image: '/team/carlos.jpg'
  }
];

// SEO metadata
const title = 'About Us';
const description = 'Learn about Hospeda and our mission to promote tourism in the Litoral region of Argentina.';
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL}/about`;
---

<!-- Layout with SEO metadata -->
<MainLayout title={title} description={description}>
  <!-- Structured data for SEO -->
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "name": title,
      "description": description,
      "url": canonicalUrl
    })} />
  </Fragment>

  <!-- Main content -->
  <article class="about-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <h1 class="title">About Hospeda</h1>
        <p class="subtitle">
          Connecting travelers with unique accommodations in Argentina's Litoral region
        </p>
      </div>
    </section>

    <!-- Mission Section -->
    <section class="mission">
      <div class="container">
        <h2>Our Mission</h2>
        <p>
          At Hospeda, we believe in the power of authentic travel experiences.
          Our platform connects travelers with carefully selected accommodations
          in Concepción del Uruguay and the broader Litoral region, promoting
          sustainable tourism and local economies.
        </p>
      </div>
    </section>

    <!-- Team Section -->
    <section class="team">
      <div class="container">
        <h2>Meet Our Team</h2>

        <div class="team-grid">
          {teamMembers.map(member => (
            <div class="team-card">
              <img
                src={member.image}
                alt={member.name}
                width="200"
                height="200"
                loading="lazy"
              />
              <h3>{member.name}</h3>
              <p class="role">{member.role}</p>
              <p class="bio">{member.bio}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="values">
      <div class="container">
        <h2>Our Values</h2>

        <div class="values-grid">
          <div class="value-card">
            <Icon name="heart" size={48} />
            <h3>Authenticity</h3>
            <p>We promote genuine local experiences and connections</p>
          </div>

          <div class="value-card">
            <Icon name="leaf" size={48} />
            <h3>Sustainability</h3>
            <p>We support eco-friendly practices and responsible tourism</p>
          </div>

          <div class="value-card">
            <Icon name="users" size={48} />
            <h3>Community</h3>
            <p>We empower local businesses and create economic opportunities</p>
          </div>

          <div class="value-card">
            <Icon name="star" size={48} />
            <h3>Quality</h3>
            <p>We ensure high standards for all listed accommodations</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
      <div class="container">
        <h2>Ready to Explore?</h2>
        <p>Discover amazing accommodations in the Litoral region</p>
        <a href="/alojamientos" class="btn-primary">
          Browse Accommodations
        </a>
      </div>
    </section>
  </article>
</MainLayout>

<!-- Scoped styles with Tailwind @apply -->
<style>
  .about-page {
    @apply min-h-screen;
  }

  /* Hero Section */
  .hero {
    @apply bg-gradient-to-r from-primary to-primary-dark text-white py-20;
  }

  .hero .container {
    @apply max-w-4xl mx-auto px-4 text-center;
  }

  .hero .title {
    @apply text-5xl font-bold mb-4;
  }

  .hero .subtitle {
    @apply text-xl opacity-90;
  }

  /* Mission Section */
  .mission {
    @apply py-16 bg-gray-50;
  }

  .mission .container {
    @apply max-w-3xl mx-auto px-4;
  }

  .mission h2 {
    @apply text-3xl font-bold mb-6 text-center;
  }

  .mission p {
    @apply text-lg text-gray-700 leading-relaxed;
  }

  /* Team Section */
  .team {
    @apply py-16;
  }

  .team .container {
    @apply max-w-6xl mx-auto px-4;
  }

  .team h2 {
    @apply text-3xl font-bold mb-12 text-center;
  }

  .team-grid {
    @apply grid grid-cols-1 md:grid-cols-3 gap-8;
  }

  .team-card {
    @apply text-center;
  }

  .team-card img {
    @apply rounded-full mx-auto mb-4 shadow-md;
  }

  .team-card h3 {
    @apply text-xl font-semibold mb-1;
  }

  .team-card .role {
    @apply text-primary font-medium mb-2;
  }

  .team-card .bio {
    @apply text-gray-600;
  }

  /* Values Section */
  .values {
    @apply py-16 bg-gray-50;
  }

  .values .container {
    @apply max-w-6xl mx-auto px-4;
  }

  .values h2 {
    @apply text-3xl font-bold mb-12 text-center;
  }

  .values-grid {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8;
  }

  .value-card {
    @apply text-center p-6 bg-white rounded-lg shadow-md;
  }

  .value-card h3 {
    @apply text-xl font-semibold mt-4 mb-2;
  }

  .value-card p {
    @apply text-gray-600;
  }

  /* CTA Section */
  .cta {
    @apply py-20 bg-primary text-white text-center;
  }

  .cta .container {
    @apply max-w-2xl mx-auto px-4;
  }

  .cta h2 {
    @apply text-4xl font-bold mb-4;
  }

  .cta p {
    @apply text-xl mb-8 opacity-90;
  }

  .btn-primary {
    @apply inline-block px-8 py-4 bg-white text-primary rounded-lg font-semibold text-lg;
    @apply hover:bg-gray-100 transition-colors;
  }
</style>
