# ===========================================
# Hospeda Admin - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# In deployment (Vercel), set these in the project settings dashboard.
# Variables marked [REQUIRED] must be set before starting.

# --- API Connection [REQUIRED] ---
# Used in deployment environments (Vercel). Must be a fully qualified URL.
VITE_API_URL=http://localhost:3001

# --- Locale Configuration ---
VITE_SUPPORTED_LOCALES=en,es
VITE_DEFAULT_LOCALE=en

# --- Debug (optional) ---
# Set to a user ID to impersonate that actor during development.
# VITE_DEBUG_ACTOR_ID=

# --- Monorepo Alternatives ---
# When running from the monorepo root with `pnpm dev`, these variables are
# read from the root .env.local and automatically mapped to the VITE_* names
# above. You only need VITE_* variables when deploying to Vercel directly.
# HOSPEDA_API_URL=http://localhost:3001
# HOSPEDA_SUPPORTED_LOCALES=en,es
# HOSPEDA_DEFAULT_LOCALE=en
# HOSPEDA_DEBUG_ACTOR_ID=
