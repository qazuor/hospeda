# =============================================================================
# apps/admin — Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in the required values.
#
#   cp .env.example .env.local
#
# Required vars are uncommented with a placeholder value.
# Optional vars are commented out; uncomment and adjust as needed.
# Production-only vars are commented with "(required in production)".
# Conditional vars note when they become required.
# Platform-injected vars (e.g. CI) are for reference only.
# SECRET vars contain sensitive credentials — never commit real values.
# =============================================================================

# =============================================================================
# CLIENT-ADMIN
# =============================================================================

# Admin dashboard's own public URL (Vite VITE_ prefix)
# How to obtain: The admin app's own origin. Used to build the absolute
# callbackUrl when redirecting unauthenticated users to the web signin
# (SPEC-182). Local: http://localhost:3000. Staging:
# https://staging-admin.hospeda.com.ar. Production:
# https://admin.hospeda.com.ar.
VITE_ADMIN_URL=http://localhost:3000

# API endpoint for the admin dashboard (Vite VITE_ prefix)
# How to obtain: Same value as HOSPEDA_API_URL but exposed to the admin browser
# bundle. Local: http://localhost:3001. Production: https://api.hospeda.com.ar.
VITE_API_URL=http://localhost:3001

# Short description of the admin application
# How to obtain: Free text used in <meta description>. Keep the default unless
# rebranding.
# VITE_APP_DESCRIPTION=Admin panel for Hospeda platform

# Display name of the admin application
# How to obtain: Free text shown in browser tab title and admin sidebar header.
# Default: "Hospeda Admin".
# VITE_APP_NAME=Hospeda Admin

# Application version string shown in the admin UI
# How to obtain: Free-text version shown in the admin footer. In CI/CD wire it
# to HOSPEDA_COMMIT_SHA so it tracks the deployed git SHA. Local: pick anything.
# VITE_APP_VERSION=1.0.0

# Better Auth endpoint URL for the admin dashboard
# How to obtain: Always VITE_API_URL + "/api/auth". Local:
# http://localhost:3001/api/auth. Production:
# https://api.hospeda.com.ar/api/auth.
VITE_BETTER_AUTH_URL=http://localhost:3001/api/auth

# Hard-coded actor ID injected for local development and testing
# How to obtain: A real user UUID from your DB to impersonate while developing.
# Get it from db:studio → users table. Leave blank in preview/prod.
# VITE_DEBUG_ACTOR_ID=dev-actor-uuid

# Enable verbose logging for lazy-loaded section components
# How to obtain: Set "true" only when debugging code-split / lazy section
# loading. Adds noisy console logs. Keep false otherwise.
# VITE_DEBUG_LAZY_SECTIONS=false

# Default locale code used by the admin app
# How to obtain: Locale used when the user has no preference (e.g. "es" for
# Argentina). Must be one of VITE_SUPPORTED_LOCALES.
# VITE_DEFAULT_LOCALE=es

# Default number of rows per page in admin data tables
# How to obtain: Initial page size for all admin tables. Default 25 — bump up
# for power users, down for low-bandwidth.
# VITE_DEFAULT_PAGE_SIZE=25

# Enable React DevTools integration in the admin app
# How to obtain: Set "true" only in local dev. Adds React DevTools profiling
# hooks. Keep false in preview/prod.
# VITE_ENABLE_DEVTOOLS=false

# Enable client-side console logging in the admin app
# How to obtain: Set "true" in dev to surface verbose admin client logs. Default
# false (silent in prod).
# VITE_ENABLE_LOGGING=false

# Enable TanStack Query DevTools panel in the admin app
# How to obtain: Set "true" only in local dev to see the floating Query
# inspector panel. Keep false everywhere else.
# VITE_ENABLE_QUERY_DEVTOOLS=false

# Enable TanStack Router DevTools panel in the admin app
# How to obtain: Set "true" only in local dev to see the floating Router
# inspector. Keep false in preview/prod.
# VITE_ENABLE_ROUTER_DEVTOOLS=false

# Include severity level label in admin client-side log output
# How to obtain: Default true — prefixes each log line with [INFO] / [WARN] /
# [ERROR].
# VITE_LOG_INCLUDE_LEVEL=true

# Include ISO-8601 timestamps in admin client-side log output
# How to obtain: Default true — prefixes each log line with ISO timestamp.
# VITE_LOG_INCLUDE_TIMESTAMPS=true

# Minimum log level for the admin client-side logger
# How to obtain: Pick: DEBUG (everything, very noisy), INFO (default), WARN
# (only warnings + errors), ERROR (only errors). Use DEBUG locally, INFO/WARN in
# prod.
# VITE_LOG_LEVEL=DEBUG

# Colorise admin client-side log output (disable in CI/production)
# How to obtain: Default true — colored console output. Set false when piping
# logs to files/CI to avoid ANSI escape garbage.
# VITE_LOG_USE_COLORS=false

# Maximum number of rows per page allowed in admin data tables
# How to obtain: Hard cap on user-selected page size. Default 100 — pages larger
# than this hit the API hard.
# VITE_MAX_PAGE_SIZE=100

# PostHog ingestion endpoint for the admin app. Defaults to US Cloud region.
# Override for EU Cloud or self-hosted.
# How to obtain: Default `https://us.i.posthog.com` (matches Hospeda org in US
# Cloud, decided 2026-05-17). Change ONLY if migrating to EU Cloud
# (`https://eu.i.posthog.com`) or self-hosted PostHog. Admin app uses Vite
# (TanStack Start) so the prefix is VITE_ instead of PUBLIC_.
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# PostHog Cloud project API key for the admin app (`phc_...`). Client-exposed by
# design (ships in the browser bundle). Empty disables PostHog init.
# How to obtain: PostHog Cloud (https://us.posthog.com) → org `Hospeda` →
# project `hospeda-admin-prod` (or `hospeda-admin-staging` for staging) →
# Settings → Project → Project API Key → copy the value starting with `phc_`.
# Stored in 1Password under "Hospeda / PostHog project keys". Admin app uses
# Vite (TanStack Start) so the prefix is VITE_ instead of PUBLIC_.
# See: https://us.posthog.com
# SECRET
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry DSN for error tracking in the admin dashboard
# How to obtain: Sentry → your admin project → Settings → Client Keys (DSN) →
# copy the DSN URL. NOTE: Sentry DSNs are write-only ingestion keys,
# intentionally public per Sentry design — they ship in the admin bundle and
# that is by design. Use a separate Sentry project from web/api so errors are
# scoped per surface. Leave blank to disable.
# See: https://docs.sentry.io/concepts/key-terms/dsn-explainer/
# VITE_SENTRY_DSN=https://abc123def456@o123456.ingest.sentry.io/7890123

# Sentry environment tag for the admin dashboard (production | staging |
# development)
# How to obtain: Free-text label applied to all Sentry events from the admin.
# Set to `production` on hospeda-admin-prod and `staging` on
# hospeda-admin-staging. Takes precedence over import.meta.env.MODE in the
# Sentry init — without it, Vite production builds always tag events as
# `production` regardless of which deployment they came from, mixing staging and
# prod in the same Sentry environment bucket. NOTE: must be passed as a Docker
# build-arg too (the admin Dockerfile bakes VITE_* into the bundle at build
# time). Mirror of HOSPEDA_SENTRY_ENVIRONMENT (API).
# VITE_SENTRY_ENVIRONMENT=staging

# Sentry project name for the admin dashboard
# How to obtain: Project slug shown in your Sentry URL:
# sentry.io/organizations/<org>/projects/<this>/. Used by source-map upload
# tooling.
# VITE_SENTRY_PROJECT=hospeda-admin

# Sentry release identifier for the admin dashboard
# How to obtain: Free-text version per deploy. Recommended: wire it to
# HOSPEDA_COMMIT_SHA in CI/CD so each deploy is a unique release in Sentry
# ("abc123def456"). Avoid semver "1.0.0" — every preview/staging would collide.
# VITE_SENTRY_RELEASE=abc123def456

# Public web app URL exposed to the admin dashboard (Vite VITE_ prefix)
# How to obtain: Public website URL — admin uses it to build "View on site"
# links. Local: http://localhost:4321. Production: https://hospeda.com.ar.
VITE_SITE_URL=http://localhost:4321

# Comma-separated list of locale codes supported by the admin app
# How to obtain: Comma-separated locale codes the admin UI offers (e.g.
# "es,en,pt"). Must match what @repo/i18n actually has translations for.
# VITE_SUPPORTED_LOCALES=es,en

# =============================================================================
# CORE
# =============================================================================

# API base URL
# How to obtain: Where the Hono API lives. Local: http://localhost:3001.
# Production: https://api.hospeda.com.ar (Coolify-managed deployment on the
# VPS).
HOSPEDA_API_URL=http://localhost:3001

# =============================================================================
# I18N
# =============================================================================

# Default locale (mapped to VITE_DEFAULT_LOCALE at build)
# How to obtain: Locale used when no preference is set (e.g. "es" for
# Argentina). Must be one of HOSPEDA_SUPPORTED_LOCALES.
# HOSPEDA_DEFAULT_LOCALE=es

# Supported locales (mapped to VITE_SUPPORTED_LOCALES at build)
# How to obtain: Comma-separated list of locale codes the admin UI offers (e.g.
# "es,en,pt"). Must be a subset of what @repo/i18n actually has translations
# for. Order does not matter for routing but tooling may use the first as a
# tie-breaker.
# HOSPEDA_SUPPORTED_LOCALES=es,en,pt

# =============================================================================
# INTEGRATIONS
# =============================================================================

# Cloudflare Turnstile site key for the admin app (PUBLIC — ships in the browser
# bundle). Powers the invisible bot-detection widget on the admin feedback form
# (SPEC-301 T-010). When unset, the widget is not rendered and the server
# applies its own fail-closed policy. Use the always-passes test key
# (1x00000000000000000000AA) locally.
# How to obtain: Cloudflare Dashboard → Turnstile → Add site → choose Invisible
# widget type → copy the Site Key. For local/staging use the always-passes test
# site key: 1x00000000000000000000AA. Set the real production key in Coolify for
# hospeda-admin-prod. The site key is intentionally public (it ships in the
# browser bundle — that is by design).
# See: https://developers.cloudflare.com/turnstile/get-started/
# (required in production)
# VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# =============================================================================
# MONITORING
# =============================================================================

# Sentry auth token used at build time to upload source maps (web, admin, api)
# How to obtain: Sentry → Settings → Account → User Auth Tokens → Create New
# Token. Required scopes: `project:releases`, `org:read`, `project:read`. Used
# by @sentry/astro (web), @sentry/vite-plugin (admin), and
# @sentry/esbuild-plugin (api) at build time to upload source maps so production
# stack traces are symbolicated. Build skips upload silently if missing. Org
# slug `qazuor` and per-app project slugs (`hospeda-web`, `hospeda-admin`,
# `hospeda-api`) are hardcoded in each app build config — the same org-scoped
# token works for all three.
# See: https://docs.sentry.io/account/auth-tokens/
# SECRET
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# SYSTEM
# =============================================================================

# Node.js execution environment; controls optimisations and feature flags
# How to obtain: Auto-set by the runtime. In Coolify the platform-level NODE_ENV
# is "production"; locally use "development" or leave it unset and pnpm scripts
# pick the right value.
# NODE_ENV=development
