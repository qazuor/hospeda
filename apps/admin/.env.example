# =============================================================================
# apps/admin — Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in the required values.
#
#   cp .env.example .env.local
#
# All variables use the VITE_ prefix so that Vite (TanStack Start) exposes
# them to the browser bundle. Do NOT put secrets in VITE_* variables — they
# are always visible to anyone who loads the admin dashboard.
#
# Required vars are uncommented with placeholder values.
# Optional vars are commented out; uncomment and adjust as needed.
# =============================================================================

# =============================================================================
# Runtime
# =============================================================================

# Node.js execution environment — controls Vite optimisations and build mode.
# Allowed: development | test | production
#
# IMPORTANT: NODE_ENV is platform-managed by Vercel. Do NOT set it in the
# Vercel project Settings (the platform rejects it). The line below is for
# reference only — uncomment in `.env.local` only if you need to override
# the local default while running outside the Vercel CLI.
# NODE_ENV=development

# =============================================================================
# Core URLs (required)
# =============================================================================

# API endpoint for the admin dashboard.
# All admin API calls are sent to this base URL.
VITE_API_URL=http://localhost:3001

# Server-side API URL used by TanStack Start server functions (e.g. session validation).
# Unlike VITE_API_URL, this variable is read via process.env and is NEVER exposed to
# the browser. It must be set in the deployment environment (Vercel, Docker, etc.).
HOSPEDA_API_URL=http://localhost:3001

# Better Auth endpoint URL for the admin dashboard.
# Used by @repo/auth-ui to redirect and validate sessions.
VITE_BETTER_AUTH_URL=http://localhost:3001/api/auth

# Public web app URL — used by admin to generate public-facing links.
VITE_SITE_URL=http://localhost:4321

# Admin dashboard's own public URL. Used to build the absolute callbackUrl when
# the _authed guard redirects unauthenticated users to the web signin (SPEC-182).
# Local: http://localhost:3000. Staging: https://staging-admin.hospeda.com.ar.
# Production: https://admin.hospeda.com.ar.
VITE_ADMIN_URL=http://localhost:3000

# =============================================================================
# Application Identity (optional)
# =============================================================================

# Display name shown in the browser tab title and sidebar header.
# VITE_APP_NAME=Hospeda Admin

# Application version string shown in the admin UI footer.
# VITE_APP_VERSION=1.0.0

# Short description of the admin application.
# VITE_APP_DESCRIPTION=Panel de administracion de Hospeda

# =============================================================================
# Developer Tools (optional)
# =============================================================================

# Enable React DevTools integration.
# VITE_ENABLE_DEVTOOLS=false

# Enable TanStack Query DevTools panel.
# VITE_ENABLE_QUERY_DEVTOOLS=false

# Enable TanStack Router DevTools panel.
# VITE_ENABLE_ROUTER_DEVTOOLS=false

# Enable verbose logging for lazy-loaded section components.
# VITE_DEBUG_LAZY_SECTIONS=false

# Hard-coded actor ID injected for local development and testing.
# VITE_DEBUG_ACTOR_ID=dev-actor-uuid

# Enable client-side console logging in the admin app.
# VITE_ENABLE_LOGGING=false

# =============================================================================
# Pagination (optional)
# =============================================================================

# Default number of rows per page in admin data tables.
# VITE_DEFAULT_PAGE_SIZE=10

# Maximum number of rows per page allowed in admin data tables.
# VITE_MAX_PAGE_SIZE=100

# =============================================================================
# Internationalisation (optional)
# =============================================================================

# Comma-separated list of locale codes supported by the admin app.
# VITE_SUPPORTED_LOCALES=es,en

# Default locale code used by the admin app.
# VITE_DEFAULT_LOCALE=es

# =============================================================================
# Monitoring — Sentry (optional)
# =============================================================================

# Sentry DSN for error tracking in the admin dashboard.
# Obtain from https://sentry.io — leave unset to disable Sentry.
# VITE_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# Sentry release identifier for the admin dashboard.
# VITE_SENTRY_RELEASE=1.0.0

# Sentry project name for the admin dashboard.
# VITE_SENTRY_PROJECT=hospeda-admin

# Sentry environment tag (production | staging | development).
# REQUIRED to separate staging from production in the Sentry dashboard. Without
# it, Vite production builds always emit MODE=production regardless of which
# deployment they came from, and staging/prod events collide in the same bucket.
# NOTE: must also be passed as a Docker build-arg (--build-arg VITE_SENTRY_ENVIRONMENT=staging)
# because Vite bakes VITE_* into the bundle at build time. Set per Coolify resource.
# VITE_SENTRY_ENVIRONMENT=staging

# =============================================================================
# Analytics — PostHog Cloud (optional, SPEC-140)
# =============================================================================

# PostHog Cloud project API key for the admin app. Public by design — ships
# in the browser bundle. Per-env values (staging vs prod) come from Coolify,
# one project key each. Leave unset locally to keep dev quiet (no events,
# no cookies, no network). The key starts with `phc_`. Keys live in
# 1Password under "Hospeda / PostHog project keys".
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostHog ingestion endpoint for the admin app. Defaults to the US Cloud
# region inside posthog-client.ts when unset. Override only if migrating
# to EU Cloud or self-hosted PostHog.
# VITE_POSTHOG_HOST=https://us.i.posthog.com
