{
    "name": "admin",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev --port 3000",
        "dev:clean": "rm -rf node_modules/.vite && pnpm dev",
        "dev:watch": "nodemon --watch '../../packages' --ext 'ts,tsx,js,jsx' --exec 'rm -rf node_modules/.vite' --delay 500ms & pnpm dev",
        "start": "node .output/server/index.mjs",
        "build": "vite build",
        "build:analyze": "ANALYZE=1 pnpm build",
        "serve": "vite preview",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage --passWithNoTests",
        "test:ui": "vitest --ui",
        "test:visual:install": "playwright install chromium --with-deps",
        "test:visual:baseline": "playwright test --config=playwright-visual.config.ts --update-snapshots",
        "test:visual": "playwright test --config=playwright-visual.config.ts",
        "check": "biome check",
        "clean": "rm -rf node_modules dist",
        "clean:cache": "rm -rf node_modules/.vite",
        "lint": "biome check .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit --project ./tsconfig.json",
        "validate:sidebar-routes": "tsx --tsconfig ./tsconfig.json ./scripts/validate-sidebar-routes.ts"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
