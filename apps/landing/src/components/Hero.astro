---
import { Image } from 'astro:assets';
import logo from '../assets/logo.webp';
import heroAtardecer from '../assets/hero/hero-atardecer.jpg';
import heroIsla from '../assets/hero/hero-isla.jpg';
import heroPlaya from '../assets/hero/hero-playa.jpg';

const heroImages = [
    { src: heroAtardecer, alt: 'Atardecer sobre el río Uruguay' },
    { src: heroIsla, alt: 'Isla en el Litoral entrerriano' },
    { src: heroPlaya, alt: 'Playa en Concepción del Uruguay' }
];
---

<section class="hero" aria-labelledby="hero-title">
    <div class="hero-images" aria-hidden="true">
        {
            heroImages.map((image, index) => (
                <div
                    class="hero-image-slot"
                    data-index={index}
                    data-active={index === 0 ? 'true' : 'false'}
                >
                    <Image
                        src={image.src}
                        alt={image.alt}
                        widths={[640, 960, 1280, 1920]}
                        sizes="100vw"
                        loading={index === 0 ? 'eager' : 'lazy'}
                        decoding="async"
                        format="webp"
                        quality={70}
                    />
                </div>
            ))
        }
    </div>

    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="hero-content container">
        <a href="/" class="hero-logo" aria-label="Hospeda — inicio">
            <Image
                src={logo}
                alt="Hospeda"
                width={140}
                height={45}
                loading="eager"
                decoding="async"
            />
        </a>

        <div class="hero-eyebrow">
            <span class="hero-eyebrow-dot" aria-hidden="true"></span>
            <span>Próximamente</span>
        </div>

        <h1 id="hero-title" class="hero-title">
            Tu escapada
            <span class="hero-title-cursive">empieza acá</span>
        </h1>

        <p class="hero-tagline">
            La forma más simple de descubrir hospedajes en Concepción del Uruguay
            y todo el Litoral entrerriano. Sin intermediarios. Sin sorpresas.
        </p>

        <div class="hero-cta">
            <a href="#newsletter" class="hero-cta-button">
                Avisame cuando esté listo
                <svg
                    aria-hidden="true"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
    </div>
</section>

<script>
    // Simple cross-fade rotator. Changes the `data-active` attribute every
    // 6 seconds; CSS handles the fade transition.
    const slots = document.querySelectorAll<HTMLElement>('.hero-image-slot');
    if (slots.length > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        let current = 0;
        setInterval(() => {
            slots[current]?.setAttribute('data-active', 'false');
            current = (current + 1) % slots.length;
            slots[current]?.setAttribute('data-active', 'true');
        }, 6000);
    }
</script>

<style>
    .hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        overflow: hidden;
        isolation: isolate;
    }

    .hero-images {
        position: absolute;
        inset: 0;
        z-index: -2;
    }

    .hero-image-slot {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 1.6s var(--ease-out);
    }

    .hero-image-slot[data-active='true'] {
        opacity: 1;
    }

    .hero-image-slot :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        z-index: -1;
        background: linear-gradient(
            135deg,
            oklch(0.18 0.04 250 / 0.78) 0%,
            oklch(0.22 0.06 220 / 0.6) 50%,
            oklch(0.18 0.04 200 / 0.78) 100%
        );
    }

    .hero-content {
        position: relative;
        z-index: 1;
        color: white;
        padding-block: var(--space-12);
        max-width: 880px;
    }

    .hero-logo {
        display: inline-flex;
        margin-bottom: var(--space-12);
    }

    .hero-logo :global(img) {
        height: 44px;
        width: auto;
        filter: drop-shadow(0 2px 8px oklch(0 0 0 / 0.3));
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-4);
        background: oklch(1 0 0 / 0.12);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid oklch(1 0 0 / 0.18);
        border-radius: var(--radius-pill);
        font-size: var(--text-body-sm);
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: var(--space-6);
    }

    .hero-eyebrow-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--brand-accent);
        box-shadow: 0 0 0 4px oklch(from var(--brand-accent) l c h / 0.3);
        animation: pulse 2s var(--ease-out) infinite;
    }

    @keyframes pulse {
        0%, 100% {
            box-shadow: 0 0 0 4px oklch(from var(--brand-accent) l c h / 0.3);
        }
        50% {
            box-shadow: 0 0 0 8px oklch(from var(--brand-accent) l c h / 0);
        }
    }

    .hero-title {
        font-size: var(--text-hero);
        font-weight: 700;
        margin-bottom: var(--space-6);
        text-shadow: 0 2px 16px oklch(0 0 0 / 0.35);
    }

    .hero-title-cursive {
        display: block;
        font-family: var(--font-decorative);
        font-weight: 600;
        font-style: italic;
        color: var(--hospeda-sand);
        letter-spacing: 0;
        margin-top: var(--space-2);
    }

    .hero-tagline {
        font-size: var(--text-tagline);
        max-width: 38ch;
        margin-bottom: var(--space-10);
        color: oklch(1 0 0 / 0.92);
        text-shadow: 0 1px 8px oklch(0 0 0 / 0.3);
    }

    .hero-cta {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
    }

    .hero-cta-button {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-4) var(--space-8);
        background: var(--brand-primary);
        color: var(--primary-foreground);
        font-size: var(--text-button);
        font-weight: 600;
        border-radius: var(--radius-pill);
        box-shadow: var(--shadow-soft);
        transition:
            transform var(--duration-fast) var(--ease-out),
            background-color var(--duration-fast) var(--ease-out);
    }

    .hero-cta-button:hover {
        background: oklch(from var(--brand-primary) calc(l + 0.05) c h);
        transform: translateY(-2px);
    }

    .hero-cta-button:active {
        transform: translateY(0);
    }

    @media (max-width: 640px) {
        .hero-content {
            padding-block: var(--space-10);
        }

        .hero-logo {
            margin-bottom: var(--space-8);
        }

        .hero-cta-button {
            width: 100%;
            justify-content: center;
        }
    }
</style>
