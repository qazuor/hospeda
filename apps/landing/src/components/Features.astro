---
// Three-card features section that grounds the abstract "value prop"
// into concrete things the user will get out of Hospeda. Inline SVG
// icons (no @repo/icons dependency to keep the landing self-contained).

interface Feature {
    title: string;
    body: string;
    iconKey: 'people' | 'shield' | 'map';
}

const features: Feature[] = [
    {
        title: 'Anfitriones locales',
        body: 'Conocés a quien te recibe. Cada hospedaje lo arman personas de la zona, con detalle y bienvenida real.',
        iconKey: 'people'
    },
    {
        title: 'Reserva directa',
        body: 'Pagás con MercadoPago, sin fees ocultos ni intermediarios. Lo que ves es lo que pagás.',
        iconKey: 'shield'
    },
    {
        title: 'El Litoral entero',
        body: 'Más que un hospedaje: descubrí los lugares, eventos y experiencias que solo conocen los locales.',
        iconKey: 'map'
    }
];
---

<section class="features" aria-labelledby="features-title">
    <div class="container">
        <h2 id="features-title" class="sr-only">Qué vas a encontrar</h2>
        <ul class="features-grid" role="list">
            {
                features.map((feature) => (
                    <li class="feature-card">
                        <div class="feature-icon" aria-hidden="true">
                            {feature.iconKey === 'people' && (
                                <svg
                                    width="32"
                                    height="32"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                                    <circle cx="9" cy="7" r="4" />
                                    <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                                </svg>
                            )}
                            {feature.iconKey === 'shield' && (
                                <svg
                                    width="32"
                                    height="32"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                    <polyline points="9 12 11 14 15 10" />
                                </svg>
                            )}
                            {feature.iconKey === 'map' && (
                                <svg
                                    width="32"
                                    height="32"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                                    <line x1="8" y1="2" x2="8" y2="18" />
                                    <line x1="16" y1="6" x2="16" y2="22" />
                                </svg>
                            )}
                        </div>
                        <h3 class="feature-title">{feature.title}</h3>
                        <p class="feature-body">{feature.body}</p>
                    </li>
                ))
            }
        </ul>
    </div>
</section>

<style>
    .features {
        background: var(--core-background);
        padding-block: var(--space-section);
        padding-top: 0;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: var(--space-6);
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .feature-card {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-4);
        padding: var(--space-8);
        background: white;
        border-radius: var(--radius-card);
        box-shadow: var(--shadow-card);
        border: 1px solid oklch(from var(--border) l c h / 0.6);
        transition:
            transform var(--duration-normal) var(--ease-out),
            box-shadow var(--duration-normal) var(--ease-out);
    }

    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-soft);
    }

    .feature-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        border-radius: var(--radius-lg);
        background: oklch(from var(--hospeda-river) l c h / 0.1);
        color: var(--hospeda-river);
    }

    .feature-title {
        font-size: 1.375rem;
        color: var(--core-foreground);
    }

    .feature-body {
        font-size: var(--text-body);
        color: var(--core-muted-foreground);
        line-height: 1.65;
    }

    @media (max-width: 540px) {
        .feature-card {
            padding: var(--space-6);
        }
    }
</style>
