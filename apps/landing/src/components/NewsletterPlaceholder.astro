---
// Phase 1: visual placeholder only. Submit handler arrives in Phase 2 with
// the POST /api/v1/public/newsletter endpoint and Brevo integration.
---

<section id="newsletter" class="newsletter" aria-labelledby="newsletter-title">
    <div class="container newsletter-inner">
        <p class="newsletter-eyebrow">Newsletter</p>
        <h2 id="newsletter-title" class="newsletter-title">
            Enterate primero cuando lance
        </h2>
        <p class="newsletter-tagline">
            Sin spam. Solo te avisamos cuando podamos abrirte las puertas y, de vez en
            cuando, te compartimos las mejores escapadas del Litoral.
        </p>

        <form
            class="newsletter-form"
            method="post"
            action="#"
            aria-label="Suscribirme al newsletter de Hospeda"
            data-phase="placeholder"
        >
            <label class="sr-only" for="newsletter-email">Email</label>
            <input
                id="newsletter-email"
                type="email"
                name="email"
                class="newsletter-input"
                placeholder="tu-email@ejemplo.com"
                autocomplete="email"
                required
                disabled
            />
            <button type="submit" class="newsletter-button" disabled>
                Avisame
            </button>
        </form>

        <p class="newsletter-note">
            Estamos terminando los últimos detalles. El formulario se activa muy pronto.
        </p>
    </div>
</section>

<style>
    .newsletter {
        background: linear-gradient(
            180deg,
            var(--core-background) 0%,
            var(--hospeda-sand) 100%
        );
        padding-block: var(--space-section);
    }

    .newsletter-inner {
        max-width: var(--container-narrow);
        text-align: center;
    }

    .newsletter-eyebrow {
        font-size: var(--text-body-sm);
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--hospeda-river);
        margin-bottom: var(--space-3);
    }

    .newsletter-title {
        font-size: var(--text-display);
        margin-bottom: var(--space-4);
    }

    .newsletter-tagline {
        font-size: var(--text-tagline);
        color: var(--core-muted-foreground);
        margin-bottom: var(--space-10);
        max-width: 52ch;
        margin-inline: auto;
    }

    .newsletter-form {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        max-width: 520px;
        margin: 0 auto var(--space-4);
        background: white;
        padding: var(--space-2);
        border-radius: var(--radius-pill);
        box-shadow: var(--shadow-card);
    }

    .newsletter-input {
        flex: 1 1 240px;
        min-width: 0;
        border: none;
        outline: none;
        background: transparent;
        font-family: inherit;
        font-size: var(--text-body);
        color: var(--core-foreground);
        padding: var(--space-3) var(--space-4);
    }

    .newsletter-input::placeholder {
        color: oklch(from var(--core-muted-foreground) l c h / 0.6);
    }

    .newsletter-input:disabled {
        cursor: not-allowed;
    }

    .newsletter-button {
        flex: 0 0 auto;
        padding: var(--space-3) var(--space-6);
        background: var(--brand-primary);
        color: var(--primary-foreground);
        border: none;
        border-radius: var(--radius-pill);
        font-family: inherit;
        font-size: var(--text-button);
        font-weight: 600;
        cursor: pointer;
        transition: background-color var(--duration-fast) var(--ease-out);
    }

    .newsletter-button:hover:not(:disabled) {
        background: oklch(from var(--brand-primary) calc(l + 0.05) c h);
    }

    .newsletter-button:disabled {
        cursor: not-allowed;
        opacity: 0.7;
    }

    .newsletter-note {
        font-size: var(--text-body-sm);
        color: var(--core-muted-foreground);
        font-style: italic;
    }

    @media (max-width: 540px) {
        .newsletter-form {
            border-radius: var(--radius-lg);
            flex-direction: column;
            padding: var(--space-3);
        }

        .newsletter-input {
            text-align: center;
            padding-block: var(--space-3);
        }

        .newsletter-button {
            width: 100%;
        }
    }
</style>
