---
/**
 * @file Homepage
 * @description Static copy of TravHub index3 template. Served as raw HTML
 * to avoid Astro/Vite processing of template JS and JSON data attributes.
 * This will be progressively replaced by Astro components.
 */
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

export const prerender = true;

export function getStaticPaths() {
    return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

const lang = Astro.params.lang ?? 'es';
const html = readFileSync(resolve(process.cwd(), 'public/template-homepage.html'), 'utf-8');
---
<Fragment set:html={html} />
