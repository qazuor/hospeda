{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "deny": [
            "Bash(git push * main)",
            "Bash(git push * main *)",
            "Bash(git push * staging)",
            "Bash(git push * staging *)",
            "Bash(git push * *:main)",
            "Bash(git push * *:main *)",
            "Bash(git push * *:staging)",
            "Bash(git push * *:staging *)",
            "Bash(git push -f *)",
            "Bash(git push --force *)",
            "Bash(git push --force-with-lease *)",
            "Bash(git commit *--amend* main)",
            "Bash(git commit *--amend* staging)"
        ]
    }
}
