# =============================================================================
# 🏠 HOSPEDA - CENTRALIZED ENVIRONMENT VARIABLES
# =============================================================================
# These are the "source of truth" variables that get mapped to client-side
# variables automatically by the @repo/config plugin
#
# 🔴 REQUIRED variables must be set for the application to work
# 🟡 OPTIONAL variables have sensible defaults

# =============================================================================
# 🌍 GENERAL CONFIGURATION
# =============================================================================
NODE_ENV=development                                    # 🟡 OPTIONAL (default: development)

# =============================================================================
# 🌐 API & SITE CONFIGURATION (Shared across apps)
# =============================================================================
HOSPEDA_API_URL=http://localhost:3001                  # 🔴 REQUIRED - API base URL (maps to PUBLIC_API_URL, VITE_API_URL)
HOSPEDA_SITE_URL=http://localhost:4321                 # 🔴 REQUIRED - Frontend site URL (maps to PUBLIC_SITE_URL)

# API-specific Configuration
API_PORT=3001                                          # 🟡 OPTIONAL (default: 3001)
API_HOST=localhost                                     # 🟡 OPTIONAL (default: localhost)

# =============================================================================
# 🔐 AUTHENTICATION (Clerk) - Shared + App-specific
# =============================================================================
HOSPEDA_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_TEST_PUBLISHABLE_HERE    # 🔴 REQUIRED - Clerk publishable key (exposed to client)
HOSPEDA_DEBUG_ACTOR_ID=00000000-0000-4000-y000-000000000000  # 🟡 OPTIONAL - Debug actor ID (maps to VITE_DEBUG_ACTOR_ID)
HOSPEDA_CLERK_SECRET_KEY=YOUR_TEST_SECRET_HERE      # 🔴 REQUIRED - Clerk secret key (server-only)
HOSPEDA_CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret # 🟡 OPTIONAL - Only if using webhooks

# =============================================================================
# 🌍 INTERNATIONALIZATION (Shared across apps)
# =============================================================================
HOSPEDA_PUBLIC_SUPPORTED_LOCALES=en,es                 # 🟡 OPTIONAL - Supported locales (exposed to client)
HOSPEDA_PUBLIC_DEFAULT_LOCALE=en                       # 🟡 OPTIONAL - Default locale (exposed to client)

# =============================================================================
# 💾 DATABASE CONFIGURATION
# =============================================================================
HOSPEDA_DATABASE_URL=postgresql://user:password@localhost:5432/hospeda  # 🔴 REQUIRED

# Database Pool Configuration (API-specific)
DB_POOL_MAX_CONNECTIONS=10                             # 🟡 OPTIONAL (default: 10)
DB_POOL_IDLE_TIMEOUT_MS=30000                          # 🟡 OPTIONAL (default: 30000)
DB_POOL_CONNECTION_TIMEOUT_MS=2000                     # 🟡 OPTIONAL (default: 2000)

# =============================================================================
# 📝 LOGGING CONFIGURATION (API-specific)
# =============================================================================
API_LOG_LEVEL=info                                     # 🟡 OPTIONAL (default: info)
API_ENABLE_REQUEST_LOGGING=true                        # 🟡 OPTIONAL (default: true)

# Log Formatting (API-specific)
API_LOG_INCLUDE_TIMESTAMPS=true                        # 🟡 OPTIONAL (default: true)
API_LOG_INCLUDE_LEVEL=true                             # 🟡 OPTIONAL (default: true)
API_LOG_USE_COLORS=true                                # 🟡 OPTIONAL (default: true)
API_LOG_SAVE=false                                     # 🟡 OPTIONAL (default: false)
API_LOG_EXPAND_OBJECTS=false                           # 🟡 OPTIONAL (default: false)
API_LOG_TRUNCATE_TEXT=true                             # 🟡 OPTIONAL (default: true)
API_LOG_TRUNCATE_AT=1000                               # 🟡 OPTIONAL (default: 1000)
API_LOG_STRINGIFY=false                                # 🟡 OPTIONAL (default: false)

# =============================================================================
# 🔗 CORS CONFIGURATION (API-specific)
# =============================================================================
API_CORS_ORIGINS=http://localhost:3000,http://localhost:4321,http://localhost:5173,http://localhost:4173  # 🟡 OPTIONAL
API_CORS_ALLOW_CREDENTIALS=true                        # 🟡 OPTIONAL (default: true)
API_CORS_MAX_AGE=86400                                 # 🟡 OPTIONAL (default: 86400)
API_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS   # 🟡 OPTIONAL
API_CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With,x-actor-id,x-user-id  # 🟡 OPTIONAL
API_CORS_EXPOSE_HEADERS=Content-Length,X-Request-ID    # 🟡 OPTIONAL

# =============================================================================
# 💾 CACHE CONFIGURATION (API-specific)
# =============================================================================
API_CACHE_ENABLED=false                                # 🟡 OPTIONAL (default: true, disabled for dev)
API_CACHE_DEFAULT_MAX_AGE=300                          # 🟡 OPTIONAL (default: 300)
API_CACHE_DEFAULT_STALE_WHILE_REVALIDATE=60            # 🟡 OPTIONAL (default: 60)
API_CACHE_DEFAULT_STALE_IF_ERROR=86400                 # 🟡 OPTIONAL (default: 86400)
API_CACHE_PUBLIC_ENDPOINTS=/api/v1/public/accommodations,/health  # 🟡 OPTIONAL
API_CACHE_PRIVATE_ENDPOINTS=/api/v1/public/users       # 🟡 OPTIONAL
API_CACHE_NO_CACHE_ENDPOINTS=/health/db,/docs          # 🟡 OPTIONAL
API_CACHE_ETAG_ENABLED=true                            # 🟡 OPTIONAL (default: true)
API_CACHE_LAST_MODIFIED_ENABLED=true                   # 🟡 OPTIONAL (default: true)

# =============================================================================
# 🗜️ COMPRESSION CONFIGURATION (API-specific)
# =============================================================================
API_COMPRESSION_ENABLED=true                           # 🟡 OPTIONAL (default: true)
API_COMPRESSION_LEVEL=6                                # 🟡 OPTIONAL (default: 6, range: 1-9)
API_COMPRESSION_THRESHOLD=1024                         # 🟡 OPTIONAL (default: 1024 bytes)
API_COMPRESSION_CHUNK_SIZE=16384                       # 🟡 OPTIONAL (default: 16KB)
API_COMPRESSION_FILTER=text/*,application/json,application/xml,application/javascript  # 🟡 OPTIONAL
API_COMPRESSION_EXCLUDE_ENDPOINTS=/health/db,/docs     # 🟡 OPTIONAL
API_COMPRESSION_ALGORITHMS=gzip,deflate                # 🟡 OPTIONAL

# =============================================================================
# 🚦 RATE LIMITING CONFIGURATION (API-specific)
# =============================================================================
# General Rate Limiting
API_RATE_LIMIT_ENABLED=true                            # 🟡 OPTIONAL (default: true)
API_RATE_LIMIT_WINDOW_MS=900000                        # 🟡 OPTIONAL (default: 15 minutes)
API_RATE_LIMIT_MAX_REQUESTS=100                        # 🟡 OPTIONAL (default: 100)
API_RATE_LIMIT_KEY_GENERATOR=ip                        # 🟡 OPTIONAL (default: ip, options: ip, user, custom)
API_RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false          # 🟡 OPTIONAL (default: false)
API_RATE_LIMIT_SKIP_FAILED_REQUESTS=false              # 🟡 OPTIONAL (default: false)
API_RATE_LIMIT_STANDARD_HEADERS=true                   # 🟡 OPTIONAL (default: true)
API_RATE_LIMIT_LEGACY_HEADERS=false                    # 🟡 OPTIONAL (default: false)
API_RATE_LIMIT_MESSAGE=Too many requests, please try again later.  # 🟡 OPTIONAL

# Auth Endpoints Rate Limiting (more permissive)
API_RATE_LIMIT_AUTH_ENABLED=true                       # 🟡 OPTIONAL (default: true)
API_RATE_LIMIT_AUTH_WINDOW_MS=300000                   # 🟡 OPTIONAL (default: 5 minutes)
API_RATE_LIMIT_AUTH_MAX_REQUESTS=50                    # 🟡 OPTIONAL (default: 50)
API_RATE_LIMIT_AUTH_MESSAGE=Too many authentication requests, please try again later.  # 🟡 OPTIONAL

# Public API Rate Limiting (more restrictive)
API_RATE_LIMIT_PUBLIC_ENABLED=true                     # 🟡 OPTIONAL (default: true)
API_RATE_LIMIT_PUBLIC_WINDOW_MS=3600000                # 🟡 OPTIONAL (default: 1 hour)
API_RATE_LIMIT_PUBLIC_MAX_REQUESTS=1000                # 🟡 OPTIONAL (default: 1000)
API_RATE_LIMIT_PUBLIC_MESSAGE=Too many API requests, please try again later.  # 🟡 OPTIONAL

# Admin Endpoints Rate Limiting (most restrictive)
API_RATE_LIMIT_ADMIN_ENABLED=true                      # 🟡 OPTIONAL (default: true)
API_RATE_LIMIT_ADMIN_WINDOW_MS=600000                  # 🟡 OPTIONAL (default: 10 minutes)
API_RATE_LIMIT_ADMIN_MAX_REQUESTS=200                  # 🟡 OPTIONAL (default: 200)
API_RATE_LIMIT_ADMIN_MESSAGE=Too many admin requests, please try again later.  # 🟡 OPTIONAL

# =============================================================================
# 🔒 SECURITY CONFIGURATION (API-specific)
# =============================================================================
API_SECURITY_ENABLED=true                              # 🟡 OPTIONAL (default: true)
API_SECURITY_CSRF_ENABLED=true                         # 🟡 OPTIONAL (default: true)
API_SECURITY_CSRF_ORIGIN=                              # 🟡 OPTIONAL (URL)
API_SECURITY_CSRF_ORIGINS=http://localhost:3000,http://localhost:5173  # 🟡 OPTIONAL
API_SECURITY_HEADERS_ENABLED=true                      # 🟡 OPTIONAL (default: true)
API_SECURITY_CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';  # 🟡 OPTIONAL
API_SECURITY_STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains  # 🟡 OPTIONAL
API_SECURITY_X_FRAME_OPTIONS=SAMEORIGIN                # 🟡 OPTIONAL (options: DENY, SAMEORIGIN, ALLOW-FROM)
API_SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff            # 🟡 OPTIONAL
API_SECURITY_X_XSS_PROTECTION=1; mode=block            # 🟡 OPTIONAL
API_SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin  # 🟡 OPTIONAL
API_SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()  # 🟡 OPTIONAL

# =============================================================================
# 📤 RESPONSE CONFIGURATION (API-specific)
# =============================================================================
API_RESPONSE_FORMAT_ENABLED=true                       # 🟡 OPTIONAL (default: true)
API_RESPONSE_INCLUDE_TIMESTAMP=true                    # 🟡 OPTIONAL (default: true)
API_RESPONSE_INCLUDE_VERSION=true                      # 🟡 OPTIONAL (default: true)
API_RESPONSE_API_VERSION=1.0.0                         # 🟡 OPTIONAL (default: 1.0.0)
API_RESPONSE_INCLUDE_REQUEST_ID=true                   # 🟡 OPTIONAL (default: true)
API_RESPONSE_INCLUDE_METADATA=true                     # 🟡 OPTIONAL (default: true)
API_RESPONSE_SUCCESS_MESSAGE=Success                   # 🟡 OPTIONAL (default: Success)
API_RESPONSE_ERROR_MESSAGE=An error occurred           # 🟡 OPTIONAL (default: An error occurred)

# =============================================================================
# ✅ VALIDATION CONFIGURATION (API-specific)
# =============================================================================
API_VALIDATION_MAX_BODY_SIZE=10485760                  # 🟡 OPTIONAL (default: 10MB in bytes)
API_VALIDATION_MAX_REQUEST_TIME=30000                  # 🟡 OPTIONAL (default: 30 seconds)
API_VALIDATION_ALLOWED_CONTENT_TYPES=application/json,multipart/form-data  # 🟡 OPTIONAL
API_VALIDATION_REQUIRED_HEADERS=user-agent             # 🟡 OPTIONAL
API_VALIDATION_CLERK_AUTH_ENABLED=true                 # 🟡 OPTIONAL (default: true)
API_VALIDATION_CLERK_AUTH_HEADERS=authorization        # 🟡 OPTIONAL
API_VALIDATION_SANITIZE_ENABLED=true                   # 🟡 OPTIONAL (default: true)
API_VALIDATION_SANITIZE_MAX_STRING_LENGTH=1000         # 🟡 OPTIONAL (default: 1000)
API_VALIDATION_SANITIZE_REMOVE_HTML_TAGS=true          # 🟡 OPTIONAL (default: true)
API_VALIDATION_SANITIZE_ALLOWED_CHARS=[\\w\\s\\-.,!?@#$%&*()+=]  # 🟡 OPTIONAL

# =============================================================================
# 📊 METRICS CONFIGURATION (API-specific)
# =============================================================================
API_METRICS_ENABLED=true                               # 🟡 OPTIONAL (default: true)
API_METRICS_SLOW_REQUEST_THRESHOLD_MS=1000             # 🟡 OPTIONAL (default: 1000ms)
API_METRICS_SLOW_AUTH_THRESHOLD_MS=2000                # 🟡 OPTIONAL (default: 2000ms)

# =============================================================================
# 🔴 REDIS CONFIGURATION (Optional - Shared)
# =============================================================================
HOSPEDA_REDIS_URL=redis://localhost:6379               # 🟡 OPTIONAL - Redis connection URL

# =============================================================================
# 🔧 TODO-LINEAR INTEGRATION (Package-specific)
# =============================================================================
LINEAR_API_KEY=lin_api_your_key_here              # 🟡 OPTIONAL - Linear API key
LINEAR_TEAM_ID=your-team-id-here                  # 🟡 OPTIONAL - Linear team ID
TODO_LINEAR_DEFAULT_USER_EMAIL=your-email@example.com  # 🟡 OPTIONAL - Default user email
TODO_LINEAR_DEFAULT_USER_NAME=your-name                # 🟡 OPTIONAL - Default user name

# =============================================================================
# 🧪 TESTING CONFIGURATION
# =============================================================================
TESTING_RATE_LIMIT=false                               # 🟡 OPTIONAL - Enable rate limiting in tests
DEBUG_TESTS=false                                      # 🟡 OPTIONAL - Enable debug logging in tests
COMMIT_SHA=unknown                                     # 🟡 OPTIONAL - Git commit SHA for version info