# Docker Compose Configuration
# Copy this file to .env and adjust values for your project

# Project name (used for container names and volumes)
COMPOSE_PROJECT_NAME=hospeda

# PostgreSQL
POSTGRES_PORT=5436
POSTGRES_USER=hospeda_user
POSTGRES_PASSWORD=hospeda_pass
POSTGRES_DB=hospeda_dev

# Redis
REDIS_PORT=6381

# pgAdmin
PGADMIN_PORT=8081
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin123
