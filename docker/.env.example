# =============================================================================
# Docker Compose Configuration
# =============================================================================
#
# Copy this file to docker/.env and adjust the values for your local setup.
#
#   cp docker/.env.example docker/.env
#
# These variables configure the services defined in docker-compose.yml.
# They are NOT the same as the app-level HOSPEDA_DATABASE_URL — they control
# the Docker container itself. The app connection string must match these values.
#
# Required vars are uncommented with placeholder values.
# Optional vars are commented out; uncomment to override the defaults.
# =============================================================================

# =============================================================================
# PostgreSQL
# =============================================================================

# PostgreSQL superuser name created on first boot.
POSTGRES_USER=hospeda

# PostgreSQL superuser password.
POSTGRES_PASSWORD=hospeda

# Name of the default database created on first boot.
POSTGRES_DB=hospeda

# Host-side port mapped to the PostgreSQL container (default: 5432).
# Change this if port 5432 is already in use on your machine.
# POSTGRES_PORT=5432

# =============================================================================
# Redis
# =============================================================================

# Host-side port mapped to the Redis container (default: 6379).
# Change this if port 6379 is already in use on your machine.
# REDIS_PORT=6379
