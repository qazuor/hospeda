# Dependencies (always re-installed inside the build)
node_modules
**/node_modules

# Build outputs (re-built inside Docker, never trust host artefacts)
**/dist
**/.output
**/.nitro
**/.turbo
**/.next
**/.astro
**/.vercel
build/

# Coverage and test runner state
**/coverage
.nyc_output/

# Environment files (secrets stay outside the image)
**/.env
**/.env.local
**/.env.*

# VCS and tooling metadata
.git
.github
.husky
.vscode
.idea
.cursorignore
.editorconfig
.gitignore
.markdownlint-cli2.jsonc
.huskyrc
# NOTE: do NOT exclude .npmrc or patches/ — pnpm install --frozen-lockfile
# inside the deps stage needs both (lockfile references patched deps).

# Repo-only documentation and AI scaffolding
**/*.md
docs
.claude
.remember
mappings

# Re-include Astro content collections — these Markdown files are app data
# (source for pages served in production), not documentation. The blanket
# `**/*.md` rule above would otherwise strip them from the build context and
# silently produce 404s for `/beta/*` routes.
!apps/web/src/content/**/*.md

# Local logs and OS junk
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db
*.swp
*.swo

# Local Docker compose state (we ship per-app Dockerfiles to Coolify)
docker-compose.yml
docker/
