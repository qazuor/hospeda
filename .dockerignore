# Dependencies (always re-installed inside the build)
node_modules
**/node_modules

# Build outputs (re-built inside Docker, never trust host artefacts)
**/dist
**/.output
**/.nitro
**/.turbo
**/.next
**/.astro
**/.vercel
build/

# Coverage and test runner state
**/coverage
.nyc_output/

# Environment files (secrets stay outside the image)
**/.env
**/.env.local
**/.env.*

# VCS and tooling metadata
# NOTE: .git/ is intentionally NOT excluded. apps/web/Dockerfile and
# apps/admin/Dockerfile read .git/HEAD inside the build to bake the
# deploy SHA into the Sentry release tag. Two prior attempts to exclude
# the directory while whitelisting just .git/HEAD failed in Coolify's
# BuildKit version (both `.git` + `!.git/HEAD` and `.git/**` + `!.git/HEAD`
# were silently dropped — BuildKit short-circuits the directory walk
# once any exclusion is matched and the negation never runs).
# Cost of shipping the full .git: Coolify clones with `--depth=1`, so the
# directory is small (~MB range). Worth it for hosting-agnostic release
# tagging that works without depending on Coolify variable expansion.
# Only exclude .git/objects/info (build cache hint files that change
# between clones for no real reason — keeps cache stable).
.git/objects/info
.github
.husky
.vscode
.idea
.cursorignore
.editorconfig
.gitignore
.markdownlint-cli2.jsonc
.huskyrc
# NOTE: do NOT exclude .npmrc or patches/ — pnpm install --frozen-lockfile
# inside the deps stage needs both (lockfile references patched deps).

# Repo-only documentation and AI scaffolding
**/*.md
docs
.claude
.remember
mappings

# Re-include Astro content collections — these Markdown files are app data
# (source for pages served in production), not documentation. The blanket
# `**/*.md` rule above would otherwise strip them from the build context and
# silently produce 404s for `/beta/*` routes.
!apps/web/src/content/**/*.md

# Local logs and OS junk
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db
*.swp
*.swo

# Local Docker compose state (we ship per-app Dockerfiles to Coolify)
docker-compose.yml
docker/
