{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "globalDependencies": ["**/.env.*local"],
    "globalEnv": [
        "NODE_ENV",
        "CI",
        "VERCEL_GIT_COMMIT_SHA",
        "HOSPEDA_API_URL",
        "HOSPEDA_SITE_URL",
        "HOSPEDA_ADMIN_URL",
        "VITE_API_URL",
        "VITE_SITE_URL",
        "VITE_BETTER_AUTH_URL",
        "VITE_APP_NAME",
        "VITE_APP_VERSION",
        "VITE_APP_DESCRIPTION",
        "VITE_ENABLE_LOGGING",
        "VITE_SENTRY_DSN",
        "VITE_SENTRY_RELEASE",
        "PUBLIC_API_URL",
        "PUBLIC_SITE_URL",
        "PUBLIC_ENABLE_LOGGING",
        "PUBLIC_VERSION",
        "PUBLIC_SENTRY_DSN",
        "PUBLIC_SENTRY_RELEASE",
        "HOSPEDA_REDIS_URL",
        "HOSPEDA_CRON_SECRET"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**"]
        },
        "admin#build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".output/**", ".tanstack/**", ".vercel/output/**"]
        },
        "lint": {
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "clean": {
            "cache": false
        },
        "typecheck": {
            "dependsOn": ["^typecheck"]
        },
        "format": {
            "outputs": []
        },
        "test": {
            "dependsOn": ["build"],
            "outputs": [],
            "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx"]
        },
        "test:watch": {
            "cache": false,
            "persistent": true
        },
        "test:coverage": {
            "dependsOn": ["build"],
            "outputs": ["coverage/**"]
        }
    },
    "concurrency": "10"
}
