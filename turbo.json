{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "globalDependencies": ["**/.env.*local"],
    "globalEnv": [
        "NODE_ENV",
        "CI",
        "HOSPEDA_GIT_SHA",
        "HOSPEDA_API_URL",
        "HOSPEDA_SITE_URL",
        "HOSPEDA_ADMIN_URL",
        "HOSPEDA_REVALIDATION_SECRET",
        "VITE_API_URL",
        "VITE_SITE_URL",
        "VITE_ADMIN_URL",
        "VITE_BETTER_AUTH_URL",
        "VITE_APP_NAME",
        "VITE_APP_VERSION",
        "VITE_APP_DESCRIPTION",
        "VITE_ENABLE_LOGGING",
        "VITE_SENTRY_DSN",
        "VITE_SENTRY_RELEASE",
        "PUBLIC_API_URL",
        "PUBLIC_SITE_URL",
        "PUBLIC_ENABLE_LOGGING",
        "PUBLIC_VERSION",
        "PUBLIC_SENTRY_DSN",
        "PUBLIC_POSTHOG_KEY",
        "PUBLIC_SENTRY_RELEASE",
        "HOSPEDA_REDIS_URL",
        "HOSPEDA_CRON_SECRET",
        "HOSPEDA_CLOUDINARY_CLOUD_NAME",
        "HOSPEDA_CLOUDINARY_API_KEY",
        "HOSPEDA_CLOUDINARY_API_SECRET",
        "HOSPEDA_MEDIA_MAX_FILE_SIZE_MB",
        "ALLOW_PLACEHOLDER_ENV_URLS"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**", ".astro/**"]
        },
        "admin#build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".output/**", ".tanstack/**", "src/routeTree.gen.ts"]
        },
        "lint": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "clean": {
            "cache": false
        },
        "typecheck": {
            "dependsOn": ["^build"]
        },
        "format": {
            "outputs": []
        },
        "test": {
            "dependsOn": ["build"],
            "outputs": [],
            "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx"],
            "env": ["VITEST_SHARD"]
        },
        "test:watch": {
            "cache": false,
            "persistent": true
        },
        "test:coverage": {
            "dependsOn": ["build"],
            "outputs": ["coverage/**"],
            "env": ["VITEST_SHARD"]
        },
        "test:integration": {
            "dependsOn": ["^build"],
            "cache": false,
            "env": ["HOSPEDA_TEST_DATABASE_URL"]
        }
    },
    "concurrency": "10"
}
